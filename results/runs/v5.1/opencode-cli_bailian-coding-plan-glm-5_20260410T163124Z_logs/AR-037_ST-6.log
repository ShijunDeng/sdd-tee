{"type":"tool_use","timestamp":1775894898606,"sessionID":"ses_2846b0c2affeHerQ03pZ9MkRHy","part":{"id":"prt_d7b95a460001svE3ZEXoU6AVGH","messageID":"msg_d7b95865f001Dstq1FfqVSf3yH","sessionID":"ses_2846b0c2affeHerQ03pZ9MkRHy","type":"tool","tool":"read","callID":"toolu_tool-4befa6eeffab43e1847cd028442f6428","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/example/pcap-analyzer/analyzer.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/example/pcap-analyzer/analyzer.py</path>\n<type>file</type>\n<content>\n1: import json\n2: import logging\n3: import time\n4: from abc import ABC, abstractmethod\n5: from dataclasses import dataclass, asdict\n6: from datetime import datetime\n7: from functools import wraps\n8: from pathlib import Path\n9: from typing import Optional, List, Dict, Any\n10: \n11: from agentcube import CodeInterpreterClient\n12: \n13: from .types import (\n14:     PacketSummary,\n15:     TCPStream,\n16:     HTTPTransaction,\n17:     DNSQuery,\n18:     AnalysisReport,\n19: )\n20: from .parsers import TCPParser, HTTPParser, DNSParser\n21: from .utils.file_utils import FileUtils\n22: from .utils.report_utils import ReportUtils\n23: from .exceptions import (\n24:     AnalyzerError,\n25:     ConnectionError,\n26:     PCAPParseError,\n27:     ToolNotAvailableError,\n28:     TimeoutError,\n29: )\n30: \n31: \n32: @dataclass\n33: class AnalyzerConfig:\n34:     router_url: Optional[str] = None\n35:     workload_manager_url: Optional[str] = None\n36:     namespace: str = \"default\"\n37:     session_name: str = \"pcap-analyzer\"\n38:     ttl: int = 3600\n39:     timeout: int = 120\n40:     verbose: bool = False\n41:     output_format: str = \"json\"\n42: \n43: \n44: def timed_operation(operation_name: str):\n45:     \"\"\"Decorator for timing operations.\"\"\"\n46:     def decorator(func):\n47:         @wraps(func)\n48:         def wrapper(*args, **kwargs):\n49:             start = time.time()\n50:             try:\n51:                 result = func(*args, **kwargs)\n52:                 duration = time.time() - start\n53:                 logging.info(f\"{operation_name} completed in {duration:.2f}s\")\n54:                 return result\n55:             except Exception as e:\n56:                 duration = time.time() - start\n57:                 logging.error(f\"{operation_name} failed after {duration:.2f}s: {e}\")\n58:                 raise\n59:         return wrapper\n60:     return decorator\n61: \n62: \n63: class PCAPAnalyzerInterface(ABC):\n64:     \"\"\"Abstract interface for PCAP analyzer.\"\"\"\n65: \n66:     @abstractmethod\n67:     def load_pcap(self, file_path: Path) -> None:\n68:         pass\n69: \n70:     @abstractmethod\n71:     def get_packet_summary(self) -> List[PacketSummary]:\n72:         pass\n73: \n74:     @abstractmethod\n75:     def get_tcp_streams(self) -> List[TCPStream]:\n76:         pass\n77: \n78:     @abstractmethod\n79:     def get_http_transactions(self) -> List[HTTPTransaction]:\n80:         pass\n81: \n82:     @abstractmethod\n83:     def get_dns_queries(self) -> List[DNSQuery]:\n84:         pass\n85: \n86:     @abstractmethod\n87:     def generate_report(self, output_format: str = \"json\") -> str:\n88:         pass\n89: \n90: \n91: class PCAPAnalyzer(PCAPAnalyzerInterface):\n92:     \"\"\"PCAP analyzer using AgentCube SDK for sandbox execution.\"\"\"\n93: \n94:     def __init__(self, config: AnalyzerConfig):\n95:         self.config = config\n96:         self._client: Optional[CodeInterpreterClient] = None\n97:         self._pcap_remote_path: Optional[str] = None\n98:         self._pcap_file: Optional[str] = None\n99:         self._packet_summary: Optional[List[PacketSummary]] = None\n100:         self._tcp_streams: Optional[List[TCPStream]] = None\n101:         self._http_transactions: Optional[List[HTTPTransaction]] = None\n102:         self._dns_queries: Optional[List[DNSQuery]] = None\n103:         self._protocol_stats: Optional[Dict[str, int]] = None\n104: \n105:         self._tcp_parser = TCPParser()\n106:         self._http_parser = HTTPParser()\n107:         self._dns_parser = DNSParser()\n108: \n109:         self._logger = logging.getLogger(__name__)\n110:         if config.verbose:\n111:             logging.basicConfig(level=logging.DEBUG)\n112: \n113:     def __enter__(self) -> \"PCAPAnalyzer\":\n114:         self.connect()\n115:         return self\n116: \n117:     def __exit__(self, exc_type, exc_val, exc_tb) -> None:\n118:         self.disconnect()\n119: \n120:     @timed_operation(\"connect\")\n121:     def connect(self) -> None:\n122:         \"\"\"Connect to AgentCube sandbox.\"\"\"\n123:         try:\n124:             self._client = CodeInterpreterClient(\n125:                 name=self.config.session_name,\n126:                 namespace=self.config.namespace,\n127:                 ttl=self.config.ttl,\n128:                 router_url=self.config.router_url,\n129:                 workload_manager_url=self.config.workload_manager_url,\n130:                 verbose=self.config.verbose,\n131:             )\n132:         except Exception as e:\n133:             raise ConnectionError(str(e), e)\n134: \n135:     def disconnect(self) -> None:\n136:         \"\"\"Disconnect from AgentCube sandbox.\"\"\"\n137:         if self._client:\n138:             try:\n139:                 self._client.stop()\n140:             except Exception:\n141:                 pass\n142:             self._client = None\n143: \n144:     @timed_operation(\"load_pcap\")\n145:     def load_pcap(self, file_path: Path) -> None:\n146:         \"\"\"Load a PCAP file into the sandbox.\n147: \n148:         Args:\n149:             file_path: Path to local PCAP file\n150: \n151:         Raises:\n152:             RuntimeError: If not connected\n153:             AnalyzerError: If file is invalid\n154:         \"\"\"\n155:         if not self._client:\n156:             raise RuntimeError(\"Not connected to sandbox\")\n157: \n158:         validation = FileUtils.validate_pcap_file(file_path)\n159:         self._logger.info(f\"Loading PCAP: {validation}\")\n160: \n161:         remote_path = FileUtils.get_remote_path(file_path)\n162:         self._client.upload_file(str(file_path), remote_path)\n163:         self._pcap_remote_path = remote_path\n164:         self._pcap_file = str(file_path)\n165: \n166:         self._check_tools_available()\n167: \n168:     def _check_tools_available(self) -> None:\n169:         \"\"\"Check required tools are available in sandbox.\"\"\"\n170:         tools = [\"tshark\", \"python3\"]\n171:         for tool in tools:\n172:             try:\n173:                 result = self._client.execute_command(f\"{tool} --version\", timeout=10)\n174:                 self._logger.debug(f\"{tool} available: {result[:50]}\")\n175:             except Exception as e:\n176:                 raise ToolNotAvailableError(tool)\n177: \n178:     @timed_operation(\"get_packet_summary\")\n179:     def get_packet_summary(self) -> List[PacketSummary]:\n180:         \"\"\"Get summary of all packets in PCAP file.\n181: \n182:         Returns:\n183:             List of PacketSummary objects\n184: \n185:         Raises:\n186:             RuntimeError: If PCAP not loaded\n187:             TimeoutError: If operation times out\n188:         \"\"\"\n189:         if not self._client or not self._pcap_remote_path:\n190:             raise RuntimeError(\"PCAP file not loaded\")\n191: \n192:         if self._packet_summary is not None:\n193:             return self._packet_summary\n194: \n195:         script = '''\n196: import json\n197: import sys\n198: \n199: try:\n200:     from scapy.all import rdpcap, IP, TCP, UDP\n201:     packets = rdpcap(\"{pcap_path}\")\n202:     summary = []\n203:     for pkt in packets:\n204:         if hasattr(pkt, 'IP'):\n205:             entry = {\n206:                 \"timestamp\": float(pkt.time),\n207:                 \"source_ip\": pkt.IP.src,\n208:                 \"dest_ip\": pkt.IP.dst,\n209:                 \"protocol\": pkt.IP.proto,\n210:                 \"length\": len(pkt)\n211:             }\n212:             if hasattr(pkt, 'TCP'):\n213:                 entry[\"source_port\"] = int(pkt.TCP.sport)\n214:                 entry[\"dest_port\"] = int(pkt.TCP.dport)\n215:                 entry[\"protocol_name\"] = \"TCP\"\n216:                 entry[\"flags\"] = str(pkt.TCP.flags)\n217:             elif hasattr(pkt, 'UDP'):\n218:                 entry[\"source_port\"] = int(pkt.UDP.sport)\n219:                 entry[\"dest_port\"] = int(pkt.UDP.dport)\n220:                 entry[\"protocol_name\"] = \"UDP\"\n221:             else:\n222:                 entry[\"source_port\"] = 0\n223:                 entry[\"dest_port\"] = 0\n224:                 entry[\"protocol_name\"] = \"Other\"\n225:             summary.append(entry)\n226:     print(json.dumps(summary))\n227: except Exception as e:\n228:     print(json.dumps({\"error\": str(e)}))\n229:     sys.exit(1)\n230: '''\n231:         try:\n232:             result = self._client.run_code(\n233:                 \"python\",\n234:                 script.format(pcap_path=self._pcap_remote_path),\n235:                 timeout=self.config.timeout\n236:             )\n237:             data = json.loads(result)\n238:             if \"error\" in data:\n239:                 raise PCAPParseError(self._pcap_file or \"\", data[\"error\"])\n240: \n241:             self._packet_summary = self._parse_summary(data)\n242:             return self._packet_summary\n243:         except Exception as e:\n244:             if \"timeout\" in str(e).lower():\n245:                 raise TimeoutError(\"get_packet_summary\", self.config.timeout)\n246:             raise\n247: \n248:     def _parse_summary(self, data: List[Dict]) -> List[PacketSummary]:\n249:         \"\"\"Parse packet summary JSON into PacketSummary objects.\"\"\"\n250:         summaries = []\n251:         for entry in data:\n252:             try:\n253:                 protocol_map = {1: \"ICMP\", 6: \"TCP\", 17: \"UDP\"}\n254:                 proto_num = entry.get(\"protocol\", 0)\n255:                 proto_name = entry.get(\"protocol_name\", protocol_map.get(proto_num, \"Other\"))\n256: \n257:                 summary = PacketSummary(\n258:                     timestamp=datetime.fromtimestamp(entry[\"timestamp\"]),\n259:                     source_ip=entry[\"source_ip\"],\n260:                     source_port=entry.get(\"source_port\", 0),\n261:                     dest_ip=entry[\"dest_ip\"],\n262:                     dest_port=entry.get(\"dest_port\", 0),\n263:                     protocol=proto_name,\n264:                     length=entry[\"length\"],\n265:                     flags=entry.get(\"flags\"),\n266:                 )\n267:                 summaries.append(summary)\n268:             except (KeyError, ValueError) as e:\n269:                 self._logger.warning(f\"Skipping invalid packet entry: {entry}\")\n270:         return summaries\n271: \n272:     @timed_operation(\"get_tcp_streams\")\n273:     def get_tcp_streams(self) -> List[TCPStream]:\n274:         \"\"\"Get TCP stream/conversation data.\n275: \n276:         Returns:\n277:             List of TCPStream objects\n278:         \"\"\"\n279:         if not self._client or not self._pcap_remote_path:\n280:             raise RuntimeError(\"PCAP file not loaded\")\n281: \n282:         if self._tcp_streams is not None:\n283:             return self._tcp_streams\n284: \n285:         try:\n286:             result = self._client.execute_command(\n287:                 f\"tshark -r {self._pcap_remote_path} -z conv,tcp\",\n288:                 timeout=self.config.timeout\n289:             )\n290:             self._tcp_streams = self._tcp_parser.parse_conversations(\n291:                 result, self._pcap_file or \"\"\n292:             )\n293:             return self._tcp_streams\n294:         except Exception as e:\n295:             if \"timeout\" in str(e).lower():\n296:                 raise TimeoutError(\"get_tcp_streams\", self.config.timeout)\n297:             raise\n298: \n299:     @timed_operation(\"get_http_transactions\")\n300:     def get_http_transactions(self) -> List[HTTPTransaction]:\n301:         \"\"\"Get HTTP transaction data.\n302: \n303:         Returns:\n304:             List of HTTPTransaction objects\n305:         \"\"\"\n306:         if not self._client or not self._pcap_remote_path:\n307:             raise RuntimeError(\"PCAP file not loaded\")\n308: \n309:         if self._http_transactions is not None:\n310:             return self._http_transactions\n311: \n312:         try:\n313:             result = self._client.execute_command(\n314:                 f\"tshark -r {self._pcap_remote_path} -Y http -T fields \"\n315:                 \"-e frame.time_epoch -e http.request.method -e http.host \"\n316:                 \"-e http.request.uri -e http.response.code\",\n317:                 timeout=self.config.timeout\n318:             )\n319:             self._http_transactions = self._http_parser.parse_http_fields(\n320:                 result, self._pcap_file or \"\"\n321:             )\n322:             return self._http_transactions\n323:         except Exception as e:\n324:             if \"timeout\" in str(e).lower():\n325:                 raise TimeoutError(\"get_http_transactions\", self.config.timeout)\n326:             raise\n327: \n328:     @timed_operation(\"get_dns_queries\")\n329:     def get_dns_queries(self) -> List[DNSQuery]:\n330:         \"\"\"Get DNS query data.\n331: \n332:         Returns:\n333:             List of DNSQuery objects\n334:         \"\"\"\n335:         if not self._client or not self._pcap_remote_path:\n336:             raise RuntimeError(\"PCAP file not loaded\")\n337: \n338:         if self._dns_queries is not None:\n339:             return self._dns_queries\n340: \n341:         try:\n342:             result = self._client.execute_command(\n343:                 f\"tshark -r {self._pcap_remote_path} -Y dns -T fields \"\n344:                 \"-e frame.time_epoch -e dns.qry.name -e dns.qry.type \"\n345:                 \"-e dns.a -e dns.aaaa\",\n346:                 timeout=self.config.timeout\n347:             )\n348:             self._dns_queries = self._dns_parser.parse_dns_fields(\n349:                 result, self._pcap_file or \"\"\n350:             )\n351:             return self._dns_queries\n352:         except Exception as e:\n353:             if \"timeout\" in str(e).lower():\n354:                 raise TimeoutError(\"get_dns_queries\", self.config.timeout)\n355:             raise\n356: \n357:     def _get_protocol_stats(self) -> Dict[str, int]:\n358:         \"\"\"Get protocol distribution statistics.\"\"\"\n359:         if self._protocol_stats is not None:\n360:             return self._protocol_stats\n361: \n362:         packets = self.get_packet_summary()\n363:         self._protocol_stats = {}\n364:         for pkt in packets:\n365:             self._protocol_stats[pkt.protocol] = self._protocol_stats.get(pkt.protocol, 0) + 1\n366:         return self._protocol_stats\n367: \n368:     def _get_top_sources(self, limit: int = 10) -> List[Dict[str, Any]]:\n369:         \"\"\"Get top source IPs by packet count.\"\"\"\n370:         packets = self.get_packet_summary()\n371:         sources: Dict[str, int] = {}\n372:         for pkt in packets:\n373:             sources[pkt.source_ip] = sources.get(pkt.source_ip, 0) + 1\n374:         sorted_sources = sorted(sources.items(), key=lambda x: x[1], reverse=True)[:limit]\n375:         return [{\"ip\": ip, \"count\": count} for ip, count in sorted_sources]\n376: \n377:     def _get_top_destinations(self, limit: int = 10) -> List[Dict[str, Any]]:\n378:         \"\"\"Get top destination IPs by packet count.\"\"\"\n379:         packets = self.get_packet_summary()\n380:         destinations: Dict[str, int] = {}\n381:         for pkt in packets:\n382:             destinations[pkt.dest_ip] = destinations.get(pkt.dest_ip, 0) + 1\n383:         sorted_dests = sorted(destinations.items(), key=lambda x: x[1], reverse=True)[:limit]\n384:         return [{\"ip\": ip, \"count\": count} for ip, count in sorted_dests]\n385: \n386:     def _detect_anomalies(self) -> List[Dict[str, Any]]:\n387:         \"\"\"Detect network anomalies in the traffic.\"\"\"\n388:         anomalies = []\n389: \n390:         packets = self.get_packet_summary()\n391: \n392:         tcp_retransmits = sum(1 for pkt in packets if pkt.protocol == \"TCP\" and pkt.flags and \"R\" in pkt.flags)\n393:         if len(packets) > 0 and tcp_retransmits > len(packets) * 0.05:\n394:             anomalies.append({\n395:                 \"type\": \"High Retransmission Rate\",\n396:                 \"description\": f\"{tcp_retransmits} TCP retransmits detected ({tcp_retransmits/len(packets)*100:.1f}%)\",\n397:                 \"severity\": \"medium\",\n398:             })\n399: \n400:         dns_queries = self.get_dns_queries()\n401:         failed_dns = sum(1 for q in dns_queries if q.response_ip is None)\n402:         if failed_dns > len(dns_queries) * 0.2:\n403:             anomalies.append({\n404:                 \"type\": \"High DNS Failure Rate\",\n405:                 \"description\": f\"{failed_dns} DNS queries failed ({failed_dns/len(dns_queries)*100:.1f}%)\",\n406:                 \"severity\": \"medium\",\n407:             })\n408: \n409:         sources = self._get_top_sources(limit=1)\n410:         if sources and sources[0][\"count\"] > len(packets) * 0.8:\n411:             anomalies.append({\n412:                 \"type\": \"Dominant Source IP\",\n413:                 \"description\": f\"{sources[0]['ip']} sends {sources[0]['count']} packets ({sources[0]['count']/len(packets)*100:.1f}%)\",\n414:                 \"severity\": \"low\",\n415:             })\n416: \n417:         return anomalies\n418: \n419:     @timed_operation(\"generate_report\")\n420:     def generate_report(self, output_format: str = \"json\") -> str:\n421:         \"\"\"Generate analysis report.\n422: \n423:         Args:\n424:             output_format: Output format (json, html, text)\n425: \n426:         Returns:\n427:             Report content string\n428:         \"\"\"\n429:         report = AnalysisReport(\n430:             pcap_file=self._pcap_file or \"\",\n431:             analysis_time=datetime.now(),\n432:             total_packets=len(self.get_packet_summary()),\n433:             protocols=self._get_protocol_stats(),\n434:             tcp_streams=self.get_tcp_streams(),\n435:             http_transactions=self.get_http_transactions(),\n436:             dns_queries=self.get_dns_queries(),\n437:             top_sources=self._get_top_sources(),\n438:             top_destinations=self._get_top_destinations(),\n439:             anomalies=self._detect_anomalies(),\n440:         )\n441: \n442:         if output_format == \"json\":\n443:             return ReportUtils.generate_json_report(report)\n444:         elif output_format == \"html\":\n445:             return ReportUtils.generate_html_report(report)\n446:         elif output_format == \"text\":\n447:             return ReportUtils.generate_text_summary(report)\n448:         else:\n449:             raise ValueError(f\"Unsupported format: {output_format}\")\n450: \n451: \n452: def safe_analyze(analyzer: PCAPAnalyzer, pcap_file: Path) -> Optional[AnalysisReport]:\n453:     \"\"\"Safely analyze a PCAP file with proper error handling.\n454: \n455:     Args:\n456:         analyzer: PCAPAnalyzer instance\n457:         pcap_file: Path to PCAP file\n458: \n459:     Returns:\n460:         AnalysisReport if successful, None otherwise\n461:     \"\"\"\n462:     try:\n463:         analyzer.connect()\n464:         analyzer.load_pcap(pcap_file)\n465:         report_json = analyzer.generate_report()\n466:         return json.loads(report_json)\n467:     except ConnectionError as e:\n468:         logging.error(f\"Failed to connect to sandbox: {e}\")\n469:         return None\n470:     except PCAPParseError as e:\n471:         logging.error(f\"Invalid PCAP file: {e}\")\n472:         return None\n473:     except ToolNotAvailableError as e:\n474:         logging.error(f\"Sandbox missing tool: {e.tool_name}\")\n475:         logging.info(\"Ensure sandbox image includes tshark, tcpdump, scapy\")\n476:         return None\n477:     except TimeoutError as e:\n478:         logging.warning(f\"Analysis took too long, try larger timeout\")\n479:         return None\n480:     finally:\n481:         analyzer.disconnect()\n482: \n483: \n484: __all__ = [\"PCAPAnalyzer\", \"AnalyzerConfig\", \"PCAPAnalyzerInterface\", \"safe_analyze\", \"timed_operation\"]\n\n(End of file - total 484 lines)\n</content>","metadata":{"preview":"import json\nimport logging\nimport time\nfrom abc import ABC, abstractmethod\nfrom dataclasses import dataclass, asdict\nfrom datetime import datetime\nfrom functools import wraps\nfrom pathlib import Path\nfrom typing import Optional, List, Dict, Any\n\nfrom agentcube import CodeInterpreterClient\n\nfrom .types import (\n    PacketSummary,\n    TCPStream,\n    HTTPTransaction,\n    DNSQuery,\n    AnalysisReport,\n)\nfrom .parsers import TCPParser, HTTPParser, DNSParser","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/example/pcap-analyzer/analyzer.py","time":{"start":1775894898585,"end":1775894898604}}}}
