kind load docker-image \"${IMAGE_REPO}/picod:${VERSION}\" --name \"$E2E_CLUSTER_NAME\"\n36: \n37: echo \"Applying CRDs...\"\n38: kubectl apply -f \"${ROOT_DIR}/manifests/crds/\" || true\n39: \n40: echo \"Deploying AgentCube with Helm...\"\n41: helm upgrade --install agentcube \"${ROOT_DIR}/manifests/charts/base/\" \\\n42:     --set workloadmanager.image.repository=\"${IMAGE_REPO}/workloadmanager\" \\\n43:     --set workloadmanager.image.tag=\"${VERSION}\" \\\n44:     --set router.image.repository=\"${IMAGE_REPO}/router\" \\\n45:     --set router.image.tag=\"${VERSION}\" \\\n46:     --set picod.image.repository=\"${IMAGE_REPO}/picod\" \\\n47:     --set picod.image.tag=\"${VERSION}\" \\\n48:     --namespace default \\\n49:     --create-namespace \\\n50:     --wait || true\n51: \n52: echo \"Waiting for pods to be ready...\"\n53: kubectl wait --for=condition=ready pod -l app=workloadmanager --timeout=120s || true\n54: kubectl wait --for=condition=ready pod -l app=router --timeout=120s || true\n55: \n56: echo \"Port-forwarding services...\"\n57: kubectl port-forward svc/workloadmanager 8080:8080 &\n58: PORT_FORWARD_WM_PID=$!\n59: kubectl port-forward svc/router 8081:8080 &\n60: PORT_FORWARD_ROUTER_PID=$!\n61: \n62: sleep 5\n63: \n64: echo \"=== Running E2E Tests ===\"\n65: cd \"$ROOT_DIR\"\n66: go test -v ./test/e2e/... || TEST_RESULT=$?\n67: \n68: if [[ -n \"${TEST_RESULT:-}\" ]]; then\n69:     echo \"=== Collecting component logs on failure ===\"\n70:     kubectl logs -l app=workloadmanager --tail=100 > /tmp/e2e-workloadmanager.log || true\n71:     kubectl logs -l app=router --tail=100 > /tmp/e2e-router.log || true\n72:     kubectl logs -l app=picod --tail=100 > /tmp/e2e-picod.log || true\n73:     echo \"Logs saved to /tmp/e2e-*.log\"\n74: fi\n75: \n76: kill $PORT_FORWARD_WM_PID $PORT_FORWARD_ROUTER_PID || true\n77: \n78: echo \"=== E2E Tests Complete ===\"\n79: exit ${TEST_RESULT:-0}\n\n(End of file - total 79 lines)\n</content>","metadata":{"preview":"#!/bin/bash\nset -euo pipefail\n\nSCRIPT_DIR=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")\" && pwd)\"\nROOT_DIR=\"$(dirname \"$SCRIPT_DIR\")\"\n\nE2E_CLUSTER_NAME=\"${E2E_CLUSTER_NAME:-agentcube-e2e}\"\nIMAGE_REPO=\"${IMAGE_REPO:-ghcr.io/volcano-sh/agentcube}\"\nVERSION=\"${VERSION:-$(git describe --tags --always --dirty 2>/dev/null || echo 'latest')}\"\n\ncleanup() {\n    echo \"Cleaning up E2E test resources...\"\n    kind delete cluster --name \"$E2E_CLUSTER_NAME\" || true\n    rm -rf /tmp/agent-sandbox || true\n}\n\ntrap cleanup EXIT\n\necho \"=== E2E Test Setup ===\"\necho \"Cluster: $E2E_CLUSTER_NAME\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/test/e2e/run_e2e.sh","time":{"start":1775901796495,"end":1775901796523}}}}
