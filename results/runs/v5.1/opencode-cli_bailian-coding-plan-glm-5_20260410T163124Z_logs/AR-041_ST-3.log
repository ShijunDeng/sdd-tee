      engine,\n55: \t\tauthManager: authManager,\n56: \t\tworkspace:   workspace,\n57: \t\tstartTime:   time.Now(),\n58: \t\thttpServer: &http.Server{\n59: \t\t\tAddr:              fmt.Sprintf(\":%d\", config.Port),\n60: \t\t\tHandler:           engine,\n61: \t\t\tReadHeaderTimeout: readHeaderTimeout,\n62: \t\t},\n63: \t}\n64: \n65: \tengine.GET(\"/health\", s.HealthCheckHandler)\n66: \n67: \tapi := engine.Group(\"/api\")\n68: \tapi.Use(s.authManager.AuthMiddleware())\n69: \t{\n70: \t\tapi.POST(\"/execute\", s.ExecuteHandler)\n71: \t\tapi.POST(\"/files\", s.UploadFileHandler)\n72: \t\tapi.GET(\"/files\", s.ListFilesHandler)\n73: \t\tapi.GET(\"/files/*path\", s.DownloadFileHandler)\n74: \t}\n75: \n76: \treturn s, nil\n77: }\n78: \n79: func (s *Server) Run(ctx context.Context) error {\n80: \tklog.InfoS(\"PicoD started\", \"port\", s.config.Port, \"workspace\", s.workspace)\n81: \terr := s.httpServer.ListenAndServe()\n82: \tif err != nil && err != http.ErrServerClosed {\n83: \t\tklog.ErrorS(err, \"server error\")\n84: \t\treturn err\n85: \t}\n86: \treturn nil\n87: }\n88: \n89: func (s *Server) Shutdown(ctx context.Context) error {\n90: \treturn s.httpServer.Shutdown(ctx)\n91: }\n\n(End of file - total 91 lines)\n</content>","metadata":{"preview":"package picod\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"net/http\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"time\"\n\n\t\"github.com/gin-gonic/gin\"\n\t\"k8s.io/klog/v2\"\n)\n\nconst readHeaderTimeout = 10 * time.Second\n\ntype Server struct {\n\tconfig      *Config\n\tengine      *gin.Engine\n\thttpServer  *http.Server","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/picod/server.go","time":{"start":1775901827314,"end":1775901827331}}}}
