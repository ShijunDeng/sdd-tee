n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestTargetPortJSONTags(t *testing.T) {\n\ttp := TargetPort{\n\t\tPathPrefix: \"/api\",\n\t\tName:       \"api\",\n\t\tPort:       8080,\n\t\tProtocol:   ProtocolTypeHTTP,\n\t}\n\tdata, err := json.Marshal(tp)\n\tif err != nil {\n\t\tt.Errorf(\"failed to marshal TargetPort: %v\", err)\n\t}\n\texpected := `{\"pathPrefix\":\"/api\",\"name\":\"api\",\"port\":8080,\"protocol\":\"HTTP\"}`\n\tif string(data) != expected {\n\t\tt.Errorf(\"expected JSON '%s', got '%s'\", expected, string(data))\n\t}\n\tvar unmarshaled TargetPort\n\terr = json.Unmarshal(data, &unmarshaled)\n\tif err != nil {\n\t\tt.Errorf(\"failed to unmarshal TargetPort: %v\", err)\n\t}\n\tif unmarshaled.PathPrefix != tp.PathPrefix {\n\t\tt.Errorf(\"expected PathPrefix '%s', got '%s'\", tp.PathPrefix, unmarshaled.PathPrefix)\n\t}\n\tif unmarshaled.Port != tp.Port {\n\t\tt.Errorf(\"expected Port %d, got %d\", tp.Port, unmarshaled.Port)\n\t}\n}\n\nfunc TestGroupVersion(t *testing.T) {\n\tif GroupVersion.Group != \"runtime.agentcube.volcano.sh\" {\n\t\tt.Errorf(\"expected Group 'runtime.agentcube.volcano.sh', got '%s'\", GroupVersion.Group)\n\t}\n\tif GroupVersion.Version != \"v1alpha1\" {\n\t\tt.Errorf(\"expected Version 'v1alpha1', got '%s'\", GroupVersion.Version)\n\t}\n}\n\nfunc TestResourceHelper(t *testing.T) {\n\tgvr := Resource(\"agentruntimes\")\n\tif gvr.Group != \"runtime.agentcube.volcano.sh\" {\n\t\tt.Errorf(\"expected Group 'runtime.agentcube.volcano.sh', got '%s'\", gvr.Group)\n\t}\n\tif gvr.Resource != \"agentruntimes\" {\n\t\tt.Errorf(\"expected Resource 'agentruntimes', got '%s'\", gvr.Resource)\n\t}\n}\n\nfunc TestKindConstants(t *testing.T) {\n\tif AgentRuntimeKind != \"AgentRuntime\" {\n\t\tt.Errorf(\"expected AgentRuntimeKind 'AgentRuntime', got '%s'\", AgentRuntimeKind)\n\t}\n\tif AgentRuntimeListKind != \"AgentRuntimeList\" {\n\t\tt.Errorf(\"expected AgentRuntimeListKind 'AgentRuntimeList', got '%s'\", AgentRuntimeListKind)\n\t}\n\tif CodeInterpreterKind 