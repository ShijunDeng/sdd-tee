\n46: \tc.mu.RUnlock()\n47: \n48: \tc.mu.Lock()\n49: \tdefer c.mu.Unlock()\n50: \n51: \tif client, exists := c.clients[key]; exists {\n52: \t\treturn client, nil\n53: \t}\n54: \n55: \tuserConfig := rest.CopyConfig(config)\n56: \tuserConfig.BearerToken = token\n57: \n58: \tclient, err := dynamic.NewForConfig(userConfig)\n59: \tif err != nil {\n60: \t\treturn nil, fmt.Errorf(\"failed to create user dynamic client: %w\", err)\n61: \t}\n62: \n63: \tc.clients[key] = client\n64: \treturn client, nil\n65: }\n66: \n67: func NewK8sClient(config *rest.Config) (*K8sClient, error) {\n68: \tdynamicClient, err := dynamic.NewForConfig(config)\n69: \tif err != nil {\n70: \t\treturn nil, fmt.Errorf(\"failed to create dynamic client: %w\", err)\n71: \t}\n72: \n73: \tcoreClient, err := kubernetes.NewForConfig(config)\n74: \tif err != nil {\n75: \t\treturn nil, fmt.Errorf(\"failed to create core client: %w\", err)\n76: \t}\n77: \n78: \tinformerFactory := informers.NewSharedInformerFactoryWithOptions(\n79: \t\tcoreClient,\n80: \t\tInformerSyncTimeout,\n81: \t)\n82: \n83: \tpodInformer := informerFactory.Core().V1().Pods().Informer()\n84: \tpodLister := informerFactory.Core().V1().Pods().Lister()\n85: \n86: \tscheme := runtime.NewScheme()\n87: \tif err := corev1.AddToScheme(scheme); err != nil {\n88: \t\treturn nil, fmt.Errorf(\"failed to add corev1 to scheme: %w\", err)\n89: \t}\n90: \n91: \treturn &K8sClient{\n92: \t\tdynamicClient:   dynamicClient,\n93: \t\tcoreClient:      coreClient,\n94: \t\tinformerFactory: informerFactory,\n95: \t\tpodLister:       podLister,\n96: \t\tpodInformer:     podInformer,\n97: \t\tscheme:          scheme,\n98: \t}, nil\n99: }\n100: \n101: func (k *K8sClient) DynamicClient() dynamic.Interface {\n102: \treturn k.dynamicClient\n103: }\n104: \n105: func (k *K8sClient) CoreClient() kubernetes.Interface {\n106: \treturn k.coreClient\n107: }\n108: \n109: func (k *K8sClient) PodLister() corev1listers.PodLister {\n110: \treturn k.podLister\n111: }\n112: \n113: func (k *K8sClient) InformerFactory() informers.SharedInformerFactory {\n114: \treturn k.informerFactory\n115: }\n116: \n117: func (k *K8sClient) StartInformers(ctx context.Context) {\n118: \tk.informerFactory.Start(ctx.Done())\n119: }\n120: \n121: func (k *K8sClient) WaitForCacheSync(ctx context.Context) bool {\n122: \tsynced := k.informerFactory.WaitForCacheSync(ctx.Done())\n123: \tfor _, isSynced := range synced {\n124: \t\tif !isSynced {\n125: \t\t\treturn false\n126: \t\t}\n127: \t}\n128: \treturn true\n129: }\n130: \n131: func (k *K8sClient) SetClients(dynamicClient dynamic.Interface, coreClient kubernetes.Interface, informerFactory informers.SharedInformerFactory) {\n132: \tk.dynamicClient = dynamicClient\n133: \tk.coreClient = coreClient\n134: \tk.informerFactory = informerFactory\n135: }\n\n(End of file - total 135 lines)\n</content>","metadata":{"preview":"package workloadmanager\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"sync\"\n\n\tcorev1 \"k8s.io/api/core/v1\"\n\t\"k8s.io/apimachinery/pkg/runtime\"\n\t\"k8s.io/client-go/dynamic\"\n\t\"k8s.io/client-go/informers\"\n\t\"k8s.io/client-go/kubernetes\"\n\tcorev1listers \"k8s.io/client-go/listers/core/v1\"\n\t\"k8s.io/client-go/rest\"\n\t\"k8s.io/client-go/tools/cache\"\n)\n\ntype K8sClient struct {\n\tdynamicClient   dynamic.Interface\n\tcoreClient      kubernetes.Interface","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/k8s_client.go","time":{"start":1775847403458,"end":1775847403470}}}}
