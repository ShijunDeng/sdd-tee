\t\tif pod.Status.Phase == corev1.PodFailed || pod.Status.Phase == corev1.PodSucceeded {\n41: \t\t\treturn false, fmt.Errorf(\"pod %s terminated with phase %s\", podName, pod.Status.Phase)\n42: \t\t}\n43: \t\treturn false, nil\n44: \t})\n45: }\n46: \n47: func WaitForPodDeletedContext(ctx context.Context, tc *TestContext, podName string) error {\n48: \treturn wait.PollUntilContextTimeout(ctx, 2*time.Second, 60*time.Second, true, func(ctx context.Context) (bool, error) {\n49: \t\t_, err := tc.K8sClient.CoreV1().Pods(tc.Namespace).Get(ctx, podName, metav1.GetOptions{})\n50: \t\tif errors.IsNotFound(err) {\n51: \t\t\treturn true, nil\n52: \t\t}\n53: \t\tif err != nil {\n54: \t\t\treturn false, err\n55: \t\t}\n56: \t\treturn false, nil\n57: \t})\n58: }\n59: \n60: func DeletePod(ctx context.Context, tc *TestContext, podName string) error {\n61: \terr := tc.K8sClient.CoreV1().Pods(tc.Namespace).Delete(ctx, podName, metav1.DeleteOptions{})\n62: \tif errors.IsNotFound(err) {\n63: \t\treturn nil\n64: \t}\n65: \treturn err\n66: }\n67: \n68: func GetPodLogs(ctx context.Context, tc *TestContext, podName, containerName string) (string, error) {\n69: \topts := &corev1.PodLogOptions{\n70: \t\tContainer: containerName,\n71: \t\tTailLines: func() *int64 { i := int64(100); return &i }(),\n72: \t}\n73: \treq := tc.K8sClient.CoreV1().Pods(tc.Namespace).GetLogs(podName, opts)\n74: \tlogs, err := req.DoRaw(ctx)\n75: \tif err != nil {\n76: \t\treturn \"\", err\n77: \t}\n78: \treturn string(logs), nil\n79: }\n80: \n81: func CollectComponentLogs(t *testing.T, tc *TestContext, componentLabel string) {\n82: \tctx := context.Background()\n83: \tpods, err := tc.K8sClient.CoreV1().Pods(tc.Namespace).List(ctx, metav1.ListOptions{\n84: \t\tLabelSelector: fmt.Sprintf(\"app=%s\", componentLabel),\n85: \t})\n86: \tif err != nil {\n87: \t\tt.Logf(\"Failed to list pods for %s: %v\", componentLabel, err)\n88: \t\treturn\n89: \t}\n90: \n91: \tfor _, pod := range pods.Items {\n92: \t\tfor _, container := range pod.Spec.Containers {\n93: \t\t\tlogs, err := GetPodLogs(ctx, tc, pod.Name, container.Name)\n94: \t\t\tif err != nil {\n95: \t\t\t\tt.Logf(\"Failed to get logs for %s/%s: %v\", pod.Name, container.Name, err)\n96: \t\t\t\tcontinue\n97: \t\t\t}\n98: \t\t\tt.Logf(\"=== Logs for %s/%s ===\\n%s\", pod.Name, container.Name, logs)\n99: \t\t}\n100: \t}\n101: }\n102: \n103: func GetPodByLabel(ctx context.Context, tc *TestContext, labelSelector string) (*corev1.Pod, error) {\n104: \tpods, err := tc.K8sClient.CoreV1().Pods(tc.Namespace).List(ctx, metav1.ListOptions{\n105: \t\tLabelSelector: labelSelector,\n106: \t})\n107: \tif err != nil {\n108: \t\treturn nil, err\n109: \t}\n110: \tif len(pods.Items) == 0 {\n111: \t\treturn nil, errors.NewNotFound(corev1.Resource(\"pods\"), \"\")\n112: \t}\n113: \treturn &pods.Items[0], nil\n114: }\n115: \n116: func ListPodsByLabel(ctx context.Context, tc *TestContext, labelSelector string) ([]corev1.Pod, error) {\n117: \tpods, err := tc.K8sClient.CoreV1().Pods(tc.Namespace).List(ctx, metav1.ListOptions{\n118: \t\tLabelSelector: labelSelector,\n119: \t})\n120: \tif err != nil {\n121: \t\treturn nil, err\n122: \t}\n123: \treturn pods.Items, nil\n124: }\n125: \n126: func EnsurePodDeleted(t *testing.T, tc *TestContext, podName string) {\n127: \tctx := context.Background()\n128: \terr := WaitForPodDeletedContext(ctx, tc, podName)\n129: \tif err != nil {\n130: \t\tt.Logf(\"Warning: Pod %s not deleted: %v\", podName, err)\n131: \t}\n132: }\n133: \n134: func WaitForDeploymentReady(ctx context.Context, tc *TestContext, deploymentName string) error {\n135: \treturn wait.PollUntilContextTimeout(ctx, 2*time.Second, 120*time.Second, true, func(ctx context.Context) (bool, error) {\n136: \t\tdeploy, err := tc.K8sClient.AppsV1().Deployments(tc.Namespace).Get(ctx, deploymentName, metav1.GetOptions{})\n137: \t\tif err != nil {\n138: \t\t\treturn false, err\n139: \t\t}\n140: \t\tif deploy.Status.ReadyReplicas == deploy.Status.Replicas && deploy.Status.Replicas > 0 {\n141: \t\t\treturn true, nil\n142: \t\t}\n143: \t\treturn false, nil\n144: \t})\n145: }\n146: \n147: func WaitForNamespaceDeleted(ctx context.Context, tc *TestContext, namespace string) error {\n148: \treturn wait.PollUntilContextTimeout(ctx, 2*time.Second, 60*time.Second, true, func(ctx context.Context) (bool, error) {\n149: \t\t_, err := tc.K8sClient.CoreV1().Namespaces().Get(ctx, namespace, metav1.GetOptions{})\n150: \t\tif errors.IsNotFound(err) {\n151: \t\t\treturn true, nil\n152: \t\t}\n153: \t\tif err != nil {\n154: \t\t\treturn false, err\n155: \t\t}\n156: \t\treturn false, nil\n157: \t})\n158: }\n159: \n160: func WaitForNoPodsWithLabel(ctx context.Context, tc *TestContext, labelSelector string) error {\n161: \treturn wait.PollUntilContextTimeout(ctx, 2*time.Second, 60*time.Second, true, func(ctx context.Context) (bool, error) {\n162: \t\tpods, err := tc.K8sClient.CoreV1().Pods(tc.Namespace).List(ctx, metav1.ListOptions{\n163: \t\t\tLabelSelector: labelSelector,\n164: \t\t})\n165: \t\tif err != nil {\n166: \t\t\treturn false, err\n167: \t\t}\n168: \t\treturn len(pods.Items) == 0, nil\n169: \t})\n170: }\n\n(End of file - total 170 lines)\n</content>","metadata":{"preview":"package framework\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"testing\"\n\t\"time\"\n\n\tcorev1 \"k8s.io/api/core/v1\"\n\t\"k8s.io/apimachinery/pkg/api/errors\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/apimachinery/pkg/util/wait\"\n)\n\nfunc GetPodStatus(ctx context.Context, tc *TestContext, podName string) (corev1.PodPhase, error) {\n\tpod, err := tc.K8sClient.CoreV1().Pods(tc.Namespace).Get(ctx, podName, metav1.GetOptions{})\n\tif err != nil {\n\t\treturn \"\", err\n\t}\n\treturn pod.Status.Phase, nil","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/test/e2e/framework/kube_client.go","time":{"start":1775903122803,"end":1775903122824}}}}
