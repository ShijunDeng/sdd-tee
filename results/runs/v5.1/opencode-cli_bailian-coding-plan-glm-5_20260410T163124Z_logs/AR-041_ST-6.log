 \t}\n47: \n48: \tfmt.Printf(\"=== E2E Test Configuration ===\\n\")\n49: \tfmt.Printf(\"Workload Manager URL: %s\\n\", wmURL)\n50: \tfmt.Printf(\"Router URL: %s\\n\", routerURLVal)\n51: \tfmt.Printf(\"Namespace: %s\\n\", os.Getenv(\"AGENTCUBE_NAMESPACE\"))\n52: \tfmt.Printf(\"API Token: %s\\n\", tokenStatus(token))\n53: \n54: \texitCode := m.Run()\n55: \tos.Exit(exitCode)\n56: }\n57: \n58: func TestE2ESuiteSetup(t *testing.T) {\n59: \ttc := framework.SetupTestContext(t)\n60: \tdefer tc.Cleanup()\n61: \n62: \tframework.WaitForServiceReady(t, tc.WorkloadManagerURL)\n63: \tframework.WaitForServiceReady(t, tc.RouterURL)\n64: \n65: \tt.Log(\"E2E test suite setup completed successfully\")\n66: }\n67: \n68: func TestE2EHealthCheck(t *testing.T) {\n69: \ttc := framework.SetupTestContext(t)\n70: \tdefer tc.Cleanup()\n71: \n72: \twmClient := framework.NewSandboxTestClient(tc.WorkloadManagerURL, tc.APIToken)\n73: \tctx := context.Background()\n74: \terr := wmClient.HealthCheck(ctx)\n75: \tif err != nil {\n76: \t\tt.Fatalf(\"Workload Manager health check failed: %v\", err)\n77: \t}\n78: \n79: \trouterClient := framework.NewRouterTestClient(tc.RouterURL, tc.APIToken)\n80: \tresp, err := routerClient.HealthLive(ctx)\n81: \tif err != nil {\n82: \t\tt.Fatalf(\"Router health live check failed: %v\", err)\n83: \t}\n84: \tdefer resp.Body.Close()\n85: \tif resp.StatusCode != http.StatusOK {\n86: \t\tt.Fatalf(\"Router health live returned status %d\", resp.StatusCode)\n87: \t}\n88: \n89: \tresp2, err := routerClient.HealthReady(ctx)\n90: \tif err != nil {\n91: \t\tt.Fatalf(\"Router health ready check failed: %v\", err)\n92: \t}\n93: \tdefer resp2.Body.Close()\n94: \tif resp2.StatusCode != http.StatusOK {\n95: \t\tt.Fatalf(\"Router health ready returned status %d\", resp2.StatusCode)\n96: \t}\n97: \n98: \tt.Log(\"All components health checks passed\")\n99: }\n100: \n101: func tokenStatus(token string) string {\n102: \tif token != \"\" {\n103: \t\treturn \"set\"\n104: \t}\n105: \treturn \