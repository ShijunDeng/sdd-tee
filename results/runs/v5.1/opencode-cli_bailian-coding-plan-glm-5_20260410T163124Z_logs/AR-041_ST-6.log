{"type":"tool_use","timestamp":1775903122824,"sessionID":"ses_283ed75beffeSWOzbX4zzxHBm7","part":{"id":"prt_d7c1321dd001Zg4Lw7OtjG56yU","messageID":"msg_d7c13059c001JFn3fBNEB89uu0","sessionID":"ses_283ed75beffeSWOzbX4zzxHBm7","type":"tool","tool":"read","callID":"toolu_tool-3e5772763cb44d14a702558c2f4d2120","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/test/e2e/framework/test_context.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/test/e2e/framework/test_context.go</path>\n<type>file</type>\n<content>\n1: package framework\n2: \n3: import (\n4: \t\"context\"\n5: \t\"fmt\"\n6: \t\"os\"\n7: \t\"sync\"\n8: \t\"testing\"\n9: \t\"time\"\n10: \n11: \t\"github.com/google/uuid\"\n12: \t\"github.com/volcano-sh/agentcube/client-go/clientset/versioned\"\n13: \tcorev1 \"k8s.io/api/core/v1\"\n14: \t\"k8s.io/apimachinery/pkg/api/errors\"\n15: \tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n16: \t\"k8s.io/client-go/dynamic\"\n17: \t\"k8s.io/client-go/kubernetes\"\n18: \t\"k8s.io/client-go/rest\"\n19: \t\"k8s.io/client-go/tools/clientcmd\"\n20: )\n21: \n22: type TestContext struct {\n23: \tNamespace          string\n24: \tWorkloadManagerURL string\n25: \tRouterURL          string\n26: \tAPIToken           string\n27: \tK8sClient          *kubernetes.Clientset\n28: \tDynamicClient      dynamic.Interface\n29: \tRESTConfig         *rest.Config\n30: \tAgentCubeClient    versioned.Interface\n31: \tTestID             string\n32: \tStartTime          time.Time\n33: \tCleanupFuncs       []func()\n34: \tcleanupMutex       sync.Mutex\n35: }\n36: \n37: func NewTestContext(namespace, wmURL, routerURL, apiToken string) (*TestContext, error) {\n38: \tconfig, err := rest.InClusterConfig()\n39: \tif err != nil {\n40: \t\tloadingRules := clientcmd.NewDefaultClientConfigLoadingRules()\n41: \t\tconfigOverrides := &clientcmd.ConfigOverrides{}\n42: \t\tclientConfig := clientcmd.NewNonInteractiveDeferredLoadingClientConfig(loadingRules, configOverrides)\n43: \t\tconfig, err = clientConfig.ClientConfig()\n44: \t\tif err != nil {\n45: \t\t\treturn nil, fmt.Errorf(\"failed to get kubernetes config: %w\", err)\n46: \t\t}\n47: \t}\n48: \n49: \tk8sClient, err := kubernetes.NewForConfig(config)\n50: \tif err != nil {\n51: \t\treturn nil, fmt.Errorf(\"failed to create k8s client: %w\", err)\n52: \t}\n53: \n54: \tdynamicClient, err := dynamic.NewForConfig(config)\n55: \tif err != nil {\n56: \t\treturn nil, fmt.Errorf(\"failed to create dynamic client: %w\", err)\n57: \t}\n58: \n59: \tagentCubeClient, err := versioned.NewForConfig(config)\n60: \tif err != nil {\n61: \t\treturn nil, fmt.Errorf(\"failed to create agentcube client: %w\", err)\n62: \t}\n63: \n64: \treturn &TestContext{\n65: \t\tNamespace:          namespace,\n66: \t\tWorkloadManagerURL: wmURL,\n67: \t\tRouterURL:          routerURL,\n68: \t\tAPIToken:           apiToken,\n69: \t\tK8sClient:          k8sClient,\n70: \t\tDynamicClient:      dynamicClient,\n71: \t\tRESTConfig:         config,\n72: \t\tAgentCubeClient:    agentCubeClient,\n73: \t\tTestID:             uuid.New().String()[:8],\n74: \t\tStartTime:          time.Now(),\n75: \t\tCleanupFuncs:       []func(){},\n76: \t}, nil\n77: }\n78: \n79: func (tc *TestContext) AddCleanup(fn func()) {\n80: \ttc.cleanupMutex.Lock()\n81: \tdefer tc.cleanupMutex.Unlock()\n82: \ttc.CleanupFuncs = append(tc.CleanupFuncs, fn)\n83: }\n84: \n85: func (tc *TestContext) Cleanup() {\n86: \ttc.cleanupMutex.Lock()\n87: \tdefer tc.cleanupMutex.Unlock()\n88: \tfor i := len(tc.CleanupFuncs) - 1; i >= 0; i-- {\n89: \t\ttc.CleanupFuncs[i]()\n90: \t}\n91: \ttc.CleanupFuncs = nil\n92: }\n93: \n94: func (tc *TestContext) EnsureNamespace(ctx context.Context) error {\n95: \t_, err := tc.K8sClient.CoreV1().Namespaces().Get(ctx, tc.Namespace, metav1.GetOptions{})\n96: \tif errors.IsNotFound(err) {\n97: \t\tns := &corev1.Namespace{\n98: \t\t\tObjectMeta: metav1.ObjectMeta{\n99: \t\t\t\tName: tc.Namespace,\n100: \t\t\t\tLabels: map[string]string{\n101: \t\t\t\t\t\"agentcube-e2e-test\": tc.TestID,\n102: \t\t\t\t},\n103: \t\t\t},\n104: \t\t}\n105: \t\t_, err = tc.K8sClient.CoreV1().Namespaces().Create(ctx, ns, metav1.CreateOptions{})\n106: \t\tif err != nil {\n107: \t\t\treturn fmt.Errorf(\"failed to create namespace %s: %w\", tc.Namespace, err)\n108: \t\t}\n109: \t\ttc.AddCleanup(func() {\n110: \t\t\tdeleteCtx := context.Background()\n111: \t\t\t_ = tc.K8sClient.CoreV1().Namespaces().Delete(deleteCtx, tc.Namespace, metav1.DeleteOptions{})\n112: \t\t})\n113: \t\treturn nil\n114: \t}\n115: \treturn err\n116: }\n117: \n118: func SetupTestContext(t *testing.T) *TestContext {\n119: \tnamespace := os.Getenv(\"AGENTCUBE_NAMESPACE\")\n120: \tif namespace == \"\" {\n121: \t\tnamespace = \"agentcube-e2e\"\n122: \t}\n123: \n124: \twmURL := os.Getenv(\"WORKLOAD_MANAGER_URL\")\n125: \tif wmURL == \"\" {\n126: \t\twmURL = \"http://localhost:8080\"\n127: \t}\n128: \n129: \trouterURL := os.Getenv(\"ROUTER_URL\")\n130: \tif routerURL == \"\" {\n131: \t\trouterURL = \"http://localhost:8081\"\n132: \t}\n133: \n134: \tapiToken := os.Getenv(\"API_TOKEN\")\n135: \tif apiToken == \"\" {\n136: \t\tsaToken, err := ReadServiceAccountToken()\n137: \t\tif err != nil {\n138: \t\t\tt.Logf(\"Warning: Could not read service account token: %v\", err)\n139: \t\t}\n140: \t\tapiToken = saToken\n141: \t}\n142: \n143: \ttc, err := NewTestContext(namespace, wmURL, routerURL, apiToken)\n144: \tif err != nil {\n145: \t\tt.Fatalf(\"Failed to create test context: %v\", err)\n146: \t}\n147: \n148: \tctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)\n149: \tdefer cancel()\n150: \n151: \tif err := tc.EnsureNamespace(ctx); err != nil {\n152: \t\tt.Fatalf(\"Failed to ensure namespace: %v\", err)\n153: \t}\n154: \n155: \treturn tc\n156: }\n157: \n158: func ReadServiceAccountToken() (string, error) {\n159: \ttokenPath := \"/var/run/secrets/kubernetes.io/serviceaccount/token\"\n160: \tdata, err := os.ReadFile(tokenPath)\n161: \tif err != nil {\n162: \t\treturn \"\", err\n163: \t}\n164: \treturn string(data), nil\n165: }\n\n(End of file - total 165 lines)\n</content>","metadata":{"preview":"package framework\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"os\"\n\t\"sync\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/google/uuid\"\n\t\"github.com/volcano-sh/agentcube/client-go/clientset/versioned\"\n\tcorev1 \"k8s.io/api/core/v1\"\n\t\"k8s.io/apimachinery/pkg/api/errors\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/client-go/dynamic\"\n\t\"k8s.io/client-go/kubernetes\"\n\t\"k8s.io/client-go/rest\"\n\t\"k8s.io/client-go/tools/clientcmd\"\n)","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/test/e2e/framework/test_context.go","time":{"start":1775903122801,"end":1775903122822}}}}
