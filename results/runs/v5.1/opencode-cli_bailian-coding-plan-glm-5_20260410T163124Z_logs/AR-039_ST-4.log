box := makeTestSandbox(\"session-123\")\n47: \tdata, err := json.Marshal(sandbox)\n48: \trequire.NoError(t, err)\n49: \n50: \tkey := store.sessionKey(\"session-123\")\n51: \terr = store.cli.Do(ctx, store.cli.B().Set().Key(key).Value(string(data)).Build()).Error()\n52: \trequire.NoError(t, err)\n53: \n54: \tresult, err := store.GetSandboxBySessionID(ctx, \"session-123\")\n55: \trequire.NoError(t, err)\n56: \tassert.Equal(t, sandbox.SessionID, result.SessionID)\n57: \tassert.Equal(t, sandbox.SandboxID, result.SandboxID)\n58: }\n59: \n60: func TestValkeyStore_GetSandboxBySessionID_NotFound(t *testing.T) {\n61: \tstore := setupTestValkeyStore(t)\n62: \tctx := context.Background()\n63: \n64: \tresult, err := store.GetSandboxBySessionID(ctx, \"non-existent\")\n65: \tassert.Nil(t, result)\n66: \tassert.ErrorIs(t, err, ErrNotFound)\n67: }\n68: \n69: func TestValkeyStore_GetSandboxBySessionID_EmptySessionID(t *testing.T) {\n70: \tstore := setupTestValkeyStore(t)\n71: \tctx := context.Background()\n72: \n73: \tresult, err := store.GetSandboxBySessionID(ctx, \"\")\n74: \tassert.Nil(t, result)\n75: \tassert.ErrorIs(t, err, ErrEmptySessionID)\n76: }\n77: \n78: func TestValkeyStore_StoreSandbox_Success(t *testing.T) {\n79: \tstore := setupTestValkeyStore(t)\n80: \tctx := context.Background()\n81: \n82: \tsandbox := makeTestSandbox(\"session-123\")\n83: \n84: \terr := store.StoreSandbox(ctx, sandbox)\n85: \trequire.NoError(t, err)\n86: \n87: \tresult, err := store.GetSandboxBySessionID(ctx, \"session-123\")\n88: \trequire.NoError(t, err)\n89: \tassert.Equal(t, sandbox.SessionID, result.SessionID)\n90: \n91: \tresp := store.cli.Do(ctx, store.cli.B().Zscore().Key(store.expiryIndexKey).Member(\"session-123\").Build())\n92: \trequire.NoError(t, resp.Error())\n93: \tscore, err := resp.AsFloat64()\n94: \trequire.NoError(t, err)\n95: \tassert.Equal(t, float64(sandbox.ExpiresAt.Unix()), score)\n96: \n97: \tresp = store.cli.Do(ctx, store.cli.B().Zscore().Key(store.lastActivityIndexKey).Member(\"session-123\").Build())\n98: \trequire.NoError(t, resp.Error())\n99: \tactivityScore, err := resp.AsFloat64()\n100: \trequire.NoError(t, err)\n101: \tassert.GreaterOrEqual(t, activityScore, float64(0))\n102: }\n103: \n104: func TestValkeyStore_StoreSandbox_NilSandbox(t *testing.T) {\n105: \tstore := setupTestValkeyStore(t)\n106: \tctx := context.Background()\n107: \n108: \terr := store.StoreSandbox(ctx, nil)\n109: \tassert.ErrorIs(t, err, ErrNilSandbox)\n110: }\n111: \n112: func TestValkeyStore_StoreSandbox_ZeroExpiresAt(t *testing.T) {\n113: \tstore := setupTestValkeyStore(t)\n114: \tctx := context.Background()\n115: \n116: \tsandbox := &types.SandboxInfo{\n117: \t\tSessionID: \"session-123\",\n118: \t\tExpiresAt: time.Time{},\n119: \t}\n120: \n121: \terr := store.StoreSandbox(ctx, sandbox)\n122: \tassert.ErrorIs(t, err, ErrZeroExpiresAt)\n123: }\n124: \n125: func TestValkeyStore_StoreSandbox_EmptySessionID(t *testing.T) {\n126: \tstore := setupTestValkeyStore(t)\n127: \tctx := context.Background()\n128: \n129: \tsandbox := &types.SandboxInfo{\n130: \t\tSessionID: \"\",\n131: \t\tExpiresAt: time.Now().Add(24 * time.Hour),\n132: \t}\n133: \n134: \terr := store.StoreSandbox(ctx, sandbox)\n135: \tassert.ErrorIs(t, err, ErrEmptySessionID)\n136: }\n137: \n138: func TestValkeyStore_StoreSandbox_Duplicate(t *testing.T) {\n139: \tstore := setupTestValkeyStore(t)\n140: \tctx := context.Background()\n141: \n142: \tsandbox := makeTestSandbox(\"session-123\")\n143: \n144: \terr := store.StoreSandbox(ctx, sandbox)\n145: \trequire.NoError(t, err)\n146: \n147: \terr = store.StoreSandbox(ctx, sandbox)\n148: \tassert.Error(t, err)\n149: \tassert.ErrorIs(t, err, ErrSessionExists)\n150: }\n151: \n152: func TestValkeyStore_UpdateSandbox_Success(t *testing.T) {\n153: \tstore := setupTestValkeyStore(t)\n154: \tctx := context.Background()\n155: \n156: \tsandbox := makeTestSandbox(\"session-123\")\n157: \terr := store.StoreSandbox(ctx, sandbox)\n158: \trequire.NoError(t, err)\n159: \n160: \tsandbox.Status = \"terminating\"\n161: \terr = store.UpdateSandbox(ctx, sandbox)\n162: \trequire.NoError(t, err)\n163: \n164: \tresult, err := store.GetSandboxBySessionID(ctx, \"session-123\")\n165: \trequire.NoError(t, err)\n166: \tassert.Equal(t, \"terminating\", result.Status)\n167: }\n168: \n169: func TestValkeyStore_UpdateSandbox_NotFound(t *testing.T) {\n170: \tstore := setupTestValkeyStore(t)\n171: \tctx := context.Background()\n172: \n173: \tsandbox := makeTestSandbox(\"non-existent\")\n174: \n175: \terr := store.UpdateSandbox(ctx, sandbox)\n176: \tassert.ErrorIs(t, err, ErrNotFound)\n177: }\n178: \n179: func TestValkeyStore_UpdateSandbox_NilSandbox(t *testing.T) {\n180: \tstore := setupTestValkeyStore(t)\n181: \tctx := context.Background()\n182: \n183: \terr := store.UpdateSandbox(ctx, nil)\n184: \tassert.ErrorIs(t, err, ErrNilSandbox)\n185: }\n186: \n187: func TestValkeyStore_UpdateSandbox_EmptySessionID(t *testing.T) {\n188: \tstore := setupTestValkeyStore(t)\n189: \tctx := context.Background()\n190: \n191: \tsandbox := &types.SandboxInfo{SessionID: \"\"}\n192: \n193: \terr := store.UpdateSandbox(ctx, sandbox)\n194: \tassert.ErrorIs(t, err, ErrEmptySessionID)\n195: }\n196: \n197: func TestValkeyStore_DeleteSandboxBySessionID_Success(t *testing.T) {\n198: \tstore := setupTestValkeyStore(t)\n199: \tctx := context.Background()\n200: \n201: \tsandbox := makeTestSandbox(\"session-123\")\n202: \terr := store.StoreSandbox(ctx, sandbox)\n203: \trequire.NoError(t, err)\n204: \n205: \terr = store.DeleteSandboxBySessionID(ctx, \"session-123\")\n206: \trequire.NoError(t, err)\n207: \n208: \tresult, err := store.GetSandboxBySessionID(ctx, \"session-123\")\n209: \tassert.Nil(t, result)\n210: \tassert.ErrorIs(t, err, ErrNotFound)\n211: \n212: \tresp := store.cli.Do(ctx, store.cli.B().Zrank().Key(store.expiryIndexKey).Member(\"session-123\").Build())\n213: \tassert.True(t, valkey.IsValkeyNil(resp.Error()))\n214: \n215: \tresp = store.cli.Do(ctx, store.cli.B().Zrank().Key(store.lastActivityIndexKey).Member(\"session-123\").Build())\n216: \tassert.True(t, valkey.IsValkeyNil(resp.Error()))\n217: }\n218: \n219: func TestValkeyStore_DeleteSandboxBySessionID_NotFound(t *testing.T) {\n220: \tstore := setupTestValkeyStore(t)\n221: \tctx := context.Background()\n222: \n223: \terr := store.DeleteSandboxBySessionID(ctx, \"non-existent\")\n224: \tassert.NoError(t, err)\n225: }\n226: \n227: func TestValkeyStore_DeleteSandboxBySessionID_EmptySessionID(t *testing.T) {\n228: \tstore := setupTestValkeyStore(t)\n229: \tctx := context.Background()\n230: \n231: \terr := store.DeleteSandboxBySessionID(ctx, \"\")\n232: \tassert.ErrorIs(t, err, ErrEmptySessionID)\n233: }\n234: \n235: func TestValkeyStore_ListExpiredSandboxes_Success(t *testing.T) {\n236: \tstore := setupTestValkeyStore(t)\n237: \tctx := context.Background()\n238: \n239: \tnow := time.Now()\n240: \n241: \texpiredSandbox := &types.SandboxInfo{\n242: \t\tKind:             types.AgentRuntimeKind,\n243: \t\tSandboxID:        \"sb-expired\",\n244: \t\tSandboxNamespace: \"default\",\n245: \t\tSessionID:        \"session-expired\",\n246: \t\tCreatedAt:        now.Add(-10 * time.Hour),\n247: \t\tExpiresAt:        now.Add(-2 * time.Hour),\n248: \t\tStatus:           \"active\",\n249: \t\tLastActivity:     now.Add(-10 * time.Hour),\n250: \t}\n251: \n252: \tactiveSandbox := &types.SandboxInfo{\n253: \t\tKind:             types.AgentRuntimeKind,\n254: \t\tSandboxID:        \"sb-active\",\n255: \t\tSandboxNamespace: \"default\",\n256: \t\tSessionID:        \"session-active\",\n257: \t\tCreatedAt:        now,\n258: \t\tExpiresAt:        now.Add(8 * time.Hour),\n259: \t\tStatus:           \"active\",\n260: \t\tLastActivity:     now,\n261: \t}\n262: \n263: \terr := store.StoreSandbox(ctx, expiredSandbox)\n264: \trequire.NoError(t, err)\n265: \terr = store.StoreSandbox(ctx, activeSandbox)\n266: \trequire.NoError(t, err)\n267: \n268: \tresults, err := store.ListExpiredSandboxes(ctx, now, 10)\n269: \trequire.NoError(t, err)\n270: \tassert.Len(t, results, 1)\n271: \tassert.Equal(t, \"session-expired\", results[0].SessionID)\n272: }\n273: \n274: func TestValkeyStore_ListExpiredSandboxes_Limit(t *testing.T) {\n275: \tstore := setupTestValkeyStore(t)\n276: \tctx := context.Background()\n277: \n278: \tnow := time.Now()\n279: \n280: \tfor i := 0; i < 20; i++ {\n281: \t\tsandbox := &types.SandboxInfo{\n282: \t\t\tKind:             types.AgentRuntimeKind,\n283: \t\t\tSandboxID:        \"sb-\" + string(rune(i)),\n284: \t\t\tSandboxNamespace: \"default\",\n285: \t\t\tSessionID:        \"session-\" + string(rune(i)),\n286: \t\t\tCreatedAt:        now.Add(-10 * time.Hour),\n287: \t\t\tExpiresAt:        now.Add(-time.Duration(i+1) * time.Hour),\n288: \t\t\tStatus:           \"active\",\n289: \t\t\tLastActivity:     now.Add(-10 * time.Hour),\n290: \t\t}\n291: \t\terr := store.StoreSandbox(ctx, sandbox)\n292: \t\trequire.NoError(t, err)\n293: \t}\n294: \n295: \tresults, err := store.ListExpiredSandboxes(ctx, now, 5)\n296: \trequire.NoError(t, err)\n297: \tassert.Len(t, results, 5)\n298: }\n299: \n300: func TestValkeyStore_ListExpiredSandboxes_ZeroLimit(t *testing.T) {\n301: \tstore := setupTestValkeyStore(t)\n302: \tctx := context.Background()\n303: \n304: \tresults, err := store.ListExpiredSandboxes(ctx, time.Now(), 0)\n305: \trequire.NoError(t, err)\n306: \tassert.Nil(t, results)\n307: }\n308: \n309: func TestValkeyStore_ListExpiredSandboxes_NegativeLimit(t *testing.T) {\n310: \tstore := setupTestValkeyStore(t)\n311: \tctx := context.Background()\n312: \n313: \tresults, err := store.ListExpiredSandboxes(ctx, time.Now(), -1)\n314: \trequire.NoError(t, err)\n315: \tassert.Nil(t, results)\n316: }\n317: \n318: func TestValkeyStore_ListExpiredSandboxes_SkipMissing(t *testing.T) {\n319: \tstore := setupTestValkeyStore(t)\n320: \tctx := context.Background()\n321: \n322: \tnow := time.Now()\n323: \n324: \terr := store.cli.Do(ctx, store.cli.B().Zadd().Key(store.expiryIndexKey).\n325: \t\tScoreMember().ScoreMember(float64(now.Add(-1*time.Hour).Unix()), \"orphan-session\").Build()).Error()\n326: \trequire.NoError(t, err)\n327: \n328: \tresults, err := store.ListExpiredSandboxes(ctx, now, 10)\n329: \trequire.NoError(t, err)\n330: \tassert.Len(t, results, 0)\n331: }\n332: \n333: func TestValkeyStore_ListExpiredSandboxes_Empty(t *testing.T) {\n334: \tstore := setupTestValkeyStore(t)\n335: \tctx := context.Background()\n336: \n337: \tresults, err := store.ListExpiredSandboxes(ctx, time.Now(), 10)\n338: \trequire.NoError(t, err)\n339: \tassert.Nil(t, results)\n340: }\n341: \n342: func TestValkeyStore_ListInactiveSandboxes_Success(t *testing.T) {\n343: \tstore := setupTestValkeyStore(t)\n344: \tctx := context.Background()\n345: \n346: \tnow := time.Now()\n347: \n348: \tinactiveSandbox := &types.SandboxInfo{\n349: \t\tKind:             types.AgentRuntimeKind,\n350: \t\tSandboxID:        \"sb-inactive\",\n351: \t\tSandboxNamespace: \"default\",\n352: \t\tSessionID:        \"session-inactive\",\n353: \t\tCreatedAt:        now,\n354: \t\tExpiresAt:        now.Add(8 * time.Hour),\n355: \t\tStatus:           \"active\",\n356: \t\tLastActivity:     now.Add(-30 * time.Minute),\n357: \t}\n358: \n359: \tactiveSandbox := &types.SandboxInfo{\n360: \t\tKind:             types.AgentRuntimeKind,\n361: \t\tSandboxID:        \"sb-active\",\n362: \t\tSandboxNamespace: \"default\",\n363: \t\tSessionID:        \"session-active\",\n364: \t\tCreatedAt:        now,\n365: \t\tExpiresAt:        now.Add(8 * time.Hour),\n366: \t\tStatus:           \"active\",\n367: \t\tLastActivity:     now,\n368: \t}\n369: \n370: \terr := store.StoreSandbox(ctx, inactiveSandbox)\n371: \trequire.NoError(t, err)\n372: \terr = store.StoreSandbox(ctx, activeSandbox)\n373: \trequire.NoError(t, err)\n374: \n375: \tresults, err := store.ListInactiveSandboxes(ctx, now.Add(-15*time.Minute), 10)\n376: \trequire.NoError(t, err)\n377: \tassert.Len(t, results, 1)\n378: \tassert.Equal(t, \"session-inactiv