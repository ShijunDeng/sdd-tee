{"type":"tool_use","timestamp":1775898338607,"sessionID":"ses_284369e59ffeHdgLjlbiaIcKCA","part":{"id":"prt_d7bca10eb001Rp4TsnmaDnmwhX","messageID":"msg_d7bc9e0c9001Dm5Wr7KgI5SYDQ","sessionID":"ses_284369e59ffeHdgLjlbiaIcKCA","type":"tool","tool":"read","callID":"toolu_tool-dbd62c4ce6d041158498073c883d7490","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/errors_test.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/errors_test.go</path>\n<type>file</type>\n<content>\n1: package router\n2: \n3: import (\n4: \t\"errors\"\n5: \t\"testing\"\n6: \n7: \t\"github.com/stretchr/testify/assert\"\n8: \t\"github.com/stretchr/testify/require\"\n9: )\n10: \n11: func TestSessionNotFoundError(t *testing.T) {\n12: \terr := &SessionNotFoundError{SessionID: \"test-session\"}\n13: \tassert.Equal(t, \"session not found: test-session\", err.Error())\n14: \tassert.Equal(t, 404, err.Status())\n15: \tassert.Equal(t, \"SESSION_NOT_FOUND\", err.Code())\n16: \tassert.Equal(t, \"session not found\", err.Message())\n17: }\n18: \n19: func TestSandboxUnreachableError(t *testing.T) {\n20: \terr := &SandboxUnreachableError{SandboxID: \"test-sandbox\"}\n21: \tassert.Equal(t, \"sandbox unreachable: test-sandbox\", err.Error())\n22: \tassert.Equal(t, 502, err.Status())\n23: \tassert.Equal(t, \"SANDBOX_UNREACHABLE\", err.Code())\n24: \tassert.Equal(t, \"sandbox unreachable\", err.Message())\n25: }\n26: \n27: func TestSandboxTimeoutError(t *testing.T) {\n28: \terr := &SandboxTimeoutError{SandboxID: \"test-sandbox\"}\n29: \tassert.Equal(t, \"sandbox timeout: test-sandbox\", err.Error())\n30: \tassert.Equal(t, 504, err.Status())\n31: \tassert.Equal(t, \"SANDBOX_TIMEOUT\", err.Code())\n32: \tassert.Equal(t, \"sandbox timeout\", err.Message())\n33: }\n34: \n35: func TestJWTSigningError(t *testing.T) {\n36: \tinnerErr := &SessionNotFoundError{SessionID: \"inner\"}\n37: \terr := &JWTSigningError{Err: innerErr}\n38: \tassert.Equal(t, 500, err.Status())\n39: \tassert.Equal(t, \"JWT_SIGNING_FAILED\", err.Code())\n40: \tassert.Equal(t, \"jwt signing failed\", err.Message())\n41: \tassert.Contains(t, err.Error(), \"jwt signing failed\")\n42: }\n43: \n44: func TestJWTValidationError(t *testing.T) {\n45: \tinnerErr := errors.New(\"validation failed\")\n46: \terr := &JWTValidationError{Err: innerErr}\n47: \tassert.Equal(t, 401, err.Status())\n48: \tassert.Equal(t, \"JWT_VALIDATION_FAILED\", err.Code())\n49: \tassert.Equal(t, \"jwt validation failed\", err.Message())\n50: \tassert.Contains(t, err.Error(), \"jwt validation failed\")\n51: }\n52: \n53: func TestJWTValidationErrorNil(t *testing.T) {\n54: \terr := &JWTValidationError{Err: nil}\n55: \tassert.Equal(t, 401, err.Status())\n56: \tassert.Equal(t, \"JWT_VALIDATION_FAILED\", err.Code())\n57: \tassert.Equal(t, \"jwt validation failed\", err.Message())\n58: \tassert.Equal(t, \"jwt validation failed\", err.Error())\n59: }\n60: \n61: func TestJWTValidationErrorUnwrap(t *testing.T) {\n62: \tinnerErr := errors.New(\"inner error\")\n63: \terr := &JWTValidationError{Err: innerErr}\n64: \tunwrapped := err.Unwrap()\n65: \trequire.NotNil(t, unwrapped)\n66: \tassert.Equal(t, \"inner error\", unwrapped.Error())\n67: }\n68: \n69: func TestJWTTokenExpiredError(t *testing.T) {\n70: \terr := &JWTTokenExpiredError{TokenID: \"expired-token-id\"}\n71: \tassert.Equal(t, \"jwt token expired: expired-token-id\", err.Error())\n72: \tassert.Equal(t, 401, err.Status())\n73: \tassert.Equal(t, \"JWT_TOKEN_EXPIRED\", err.Code())\n74: \tassert.Equal(t, \"jwt token expired\", err.Message())\n75: }\n76: \n77: func TestJWTTokenMissingError(t *testing.T) {\n78: \terr := &JWTTokenMissingError{}\n79: \tassert.Equal(t, \"jwt token missing\", err.Error())\n80: \tassert.Equal(t, 401, err.Status())\n81: \tassert.Equal(t, \"JWT_TOKEN_MISSING\", err.Code())\n82: \tassert.Equal(t, \"jwt token missing\", err.Message())\n83: }\n84: \n85: func TestJWTInvalidFormatError(t *testing.T) {\n86: \terr := &JWTInvalidFormatError{Reason: \"missing bearer prefix\"}\n87: \tassert.Equal(t, \"invalid authorization header format: missing bearer prefix\", err.Error())\n88: \tassert.Equal(t, 401, err.Status())\n89: \tassert.Equal(t, \"JWT_INVALID_FORMAT\", err.Code())\n90: \tassert.Equal(t, \"invalid authorization header format\", err.Message())\n91: }\n92: \n93: func TestJWTInvalidFormatErrorEmptyReason(t *testing.T) {\n94: \terr := &JWTInvalidFormatError{Reason: \"\"}\n95: \tassert.Equal(t, \"invalid authorization header format\", err.Error())\n96: \tassert.Equal(t, 401, err.Status())\n97: \tassert.Equal(t, \"JWT_INVALID_FORMAT\", err.Code())\n98: \tassert.Equal(t, \"invalid authorization header format\", err.Message())\n99: }\n100: \n101: func TestJWTKeyLoadError(t *testing.T) {\n102: \tinnerErr := errors.New(\"key load failed\")\n103: \terr := &JWTKeyLoadError{Err: innerErr}\n104: \tassert.Equal(t, 500, err.Status())\n105: \tassert.Equal(t, \"JWT_KEY_LOAD_FAILED\", err.Code())\n106: \tassert.Equal(t, \"jwt key load failed\", err.Message())\n107: \tassert.Contains(t, err.Error(), \"jwt key load failed\")\n108: }\n109: \n110: func TestJWTKeyLoadErrorNil(t *testing.T) {\n111: \terr := &JWTKeyLoadError{Err: nil}\n112: \tassert.Equal(t, 500, err.Status())\n113: \tassert.Equal(t, \"JWT_KEY_LOAD_FAILED\", err.Code())\n114: \tassert.Equal(t, \"jwt key load failed\", err.Message())\n115: \tassert.Equal(t, \"jwt key load failed\", err.Error())\n116: }\n117: \n118: func TestJWTKeyLoadErrorUnwrap(t *testing.T) {\n119: \tinnerErr := errors.New(\"inner error\")\n120: \terr := &JWTKeyLoadError{Err: innerErr}\n121: \tunwrapped := err.Unwrap()\n122: \trequire.NotNil(t, unwrapped)\n123: \tassert.Equal(t, \"inner error\", unwrapped.Error())\n124: }\n125: \n126: func TestServerOverloadedError(t *testing.T) {\n127: \terr := &ServerOverloadedError{}\n128: \tassert.Equal(t, \"server overloaded\", err.Error())\n129: \tassert.Equal(t, 429, err.Status())\n130: \tassert.Equal(t, \"SERVER_OVERLOADED\", err.Code())\n131: \tassert.Equal(t, \"server overloaded, please try again later\", err.Message())\n132: }\n133: \n134: func TestNoEntryPointError(t *testing.T) {\n135: \terr := &NoEntryPointError{SandboxID: \"test-sandbox\"}\n136: \tassert.Equal(t, \"no entry point for sandbox: test-sandbox\", err.Error())\n137: \tassert.Equal(t, 404, err.Status())\n138: \tassert.Equal(t, \"NO_ENTRY_POINT\", err.Code())\n139: \tassert.Equal(t, \"no entry point configured\", err.Message())\n140: }\n141: \n142: func TestWorkloadManagerError(t *testing.T) {\n143: \terr := &WorkloadManagerError{StatusCode: 500, Msg: \"test message\"}\n144: \tassert.Equal(t, \"test message\", err.Error())\n145: \tassert.Equal(t, 500, err.Status())\n146: \tassert.Equal(t, \"WORKLOAD_MANAGER_ERROR\", err.Code())\n147: \tassert.Equal(t, \"test message\", err.Message())\n148: }\n149: \n150: func TestAPIStatusInterface(t *testing.T) {\n151: \tapiErrors := []APIStatus{\n152: \t\t&SessionNotFoundError{SessionID: \"test\"},\n153: \t\t&SandboxUnreachableError{SandboxID: \"test\"},\n154: \t\t&SandboxTimeoutError{SandboxID: \"test\"},\n155: \t\t&JWTSigningError{Err: nil},\n156: \t\t&JWTValidationError{Err: nil},\n157: \t\t&JWTTokenExpiredError{TokenID: \"test\"},\n158: \t\t&JWTTokenMissingError{},\n159: \t\t&JWTInvalidFormatError{Reason: \"test\"},\n160: \t\t&JWTKeyLoadError{Err: nil},\n161: \t\t&ServerOverloadedError{},\n162: \t\t&NoEntryPointError{SandboxID: \"test\"},\n163: \t\t&WorkloadManagerError{StatusCode: 500, Msg: \"test\"},\n164: \t}\n165: \n166: \tfor _, err := range apiErrors {\n167: \t\tassert.NotZero(t, err.Status(), \"Status() returned 0 for %T\", err)\n168: \t\tassert.NotEmpty(t, err.Code(), \"Code() returned empty string for %T\", err)\n169: \t\tassert.NotEmpty(t, err.Message(), \"Message() returned empty string for %T\", err)\n170: \t\tasErr, ok := err.(error)\n171: \t\trequire.True(t, ok, \"APIStatus %T does not implement error interface\", err)\n172: \t\tassert.NotEmpty(t, asErr.Error(), \"Error() returned empty string for %T\", err)\n173: \t}\n174: }\n175: \n176: func TestJWTErrorInterface(t *testing.T) {\n177: \tjwtErrors := []APIStatus{\n178: \t\t&JWTSigningError{Err: errors.New(\"test\")},\n179: \t\t&JWTValidationError{Err: errors.New(\"test\")},\n180: \t\t&JWTTokenExpiredError{TokenID: \"test\"},\n181: \t\t&JWTTokenMissingError{},\n182: \t\t&JWTInvalidFormatError{Reason: \"test\"},\n183: \t\t&JWTKeyLoadError{Err: errors.New(\"test\")},\n184: \t}\n185: \n186: \tfor _, err := range jwtErrors {\n187: \t\tassert.IsType(t, err, err)\n188: \t}\n189: }\n\n(End of file - total 189 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"errors\"\n\t\"testing\"\n\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n)\n\nfunc TestSessionNotFoundError(t *testing.T) {\n\terr := &SessionNotFoundError{SessionID: \"test-session\"}\n\tassert.Equal(t, \"session not found: test-session\", err.Error())\n\tassert.Equal(t, 404, err.Status())\n\tassert.Equal(t, \"SESSION_NOT_FOUND\", err.Code())\n\tassert.Equal(t, \"session not found\", err.Message())\n}\n\nfunc TestSandboxUnreachableError(t *testing.T) {\n\terr := &SandboxUnreachableError{SandboxID: \"test-sandbox\"}","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/errors_test.go","time":{"start":1775898338574,"end":1775898338606}}}}
{"type":"tool_use","timestamp":1775898338609,"sessionID":"ses_284369e59ffeHdgLjlbiaIcKCA","part":{"id":"prt_d7bca14a2001EDB9sMgzS5K03n","messageID":"msg_d7bc9e0c9001Dm5Wr7KgI5SYDQ","sessionID":"ses_284369e59ffeHdgLjlbiaIcKCA","type":"tool","tool":"read","callID":"toolu_tool-74410e32f5134a6296d2cdb2f8a091d2","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/session_manager.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/session_manager.go</path>\n<type>file</type>\n<content>\n1: package router\n2: \n3: import (\n4: \t\"bytes\"\n5: \t\"context\"\n6: \t\"encoding/json\"\n7: \t\"fmt\"\n8: \t\"io\"\n9: \t\"net/http\"\n10: \t\"os\"\n11: \t\"strings\"\n12: \t\"time\"\n13: \n14: \t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n15: \t\"golang.org/x/net/http2\"\n16: )\n17: \n18: type sessionManager struct {\n19: \tstoreClient     Store\n20: \tworkloadMgrAddr string\n21: \thttpClient      *http.Client\n22: }\n23: \n24: func NewSessionManager(storeClient Store) (SessionManager, error) {\n25: \tworkloadMgrAddr := os.Getenv(\"WORKLOAD_MANAGER_URL\")\n26: \tif workloadMgrAddr == \"\" {\n27: \t\treturn nil, fmt.Errorf(\"WORKLOAD_MANAGER_URL environment variable is required\")\n28: \t}\n29: \n30: \ttransport := &http.Transport{\n31: \t\tMaxIdleConnsPerHost: 100,\n32: \t\tDisableCompression:  false,\n33: \t}\n34: \n35: \thttp2.ConfigureTransport(transport)\n36: \n37: \thttpClient := &http.Client{\n38: \t\tTimeout:   2 * time.Minute,\n39: \t\tTransport: transport,\n40: \t}\n41: \n42: \treturn &sessionManager{\n43: \t\tstoreClient:     storeClient,\n44: \t\tworkloadMgrAddr: workloadMgrAddr,\n45: \t\thttpClient:      httpClient,\n46: \t}, nil\n47: }\n48: \n49: func (m *sessionManager) GetSandboxBySession(ctx context.Context, sessionID string, namespace string, name string, kind string) (*types.SandboxInfo, error) {\n50: \tif sessionID == \"\" {\n51: \t\treturn m.createSandbox(ctx, namespace, name, kind)\n52: \t}\n53: \n54: \tsandbox, err := m.storeClient.GetSandboxBySessionID(ctx, sessionID)\n55: \tif err != nil {\n56: \t\treturn nil, &SessionNotFoundError{SessionID: sessionID}\n57: \t}\n58: \n59: \treturn sandbox, nil\n60: }\n61: \n62: func (m *sessionManager) createSandbox(ctx context.Context, namespace string, name string, kind string) (*types.SandboxInfo, error) {\n63: \treqBody := types.CreateSandboxRequest{\n64: \t\tKind:      kind,\n65: \t\tName:      name,\n66: \t\tNamespace: namespace,\n67: \t}\n68: \n69: \tif err := reqBody.Validate(); err != nil {\n70: \t\treturn nil, err\n71: \t}\n72: \n73: \tvar endpoint string\n74: \tswitch kind {\n75: \tcase types.AgentRuntimeKind:\n76: \t\tendpoint = m.workloadMgrAddr + \"/v1/agent-runtime\"\n77: \tcase types.CodeInterpreterKind:\n78: \t\tendpoint = m.workloadMgrAddr + \"/v1/code-interpreter\"\n79: \tdefault:\n80: \t\treturn nil, fmt.Errorf(\"unsupported kind: %s\", kind)\n81: \t}\n82: \n83: \tbodyBytes, err := json.Marshal(reqBody)\n84: \tif err != nil {\n85: \t\treturn nil, fmt.Errorf(\"failed to marshal request: %w\", err)\n86: \t}\n87: \n88: \treq, err := http.NewRequestWithContext(ctx, http.MethodPost, endpoint, bytes.NewReader(bodyBytes))\n89: \tif err != nil {\n90: \t\treturn nil, fmt.Errorf(\"failed to create request: %w\", err)\n91: \t}\n92: \n93: \treq.Header.Set(\"Content-Type\", \"application/json\")\n94: \n95: \tsaToken, err := readServiceAccountToken()\n96: \tif err == nil && saToken != \"\" {\n97: \t\treq.Header.Set(\"Authorization\", \"Bearer \"+saToken)\n98: \t}\n99: \n100: \tresp, err := m.httpClient.Do(req)\n101: \tif err != nil {\n102: \t\treturn nil, &WorkloadManagerError{\n103: \t\t\tStatusCode: http.StatusInternalServerError,\n104: \t\t\tMsg:        fmt.Sprintf(\"failed to connect to workload manager: %v\", err),\n105: \t\t}\n106: \t}\n107: \tdefer resp.Body.Close()\n108: \n109: \trespBody, err := io.ReadAll(resp.Body)\n110: \tif err != nil {\n111: \t\treturn nil, fmt.Errorf(\"failed to read response: %w\", err)\n112: \t}\n113: \n114: \tif resp.StatusCode != http.StatusOK {\n115: \t\treturn nil, &WorkloadManagerError{\n116: \t\t\tStatusCode: resp.StatusCode,\n117: \t\t\tMsg:        string(respBody),\n118: \t\t}\n119: \t}\n120: \n121: \tvar createResp types.CreateSandboxResponse\n122: \tif err := json.Unmarshal(respBody, &createResp); err != nil {\n123: \t\treturn nil, fmt.Errorf(\"failed to parse response: %w\", err)\n124: \t}\n125: \n126: \tif createResp.SessionID == \"\" {\n127: \t\treturn nil, fmt.Errorf(\"empty sessionId in response\")\n128: \t}\n129: \n130: \tsandbox := &types.SandboxInfo{\n131: \t\tKind:             kind,\n132: \t\tSandboxID:        createResp.SandboxID,\n133: \t\tSandboxNamespace: IdentityNamespace,\n134: \t\tSandboxName:      createResp.SandboxName,\n135: \t\tName:             name,\n136: \t\tSessionID:        createResp.SessionID,\n137: \t\tCreatedAt:        time.Now(),\n138: \t\tExpiresAt:        time.Now().Add(30 * time.Minute),\n139: \t\tStatus:           \"Running\",\n140: \t\tEntryPoints:      createResp.EntryPoints,\n141: \t}\n142: \n143: \tif err := m.storeClient.StoreSandbox(ctx, sandbox); err != nil {\n144: \t\treturn nil, fmt.Errorf(\"failed to store sandbox: %w\", err)\n145: \t}\n146: \n147: \treturn sandbox, nil\n148: }\n149: \n150: func readServiceAccountToken() (string, error) {\n151: \ttokenPath := \"/var/run/secrets/kubernetes.io/serviceaccount/token\"\n152: \tdata, err := os.ReadFile(tokenPath)\n153: \tif err != nil {\n154: \t\treturn \"\", err\n155: \t}\n156: \treturn strings.TrimSpace(string(data)), nil\n157: }\n\n(End of file - total 157 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"bytes\"\n\t\"context\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"io\"\n\t\"net/http\"\n\t\"os\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n\t\"golang.org/x/net/http2\"\n)\n\ntype sessionManager struct {\n\tstoreClient     Store\n\tworkloadMgrAddr string","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/session_manager.go","time":{"start":1775898338576,"end":1775898338607}}}}
{"type":"tool_use","timestamp":1775898338610,"sessionID":"ses_284369e59ffeHdgLjlbiaIcKCA","part":{"id":"prt_d7bca1c42001jF5Fs5jtxj5p4t","messageID":"msg_d7bc9e0c9001Dm5Wr7KgI5SYDQ","sessionID":"ses_284369e59ffeHdgLjlbiaIcKCA","type":"tool","tool":"read","callID":"toolu_tool-07e8de7f1c9e4391b331b7f7d51e1502","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/reverse_proxy.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/reverse_proxy.go</path>\n<type>file</type>\n<content>\n1: package router\n2: \n3: import (\n4: \t\"encoding/json\"\n5: \t\"net/http\"\n6: \t\"net/url\"\n7: \t\"strings\"\n8: \n9: \t\"github.com/gin-gonic/gin\"\n10: \t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n11: )\n12: \n13: func newReverseProxy(target *url.URL, jwt string, sessionID string) *ReverseProxyWrapper {\n14: \tdirector := func(req *http.Request) {\n15: \t\tpath := req.URL.Path\n16: \t\tif path != \"\" && path[0] != '/' {\n17: \t\t\tpath = \"/\" + path\n18: \t\t}\n19: \n20: \t\treq.URL.Scheme = target.Scheme\n21: \t\treq.URL.Host = target.Host\n22: \t\treq.URL.Path = path\n23: \t\treq.URL.RawPath = \"\"\n24: \t\treq.Host = target.Host\n25: \n26: \t\treq.Header.Set(\"X-Forwarded-Host\", req.Header.Get(\"Host\"))\n27: \n28: \t\tproto := \"http\"\n29: \t\tif req.TLS != nil {\n30: \t\t\tproto = \"https\"\n31: \t\t}\n32: \t\treq.Header.Set(\"X-Forwarded-Proto\", proto)\n33: \n34: \t\texistingXFF := req.Header.Get(\"X-Forwarded-For\")\n35: \t\tclientIP := req.RemoteAddr\n36: \t\tif existingXFF != \"\" {\n37: \t\t\tclientIP = existingXFF + \",\" + clientIP\n38: \t\t}\n39: \t\treq.Header.Set(\"X-Forwarded-For\", clientIP)\n40: \n41: \t\tif jwt != \"\" {\n42: \t\t\treq.Header.Set(\"Authorization\", \"Bearer \"+jwt)\n43: \t\t}\n44: \t}\n45: \n46: \tmodifyResponse := func(resp *http.Response) error {\n47: \t\tresp.Header.Set(\"x-agentcube-session-id\", sessionID)\n48: \t\treturn nil\n49: \t}\n50: \n51: \terrorHandler := func(resp http.ResponseWriter, req *http.Request, err error) {\n52: \t\terrMsg := err.Error()\n53: \t\tvar statusCode int\n54: \t\tvar message string\n55: \n56: \t\tif strings.Contains(errMsg, \"connection refused\") {\n57: \t\t\tstatusCode = http.StatusBadGateway\n58: \t\t\tmessage = \"sandbox unreachable\"\n59: \t\t} else if strings.Contains(errMsg, \"timeout\") {\n60: \t\t\tstatusCode = http.StatusGatewayTimeout\n61: \t\t\tmessage = \"sandbox timeout\"\n62: \t\t} else {\n63: \t\t\tstatusCode = http.StatusBadGateway\n64: \t\t\tmessage = \"sandbox unreachable\"\n65: \t\t}\n66: \n67: \t\tresp.Header().Set(\"Content-Type\", \"application/json\")\n68: \t\tresp.WriteHeader(statusCode)\n69: \t\tjson.NewEncoder(resp).Encode(gin.H{\"error\": message})\n70: \t}\n71: \n72: \treturn &ReverseProxyWrapper{\n73: \t\tdirector:       director,\n74: \t\tmodifyResponse: modifyResponse,\n75: \t\terrorHandler:   errorHandler,\n76: \t}\n77: }\n78: \n79: type ReverseProxyWrapper struct {\n80: \tdirector       func(*http.Request)\n81: \tmodifyResponse func(*http.Response) error\n82: \terrorHandler   func(http.ResponseWriter, *http.Request, error)\n83: }\n84: \n85: func (rpw *ReverseProxyWrapper) Director(req *http.Request) {\n86: \trpw.director(req)\n87: }\n88: \n89: func (rpw *ReverseProxyWrapper) ModifyResponse(resp *http.Response) error {\n90: \treturn rpw.modifyResponse(resp)\n91: }\n92: \n93: func (rpw *ReverseProxyWrapper) ErrorHandler(resp http.ResponseWriter, req *http.Request, err error) {\n94: \trpw.errorHandler(resp, req, err)\n95: }\n96: \n97: func selectEntryPoint(entryPoints []types.SandboxEntryPoint, invocationPath string) *types.SandboxEntryPoint {\n98: \tif len(entryPoints) == 0 {\n99: \t\treturn nil\n100: \t}\n101: \n102: \tfor _, ep := range entryPoints {\n103: \t\tif strings.HasPrefix(invocationPath, ep.Path) {\n104: \t\t\treturn &ep\n105: \t\t}\n106: \t}\n107: \n108: \treturn &entryPoints[0]\n109: }\n110: \n111: func buildTargetURL(ep *types.SandboxEntryPoint) (*url.URL, error) {\n112: \tendpoint := ep.Endpoint\n113: \tif ep.Protocol != \"\" && !strings.Contains(endpoint, \"://\") {\n114: \t\tendpoint = strings.ToLower(ep.Protocol) + \"://\" + endpoint\n115: \t}\n116: \treturn url.Parse(endpoint)\n117: }\n\n(End of file - total 117 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"encoding/json\"\n\t\"net/http\"\n\t\"net/url\"\n\t\"strings\"\n\n\t\"github.com/gin-gonic/gin\"\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n)\n\nfunc newReverseProxy(target *url.URL, jwt string, sessionID string) *ReverseProxyWrapper {\n\tdirector := func(req *http.Request) {\n\t\tpath := req.URL.Path\n\t\tif path != \"\" && path[0] != '/' {\n\t\t\tpath = \"/\" + path\n\t\t}\n\n\t\treq.URL.Scheme = target.Scheme","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/reverse_proxy.go","time":{"start":1775898338580,"end":1775898338609}}}}
