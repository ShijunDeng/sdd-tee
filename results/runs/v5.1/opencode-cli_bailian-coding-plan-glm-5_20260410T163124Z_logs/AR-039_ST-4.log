{"type":"tool_use","timestamp":1775898349861,"sessionID":"ses_284369e59ffeHdgLjlbiaIcKCA","part":{"id":"prt_d7bca3a07001BQ8oNBrMHg3jsn","messageID":"msg_d7bca256c001Ki2KAVxAV8cLZ8","sessionID":"ses_284369e59ffeHdgLjlbiaIcKCA","type":"tool","tool":"read","callID":"toolu_tool-d0ad2f603e264275bae459729c12c832","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/middleware.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/middleware.go</path>\n<type>file</type>\n<content>\n1: package router\n2: \n3: import (\n4: \t\"net/http\"\n5: \t\"time\"\n6: \n7: \t\"github.com/gin-gonic/gin\"\n8: )\n9: \n10: func concurrencyLimitMiddleware(maxConcurrent int) gin.HandlerFunc {\n11: \tif maxConcurrent <= 0 {\n12: \t\tmaxConcurrent = 1000\n13: \t}\n14: \n15: \tsem := make(chan struct{}, maxConcurrent)\n16: \n17: \treturn func(c *gin.Context) {\n18: \t\tselect {\n19: \t\tcase sem <- struct{}{}:\n20: \t\t\tdefer func() { <-sem }()\n21: \t\t\tc.Next()\n22: \t\tdefault:\n23: \t\t\tc.JSON(http.StatusTooManyRequests, gin.H{\n24: \t\t\t\t\"error\": \"server overloaded, please try again later\",\n25: \t\t\t\t\"code\":  \"SERVER_OVERLOADED\",\n26: \t\t\t})\n27: \t\t\tc.Abort()\n28: \t\t}\n29: \t}\n30: }\n31: \n32: func loggingMiddleware(logger Logger) gin.HandlerFunc {\n33: \treturn func(c *gin.Context) {\n34: \t\tstart := time.Now()\n35: \n36: \t\tc.Next()\n37: \n38: \t\tif logger == nil {\n39: \t\t\treturn\n40: \t\t}\n41: \n42: \t\tduration := time.Since(start)\n43: \t\tstatus := c.Writer.Status()\n44: \n45: \t\tlogger.Info(\"request\",\n46: \t\t\t\"method\", c.Request.Method,\n47: \t\t\t\"path\", c.Request.URL.Path,\n48: \t\t\t\"status\", status,\n49: \t\t\t\"duration\", duration,\n50: \t\t)\n51: \t}\n52: }\n53: \n54: func recoveryMiddleware(logger Logger) gin.HandlerFunc {\n55: \treturn func(c *gin.Context) {\n56: \t\tdefer func() {\n57: \t\t\tif err := recover(); err != nil {\n58: \t\t\t\tif logger != nil {\n59: \t\t\t\t\tlogger.Error(\"panic recovered\",\n60: \t\t\t\t\t\t\"error\", err,\n61: \t\t\t\t\t\t\"path\", c.Request.URL.Path,\n62: \t\t\t\t\t\t\"method\", c.Request.Method,\n63: \t\t\t\t\t)\n64: \t\t\t\t}\n65: \n66: \t\t\t\tc.JSON(http.StatusInternalServerError, gin.H{\n67: \t\t\t\t\t\"error\": \"internal server error\",\n68: \t\t\t\t})\n69: \t\t\t\tc.Abort()\n70: \t\t\t}\n71: \t\t}()\n72: \t\tc.Next()\n73: \t}\n74: }\n\n(End of file - total 74 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"net/http\"\n\t\"time\"\n\n\t\"github.com/gin-gonic/gin\"\n)\n\nfunc concurrencyLimitMiddleware(maxConcurrent int) gin.HandlerFunc {\n\tif maxConcurrent <= 0 {\n\t\tmaxConcurrent = 1000\n\t}\n\n\tsem := make(chan struct{}, maxConcurrent)\n\n\treturn func(c *gin.Context) {\n\t\tselect {\n\t\tcase sem <- struct{}{}:\n\t\t\tdefer func() { <-sem }()","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/middleware.go","time":{"start":1775898349823,"end":1775898349860}}}}
{"type":"tool_use","timestamp":1775898349863,"sessionID":"ses_284369e59ffeHdgLjlbiaIcKCA","part":{"id":"prt_d7bca471b001iUaMwFZv8WLTei","messageID":"msg_d7bca256c001Ki2KAVxAV8cLZ8","sessionID":"ses_284369e59ffeHdgLjlbiaIcKCA","type":"tool","tool":"read","callID":"toolu_tool-bb742de4d15949678350aef198bf303f","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/picod/auth.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/picod/auth.go</path>\n<type>file</type>\n<content>\n1: package picod\n2: \n3: import (\n4: \t\"crypto/rsa\"\n5: \t\"crypto/x509\"\n6: \t\"encoding/pem\"\n7: \t\"errors\"\n8: \t\"fmt\"\n9: \t\"net/http\"\n10: \t\"os\"\n11: \t\"strings\"\n12: \t\"sync\"\n13: \t\"time\"\n14: \n15: \t\"github.com/gin-gonic/gin\"\n16: \t\"github.com/golang-jwt/jwt/v5\"\n17: )\n18: \n19: const (\n20: \tPublicKeyEnvVar = \"PICOD_AUTH_PUBLIC_KEY\"\n21: \tMaxBodySize     = 32 << 20\n22: )\n23: \n24: type AuthManager struct {\n25: \tpublicKey *rsa.PublicKey\n26: \tmutex     sync.RWMutex\n27: }\n28: \n29: func NewAuthManager() (*AuthManager, error) {\n30: \tpublicKey, err := LoadPublicKeyFromEnv()\n31: \tif err != nil {\n32: \t\treturn nil, fmt.Errorf(\"failed to load public key: %w\", err)\n33: \t}\n34: \treturn &AuthManager{\n35: \t\tpublicKey: publicKey,\n36: \t}, nil\n37: }\n38: \n39: func LoadPublicKeyFromEnv() (*rsa.PublicKey, error) {\n40: \tpemKey := strings.TrimSpace(os.Getenv(PublicKeyEnvVar))\n41: \tif pemKey == \"\" {\n42: \t\treturn nil, errors.New(\"public key environment variable not set\")\n43: \t}\n44: \n45: \tblock, _ := pem.Decode([]byte(pemKey))\n46: \tif block == nil {\n47: \t\treturn nil, errors.New(\"failed to decode PEM block\")\n48: \t}\n49: \n50: \tif block.Type != \"PUBLIC KEY\" {\n51: \t\treturn nil, fmt.Errorf(\"expected PUBLIC KEY PEM block, got %s\", block.Type)\n52: \t}\n53: \n54: \tpub, err := x509.ParsePKIXPublicKey(block.Bytes)\n55: \tif err != nil {\n56: \t\treturn nil, fmt.Errorf(\"failed to parse public key: %w\", err)\n57: \t}\n58: \n59: \trsaPub, ok := pub.(*rsa.PublicKey)\n60: \tif !ok {\n61: \t\treturn nil, errors.New(\"public key is not RSA\")\n62: \t}\n63: \n64: \treturn rsaPub, nil\n65: }\n66: \n67: func (a *AuthManager) AuthMiddleware() gin.HandlerFunc {\n68: \treturn func(c *gin.Context) {\n69: \t\tauthHeader := c.GetHeader(\"Authorization\")\n70: \t\tif authHeader == \"\" {\n71: \t\t\tc.JSON(401, gin.H{\"error\": \"missing authorization header\"})\n72: \t\t\tc.Abort()\n73: \t\t\treturn\n74: \t\t}\n75: \n76: \t\tif !strings.HasPrefix(authHeader, \"Bearer \") {\n77: \t\t\tc.JSON(401, gin.H{\"error\": \"invalid token format\"})\n78: \t\t\tc.Abort()\n79: \t\t\treturn\n80: \t\t}\n81: \n82: \t\ttokenString := strings.TrimPrefix(authHeader, \"Bearer \")\n83: \n84: \t\ta.mutex.RLock()\n85: \t\tpubKey := a.publicKey\n86: \t\ta.mutex.RUnlock()\n87: \n88: \t\ttoken, err := jwt.Parse(tokenString, func(token *jwt.Token) (interface{}, error) {\n89: \t\t\tif _, ok := token.Method.(*jwt.SigningMethodRSA); !ok {\n90: \t\t\t\treturn nil, fmt.Errorf(\"invalid signing method\")\n91: \t\t\t}\n92: \t\t\treturn pubKey, nil\n93: \t\t}, jwt.WithExpirationRequired(), jwt.WithIssuedAt(), jwt.WithLeeway(time.Minute))\n94: \n95: \t\tif err != nil {\n96: \t\t\tif errors.Is(err, jwt.ErrTokenExpired) {\n97: \t\t\t\tc.JSON(401, gin.H{\"error\": \"token is expired\"})\n98: \t\t\t} else if errors.Is(err, jwt.ErrTokenSignatureInvalid) {\n99: \t\t\t\tc.JSON(401, gin.H{\"error\": \"invalid signature\"})\n100: \t\t\t} else if strings.Contains(err.Error(), \"invalid signing method\") {\n101: \t\t\t\tc.JSON(401, gin.H{\"error\": \"invalid signing method\"})\n102: \t\t\t} else {\n103: \t\t\t\tc.JSON(401, gin.H{\"error\": err.Error()})\n104: \t\t\t}\n105: \t\t\tc.Abort()\n106: \t\t\treturn\n107: \t\t}\n108: \n109: \t\tif !token.Valid {\n110: \t\t\tc.JSON(401, gin.H{\"error\": \"invalid token\"})\n111: \t\t\tc.Abort()\n112: \t\t\treturn\n113: \t\t}\n114: \n115: \t\thttp.MaxBytesReader(c.Writer, c.Request.Body, MaxBodySize)\n116: \t\tc.Next()\n117: \t}\n118: }\n119: \n120: func (a *AuthManager) SetPublicKey(key *rsa.PublicKey) {\n121: \ta.mutex.Lock()\n122: \ta.publicKey = key\n123: \ta.mutex.Unlock()\n124: }\n125: \n126: func (a *AuthManager) GetPublicKey() *rsa.PublicKey {\n127: \ta.mutex.RLock()\n128: \tdefer a.mutex.RUnlock()\n129: \treturn a.publicKey\n130: }\n\n(End of file - total 130 lines)\n</content>","metadata":{"preview":"package picod\n\nimport (\n\t\"crypto/rsa\"\n\t\"crypto/x509\"\n\t\"encoding/pem\"\n\t\"errors\"\n\t\"fmt\"\n\t\"net/http\"\n\t\"os\"\n\t\"strings\"\n\t\"sync\"\n\t\"time\"\n\n\t\"github.com/gin-gonic/gin\"\n\t\"github.com/golang-jwt/jwt/v5\"\n)\n\nconst (\n\tPublicKeyEnvVar = \"PICOD_AUTH_PUBLIC_KEY\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/picod/auth.go","time":{"start":1775898349834,"end":1775898349862}}}}
{"type":"tool_use","timestamp":1775898349864,"sessionID":"ses_284369e59ffeHdgLjlbiaIcKCA","part":{"id":"prt_d7bca49fc001wliH0nnFIaqHff","messageID":"msg_d7bca256c001Ki2KAVxAV8cLZ8","sessionID":"ses_284369e59ffeHdgLjlbiaIcKCA","type":"tool","tool":"read","callID":"toolu_tool-3a7b3820c77f4f6f85cdec57082b06e5","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/picod/auth_test.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/picod/auth_test.go</path>\n<type>file</type>\n<content>\n1: package picod\n2: \n3: import (\n4: \t\"crypto/ecdsa\"\n5: \t\"crypto/elliptic\"\n6: \t\"crypto/rand\"\n7: \t\"crypto/rsa\"\n8: \t\"crypto/x509\"\n9: \t\"encoding/pem\"\n10: \t\"net/http/httptest\"\n11: \t\"os\"\n12: \t\"sync\"\n13: \t\"testing\"\n14: \t\"time\"\n15: \n16: \t\"github.com/gin-gonic/gin\"\n17: \t\"github.com/golang-jwt/jwt/v5\"\n18: \t\"github.com/stretchr/testify/assert\"\n19: \t\"github.com/stretchr/testify/require\"\n20: )\n21: \n22: func TestNewAuthManagerValid(t *testing.T) {\n23: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n24: \trequire.NoError(t, err)\n25: \n26: \tpublicKeyPEM := encodePublicKeyPEMForTest(&privateKey.PublicKey)\n27: \n28: \toldEnv := os.Getenv(PublicKeyEnvVar)\n29: \tos.Setenv(PublicKeyEnvVar, publicKeyPEM)\n30: \tt.Cleanup(func() {\n31: \t\tif oldEnv != \"\" {\n32: \t\t\tos.Setenv(PublicKeyEnvVar, oldEnv)\n33: \t\t} else {\n34: \t\t\tos.Unsetenv(PublicKeyEnvVar)\n35: \t\t}\n36: \t})\n37: \n38: \tauthMgr, err := NewAuthManager()\n39: \trequire.NoError(t, err)\n40: \tassert.NotNil(t, authMgr)\n41: \tassert.NotNil(t, authMgr.GetPublicKey())\n42: }\n43: \n44: func TestNewAuthManagerMissingKey(t *testing.T) {\n45: \toldEnv := os.Getenv(PublicKeyEnvVar)\n46: \tos.Unsetenv(PublicKeyEnvVar)\n47: \tt.Cleanup(func() {\n48: \t\tif oldEnv != \"\" {\n49: \t\t\tos.Setenv(PublicKeyEnvVar, oldEnv)\n50: \t\t}\n51: \t})\n52: \n53: \t_, err := NewAuthManager()\n54: \tassert.Error(t, err)\n55: \tassert.Contains(t, err.Error(), \"failed to load public key\")\n56: \tassert.Contains(t, err.Error(), \"public key environment variable not set\")\n57: }\n58: \n59: func TestNewAuthManagerInvalidPEM(t *testing.T) {\n60: \toldEnv := os.Getenv(PublicKeyEnvVar)\n61: \tos.Setenv(PublicKeyEnvVar, \"invalid pem data\")\n62: \tt.Cleanup(func() {\n63: \t\tif oldEnv != \"\" {\n64: \t\t\tos.Setenv(PublicKeyEnvVar, oldEnv)\n65: \t\t} else {\n66: \t\t\tos.Unsetenv(PublicKeyEnvVar)\n67: \t\t}\n68: \t})\n69: \n70: \t_, err := NewAuthManager()\n71: \tassert.Error(t, err)\n72: \tassert.Contains(t, err.Error(), \"failed to load public key\")\n73: \tassert.Contains(t, err.Error(), \"failed to decode PEM block\")\n74: }\n75: \n76: func TestNewAuthManagerWrongKeyType(t *testing.T) {\n77: \tprivateKey, err := ecdsa.GenerateKey(elliptic.P256(), rand.Reader)\n78: \trequire.NoError(t, err)\n79: \n80: \tpubBytes, err := x509.MarshalPKIXPublicKey(&privateKey.PublicKey)\n81: \trequire.NoError(t, err)\n82: \n83: \tpemData := pem.EncodeToMemory(&pem.Block{\n84: \t\tType:  \"PUBLIC KEY\",\n85: \t\tBytes: pubBytes,\n86: \t})\n87: \n88: \toldEnv := os.Getenv(PublicKeyEnvVar)\n89: \tos.Setenv(PublicKeyEnvVar, string(pemData))\n90: \tt.Cleanup(func() {\n91: \t\tif oldEnv != \"\" {\n92: \t\t\tos.Setenv(PublicKeyEnvVar, oldEnv)\n93: \t\t} else {\n94: \t\t\tos.Unsetenv(PublicKeyEnvVar)\n95: \t\t}\n96: \t})\n97: \n98: \t_, err = NewAuthManager()\n99: \tassert.Error(t, err)\n100: \tassert.Contains(t, err.Error(), \"failed to load public key\")\n101: \tassert.Contains(t, err.Error(), \"public key is not RSA\")\n102: }\n103: \n104: func TestAuthMiddlewareInvalidSignature(t *testing.T) {\n105: \tprivateKey1, err := rsa.GenerateKey(rand.Reader, 2048)\n106: \trequire.NoError(t, err)\n107: \n108: \tprivateKey2, err := rsa.GenerateKey(rand.Reader, 2048)\n109: \trequire.NoError(t, err)\n110: \n111: \tpublicKeyPEM := encodePublicKeyPEMForTest(&privateKey1.PublicKey)\n112: \n113: \toldEnv := os.Getenv(PublicKeyEnvVar)\n114: \tos.Setenv(PublicKeyEnvVar, publicKeyPEM)\n115: \tt.Cleanup(func() {\n116: \t\tif oldEnv != \"\" {\n117: \t\t\tos.Setenv(PublicKeyEnvVar, oldEnv)\n118: \t\t} else {\n119: \t\t\tos.Unsetenv(PublicKeyEnvVar)\n120: \t\t}\n121: \t})\n122: \n123: \tauthMgr, err := NewAuthManager()\n124: \trequire.NoError(t, err)\n125: \n126: \tgin.SetMode(gin.TestMode)\n127: \tengine := gin.New()\n128: \tapi := engine.Group(\"/api\")\n129: \tapi.Use(authMgr.AuthMiddleware())\n130: \tapi.POST(\"/test\", func(c *gin.Context) {\n131: \t\tc.JSON(200, gin.H{\"status\": \"ok\"})\n132: \t})\n133: \n134: \ttokenSignedWithKey2 := generateTestJWT(privateKey2, false)\n135: \n136: \tw := httptest.NewRecorder()\n137: \treq := httptest.NewRequest(\"POST\", \"/api/test\", nil)\n138: \treq.Header.Set(\"Authorization\", \"Bearer \"+tokenSignedWithKey2)\n139: \tengine.ServeHTTP(w, req)\n140: \n141: \tassert.Equal(t, 401, w.Code)\n142: \tassert.Contains(t, w.Body.String(), \"invalid signature\")\n143: }\n144: \n145: func TestAuthMiddlewareEmptyToken(t *testing.T) {\n146: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n147: \trequire.NoError(t, err)\n148: \n149: \tpublicKeyPEM := encodePublicKeyPEMForTest(&privateKey.PublicKey)\n150: \n151: \toldEnv := os.Getenv(PublicKeyEnvVar)\n152: \tos.Setenv(PublicKeyEnvVar, publicKeyPEM)\n153: \tt.Cleanup(func() {\n154: \t\tif oldEnv != \"\" {\n155: \t\t\tos.Setenv(PublicKeyEnvVar, oldEnv)\n156: \t\t} else {\n157: \t\t\tos.Unsetenv(PublicKeyEnvVar)\n158: \t\t}\n159: \t})\n160: \n161: \tauthMgr, err := NewAuthManager()\n162: \trequire.NoError(t, err)\n163: \n164: \tgin.SetMode(gin.TestMode)\n165: \tengine := gin.New()\n166: \tapi := engine.Group(\"/api\")\n167: \tapi.Use(authMgr.AuthMiddleware())\n168: \tapi.POST(\"/test\", func(c *gin.Context) {\n169: \t\tc.JSON(200, gin.H{\"status\": \"ok\"})\n170: \t})\n171: \n172: \tw := httptest.NewRecorder()\n173: \treq := httptest.NewRequest(\"POST\", \"/api/test\", nil)\n174: \treq.Header.Set(\"Authorization\", \"Bearer \")\n175: \tengine.ServeHTTP(w, req)\n176: \n177: \tassert.Equal(t, 401, w.Code)\n178: }\n179: \n180: func TestSetGetPublicKey(t *testing.T) {\n181: \tprivateKey1, err := rsa.GenerateKey(rand.Reader, 2048)\n182: \trequire.NoError(t, err)\n183: \n184: \tprivateKey2, err := rsa.GenerateKey(rand.Reader, 2048)\n185: \trequire.NoError(t, err)\n186: \n187: \tpublicKeyPEM := encodePublicKeyPEMForTest(&privateKey1.PublicKey)\n188: \n189: \toldEnv := os.Getenv(PublicKeyEnvVar)\n190: \tos.Setenv(PublicKeyEnvVar, publicKeyPEM)\n191: \tt.Cleanup(func() {\n192: \t\tif oldEnv != \"\" {\n193: \t\t\tos.Setenv(PublicKeyEnvVar, oldEnv)\n194: \t\t} else {\n195: \t\t\tos.Unsetenv(PublicKeyEnvVar)\n196: \t\t}\n197: \t})\n198: \n199: \tauthMgr, err := NewAuthManager()\n200: \trequire.NoError(t, err)\n201: \n202: \tinitialKey := authMgr.GetPublicKey()\n203: \tassert.Equal(t, &privateKey1.PublicKey, initialKey)\n204: \n205: \tauthMgr.SetPublicKey(&privateKey2.PublicKey)\n206: \n207: \tnewKey := authMgr.GetPublicKey()\n208: \tassert.Equal(t, &privateKey2.PublicKey, newKey)\n209: \tassert.NotEqual(t, initialKey, newKey)\n210: }\n211: \n212: func TestPublicKeyConcurrency(t *testing.T) {\n213: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n214: \trequire.NoError(t, err)\n215: \n216: \tpublicKeyPEM := encodePublicKeyPEMForTest(&privateKey.PublicKey)\n217: \n218: \toldEnv := os.Getenv(PublicKeyEnvVar)\n219: \tos.Setenv(PublicKeyEnvVar, publicKeyPEM)\n220: \tt.Cleanup(func() {\n221: \t\tif oldEnv != \"\" {\n222: \t\t\tos.Setenv(PublicKeyEnvVar, oldEnv)\n223: \t\t} else {\n224: \t\t\tos.Unsetenv(PublicKeyEnvVar)\n225: \t\t}\n226: \t})\n227: \n228: \tauthMgr, err := NewAuthManager()\n229: \trequire.NoError(t, err)\n230: \n231: \tkey1, err := rsa.GenerateKey(rand.Reader, 2048)\n232: \trequire.NoError(t, err)\n233: \tkey2, err := rsa.GenerateKey(rand.Reader, 2048)\n234: \trequire.NoError(t, err)\n235: \tkey3, err := rsa.GenerateKey(rand.Reader, 2048)\n236: \trequire.NoError(t, err)\n237: \n238: \tnumOps := 100\n239: \tdone := make(chan bool, numOps)\n240: \n241: \tvar wg sync.WaitGroup\n242: \twg.Add(numOps)\n243: \n244: \tfor i := 0; i < numOps; i++ {\n245: \t\tgo func(idx int) {\n246: \t\t\tdefer wg.Done()\n247: \t\t\tif idx%3 == 0 {\n248: \t\t\t\tauthMgr.SetPublicKey(&key1.PublicKey)\n249: \t\t\t} else if idx%3 == 1 {\n250: \t\t\t\tauthMgr.SetPublicKey(&key2.PublicKey)\n251: \t\t\t} else {\n252: \t\t\t\tauthMgr.SetPublicKey(&key3.PublicKey)\n253: \t\t\t}\n254: \t\t\t_ = authMgr.GetPublicKey()\n255: \t\t\tdone <- true\n256: \t\t}(i)\n257: \t}\n258: \n259: \twg.Wait()\n260: \n261: \tfor i := 0; i < numOps; i++ {\n262: \t\tselect {\n263: \t\tcase <-done:\n264: \t\tcase <-time.After(5 * time.Second):\n265: \t\t\tt.Fatal(\"concurrent operation timed out\")\n266: \t\t}\n267: \t}\n268: \n269: \tfinalKey := authMgr.GetPublicKey()\n270: \tassert.NotNil(t, finalKey)\n271: }\n272: \n273: func TestAuthMiddlewareKeyRotation(t *testing.T) {\n274: \tkey1, err := rsa.GenerateKey(rand.Reader, 2048)\n275: \trequire.NoError(t, err)\n276: \n277: \tkey2, err := rsa.GenerateKey(rand.Reader, 2048)\n278: \trequire.NoError(t, err)\n279: \n280: \tpublicKeyPEM := encodePublicKeyPEMForTest(&key1.PublicKey)\n281: \n282: \toldEnv := os.Getenv(PublicKeyEnvVar)\n283: \tos.Setenv(PublicKeyEnvVar, publicKeyPEM)\n284: \tt.Cleanup(func() {\n285: \t\tif oldEnv != \"\" {\n286: \t\t\tos.Setenv(PublicKeyEnvVar, oldEnv)\n287: \t\t} else {\n288: \t\t\tos.Unsetenv(PublicKeyEnvVar)\n289: \t\t}\n290: \t})\n291: \n292: \tauthMgr, err := NewAuthManager()\n293: \trequire.NoError(t, err)\n294: \n295: \tgin.SetMode(gin.TestMode)\n296: \tengine := gin.New()\n297: \tapi := engine.Group(\"/api\")\n298: \tapi.Use(authMgr.AuthMiddleware())\n299: \tapi.POST(\"/test\", func(c *gin.Context) {\n300: \t\tc.JSON(200, gin.H{\"status\": \"ok\"})\n301: \t})\n302: \n303: \ttoken1 := generateTestJWT(key1, false)\n304: \n305: \tw := httptest.NewRecorder()\n306: \treq := httptest.NewRequest(\"POST\", \"/api/test\", nil)\n307: \treq.Header.Set(\"Authorization\", \"Bearer \"+token1)\n308: \tengine.ServeHTTP(w, req)\n309: \tassert.Equal(t, 200, w.Code)\n310: \n311: \tauthMgr.SetPublicKey(&key2.PublicKey)\n312: \n313: \ttoken2 := generateTestJWT(key2, false)\n314: \n315: \tw = httptest.NewRecorder()\n316: \treq = httptest.NewRequest(\"POST\", \"/api/test\", nil)\n317: \treq.Header.Set(\"Authorization\", \"Bearer \"+token2)\n318: \tengine.ServeHTTP(w, req)\n319: \tassert.Equal(t, 200, w.Code)\n320: \n321: \tw = httptest.NewRecorder()\n322: \treq = httptest.NewRequest(\"POST\", \"/api/test\", nil)\n323: \treq.Header.Set(\"Authorization\", \"Bearer \"+token1)\n324: \tengine.ServeHTTP(w, req)\n325: \tassert.Equal(t, 401, w.Code)\n326: \tassert.Contains(t, w.Body.String(), \"invalid signature\")\n327: }\n328: \n329: func TestAuthMiddlewareMalformedAuthHeader(t *testing.T) {\n330: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n331: \trequire.NoError(t, err)\n332: \n333: \tpublicKeyPEM := encodePublicKeyPEMForTest(&privateKey.PublicKey)\n334: \n335: \toldEnv := os.Getenv(PublicKeyEnvVar)\n336: \tos.Setenv(PublicKeyEnvVar, publicKeyPEM)\n337: \tt.Cleanup(func() {\n338: \t\tif oldEnv != \"\" {\n339: \t\t\tos.Setenv(PublicKeyEnvVar, oldEnv)\n340: \t\t} else {\n341: \t\t\tos.Unsetenv(PublicKeyEnvVar)\n342: \t\t}\n343: \t})\n344: \n345: \tauthMgr, err := NewAuthManager()\n346: \trequire.NoError(t, err)\n347: \n348: \tgin.SetMode(gin.TestMode)\n349: \tengine := gin.New()\n350: \tapi := engine.Group(\"/api\")\n351: \tapi.Use(authMgr.AuthMiddleware())\n352: \tapi.POST(\"/test\", func(c *gin.Context) {\n353: \t\tc.JSON(200, gin.H{\"status\": \"ok\"})\n354: \t})\n355: \n356: \tw := httptest.NewRecorder()\n357: \treq := httptest.NewRequest(\"POST\", \"/api/test\", nil)\n358: \treq.Header.Set(\"Authorization\", \"Basic some-token\")\n359: \tengine.ServeHTTP(w, req)\n360: \n361: \tassert.Equal(t, 401, w.Code)\n362: \tassert.Contains(t, w.Body.String(), \"invalid token format\")\n363: }\n364: \n365: func TestAuthMiddlewareNoBearerPrefix(t *testing.T) {\n366: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n367: \trequire.NoError(t, err)\n368: \n369: \tpublicKeyPEM := encodePublicKeyPEMForTest(&privateKey.PublicKey)\n370: \n371: \toldEnv := os.Getenv(PublicKeyEnvVar)\n372: \tos.Setenv(PublicKeyEnvVar, publicKeyPEM)\n373: \tt.Cleanup(func() {\n374: \t\tif oldEnv != \"\" {\n375: \t\t\tos.Setenv(PublicKeyEnvVar, oldEnv)\n376: \t\t} else {\n377: \t\t\tos.Unsetenv(PublicKeyEnvVar)\n378: \t\t}\n379: \t})\n380: \n381: \tauthMgr, err := NewAuthManager()\n382: \trequire.NoError(t, err)\n383: \n384: \tgin.SetMode(gin.TestMode)\n385: \tengine := gin.New()\n386: \tapi := engine.Group(\"/api\")\n387: \tapi.Use(authMgr.AuthMiddleware())\n388: \tapi.POST(\"/test\", func(c *gin.Context) {\n389: \t\tc.JSON(200, gin.H{\"status\": \"ok\"})\n390: \t})\n391: \n392: \ttoken := generateTestJWT(privateKey, false)\n393: \n394: \tw := httptest.NewRecorder()\n395: \treq := httptest.NewRequest(\"POST\", \"/api/test\", nil)\n396: \treq.Header.Set(\"Authorization\", token)\n397: \tengine.ServeHTTP(w, req)\n398: \n399: \tassert.Equal(t, 401, w.Code)\n400: \tassert.Contains(t, w.Body.String(), \"invalid token format\")\n401: }\n402: \n403: func TestAuthMiddlewareBearerPrefixOnly(t *testing.T) {\n404: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n405: \trequire.NoError(t, err)\n406: \n407: \tpublicKeyPEM := encodePublicKeyPEMForTest(&privateKey.PublicKey)\n408: \n409: \toldEnv := os.Getenv(PublicKeyEnvVar)\n410: \tos.Setenv(PublicKeyEnvVar, publicKeyPEM)\n411: \tt.Cleanup(func() {\n412: \t\tif oldEnv != \"\" {\n413: \t\t\tos.Setenv(PublicKeyEnvVar, oldEnv)\n414: \t\t} else {\n415: \t\t\tos.Unsetenv(PublicKeyEnvVar)\n416: \t\t}\n417: \t})\n418: \n419: \tauthMgr, err := NewAuthManager()\n420: \trequire.NoError(t, err)\n421: \n422: \tgin.SetMode(gin.TestMode)\n423: \tengine := gin.New()\n424: \tapi := engine.Group(\"/api\")\n425: \tapi.Use(authMgr.AuthMiddleware())\n426: \tapi.POST(\"/test\", func(c *gin.Context) {\n427: \t\tc.JSON(200, gin.H{\"status\": \"ok\"})\n428: \t})\n429: \n430: \tw := httptest.NewRecorder()\n431: \treq := httptest.NewRequest(\"POST\", \"/api/test\", nil)\n432: \treq.Header.Set(\"Authorization\", \"Bearer\")\n433: \tengine.ServeHTTP(w, req)\n434: \n435: \tassert.Equal(t, 401, w.Code)\n436: }\n437: \n438: func TestAuthMiddlewareLeeway(t *testing.T) {\n439: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n440: \trequire.NoError(t, err)\n441: \n442: \tpublicKeyPEM := encodePublicKeyPEMForTest(&privateKey.PublicKey)\n443: \n444: \toldEnv := os.Getenv(PublicKeyEnvVar)\n445: \tos.Setenv(PublicKeyEnvVar, publicKeyPEM)\n446: \tt.Cleanup(func() {\n447: \t\tif oldEnv != \"\" {\n448: \t\t\tos.Setenv(PublicKeyEnvVar, oldEnv)\n449: \t\t} else {\n450: \t\t\tos.Unsetenv(PublicKeyEnvVar)\n451: \t\t}\n452: \t})\n453: \n454: \tauthMgr, err := NewAuthManager()\n455: \trequire.NoError(t, err)\n456: \n457: \tgin.SetMode(gin.TestMode)\n458: \tengine := gin.New()\n459: \tapi := engine.Group(\"/api\")\n460: \tapi.Use(authMgr.AuthMiddleware())\n461: \tapi.POST(\"/test\", func(c *gin.Context) {\n462: \t\tc.JSON(200, gin.H{\"status\": \"ok\"})\n463: \t})\n464: \n465: \tnow := time.Now()\n466: \tclaims := jwt.MapClaims{\n467: \t\t\"exp\": now.Add(30 * time.Second).Unix(),\n468: \t\t\"iat\": now.Add(30 * time.Second).Unix(),\n469: \t}\n470: \n471: \ttoken := jwt.NewWithClaims(jwt.SigningMethodRS256, claims)\n472: \ttokenString, err := token.SignedString(privateKey)\n473: \trequire.NoError(t, err)\n474: \n475: \tw := httptest.NewRecorder()\n476: \treq := httptest.NewRequest(\"POST\", \"/api/test\", nil)\n477: \treq.Header.Set(\"Authorization\", \"Bearer \"+tokenString)\n478: \tengine.ServeHTTP(w, req)\n479: \n480: \tassert.Equal(t, 200, w.Code)\n481: }\n\n(End of file - total 481 lines)\n</content>","metadata":{"p