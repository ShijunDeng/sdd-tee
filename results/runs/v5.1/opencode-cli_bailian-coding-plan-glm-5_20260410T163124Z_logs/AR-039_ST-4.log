") || strings.HasPrefix(rel, \"../\") {\n41: \t\t\treturn \"\", errors.New(\"path escape detected after symlink resolution\")\n42: \t\t}\n43: \t\treturn resolved, nil\n44: \t}\n45: \n46: \treturn candidate, nil\n47: }\n\n(End of file - total 47 lines)\n</content>","metadata":{"preview":"package picod\n\nimport (\n\t\"errors\"\n\t\"fmt\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"strings\"\n)\n\nfunc sanitizePath(workspace, requestedPath string) (string, error) {\n\tresolvedWorkspace, err := filepath.EvalSymlinks(workspace)\n\tif err != nil {\n\t\treturn \"\", fmt.Errorf(\"failed to resolve workspace: %w\", err)\n\t}\n\n\tcleaned := filepath.Clean(requestedPath)\n\tcleaned = strings.TrimPrefix(cleaned, \"/\")\n\n\tcandidate := filepath.Join(resolvedWorkspace, cleaned)","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/picod/sanitize.go","time":{"start":1775898364036,"end":1775898364107}}}}
{"type":"tool_use","timestamp":1775898364111,"sessionID":"ses_284369e59ffeHdgLjlbiaIcKCA","part":{"id":"prt_d7bca8357001M8QV3q0uTmp8V5","messageID":"msg_d7bca5169001hLiuf6P7MpXRHv","sessionID":"ses_284369e59ffeHdgLjlbiaIcKCA","type":"tool","tool":"read","callID":"toolu_tool-25b79657add94fb99685136c657cf5bc","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/store/store_redis.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/store/store_redis.go</path>\n<type>file</type>\n<content>\n1: package store\n2: \n3: import (\n4: \t\"context\"\n5: \t\"encoding/json\"\n6: \t\"errors\"\n7: \t\"fmt\"\n8: \t\"os\"\n9: \t\"strconv\"\n10: \t\"strings\"\n11: \t\"time\"\n12: \n13: \tredisv9 \"github.com/redis/go-redis/v9\"\n14: \t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n15: \t\"k8s.io/klog/v2\"\n16: )\n17: \n18: type redisStore struct {\n19: \tcli                  *redisv9.Client\n20: \tsessionPrefix        string\n21: \texpiryIndexKey       string\n22: \tlastActivityIndexKey string\n23: }\n24: \n25: const (\n26: \tdefaultSessionPrefix        = \"session:\"\n27: \tdefaultExpiryIndexKey       = \"session:expiry\"\n28: \tdefaultLastActivityIndexKey = \"session:last_activity\"\n29: )\n30: \n31: func NewRedisStore(addr, password string) Store {\n32: \treturn NewRedisStoreWithOptions(addr, password, defaultSessionPrefix, defaultExpiryIndexKey, defaultLastActivityIndexKey)\n33: }\n34: \n35: func NewRedisStoreWithOptions(addr, password, sessionPrefix, expiryIndexKey, lastActivityIndexKey string) Store {\n36: \tcli := redisv9.NewClient(&redisv9.Options{\n37: \t\tAddr:     addr,\n38: \t\tPassword: password,\n39: \t})\n40: \treturn &redisStore{\n41: \t\tcli:                  cli,\n42: \t\tsessionPrefix:        sessionPrefix,\n43: \t\texpiryIndexKey:       expiryIndexKey,\n44: \t\tlastActivityIndexKey: lastActivityIndexKey,\n45: \t}\n46: }\n47: \n48: func NewRedisStoreWithClient(cli *redisv9.Client) Store {\n49: \treturn &redisStore{\n50: \t\tcli:                  cli,\n51: \t\tsessionPrefix:        defaultSessionPrefix,\n52: \t\texpiryIndexKey:       defaultExpiryIndexKey,\n53: \t\tlastActivityIndexKey: defaultLastActivityIndexKey,\n54: \t}\n55: }\n56: \n57: func makeRedisOptions() (*redisv9.Options, error) {\n58: \taddr := os.Getenv(\"REDIS_ADDR\")\n59: \tif addr == \"\" {\n60: \t\treturn nil, errors.New(\"REDIS_ADDR is required\")\n61: \t}\n62: \n63: \tpassword := os.Getenv(\"REDIS_PASSWORD\")\n64: \tpasswordRequired := strings.ToLower(os.Getenv(\"REDIS_PASSWORD_REQUIRED\"))\n65: \tif password == \"\" && passwordRequired != \"false\" {\n66: \t\treturn nil, ErrPasswordRequired\n67: \t}\n68: \n69: \treturn &redisv9.Options{\n70: \t\tAddr:     addr,\n71: \t\tPassword: password,\n72: \t}, nil\n73: }\n74: \n75: func initStore() {\n76: \tstoreType := os.Getenv(\"STORE_TYPE\")\n77: \tif storeType == \"\" {\n78: \t\tstoreType = redisStoreType\n79: \t}\n80: \n81: \tvar err error\n82: \tswitch storeType {\n83: \tcase redisStoreType:\n84: \t\topts, err := makeRedisOptions()\n85: \t\tif err != nil {\n86: \t\t\tklog.ErrorS(err, \"failed to create redis options\")\n87: \t\t\treturn\n88: \t\t}\n89: \t\tprovider = NewRedisStore(opts.Addr, opts.Password)\n90: \tcase valkeyStoreType:\n91: \t\tprovider, err = newValkeyStoreFromEnv()\n92: \t\tif err != nil {\n93: \t\t\tklog.ErrorS(err, \"failed to create valkey store\")\n94: \t\t\treturn\n95: \t\t}\n96: \tdefault:\n97: \t\tklog.ErrorS(nil, \"invalid store type\", \"type\", storeType)\n98: \t}\n99: }\n100: \n101: func (s *redisStore) sessionKey(sessionID string) string {\n102: \treturn s.sessionPrefix + sessionID\n103: }\n104: \n105: func (s *redisStore) Ping(ctx context.Context) error {\n106: \tresult, err := s.cli.Ping(ctx).Result()\n107: \tif err != nil {\n108: \t\treturn fmt.Errorf(\"store: ping failed: %w\", err)\n109: \t}\n110: \tif result != \"PONG\" {\n111: \t\treturn fmt.Errorf(\"store: unexpected ping response: %s\", result)\n112: \t}\n113: \treturn nil\n114: }\n115: \n116: func (s *redisStore) GetSandboxBySessionID(ctx context.Context, sessionID string) (*types.SandboxInfo, error) {\n117: \tif sessionID == \"\" {\n118: \t\treturn nil, ErrEmptySessionID\n119: \t}\n120: \n121: \tkey := s.sessionKey(sessionID)\n122: \tresult, err := s.cli.Get(ctx, key).Result()\n123: \tif err != nil {\n124: \t\tif errors.Is(err, redisv9.Nil) {\n125: \t\t\treturn nil, ErrNotFound\n126: \t\t}\n127: \t\treturn nil, fmt.Errorf(\"store: get session %s: %w\", sessionID, err)\n128: \t}\n129: \n130: \tvar sandbox types.SandboxInfo\n131: \tif err := json.Unmarshal([]byte(result), &sandbox); err != nil {\n132: \t\treturn nil, fmt.Errorf(\"store: unmarshal session %s: %w\", sessionID, err)\n133: \t}\n134: \n135: \treturn &sandbox, nil\n136: }\n137: \n138: func (s *redisStore) StoreSandbox(ctx context.Context, sandbox *types.SandboxInfo) error {\n139: \tif sandbox == nil {\n140: \t\treturn ErrNilSandbox\n141: \t}\n142: \tif sandbox.ExpiresAt.IsZero() {\n143: \t\treturn ErrZeroExpiresAt\n144: \t}\n145: \tif sandbox.SessionID == \"\" {\n146: \t\treturn ErrEmptySessionID\n147: \t}\n148: \n149: \tkey := s.sessionKey(sandbox.SessionID)\n150: \tdata, err := json.Marshal(sandbox)\n151: \tif err != nil {\n152: \t\treturn fmt.Errorf(\"store: marshal sandbox: %w\", err)\n153: \t}\n154: \n155: \tnow := time.Now()\n156: \tif sandbox.LastActivity.IsZero() {\n157: \t\tsandbox.LastActivity = now\n158: \t}\n159: \n160: \tpipe := s.cli.Pipeline()\n161: \tsetNXCmd := pipe.SetNX(ctx, key, data, 0)\n162: \tpipe.ZAdd(ctx, s.expiryIndexKey, redisv9.Z{\n163: \t\tScore:  float64(sandbox.ExpiresAt.Unix()),\n164: \t\tMember: sandbox.SessionID,\n165: \t})\n166: \tpipe.ZAdd(ctx, s.lastActivityIndexKey, redisv9.Z{\n167: \t\tScore:  float64(sandbox.LastActivity.Unix()),\n168: \t\tMember: sandbox.SessionID,\n169: \t})\n170: \n171: \t_, err = pipe.Exec(ctx)\n172: \tif err != nil {\n173: \t\treturn fmt.Errorf(\"store: pipeline exec: %w\", err)\n174: \t}\n175: \n176: \tsetResult, err := setNXCmd.Result()\n177: \tif err != nil {\n178: \t\treturn fmt.Errorf(\"store: setnx result: %w\", err)\n179: \t}\n180: \tif !setResult {\n181: \t\treturn ErrSessionExists\n182: \t}\n183: \n184: \treturn nil\n185: }\n186: \n187: func (s *redisStore) UpdateSandbox(ctx context.Context, sandbox *types.SandboxInfo) error {\n188: \tif sandbox == nil {\n189: \t\treturn ErrNilSandbox\n190: \t}\n191: \tif sandbox.SessionID == \"\" {\n192: \t\treturn ErrEmptySessionID\n193: \t}\n194: \n195: \tkey := s.sessionKey(sandbox.SessionID)\n196: \n197: \texists, err := s.cli.Exists(ctx, key).Result()\n198: \tif err != nil {\n199: \t\treturn fmt.Errorf(\"store: check exists: %w\", err)\n200: \t}\n201: \tif exists == 0 {\n202: \t\treturn ErrNotFound\n203: \t}\n204: \n205: \tdata, err := json.Marshal(sandbox)\n206: \tif err != nil {\n207: \t\treturn fmt.Errorf(\"store: marshal sandbox: %w\", err)\n208: \t}\n209: \n210: \tif err := s.cli.Set(ctx, key, data, 0).Err(); err != nil {\n211: \t\treturn fmt.Errorf(\"store: update sandbox: %w\", err)\n212: \t}\n213: \n214: \treturn nil\n215: }\n216: \n217: func (s *redisStore) DeleteSandboxBySessionID(ctx context.Context, sessionID string) error {\n218: \tif sessionID == \"\" {\n219: \t\treturn ErrEmptySessionID\n220: \t}\n221: \n222: \tkey := s.sessionKey(sessionID)\n223: \n224: \tpipe := s.cli.Pipeline()\n225: \tpipe.Del(ctx, key)\n226: \tpipe.ZRem(ctx, s.expiryIndexKey, sessionID)\n227: \tpipe.ZRem(ctx, s.lastActivityIndexKey, sessionID)\n228: \n229: \t_, err := pipe.Exec(ctx)\n230: \tif err != nil {\n231: \t\treturn fmt.Errorf(\"store: delete sandbox: %w\", err)\n232: \t}\n233: \n234: \treturn nil\n235: }\n236: \n237: func (s *redisStore) ListExpiredSandboxes(ctx context.Context, before time.Time, limit int64) ([]*types.SandboxInfo, error) {\n238: \tif limit <= 0 {\n239: \t\treturn nil, nil\n240: \t}\n241: \n242: \tsessionIDs, err := s.cli.ZRangeByScore(ctx, s.expiryIndexKey, &redisv9.ZRangeBy{\n243: \t\tMin:   \"-inf\",\n244: \t\tMax:   fmt.Sprintf(\"%d\", before.Unix()),\n245: \t\tCount: limit,\n246: \t}).Result()\n247: \tif err != nil {\n248: \t\treturn nil, fmt.Errorf(\"store: list expired: %w\", err)\n249: \t}\n250: \n251: \tif len(sessionIDs) == 0 {\n252: \t\treturn nil, nil\n253: \t}\n254: \n255: \treturn s.batchGetSandboxes(ctx, sessionIDs)\n256: }\n257: \n258: func (s *redisStore) ListInactiveSandboxes(ctx context.Context, before time.Time, limit int64) ([]*types.SandboxInfo, error) {\n259: \tif limit <= 0 {\n260: \t\treturn nil, nil\n261: \t}\n262: \n263: \tsessionIDs, err := s.cli.ZRangeByScore(ctx, s.lastActivityIndexKey, &redisv9.ZRangeBy{\n264: \t\tMin:   \"-inf\",\n265: \t\tMax:   fmt.Sprintf(\"%d\", before.Unix()),\n266: \t\tCount: limit,\n267: \t}).Result()\n268: \tif err != nil {\n269: \t\treturn nil, fmt.Errorf(\"store: list inactive: %w\", err)\n270: \t}\n271: \n272: \tif len(sessionIDs) == 0 {\n273: \t\treturn nil, nil\n274: \t}\n275: \n276: \treturn s.batchGetSandboxes(ctx, sessionIDs)\n277: }\n278: \n279: func (s *redisStore) batchGetSandboxes(ctx context.Context, sessionIDs []string) ([]*types.SandboxInfo, error) {\n280: \tkeys := make([]string, len(sessionIDs))\n281: \tfor i, id := range sessionIDs {\n282: \t\tkeys[i] = s.sessionKey(id)\n283: \t}\n284: \n285: \tpipe := s.cli.Pipeline()\n286: \tcmds := make([]*redisv9.StringCmd, len(keys))\n287: \tfor i, key := range keys {\n288: \t\tcmds[i] = pipe.Get(ctx, key)\n289: \t}\n290: \n291: \t_, err := pipe.Exec(ctx)\n292: \tif err != nil && !errors.Is(err, redisv9.Nil) {\n293: \t\treturn nil, fmt.Errorf(\"store: batch get: %w\", err)\n294: \t}\n295: \n296: \tvar sandboxes []*types.SandboxInfo\n297: \tfor i, cmd := range cmds {\n298: \t\tresult, err := cmd.Result()\n299: \t\tif err != nil {\n300: \t\t\tif errors.Is(err, redisv9.Nil) {\n301: \t\t\t\tcontinue\n302: \t\t\t}\n303: \t\t\treturn nil, fmt.Errorf(\"store: get session %s: %w\", sessionIDs[i], err)\n304: \t\t}\n305: \n306: \t\tvar sandbox types.SandboxInfo\n307: \t\tif err := json.Unmarshal([]byte(result), &sandbox); err != nil {\n308: \t\t\tcontinue\n309: \t\t}\n310: \t\tsandboxes = append(sandboxes, &sandbox)\n311: \t}\n312: \n313: \treturn sandboxes, nil\n314: }\n315: \n316: func (s *redisStore) UpdateSessionLastActivity(ctx context.Context, sessionID string, at time.Time) error {\n317: \tif sessionID == \"\" {\n318: \t\treturn ErrEmptySessionID\n319: \t}\n320: \n321: \tkey := s.sessionKey(sessionID)\n322: \n323: \texists, err := s.cli.Exists(ctx, key).Result()\n324: \tif err != nil {\n325: \t\treturn fmt.Errorf(\"store: check exists: %w\", err)\n326: \t}\n327: \tif exists == 0 {\n328: \t\treturn ErrNotFound\n329: \t}\n330: \n331: \tif at.IsZero() {\n332: \t\tat = time.Now()\n333: \t}\n334: \n335: \tif err := s.cli.ZAdd(ctx, s.lastActivityIndexKey, redisv9.Z{\n336: \t\tScore:  float64(at.Unix()),\n337: \t\tMember: sessionID,\n338: \t}).Err(); err != nil {\n339: \t\treturn fmt.Errorf(\"store: update last activity: %w\", err)\n340: \t}\n341: \n342: \treturn nil\n343: }\n344: \n345: func (s *redisStore) Close() error {\n346: \treturn s.cli.Close()\n347: }\n348: \n349: func newValkeyStoreFromEnv() (Store, error) {\n350: \taddr := os.Getenv(\"VALKEY_ADDR\")\n351: \tif addr == \"\" {\n352: \t\treturn nil, errors.New(\"VALKEY_ADDR is required\")\n353: \t}\n354: \n355: \tpassword := os.Getenv(\"VALKEY_PASSWORD\")\n356: \tpasswordRequired := strings.ToLower(os.Getenv(\"VALKEY_PASSWORD_REQUIRED\"))\n357: \tif password == \"\" && passwordRequired != \"false\" {\n358: \t\treturn nil, ErrPasswordRequired\n359: \t}\n360: \n361: \topts := &valkeyClientOption{\n362: \t\tInitAddress: strings.Split(addr, \",\"),\n363: \t\tPassword:    password,\n364: \t}\n365: \n366: \tif v, _ := strconv.ParseBool(os.Getenv(\"VALKEY_DISABLE_CACHE\")); v {\n367: \t\topts.DisableCache = true\n368: \t}\n369: \tif v, _ := strconv.ParseBool(os.Getenv(\"VALKEY_FORCE_SINGLE\")); v {\n370: \t\topts.ForceSingleClient = true\n371: \t}\n372: \n373: \treturn newValkeyStore(opts)\n374: }\n375: \n376: type valkeyClientOption struct {\n377: \tInitAddress       []string\n378: \tPassword          string\n379: \tDisableCache      bool\n380: \tForceSingleClient bool\n381: }\n\n(End of file - total 381 lines)\n</content>","metadata":{"preview":"package store\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"errors\"\n\t\"fmt\"\n\t\"os\"\n\t\"strconv\"\n\t\"strings\"\n\t\"time\"\n\n\tredisv9 \"github.com/redis/go-redis/v9\"\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n\t\"k8s.io/klog/v2\"\n)\n\ntype redisStore struct {\n\tcli                  *redisv9.Client\n\tsessionPrefix        string","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/store/store_redis.go","time":{"start":1775898364038,"end":1775898364109}}}}
