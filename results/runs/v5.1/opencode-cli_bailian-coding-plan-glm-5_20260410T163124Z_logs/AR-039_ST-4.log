arer test-jwt\" {\n44: \t\tt.Errorf(\"unexpected Authorization header: %s\", req.Header.Get(\"Authorization\"))\n45: \t}\n46: \tif req.Header.Get(\"X-Forwarded-Host\") != \"original-host\" {\n47: \t\tt.Errorf(\"unexpected X-Forwarded-Host: %s\", req.Header.Get(\"X-Forwarded-Host\"))\n48: \t}\n49: \tif req.Header.Get(\"X-Forwarded-Proto\") != \"http\" {\n50: \t\tt.Errorf(\"unexpected X-Forwarded-Proto: %s\", req.Header.Get(\"X-Forwarded-Proto\"))\n51: \t}\n52: \tif !strings.Contains(req.Header.Get(\"X-Forwarded-For\"), \"192.168.1.1\") {\n53: \t\tt.Errorf(\"unexpected X-Forwarded-For: %s\", req.Header.Get(\"X-Forwarded-For\"))\n54: \t}\n55: }\n56: \n57: func TestDirectorNoJWT(t *testing.T) {\n58: \ttarget, _ := url.Parse(\"http://sandbox-host:9000\")\n59: \trpw := newReverseProxy(target, \"\", \"test-session\")\n60: \n61: \treq := httptest.NewRequest(http.MethodGet, \"http://original-host/api\", nil)\n62: \trpw.Director(req)\n63: \n64: \tif req.Header.Get(\"Authorization\") != \"\" {\n65: \t\tt.Errorf(\"expected empty Authorization header, got: %s\", req.Header.Get(\"Authorization\"))\n66: \t}\n67: }\n68: \n69: func TestDirectorPathNormalization(t *testing.T) {\n70: \ttarget, _ := url.Parse(\"http://sandbox-host:9000\")\n71: \trpw := newReverseProxy(target, \"jwt\", \"session\")\n72: \n73: \treq := httptest.NewRequest(http.MethodGet, \"http://host\", nil)\n74: \treq.URL.Path = \"api/v1/resource\"\n75: \trpw.Director(req)\n76: \n77: \tif req.URL.Path != \"/api/v1/resource\" {\n78: \t\tt.Errorf(\"unexpected path: %s\", req.URL.Path)\n79: \t}\n80: }\n81: \n82: func TestModifyResponse(t *testing.T) {\n83: \ttarget, _ := url.Parse(\"http://localhost:8080\")\n84: \trpw := newReverseProxy(target, \"jwt\", \"test-session-id\")\n85: \n86: \tresp := &http.Response{\n87: \t\tHeader: http.Header{},\n88: \t}\n89: \n90: \terr := rpw.ModifyResponse(resp)\n91: \tif err != nil {\n92: \t\tt.Errorf(\"unexpected error: %v\", err)\n93: \t}\n94: \n95: \tif resp.Header.Get(\"x-agentcube-session-id\") != \"test-session-id\" {\n96: \t\tt.Errorf(\"unexpected x-agentcube-session-id header: %s\", resp.Header.Get(\"x-agentcube-session-id\"))\n97: \t}\n98: }\n99: \n100: func TestErrorHandlerConnectionRefused(t *testing.T) {\n101: \ttarget, _ := url.Parse(\"http://localhost:8080\")\n102: \trpw := newReverseProxy(target, \"jwt\", \"session\")\n103: \n104: \tw := httptest.NewRecorder()\n105: \treq := httptest.NewRequest(http.MethodGet, \"/test\", nil)\n106: \terr := &url.Error{Err: &testError{msg: \"connection refused\"}}\n107: \n108: \trpw.ErrorHandler(w, req, err)\n109: \n110: \tif w.Code != http.StatusBadGateway {\n111: \t\tt.Errorf(\"unexpected status code: %d\", w.Code)\n112: \t}\n113: \n114: \tvar resp map[string]string\n115: \tjson.Unmarshal(w.Body.Bytes(), &resp)\n116: \tif resp[\"error\"] != \"sandbox unreachable\" {\n117: \t\tt.Errorf(\"unexpected error message: %s\", resp[\"error\"])\n118: \t}\n119: }\n120: \n121: func TestErrorHandlerTimeout(t *testing.T) {\n122: \ttarget, _ := url.Parse(\"http://localhost:8080\")\n123: \trpw := newReverseProxy(target, \"jwt\", \"session\")\n124: \n125: \tw := httptest.NewRecorder()\n126: \treq := httptest.NewRequest(http.MethodGet, \"/test\", nil)\n127: \terr := &testError{msg: \"timeout occurred\"}\n128: \n129: \trpw.ErrorHandler(w, req, err)\n130: \n131: \tif w.Code != http.StatusGatewayTimeout {\n132: \t\tt.Errorf(\"unexpected status code: %d\", w.Code)\n133: \t}\n134: \n135: \tvar resp map[string]string\n136: \tjson.Unmarshal(w.Body.Bytes(), &resp)\n137: \tif resp[\"error\"] != \"sandbox timeout\" {\n138: \t\tt.Errorf(\"unexpected error message: %s\", resp[\"error\"])\n139: \t}\n140: }\n141: \n142: func TestErrorHandlerGeneric(t *testing.T) {\n143: \ttarget, _ := url.Parse(\"http://localhost:8080\")\n144: \trpw := newReverseProxy(target, \"jwt\", \"session\")\n145: \n146: \tw := httptest.NewRecorder()\n147: \treq := httptest.NewRequest(http.MethodGet, \"/test\", nil)\n148: \terr := &testError{msg: \"some other error\"}\n149: \n150: \trpw.ErrorHandler(w, req, err)\n151: \n152: \tif w.Code != http.StatusBadGateway {\n153: \t\tt.Errorf(\"unexpected status code: %d\", w.Code)\n154: \t}\n155: }\n156: \n157: func TestSelectEntryPointByPrefix(t *testing.T) {\n158: \tentryPoints := []types.SandboxEntryPoint{\n159: \t\t{Path: \"/api/v1\", Protocol: \"http\", Endpoint: \"host1:8080\"},\n160: \t\t{Path: \"/api/v2\", Protocol: \"http\", Endpoint: \"host2:8080\"},\n161: \t\t{Path: \"/execute\", Protocol: \"http\", Endpoint: \"host3:9000\"},\n162: \t}\n163: \n164: \tep := selectEntryPoint(entryPoints, \"/api/v1/users\")\n165: \tif ep == nil || ep.Endpoint != \"host1:8080\" {\n166: \t\tt.Errorf(\"expected host1:8080 endpoint\")\n167: \t}\n168: \n169: \tep = selectEntryPoint(entryPoints, \"/api/v2/items\")\n170: \tif ep == nil || ep.Endpoint != \"host2:8080\" {\n171: \t\tt.Errorf(\"expected host2:8080 endpoint\")\n172: \t}\n173: \n174: \tep = selectEntryPoint(entryPoints, \"/execute/code\")\n175: \tif ep == nil || ep.Endpoint != \"host3:9000\" {\n176: \t\tt.Errorf(\"expected host3:9000 endpoint\")\n177: \t}\n178: }\n179: \n180: func TestSelectEntryPointDefault(t *testing.T) {\n181: \tentryPoints := []types.SandboxEntryPoint{\n182: \t\t{Path: \"/api\", Protocol: \"http\", Endpoint: \"host1:8080\"},\n183: \t\t{Path: \"/execute\", Protocol: \"http\", Endpoint: \"host2:9000\"},\n184: \t}\n185: \n186: \tep := selectEntryPoint(entryPoints, \"/unknown/path\")\n187: \tif ep == nil || ep.Endpoint != \"host1:8080\" {\n188: \t\tt.Errorf(\"expected first entry point as default\")\n189: \t}\n190: }\n191: \n192: func TestSelectEntryPointEmpty(t *testing.T) {\n193: \tep := selectEntryPoint([]types.SandboxEntryPoint{}, \"/any/path\")\n194: \tif ep != nil {\n195: \t\tt.Errorf(\"expected nil for empty entry points\")\n196: \t}\n197: }\n198: \n199: func TestBuildTargetURLWithProtocol(t *testing.T) {\n200: \tep := &types.SandboxEntryPoint{\n201: \t\tPath:     \"/api\",\n202: \t\tProtocol: \"http\",\n203: \t\tEndpoint: \"sandbox-host:8080\",\n204: \t}\n205: \n206: \tu, err := buildTargetURL(ep)\n207: \tif err != nil {\n208: \t\tt.Fatalf(\"unexpected error: %v\", err)\n209: \t}\n210: \n211: \tif u.Scheme != \"http\" {\n212: \t\tt.Errorf(\"unexpected scheme: %s\", u.Scheme)\n213: \t}\n214: \tif u.Host != \"sandbox-host:8080\" {\n215: \t\tt.Errorf(\"unexpected host: %s\", u.Host)\n216: \t}\n217: }\n218: \n219: func TestBuildTargetURLNoProtocol(t *testing.T) {\n220: \tep := &types.SandboxEntryPoint{\n221: \t\tPath:     \"/api\",\n222: \t\tProtocol: \"\",\n223: \t\tEndpoint: \"http://sandbox-host:8080\",\n224: \t}\n225: \n226: \tu, err := buildTargetURL(ep)\n227: \tif err != nil {\n228: \t\tt.Fatalf(\"unexpected error: %v\", err)\n229: \t}\n230: \n231: \tif u.Scheme != \"http\" {\n232: \t\tt.Errorf(\"unexpected scheme: %s\", u.Scheme)\n233: \t}\n234: }\n235: \n236: func TestBuildTargetURLHTTPS(t *testing.T) {\n237: \tep := &types.SandboxEntryPoint{\n238: \t\tPath:     \"/api\",\n239: \t\tProtocol: \"https\",\n240: \t\tEndpoint: \"sandbox-host:8443\",\n241: \t}\n242: \n243: \tu, err := buildTargetURL(ep)\n244: \tif err != nil {\n245: \t\tt.Fatalf(\"unexpected error: %v\", err)\n246: \t}\n247: \n248: \tif u.Scheme != \"https\" {\n249: \t\tt.Errorf(\"unexpected scheme: %s\", u.Scheme)\n250: \t}\n251: }\n252: \n253: func TestBuildTargetURLInvalid(t *testing.T) {\n254: \tep := &types.SandboxEntryPoint{\n255: \t\tPath:     \"/api\",\n256: \t\tProtocol: \"http\",\n257: \t\tEndpoint: \":::invalid-host\",\n258: \t}\n259: \n260: \t_, err := buildTargetURL(ep)\n261: \tif err == nil {\n262: \t\tt.Error(\"expected error for invalid endpoint\")\n263: \t}\n264: }\n265: \n266: func TestDirectorTLSRequest(t *testing.T) {\n267: \ttarget, _ := url.Parse(\"http://sandbox-host:9000\")\n268: \trpw := newReverseProxy(target, \"jwt\", \"session\")\n269: \n270: \treq := httptest.NewRequest(http.MethodGet, \"https://original-host/api\", nil)\n271: \treq.TLS = &tls.ConnectionState{}\n272: \trpw.Director(req)\n273: \n274: \tif req.Header.Get(\"X-Forwarded-Proto\") != \"https\" {\n275: \t\tt.Errorf(\"unexpected X-Forwarded-Proto for TLS request: %s\", req.Header.Get(\"X-Forwarded-Proto\"))\n276: \t}\n277: }\n278: \n279: func TestDirectorExistingXFF(t *testing.T) {\n280: \ttarget, _ := url.Parse(\"http://sandbox-host:9000\")\n281: \trpw := newReverseProxy(target, \"jwt\", \"session\")\n282: \n283: \treq := httptest.NewRequest(http.MethodGet, \"http://host/api\", nil)\n284: \treq.Header.Set(\"X-Forwarded-For\", \"10.0.0.1\")\n285: \treq.RemoteAddr = \"192.168.1.1:12345\"\n286: \trpw.Director(req)\n287: \n288: \txff := req.Header.Get(\"X-Forwarded-For\")\n289: \tif !strings.Contains(xff, \"10.0.0.1\") || !strings.Contains(xff, \"192.168.1.1\") {\n290: \t\tt.Errorf(\"unexpected X-Forwarded-For: %s\", xff)\n291: \t}\n292: }\n293: \n294: type testError struct {\n295: \tmsg string\n296: }\n297: \n298: func (e *testError) Error() string {\n299: \treturn e.msg\n300: }\n\n(End of file - total 300 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"crypto/tls\"\n\t\"encoding/json\"\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"net/url\"\n\t\"strings\"\n\t\"testing\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n)\n\nfunc TestNewReverseProxy(t *testing.T) {\n\ttarget, _ := url.Parse(\"http://localhost:8080\")\n\trpw := newReverseProxy(target, \"test-jwt\", \"test-session\")\n\n\tif rpw == nil {\n\t\tt.Fatal(\"expected ReverseProxyWrapper\")","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/reverse_proxy_test.go","time":{"start":1775898338581,"end":1775898338612}}}}
