stfile.txt\", nil, \"\", validToken)\n672: \tassert.Equal(t, 200, w.Code)\n673: \tassert.Equal(t, \"download content\", w.Body.String())\n674: }\n675: \n676: func TestDownloadFileHandlerLeadingSlash(t *testing.T) {\n677: \tserver := setupTestServer(t)\n678: \n679: \tfilePath := filepath.Join(server.workspace, \"absolute.txt\")\n680: \trequire.NoError(t, os.WriteFile(filePath, []byte(\"absolute content\"), 0644))\n681: \n682: \tauthMgr := server.authManager\n683: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n684: \trequire.NoError(t, err)\n685: \tauthMgr.SetPublicKey(&privateKey.PublicKey)\n686: \n687: \tvalidToken := generateTestJWT(privateKey, false)\n688: \n689: \tw := makeAuthenticatedRequest(t, server, \"GET\", \"/api/files//absolute.txt\", nil, \"\", validToken)\n690: \tassert.Equal(t, 200, w.Code)\n691: }\n692: \n693: func TestDownloadFileHandlerPathEscape(t *testing.T) {\n694: \tserver := setupTestServer(t)\n695: \n696: \tauthMgr := server.authManager\n697: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n698: \trequire.NoError(t, err)\n699: \tauthMgr.SetPublicKey(&privateKey.PublicKey)\n700: \n701: \tvalidToken := generateTestJWT(privateKey, false)\n702: \n703: \tw := makeAuthenticatedRequest(t, server, \"GET\", \"/api/files/../escape.txt\", nil, \"\", validToken)\n704: \tassert.Equal(t, 400, w.Code)\n705: \n706: \tvar resp map[string]string\n707: \trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n708: \tassert.Contains(t, resp[\"error\"], \"invalid path\")\n709: }\n710: \n711: func TestDownloadFileHandlerNotFound(t *testing.T) {\n712: \tserver := setupTestServer(t)\n713: \n714: \tauthMgr := server.authManager\n715: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n716: \trequire.NoError(t, err)\n717: \tauthMgr.SetPublicKey(&privateKey.PublicKey)\n718: \n719: \tvalidToken := generateTestJWT(privateKey, false)\n720: \n721: \tw := makeAuthenticatedRequest(t, server, \"GET\", \"/api/files/nonexistent.txt\", nil, \"\", validTo