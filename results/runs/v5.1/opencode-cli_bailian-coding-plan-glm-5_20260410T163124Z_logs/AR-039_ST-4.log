{"type":"tool_use","timestamp":1775898349869,"sessionID":"ses_284369e59ffeHdgLjlbiaIcKCA","part":{"id":"prt_d7bca40670016pkWZQotP44RRK","messageID":"msg_d7bca256c001Ki2KAVxAV8cLZ8","sessionID":"ses_284369e59ffeHdgLjlbiaIcKCA","type":"tool","tool":"read","callID":"toolu_tool-e77f2fce215947bba522b932c7827acf","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/middleware/auth.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/middleware/auth.go</path>\n<type>file</type>\n<content>\n1: package middleware\n2: \n3: import (\n4: \t\"net/http\"\n5: \t\"strings\"\n6: \n7: \t\"github.com/gin-gonic/gin\"\n8: \t\"github.com/golang-jwt/jwt/v5\"\n9: \t\"github.com/volcano-sh/agentcube/pkg/router\"\n10: )\n11: \n12: type JWTAuthMiddlewareConfig struct {\n13: \tSkipPaths      []string\n14: \tTokenExtractor TokenExtractor\n15: \tKeyFunc        jwt.Keyfunc\n16: \tJWTManager     *router.JWTManager\n17: }\n18: \n19: type TokenExtractor func(r *http.Request) (string, error)\n20: \n21: func DefaultTokenExtractor(r *http.Request) (string, error) {\n22: \tauthHeader := r.Header.Get(\"Authorization\")\n23: \tif authHeader == \"\" {\n24: \t\treturn \"\", &router.JWTTokenMissingError{}\n25: \t}\n26: \n27: \tparts := strings.SplitN(authHeader, \" \", 2)\n28: \tif len(parts) != 2 {\n29: \t\treturn \"\", &router.JWTInvalidFormatError{Reason: \"missing token part\"}\n30: \t}\n31: \n32: \tif parts[0] != \"Bearer\" {\n33: \t\treturn \"\", &router.JWTInvalidFormatError{Reason: \"expected Bearer prefix\"}\n34: \t}\n35: \n36: \tif parts[1] == \"\" {\n37: \t\treturn \"\", &router.JWTInvalidFormatError{Reason: \"empty token\"}\n38: \t}\n39: \n40: \treturn parts[1], nil\n41: }\n42: \n43: func JWTAuthMiddleware(jwtManager *router.JWTManager) gin.HandlerFunc {\n44: \treturn JWTAuthMiddlewareWithConfig(&JWTAuthMiddlewareConfig{\n45: \t\tJWTManager:     jwtManager,\n46: \t\tTokenExtractor: DefaultTokenExtractor,\n47: \t})\n48: }\n49: \n50: func JWTAuthMiddlewareWithConfig(config *JWTAuthMiddlewareConfig) gin.HandlerFunc {\n51: \tif config == nil || config.JWTManager == nil {\n52: \t\treturn func(c *gin.Context) {\n53: \t\t\tc.Next()\n54: \t\t}\n55: \t}\n56: \n57: \textractor := config.TokenExtractor\n58: \tif extractor == nil {\n59: \t\textractor = DefaultTokenExtractor\n60: \t}\n61: \n62: \tskipPaths := config.SkipPaths\n63: \n64: \treturn func(c *gin.Context) {\n65: \t\tpath := c.Request.URL.Path\n66: \n67: \t\tfor _, skipPath := range skipPaths {\n68: \t\t\tif strings.HasPrefix(path, skipPath) || path == skipPath {\n69: \t\t\t\tc.Next()\n70: \t\t\t\treturn\n71: \t\t\t}\n72: \t\t}\n73: \n74: \t\ttokenString, err := extractor(c.Request)\n75: \t\tif err != nil {\n76: \t\t\trespondWithError(c, err)\n77: \t\t\tc.Abort()\n78: \t\t\treturn\n79: \t\t}\n80: \n81: \t\tclaims, err := config.JWTManager.ValidateToken(tokenString)\n82: \t\tif err != nil {\n83: \t\t\trespondWithError(c, err)\n84: \t\t\tc.Abort()\n85: \t\t\treturn\n86: \t\t}\n87: \n88: \t\tc.Set(\"session_id\", claims.SessionID)\n89: \t\tc.Set(\"sandbox_id\", claims.SandboxID)\n90: \t\tc.Set(\"namespace\", claims.Namespace)\n91: \t\tc.Set(\"name\", claims.Name)\n92: \t\tc.Set(\"jwt_claims\", claims)\n93: \n94: \t\tc.Next()\n95: \t}\n96: }\n97: \n98: func respondWithError(c *gin.Context, err error) {\n99: \tvar status int\n100: \tvar code string\n101: \tvar message string\n102: \n103: \tif apiErr, ok := err.(router.APIStatus); ok {\n104: \t\tstatus = apiErr.Status()\n105: \t\tcode = apiErr.Code()\n106: \t\tmessage = apiErr.Message()\n107: \t} else {\n108: \t\tstatus = http.StatusUnauthorized\n109: \t\tcode = \"JWT_VALIDATION_FAILED\"\n110: \t\tmessage = \"jwt validation failed\"\n111: \t}\n112: \n113: \tc.JSON(status, gin.H{\n114: \t\t\"error\": message,\n115: \t\t\"code\":  code,\n116: \t})\n117: }\n118: \n119: func GetClaimsFromContext(c *gin.Context) *router.RouterClaims {\n120: \tclaims, exists := c.Get(\"jwt_claims\")\n121: \tif !exists {\n122: \t\treturn nil\n123: \t}\n124: \n125: \trouterClaims, ok := claims.(*router.RouterClaims)\n126: \tif !ok {\n127: \t\treturn nil\n128: \t}\n129: \n130: \treturn routerClaims\n131: }\n132: \n133: func GetSessionIDFromContext(c *gin.Context) string {\n134: \tsessionID, exists := c.Get(\"session_id\")\n135: \tif !exists {\n136: \t\treturn \"\"\n137: \t}\n138: \n139: \tif s, ok := sessionID.(string); ok {\n140: \t\treturn s\n141: \t}\n142: \treturn \"\"\n143: }\n144: \n145: func GetSandboxIDFromContext(c *gin.Context) string {\n146: \tsandboxID, exists := c.Get(\"sandbox_id\")\n147: \tif !exists {\n148: \t\treturn \"\"\n149: \t}\n150: \n151: \tif s, ok := sandboxID.(string); ok {\n152: \t\treturn s\n153: \t}\n154: \treturn \"\"\n155: }\n156: \n157: func GetNamespaceFromContext(c *gin.Context) string {\n158: \tnamespace, exists := c.Get(\"namespace\")\n159: \tif !exists {\n160: \t\treturn \"\"\n161: \t}\n162: \n163: \tif s, ok := namespace.(string); ok {\n164: \t\treturn s\n165: \t}\n166: \treturn \"\"\n167: }\n168: \n169: func GetNameFromContext(c *gin.Context) string {\n170: \tname, exists := c.Get(\"name\")\n171: \tif !exists {\n172: \t\treturn \"\"\n173: \t}\n174: \n175: \tif s, ok := name.(string); ok {\n176: \t\treturn s\n177: \t}\n178: \treturn \"\"\n179: }\n180: \n181: type TokenRequest struct {\n182: \tUserID   string                 `json:\"user_id\"`\n183: \tRoles    []string               `json:\"roles,omitempty\"`\n184: \tMetadata map[string]interface{} `json:\"metadata,omitempty\"`\n185: }\n186: \n187: type TokenResponse struct {\n188: \tAccessToken  string `json:\"access_token\"`\n189: \tRefreshToken string `json:\"refresh_token\"`\n190: \tExpiresIn    int64  `json:\"expires_in\"`\n191: \tTokenType    string `json:\"token_type\"`\n192: }\n193: \n194: type RefreshRequest struct {\n195: \tRefreshToken string `json:\"refresh_token\"`\n196: }\n197: \n198: type PublicKeyResponse struct {\n199: \tPublicKey string `json:\"public_key\"`\n200: \tAlgorithm string `json:\"algorithm\"`\n201: \tIssuer    string `json:\"issuer\"`\n202: }\n203: \n204: func TokenIssuanceHandler(jwtManager *router.JWTManager) gin.HandlerFunc {\n205: \treturn func(c *gin.Context) {\n206: \t\tvar req TokenRequest\n207: \t\tif err := c.ShouldBindJSON(&req); err != nil {\n208: \t\t\tc.JSON(http.StatusBadRequest, gin.H{\n209: \t\t\t\t\"error\": \"invalid request body\",\n210: \t\t\t\t\"code\":  \"INVALID_REQUEST\",\n211: \t\t\t})\n212: \t\t\treturn\n213: \t\t}\n214: \n215: \t\tclaims := &router.RouterClaims{\n216: \t\t\tSessionID: req.UserID,\n217: \t\t}\n218: \n219: \t\tif req.Metadata != nil {\n220: \t\t\tif sandboxID, ok := req.Metadata[\"sandbox_id\"].(string); ok {\n221: \t\t\t\tclaims.SandboxID = sandboxID\n222: \t\t\t}\n223: \t\t\tif namespace, ok := req.Metadata[\"namespace\"].(string); ok {\n224: \t\t\t\tclaims.Namespace = namespace\n225: \t\t\t}\n226: \t\t\tif name, ok := req.Metadata[\"name\"].(string); ok {\n227: \t\t\t\tclaims.Name = name\n228: \t\t\t}\n229: \t\t}\n230: \n231: \t\ttokenPair, err := jwtManager.GenerateTokenPair(claims)\n232: \t\tif err != nil {\n233: \t\t\tc.JSON(http.StatusInternalServerError, gin.H{\n234: \t\t\t\t\"error\": \"token generation failed\",\n235: \t\t\t\t\"code\":  \"TOKEN_GENERATION_FAILED\",\n236: \t\t\t})\n237: \t\t\treturn\n238: \t\t}\n239: \n240: \t\tc.JSON(http.StatusOK, TokenResponse{\n241: \t\t\tAccessToken:  tokenPair.AccessToken,\n242: \t\t\tRefreshToken: tokenPair.RefreshToken,\n243: \t\t\tExpiresIn:    tokenPair.ExpiresIn,\n244: \t\t\tTokenType:    tokenPair.TokenType,\n245: \t\t})\n246: \t}\n247: }\n248: \n249: func TokenRefreshHandler(jwtManager *router.JWTManager) gin.HandlerFunc {\n250: \treturn func(c *gin.Context) {\n251: \t\tvar req RefreshRequest\n252: \t\tif err := c.ShouldBindJSON(&req); err != nil {\n253: \t\t\tc.JSON(http.StatusBadRequest, gin.H{\n254: \t\t\t\t\"error\": \"invalid request body\",\n255: \t\t\t\t\"code\":  \"INVALID_REQUEST\",\n256: \t\t\t})\n257: \t\t\treturn\n258: \t\t}\n259: \n260: \t\tif req.RefreshToken == \"\" {\n261: \t\t\tc.JSON(http.StatusBadRequest, gin.H{\n262: \t\t\t\t\"error\": \"refresh token required\",\n263: \t\t\t\t\"code\":  \"REFRESH_TOKEN_REQUIRED\",\n264: \t\t\t})\n265: \t\t\treturn\n266: \t\t}\n267: \n268: \t\ttokenPair, err := jwtManager.RefreshToken(req.RefreshToken)\n269: \t\tif err != nil {\n270: \t\t\tif apiErr, ok := err.(router.APIStatus); ok {\n271: \t\t\t\tc.JSON(apiErr.Status(), gin.H{\n272: \t\t\t\t\t\"error\": apiErr.Message(),\n273: \t\t\t\t\t\"code\":  apiErr.Code(),\n274: \t\t\t\t})\n275: \t\t\t\treturn\n276: \t\t\t}\n277: \t\t\tc.JSON(http.StatusUnauthorized, gin.H{\n278: \t\t\t\t\"error\": \"refresh token invalid\",\n279: \t\t\t\t\"code\":  \"REFRESH_TOKEN_INVALID\",\n280: \t\t\t})\n281: \t\t\treturn\n282: \t\t}\n283: \n284: \t\tc.JSON(http.StatusOK, TokenResponse{\n285: \t\t\tAccessToken:  tokenPair.AccessToken,\n286: \t\t\tRefreshToken: tokenPair.RefreshToken,\n287: \t\t\tExpiresIn:    tokenPair.ExpiresIn,\n288: \t\t\tTokenType:    tokenPair.TokenType,\n289: \t\t})\n290: \t}\n291: }\n292: \n293: func PublicKeyHandler(jwtManager *router.JWTManager) gin.HandlerFunc {\n294: \treturn func(c *gin.Context) {\n295: \t\tpublicKeyPEM := jwtManager.GetPublicKeyPEM()\n296: \t\tif publicKeyPEM == \"\" {\n297: \t\t\tc.JSON(http.StatusInternalServerError, gin.H{\n298: \t\t\t\t\"error\": \"public key not available\",\n299: \t\t\t\t\"code\":  \"PUBLIC_KEY_NOT_AVAILABLE\",\n300: \t\t\t})\n301: \t\t\treturn\n302: \t\t}\n303: \n304: \t\tc.JSON(http.StatusOK, PublicKeyResponse{\n305: \t\t\tPublicKey: publicKeyPEM,\n306: \t\t\tAlgorithm: \"RS256\",\n307: \t\t\tIssuer:    \"agentcube-router\",\n308: \t\t})\n309: \t}\n310: }\n\n(End of file - total 310 lines)\n</content>","metadata":{"preview":"package middleware\n\nimport (\n\t\"net/http\"\n\t\"strings\"\n\n\t\"github.com/gin-gonic/gin\"\n\t\"github.com/golang-jwt/jwt/v5\"\n\t\"github.com/volcano-sh/agentcube/pkg/router\"\n)\n\ntype JWTAuthMiddlewareConfig struct {\n\tSkipPaths      []string\n\tTokenExtractor TokenExtractor\n\tKeyFunc        jwt.Keyfunc\n\tJWTManager     *router.JWTManager\n}\n\ntype TokenExtractor func(r *http.Request) (string, error)\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/middleware/auth.go","time":{"start":1775898349830,"end":1775898349868}}}}
{"type":"tool_use","timestamp":1775898349872,"sessionID":"ses_284369e59ffeHdgLjlbiaIcKCA","part":{"id":"prt_d7bca4413001CUZCoEteFiZYB1","messageID":"msg_d7bca256c001Ki2KAVxAV8cLZ8","sessionID":"ses_284369e59ffeHdgLjlbiaIcKCA","type":"tool","tool":"read","callID":"toolu_tool-6a546016004047fd90b4fb538b98118c","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/middleware/auth_test.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/middleware/auth_test.go</path>\n<type>file</type>\n<content>\n1: package middleware\n2: \n3: import (\n4: \t\"net/http\"\n5: \t\"net/http/httptest\"\n6: \t\"testing\"\n7: \n8: \t\"github.com/gin-gonic/gin\"\n9: \t\"github.com/volcano-sh/agentcube/pkg/router\"\n10: )\n11: \n12: func init() {\n13: \tgin.SetMode(gin.TestMode)\n14: }\n15: \n16: func TestDefaultTokenExtractor(t *testing.T) {\n17: \ttests := []struct {\n18: \t\tname        string\n19: \t\tauthHeader  string\n20: \t\texpectToken string\n21: \t\texpectError bool\n22: \t}{\n23: \t\t{\n24: \t\t\tname:        \"valid bearer token\",\n25: \t\t\tauthHeader:  \"Bearer valid-token\",\n26: \t\t\texpectToken: \"valid-token\",\n27: \t\t\texpectError: false,\n28: \t\t},\n29: \t\t{\n30: \t\t\tname:        \"missing authorization header\",\n31: \t\t\tauthHeader:  \"\",\n32: \t\t\texpectToken: \"\",\n33: \t\t\texpectError: true,\n34: \t\t},\n35: \t\t{\n36: \t\t\tname:        \"missing bearer prefix\",\n37: \t\t\tauthHeader:  \"valid-token\",\n38: \t\t\texpectToken: \"\",\n39: \t\t\texpectError: true,\n40: \t\t},\n41: \t\t{\n42: \t\t\tname:        \"wrong prefix\",\n43: \t\t\tauthHeader:  \"Basic valid-token\",\n44: \t\t\texpectToken: \"\",\n45: \t\t\texpectError: true,\n46: \t\t},\n47: \t\t{\n48: \t\t\tname:        \"empty token\",\n49: \t\t\tauthHeader:  \"Bearer \",\n50: \t\t\texpectToken: \"\",\n51: \t\t\texpectError: true,\n52: \t\t},\n53: \t\t{\n54: \t\t\tname:        \"no space separator\",\n55: \t\t\tauthHeader:  \"BearerValidToken\",\n56: \t\t\texpectToken: \"\",\n57: \t\t\texpectError: true,\n58: \t\t},\n59: \t}\n60: \n61: \tfor _, tt := range tests {\n62: \t\tt.Run(tt.name, func(t *testing.T) {\n63: \t\t\treq := httptest.NewRequest(http.MethodGet, \"/test\", nil)\n64: \t\t\tif tt.authHeader != \"\" {\n65: \t\t\t\treq.Header.Set(\"Authorization\", tt.authHeader)\n66: \t\t\t}\n67: \n68: \t\t\ttoken, err := DefaultTokenExtractor(req)\n69: \n70: \t\t\tif tt.expectError {\n71: \t\t\t\tif err == nil {\n72: \t\t\t\t\tt.Error(\"expected error, got nil\")\n73: \t\t\t\t}\n74: \t\t\t} else {\n75: \t\t\t\tif err != nil {\n76: \t\t\t\t\tt.Errorf(\"unexpected error: %v\", err)\n77: \t\t\t\t}\n78: \t\t\t\tif token != tt.expectToken {\n79: \t\t\t\t\tt.Errorf(\"expected token %s, got %s\", tt.expectToken, token)\n80: \t\t\t\t}\n81: \t\t\t}\n82: \t\t})\n83: \t}\n84: }\n85: \n86: func TestJWTAuthMiddleware(t *testing.T) {\n87: \tjwtMgr, err := router.NewJWTManager()\n88: \tif err != nil {\n89: \t\tt.Fatalf(\"failed to create JWT manager: %v\", err)\n90: \t}\n91: \n92: \ttoken, err := jwtMgr.GenerateToken(map[string]interface{}{\n93: \t\t\"session_id\": \"test-session\",\n94: \t\t\"sandbox_id\": \"test-sandbox\",\n95: \t\t\"namespace\":  \"test-namespace\",\n96: \t\t\"name\":       \"test-name\",\n97: \t})\n98: \tif err != nil {\n99: \t\tt.Fatalf(\"failed to generate token: %v\", err)\n100: \t}\n101: \n102: \trouterTest := gin.New()\n103: \trouterTest.Use(JWTAuthMiddleware(jwtMgr))\n104: \trouterTest.GET(\"/test\", func(c *gin.Context) {\n105: \t\tc.JSON(http.StatusOK, gin.H{\"status\": \"ok\"})\n106: \t})\n107: \n108: \treq := httptest.NewRequest(http.MethodGet, \"/test\", nil)\n109: \treq.Header.Set(\"Authorization\", \"Bearer \"+token)\n110: \tw := httptest.NewRecorder()\n111: \n112: \trouterTest.ServeHTTP(w, req)\n113: \n114: \tif w.Code != http.StatusOK {\n115: \t\tt.Errorf(\"unexpected status code: %d, body: %s\", w.Code, w.Body.String())\n116: \t}\n117: }\n118: \n119: func TestJWTAuthMiddlewareMissingToken(t *testing.T) {\n120: \tjwtMgr, err := router.NewJWTManager()\n121: \tif err != nil {\n122: \t\tt.Fatalf(\"failed to create JWT manager: %v\", err)\n123: \t}\n124: \n125: \trouterTest := gin.New()\n126: \trouterTest.Use(JWTAuthMiddleware(jwtMgr))\n127: \trouterTest.GET(\"/test\", func(c *gin.Context) {\n128: \t\tc.JSON(http.StatusOK, gin.H{\"status\": \"ok\"})\n129: \t})\n130: \n131: \treq := httptest.NewRequest(http.MethodGet, \"/test\", nil)\n132: \tw := httptest.NewRecorder()\n133: \n134: \trouterTest.ServeHTTP(w, req)\n135: \n136: \tif w.Code != http.StatusUnauthorized {\n137: \t\tt.Errorf(\"expected status %d, got %d\", http.StatusUnauthorized, w.Code)\n138: \t}\n139: }\n140: \n141: func TestJWTAuthMiddlewareInvalidToken(t *testing.T) {\n142: \tjwtMgr, err := router.NewJWTManager()\n143: \tif err != nil {\n144: \t\tt.Fatalf(\"failed to create JWT manager: %v\", err)\n145: \t}\n146: \n147: \trouterTest := gin.New()\n148: \trouterTest.Use(JWTAuthMiddleware(jwtMgr))\n149: \trouterTest.GET(\"/test\", func(c *gin.Context) {\n150: \t\tc.JSON(http.StatusOK, gin.H{\"status\": \"ok\"})\n151: \t})\n152: \n153: \treq := httptest.NewRequest(http.MethodGet, \"/test\", nil)\n154: \treq.Header.Set(\"Authorization\", \"Bearer invalid-token\")\n155: \tw := httptest.NewRecorder()\n156: \n157: \trouterTest.ServeHTTP(w, req)\n158: \n159: \tif w.Code != http.StatusUnauthorized {\n160: \t\tt.Errorf(\"expected status %d, got %d\", http.StatusUnauthorized, w.Code)\n161: \t}\n162: }\n163: \n164: func TestJWTAuthMiddlewareSkipPaths(t *testing.T) {\n165: \tjwtMgr, err := router.NewJWTManager()\n166: \tif err != nil {\n167: \t\tt.Fatalf(\"failed to create JWT manager: %v\", err)\n168: \t}\n169: \n170: \tconfig := &JWTAuthMiddlewareConfig{\n171: \t\tJWTManager: jwtMgr,\n172: \t\tSkipPaths:  []string{\"/health\", \"/metrics\"},\n173: \t}\n174: \n175: \trouterTest := gin.New()\n176: \trouterTest.Use(JWTAuthMiddlewareWithConfig(config))\n177: \trouterTest.GET(\"/health\", func(c *gin.Context) {\n178: \t\tc.JSON(http.StatusOK, gin.H{\"status\": \"ok\"})\n179: \t})\n180: \trouterTest.GET(\"/metrics\", func(c *gin.Context) {\n181: \t\tc.JSON(http.StatusOK, gin.H{\"metrics\": \"ok\"})\n182: \t})\n183: \trouterTest.GET(\"/protected\", func(c *gin.Context) {\n184: \t\tc.JSON(http.StatusOK, gin.H{\"status\": \"ok\"})\n185: \t})\n186: \n187: \ttests := []struct {\n188: \t\tpath       string\n189: \t\texpectCode int\n190: \t}{\n191: \t\t{\"/health\", http.StatusOK},\n192: \t\t{\"/metrics\", http.StatusOK},\n193: \t\t{\"/protected\", http.StatusUnauthorized},\n194: \t}\n195: \n196: \tfor _, tt := range tests {\n197: \t\tt.Run(tt.path, func(t *testing.T) {\n198: \t\t\treq := httptest.NewRequest(http.MethodGet, tt.path, nil)\n199: \t\t\tw := httptest.NewRecorder()\n200: \t\t\trouterTest.ServeHTTP(w, req)\n201: \n202: \t\t\tif w.Code != tt.expectCode {\n203: \t\t\t\tt.Errorf(\"path %s: expected status %d, got %d\", tt.path, tt.expectCode, w.Code)\n204: \t\t\t}\n205: \t\t})\n206: \t}\n207: }\n208: \n209: func TestJWTAuthMiddlewareNilManager(t *testing.T) {\n210: \trouterTest := gin.New()\n211: \trouterTest.Use(JWTAuthMiddleware(nil))\n212: \trouterTest.GET(\"/test\", func(c *gin.Context) {\n213: \t\tc.JSON(http.StatusOK, gin.H{\"status\": \"ok\"})\n214: \t})\n215: \n216: \treq := httptest.NewRequest(http.MethodGet, \"/test\", nil)\n217: \tw := httptest.NewRecorder()\n218: \n219: \trouterTest.ServeHTTP(w, req)\n220: \n221: \tif w.Code != http.StatusOK {\n222: \t\tt.Errorf(\"expected status %d with nil manager, got %d\", http.StatusOK, w.Code)\n223: \t}\n224: }\n225: \n226: func TestJWTAuthMiddlewareNilConfig(t *testing.T) {\n227: \trouterTest := gin.New()\n228: \trouterTest.Use(JWTAuthMiddlewareWithConfig(nil))\n229: \trouterTest.GET(\"/test\", func(c *gin.Context) {\n230: \t\tc.JSON(http.StatusOK, gin.H{\"status\": \"ok\"})\n231: \t})\n232: \n233: \treq := httptest.NewRequest(http.MethodGet, \"/test\", nil)\n234: \tw := httptest.NewRecorder()\n235: \n236: \trouterTest.ServeHTTP(w, req)\n237: \n238: \tif w.Code != http.StatusOK {\n239: \t\tt.Errorf(\"expected status %d with nil config, got %d\", http.StatusOK, w.Code)\n240: \t}\n241: }\n242: \n243: func TestJWTAuthMiddlewareContextClaims(t *testing.T) {\n244: \tjwtMgr, err := router.NewJWTManager()\n245: \tif err != nil {\n246: \t\tt.Fatalf(\"failed to create JWT manager: %v\", err)\n247: \t}\n248: \n249: \ttoken, err := jwtMgr.GenerateToken(map[string]interface{}{\n250: \t\t\"session_id\": \"context-session\",\n251: \t\t\"sandbox_id\": \"context-sandbox\",\n252: \t\t\"namespace\":  \"context-namespace\",\n253: \t\t\"name\":       \"context-name\",\n254: \t})\n255: \tif err != nil {\n256: \t\tt.Fatalf(\"failed to generate token: %v\", err)\n257: \t}\n258: \n259: \trouterTest := gin.New()\n260: \trouterTest.Use(JWTAuthMiddleware(jwtMgr))\n261: \trouterTest.GET(\"/test\", func(c *gin.Context) {\n262: \t\tsessionID := GetSessionIDFromContext(c)\n263: \t\tsandboxID := GetSandboxIDFromContext(c)\n264: \t\tnamespace := GetNamespaceFromContext(c)\n265: \t\tname := GetNameFromContext(c)\n266: \t\tclaims := GetClaimsFromContext(c)\n267: \n268: \t\tc.JSON(http.StatusOK, gin.H{\n269: \t\t\t\"session_id\": sessionID,\n270: \t\t\t\"sandbox_id\": sandboxID,\n271: \t\t\t\"namespace\":  namespace,\n272: \t\t\t\"name\":       name,\n273: \t\t\t\"has_claims\": claims != nil,\n274: \t\t})\n275: \t})\n276: \n277: \treq := httptest.NewRequest(http.MethodGet, \"/test\", nil)\n278: \treq.Header.Set(\"Authorization\", \"Bearer \"+token)\n279: \tw := httptest.NewRecorder()\n280: \n281: \trouterTest.ServeHTTP(w, req)\n282: \n283: \tif w.Code != http.StatusOK {\n284: \t\tt.Errorf(\"unexpected status code: %d\", w.Code)\n285: \t}\n286: }\n287: \n288: func TestGetSessionIDFromContextEmpty(t *testing.T) {\n289: \trouterTest := gin.New()\n290: \trouterTest.GET(\"/test\", func(c *gin.Context) {\n291: \t\tsessionID := GetSessionIDFromContext(c)\n292: \t\tif sessionID != \"\" {\n293: \t\t\tt.Errorf(\"expected empty session ID, got %s\", sessionID)\n294: \t\t}\n295: \t\tc.JSON(http.StatusOK, gin.H{})\n296: \t})\n297: \n298: \treq := httptest.NewRequest(http.MethodGet, \"/test\", nil)\n299: \tw := httptest.NewRecorder()\n300: \trouterTest.ServeHTTP(w, req)\n301: }\n302: \n303: func TestGetClaimsFromContextEmpty(t *testing.T) {\n304: \trouterTest := gin.New()\n305: \trouterTest.GET(\"/test\", func(c *gin.Context) {\n306: \t\tclaims := GetClaimsFromContext(c)\n307: \t\tif claims != nil {\n308: \t\t\tt.Errorf(\"expected nil claims, got %v\", claims)\n309: \t\t}\n310: \t\tc.JSON(http.StatusOK, gin.H{})\n311: \t})\n312: \n313: \treq := httptest.NewRequest(http.MethodGet, \"/test\", nil)\n314: \tw := httptest.NewRecorder()\n315: \trouterTest.ServeHTTP(w, req)\n316: }\n317: \n318: func TestTokenIssuanceHandler(t *testing.T) {\n319: \tjwtMgr, err := router.NewJWTManager()\n320: \tif err != nil {\n321: \t\tt.Fatalf(\"failed to create JWT manager: %v\", err)\n322: \t}\n323: \n324: \trouterTest := gin.New()\n325: \trouterTest.POST(\"/auth/token\", TokenIssuanceHandler(jwtMgr))\n326: \n327: \treq := httptest.NewRequest(http.MethodPost, \"/auth/token\", nil)\n328: \treq.Header.Set(\"Content-Type\", \"application/json\")\n329: \treq.Body = httptest.NewRequest(http.MethodPost, \"/auth/token\", nil).Body\n330: \tw := httptest.NewRecorder()\n331: \n332: \trouterTest.ServeHTTP(w, req)\n333: \n334: \tif w.Code != http.StatusBadRequest {\n335: \t\tt.Errorf(\"expected status %d for empty body, got %d\", http.StatusBadRequest, w.Code)\n336: \t}\n337: }\n338: \n339: func TestTokenRefreshHandler(t *testing.T) {\n340: \tjwtMgr, err := router.NewJWTManager()\n341: \tif err != nil {\n342: \t\tt.Fatalf(\"failed to create JWT manager: %v\", err)\n343: \t}\n344: \n345: \trouterTest := gin.New()\n346: \trouterTest.POST(\"/auth/refresh\", TokenRefreshHandler(jwtMgr))\n347: \n348: \treq := httptest.NewRequest(http.MethodPost, \"/auth/refresh\", nil)\n349: \treq.Header.Set(\"Content-Type\", \"application/json\")\n350: \tw := httptest.NewRecorder()\n351: \n352: \trouterTest.ServeHTTP(w, req)\n353: \n354: \tif w.Code != http.StatusBadRequest {\n355: \t\tt.Errorf(\"expected status %d for empty body, got %d\", http.StatusBadRequest, w.Code)\n356: \t}\n357: }\n358: \n359: func TestPublicKeyHandler(t *testing.T) {\n360: \tjwtMgr, err := router.NewJWTManager()\n361: \tif err != nil {\n362: \t\tt.Fatalf(\"failed to create JWT manager: %v\", err)\n363: \t}\n364: \n365: \trouterTest := gin.New()\n366: \trouterTest.GET(\"/auth/public-key\", PublicKeyHandler(jwtMgr))\n367: \n368: \treq := httptest.NewRequest(http.MethodGet, \"/auth/public-key\", nil)\n369: \tw := httptest.NewRecorder()\n370: \n371: \trouterTest.ServeHTTP(w, req)\n372: \n373: \tif w.Code != http.StatusOK {\n374: \t\tt.Errorf(\"expected status %d, got %d\", http.StatusOK, w.Code)\n375: \t}\n376: }\n377: \n378: func TestJWTAuthMiddlewareWithConfigCustomExtractor(t *testing.T) {\n379: \tjwtMgr, err := router.NewJWTManager()\n380: \tif err != nil {\n381: \t\tt.Fatalf(\"failed to create JWT manager: %v\", err)\n382: \t}\n383: \n384: \ttoken, err := jwtMgr.GenerateToken(map[string]interface{}{\n385: \t\t\"session_id\": \"custom-session\",\n386: \t})\n387: \tif err != nil {\n388: \t\tt.Fatalf(\"failed to generate token: %v\", err)\n389: \t}\n390: \n391: \tcustomExtractor := func(r *http.Request) (string, error) {\n392: \t\ttoken := r.Header.Get(\"X-Custom-Token\")\n393: \t\tif token == \"\" {\n394: \t\t\treturn \"\", &router.JWTTokenMissingError{}\n395: \t\t}\n396: \t\treturn token, nil\n397: \t}\n398: \n399: \tconfig := &JWTAuthMiddlewareConfig{\n400: \t\tJWTManager:     jwtMgr,\n401: \t\tTokenExtractor: customExtractor,\n402: \t}\n403: \n404: \trouterTest := gin.New()\n405: \trouterTest.Use(JWTAuthMiddlewareWithConfig(config))\n406: \trouterTest.GET(\"/test\", func(c *gin.Context) {\n407: \t\tc.JSON(http.StatusOK, gin.H{\"status\": \"ok\"})\n408: \t})\n409: \n410: \treq := httptest.NewRequest(http.MethodGet, \"/test\", nil)\n411: \treq.Header.Set(\"X-Custom-Token\", token)\n412: \tw := httptest.NewRecorder()\n413: \n414: \trouterTest.ServeHTTP(w, req)\n415: \n416: \tif w.Code != http.StatusOK {\n417: \t\tt.Errorf(\"expected status %d with custom extractor, got %d\", http.StatusOK, w.Code)\n418: \t}\n419: }\n420: \n421: func TestJWTAuthMiddlewareExpiresToken(t *testing.T) {\n422: \tjwtMgr, err := router.NewJWTManager()\n423: \tif err != nil {\n424: \t\tt.Fatalf(\"failed to create JWT manager: %v\", err)\n425: \t}\n426: \n427: \ttoken, err := jwtMgr.GenerateToken(map[string]interface{}{\n428: \t\t\"session_id\": \"expired-session\",\n429: \t})\n430: \tif err != nil {\n431: \t\tt.Fatalf(\"failed to generate token: %v\", err)\n432: \t}\n433: \n434: \trouterTest := gin.New()\n435: \trouterTest.Use(JWTAuthMiddleware(jwtMgr))\n436: \trouterTest.GET(\"/test\", func(c *gin.Context) {\n437: \t\tc.JSON(http.StatusOK, gin.H{\"status\": \"ok\"})\n438: \t})\n439: \n440: \treq := httptest.NewRequest(http.MethodGet, \"/test\", nil)\n441: \treq.Header.Set(\"Authorization\", \"Bearer \"+token)\n442: \tw := httptest.NewRecorder()\n443: \n444: \trouterTest.ServeHTTP(w, req)\n445: \n446: \tif w.Code != http.StatusOK {\n447: \t\tt.Errorf(\"unexpected status code: %d\", w.Code)\n448: \t}\n449: }\n450: \n451: func TestJWTAuthMiddlewareWrongSigningMethod(t *testing.T) {\n452: \trouterTest := gin.New()\n453: \trouterTest.Use(JWTAuthMiddlewareWithConfig(&JWTAuthMiddlewareConfig{\n454: \t\tJWTManager:     nil,\n455: \t\tTokenExtractor: DefaultTokenExtractor,\n456: \t}))\n457: \trouterTest.GET(\"/test\", func(c *gin.Context) {\n458: \t\tc.JSON(http.StatusOK, gin.H{\"status\": \"ok\"})\n459: \t})\n460: \n461: \treq := httptest.NewRequest(http.MethodGet, \"/test\", nil)\n462: \treq.Header.Set(\"Authorization\", \"Bearer some-token\")\n463: \tw := httptest.NewRecorder()\n464: \n465: \trouterTest.ServeHTTP(w, req)\n466: \n467: \tif w.Code != http.StatusOK {\n468: \t\tt.Errorf(\"expected status %d with nil manager (skips auth), got %d\", http.StatusOK, w.Code)\n469: \t}\n470: }\n\n(End of file - total 470 lines)\n</content>","metadata":{"preview":"package middleware\n\nimport (\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"testing\"\n\n\t\"github.com/gin-gonic/gin\"\n\t\"github.com/volcano-sh/agentcube/pkg/router\"\n)\n\nfunc init() {\n\tgin.SetMode(gin.TestMode)\n}\n\nfunc TestDefaultTokenExtractor(t *testing.T) {\n\ttests := []struct {\n\t\tname        string\n\t\tauthHeader  string\n\t\texpectToken string","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/middleware/auth_test.go","time":{"start":1775898349832,"end":1775898349870}}}}
