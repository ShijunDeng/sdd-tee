efix\", err.Error())\n\tassert.Equal(t, 401, err.Status())\n\tassert.Equal(t, \"JWT_INVALID_FORMAT\", err.Code())\n\tassert.Equal(t, \"invalid authorization header format\", err.Message())\n}\n\nfunc TestJWTInvalidFormatErrorEmptyReason(t *testing.T) {\n\terr := &JWTInvalidFormatError{Reason: \"\"}\n\tassert.Equal(t, \"invalid authorization header format\", err.Error())\n\tassert.Equal(t, 401, err.Status())\n\tassert.Equal(t, \"JWT_INVALID_FORMAT\", err.Code())\n\tassert.Equal(t, \"invalid authorization header format\", err.Message())\n}\n\nfunc TestJWTKeyLoadError(t *testing.T) {\n\tinnerErr := errors.New(\"key load failed\")\n\terr := &JWTKeyLoadError{Err: innerErr}\n\tassert.Equal(t, 500, err.Status())\n\tassert.Equal(t, \"JWT_KEY_LOAD_FAILED\", err.Code())\n\tassert.Equal(t, \"jwt key load failed\", err.Message())\n\tassert.Contains(t, err.Error(), \"jwt key load failed\")\n}\n\nfunc TestJWTKeyLoadErrorNil(t *testing.T) {\n\terr := &JWTKeyLoadError{Err: nil}\n\tassert.Equal(t, 500, err.Status())\n\tassert.Equal(t, \"JWT_KEY_LOAD_FAILED\", err.Code())\n\tassert.Equal(t, \"jwt key load failed\", err.Message())\n\tassert.Equal(t, \"jwt key load failed\", err.Error())\n}\n\nfunc TestJWTKeyLoadErrorUnwrap(t *testing.T) {\n\tinnerErr := errors.New(\"inner error\")\n\terr := &JWTKeyLoadError{Err: innerErr}\n\tunwrapped := err.Unwrap()\n\trequire.NotNil(t, unwrapped)\n\tassert.Equal(t, \"inner error\", unwrapped.Error())\n}\n\nfunc TestServerOverloadedError(t *testing.T) {\n\terr := &ServerOverloadedError{}\n\tassert.Equal(t, \"server overloaded\", err.Error())\n\tassert.Equal(t, 429, err.Status())\n\tassert.Equal(t, \"SERVER_OVERLOADED\", err.Code())\n\tassert.Equal(t, \"server overloaded, please try again later\", err.Message())\n}\n\nfunc TestNoEntryPointError(t *testing.T) {\n\terr := &NoEntryPointError{SandboxID: \"test-sandbox\"}\n\tassert.Equal(t, \"no entry point for sandbox: test-sandbox\", err.Error())\n\tassert.Equal(t, 404, err.Status())\n\tassert.Equal(t, \"NO_ENTRY_POINT\", err.Code())\n\tassert.Equal(t, \"no entry point configured\", err.Message())\n}\n\nfunc TestWorkloadManagerError(t *testing.T) {\n\terr := &WorkloadManagerError{StatusCode: 500, Msg: \"test message\"}\n\tassert.Equal(t, \"test message\", err.Error())\n\tassert.Equal(t, 500, err.Status())\n\tassert.Equal(t, \"WORKLOAD_MANAGER_ERROR\", err.Code())\n\tassert.Equal(t, \"test message\", err.Message())\n}\n\nfunc TestAPIStatusInterface(t *testing.T) {\n\tapiErrors := []APIStatus{\n\t\t&SessionNotFoundError{SessionID: \"test\"},\n\t\t&SandboxUnreachableError{SandboxID: \"test\"},\n\t\t&SandboxTimeoutError{SandboxID: \"test\"},\n\t\t&JWTSigningError{Err: nil},\n\t\t&JWTValidationError{Err: nil},\n\t\t&JWTTokenExpiredError{TokenID: \"test\"},\n\t\t&JWTTokenMissingError{},\n\t\t&JWTInvalidFormatError{Reason: \"test\"},\n\t\t&JWTKeyLoadError{Err: nil},\n\t\t&ServerOverloadedError{},\n\t\t&NoEntryPointError{SandboxID: \"test\"},\n\t\t&WorkloadManagerError{StatusCode: 500, Msg: \"test\"},\n\t}\n\n\tfor _, err := range apiErrors {\n\t\tassert.NotZero(t, err.Status(), \"Status() returned 0 for %T\", err)\n\t\tassert.NotEmpty(t, err.Code(), \"Code() returned empty string for %T\", err)\n\t\tassert.NotEmpty(t, err.Message(), \"Message() returned empty string for %T\", err)\n\t\tasErr, ok := err.(error)\n\t\trequire.True(t, ok, \"APIStatus %T does not implement error interface\", err)\n\t\tassert.NotEmpty(t, asErr.Error(), \"Error() returned empty string for %T\", err)\n\t}\n}\n\nfunc TestJWTErrorInterface(t *testing.T) {\n\tjwtErrors := []APIStatus{\n\t\t&JWTSigningError{Err: errors.New(\"test\")},\n\t\t&JWTValidationError{Err: errors.New(\"test\")},\n\t\t&JWTTokenExpiredError{TokenID: \"test\"},\n\t\t&JWTTokenMissingError{},\n\t\t&JWTInvalidFormatError{Reason: \"test\"},\n\t\t&JWTKeyLoadError{Err: errors.New(\"test\")},\n\t}\n\n\tfor _, err := range jwtErrors {\n\t\tassert.IsType(t, err, err)\n\t}\n}\n","additions":3,"deletions":1},"truncated":false},"title":"wor