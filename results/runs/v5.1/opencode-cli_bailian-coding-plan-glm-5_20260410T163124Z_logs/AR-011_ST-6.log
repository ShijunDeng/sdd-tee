{"type":"tool_use","timestamp":1775853445287,"sessionID":"ses_286e34833ffedub7xE6ZLTR62L","part":{"id":"prt_d791d206d001IGiQQbbEv8Y8ku","messageID":"msg_d791cfc87001qhLU5ipNijx4r4","sessionID":"ses_286e34833ffedub7xE6ZLTR62L","type":"tool","tool":"read","callID":"toolu_tool-fd1c7d2fc82b4c89a9c3000a4224830f","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/middleware/auth.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/middleware/auth.go</path>\n<type>file</type>\n<content>\n1: package middleware\n2: \n3: import (\n4: \t\"net/http\"\n5: \t\"strings\"\n6: \n7: \t\"github.com/gin-gonic/gin\"\n8: \t\"github.com/golang-jwt/jwt/v5\"\n9: \t\"github.com/volcano-sh/agentcube/pkg/router\"\n10: )\n11: \n12: type JWTAuthMiddlewareConfig struct {\n13: \tSkipPaths      []string\n14: \tTokenExtractor TokenExtractor\n15: \tKeyFunc        jwt.Keyfunc\n16: \tJWTManager     *router.JWTManager\n17: }\n18: \n19: type TokenExtractor func(r *http.Request) (string, error)\n20: \n21: func DefaultTokenExtractor(r *http.Request) (string, error) {\n22: \tauthHeader := r.Header.Get(\"Authorization\")\n23: \tif authHeader == \"\" {\n24: \t\treturn \"\", &router.JWTTokenMissingError{}\n25: \t}\n26: \n27: \tparts := strings.SplitN(authHeader, \" \", 2)\n28: \tif len(parts) != 2 {\n29: \t\treturn \"\", &router.JWTInvalidFormatError{Reason: \"missing token part\"}\n30: \t}\n31: \n32: \tif parts[0] != \"Bearer\" {\n33: \t\treturn \"\", &router.JWTInvalidFormatError{Reason: \"expected Bearer prefix\"}\n34: \t}\n35: \n36: \tif parts[1] == \"\" {\n37: \t\treturn \"\", &router.JWTInvalidFormatError{Reason: \"empty token\"}\n38: \t}\n39: \n40: \treturn parts[1], nil\n41: }\n42: \n43: func JWTAuthMiddleware(jwtManager *router.JWTManager) gin.HandlerFunc {\n44: \treturn JWTAuthMiddlewareWithConfig(&JWTAuthMiddlewareConfig{\n45: \t\tJWTManager:     jwtManager,\n46: \t\tTokenExtractor: DefaultTokenExtractor,\n47: \t})\n48: }\n49: \n50: func JWTAuthMiddlewareWithConfig(config *JWTAuthMiddlewareConfig) gin.HandlerFunc {\n51: \tif config == nil || config.JWTManager == nil {\n52: \t\treturn func(c *gin.Context) {\n53: \t\t\tc.Next()\n54: \t\t}\n55: \t}\n56: \n57: \textractor := config.TokenExtractor\n58: \tif extractor == nil {\n59: \t\textractor = DefaultTokenExtractor\n60: \t}\n61: \n62: \tskipPaths := config.SkipPaths\n63: \n64: \treturn func(c *gin.Context) {\n65: \t\tpath := c.Request.URL.Path\n66: \n67: \t\tfor _, skipPath := range skipPaths {\n68: \t\t\tif strings.HasPrefix(path, skipPath) || path == skipPath {\n69: \t\t\t\tc.Next()\n70: \t\t\t\treturn\n71: \t\t\t}\n72: \t\t}\n73: \n74: \t\ttokenString, err := extractor(c.Request)\n75: \t\tif err != nil {\n76: \t\t\trespondWithError(c, err)\n77: \t\t\tc.Abort()\n78: \t\t\treturn\n79: \t\t}\n80: \n81: \t\tclaims, err := config.JWTManager.ValidateToken(tokenString)\n82: \t\tif err != nil {\n83: \t\t\trespondWithError(c, err)\n84: \t\t\tc.Abort()\n85: \t\t\treturn\n86: \t\t}\n87: \n88: \t\tc.Set(\"session_id\", claims.SessionID)\n89: \t\tc.Set(\"sandbox_id\", claims.SandboxID)\n90: \t\tc.Set(\"namespace\", claims.Namespace)\n91: \t\tc.Set(\"name\", claims.Name)\n92: \t\tc.Set(\"jwt_claims\", claims)\n93: \n94: \t\tc.Next()\n95: \t}\n96: }\n97: \n98: func respondWithError(c *gin.Context, err error) {\n99: \tvar status int\n100: \tvar code string\n101: \tvar message string\n102: \n103: \tif apiErr, ok := err.(router.APIStatus); ok {\n104: \t\tstatus = apiErr.Status()\n105: \t\tcode = apiErr.Code()\n106: \t\tmessage = apiErr.Message()\n107: \t} else {\n108: \t\tstatus = http.StatusUnauthorized\n109: \t\tcode = \"JWT_VALIDATION_FAILED\"\n110: \t\tmessage = \"jwt validation failed\"\n111: \t}\n112: \n113: \tc.JSON(status, gin.H{\n114: \t\t\"error\": message,\n115: \t\t\"code\":  code,\n116: \t})\n117: }\n118: \n119: func GetClaimsFromContext(c *gin.Context) *router.RouterClaims {\n120: \tclaims, exists := c.Get(\"jwt_claims\")\n121: \tif !exists {\n122: \t\treturn nil\n123: \t}\n124: \n125: \trouterClaims, ok := claims.(*router.RouterClaims)\n126: \tif !ok {\n127: \t\treturn nil\n128: \t}\n129: \n130: \treturn routerClaims\n131: }\n132: \n133: func GetSessionIDFromContext(c *gin.Context) string {\n134: \tsessionID, exists := c.Get(\"session_id\")\n135: \tif !exists {\n136: \t\treturn \"\"\n137: \t}\n138: \n139: \tif s, ok := sessionID.(string); ok {\n140: \t\treturn s\n141: \t}\n142: \treturn \"\"\n143: }\n144: \n145: func GetSandboxIDFromContext(c *gin.Context) string {\n146: \tsandboxID, exists := c.Get(\"sandbox_id\")\n147: \tif !exists {\n148: \t\treturn \"\"\n149: \t}\n150: \n151: \tif s, ok := sandboxID.(string); ok {\n152: \t\treturn s\n153: \t}\n154: \treturn \"\"\n155: }\n156: \n157: func GetNamespaceFromContext(c *gin.Context) string {\n158: \tnamespace, exists := c.Get(\"namespace\")\n159: \tif !exists {\n160: \t\treturn \"\"\n161: \t}\n162: \n163: \tif s, ok := namespace.(string); ok {\n164: \t\treturn s\n165: \t}\n166: \treturn \"\"\n167: }\n168: \n169: func GetNameFromContext(c *gin.Context) string {\n170: \tname, exists := c.Get(\"name\")\n171: \tif !exists {\n172: \t\treturn \"\"\n173: \t}\n174: \n175: \tif s, ok := name.(string); ok {\n176: \t\treturn s\n177: \t}\n178: \treturn \"\"\n179: }\n180: \n181: type TokenRequest struct {\n182: \tUserID   string                 `json:\"user_id\"`\n183: \tRoles    []string               `json:\"roles,omitempty\"`\n184: \tMetadata map[string]interface{} `json:\"metadata,omitempty\"`\n185: }\n186: \n187: type TokenResponse struct {\n188: \tAccessToken  string `json:\"access_token\"`\n189: \tRefreshToken string `json:\"refresh_token\"`\n190: \tExpiresIn    int64  `json:\"expires_in\"`\n191: \tTokenType    string `json:\"token_type\"`\n192: }\n193: \n194: type RefreshRequest struct {\n195: \tRefreshToken string `json:\"refresh_token\"`\n196: }\n197: \n198: type PublicKeyResponse struct {\n199: \tPublicKey string `json:\"public_key\"`\n200: \tAlgorithm string `json:\"algorithm\"`\n201: \tIssuer    string `json:\"issuer\"`\n202: }\n203: \n204: func TokenIssuanceHandler(jwtManager *router.JWTManager) gin.HandlerFunc {\n205: \treturn func(c *gin.Context) {\n206: \t\tvar req TokenRequest\n207: \t\tif err := c.ShouldBindJSON(&req); err != nil {\n208: \t\t\tc.JSON(http.StatusBadRequest, gin.H{\n209: \t\t\t\t\"error\": \"invalid request body\",\n210: \t\t\t\t\"code\":  \"INVALID_REQUEST\",\n211: \t\t\t})\n212: \t\t\treturn\n213: \t\t}\n214: \n215: \t\tclaims := &router.RouterClaims{\n216: \t\t\tSessionID: req.UserID,\n217: \t\t}\n218: \n219: \t\tif req.Metadata != nil {\n220: \t\t\tif sandboxID, ok := req.Metadata[\"sandbox_id\"].(string); ok {\n221: \t\t\t\tclaims.SandboxID = sandboxID\n222: \t\t\t}\n223: \t\t\tif namespace, ok := req.Metadata[\"namespace\"].(string); ok {\n224: \t\t\t\tclaims.Namespace = namespace\n225: \t\t\t}\n226: \t\t\tif name, ok := req.Metadata[\"name\"].(string); ok {\n227: \t\t\t\tclaims.Name = name\n228: \t\t\t}\n229: \t\t}\n230: \n231: \t\ttokenPair, err := jwtManager.GenerateTokenPair(claims)\n232: \t\tif err != nil {\n233: \t\t\tc.JSON(http.StatusInternalServerError, gin.H{\n234: \t\t\t\t\"error\": \"token generation failed\",\n235: \t\t\t\t\"code\":  \"TOKEN_GENERATION_FAILED\",\n236: \t\t\t})\n237: \t\t\treturn\n238: \t\t}\n239: \n240: \t\tc.JSON(http.StatusOK, TokenResponse{\n241: \t\t\tAccessToken:  tokenPair.AccessToken,\n242: \t\t\tRefreshToken: tokenPair.RefreshToken,\n243: \t\t\tExpiresIn:    tokenPair.ExpiresIn,\n244: \t\t\tTokenType:    tokenPair.TokenType,\n245: \t\t})\n246: \t}\n247: }\n248: \n249: func TokenRefreshHandler(jwtManager *router.JWTManager) gin.HandlerFunc {\n250: \treturn func(c *gin.Context) {\n251: \t\tvar req RefreshRequest\n252: \t\tif err := c.ShouldBindJSON(&req); err != nil {\n253: \t\t\tc.JSON(http.StatusBadRequest, gin.H{\n254: \t\t\t\t\"error\": \"invalid request body\",\n255: \t\t\t\t\"code\":  \"INVALID_REQUEST\",\n256: \t\t\t})\n257: \t\t\treturn\n258: \t\t}\n259: \n260: \t\tif req.RefreshToken == \"\" {\n261: \t\t\tc.JSON(http.StatusBadRequest, gin.H{\n262: \t\t\t\t\"error\": \"refresh token required\",\n263: \t\t\t\t\"code\":  \"REFRESH_TOKEN_REQUIRED\",\n264: \t\t\t})\n265: \t\t\treturn\n266: \t\t}\n267: \n268: \t\ttokenPair, err := jwtManager.RefreshToken(req.RefreshToken)\n269: \t\tif err != nil {\n270: \t\t\tif apiErr, ok := err.(router.APIStatus); ok {\n271: \t\t\t\tc.JSON(apiErr.Status(), gin.H{\n272: \t\t\t\t\t\"error\": apiErr.Message(),\n273: \t\t\t\t\t\"code\":  apiErr.Code(),\n274: \t\t\t\t})\n275: \t\t\t\treturn\n276: \t\t\t}\n277: \t\t\tc.JSON(http.StatusUnauthorized, gin.H{\n278: \t\t\t\t\"error\": \"refresh token invalid\",\n279: \t\t\t\t\"code\":  \"REFRESH_TOKEN_INVALID\",\n280: \t\t\t})\n281: \t\t\treturn\n282: \t\t}\n283: \n284: \t\tc.JSON(http.StatusOK, TokenResponse{\n285: \t\t\tAccessToken:  tokenPair.AccessToken,\n286: \t\t\tRefreshToken: tokenPair.RefreshToken,\n287: \t\t\tExpiresIn:    tokenPair.ExpiresIn,\n288: \t\t\tTokenType:    tokenPair.TokenType,\n289: \t\t})\n290: \t}\n291: }\n292: \n293: func PublicKeyHandler(jwtManager *router.JWTManager) gin.HandlerFunc {\n294: \treturn func(c *gin.Context) {\n295: \t\tpublicKeyPEM := jwtManager.GetPublicKeyPEM()\n296: \t\tif publicKeyPEM == \"\" {\n297: \t\t\tc.JSON(http.StatusInternalServerError, gin.H{\n298: \t\t\t\t\"error\": \"public key not available\",\n299: \t\t\t\t\"code\":  \"PUBLIC_KEY_NOT_AVAILABLE\",\n300: \t\t\t})\n301: \t\t\treturn\n302: \t\t}\n303: \n304: \t\tc.JSON(http.StatusOK, PublicKeyResponse{\n305: \t\t\tPublicKey: publicKeyPEM,\n306: \t\t\tAlgorithm: \"RS256\",\n307: \t\t\tIssuer:    \"agentcube-router\",\n308: \t\t})\n309: \t}\n310: }\n\n(End of file - total 310 lines)\n</content>","metadata":{"preview":"package middleware\n\nimport (\n\t\"net/http\"\n\t\"strings\"\n\n\t\"github.com/gin-gonic/gin\"\n\t\"github.com/golang-jwt/jwt/v5\"\n\t\"github.com/volcano-sh/agentcube/pkg/router\"\n)\n\ntype JWTAuthMiddlewareConfig struct {\n\tSkipPaths      []string\n\tTokenExtractor TokenExtractor\n\tKeyFunc        jwt.Keyfunc\n\tJWTManager     *router.JWTManager\n}\n\ntype TokenExtractor func(r *http.Request) (string, error)\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/middleware/auth.go","time":{"start":1775853445259,"end":1775853445284}}}}
