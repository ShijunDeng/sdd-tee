(t, 404, err.Status())\n\tassert.Equal(t, \"SESSION_NOT_FOUND\", err.Code())\n\tassert.Equal(t, \"session not found\", err.Message())\n}\n\nfunc TestSandboxUnreachableError(t *testing.T) {\n\terr := &SandboxUnreachableError{SandboxID: \"test-sandbox\"}\n\tassert.Equal(t, \"sandbox unreachable: test-sandbox\", err.Error())\n\tassert.Equal(t, 502, err.Status())\n\tassert.Equal(t, \"SANDBOX_UNREACHABLE\", err.Code())\n\tassert.Equal(t, \"sandbox unreachable\", err.Message())\n}\n\nfunc TestSandboxTimeoutError(t *testing.T) {\n\terr := &SandboxTimeoutError{SandboxID: \"test-sandbox\"}\n\tassert.Equal(t, \"sandbox timeout: test-sandbox\", err.Error())\n\tassert.Equal(t, 504, err.Status())\n\tassert.Equal(t, \"SANDBOX_TIMEOUT\", err.Code())\n\tassert.Equal(t, \"sandbox timeout\", err.Message())\n}\n\nfunc TestJWTSigningError(t *testing.T) {\n\tinnerErr := &SessionNotFoundError{SessionID: \"inner\"}\n\terr := &JWTSigningError{Err: innerErr}\n\tassert.Equal(t, 500, err.Status())\n\tassert.Equal(t, \"JWT_SIGNING_FAILED\", err.Code())\n\tassert.Equal(t, \"jwt signing failed\", err.Message())\n\tassert.Contains(t, err.Error(), \"jwt signing failed\")\n}\n\nfunc TestJWTValidationError(t *testing.T) {\n\tinnerErr := errors.New(\"validation failed\")\n\terr := &JWTValidationError{Err: innerErr}\n\tassert.Equal(t, 401, err.Status())\n\tassert.Equal(t, \"JWT_VALIDATION_FAILED\", err.Code())\n\tassert.Equal(t, \"jwt validation failed\", err.Message())\n\tassert.Contains(t, err.Error(), \"jwt validation failed\")\n}\n\nfunc TestJWTValidationErrorNil(t *testing.T) {\n\terr := &JWTValidationError{Err: nil}\n\tassert.Equal(t, 401, err.Status())\n\tassert.Equal(t, \"JWT_VALIDATION_FAILED\", err.Code())\n\tassert.Equal(t, \"jwt validation failed\", err.Message())\n\tassert.Equal(t, \"jwt validation failed\", err.Error())\n}\n\nfunc TestJWTValidationErrorUnwrap(t *testing.T) {\n\tinnerErr := errors.New(\"inner error\")\n\terr := &JWTValidationError{Err: innerErr}\n\tunwrapped := err.Unwrap()\n\trequire.NotNil(t, unwrapped)\n\tassert.Equal(t, \"inner error\", unwrapped.Error())\n}\n\nfunc TestJWTTokenExpiredError(t *testing.T) {\n\terr := &JWTTokenExpiredError{TokenID: \"expired-token-id\"}\n\tassert.Equal(t, \"jwt token expired: expired-token-id\", err.Error())\n\tassert.Equal(t, 401, err.Status())\n\tassert.Equal(t, \"JWT_TOKEN_EXPIRED\", err.Code())\n\tassert.Equal(t, \"jwt token expired\", err.Message())\n}\n\nfunc TestJWTTokenMissingError(t *testing.T) {\n\terr := &JWTTokenMissingError{}\n\tassert.Equal(t, \"jwt token missing\", err.Error())\n\tassert.Equal(t, 401, err.Status())\n\tassert.Equal(t, \"JWT_TOKEN_MISSING\", err.Code())\n\tassert.Equal(t, \"jwt token missing\", err.Message())\n}\n\nfunc TestJWTInvalidFormatError(t *testing.T) {\n\terr := &JWTInvalidFormatError{Reason: \"missing bearer prefix\"}\n\tassert.Equal(t, \"invalid authorization header format: missing bearer prefix\", err.Error())\n\tassert.Equal(t, 401, err.Status())\n\tassert.Equal(t, \"JWT_INVALID_FORMAT\", err.Code())\n\tassert.Equal(t, \"invalid authorization header format\", err.Message())\n}\n\nfunc TestJWTInvalidFormatErrorEmptyReason(t *testing.T) {\n\terr := &JWTInvalidFormatError{Reason: \"\"}\n\tassert.Equal(t, \"invalid authorization header format\", err.Error())\n\tassert.Equal(t, 401, err.Status())\n\tassert.Equal(t, \"JWT_INVALID_FORMAT\", err.Code())\n\tassert.Equal(t, \"invalid authorization header format\", err.Message())\n}\n\nfunc TestJWTKeyLoadError(t *testing.T) {\n\tinnerErr := errors.New(\"key load failed\")\n\terr := &JWTKeyLoadError{Err: innerErr}\n\tassert.Equal(t, 500, err.Status())\n\tassert.Equal(t, \"JWT_KEY_LOAD_FAILED\", err.Code())\n\tassert.Equal(t, \"jwt key load failed\", err.Message())\n\tassert.Contains(t, err.Error(), \"jwt key load failed\")\n}\n\nfunc TestJWTKeyLoadErrorNil(t *testing.T) {\n\terr := &JWTKeyLoadError{Err: nil}\n\tassert.Equal(t, 500, err.Status())\n\tassert.Equal(t, \"JWT_KEY_LOAD_FAILED\", err.Code())\n\tassert.Equal(