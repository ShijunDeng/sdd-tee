"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/config_test.go":[]},"diff":"Index: /home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/jwt_test.go\n===================================================================\n--- /home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/jwt_test.go\n+++ /home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/jwt_test.go\n@@ -371,9 +371,9 @@\n \t}\n \n \tassert.Equal(t, \"access-token\", tokenPair.AccessToken)\n \tassert.Equal(t, \"refresh-token\", tokenPair.RefreshToken)\n-\tassert.Equal(t, 300, tokenPair.ExpiresIn)\n+\tassert.Equal(t, int64(300), tokenPair.ExpiresIn)\n \tassert.Equal(t, \"Bearer\", tokenPair.TokenType)\n }\n \n func TestJWTManagerValidateTokenEmpty(t *testing.T) {\n","filediff":{"file":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/jwt_test.go","before":"package router\n\nimport (\n\t\"context\"\n\t\"crypto/rand\"\n\t\"crypto/rsa\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/golang-jwt/jwt/v5\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n)\n\nfunc TestNewJWTManager(t *testing.T) {\n\tjwtMgr, err := NewJWTManager()\n\trequire.NoError(t, err)\n\trequire.NotNil(t, jwtMgr.privateKey)\n\trequire.NotNil(t, jwtMgr.publicKey)\n\trequire.NotNil(t, jwtMgr.config)\n}\n\nfunc TestNewJWTManagerWithConfig(t *testing.T) {\n\tconfig := &JWTConfig{\n\t\tTokenExpiry:   10 * time.Minute,\n\t\tRefreshExpiry: 60 * time.Minute,\n\t\tIssuer:        \"custom-issuer\",\n\t}\n\tjwtMgr, err := NewJWTManagerWithConfig(config)\n\trequire.NoError(t, err)\n\trequire.NotNil(t, jwtMgr.config)\n\tassert.Equal(t, 10*time.Minute, jwtMgr.config.TokenExpiry)\n}\n\nfunc TestNewJWTManagerWithConfigNil(t *testing.T) {\n\tjwtMgr, err := NewJWTManagerWithConfig(nil)\n\trequire.NoError(t, err)\n\trequire.NotNil(t, jwtMgr.config)\n\tassert.Equal(t, jwtExpiration, jwtMgr.config.TokenExpiry)\n}\n\nfunc TestNewJWTManagerFromPrivateKey(t *testing.T) {\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\n\tjwtMgr, err := NewJWTManagerFromPrivateKey(privateKey)\n\trequire.NoError(t, err)\n\trequire.NotNil(t, jwtMgr.privateKey)\n\tassert.Equal(t, privateKey.N, jwtMgr.privateKey.N)\n}\n\nfunc TestNewJWTManagerFromPrivateKeyNil(t *testing.T) {\n\t_, err := NewJWTManagerFromPrivateKey(nil)\n\trequire.Error(t, err)\n\tassert.IsType(t, &JWTKeyLoadError{}, err)\n}\n\nfunc TestJWTManagerGenerateToken(t *testing.T) {\n\tjwtMgr, err := NewJWTManager()\n\trequire.NoError(t, err)\n\n\tclaims := map[string]interface{}{\n\t\t\"session_id\": \"test-session\",\n\t\t\"sandbox_id\": \"test-sandbox\",\n\t}\n\n\ttokenStr, err := jwtMgr.GenerateToken(claims)\n\trequire.NoError(t, err)\n\tassert.NotEmpty(t, tokenStr)\n\n\ttoken, err := jwt.Parse(tokenStr, func(token *jwt.Token) (interface{}, error) {\n\t\tif _, ok := token.Method.(*jwt.SigningMethodRSA); !ok {\n\t\t\treturn nil, jwt.ErrSignatureInvalid\n\t\t}\n\t\treturn jwtMgr.publicKey, nil\n\t})\n\n\trequire.NoError(t, err)\n\tassert.True(t, token.Valid)\n\n\tmapClaims, ok := token.Claims.(jwt.MapClaims)\n\trequire.True(t, ok)\n\tassert.Equal(t, \"agentcube-router\", mapClaims[\"iss\"])\n\tassert.Equal(t, \"test-session\", mapClaims[\"session_id\"])\n}\n\nfunc TestJWTManagerGenerateTokenWithClaims(t *testing.T) {\n\tjwtMgr, err := NewJWTManager()\n\trequire.NoError(t, err)\n\n\tclaims := &RouterClaims{\n\t\tSessionID: \"test-session\",\n\t\tSandboxID: \"test-sandbox\",\n\t\tNamespace: \"test-namespace\",\n\t\tName:      \"test-name\",\n\t}\n\n\ttokenStr, err := jwtMgr.GenerateTokenWithClaims(claims)\n\trequire.NoError(t, err)\n\tassert.NotEmpty(t, tokenStr)\n\n\tvalidatedClaims, err := jwtMgr.ValidateToken(tokenStr)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"test-session\", validatedClaims.SessionID)\n\tassert.Equal(t, \"test-sandbox\", validatedClaims.SandboxID)\n\tassert.Equal(t, \"test-namespace\", validatedClaims.Namespace)\n\tassert.Equal(t, \"test-name\", validatedClaims.Name)\n}\n\nfunc TestJWTManagerGenerateTokenPair(t *testing.T) {\n\tjwtMgr, err := NewJWTManager()\n\trequire.NoError(t, err)\n\n\tclaims := &RouterClaims{\n\t\tSessionID: \"test-session\",\n\t\tSandboxID: \"test-sandbox\",\n\t\tNamespace: \"test-namespace\",\n\t\tName:      \"test-name\",\n\t}\n\n\ttokenPair, err := jwtMgr.GenerateTokenPair(claims)\n\trequire.NoError(t, err)\n\trequire.NotNil(t, tokenPair)\n\tassert.NotEmpty(t, tokenPair.AccessToken)\n\tassert.NotEmpty(t, tokenPair.RefreshToken)\n\tassert.Equal(t, \"Bearer\", tokenPair.TokenType)\n\tassert.Equal(t, int64(jwtExpiration.Seconds()), tokenPair.ExpiresIn)\n\n\taccessClaims, err := jwtMgr.ValidateToken(tokenPair.AccessToken)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"test-session\", accessClaims.SessionID)\n\n\trefreshClaims, err := jwtMgr.ValidateToken(tokenPair.RefreshToken)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"test-session\", refreshClaims.SessionID)\n\tassert.NotEmpty(t, refreshClaims.RegisteredClaims.ID)\n}\n\nfunc TestJWTManagerValidateToken(t *testing.T) {\n\tjwtMgr, err := NewJWTManager()\n\trequire.NoError(t, err)\n\n\ttoken, err := jwtMgr.GenerateToken(map[string]interface{}{\n\t\t\"session_id\": \"validate-session\",\n\t\t\"sandbox_id\": \"validate-sandbox\",\n\t\t\"namespace\":  \"validate-namespace\",\n\t\t\"name\":       \"validate-name\",\n\t})\n\trequire.NoError(t, err)\n\n\tclaims, err := jwtMgr.ValidateToken(token)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"validate-session\", claims.SessionID)\n\tassert.Equal(t, \"validate-sandbox\", claims.SandboxID)\n\tassert.Equal(t, \"validate-namespace\", claims.Namespace)\n\tassert.Equal(t, \"validate-name\", claims.Name)\n}\n\nfunc TestJWTManagerValidateTokenInvalid(t *testing.T) {\n\tjwtMgr, err := NewJWTManager()\n\trequire.NoError(t, err)\n\n\t_, err = jwtMgr.ValidateToken(\"invalid-token-string\")\n\trequire.Error(t, err)\n\tassert.IsType(t, &JWTValidationError{}, err)\n}\n\nfunc TestJWTManagerValidateTokenWrongKey(t *testing.T) {\n\tjwtMgr1, err := NewJWTManager()\n\trequire.NoError(t, err)\n\n\tjwtMgr2, err := NewJWTManager()\n\trequire.NoError(t, err)\n\n\ttoken, err := jwtMgr1.GenerateToken(map[string]interface{}{\n\t\t\"session_id\": \"wrong-key-session\",\n\t})\n\trequire.NoError(t, err)\n\n\t_, err = jwtMgr2.ValidateToken(token)\n\trequire.Error(t, err)\n\tassert.IsType(t, &JWTValidationError{}, err)\n}\n\nfunc TestJWTManagerRefreshToken(t *testing.T) {\n\tjwtMgr, err := NewJWTManager()\n\trequire.NoError(t, err)\n\n\tclaims := &RouterClaims{\n\t\tSessionID: \"refresh-session\",\n\t\tSandboxID: \"refresh-sandbox\",\n\t\tNamespace: \"refresh-namespace\",\n\t\tName:      \"refresh-name\",\n\t}\n\n\ttokenPair, err := jwtMgr.GenerateTokenPair(claims)\n\trequire.NoError(t, err)\n\n\tnewTokenPair, err := jwtMgr.RefreshToken(tokenPair.RefreshToken)\n\trequire.NoError(t, err)\n\trequire.NotNil(t, newTokenPair)\n\tassert.NotEmpty(t, newTokenPair.AccessToken)\n\tassert.NotEmpty(t, newTokenPair.RefreshToken)\n\n\tnewClaims, err := jwtMgr.ValidateToken(newTokenPair.AccessToken)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"refresh-session\", newClaims.SessionID)\n}\n\nfunc TestJWTManagerRefreshTokenWithAccessToken(t *testing.T) {\n\tjwtMgr, err := NewJWTManager()\n\trequire.NoError(t, err)\n\n\tclaims := &RouterClaims{\n\t\tSessionID: \"access-session\",\n\t}\n\n\ttoken, err := jwtMgr.GenerateTokenWithClaims(claims)\n\trequire.NoError(t, err)\n\n\t_, err = jwtMgr.RefreshToken(token)\n\trequire.Error(t, err)\n\tassert.IsType(t, &JWTValidationError{}, err)\n}\n\nfunc TestJWTManagerGetPublicKeyPEM(t *testing.T) {\n\tjwtMgr, err := NewJWTManager()\n\trequire.NoError(t, err)\n\n\tpemStr := jwtMgr.GetPublicKeyPEM()\n\tassert.NotEmpty(t, pemStr)\n\tassert.Contains(t, pemStr, \"PUBLIC KEY\")\n}\n\nfunc TestJWTManagerTokenExpiration(t *testing.T) {\n\tjwtMgr, err := NewJWTManager()\n\trequire.NoError(t, err)\n\n\ttokenStr, err := jwtMgr.GenerateToken(map[string]interface{}{})\n\trequire.NoError(t, err)\n\n\ttoken, err := jwt.Parse(tokenStr, func(token *jwt.Token) (interface{}, error) {\n\t\treturn jwtMgr.publicKey, nil\n\t})\n\trequire.NoError(t, err)\n\n\tmapClaims, ok := token.Claims.(jwt.MapClaims)\n\trequire.True(t, ok)\n\n\texp, ok := mapClaims[\"exp\"].(float64)\n\trequire.True(t, ok)\n\n\tnow := time.Now().Unix()\n\texpectedExp := now + int64(jwtExpiration.Seconds())\n\n\tassert.GreaterOrEqual(t, int64(exp), now)\n\tassert.LessOrEqual(t, int64(exp), expectedExp+5)\n\tassert.GreaterOrEqual(t, int64(exp), expectedExp-5)\n}\n\nfunc TestJWTManagerGetPublicKey(t *testing.T) {\n\tjwtMgr, err := NewJWTManager()\n\trequire.NoError(t, err)\n\n\tpubKey := jwtMgr.GetPublicKey()\n\trequire.NotNil(t, pubKey)\n\tassert.Equal(t, 2048/8, pubKey.Size())\n}\n\nfunc TestDefaultJWTConfig(t *testing.T) {\n\tconfig := DefaultJWTConfig()\n\trequire.NotNil(t, config)\n\tassert.Equal(t, jwtExpiration, config.TokenExpiry)\n\tassert.Equal(t, refreshExpiration, config.RefreshExpiry)\n\tassert.Equal(t, jwtIssuer, config.Issuer)\n\tassert.Equal(t, defaultClockSkew, config.ClockSkew)\n}\n\nfunc TestEncodePrivateKeyPEM(t *testing.T) {\n\tjwtMgr, err := NewJWTManager()\n\trequire.NoError(t, err)\n\n\tpemData := encodePrivateKeyPEM(jwtMgr.privateKey)\n\trequire.NotNil(t, pemData)\n\tassert.Contains(t, string(pemData), \"RSA PRIVATE KEY\")\n}\n\nfunc TestEncodePublicKeyPEM(t *testing.T) {\n\tjwtMgr, err := NewJWTManager()\n\trequire.NoError(t, err)\n\n\tpemData := encodePublicKeyPEM(jwtMgr.publicKey)\n\trequire.NotNil(t, pemData)\n\tassert.Contains(t, string(pemData), \"PUBLIC KEY\")\n}\n\nfunc TestLoadPrivateKeyPEM(t *testing.T) {\n\tjwtMgr, err := NewJWTManager()\n\trequire.NoError(t, err)\n\n\tpemData := encodePrivateKeyPEM(jwtMgr.privateKey)\n\tloadedKey, err := loadPrivateKeyPEM(pemData)\n\trequire.NoError(t, err)\n\tassert.Equal(t, 0, loadedKey.N.Cmp(jwtMgr.privateKey.N))\n}\n\nfunc TestLoadPrivateKeyPEMInvalid(t *testing.T) {\n\t_, err := loadPrivateKeyPEM([]byte(\"invalid pem data\"))\n\trequire.Error(t, err)\n}\n\nfunc TestLoadPrivateKeyPEMInvalidBlock(t *testing.T) {\n\t_, err := loadPrivateKeyPEM([]byte(\"-----BEGIN CERTIFICATE-----\\ninvalid\\n-----END CERTIFICATE-----\"))\n\trequire.Error(t, err)\n}\n\nfunc TestJWTManagerTryStoreOrLoadJWTKeySecretNoClient(t *testing.T) {\n\tjwtMgr, err := NewJWTManager()\n\trequire.NoError(t, err)\n\n\terr = jwtMgr.TryStoreOrLoadJWTKeySecret(context.Background())\n\tassert.NoError(t, err)\n}\n\nfunc TestJWTManagerLoadKeysFromSecretNoClient(t *testing.T) {\n\tjwtMgr, err := NewJWTManager()\n\trequire.NoError(t, err)\n\n\terr = jwtMgr.LoadKeysFromSecret(context.Background())\n\trequire.Error(t, err)\n\tassert.IsType(t, &JWTKeyLoadError{}, err)\n}\n\nfunc TestJWTManagerStoreKeysToSecretNoClient(t *testing.T) {\n\tjwtMgr, err := NewJWTManager()\n\trequire.NoError(t, err)\n\n\terr = jwtMgr.StoreKeysToSecret(context.Background())\n\trequire.Error(t, err)\n\tassert.IsType(t, &JWTKeyLoadError{}, err)\n}\n\nfunc TestRouterClaims(t *testing.T) {\n\tclaims := &RouterClaims{\n\t\tSessionID: \"claim-session\",\n\t\tSandboxID: \"claim-sandbox\",\n\t\tNamespace: \"claim-namespace\",\n\t\tName:      \"claim-name\",\n\t}\n\n\tjwtMgr, err := NewJWTManager()\n\trequire.NoError(t, err)\n\n\ttoken, err := jwtMgr.GenerateTokenWithClaims(claims)\n\trequire.NoError(t, err)\n\n\tvalidated, err := jwtMgr.ValidateToken(token)\n\trequire.NoError(t, err)\n\tassert.Equal(t, claims.SessionID, validated.SessionID)\n\tassert.Equal(t, claims.SandboxID, validated.SandboxID)\n\tassert.Equal(t, claims.Namespace, validated.Namespace)\n\tassert.Equal(t, claims.Name, validated.Name)\n}\n\nfunc TestTokenPair(t *testing.T) {\n\ttokenPair := &TokenPair{\n\t\tAccessToken:  \"access-token\",\n\t\tRefreshToken: \"refresh-token\",\n\t\tExpiresIn:    300,\n\t\tTokenType:    \"Bearer\",\n\t}\n\n\tassert.Equal(t, \"access-token\", tokenPair.AccessToken)\n\tassert.Equal(t, \"refresh-token\", tokenPair.RefreshToken)\n\tassert.Equal(t, 300, tokenPair.ExpiresIn)\n\tassert.Equal(t, \"Bearer\", tokenPair.TokenType)\n}\n\nfunc TestJWTManagerValidateTokenEmpty(t *testing.T) {\n\tjwtMgr, err := NewJWTManager()\n\trequire.NoError(t, err)\n\n\t_, err = jwtMgr.ValidateToken(\"\")\n\trequire.Error(t, err)\n}\n\nfunc BenchmarkJWTGenerateToken(b *testing.B) {\n\tjwtMgr, err := NewJWTManager()\n\tif err != nil {\n\t\tb.Fatalf(\"failed to create JWT manager: %v\", err)\n\t}\n\n\tclaims := map[string]interface{}{\n\t\t\"session_id\": \"bench-session\",\n\t\t\"sandbox_id\": \"bench-sandbox\",\n\t}\n\n\tb.ResetTimer()\n\tfor i := 0; i < b.N; i++ {\n\t\t_, _ = jwtMgr.GenerateToken(claims)\n\t}\n}\n\nfunc BenchmarkJWTValidateToken(b *testing.B) {\n\tjwtMgr, err := NewJWTManager()\n\tif err != nil {\n\t\tb.Fatalf(\"failed to create JWT manager: %v\", err)\n\t}\n\n\ttoken, err := jwtMgr.GenerateToken(map[string]interface{}{\n\t\t\"session_id\": \"bench-session\",\n\t})\n\tif err != nil {\n\t\tb.Fatalf(\"failed to generate token: %v\", err)\n\t}\n\n\tb.ResetTimer()\n\tfor i := 0; i < b.N; i++ {\n\t\t_, _ = jwtMgr.ValidateToken(token)\n\t}\n}\n\nfunc BenchmarkJWTGenerateTokenPair(b *testing.B) {\n\tjwtMgr, err := NewJWTManager()\n\tif err != nil {\n\t\tb.Fatalf(\"failed to create JWT manager: %v\", err)\n\t}\n\n\tclaims := &RouterClaims{\n\t\tSessionID: \"bench-session\",\n\t\tSandboxID: \"bench-sandbox\",\n\t}\n\n\tb.ResetTimer()\n\tfor i := 0; i < b.N; i++ {\n\t\t_, _ = jwtMgr.GenerateTokenPair(claims)\n\t}\n}\n\nfunc contains(s, substr string) bool {\n\treturn len(s) > 0 && len(substr) > 0 && len(s) >= len(substr)\n}\n","after":"package router\n\nimport (\n\t\"context\"\n\t\"crypto/rand\"\n\t\"crypto/rsa\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/golang-jwt/jwt/v5\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n)\n\nfunc TestNewJWTManager(t *testing.T) {\n\tjwtMgr, err := NewJWTManager()\n\trequire.NoError(t, err)\n\trequire.NotNil(t, jwtMgr.privateKey)\n\trequire.NotNil(t, jwtMgr.publicKey)\n\trequire.NotNil(t, jwtMgr.config)\n}\n\nfunc TestNewJWTManagerWithConfig(t *testing.T) {\n\tconfig := &JWTConfig{\n\t\tTokenExpiry:   10 * time.Minute,\n\t\tRefreshExpiry: 60 * time.Minute,\n\t\tIssuer:        \"custom-issuer\",\n\t}\n\tjwtMgr, err := NewJWTManagerWithConfig(config)\n\trequire.NoError(t, err)\n\trequire.NotNil(t, jwtMgr.config)\n\tassert.Equal(t, 10*time.Minute, jwtMgr.config.TokenExpiry)\n}\n\nfunc TestNewJWTManagerWithConfigNil(t *testing.T) {\n\tjwtMgr, err := NewJWTManagerWithConfig(nil)\n\trequire.NoError(t, err)\n\trequire.NotNil(t, jwtMgr.config)\n\tassert.Equal(t, jwtExpiration, jwtMgr.config.TokenExpiry)\n}\n\nfunc TestNewJWTManagerFromPrivateKey(t *testing.T) {\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\n\tjwtMgr, err := NewJWTManagerFromPrivateKey(privateKey)\n\trequire.NoError(t, err)\n\trequire.NotNil(t, jwtMgr.privateKey)\n\tassert.Equal(t, privateKey.N, jwtMgr.privateKey.N)\n}\n\nfunc TestNewJWTManagerFromPrivateKeyNil(t *testing.T) {\n\t_, err := NewJWTManagerFromPrivateKey(nil)\n\trequire.Error(t, err)\n\tassert.IsType(t, &JWTKeyLoadError{}, err)\n}\n\nfunc TestJWTManagerGenerateToken(t *testing.T) {\n\tjwtMgr, err := NewJWTManager()\n\trequire.NoError(t, err)\n\n\tclaims := map[string]interface{}{\n\t\t\"session_id\": \"test-session\",\n\t\t\"sandbox_id\": \"test-sandbox\",\n\t}\n\n\ttokenStr, err := jwtMgr.GenerateToken(claims)\n\trequire.NoError(t, err)\n\tassert.NotEmpty(t, tokenStr)\n\n\ttoken, err := jwt.Parse(tokenStr, func(token *jwt.Token) (interface{}, error) {\n\t\tif _, ok := token.Method.(*jwt.SigningMethodRSA); !ok {\n\t\t\treturn nil, jwt.ErrSignatureInvalid\n\t\t}\n\t\treturn jwtMgr.publicKey, nil\n\t})\n\n\trequire.NoError(t, err)\n\tassert.True(t, token.Valid)\n\n\tmapClaims, ok := token.Claims.(jwt.MapClaims)\n\trequire.True(t, ok)\n\tassert.Equal(t, \"agentcube-router\", mapClaims[\"iss\"])\n\tassert.Equal(t, \"test-session\", mapClaims[\"session_id\"])\n}\n\nfunc TestJWTManagerGenerateTokenWithClaims(t *testing.T) {\n\tjwtMgr, err := NewJWTManager()\n\trequire.NoError(t, err)\n\n\tclaims := &RouterClaims{\n\t\tSessionID: \"test-session\",\n\t\tSandboxID: \"test-sandbox\",\n\t\tNamespace: \"test-namespace\",\n\t\tName:      \"test-name\",\n\t}\n\n\ttokenStr, err := jwtMgr.GenerateTokenWithClaims(claims)\n\trequire.NoError(t, err)\n\tassert.NotEmpty(t, tokenStr)\n\n\tvalidatedClaims, err := jwtMgr.ValidateToken(tokenStr)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"test-session\", validatedClaims.SessionID)\n\tassert.Equal(t, \"test-sandbox\", validatedClaims.SandboxID)\n\tassert.Equal(t, \"test-namespace\", validatedClaims.Namespace)\n\tassert.Equal(t, \"test-name\", validatedClaims.Name)\n}\n\nfunc TestJWTManagerGenerateTokenPair(t *testing.T) {\n\tjwtMgr, err := NewJWTManager()\n\trequire.NoError(t, err)\n\n\tclaims := &RouterClaims{\n\t\tSessionID: \"test-session\",\n\t\tSandboxID: \"test-sandbox\",\n\t\tNamespace: \"test-namespace\",\n\t\tName:      \"test-name\",\n\t}\n\n\ttokenPair, err := jwtMgr.GenerateTokenPair(claims)\n\trequire.NoError(t, err)\n\trequire.NotNil(t, tokenPair)\n\tassert.NotEmpty(t, tokenPair.AccessToken)\n\tassert.NotEmpty(t, tokenPair.RefreshToken)\n\tassert.Equal(t, \"Bearer\", tokenPair.TokenType)\n\tassert.Equal(t, int64(jwtExpiration.Seconds()), tokenPair.ExpiresIn)\n\n\taccessClaims, err := jwtMgr.ValidateToken(tokenPair.AccessToken)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"test-session\", accessClaims.SessionID)\n\n\trefreshClaims, err := jwtMgr.ValidateToken(tokenPair.RefreshToken)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"test-session\", refreshClaims.SessionID)\n\tassert.NotEmpty(t, refreshClaims.RegisteredClaims.ID)\n}\n\nfunc TestJWTManagerValidateToken(t *testing.T) {\n\tjwtMgr, err := NewJWTManager()\n\trequire.NoError(t, err)\n\n\ttoken, err := jwtMgr.GenerateToken(map[string]interface{}{\n\t\t\"session_id\": \"validate-session\",\n\t\t\"sandbox_id\": \"validate-sandbox\",\n\t\t\"namespace\":  \"validate-namespace\",\n\t\t\"name\":       \"validate-name\",\n\t})\n\trequire.NoError(t, err)\n\n\tclaims, err := jwtMgr.ValidateToken(token)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"validate-session\", claims.SessionID)\n\tassert.Equal(t, \"validate-sandbox\", claims.SandboxID)\n\tassert.Equal(t, \"validate-namespace\", claims.Namespace)\n\tassert.Equal(t, \"validate-name\", claims.Name)\n}\n\nfunc TestJWTManagerValidateTokenInvalid(t *testing.T) {\n\tjwtMgr, err := NewJWTManager()\n\trequire.NoError(t, err)\n\n\t_, err = jwtMgr.ValidateToken(\"invalid-token-string\")\n\trequire.Error(t, err)\n\tassert.IsType(t, &JWTValidationError{}, err)\n}\n\nfunc TestJWTManagerValidateTokenWrongKey(t *testing.T) {\n\tjwtMgr1, err := NewJWTManager()\n\trequire.NoError(t, err)\n\n\tjwtMgr2, err := NewJWTManager()\n\trequire.NoError(t, err)\n\n\ttoken, err := jwtMgr1.GenerateToken(map[string]interface{}{\n\t\t\"session_id\": \"wrong-key-session\",\n\t})\n\trequire.NoError(t, err)\n\n\t_, err = jwtMgr2.ValidateToken(token)\n\trequire.Error(t, err)\n\tassert.IsType(t, &JWTValidationError{}, err)\n}\n\nfunc TestJWTManagerRefreshToken(t *testing.T) {\n\tjwtMgr, err := NewJWTManager()\n\trequire.NoError(t, err)\n\n\tclaims := &RouterClaims{\n\t\tSessionID: \"refresh-session\",\n\t\tSandboxID: \"refresh-sandbox\",\n\t\tNamespace: \"refresh-namespace\",\n\t\tName:      \"refresh-name\",\n\t}\n\n\ttokenPair, err := jwtMgr.GenerateTokenPair(claims)\n\trequire.NoError(t, err)\n\n\tnewTokenPair, err := jwtMgr.RefreshToken(tokenPair.RefreshToken)\n\trequire.NoError(t, err)\n\trequire.NotNil(t, newTokenPair)\n\tassert.NotEmpty(t, newTokenPair.AccessToken)\n\tassert.NotEmpty(t, newTokenPair.RefreshToken)\n\n\tnewClaims, err := jwtMgr.ValidateToken(newTokenPair.AccessToken)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"refresh-session\", newClaims.SessionID)\n}\n\nfunc TestJWTManagerRefreshTokenWithAccessToken(t *testing.T) {\n\tjwtMgr, err := NewJWTManager()\n\trequire.NoError(t, err)\n\n\tclaims := &RouterClaims{\n\t\tSessionID: \"access-session\",\n\t}\n\n\ttoken, err := jwtMgr.GenerateTokenWithClaims(claims)\n\trequire.NoError(t, err)\n\n\t_, err = jwtMgr.RefreshToken(token)\n\trequire.Error(t, err)\n\tassert.IsType(t, &JWTValidationError{}, err)\n}\n\nfunc TestJWTManagerGetPublicKeyPEM(t *testing.T) {\n\tjwtMgr, err := NewJWTManager()\n\trequire.NoError(t, err)\n\n\tpemStr := jwtMgr.GetPublicKeyPEM()\n\tassert.NotEmpty(t, pemStr)\n\tassert.Contains(t, pemStr, \"PUBLIC KEY\")\n}\n\nfunc TestJWTManagerTokenExpiration(t *testing.T) {\n\tjwtMgr, err := NewJWTManager()\n\trequire.NoError(t, err)\n\n\ttokenStr, err := jwtMgr.GenerateToken(map[string]interface{}{})\n\trequire.NoError(t, err)\n\n\ttoken, err := jwt.Parse(tokenStr, func(token *jwt.Token) (interface{}, error) {\n\t\treturn jwtMgr.publicKey, nil\n\t})\n\trequire.NoError(t, err)\n\n\tmapClaims, ok := token.Claims.(jwt.MapClaims)\n\trequire.True(t, ok)\n\n\texp, ok := mapClaims[\"exp\"].(float64)\n\trequire.True(t, ok)\n\n\tnow := time.Now().Unix()\n\texpectedExp := now + int64(jwtExpiration.Seconds())\n\n\tassert.GreaterOrEqual(t, int64(exp), now)\n\tassert.LessOrEqual(t, int64(exp), expectedExp+5)\n\tassert.GreaterOrEqual(t, int64(exp), expectedExp-5)\n}\n\nfunc TestJWTManagerGetPublicKey(t *testing.T) {\n\tjwtMgr, err := NewJWTManager()\n\trequire.NoError(t, err)\n\n\tpubKey := jwtMgr.GetPublicKey()\n\trequire.NotNil(t, pubKey)\n\tassert.Equal(t, 2048/8, pubKey.Size())\n}\n\nfunc TestDefaultJWTConfig(t *testing.T) {\n\tconfig := DefaultJWTConfig()\n\trequire.NotNil(t, config)\n\tassert.Equal(t, jwtExpiration, config.TokenExpiry)\n\tassert.Equal(t, refreshExpiration, config.RefreshExpiry)\n\tassert.Equal(t, jwtIssuer, config.Issuer)\n\tassert.Equal(t, defaultClockSkew, config.ClockSkew)\n}\n\nfunc TestEncodePrivateKeyPEM(t *testing.T) {\n\tjwtMgr, err := NewJWTManager()\n\trequire.NoError(t, err)\n\n\tpemData := encodePrivateKeyPEM(jwtMgr.privateKey)\n\trequire.NotNil(t, pemData)\n\tassert.Contains(t, string(pemData), \"RSA PRIVATE KEY\")\n}\n\nfunc TestEncodePublicKeyPEM(t *testing.T) {\n\tjwtMgr, err := NewJWTManager()\n\trequire.NoError(t, err)\n\n\tpemData := encodePublicKeyPEM(jwtMgr.publicKey)\n\trequire.NotNil(t, pemData)\n\tassert.Contains(t, string(pemData), \"PUBLIC KEY\")\n}\n\nfunc TestLoadPrivateKeyPEM(t *testing.T) {\n\tjwtMgr, err := NewJWTManager()\n\trequire.NoError(t, err)\n\n\tpemData := encodePrivateKeyPEM(jwtMgr.privateKey)\n\tloadedKey, err := loadPrivateKeyPEM(pemData)\n\trequire.NoError(t, err)\n\tassert.Equal(t, 0, loadedKey.N.Cmp(jwtMgr.privateKey.N))\n}\n\nfunc TestLoadPrivateKeyPEMInvalid(t *testing.T) {\n\t_, err := loadPrivateKeyPEM([]byte(\"invalid pem data\"))\n\trequire.Error(t, err)\n}\n\nfunc TestLoadPrivateKeyPEMInvalidBlock(t *testing.T) {\n\t_, err := loadPrivateKeyPEM([]byte(\"-----BEGIN CERTIFICATE-----\\ninvalid\\n-----END CERTIFICATE-----\"))\n\trequire.Error(t, err)\n}\n\nfunc TestJWTManagerTryStoreOrLoadJWTKeySecretNoClient(t *testing.T) {\n\tjwtMgr, err := NewJWTManager()\n\trequire.NoError(t, err)\n\n\terr = jwtMgr.TryStoreOrLoadJWTKeySecret(context.Background())\n\tassert.NoError(t, err)\n}\n\nfunc TestJWTManagerLoadKeysFromSecretNoClient(t *testing.T) {\n\tjwtMgr, err := NewJWTManager()\n\trequire.NoError(t, err)\n\n\terr = jwtMgr.LoadKeysFromSecret(context.Background())\n\trequire.Error(t, err)\n\tassert.IsType(t, &JWTKeyLoadError{}, err)\n}\n\nfunc TestJWTManagerStoreKeysToSecretNoClient(t *testing.T) {\n\tjwtMgr, err := NewJWTManager()\n\trequire.NoError(t, err)\n\n\terr = jwtMgr.StoreKeysToSecret(context.Background())\n\trequire.Error(t, err)\n\tassert.IsType(t, &JWTKeyLoadError{}, err)\n}\n\nfunc TestRouterClaims(t *testing.T) {\n\tclaims := &RouterClaims{\n\t\tSessionID: \"claim-session\",\n\t\tSandboxID: \"claim-sandbox\",\n\t\tNamespace: \"claim-namespace\",\n\t\tName:      \"claim-name\",\n\t}\n\n\tjwtMgr, err := NewJWTManager()\n\trequire.NoError(t, err)\n\n\ttoken, err := jwtMgr.GenerateTokenWithClaims(claims)\n\trequire.NoError(t, err)\n\n\tvalidated, err := jwtMgr.ValidateToken(token)\n\trequire.NoError(t, err)\n\tassert.Equal(t, claims.SessionID, validated.SessionID)\n\tassert.Equal(t, claims.SandboxID, validated.SandboxID)\n\tassert.Equal(t, claims.Namespace, validated.Namespace)\n\tassert.Equal(t, claims.Name, validated.Name)\n}\n\nfunc TestTokenPair(t *testing.T) {\n\ttokenPair := &TokenPair{\n\t\tAccessToken:  \"access-token\",\n\t\tRefreshToken: \"refresh-token\",\n\t\tExpiresIn:    300,\n\t\tTokenType:    \"Bearer\",\n\t}\n\n\tassert.Equal(t, \"access-token\", tokenPair.AccessToken)\n\tassert.Equal(t, \"refresh-token\", tokenPair.RefreshToken)\n\tassert.Equal(t, int64(300), tokenPair.ExpiresIn)\n\tassert.Equal(t, \"Bearer\", tokenPair.TokenType)\n}\n\nfunc TestJWTManagerValidateTokenEmpty(t *testing.T) {\n\tjwtMgr, err := NewJWTManager()\n\trequire.NoError(t, err)\n\n\t_, err = jwtMgr.ValidateToken(\"\")\n\trequire.Error(t, err)\n}\n\nfunc BenchmarkJWTGenerateToken(b *testing.B) {\n\tjwtMgr, err := NewJWTManager()\n\tif err != nil {\n\t\tb.Fatalf(\"failed to create JWT manager: %v\", err)\n\t}\n\n\tclaims := map[string]interface{}{\n\t\t\"session_id\": \"bench-session\",\n\t\t\"sandbox_id\": \"bench-sandbox\",\n\t}\n\n\tb.ResetTimer()\n\tfor i := 0; i < b.N; i++ {\n\t\t_, _ = jwtMgr.GenerateToken(claims)\n\t}\n}\n\nfunc BenchmarkJWTValidateToken(b *testing.B) {\n\tjwtMgr, err := NewJWTManager()\n\tif err != nil {\n\t\tb.Fatalf(\"failed to create JWT manager: %v\", err)\n\t}\n\n\ttoken, err := jwtMgr.GenerateToken(map[string]interface{}{\n\t\t\"session_id\": \"bench-session\",\n\t})\n\tif err != nil {\n\t\tb.Fatalf(\"failed to generate token: %v\", err)\n\t}\n\n\tb.ResetTimer()\n\tfor i := 0; i < b.N; i++ {\n\t\t_, _ = jwtMgr.ValidateToken(token)\n\t}\n}\n\nfunc BenchmarkJWTGenerateTokenPair(b *testing.B) {\n\tjwtMgr, err := NewJWTManager()\n\tif err != nil {\n\t\tb.Fatalf(\"failed to create JWT manager: %v\", err)\n\t}\n\n\tclaims := &RouterClaims{\n\t\tSessionID: \"bench-session\",\n\t\tSandboxID: \"bench-sandbox\",\n\t}\n\n\tb.ResetTimer()\n\tfor i := 0; i < b.N; i++ {\n\t\t_, _ = jwtMgr.GenerateTokenPair(claims)\n\t}\n}\n\nfunc contains(s, substr string) bool {\n\treturn len(s) > 0 && len(substr) > 0 && len(s) >= len(substr)\n}\n","additions":1,"deletions":1},"truncated":false},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/jwt_test.go","time":{"start":1775853554491,"end":1775853554694}}}}
