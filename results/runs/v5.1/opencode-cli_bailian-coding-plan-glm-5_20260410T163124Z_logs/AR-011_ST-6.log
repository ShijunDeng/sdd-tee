, \"Status() returned 0 for %T\", err)\n\t\tassert.NotEmpty(t, err.Code(), \"Code() returned empty string for %T\", err)\n\t\tassert.NotEmpty(t, err.Message(), \"Message() returned empty string for %T\", err)\n\t\tassert.NotEmpty(t, err.Error(), \"Error() returned empty string for %T\", err)\n\t}\n}\n\nfunc TestJWTErrorInterface(t *testing.T) {\n\tjwtErrors := []APIStatus{\n\t\t&JWTSigningError{Err: errors.New(\"test\")},\n\t\t&JWTValidationError{Err: errors.New(\"test\")},\n\t\t&JWTTokenExpiredError{TokenID: \"test\"},\n\t\t&JWTTokenMissingError{},\n\t\t&JWTInvalidFormatError{Reason: \"test\"},\n\t\t&JWTKeyLoadError{Err: errors.New(\"test\")},\n\t}\n\n\tfor _, err := range jwtErrors {\n\t\tassert.IsType(t, err, err)\n\t}\n}\n","after":"package router\n\nimport (\n\t\"errors\"\n\t\"testing\"\n\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n)\n\nfunc TestSessionNotFoundError(t *testing.T) {\n\terr := &SessionNotFoundError{SessionID: \"test-session\"}\n\tassert.Equal(t, \"session not found: test-session\", err.Error())\n\tassert.Equal(t, 404, err.Status())\n\tassert.Equal(t, \"SESSION_NOT_FOUND\", err.Code())\n\tassert.Equal(t, \"session not found\", err.Message())\n}\n\nfunc TestSandboxUnreachableError(t *testing.T) {\n\terr := &SandboxUnreachableError{SandboxID: \"test-sandbox\"}\n\tassert.Equal(t, \"sandbox unreachable: test-sandbox\", err.Error())\n\tassert.Equal(t, 502, err.Status())\n\tassert.Equal(t, \"SANDBOX_UNREACHABLE\", err.Code())\n\tassert.Equal(t, \"sandbox unreachable\", err.Message())\n}\n\nfunc TestSandboxTimeoutError(t *testing.T) {\n\terr := &SandboxTimeoutError{SandboxID: \"test-sandbox\"}\n\tassert.Equal(t, \"sandbox timeout: test-sandbox\", err.Error())\n\tassert.Equal(t, 504, err.Status())\n\tassert.Equal(t, \"SANDBOX_TIMEOUT\", err.Code())\n\tassert.Equal(t, \"sandbox timeout\", err.Message())\n}\n\nfunc TestJWTSigningError(t *testing.T) {\n\tinnerErr := &SessionNotFoundError{SessionID: \"inner\"}\n\terr 