\"auth-enabled\" default:\"true\" usage:\"Enable authentication\"`\n126:     MaxExecTime  int    `flag:\"max-exec-time\" default:\"30\" usage:\"Maximum execution time in seconds\"`\n127:     MaxFileSize  int64  `flag:\"max-file-size\" default:\"10485760\" usage:\"Maximum file size in bytes\"`\n128:     SanitizeRoot string `flag:\"sanitize-root\" default:\"\" usage:\"Root directory for path sanitization\"`\n129: }\n130: ```\n131: \n132: ### Router CLI Configuration\n133: \n134: ```go\n135: package main\n136: \n137: type RouterConfig struct {\n138:     CLIConfig\n139:     Port                 string `flag:\"port\" default:\":8080\" usage:\"HTTP listening port\"`\n140:     MaxConcurrentRequests int   `flag:\"max-concurrent\" default:\"1000\" usage:\"Maximum concurrent requests\"`\n141:     Debug                bool   `flag:\"debug\" default:\"false\" usage:\"Enable debug mode\"`\n142:     EnableTLS            bool   `flag:\"enable-tls\" default:\"false\" usage:\"Enable TLS\"`\n143:     TLSCert              string `flag:\"tls-cert\" default:\"\" usage:\"TLS certificate file\"`\n144:     TLSKey               string `flag:\"tls-key\" default:\"\" usage:\"TLS key file\"`\n145:     StoreAddr            string `flag:\"store-addr\" default:\"\" usage:\"Redis/Valkey address\"`\n146:     StorePassword        string `flag:\"store-password\" default:\"\" usage:\"Redis/Valkey password\"`\n147:     StoreType            string `flag:\"store-type\" default:\"redis\" usage:\"Store type (redis, valkey)\"`\n148: }\n149: ```\n150: \n151: ### WorkloadManager CLI Configuration\n152: \n153: ```go\n154: package main\n155: \n156: type WorkloadManagerConfig struct {\n157:     CLIConfig\n158:     Addr              string        `flag:\"addr\" default:\":8080\" usage:\"HTTP server address\"`\n159:     ReadTimeout       time.Duration `flag:\"read-timeout\" default:\"30s\" usage:\"HTTP read timeout\"`\n160:     WriteTimeout      time.Duration `flag:\"write-timeout\" default:\"30s\" usage:\"HTTP write timeout\"`\n161:     IdleTimeout       time.Duration `flag:\"idle-timeout\" default:\"90s\" usage:\"HTTP idle timeout\"`\n162:     ShutdownTimeout   time.Duration `flag:\"shutdown-timeout\" default:\"10s\" usage:\"Graceful shutdown timeout\"`\n163:     GCInterval        time.Duration `flag:\"gc-interval\" default:\"5m\" usage:\"Garbage collection interval\"`\n164:     GCOnceTimeout     time.Duration `flag:\"gc-once-timeout\" default:\"30s\" usage:\"Single GC run timeout\"`\n165:     Kubeconfig        string        `flag:\"kubeconfig\" default:\"\" usage:\"Kubernetes config file path\"`\n166:     MasterURL         string        `flag:\"master-url\" default:\"\" usage:\"Kubernetes API server URL\"`\n167: }\n168: ```\n169: \n170: ### Agentd CLI Configuration\n171: \n172: ```go\n173: package main\n174: \n175: type AgentdConfig struct {\n176:     CLIConfig\n177:     IdleThreshold        time.Duration `flag:\"idle-threshold\" default:\"30m\" usage:\"Idle threshold for cleanup\"`\n178:     CheckInterval        time.Duration `flag:\"check-interval\" default:\"5m\" usage:\"Cleanup check interval\"`\n179:     MaxConcurrentCleanup int           `flag:\"max-concurrent\" default:\"10\" usage:\"Maximum concurrent cleanups\"`\n180:     Namespaces           []string      `flag:\"namespace\" default:\"default\" usage:\"Namespaces to watch\"`\n181:     LeaderElection       bool          `flag:\"leader-election\" default:\"true\" usage:\"Enable leader election\"`\n182:     LeaderElectionID     string        `flag:\"leader-election-id\" default:\"agentcube-agentd\" usage:\"Leader election ID\"`\n183:     Kubeconfig           string        `flag:\"kubeconfig\" default:\"\" usage:\"Kubernetes config file path\"`\n184: }\n185: ```\n186: \n187: ---\n188: \n189: ## API Contracts\n190: \n191: ### Binary Entry Point Interface\n192: \n193: Each binary follows this pattern:\n194: \n195: ```go\n196: package main\n197: \n198: type Binary interface {\n199:     InitFlags() *Config\n200:     ValidateConfig(cfg *Config) error\n201:     Run(ctx context.Context, cfg *Config) error\n202:     Shutdown(ctx context.Context) error\n203: }\n204: \n205: func main() {\n206:     klog.InitFlags(nil)\n207:     flag.Parse()\n208:     \n209:     cfg := InitFlags()\n210:     if err := ValidateConfig(cfg); err != nil {\n211:         klog.Fatalf(\"invalid config: %v\", err)\n212:         os.Exit(1)\n213:     }\n214:     \n215:     ctx, cancel := signal.NotifyContext(context.Background(), syscall.SIGTERM, syscall.SIGINT)\n216:     defer cancel()\n217:     \n218:     if err := Run(ctx, cfg); err != nil {\n219:         klog.Fatalf(\"run error: %v\", err)\n220:         os.Exit(1)\n221:     }\n222: }\n223: ```\n224: \n225: ### Signal Handling Contract\n226: \n227: ```go\n228: package main\n229: \n230: func setupSignalHandler() context.Context {\n231:     ctx, cancel := context.WithCancel(context.Background())\n232:     \n233:     c := make(chan os.Signal, 2)\n234:     signal.Notify(c, syscall.SIGTERM, syscall.SIGINT)\n235:     \n236:     go func() {\n237:         sig := <-c\n238:         klog.InfoS(\"received signal\", \"signal\", sig)\n239:         cancel()\n240:         \n241:         if sig == syscall.SIGKILL {\n242:             <-c\n243:             klog.InfoS(\"received second signal, forcing exit\")\n244:             os.Exit(1)\n245:         }\n246:     }()\n247:     \n248:     return ctx\n249: }\n250: ```\n251: \n252: ### Health Check Contract\n253: \n254: ```go\n255: package main\n256: \n257: type HealthChecker interface {\n258:     Live() bool\n259:     Ready() bool\n260: }\n261: \n262: func (h *HealthServer) Start(addr string) error {\n263:     mux := http.NewServeMux()\n264:     mux.HandleFunc(\"/live\", func(w http.ResponseWriter, r *http.Request) {\n265:         if h.Live() {\n266:             w.WriteHeader(http.StatusOK)\n267:             w.Write([]byte(\"OK\"))\n268:         } else {\n269:             w.WriteHeader(http.StatusServiceUnavailable)\n270:         }\n271:     })\n272:     mux.HandleFunc(\"/ready\", func(w http.ResponseWriter, r *http.Request) {\n273:         if h.Ready() {\n274:             w.WriteHeader(http.StatusOK)\n275:             w.Write([]byte(\"OK\"))\n276:         } else {\n277:             w.WriteHeader(http.StatusServiceUnavailable)\n278:         }\n279:     })\n280:     return http.ListenAndServe(addr, mux)\n281: }\n282: ```\n283: \n284: ### Flag Registration Contract\n285: \n286: ```go\n287: package main\n288: \n289: func InitFlags() *Config {\n290:     cfg := &Config{}\n291:     \n292:     klog.InitFlags(nil)\n293:     flag.Set(\"logtostderr\", \"true\")\n294:     \n295:     flag.StringVar(&cfg.LogLevel, \"log-level\", \"info\", \"Log level\")\n296:     flag.StringVar(&cfg.MetricsAddr, \"metrics-addr\", \"0\", \"Metrics address\")\n297:     flag.StringVar(&cfg.HealthAddr, \"health-addr\", \"\", \"Health address\")\n298:     \n299:     flag.Parse()\n300:     \n301:     return cfg\n302: }\n303: ```\n304: \n305: ---\n306: \n307: ## Binary Implementation Details\n308: \n309: ### 1. picod (cmd/picod/main.go)\n310: \n311: **Purpose**: Local code execution daemon running as a sidecar in sandbox pods.\n312: \n313: **Current Implementation** (pkg/picod/server.go:26-77):\n314: \n315: ```go\n316: func main() {\n317:     klog.InitFlags(nil)\n318:     flag.Set(\"logtostderr\", \"true\")\n319: \n320:     port := flag.Int(\"port\", 8080, \"HTTP listening port\")\n321:     workspace := flag.String(\"workspace\", \"\", \"Workspace directory path\")\n322:     flag.Parse()\n323: \n324:     config := &picod.Config{\n325:         Port:      *port,\n326:         Workspace: *workspace,\n327:     }\n328: \n329:     server, err := picod.NewServer(config)\n330:     if err != nil {\n331:         klog.Fatalf(\"failed to create server: %v\", err)\n332:         os.Exit(1)\n333:     }\n334: \n335:     if err := server.Run(context.Background()); err != nil {\n336:         klog.Fatalf(\"server error: %v\", err)\n337:         os.Exit(1)\n338:     }\n339: }\n340: ```\n341: \n342: **Endpoints**:\n343: | Path | Method | Purpose |\n344: |------|--------|---------|\n345: | `/health` | GET | Health check |\n346: | `/api/execute` | POST | Execute code |\n347: | `/api/files` | POST | Upload file |\n348: | `/api/files` | GET | List files |\n349: | `/api/files/*path` | GET | Download file |\n350: \n351: ### 2. router (cmd/router/main.go)\n352: \n353: **Purpose**: Session routing and reverse proxy for agent/code interpreter invocations.\n354: \n355: **Implementation Template**:\n356: \n357: ```go\n358: func main() {\n359:     klog.InitFlags(nil)\n360:     flag.Set(\"logtostderr\", \"true\")\n361:     \n362:     cfg := &RouterConfig{}\n363:     flag.StringVar(&cfg.Port, \"port\", \":8080\", \"HTTP listening port\")\n364:     flag.StringVar(&cfg.StoreAddr, \"store-addr\", \"\", \"Redis/Valkey address\")\n365:     flag.StringVar(&cfg.StoreType, \"store-type\", \"redis\", \"Store type\")\n366:     flag.IntVar(&cfg.MaxConcurrentRequests, \"max-concurrent\", 1000, \"Max concurrent requests\")\n367:     flag.BoolVar(&cfg.Debug, \"debug\", false, \"Enable debug mode\")\n368:     flag.Parse()\n369:     \n370:     ctx := setupSignalHandler()\n371:     \n372:     store, err := initStore(cfg)\n373:     if err != nil {\n374:         klog.Fatalf(\"failed to init store: %v\", err)\n375:     }\n376:     \n377:     sessionManager := router.NewSessionManager(store)\n378:     jwtManager := router.NewJWTManager()\n379:     \n380:     server := router.NewServer(&router.Config{\n381:         Port:                 cfg.Port,\n382:         MaxConcurrentRequests: cfg.MaxConcurrentRequests,\n383:         Debug:                cfg.Debug,\n384:     }, sessionManager, store, jwtManager, klog.Logger{})\n385:     \n386:     if err := server.Start(ctx); err != nil {\n387:         klog.Fatalf(\"router error: %v\", err)\n388:     }\n389: }\n390: ```\n391: \n392: **Endpoints**:\n393: | Path | Method | Purpose |\n394: |------|--------|---------|\n395: | `/health/live` | GET | Liveness probe |\n396: | `/health/ready` | GET | Readiness probe |\n397: | `/v1/namespaces/:namespace/agent-runtimes/:name/invocations/*path` | GET/POST | Agent invocation proxy |\n398: | `/v1/namespaces/:namespace/code-interpreters/:name/invocations/*path` | GET/POST | Code interpreter proxy |\n399: \n400: ### 3. workloadmanager (cmd/workloadmanager/main.go)\n401: \n402: **Purpose**: Workload manager HTTP server for sandbox lifecycle management.\n403: \n404: **Implementation Template**:\n405: \n406: ```go\n407: func main() {\n408:     klog.InitFlags(nil)\n409:     flag.Set(\"logtostderr\", \"true\")\n410:     \n411:     cfg := &WorkloadManagerConfig{}\n412:     flag.StringVar(&cfg.Addr, \"addr\", \":8080\", \"HTTP server address\")\n413:     flag.DurationVar(&cfg.ReadTimeout, \"read-timeout\", 30*time.Second, \"Read timeout\")\n414:     flag.DurationVar(&cfg.WriteTimeout, \"write-timeout\", 30*time.Second, \"Write timeout\")\n415:     flag.DurationVar(&cfg.GCInterval, \"gc-interval\", 5*time.Minute, \"GC interval\")\n416:     flag.StringVar(&cfg.Kubeconfig, \"kubeconfig\", \"\", \"Kubeconfig path\")\n417:     flag.Parse()\n418:     \n419:     ctx := setupSignalHandler()\n420:     \n421:     k8sClient, err := workloadmanager.NewK8sClient(cfg.Kubeconfig, cfg.MasterURL)\n422:     if err != nil {\n423:         klog.Fatalf(\"failed to create k8s client: %v\", err)\n424:     }\n425:     \n426:     store, err := initStore(cfg)\n427:     if err != nil {\n428:         klog.Fatalf(\"failed to init store: %v\", err)\n429:     }\n430:     \n431:     server := workloadmanager.NewHTTPServerWithClients(\n432:         workloadmanager.Config{\n433:             Addr:            cfg.Addr,\n434:             ReadTimeout:     cfg.ReadTimeout,\n435:             WriteTimeout:    cfg.WriteTimeout,\n436:             ShutdownTimeout: cfg.ShutdownTimeout,\n437:         },\n438:         klog.Logger{},\n439:         k8sClient,\n440:         store,\n441:     )\n442:     \n443:     server.RegisterHandler(\"health\", workloadmanager.NewHealthHandler())\n444:     server.RegisterHandler(\"sandbox\", workloadmanager.NewSandboxHandler(k8sClient, store))\n445:     \n446:     server.GracefulShutdown()\n447:     \n448:     errCh := server.Start()\n449:     select {\n450:     case err := <-errCh:\n451:         klog.Fatalf(\"workloadmanager error: %v\", err)\n452:     case <-ctx.Done():\n453:         server.Stop(context.Background())\n454:     }\n455: }\n456: ```\n457: \n458: **Endpoints**:\n459: | Path | Method | Purpose |\n460: |------|--------|---------|\n461: | `/health/live` | GET | Liveness probe |\n462: | `/health/ready` | GET | Readiness probe |\n463: | `/sandboxes` | POST | Create sandbox |\n464: | `/sandboxes/:id` | GET | Get sandbox |\n465: | `/sandboxes/:id` | DELETE | Delete sandbox |\n466: \n467: ### 4. agentd (cmd/agentd/main.go)\n468: \n469: **Purpose**: Kubernetes controller for idle resource cleanup using controller-runtime.\n470: \n471: **Implementation Template**:\n472: \n473: ```go\n474: func main() {\n475:     klog.InitFlags(nil)\n476:     flag.Set(\"logtostderr\", \"true\")\n477:     \n478:     cfg := &AgentdConfig{}\n479:     flag.DurationVar(&cfg.IdleThreshold, \"idle-threshold\", 30*time.Minute, \"Idle threshold\")\n480:     flag.DurationVar(&cfg.CheckInterval, \"check-interval\", 5*time.Minute, \"Check interval\")\n481:     flag.IntVar(&cfg.MaxConcurrentCleanup, \"max-concurrent\", 10, \"Max concurrent cleanups\")\n482:     flag.BoolVar(&cfg.LeaderElection, \"leader-election\", true, \"Enable leader election\")\n483:     flag.StringVar(&cfg.LeaderElectionID, \"leader-election-id\", \"agentcube-agentd\", \"Leader election ID\")\n484:     flag.Parse()\n485:     \n486:     k8sConfig, err := ctrl.GetConfig()\n487:     if err != nil {\n488:         klog.Fatalf(\"failed to get k8s config: %v\", err)\n489:     }\n490:     \n491:     mgr, err := ctrl.NewManager(k8sConfig, ctrl.Options{\n492:         LeaderElection:          cfg.LeaderElection,\n493:         LeaderElectionID:        cfg.LeaderElectionID,\n494:         LeaderElectionNamespace: \"default\",\n495:     })\n496:     if err != nil {\n497:         klog.Fatalf(\"failed to create manager: %v\", err)\n498:     }\n499:     \n500:     if err := agentd.SetupIdleCleanupController(mgr, cfg); err != nil {\n501:         klog.Fatalf(\"failed to setup controller: %v\", err)\n502:     }\n503:     \n504:     klog.InfoS(\"starting agentd controller\")\n505:     if err := mgr.Start(ctrl.SetupSignalHandler()); err != nil {\n506:         klog.Fatalf(\"controller error: %v\", err)\n507:     }\n508: }\n509: ```\n510: \n511: ---\n512: \n513: ## Error Handling\n514: \n515: ### Error Categories\n516: \n517: | Category | Description | Action |\n518: |----------|-------------|--------|\n519: | `ErrConfigInvalid` | Configuration validation failure | Log fatal, exit 1 |\n520: | `ErrStoreConnect` | Store connection failure | Log fatal, exit 1 |\n521: | `ErrK8sConnect` | Kubernetes connection failure | Log fatal, exit 1 |\n522: | `ErrServerStart` | HTTP server start failure | Log fatal, exit 1 |\n523: | `ErrSignalReceived` | Graceful shutdown triggered | Log info, cancel context |\n524: | `ErrShutdownTimeout` | Shutdown exceeded timeout | Log warning, force exit |\n525: \n526: ### Error Handling Pattern\n527: \n528: ```go\n529: func handleStartupError(component string, err error) {\n530:     if errors.Is(err, context.Canceled) {\n531:         klog.InfoS(\"shutdown requested\")\n532:         return\n533:     }\n534:     \n535:     if errors.Is(err, syscall.SIGTERM) || errors.Is(err, syscall.SIGINT) {\n536:         klog.InfoS(\"received termination signal\", \"signal\", err)\n537:         return\n538:     }\n539:     \n540:     klog.ErrorS(err, \"startup failure\", \"component\", component)\n541:     os.Exit(1)\n542: }\n543: ```\n544: \n545: ### Graceful Shutdown Sequence\n546: \n547: ```\n548: 1. Signal received (SIGTERM/SIGINT)\n549: 2. Cancel main context\n550: 3. Stop accepting new requests\n551: 4. Wait for in-flight requests (timeout configurable)\n552: 5. Close store connections\n553: 6. Close K8s client connections\n554: 7. Exit with code 0\n555: ```\n556: \n557: ### Validation Errors\n558: \n559: ```go\n560: func ValidateConfig(cfg *Config) error {\n561:     if cfg.Port <= 0 || cfg.Port > 65535 {\n562:         return fmt.Errorf(\"invalid port: %d\", cfg.Port)\n563:     }\n564:     \n565:     if cfg.IdleThreshold < 0 {\n566:         return fmt.Errorf(\"invalid idle threshold: %v\", cfg.IdleThreshold)\n567:     }\n568:     \n569:     if cfg.CheckInterval < 0 {\n570:         return fmt.Errorf(\"invalid check interval: %v\", cfg.CheckInterval)\n571:     }\n572:     \n573:     if cfg.MaxConcurrentCleanup < 0 {\n574:         return fmt.Errorf(\"invalid max concurrent cleanup: %d\", cfg.MaxConcurrentCleanup)\n575:     }\n576:     \n577:     return nil\n578: }\n579: ```\n580: \n581: ---\n582: \n583: ## Testing Strategy\n584: \n585: ### Unit Tests\n586: \n587: #### Flag Parsing Tests\n588: \n589: ```go\n590: func TestInitFlags(t *testing.T) {\n591:     tests := []struct {\n592:         name     string\n593:         args     []string\n594:         expected *Config\n595:     }{\n596:         {\n597:             name: \"default values\",\n598:             args: []string{},\n599:             expected: &Config{\n600:                 Port:           8080,\n601:                 LogLevel:       \"info\",\n602:                 IdleThreshold:  30 * time.Minute,\n603:             },\n604:         },\n605:         {\n606:             name: \"custom port\",\n607:             args: []string{\"-port\", \"9000\"},\n608:             expected: &Config{\n609:                 Port:          9000,\n610:             },\n611:         },\n612:         {\n613:             name: \"multiple flags\",\n614:             args: []string{\"-port\", \"9000\", \"-debug\", \"true\"},\n615:             expected: &Config{\n616:                 Port:  9000,\n617:                 Debug: true,\n618:             },\n619:         },\n620:     }\n621:     \n622:     for _, tt := range tests {\n623:         t.Run(tt.name, func(t *testing.T) {\n624:             fs := flag.NewFlagSet(\"test\", flag.ContinueOnError)\n625:             cfg := &Config{}\n626:             setupFlags(fs, cfg)\n627:             \n628:             err := fs.Parse(tt.args)\n629:             require.NoError(t, err)\n630:             \n631:             assert.Equal(t, tt.expected.Port, cfg.Port)\n632:         })\n633:     }\n634: }\n635: ```\n636: \n637: #### Signal Handler Tests\n638: \n639: ```go\n640: func TestSignalHandler(t *testing.T) {\n641:     ctx := setupSignalHandler()\n642:     \n643:     syscall.Kill(syscall.Getpid(), syscall.SIGTERM)\n644:     \n645:     select {\n646:     case <-ctx.Done():\n647:         assert.True(t, true)\n648:     case <-time.After(5 * time.Second):\n649:         t.Fatal(\"signal handler did not cancel context\")\n650:     }\n651: }\n652: ```\n653: \n654: #### Config Validation Tests\n655: \n656: ```go\n657: func TestValidateConfig(t *testing.T) {\n658:     tests := []struct {\n659:         name        string\n660:         config      *Config\n661:         expectError bool\n662:     }{\n663:         {\n664:             name: \"valid config\",\n665:             config: &Config{\n666:                 Port:          8080,\n667:                 IdleThreshold: 30 * time.Minute,\n668:             },\n669:             expectError: false,\n670:         },\n671:         {\n672:             name: \"invalid port\",\n673:             config: &Config{\n674:                 Port: -1,\n675:             },\n676:             expectError: true,\n677:         },\n678:         {\n679:             name: \"invalid idle threshold\",\n680:             config: &Config{\n681:                 IdleThreshold: -1 * time.Minute,\n682:             },\n683:             expectError: true,\n684:         },\n685:     }\n686:     \n687:     for _, tt := range tests {\n688:         t.Run(tt.name, func(t *testing.T) {\n689:             err := ValidateConfig(tt.config)\n690:             if tt.expectError {\n691:                 assert.Error(t, err)\n692:             } else {\n693:                 assert.NoError(t, err)\n694:             }\n695:         })\n696:     }\n697: }\n698: ```\n699: \n700: ### Integration Tests\n701: \n702: #### Binary Startup Tests\n703: \n704: ```go\n705: func TestBinaryStartup(t *testing.T) {\n706:     if testing.Short() {\n707:         t.Skip(\"skipping integration test\")\n708:     }\n709:     \n710:     binary := buildBinary(t, \"picod\")\n711:     \n712:     cmd := exec.Command(binary, \"-port\", \"18080\")\n713:     cmd.Stdout = &bytes.Buffer{}\n714:     cmd.Stderr = &bytes.Buffer{}\n715:     \n716:     err := cmd.Start()\n717:     require.NoError(t, err)\n718:     \n719:     defer cmd.Process.Kill()\n720:     \n721:     assert.Eventually(t, func() bool {\n722:         resp, err := http.Get(\"http://localhost:18080/health\")\n723:         if err != nil {\n724:             return false\n725:         }\n726:         defer resp.Body.Close()\n727:         return resp.StatusCode == http.StatusOK\n728:     }, 10*time.Second, 100*time.Millisecond)\n729: }\n730: ```\n731: \n732: #### Graceful Shutdown Tests\n733: \n734: ```go\n735: func TestGracefulShutdown(t *testing.T) {\n736:     binary := buildBinary(t, \"router\")\n737:     \n738:     cmd := exec.Command(binary, \"-port\", \":18080\", \"-store-type\", \"memory\")\n739:     cmd.Stdout = &bytes.Buffer{}\n740:     cmd.Stderr = &bytes.Buffer{}\n741:     \n742:     err := cmd.Start()\n743:     require.NoError(t, err)\n744:     \n745:     waitForHealthy(t, \"http://localhost:18080/health/live\")\n746:     \n747:     syscall.Kill(cmd.Process.Pid, syscall.SIGTERM)\n748:     \n749:     done := make(chan error, 1)\n750:     go func() {\n751:         done <- cmd.Wait()\n752:     }()\n753:     \n754:     select {\n755:     case err := <-done:\n756:         assert.NoError(t, err)\n757:     case <-time.After(15 * time.Second):\n758:         t.Fatal(\"binary did not shutdown within timeout\")\n759:     }\n760: }\n761: ```\n762: \n763: ### Build Tests\n764: \n765: ```go\n766: func TestBuildAllBinaries(t *testing.T) {\n767:     binaries := []string{\"picod\", \"router\", \"workloadmanager\", \"agentd\"}\n768:     \n769:     for _, binary := range binaries {\n770:         t.Run(binary, func(t *testing.T) {\n771:             cmd := exec.Command(\"go\", \"build\", \"-o\", \"/tmp/\"+binary, \"./cmd/\"+binary)\n772:             output, err := cmd.CombinedOutput()\n773:             assert.NoError(t, err, \"build output: %s\", output)\n774:             \n775:             assert.FileExists(t, \"/tmp/\"+binary)\n776:         })\n777:     }\n778: }\n779: ```\n780: \n781: ---\n782: \n783: ## Metrics\n784: \n785: ### Prometheus Metrics\n786: \n787: ```go\n788: var (\n789:     startupDuration = prometheus.NewGaugeVec(\n790:         prometheus.GaugeOpts{\n791:             Name: \"agentcube_binary_startup_duration_seconds\",\n792:             Help: \"Time taken for binary startup\",\n793:         },\n794:         []string{\"binary\"},\n795:     )\n796:     \n797:     shutdownDuration = prometheus.NewGaugeVec(\n798:         prometheus.GaugeOpts{\n799:             Name: \"agentcube_binary_shutdown_duration_seconds\",\n800:             Help: \"Time taken for graceful shutdown\",\n801:         },\n802:         []string{\"binary\"},\n803:     )\n804:     \n805:     configReloadCount = prometheus.NewCounterVec(\n806:         prometheus.CounterOpts{\n807:             Name: \"agentcube_binary_config_reload_total\",\n808:             Help: \"Number of configuration reloads\",\n809:         },\n810:         []string{\"binary\"},\n811:     )\n812: )\n813: ```\n814: \n815: ---\n816: \n817: ## Configuration\n818: \n819: ### Environment Variables\n820: \n821: | Variable | Binary | Purpose |\n822: |----------|--------|---------|\n823: | `PORT` | picod, router, workloadmanager | HTTP port override |\n824: | `WORKSPACE` | picod | Workspace directory |\n825: | `STORE_ADDR` | router, workloadmanager | Redis/Valkey address |\n826: | `STORE_TYPE` | router, workloadmanager | Store backend type |\n827: | `KUBECONFIG` | workloadmanager, agentd | Kubernetes config path |\n828: | `LOG_LEVEL` | all | Log level override |\n829: \n830: ### Command-Line Flags Summary\n831: \n832: | Flag | Default | Purpose |\n833: |------|---------|---------|\n834: | `-port` | 8080 | HTTP listening port |\n835: | `-workspace` | current dir | Workspace directory (picod) |\n836: | `-idle-threshold` | 30m | Idle cleanup threshold (agentd) |\n837: | `-check-interval` | 5m | Cleanup check interval (agentd) |\n838: | `-leader-election` | true | Enable leader election (agentd) |\n839: | `-kubeconfig` | in-cluster | Kubernetes config path |\n840: | `-debug` | false | Enable debug mode (router) |\n841: | `-metrics-addr` | 0 | Prometheus metrics address |\n842: \n843: ---\n844: \n845: ## Build Configuration\n846: \n847: ### Go Module\n848: \n849: ```go\n850: // go.mod\n851: module github.com/volcano-sh/agentcube\n852: \n853: go 1.24\n854: \n855: require (\n856:     github.com/gin-gonic/gin v1.x\n857:     github.com/go-chi/chi/v5 v5.x\n858:     k8s.io/klog/v2 v2.x\n859:     sigs.k8s.io/controller-runtime v0.19.x\n860: )\n861: ```\n862: \n863: ### Makefile Targets\n864: \n865: ```makefile\n866: .PHONY: build clean\n867: \n868: build:\n869: \tgo build -o bin/picod ./cmd/picod\n870: \tgo build -o bin/router ./cmd/router\n871: \tgo build -o bin/workloadmanager ./cmd/workloadmanager\n872: \tgo build -o bin/agentd ./cmd/agentd\n873: \n874: clean:\n875: \trm -rf bin/\n876: \n877: build-picod:\n878: \tgo build -o bin/picod ./cmd/picod\n879: \n880: build-router:\n881: \tgo build -o bin/router ./cmd/router\n882: \n883: build-workloadmanager:\n884: \tgo build -o bin/workloadmanager ./cmd/workloadmanager\n885: \n886: build-agentd:\n887: \tgo build -o bin/agentd ./cmd/agentd\n888: ```\n889: \n890: ### Docker Build\n891: \n892: ```dockerfile\n893: # Dockerfile for picod\n894: FROM golang:1.24-alpine AS builder\n895: WORKDIR /app\n896: COPY . .\n897: RUN go build -o /picod ./cmd/picod\n898: \n899: FROM alpine:3.19\n900: COPY --from=builder /picod /picod\n901: ENTRYPOINT [\"/picod\"]\n902: ```\n903: \n904: ---\n905: \n906: ## Implementation Checklist\n907: \n908: - [x] `cmd/picod/main.go` - PicoD entry point (implemented)\n909: - [ ] `cmd/router/main.go` - Router entry point\n910: - [ ] `cmd/workloadmanager/main.go` - WorkloadManager entry point\n911: - [ ] `cmd/agentd/main.go` - Agentd entry point\n912: - [ ] Common signal handling package\n913: - [ ] Common flag validation utilities\n914: - [ ] Health check server integration\n915: - [ ] Metrics server integration\n916: - [ ] Unit tests for flag parsing\n917: - [ ] Unit tests for config validation\n918: - [ ] Integration tests for binary startup\n919: - [ ] Integration tests for graceful shutdown\n920: - [ ] Makefile build targets\n921: - [ ] Docker build configurations\n922: - [ ] Helm deployment manifests\n923: \n924: ---\n925: \n926: ## Dependencies\n927: \n928: | Package | Version | Purpose |\n929: |---------|---------|---------|\n930: | `k8s.io/klog/v2` | v2.x | Structured logging |\n931: | `github.com/spf13/pflag` | v1.x | POSIX/GNU-style flags |\n932: | `sigs.k8s.io/controller-runtime` | v0.19.x | Controller utilities (agentd) |\n933: | `github.com/gin-gonic/gin` | v1.x | HTTP framework (picod, router) |\n934: | `github.com/go-chi/chi/v5` | v5.x | HTTP framework (workloadmanager) |\n935: | `github.com/prometheus/client_golang` | v1.x | Metrics |\n\n(End of file - total 935 lines)\n</content>","metadata":{"preview":"# AR-019: CLI Binary Entry Points (4 Binaries)\n\n## Overview\n\nThis module defines the CLI binary entry points for the agentcube system, consisting of four main executables:\n\n| Binary | Purpose | Module | HTTP Framework |\n|--------|---------|--------|----------------|\n| `picod` | Local code execution daemon | `pkg/picod` | Gin |\n| `router` | Session routing and reverse proxy | `pkg/router` | Gin |\n| `workloadmanager` | Workload manager HTTP server | `pkg/workloadmanager` | Chi |\n| `agentd` | Agent daemon (idle cleanup controller) | `pkg/agentd` | controller-runtime |\n\n---\n\n## Architecture\n\n### Directory Structure\n\n```","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/design.md","time":{"start":1775889150426,"end":1775889150436}}}}
{"type":"tool_use","timestamp":1775889150440,"sessionID":"ses_284c266ecffec55s5eapOZAOMv","part":{"id":"prt_d7b3df1ba001mnV8VV64GgBrtw","messageID":"msg_d7b3dd55800118985E1M6zSX1Z","sessionID":"ses_284c266ecffec55s5eapOZAOMv","type":"tool","tool":"read","callID":"toolu_tool-e49f61e64dd74e8c95007745ebfd3935","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/delta-spec.md"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/delta-spec.md</path>\n<type>file</type>\n<content>\n1: # Delta Specification: AR-034 вҖ” CI/CD GitHub Actions (12 workflows)\n2: \n3: **Module:** .github  \n4: **Language:** YAML  \n5: **Size:** L\n6: \n7: ---\n8: \n9: ## Purpose\n10: \n11: Automate validation on pull requests (build, lint, tests, codegen drift checks), publish container images on pushes to `main` and version tags, run end-to-end tests on Kind, exercise the Python SDK, and enforce spelling and copyright consistency.\n12: \n13: ---\n14: \n15: ## Requirements\n16: \n17: ### Requirement: Pull Request Docker Build Verification\n18: \n19: The system SHALL build the Workload Manager Docker image on pull requests targeting `main` or `release-*` branches.\n20: \n21: #### Scenario: Docker Buildx Setup\n22: \n23: - **GIVEN** a pull request to `main` or `release-*` branch\n24: - **WHEN** the \"Agentcube CI Workflow\" job runs\n25: - **THEN** the workflow SHALL checkout the repository\n26: - **AND** set up Docker Buildx with `docker/setup-buildx-action@v3`\n27: - **AND** verify `docker --version` and `docker buildx version` outputs\n28: \n29: #### Scenario: Docker Build Execution\n30: \n31: - **GIVEN** Docker Buildx is configured\n32: - **WHEN** the build step executes\n33: - **THEN** the workflow SHALL run `make docker-build`\n34: - **AND** the job SHALL complete successfully if build passes\n35: \n36: ---\n37: \n38: ### Requirement: E2E Testing on Kind\n39: \n40: The system SHALL run `make e2e` in CI using a Kind-capable Ubuntu runner, capturing logs on failure.\n41: \n42: #### Scenario: Kind Tool Installation\n43: \n44: - **GIVEN** a pull request to `main` or `release-*` branch\n45: - **WHEN** the E2E workflow runs\n46: - **THEN** the workflow SHALL use `helm/kind-action@v1` with `install_only: true`\n47: - **AND** Kind version SHALL be `v0.30.0`\n48: \n49: #### Scenario: E2E Execution\n50: \n51: - **GIVEN** Kind tool is installed\n52: - **WHEN** the E2E test step runs\n53: - **THEN** the workflow SHALL set `ARTIFACTS_PATH=${{ github.workspace }}/e2e-logs`\n54: - **AND** use Go `1.23`\n55: - **AND** run `make e2e`\n56: \n57: #### Scenario: E2E Failure Artifacts\n58: \n59: - **GIVEN** the E2E tests fail\n60: - **WHEN** the failure handling step executes\n61: - **THEN** the workflow SHALL upload `e2e-logs` directory as artifact\n62: \n63: #### Scenario: E2E Cleanup\n64: \n65: - **GIVEN** E2E tests complete (success or failure)\n66: - **WHEN** the cleanup step runs\n67: - **THEN** the workflow SHALL execute `make e2e-clean`\n68: - **AND** cleanup SHALL run even if tests fail (using `if: always()`)\n69: \n70: ---\n71: \n72: ### Requirement: Go Lint on Changed Go Code\n73: \n74: The system SHALL run `make lint` (golangci-lint) when Go-related paths change on pull requests to `main` or `release-*`.\n75: \n76: #### Scenario: Path Filter Configuration\n77: \n78: - **GIVEN** a pull request to `main` or `release-*` branch\n79: - **WHEN** the Lint workflow runs\n80: - **THEN** the workflow SHALL use `dorny/paths-filter@v3`\n81: - **AND** the `lint` filter SHALL match `**/*.go`, `go.mod`, `go.sum`, `.golangci.yml`, `.github/workflows/lint.yml`\n82: \n83: #### Scenario: Lint Execution\n84: \n85: - **GIVEN** path filter `lint` matches changed files\n86: - **WHEN** the lint job executes\n87: - **THEN** the workflow SHALL use Go `1.24`\n88: - **AND** run `make lint`\n89: \n90: #### Scenario: Lint Skip\n91: \n92: - **GIVEN** path filter `lint` does NOT match changed files\n93: - **WHEN** the workflow evaluates the filter\n94: - **THEN** the lint job SHALL be skipped\n95: \n96: ---\n97: \n98: ### Requirement: Code Generation Check\n99: \n100: The system SHALL verify generated artifacts match `make gen-all` when API, hack, workflow, or Makefile inputs change.\n101: \n102: #### Scenario: Codegen Path Filter\n103: \n104: - **GIVEN** a pull request to `main` or `release-*` branch\n105: - **WHEN** the Codegen Check workflow runs\n106: - **THEN** the `codegen` filter SHALL match `pkg/apis/**`, `hack/**`, `.github/workflows/**`, `Makefile`\n107: \n108: #### Scenario: Codegen Verification\n109: \n110: - **GIVEN** path filter `codegen` matches\n111: - **WHEN** the verification step executes\n112: - **THEN** the workflow SHALL use Go `1.24.4`\n113: - **AND** run `make gen-check` (which runs `gen-all` and `git diff --exit-code`)\n114: - **AND** fail if generated files differ from committed version\n115: \n116: ---\n117: \n118: ### Requirement: Go Test Coverage Reporting\n119: \n120: The system SHALL run race-enabled coverage tests on `pkg/...` for qualifying pull requests and merge groups, optionally uploading to Codecov.\n121: \n122: #### Scenario: Coverage Path Filter\n123: \n124: - **GIVEN** a pull request or merge_group event\n125: - **WHEN** the Test Coverage workflow runs\n126: - **THEN** the `coverage` filter SHALL match all paths except `*.md`, `*.svg`, `*.png`\n127: \n128: #### Scenario: Coverage Test Execution\n129: \n130: - **GIVEN** path filter `coverage` matches\n131: - **WHEN** the coverage job runs\n132: - **THEN** the workflow SHALL use Go `1.24`\n133: - **AND** run `go test -race -v -coverprofile=coverage.out -coverpkg=./pkg/... ./pkg/...`\n134: - **AND** upload `coverage.out` as artifact named `go-coverage`\n135: \n136: #### Scenario: Codecov Upload\n137: \n138: - **GIVEN** `CODECOV_TOKEN` secret is configured\n139: - **WHEN** coverage tests complete successfully\n140: - **THEN** the workflow SHALL upload coverage to Codecov using `codecov/codecov-action@v4`\n141: \n142: #### Scenario: Coverage Workflow Call\n143: \n144: - **GIVEN** another workflow calls `test-coverage.yml` via `workflow_call`\n145: - **WHEN** the reusable workflow is invoked\n146: - **THEN** the workflow SHALL accept optional `CODECOV_TOKEN` input\n147: \n148: ---\n149: \n150: ### Requirement: Python SDK Unit Tests\n151: \n152: The system SHALL run pytest for the SDK when `sdk-python/**` changes.\n153: \n154: #### Scenario: Python SDK Path Filter\n155: \n156: - **GIVEN** a pull request or merge_group event\n157: - **WHEN** the Python SDK Tests workflow runs\n158: - **THEN** the `sdk` filter SHALL match `sdk-python/**`\n159: \n160: #### Scenario: Python SDK Test Execution\n161: \n162: - **GIVEN** path filter `sdk` matches\n163: - **WHEN** the test job runs\n164: - **THEN** the workflow SHALL use Python `3.12`\n165: - **AND** set `working-directory: sdk-python`\n166: - **AND** run `pip install pytest`\n167: - **AND** run `pip install -e .`\n168: - **AND** run `python -m pytest tests/ -v`\n169: \n170: ---\n171: \n172: ### Requirement: Python Lint\n173: \n174: The system SHALL run Ruff from repository root using `pyproject.toml` when Python-touching paths change.\n175: \n176: #### Scenario: Python Lint Path Filter\n177: \n178: - **GIVEN** a pull request to `main` or `release-*` branch\n179: - **WHEN** the Python Lint workflow runs\n180: - **THEN** the `python` filter SHALL match `cmd/cli/**`, `sdk-python/**`, `example/**`, `test/**/*.py`, `pyproject.toml`, `.github/workflows/python-lint.yml`\n181: \n182: #### Scenario: Ruff Execution\n183: \n184: - **GIVEN** path filter `python` matches\n185: - **WHEN** the lint job runs\n186: - **THEN** the workflow SHALL use Python `3.10`\n187: - **AND** run `pip install ruff`\n188: - **AND** run `python3 -m ruff check . --config pyproject.toml`\n189: \n190: ---\n191: \n192: ### Requirement: Spelling Check (codespell)\n193: \n194: The system SHALL run codespell on the repository for pull requests to `main` or `release-*`, temporarily moving files that cause false positives.\n195: \n196: #### Scenario: False Positive File Handling\n197: \n198: - **GIVEN** checkout is complete\n199: - **WHEN** codespell preparation runs\n200: - **THEN** the workflow SHALL backup/remove `pyproject.toml`, `package-lock.json`, `package.json` at repository root\n201: - **AND** find and remove nested copies of these files\n202: \n203: #### Scenario: Codespell Invocation\n204: \n205: - **GIVEN** false-positive files are removed\n206: - **WHEN** codespell runs\n207: - **THEN** the workflow SHALL use `pip install codespell`\n208: - **AND** run codespell with `--check-filenames`\n209: - **AND** use `--skip` globs for excluded paths\n210: - **AND** use `--ignore-words-list fo,nam,te,notin,NotIn`\n211: - **AND** scan the entire repository `.`\n212: \n213: #### Scenario: File Restoration\n214: \n215: - **GIVEN** codespell check completes\n216: - **WHEN** the restoration step runs\n217: - **THEN** the workflow SHALL restore all backed-up files to original locations\n218: \n219: ---\n220: \n221: ### Requirement: Copyright Header Check\n222: \n223: The system SHALL ensure `make gen-copyright` produces no git diff when applicable files change.\n224: \n225: #### Scenario: Copyright Path Filter\n226: \n227: - **GIVEN** a pull request to `main` or `release-*` branch\n228: - **WHEN** the Copyright Check workflow runs\n229: - **THEN** the `copyright` filter SHALL match all files except `*.md`, `*.svg`, `*.png`, `docs/**`, `.github/**`\n230: \n231: #### Scenario: Copyright Verification\n232: \n233: - **GIVEN** path filter `copyright` matches\n234: - **WHEN** the check job runs\n235: - **THEN** the workflow SHALL install `moreutils` package (provides `sponge`)\n236: - **AND** run `make gen-copyright`\n237: - **AND** run `git diff --exit-code`\n238: - **AND** fail if any copyright headers differ\n239: \n240: ---\n241: \n242: ### Requirement: Release Image Publication\n243: \n244: The system SHALL build and push multi-architecture images for workloadmanager, router, and picod to GitHub Container Registry on pushes to `main` and on semantic version tags.\n245: \n246: #### Scenario: Tag Selection\n247: \n248: - **GIVEN** a `push` event to `main` branch\n249: - **WHEN** the build-and-push job runs\n250: - **THEN** the environment variable `TAG` SHALL be set to `latest`\n251: \n252: #### Scenario: Semantic Version Tag\n253: \n254: - **GIVEN** a `push` event with tag matching `v*.*.*` or `v*.*.*-*`\n255: - **WHEN** the build-and-push job runs\n256: - **THEN** the environment variable `TAG` SHALL be set to `github.ref_name` (the tag name)\n257: \n258: #### Scenario: Registry Login\n259: \n260: - **GIVEN** the job is running\n261: - **WHEN** Docker login executes\n262: - **THEN** the workflow SHALL use `docker/login-action@v3`\n263: - **AND** login to `ghcr.io` using `GITHUB_TOKEN`\n264: \n265: #### Scenario: Image Build and Push - Workload Manager\n266: \n267: - **GIVEN** authenticated to `ghcr.io`\n268: - **WHEN** the workload manager push step runs\n269: - **THEN** the workflow SHALL run `make docker-buildx-push`\n270: - **AND** set `IMAGE_REGISTRY=ghcr.io/${{ github.repository_owner }}`\n271: - **AND** set `WORKLOAD_MANAGER_IMAGE=workloadmanager:${TAG}`\n272: \n273: #### Scenario: Image Build and Push - Router\n274: \n275: - **GIVEN** authenticated to `ghcr.io`\n276: - **WHEN** the router push step runs\n277: - **THEN** the workflow SHALL run `make docker-buildx-push-router`\n278: - **AND** set `ROUTER_IMAGE=agentcube-router:${TAG}`\n279: \n280: #### Scenario: Image Build and Push - Picod\n281: \n282: - **GIVEN** authenticated to `ghcr.io`\n283: - **WHEN** the picod push step runs\n284: - **THEN** the workflow SHALL run `make docker-buildx-push-picod`\n285: - **AND** set `PICOD_IMAGE=picod:${TAG}`\n286: \n287: #### Scenario: Go Version for Release\n288: \n289: - **GIVEN** the build-and-push job runs\n290: - **WHEN** Go is set up\n291: - **THEN** the workflow SHALL use Go `1.24.4`\n292: \n293: ---\n294: \n295: ### Requirement: Dify Plugin Publish\n296: \n297: The system SHALL publish Dify plugin packages when `dify-plugin/v*` tags are pushed.\n298: \n299: #### Scenario: Dify Plugin Tag Trigger\n300: \n301: - **GIVEN** a `push` event with tag matching `dify-plugin/v*`\n302: - **WHEN** the workflow triggers\n303: - **THEN** only the `publish` job SHALL run\n304: \n305: #### Scenario: Dify CLI Download\n306: \n307: - **GIVEN** the publish job runs\n308: - **WHEN** tool setup executes\n309: - **THEN** the workflow SHALL download `dify-plugin` CLI version `0.0.6`\n310: - **AND** install `yq` for YAML processing\n311: \n312: #### Scenario: Plugin Packaging\n313: \n314: - **GIVEN** tools are installed\n315: - **WHEN** packaging runs\n316: - **THEN** the workflow SHALL read `manifest.yaml`\n317: - **AND** package the plugin into `.difypkg` format\n318: \n319: #### Scenario: Cross-repo PR Creation\n320: \n321: - **GIVEN** plugin is packaged\n322: - **WHEN** publishing executes\n323: - **THEN** the workflow SHALL checkout `author/dify-plugins` repository with `GH_TOKEN`\n324: - **AND** move `.difypkg` file to target location\n325: - **AND** create branch, commit, and push\n326: - **AND** create PR to `langgenius/dify-plugins` using `gh pr create`\n327: \n328: ---\n329: \n330: ### Requirement: Workflow Approval for First-time Contributors\n331: \n332: The system SHALL optionally approve pending workflow runs for pull requests from repeat contributors or those labeled `ok-to-test`.\n333: \n334: #### Scenario: PR Target Event\n335: \n336: - **GIVEN** `pull_request_target` event on `main` or `release-**` branch\n337: - **AND** event types are `labeled` or `synchronize`\n338: - **WHEN** the Approve Workflows workflow runs\n339: - **THEN** the workflow SHALL check contributor status\n340: \n341: #### Scenario: Repeat Contributor Approval\n342: \n343: - **GIVEN** the contributor has more than one PR in the repository\n344: - **WHEN** approval logic evaluates\n345: - **THEN** the workflow SHALL list workflow runs for the head SHA with `status: action_required`\n346: - **AND** call `approveWorkflowRun` for each pending run\n347: \n348: #### Scenario: Ok-to-test Label Approval\n349: \n350: - **GIVEN** the PR has label `ok-to-test`\n351: - **WHEN** approval logic evaluates\n352: - **THEN** the workflow SHALL approve pending workflow runs even for first-time contributors\n353: \n354: #### Scenario: First-time Contributor Skip\n355: \n356: - **GIVEN** the contributor has only one PR\n357: - **AND** the PR does NOT have `ok-to-test` label\n358: - **WHEN** approval logic evaluates\n359: - **THEN** the workflow SHALL NOT approve pending runs\n360: \n361: ---\n362: \n363: ### Requirement: Workflow File Structure\n364: \n365: The system SHALL place all workflow files in `.github/workflows/` directory.\n366: \n367: #### Scenario: Workflow Directory\n368: \n369: - **GIVEN** the `.github` module is implemented\n370: - **WHEN** checking the directory structure\n371: - **THEN** all workflow YAML files SHALL be in `.github/workflows/`\n372: \n373: #### Scenario: Workflow Naming Convention\n374: \n375: - **GIVEN** workflow files are created\n376: - **WHEN** naming workflows\n377: - **THEN** workflow filenames SHALL use lowercase with hyphens (e.g., `main.yml`, `e2e.yml`, `lint.yml`)\n378: - **AND** workflow `name` fields SHALL use descriptive titles (e.g., \"Agentcube CI Workflow\", \"Lint\")\n379: \n380: ---\n381: \n382: ## Implementation Files\n383: \n384: | File | Purpose |\n385: |------|---------|\n386: | `.github/workflows/main.yml` | Pull request Docker build verification |\n387: | `.github/workflows/e2e.yml` | End-to-end tests on Kind cluster |\n388: | `.github/workflows/lint.yml` | Go lint with path filtering |\n389: | `.github/workflows/python-sdk-tests.yml` | Python SDK pytest execution |\n390: | `.github/workflows/python-lint.yml` | Python Ruff lint check |\n391: | `.github/workflows/test-coverage.yml` | Go test coverage with Codecov upload |\n392: | `.github/workflows/codegen-check.yml` | Code generation drift verification |\n393: | `.github/workflows/copyright-check.yml` | Copyright header consistency check |\n394: | `.github/workflows/codespell.yml` | Spelling check with false-positive handling |\n395: | `.github/workflows/build-push-release.yml` | Multi-arch image build and push to GHCR |\n396: | `.github/workflows/dify-plugin-publish.yml` | Dify plugin packaging and cross-repo PR |\n397: | `.github/workflows/workflows-approve.yml` | Workflow approval for trusted contributors |\n398: \n399: ---\n400: \n401: ## Dependencies\n402: \n403: | Dependency | Version | Purpose |\n404: |------------|---------|---------|\n405: | `dorny/paths-filter` | v3 | Path-based job filtering |\n406: | `docker/setup-buildx-action` | v3 | Docker Buildx setup |\n407: | `docker/login-action` | v3 | Container registry authentication |\n408: | `helm/kind-action` | v1 | Kind cluster tooling |\n409: | `actions/setup-go` | v5 | Go runtime setup |\n410: | `actions/setup-python` | v5 | Python runtime setup |\n411: | `codecov/codecov-action` | v4 | Coverage upload |\n412: | `actions/github-script` | v7 | GitHub API scripting |\n413: \n414: ---\n415: \n416: ## Validation Checklist\n417: \n418: - [ ] `main.yml` builds Docker image on PR to `main` or `release-*`\n419: - [ ] `e2e.yml` runs `make e2e` with Kind v0.30.0, uploads logs on failure\n420: - [ ] `lint.yml` path-filters for Go files and runs `make lint`\n421: - [ ] `python-sdk-tests.yml` runs pytest in `sdk-python/` directory\n422: - [ ] `python-lint.yml` runs Ruff with `pyproject.toml` config\n423: - [ ] `test-coverage.yml` runs race-enabled coverage tests, uploads to Codecov\n424: - [ ] `test-coverage.yml` supports `workflow_call` with optional `CODECOV_TOKEN`\n425: - [ ] `codegen-check.yml` path-filters and runs `make gen-check`\n426: - [ ] `copyright-check.yml` path-filters and runs `make gen-copyright`\n427: - [ ] `codespell.yml` handles false-positive files and restores them\n428: - [ ] `build-push-release.yml` pushes to `ghcr.io` on `main` push and version tags\n429: - [ ] `build-push-release.yml` sets `TAG=latest` for main, `TAG=tag-name` for tags\n430: - [ ] `dify-plugin-publish.yml` triggers on `dify-plugin/v*` tags\n431: - [ ] `workflows-approve.yml` approves runs for repeat contributors or `ok-to-test` label\n432: - [ ] All 12 workflow files exist in `.github/workflows/`\n433: - [ ] Workflow names follow descriptive naming convention\n\n(End of file - total 433 lines)\n</content>","metadata":{"preview":"# Delta Specification: AR-034 вҖ” CI/CD GitHub Actions (12 workflows)\n\n**Module:** .github  \n**Language:** YAML  \n**Size:** L\n\n---\n\n## Purpose\n\nAutomate validation on pull requests (build, lint, tests, codegen drift checks), publish container images on pushes to `main` and version tags, run end-to-end tests on Kind, exercise the Python SDK, and enforce spelling and copyright consistency.\n\n---\n\n## Requirements\n\n### Requirement: Pull Request Docker Build Verification\n\nThe system SHALL build the Workload Manager Docker image on pull requests targeting `main` or `release-*` branches.\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/delta-spec.md","time":{"start":1775889150428,"end":1775889150439}}}}
