1674 Mar 21 15:53 project.md\n-rw-r--r--  1 root root     4894 Apr 11 11:44 proposal.md\ndrwxr-xr-x  3 root root     4096 Apr 11 12:23 .pytest_cache\ndrwxr-xr-x  2 root root     4096 Mar 21 15:56 python-sdk\ndrwxr-xr-x  3 root root     4096 Apr 10 18:18 sandbox-orchestration\n-rw-r--r--  1 root root    18689 Apr 11 12:34 .sdd_prompt.md\ndrwxr-xr-x  7 root root     4096 Apr 11 12:52 sdk-python\ndrwxr-xr-x  2 root root     4096 Mar 21 15:55 session-routing\ndrwxr-xr-x  2 root root     4096 Mar 21 15:56 session-store\ndrwxr-xr-x  4 root root     4096 Apr 11 14:17 test\ndrwxr-xr-x  2 root root     4096 Mar 25 09:51 testing\n-rw-r--r--  1 root root     1983 Mar 25 09:36 test_spec.md\n","exit":0,"description":"List workspace contents","truncated":false},"title":"List workspace contents","time":{"start":1775889133399,"end":1775889133467}}}}
