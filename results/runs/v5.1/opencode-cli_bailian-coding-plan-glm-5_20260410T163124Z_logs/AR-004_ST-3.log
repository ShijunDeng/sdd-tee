dbox template for the code interpreter.\n34: \t// +kubebuilder:validation:Required\n35: \tTemplate *CodeInterpreterSandboxTemplate `json:\"template\"`\n36: \n37: \t// SessionTimeout specifies the idle timeout for a session.\n38: \t// Default is 15 minutes.\n39: \t// +kubebuilder:default=\"15m\"\n40: \tSessionTimeout *metav1.Duration `json:\"sessionTimeout,omitempty\"`\n41: \n42: \t// MaxSessionDuration specifies the maximum duration a session can exist.\n43: \t// Default is 8 hours.\n44: \t// +kubebuilder:default=\"8h\"\n45: \tMaxSessionDuration *metav1.Duration `json:\"maxSessionDuration,omitempty\"`\n46: \n47: \t// WarmPoolSize specifies the number of pre-warmed instances to maintain.\n48: \t// +optional\n49: \tWarmPoolSize *int32 `json:\"warmPoolSize,omitempty\"`\n50: \n51: \t// AuthMode specifies the authentication mode for the code interpreter.\n52: \t// Default is \"picod\".\n53: \t// +kubebuilder:default=picod\n54: \t// +kubebuilder:validation:Enum=picod;none\n55: \t// +optional\n56: \tAuthMode AuthModeType `json:\"authMode,omitempty\"`\n57: }\n58: \n59: // CodeInterpreterStatus defines the observed state of CodeInterpreter.\n60: type CodeInterpreterStatus struct {\n61: \t// Conditions represents the latest available observations of the CodeInterpreter's state.\n62: \t// +optional\n63: \t// +listType=atomic\n64: \tConditions []metav1.Condition `json:\"conditions,omitempty\"`\n65: \n66: \t// Ready indicates whether the CodeInterpreter is ready to serve requests.\n67: \t// +optional\n68: \tReady bool `json:\"ready,omitempty\"`\n69: }\n70: \n71: // CodeInterpreterSandboxTemplate defines the sandbox template for code interpreter pods.\n72: type CodeInterpreterSandboxTemplate struct {\n73: \t// Labels are applied to the code interpreter pod.\n74: \t// +optional\n75: \tLabels map[string]string `json:\"labels,omitempty\"`\n76: \n77: \t// Annotations are applied to the code interpreter pod.\n78: \t// +optional\n79: \tAnnotations map[string]string `json:\"annotations,