r)\n35: \tListInactiveSandboxes(ctx context.Context, before time.Time, limit int64) ([]*types.SandboxInfo, error)\n36: \tUpdateSessionLastActivity(ctx context.Context, sessionID string, at time.Time) error\n37: \tClose() error\n38: }\n39: \n40: var (\n41: \tinitStoreOnce sync.Once\n42: \tprovider      Store\n43: )\n44: \n45: func Storage() Store {\n46: \tinitStoreOnce.Do(initStore)\n47: \treturn provider\n48: }\n49: \n50: func ResetStorage() {\n51: \tinitStoreOnce = sync.Once{}\n52: \tprovider = nil\n53: }\n\n(End of file - total 53 lines)\n</content>","metadata":{"preview":"package store\n\nimport (\n\t\"context\"\n\t\"errors\"\n\t\"sync\"\n\t\"time\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n)\n\nvar (\n\tErrNotFound         = errors.New(\"store: not found\")\n\tErrNilSandbox       = errors.New(\"store: sandbox is nil\")\n\tErrZeroExpiresAt    = errors.New(\"store: expiresAt is required\")\n\tErrEmptySessionID   = errors.New(\"store: sessionID is required\")\n\tErrInvalidProvider  = errors.New(\"store: invalid provider type\")\n\tErrPasswordRequired = errors.New(\"store: password is required\")\n\tErrKeyNotExists     = errors.New(\"store: key not exists\")\n\tErrSessionExists    = errors.New(\"store: session already exists\")","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/store/store.go","time":{"start":1775858167575,"end":1775858167600}}}}
