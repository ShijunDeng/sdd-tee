tActivityIndexKey,\n46: \t}\n47: }\n48: \n49: func NewRedisStoreWithClient(cli *redisv9.Client) Store {\n50: \treturn &redisStore{\n51: \t\tcli:                  cli,\n52: \t\tsessionPrefix:        defaultSessionPrefix,\n53: \t\texpiryIndexKey:       defaultExpiryIndexKey,\n54: \t\tlastActivityIndexKey: defaultLastActivityIndexKey,\n55: \t}\n56: }\n57: \n58: func makeRedisOptions() (*redisv9.Options, error) {\n59: \taddr := os.Getenv(\"REDIS_ADDR\")\n60: \tif addr == \"\" {\n61: \t\treturn nil, errors.New(\"REDIS_ADDR is required\")\n62: \t}\n63: \n64: \tpassword := os.Getenv(\"REDIS_PASSWORD\")\n65: \tpasswordRequired := strings.ToLower(os.Getenv(\"REDIS_PASSWORD_REQUIRED\"))\n66: \tif password == \"\" && passwordRequired != \"false\" {\n67: \t\treturn nil, ErrPasswordRequired\n68: \t}\n69: \n70: \treturn &redisv9.Options{\n71: \t\tAddr:     addr,\n72: \t\tPassword: password,\n73: \t}, nil\n74: }\n75: \n76: func initStore() {\n77: \tstoreType := os.Getenv(\"STORE_TYPE\")\n78: \tif storeType == \"\" {\n79: \t\tstoreType = redisStoreType\n80: \t}\n81: \n82: \tvar err error\n83: \tswitch storeType {\n84: \tcase redisStoreType:\n85: \t\topts, err := makeRedisOptions()\n86: \t\tif err != nil {\n87: \t\t\tklog.ErrorS(err, \"failed to create redis options\")\n88: \t\t\treturn\n89: \t\t}\n90: \t\tprovider = NewRedisStore(opts.Addr, opts.Password)\n91: \tcase valkeyStoreType:\n92: \t\tprovider, err = newValkeyStoreFromEnv()\n93: \t\tif err != nil {\n94: \t\t\tklog.ErrorS(err, \"failed to create valkey store\")\n95: \t\t\treturn\n96: \t\t}\n97: \tdefault:\n98: \t\tklog.ErrorS(nil, \"invalid store type\", \"type\", storeType)\n99: \t}\n100: }\n101: \n102: func (s *redisStore) sessionKey(sessionID string) string {\n103: \treturn s.sessionPrefix + sessionID\n104: }\n105: \n106: func (s *redisStore) Ping(ctx context.Context) error {\n107: \tresult, err := s.cli.Ping(ctx).Result()\n108: \tif err != nil {\n109: \t\treturn fmt.Errorf(\"store: ping failed: %w\", err)\n110: \t}\n111: \tif result != \"PONG\" {\n112: \t\treturn fmt.Errorf(\"store: unexpected ping response: %s\", result)\n113: \t}\n114: \treturn nil\n115: }\n116: \n117: func (s *redisStore) GetSandboxBySessionID(ctx context.Context, sessionID string) (*types.SandboxInfo, error) {\n118: \tif sessionID == \"\" {\n119: \t\treturn nil, ErrEmptySessionID\n120: \t}\n121: \n122: \tkey := s.sessionKey(sessionID)\n123: \tresult, err := s.cli.Get(ctx, key).Result()\n124: \tif err != nil {\n125: \t\tif errors.Is(err, redisv9.Nil) {\n126: \t\t\treturn nil, ErrNotFound\n127: \t\t}\n128: \t\treturn nil, fmt.Errorf(\"store: get session %s: %w\", sessionID, err)\n129: \t}\n130: \n131: \tvar sandbox types.SandboxInfo\n132: \tif err := json.Unmarshal([]byte(result), &sandbox); err != nil {\n133: \t\treturn nil, fmt.Errorf(\"store: unmarshal session %s: %w\", sessionID, err)\n134: \t}\n135: \n136: \treturn &sandbox, nil\n137: }\n138: \n139: func (s *redisStore) StoreSandbox(ctx context.Context, sandbox *types.SandboxInfo) error {\n140: \tif sandbox == nil {\n141: \t\treturn ErrNilSandbox\n142: \t}\n143: \tif sandbox.ExpiresAt.IsZero() {\n144: \t\treturn ErrZeroExpiresAt\n145: \t}\n146: \tif sandbox.SessionID == \"\" {\n147: \t\treturn ErrEmptySessionID\n148: \t}\n149: \n150: \tkey := s.sessionKey(sandbox.SessionID)\n151: \tdata, err := json.Marshal(sandbox)\n152: \tif err != nil {\n153: \t\treturn fmt.Errorf(\"store: marshal sandbox: %w\", err)\n154: \t}\n155: \n156: \tnow := time.Now()\n157: \tif sandbox.LastActivity.IsZero() {\n158: \t\tsandbox.LastActivity = now\n159: \t}\n160: \n161: \tpipe := s.cli.Pipeline()\n162: \tsetNXCmd := pipe.SetNX(ctx, key, data, 0)\n163: \tpipe.ZAdd(ctx, s.expiryIndexKey, redisv9.Z{\n164: \t\tScore:  float64(sandbox.ExpiresAt.Unix()),\n165: \t\tMember: sandbox.SessionID,\n166: \t})\n167: \tpipe.ZAdd(ctx, s.lastActivityIndexKey, redisv9.Z{\n168: \t\tScore:  float64(sandbox.LastActivity.Unix()),\n169: \t\tMember: sandbox.SessionID,\n170: \t})\n171: \n172: \t_, err = pipe.Exec(ctx)\n173: \tif err != nil {\n174: \t\treturn fmt.Errorf(\"store: pipeline exec: %w\", err)\n175: \t}\n176: \n177: \tsetResult, err := setNXCmd.Result()\n178: \tif err != nil {\n179: \t\treturn fmt.Errorf(\"store: setnx result: %w\", err)\n180: \t}\n181: \tif !setResult {\n182: \t\treturn ErrSessionExists\n183: \t}\n184: \n185: \treturn nil\n186: }\n187: \n188: func (s *redisStore) UpdateSandbox(ctx context.Context, sandbox *types.SandboxInfo) error {\n189: \tif sandbox == nil {\n190: \t\treturn ErrNilSandbox\n191: \t}\n192: \tif sandbox.SessionID == \"\" {\n193: \t\treturn ErrEmptySessionID\n194: \t}\n195: \n196: \tkey := s.sessionKey(sandbox.SessionID)\n197: \n198: \texists, err := s.cli.Exists(ctx, key).Result()\n199: \tif err != nil {\n200: \t\treturn fmt.Errorf(\"store: check exists: %w\", err)\n201: \t}\n202: \tif exists == 0 {\n203: \t\treturn ErrNotFound\n204: \t}\n205: \n206: \tdata, err := json.Marshal(sandbox)\n207: \tif err != nil {\n208: \t\treturn fmt.Errorf(\"store: marshal sandbox: %w\", err)\n209: \t}\n210: \n211: \tif err := s.cli.Set(ctx, key, data, 0).Err(); err != nil {\n212: \t\treturn fmt.Errorf(\"store: update sandbox: %w\", err)\n213: \t}\n214: \n215: \treturn nil\n216: }\n217: \n218: func (s *redisStore) DeleteSandboxBySessionID(ctx context.Context, sessionID string) error {\n219: \tif sessionID == \"\" {\n220: \t\treturn ErrEmptySessionID\n221: \t}\n222: \n223: \tkey := s.sessionKey(sessionID)\n224: \n225: \tpipe := s.cli.Pipeline()\n226: \tpipe.Del(ctx, key)\n227: \tpipe.ZRem(ctx, s.expiryIndexKey, sessionID)\n228: \tpipe.ZRem(ctx, s.lastActivityIndexKey, sessionID)\n229: \n230: \t_, err := pipe.Exec(ctx)\n231: \tif err != nil {\n232: \t\treturn fmt.Errorf(\"store: delete sandbox: %w\", err)\n233: \t}\n234: \n235: \treturn nil\n236: }\n237: \n238: func (s *redisStore) ListExpiredSandboxes(ctx context.Context, before time.Time, limit int64) ([]*types.SandboxInfo, error) {\n239: \tif limit <= 0 {\n240: \t\treturn nil, nil\n241: \t}\n242: \n243: \tsessionIDs, err := s.cli.ZRangeByScore(ctx, s.expiryIndexKey, &redisv9.ZRangeBy{\n244: \t\tMin:   \"-inf\",\n245: \t\tMax:   fmt.Sprintf(\"%d\", before.Unix()),\n246: \t\tCount: limit,\n247: \t}).Result()\n248: \tif err != nil {\n249: \t\treturn nil, fmt.Errorf(\"store: list expired: %w\", err)\n250: \t}\n251: \n252: \tif len(sessionIDs) == 0 {\n253: \t\treturn nil, nil\n254: \t}\n255: \n256: \treturn s.batchGetSandboxes(ctx, sessionIDs)\n257: }\n258: \n259: func (s *redisStore) ListInactiveSandboxes(ctx context.Context, before time.Time, limit int64) ([]*types.SandboxInfo, error) {\n260: \tif limit <= 0 {\n261: \t\treturn nil, nil\n262: \t}\n263: \n264: \tsessionIDs, err := s.cli.ZRangeByScore(ctx, s.lastActivityIndexKey, &redisv9.ZRangeBy{\n265: \t\tMin:   \"-inf\",\n266: \t\tMax:   fmt.Sprintf(\"%d\", before.Unix()),\n267: \t\tCount: limit,\n268: \t}).Result()\n269: \tif err != nil {\n270: \t\treturn nil, fmt.Errorf(\"store: list inactive: %w\", err)\n271: \t}\n272: \n273: \tif len(sessionIDs) == 0 {\n274: \t\treturn nil, nil\n275: \t}\n276: \n277: \treturn s.batchGetSandboxes(ctx, sessionIDs)\n278: }\n279: \n280: func (s *redisStore) batchGetSandboxes(ctx context.Context, sessionIDs []string) ([]*types.SandboxInfo, error) {\n281: \tkeys := make([]string, len(sessionIDs))\n282: \tfor i, id := range sessionIDs {\n283: \t\tkeys[i] = s.sessionKey(id)\n284: \t}\n285: \n286: \tpipe := s.cli.Pipeline()\n287: \tcmds := make([]*redisv9.StringCmd, len(keys))\n288: \tfor i, key := range keys {\n289: \t\tcmds[i] = pipe.Get(ctx, key)\n290: \t}\n291: \n292: \t_, err := pipe.Exec(ctx)\n293: \tif err != nil && !errors.Is(err, redisv9.Nil) {\n294: \t\treturn nil, fmt.Errorf(\"store: batch get: %w\", err)\n295: \t}\n296: \n297: \tvar sandboxes []*types.SandboxInfo\n298: \tfor i, cmd := range cmds {\n299: \t\tresult, err := cmd.Result()\n300: \t\tif err != nil {\n301: \t\t\tif errors.Is(err, redisv9.Nil) {\n302: \t\t\t\tcontinue\n303: \t\t\t}\n304: \t\t\treturn nil, fmt.Errorf(\"store: get session %s: %w\", sessionIDs[i], err)\n305: \t\t}\n306: \n307: \t\tvar sandbox types.SandboxInfo\n308: \t\tif err := json.Unmarshal([]byte(result), &sandbox); err != nil {\n309: \t\t\tcontinue\n310: \t\t}\n311: \t\tsandboxes = append(sandboxes, &sandbox)\n312: \t}\n313: \n314: \treturn sandboxes, nil\n315: }\n316: \n317: func (s *redisStore) UpdateSessionLastActivity(ctx context.Context, sessionID string, at time.Time) error {\n318: \tif sessionID == \"\" {\n319: \t\treturn ErrEmptySessionID\n320: \t}\n321: \n322: \tkey := s.sessionKey(sessionID)\n323: \n324: \texists, err := s.cli.Exists(ctx, key).Result()\n325: \tif err != nil {\n326: \t\treturn fmt.Errorf(\"store: check exists: %w\", err)\n327: \t}\n328: \tif exists == 0 {\n329: \t\treturn ErrNotFound\n330: \t}\n331: \n332: \tif at.IsZero() {\n333: \t\tat = time.Now()\n334: \t}\n335: \n336: \tif err := s.cli.ZAdd(ctx, s.lastActivityIndexKey, redisv9.Z{\n337: \t\tScore:  float64(at.Unix()),\n338: \t\tMember: sessionID,\n339: \t}).Err(); err != nil {\n340: \t\treturn fmt.Errorf(\"store: update last activity: %w\", err)\n341: \t}\n342: \n343: \treturn nil\n344: }\n345: \n346: func (s *redisStore) Close() error {\n347: \treturn s.cli.Close()\n348: }\n349: \n350: func newValkeyStoreFromEnv() (Store, error) {\n351: \taddr := os.Getenv(\"VALKEY_ADDR\")\n352: \tif addr == \"\" {\n353: \t\treturn nil, errors.New(\"VALKEY_ADDR is required\")\n354: \t}\n355: \n356: \tpassword := os.Getenv(\"VALKEY_PASSWORD\")\n357: \tpasswordRequired := strings.ToLower(os.Getenv(\"VALKEY_PASSWORD_REQUIRED\"))\n358: \tif password == \"\" && passwordRequired != \"false\" {\n359: \t\treturn nil, ErrPasswordRequired\n360: \t}\n361: \n362: \topts := &valkeyClientOption{\n363: \t\tInitAddress: strings.Split(addr, \",\"),\n364: \t\tPassword:    password,\n365: \t}\n366: \n367: \tif v, _ := strconv.ParseBool(os.Getenv(\"VALKEY_DISABLE_CACHE\")); v {\n368: \t\topts.DisableCache = true\n369: \t}\n370: \tif v, _ := strconv.ParseBool(os.Getenv(\"VALKEY_FORCE_SINGLE\")); v {\n371: \t\topts.ForceSingleClient = true\n372: \t}\n373: \n374: \treturn newValkeyStore(opts)\n375: }\n376: \n377: type valkeyClientOption struct {\n378: \tInitAddress       []string\n379: \tPassword          string\n380: \tDisableCache      bool\n381: \tForceSingleClient bool\n382: }\n383: \n384: var valkeyInit sync.Once\n385: var valkeyProvider Store\n386: \n387: func newValkeyStore(opts *valkeyClientOption) (Store, error) {\n388: \tvalkeyInit.Do(func() {\n389: \t\tvalkeyProvider = &valkeyStore{\n390: \t\t\tsessionPrefix:        defaultSessionPrefix,\n391: \t\t\texpiryIndexKey:       defaultExpiryIndexKey,\n392: \t\t\tlastActivityIndexKey: defaultLastActivityIndexKey,\n393: \t\t}\n394: \t})\n395: \treturn valkeyProvider, nil\n396: }\n397: \n398: type valkeyStore struct {\n399: \tcli                  interface{}\n400: \tsessionPrefix        string\n401: \texpiryIndexKey       string\n402: \tlastActivityIndexKey string\n403: }\n404: \n405: func (s *valkeyStore) Ping(ctx context.Context) error {\n406: \treturn errors.New(\"store: valkey not configured\")\n407: }\n408: \n409: func (s *valkeyStore) GetSandboxBySessionID(ctx context.Context, sessionID string) (*types.SandboxInfo, error) {\n410: \treturn nil, errors.New(\"store: valkey not configured\")\n411: }\n412: \n413: func (s *valkeyStore) StoreSandbox(ctx context.Context, sandbox *types.SandboxInfo) error {\n414: \treturn errors.New(\"store: valkey not configured\")\n415: }\n416: \n417: func (s *valkeyStore) UpdateSandbox(ctx context.Context, sandbox *types.SandboxInfo) error {\n418: \treturn errors.New(\"store: valkey not configured\")\n419: }\n420: \n421: func (s *valkeyStore) DeleteSandboxBySessionID(ctx context.Context, sessionID string) error {\n422: \treturn errors.New(\"store: valkey not configured\")\n423: }\n424: \n425: func (s *valkeyStore) ListExpiredSandboxes(ctx context.Context, before time.Time, limit int64) ([]*types.SandboxInfo, error) {\n426: \treturn nil, errors.New(\"store: valkey not configured\")\n427: }\n428: \n429: func (s *valkeyStore) ListInactiveSandboxes(ctx context.Context, before time.Time, limit int64) ([]*types.SandboxInfo, error) {\n430: \treturn nil, errors.New(\"store: valkey not configured\")\n431: }\n432: \n433: func (s *valkeyStore) UpdateSessionLastActivity(ctx context.Context, sessionID string, at time.Time) error {\n434: \treturn errors.New(\"store: valkey not configured\")\n435: }\n436: \n437: func (s *valkeyStore) Close() error {\n438: \treturn nil\n439: }\n\n(End of file - total 439 lines)\n</content>","metadata":{"preview":"package store\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"errors\"\n\t\"fmt\"\n\t\"os\"\n\t\"strconv\"\n\t\"strings\"\n\t\"sync\"\n\t\"time\"\n\n\tredisv9 \"github.com/redis/go-redis/v9\"\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n\t\"k8s.io/klog/v2\"\n)\n\ntype redisStore struct {\n\tcli                  *redisv9.Client","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/store/store_redis.go","time":{"start":1775858167577,"end":1775858167602}}}}
