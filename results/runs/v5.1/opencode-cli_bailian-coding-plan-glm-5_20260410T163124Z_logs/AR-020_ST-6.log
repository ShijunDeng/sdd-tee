        self._update_pack_metadata(workspace_path, metadata, dockerfile_path)\n30:             output_path = self._prepare_output_path(workspace_path, options.get(\"output\"))\n31: \n32:             result[\"agent_name\"] = metadata.agent_name\n33:             result[\"metadata_path\"] = str(workspace_path / \"agent_metadata.yaml\")\n34:             result[\"dockerfile_path\"] = str(dockerfile_path) if dockerfile_path else None\n35:             result[\"status\"] = \"success\"\n36:         except Exception as e:\n37:             result[\"status\"] = \"error\"\n38:             result[\"error\"] = str(e)\n39:             raise\n40:         return result\n41: \n42:     def _validate_workspace_structure(self, workspace_path: Path) -> None:\n43:         if not workspace_path.exists():\n44:             raise ValueError(f\"Workspace directory does not exist: {workspace_path}\")\n45:         if not workspace_path.is_dir():\n46:             raise ValueError(f\"Workspace path is not a directory: {workspace_path}\")\n47: \n48:     def _load_or_create_metadata(\n49:         self, workspace_path: Path, options: Dict[str, Any]\n50:     ) -> AgentMetadata:\n51:         metadata_files = [\"agent_metadata.yaml\", \"agent.yaml\", \"metadata.yaml\"]\n52:         for filename in metadata_files:\n53:             filepath = workspace_path / filename\n54:             if filepath.exists():\n55:                 return self._metadata_service.load_metadata(workspace_path)\n56: \n57:         agent_name = options.get(\"agent_name\") or workspace_path.name\n58:         language = options.get(\"language\", \"python\")\n59:         entrypoint = options.get(\"entrypoint\") or self._infer_entrypoint(\n60:             workspace_path, language\n61:         )\n62:         return AgentMetadata.model_construct(\n63:             agent_name=agent_name,\n64:             language=language,\n65:             entrypoint=entrypoint,\n66:             port=options.get(\"port\") or 8080,\n67:             build_mode=options.get(\"build_mode\") or \"local\",\n68:             description=options.get(\"description\") or \"\",\n69:         )\n70: \n71:     def _apply_option_overrides(\n72:         self, metadata: AgentMetadata, options: Dict[str, Any]\n73:     ) -> AgentMetadata:\n74:         if options.get(\"agent_name\"):\n75:             metadata.agent_name = options[\"agent_name\"]\n76:         if options.get(\"language\"):\n77:             metadata.language = options[\"language\"]\n78:         if options.get(\"entrypoint\"):\n79:             metadata.entrypoint = options[\"entrypoint\"]\n80:         if options.get(\"port\"):\n81:             metadata.port = options[\"port\"]\n82:         if options.get(\"build_mode\"):\n83:             metadata.build_mode = options[\"build_mode\"]\n84:         if options.get(\"description\"):\n85:             metadata.description = options[\"description\"]\n86:         return metadata\n87: \n88:     def _validate_language_compatibility(\n89:         self, workspace_path: Path, metadata: AgentMetadata\n90:     ) -> None:\n91:         if metadata.language == \"python\":\n92:             self._validate_python_compatibility(workspace_path)\n93:         elif metadata.language == \"java\":\n94:             self._validate_java_compatibility(workspace_path)\n95: \n96:     def _validate_python_compatibility(self, workspace_path: Path) -> None:\n97:         py_files = list(workspace_path.glob(\"*.py\"))\n98:         if not py_files:\n99:             raise ValueError(\"No Python files found in workspace\")\n100: \n101:     def _validate_java_compatibility(self, workspace_path: Path) -> None:\n102:         pom_file = workspace_path / \"pom.xml\"\n103:         if not pom_file.exists():\n104:             raise ValueError(\"No pom.xml found in Java workspace\")\n105: \n106:     def _process_dependencies(\n107:         self, workspace_path: Path, metadata: AgentMetadata\n108:     ) -> None:\n109:         if metadata.language == \"python\":\n110:             self._process_python_dependencies(workspace_path)\n111:         elif metadata.language == \"java\":\n112:             self._process_java_dependencies(workspace_path)\n113: \n114:     def _process_python_dependencies(self, workspace_path: Path) -> None:\n115:         requirements_file = workspace_path / \"requirements.txt\"\n116:         if not requirements_file.exists():\n117:             pass\n118: \n119:     def _process_java_dependencies(self, workspace_path: Path) -> None:\n120:         pass\n121: \n122:     def _generate_dockerfile(\n123:         self, workspace_path: Path, metadata: AgentMetadata\n124:     ) -> Optional[Path]:\n125:         dockerfile_path = workspace_path / \"Dockerfile\"\n126:         if dockerfile_path.exists():\n127:             return dockerfile_path\n128: \n129:         content = \"\"\n130:         if metadata.language == \"python\":\n131:             content = self._generate_python_dockerfile(metadata)\n132:         elif metadata.language == \"java\":\n133:             content = self._generate_java_dockerfile(metadata)\n134: \n135:         dockerfile_path.write_text(content)\n136:         return dockerfile_path\n137: \n138:     def _generate_python_dockerfile(self, metadata: AgentMetadata) -> str:\n139:         return f'''FROM python:3.10-slim\n140: WORKDIR /app\n141: COPY requirements.txt .\n142: RUN pip install --no-cache-dir -r requirements.txt\n143: COPY . .\n144: EXPOSE {metadata.port}\n145: CMD [\"{metadata.entrypoint}\"]\n146: '''\n147: \n148:     def _generate_java_dockerfile(self, metadata: AgentMetadata) -> str:\n149:         return f'''FROM maven:3.8-openjdk-17 as build\n150: WORKDIR /app\n151: COPY pom.xml .\n152: RUN mvn dependency:go-offline\n153: COPY . .\n154: RUN mvn package -DskipTests\n155: FROM openjdk:17-slim\n156: WORKDIR /app\n157: COPY --from=build /app/target/*.jar app.jar\n158: EXPOSE {metadata.port}\n159: CMD [\"{metadata.entrypoint}\"]\n160: '''\n161: \n162:     def _update_pack_metadata(\n163:         self, workspace_path: Path, metadata: AgentMetadata, dockerfile_path: Optional[Path]\n164:     ) -> None:\n165:         if dockerfile_path:\n166:             metadata.image = {\"dockerfile_path\": str(dockerfile_path)}\n167:         self._metadata_service.save_metadata(workspace_path, metadata)\n168: \n169:     def _prepare_output_path(\n170:         self, workspace_path: Path, output_path: Optional[str]\n171:     ) -> Path:\n172:         if output_path:\n173:             return Path(output_path)\n174:         return workspace_path / \"packaged\"\n175: \n176:     def _infer_entrypoint(self, workspace_path: Path, language: str) -> str:\n177:         if language == \"python\":\n178:             main_py = workspace_path / \"main.py\"\n179:             if main_py.exists():\n180:                 return \"python main.py\"\n181:             py_files = list(workspace_path.glob(\"*.py\"))\n182:             if py_files:\n183:                 return f\"python {py_files[0].name}\"\n184:         elif language == \"java\":\n185:             return \"java -jar app.jar\"\n186:         return \"\"\n\n(End of file - total 186 lines)\n</content>","metadata":{"preview":"from pathlib import Path\nfrom typing import Any, Dict, Optional\n\nfrom agentcube.services.metadata_service import AgentMetadata, MetadataService\nfrom agentcube.services.docker_service import DockerService\n\n\nclass PackRuntime:\n    def __init__(self, verbose: bool = False) -> None:\n        self.verbose = verbose\n        self._metadata_service = MetadataService(verbose)\n        self._docker_service = DockerService(verbose)\n\n    def pack(self, workspace_path: Path, **options: Any) -> Dict[str, Any]:\n        result = {\n            \"agent_name\": None,\n            \"workspace_path\": str(workspace_path),\n            \"metadata_path\": None,\n            \"dockerfile_path\": None,\n            \"status\": \"pending\",","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_202