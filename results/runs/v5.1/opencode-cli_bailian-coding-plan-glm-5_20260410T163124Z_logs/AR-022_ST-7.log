         agent_name: str,\n42:         image_url: str,\n43:         port: int,\n44:         entrypoint: Optional[str] = None,\n45:         env_vars: Optional[Dict[str, str]] = None,\n46:         workload_manager_url: Optional[str] = None,\n47:         router_url: Optional[str] = None,\n48:         readiness_probe_path: Optional[str] = None,\n49:         readiness_probe_port: Optional[int] = None,\n50:     ) -> Dict[str, Any]:\n51:         sanitized_name = self._sanitize_name(agent_name)\n52:         self._ensure_namespace()\n53:         \n54:         env_list = []\n55:         if workload_manager_url:\n56:             env_list.append({\"name\": \"WORKLOAD_MANAGER_URL\", \"value\": workload_manager_url})\n57:         if router_url:\n58:             env_list.append({\"name\": \"ROUTER_URL\", \"value\": router_url})\n59:         if env_vars:\n60:             for k, v in env_vars.items():\n61:                 if k not in [\"WORKLOAD_MANAGER_URL\", \"ROUTER_URL\"]:\n62:                     env_list.append({\"name\": k, \"value\": v})\n63:         \n64:         cr_body = {\n65:             \"apiVersion\": f\"{self.CR_GROUP}/{self.CR_VERSION}\",\n66:             \"kind\": \"AgentRuntime\",\n67:             \"metadata\": {\n68:                 \"name\": sanitized_name,\n69:                 \"namespace\": self.namespace,\n70:             },\n71:             \"spec\": {\n72:                 \"image\": image_url,\n73:                 \"port\": port,\n74:                 \"sessionTimeout\": self.SESSION_TIMEOUT,\n75:                 \"maxSessionDuration\": self.MAX_SESSION_DURATION,\n76:                 \"imagePullSecrets\": [{\"name\": self.DEFAULT_SECRET}],\n77:                 \"env\": env_list,\n78:                 \"readinessProbe\": {\n79:                     \"httpGet\": {\n80:                         \"path\": readiness_probe_path or \"/health\",\n81:                         \"port\": readiness_probe_port or port,\n82:                     },\n83:                 },\n84:             },\n85:         }\n86:         \n87:         if entrypoint:\n88:             cr_body[\"spec\"][\"entrypoint\"] = entrypoint\n89:         \n90:         try:\n91:             result = self._custom_api.create_namespaced_custom_object(\n92:                 group=self.CR_GROUP,\n93:                 version=self.CR_VERSION,\n94:                 namespace=self.namespace,\n95:                 plural=self.CR_PLURAL,\n96:                 body=cr_body,\n97:             )\n98:             status = \"created\"\n99:         except kubernetes.client.exceptions.ApiException as e:\n100:             if e.status == 409:\n101:                 result = self._custom_api.patch_namespaced_custom_object(\n102:                     group=self.CR_GROUP,\n103:                     version=self.CR_VERSION,\n104:                     namespace=self.namespace,\n105:                     plural=self.CR_PLURAL,\n106:                     name=sanitized_name,\n107:                     body=cr_body,\n108:                 )\n109:                 status = \"patched\"\n110:             elif e.status == 404 and \"AgentRuntime\" in str(e):\n111:                 raise ValueError(\n112:                     \"AgentRuntime CRD not installed. Install Volcano AgentCube CRDs\"\n113:                 )\n114:             else:\n115:                 raise RuntimeError(f\"Failed to deploy AgentRuntime CR: {e}\")\n116:         \n117:         agent_id = result.get(\"metadata\", {}).get(\"name\", sanitized_name)\n118:         agent_endpoint = None\n119:         if result.get(\"status\"):\n120:             agent_endpoint = result.get(\"status\", {}).get(\"agentEndpoint\")\n121:         \n122:         if self.verbose:\n123:             self._logger.info(f\"Deployed AgentRuntime {sanitized_name} with agent_id {agent_id}\")\n124:         \n125:         return {\n126:             \"deployment_name\": sanitized_name,\n127:             \"agent_id\": agent_id,\n128:             \"agent_endpoint\": agent_endpoint,\n129:             \"status\": status,\n130:         }\n131: \n132:     def get_agent_runtime(self, name: str, namespace: Optional[str] = None) -> Optional[Dict[str, Any]]:\n133:         ns = namespace or self.namespace\n134:         sanitized_name = self._sanitize_name(name)\n135:         \n136:         try:\n137:             result = self._custom_api.get_namespaced_custom_object(\n138:                 group=self.CR_GROUP,\n139:                 version=self.CR_VERSION,\n140:                 namespace=ns,\n141:                 plural=self.CR_PLURAL,\n142:                 name=sanitized_name,\n143:             )\n144:             return result\n145:         except kubernetes.client.exceptions.ApiException as e:\n146:             if e.status == 404:\n147:                 return None\n148:             raise\n149: \n150:     def delete_agent_runtime(self, name: str, namespace: Optional[str] = None) -> Dict[str, Any]:\n151:         ns = namespace or self.namespace\n152:         sanitized_name = self._sanitize_name(name)\n153:         \n154:         try:\n155:             self._custom_api.delete_namespaced_custom_object(\n156:                 group=self.CR_GROUP,\n157:                 version=self.CR_VERSION,\n158:                 namespace=ns,\n159:                 plural=self.CR_PLURAL,\n160:                 name=sanitized_name,\n161:                 body=kubernetes.client.V1DeleteOptions(),\n162:             )\n163:             return {\"deleted\": True, \"name\": sanitized_name}\n164:         except kubernetes.client.exceptions.ApiException as e:\n165:             if e.status == 404:\n166:                 return {\"deleted\": False, \"reason\": \"not_found\"}\n167:             raise RuntimeError(f\"Failed to delete AgentRuntime: {e}\")\n168: \n169:     def _ensure_namespace(self) -> None:\n170:         try:\n171:             self._core_api.read_namespace(name=self.namespace)\n172:         except kubernetes.client.exceptions.ApiException as e:\n173:             if e.status == 404:\n174:                 namespace_body = {\n175:                     \"apiVersion\": \"v1\",\n176:                     \"kind\": \"Namespace\",\n177:                     \"metadata\": {\"name\": self.namespace},\n178:                 }\n179:                 self._core_api.create_namespace(body=namespace_body)\n180:                 if self.verbose:\n181:                     self._logger.info(f\"Created namespace {self.namespace}\")\n182:             else:\n183:                 raise\n184: \n185:     def _sanitize_name(self, name: str) -> str:\n186:         sanitized = name.lower()\n187:         sanitized = re.sub(r\"[^a-z0-9-]\", \"-\", sanitized)\n188:         sanitized = re.sub(r\"-+\", \"-\", sanitized)\n189:         sanitized = sanitized.strip(\"-\")\n190:         return sanitized[:63] if sanitized else \"default\"\n\n(End of file - total 190 lines)\n</content>","metadata":{"preview":"import logging\nimport re\nfrom typing import Any, Dict, Optional\n\nimport kubernetes\nimport kubernetes.client\nimport kubernetes.config\n\n\nclass AgentCubeProvider:\n    CR_GROUP = \"runtime.agentcube.volcano.sh\"\n    CR_VERSION = \"v1alpha1\"\n    CR_PLURAL = \"agentruntimes\"\n    SESSION_TIMEOUT = \"15m\"\n    MAX_SESSION_DURATION = \"8h\"\n    DEFAULT_SECRET = \"default-secret\"\n\n    def __init__(\n        self,\n        namespace: str = \"default\",","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/cmd/cli/agentcube/services/agentcube_provider.py","time":{"start":1775872554280,"end":1775872554296}}}}
