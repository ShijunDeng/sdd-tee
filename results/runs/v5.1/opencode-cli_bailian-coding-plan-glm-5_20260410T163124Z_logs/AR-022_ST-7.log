 TestApplyOptionOverrides:\n31:     def test_apply_override_version(self, tmp_path: Path) -> None:\n32:         metadata = AgentMetadata.model_construct(\n33:             agent_name=\"test-agent\",\n34:             language=\"python\",\n35:             entrypoint=\"python main.py\",\n36:         )\n37:         \n38:         with patch(\"agentcube.services.agentcube_provider.AgentCubeProvider\") as mock_provider:\n39:             mock_provider.return_value = MagicMock()\n40:             runtime = PublishRuntime()\n41:             result = runtime._apply_option_overrides(metadata, {\"version\": \"v1.0.0\"})\n42:             assert result.version == \"v1.0.0\"\n43: \n44:     def test_apply_override_image_url(self, tmp_path: Path) -> None:\n45:         metadata = AgentMetadata.model_construct(\n46:             agent_name=\"test-agent\",\n47:             language=\"python\",\n48:             entrypoint=\"python main.py\",\n49:             image={},\n50:         )\n51:         \n52:         with patch(\"agentcube.services.agentcube_provider.AgentCubeProvider\") as mock_provider:\n53:             mock_provider.return_value = MagicMock()\n54:             runtime = PublishRuntime()\n55:             result = runtime._apply_option_overrides(metadata, {\"image_url\": \"registry.example.com/test-agent\"})\n56:             assert result.image.get(\"url\") == \"registry.example.com/test-agent\"\n57: \n58:     def test_apply_override_description(self, tmp_path: Path) -> None:\n59:         metadata = AgentMetadata.model_construct(\n60:             agent_name=\"test-agent\",\n61:             language=\"python\",\n62:             entrypoint=\"python main.py\",\n63:         )\n64:         \n65:         with patch(\"agentcube.services.agentcube_provider.AgentCubeProvider\") as mock_provider:\n66:             mock_provider.return_value = MagicMock()\n67:             runtime = PublishRuntime()\n68:             result = runtime._apply_option_overrides(metadata, {\"description\": \"New description\"})\n69:             assert result.description == \"New description\"\n70: \n71:     def test_apply_override_region(self, tmp_path: Path) -> None:\n72:         metadata = AgentMetadata.model_construct(\n73:             agent_name=\"test-agent\",\n74:             language=\"python\",\n75:             entrypoint=\"python main.py\",\n76:         )\n77:         \n78:         with patch(\"agentcube.services.agentcube_provider.AgentCubeProvider\") as mock_provider:\n79:             mock_provider.return_value = MagicMock()\n80:             runtime = PublishRuntime()\n81:             result = runtime._apply_option_overrides(metadata, {\"region\": \"us-west\"})\n82:             assert result.region == \"us-west\"\n83: \n84: \n85: class TestValidatePublishPrerequisites:\n86:     def test_validate_agentcube_missing_router_url(self, tmp_path: Path) -> None:\n87:         metadata = AgentMetadata.model_construct(\n88:             agent_name=\"test-agent\",\n89:             language=\"python\",\n90:             entrypoint=\"python main.py\",\n91:             workload_manager_url=\"http://workload-manager\",\n92:             router_url=\"\",\n93:             build_mode=\"cloud\",\n94:         )\n95:         \n96:         with patch(\"agentcube.services.agentcube_provider.AgentCubeProvider\") as mock_provider:\n97:             mock_provider.return_value = MagicMock()\n98:             runtime = PublishRuntime(provider=\"agentcube\")\n99:             with pytest.raises(ValueError, match=\"router_url is required\"):\n100:                 runtime._validate_publish_prerequisites(tmp_path, metadata, {})\n101: \n102:     def test_validate_agentcube_missing_workload_manager(self, tmp_path: Path) -> None:\n103:         metadata = AgentMetadata.model_construct(\n104:             agent_name=\"test-agent\",\n105:             language=\"python\",\n106:             entrypoint=\"python main.py\",\n107:             workload_manager_url=\"\",\n108:             router_url=\"http://router\",\n109:             build_mode=\"cloud\",\n110:         )\n111:         \n112:         with patch(\"agentcube.services.agentcube_provider.AgentCubeProvider\") as mock_provider:\n113:             mock_provider.return_value = MagicMock()\n114:             runtime = PublishRuntime(provider=\"agentcube\")\n115:             with pytest.raises(ValueError, match=\"workload_manager_url is required\"):\n116:                 runtime._validate_publish_prerequisites(tmp_path, metadata, {})\n117: \n118:     def test_validate_agentcube_with_router_url_from_options(self, tmp_path: Path) -> None:\n119:         metadata = AgentMetadata.model_construct(\n120:             agent_name=\"test-agent\",\n121:             language=\"python\",\n122:             entrypoint=\"python main.py\",\n123:             workload_manager_url=\"http://workload-manager\",\n124:             router_url=\"\",\n125:             build_mode=\"cloud\",\n126:         )\n127:         \n128:         with patch(\"agentcube.services.agentcube_provider.AgentCubeProvider\") as mock_provider:\n129:             mock_provider.return_value = MagicMock()\n130:             runtime = PublishRuntime(provider=\"agentcube\")\n131:             runtime._validate_publish_prerequisites(\n132:                 tmp_path, metadata, {\"router_url\": \"http://router\"}\n133:             )\n134: \n135:     def test_validate_local_mode_missing_image_url(self, tmp_path: Path) -> None:\n136:         metadata = AgentMetadata.model_construct(\n137:             agent_name=\"test-agent\",\n138:             language=\"python\",\n139:             entrypoint=\"python main.py\",\n140:             router_url=\"http://router\",\n141:             workload_manager_url=\"http://workload-manager\",\n142:             build_mode=\"local\",\n143:         )\n144:         \n145:         with patch(\"agentcube.services.agentcube_provider.AgentCubeProvider\") as mock_provider:\n146:             mock_provider.return_value = MagicMock()\n147:             runtime = PublishRuntime(provider=\"agentcube\")\n148:             with pytest.raises(ValueError, match=\"--image-url is required\"):\n149:                 runtime._validate_publish_prerequisites(tmp_path, metadata, {})\n150: \n151:     def test_validate_local_mode_with_image_url(self, tmp_path: Path) -> None:\n152:         metadata = AgentMetadata.model_construct(\n153:             agent_name=\"test-agent\",\n154:             language=\"python\",\n155:             entrypoint=\"python main.py\",\n156:             router_url=\"http://router\",\n157:             workload_manager_url=\"http://workload-manager\",\n158:             build_mode=\"local\",\n159:         )\n160:         \n161:         mock_docker_service = MagicMock()\n162:         mock_docker_service.check_docker_available.return_value = True\n163:         \n164:         with patch(\"agentcube.services.agentcube_provider.AgentCubeProvider\") as mock_provider:\n165:             mock_provider.return_value = MagicMock()\n166:             with patch(\"agentcube.services.docker_service.DockerService\") as mock_docker:\n167:                 mock_docker.return_value = mock_docker_service\n168:                 runtime = PublishRuntime(provider=\"agentcube\")\n169:                 runtime._docker_service = mock_docker_service\n170:                 runtime._validate_publish_prerequisites(\n171:                     tmp_path, metadata, {\"image_url\": \"registry.example.com/test-agent\"}\n172:                 )\n173: \n174:     def test_validate_node_port_out_of_range_low(self, tmp_path: Path) -> None:\n175:         metadata = AgentMetadata.model_construct(\n176:             agent_name=\"test-agent\",\n177:             language=\"python\",\n178:             entrypoint=\"python main.py\",\n179:             router_url=\"http://router\",\n180:             workload_manager_url=\"http://workload-manager\",\n181:             build_mode=\"cloud\",\n182:         )\n183:         \n184:         with patch(\"agentcube.services.agentcube_provider.AgentCubeProvider\") as mock_provider:\n185:             mock_provider.return_value = MagicMock()\n186:             runtime = PublishRuntime(provider=\"agentcube\")\n187:             with pytest.raises(ValueError, match=\"NodePort must be in range\"):\n188:                 runtime._validate_publish_prerequisites(tmp_path, metadata, {\"node_port\": 29999})\n189: \n190:     def test_validate_node_port_out_of_range_high(self, tmp_path: Path) -> None:\n191:         metadata = AgentMetadata.model_construct(\n192:             agent_name=\"test-agent\",\n193:             language=\"python\",\n194:             entrypoint=\"python main.py\",\n195:             router_url=\"http://router\",\n196:             workload_manager_url=\"http://workload-manager\",\n197:             build_mode=\"cloud\",\n198:         )\n199:         \n200:         with patch(\"agentcube.services.agentcube_provider.AgentCubeProvider\") as mock_provider:\n201:             mock_provider.return_value = MagicMock()\n202:             runtime = PublishRuntime(provider=\"agentcube\")\n203:             with pytest.raises(ValueError, match=\"NodePort must be in range\"):\n204:                 runtime._validate_publish_prerequisites(tmp_path, metadata, {\"node_port\": 32768})\n205: \n206:     def test_validate_node_port_in_range(self, tmp_path: Path) -> None:\n207:         metadata = AgentMetadata.model_construct(\n208:             agent_name=\"test-agent\",\n209:             language=\"python\",\n210:             entrypoint=\"python main.py\",\n211:             router_url=\"http://router\",\n212:             workload_manager_url=\"http://workload-manager\",\n213:             build_mode=\"cloud\",\n214:         )\n215:         \n216:         with patch(\"agentcube.services.agentcube_provider.AgentCubeProvider\") as mock_provider:\n217:             mock_provider.return_value = MagicMock()\n218:             runtime = PublishRuntime(provider=\"agentcube\")\n219:             runtime._validate_publish_prerequisites(tmp_path, metadata, {\"node_port\": 30000})\n220: \n221: \n222: class TestPublishCRToK8s:\n223:     def test_publish_cr_to_k8s_success(self, tmp_path: Path) -> None:\n224:         metadata = AgentMetadata.model_construct(\n225:             agent_name=\"test-agent\",\n226:             language=\"python\",\n227:             entrypoint=\"python main.py\",\n228:             port=8080,\n229:             readiness_probe_path=\"/health\",\n230:             readiness_probe_port=8080,\n231:         )\n232:         \n233:         mock_agentcube_provider = MagicMock()\n234:         mock_agentcube_provider.deploy_agent_runtime.return_value = {\n235:             \"deployment_name\": \"test-agent\",\n236:             \"agent_id\": \"agent-123\",\n237:             \"agent_endpoint\": \"http://test-agent.example.com\",\n238:             \"status\": \"created\",\n239:         }\n240:         \n241:         with patch(\"agentcube.services.agentcube_provider.AgentCubeProvider\") as mock_provider_class:\n242:             mock_provider_class.return_value = mock_agentcube_provider\n243:             runtime = PublishRuntime(provider=\"agentcube\")\n244:             runtime._agentcube_provider = mock_agentcube_provider\n245:             \n246:             result = runtime._publish_cr_to_k8s(\n247:                 tmp_path, metadata, \"registry.example.com/test-agent:v1.0.0\",\n248:                 {\"workload_manager_url\": \"http://wm\", \"router_url\": \"http://router\"}\n249:             )\n250:             \n251:             assert result[\"agent_id\"] == \"agent-123\"\n252:             assert result[\"deployment_type\"] == \"AgentRuntime\"\n253:             assert result[\"namespace\"] == \"default\"\n254: \n255: \n256: class TestPublishK8s:\n257:     def test_publish_k8s_success(self, tmp_path: Path) -> None:\n258:         metadata = AgentMetadata.model_construct(\n259:             agent_name=\"test-agent\",\n260:             language=\"python\",\n261:             entrypoint=\"python main.py\",\n262:             port=8080,\n263:         )\n264:         \n265:         mock_k8s_provider = MagicMock()\n266:         mock_k8s_provider.deploy_agent.return_value = {\n267:             \"deployment_name\": \"test-agent\",\n268:             \"service_name\": \"test-agent\",\n269:             \"node_port\": 30001,\n270:             \"service_url\": \"http://localhost:30001\",\n271:             \"replicas\": 1,\n272:         }\n273:         \n274:         with patch(\"agentcube.services.k8s_provider.KubernetesProvider\") as mock_provider_class:\n275:             mock_provider_class.return_value = mock_k8s_provider\n276:             runtime = PublishRuntime(provider=\"k8s\")\n277:             runtime._k8s_provider = mock_k8s_provider\n278:             \n279:             result = runtime._publish_k8s(\n280:                 tmp_path, metadata, \"registry.example.com/test-agent:v1.0.0\",\n281:                 {\"replicas\": 2, \"node_port\": 30001}\n282:             )\n283:             \n284:             assert result[\"agent_endpoint\"] == \"http://localhost:30001\"\n285:             assert result[\"deployment_type\"] == \"Deployment\"\n286: \n287: \n288: class TestPrepareImageForPublishing:\n289:     def test_prepare_cloud_image(self, tmp_path: Path) -> None:\n290:         metadata = AgentMetadata.model_construct(\n291:             agent_name=\"test-agent\",\n292:             language=\"python\",\n293:             entrypoint=\"python main.py\",\n294:             build_mode=\"cloud\",\n295:             image={\"url\": \"registry.example.com/test-agent:v1.0.0\"},\n296:         )\n297:         \n298:         with patch(\"agentcube.services.agentcube_provider.AgentCubeProvider\") as mock_provider:\n299:             mock_provider.return_value = MagicMock()\n300:             runtime = PublishRuntime(provider=\"agentcube\")\n301:             result = runtime._prepare_cloud_image(\n302:                 tmp_path, metadata, {\"image_url\": \"registry.example.com/test-agent:v1.0.0\"}\n303:             )\n304:             assert result == \"registry.example.com/test-agent:v1.0.0\"\n305: \n306: \n307: class TestUpdatePublishMetadata:\n308:     def test_update_publish_metadata(self, tmp_path: Path) -> None:\n309:         metadata_content = \"\"\"\n310: agent_name: test-agent\n311: language: python\n312: entrypoint: python main.py\n313: \"\"\"\n314:         metadata_file = tmp_path / \"agent_metadata.yaml\"\n315:         metadata_file.write_text(metadata_content)\n316:         \n317:         metadata = AgentMetadata.model_construct(\n318:             agent_name=\"test-agent\",\n319:             language=\"python\",\n320:             entrypoint=\"python main.py\",\n321:         )\n322:         \n323:         result = {\n324:             \"agent_id\": \"agent-123\",\n325:             \"agent_endpoint\": \"http://test-agent.example.com\",\n326:             \"k8s_deployment\": {\n327:                 \"type\": \"AgentRuntime\",\n328:                 \"status\": \"created\",\n329:             },\n330:         }\n331:         \n332:         with patch(\"agentcube.services.agentcube_provider.AgentCubeProvider\") as mock_provider:\n333:             mock_provider.return_value = MagicMock()\n334:             runtime = PublishRuntime(provider=\"agentcube\")\n335:             runtime._update_publish_metadata(tmp_path, metadata, result)\n336:             \n337:             saved_file = tmp_path / \"agent_metadata.yaml\"\n338:             with open(saved_file) as f:\n339:                 data = yaml.safe_load(f)\n340:             \n341:             assert data[\"agent_id\"] == \"agent-123\"\n342:             assert data[\"agent_endpoint\"] == \"http://test-agent.example.com\"\n343: \n344: \n345: class TestRecordErrorInMetadata:\n346:     def test_record_error_in_metadata(self, tmp_path: Path) -> None:\n347:         metadata_content = \"\"\"\n348: agent_name: test-agent\n349: language: python\n350: entrypoint: python main.py\n351: \"\"\"\n352:         metadata_file = tmp_path / \"agent_metadata.yaml\"\n353:         metadata_file.write_text(metadata_content)\n354:         \n355:         with patch(\"agentcube.services.agentcube_provider.AgentCubeProvider\") as mock_provider:\n356:             mock_provider.return_value = MagicMock()\n357:             runtime = PublishRuntime(provider=\"agentcube\")\n358:             runtime._record_error_in_metadata(tmp_path, \"Test error message\")\n359:             \n360:             saved_file = tmp_path / \"agent_metadata.yaml\"\n361:             with open(saved_file) as f:\n362:                 data = yaml.safe_load(f)\n363:             \n364:             assert data[\"k8s_deployment\"][\"status\"] == \"error\"\n365:             assert data[\"k8s_deployment\"][\"error\"] == \"Test error message\"\n366: \n367: \n368: class TestPublishFullWorkflow:\n369:     def test_publish_agentcube_success(self, tmp_path: Path) -> None:\n370:         metadata_content = \"\"\"\n371: agent_name: test-agent\n372: language: python\n373: entrypoint: python main.py\n374: port: 8080\n375: build_mode: cloud\n376: router_url: http://router\n377: workload_manager_url: http://workload-manager\n378: \"\"\"\n379:         metadata_file = tmp_path / \"agent_metadata.yaml\"\n380:         metadata_file.write_text(metadata_content)\n381:         \n382:         mock_agentcube_provider = MagicMock()\n383:         mock_agentcube_provider.deploy_agent_runtime.return_value = {\n384:             \"deployment_name\": \"test-agent\",\n385:             \"agent_id\": \"agent-123\",\n386:             \"agent_endpoint\": \"http://test-agent.example.com\",\n387:             \"status\": \"created\",\n388:         }\n389:         \n390:         with patch(\"agentcube.services.agentcube_provider.AgentCubeProvider\") as mock_provider_class:\n391:             mock_provider_class.return_value = mock_agentcube_provider\n392:             runtime = PublishRuntime(provider=\"agentcube\")\n393:             runtime._agentcube_provider = mock_agentcube_provider\n394:             \n395:             result = runtime.publish(tmp_path, image_url=\"registry.example.com/test-agent:v1.0.0\")\n396:             \n397:             assert result[\"status\"] == \"success\"\n398:             assert result[\"agent_name\"] == \"test-agent\"\n399:             assert result[\"agent_id\"] == \"agent-123\"\n400:             assert result[\"deployment_type\"] == \"AgentRuntime\"\n401: \n402:     def test_publish_k8s_success(self, tmp_path: Path) -> None:\n403:         metadata_content = \"\"\"\n404: agent_name: test-agent\n405: language: python\n406: entrypoint: python main.py\n407: port: 8080\n408: build_mode: cloud\n409: \"\"\"\n410:         metadata_file = tmp_path / \"agent_metadata.yaml\"\n411:         metadata_file.write_text(metadata_content)\n412:         \n413:         mock_k8s_provider = MagicMock()\n414:         mock_k8s_provider.deploy_agent.return_value = {\n415:             \"deployment_name\": \"test-agent\",\n416:             \"service_name\": \"test-agent\",\n417:             \"node_port\": 30001,\n418:             \"service_url\": \"http://localhost:30001\",\n419:             \"replicas\": 1,\n420:         }\n421:         \n422:         with patch(\"agentcube.services.k8s_provider.KubernetesProvider\") as mock_provider_class:\n423:             mock_provider_class.return_value = mock_k8s_provider\n424:             runtime = PublishRuntime(provider=\"k8s\")\n425:             runtime._k8s_provider = mock_k8s_provider\n426:             \n427:             result = runtime.publish(tmp_path, image_url=\"registry.example.com/test-agent:v1.0.0\")\n428:             \n429:             assert result[\"status\"] == \"success\"\n430:             assert result[\"agent_name\"] == \"test-agent\"\n431:             assert result[\"deployment_type\"] == \"Deployment\"\n\n(End of file - total 431 lines)\n</content>","metadata":{"preview":"import pytest\nfrom pathlib import Path\nfrom unittest.mock import MagicMock, patch, PropertyMock\nimport yaml\n\nfrom agentcube.runtime.publish_runtime import PublishRuntime\nfrom agentcube.services.metadata_service import AgentMetadata\n\n\nclass TestPublishRuntimeInit:\n    def test_init_agentcube_provider(self) -> None:\n        with patch(\"agentcube.services.agentcube_provider.AgentCubeProvider\") as mock_provider:\n            mock_provider.return_value = MagicMock()\n            runtime = PublishRuntime(verbose=False, provider=\"agentcube\")\n            assert runtime.verbose == False\n            assert runtime.provider == \"agentcube\"\n\n    def test_init_k8s_provider(self) -> None:\n        with patch(\"agentcube.services.k8s_provider.KubernetesProvider\") as mock_provider:\n            mock_provider.return_value = MagicMock()","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/cmd/cli/tests/test_publish_runtime.py","time":{"start":1775872548385,"end":1775872548407}}}}
