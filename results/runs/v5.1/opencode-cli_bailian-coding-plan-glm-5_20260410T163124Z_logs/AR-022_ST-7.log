tes.client.CoreV1Api\"):\n70:                     provider = AgentCubeProvider()\n71:                     result = provider._sanitize_name(\"test-agent_123\")\n72:                     assert result == \"test-agent-123\"\n73: \n74:     def test_sanitize_name_truncate_to_63_chars(self) -> None:\n75:         with patch(\"kubernetes.config.load_kube_config\"):\n76:             with patch(\"kubernetes.client.CustomObjectsApi\"):\n77:                 with patch(\"kubernetes.client.CoreV1Api\"):\n78:                     provider = AgentCubeProvider()\n79:                     long_name = \"a\" * 100\n80:                     result = provider._sanitize_name(long_name)\n81:                     assert len(result) == 63\n82: \n83:     def test_sanitize_name_strip_dashes(self) -> None:\n84:         with patch(\"kubernetes.config.load_kube_config\"):\n85:             with patch(\"kubernetes.client.CustomObjectsApi\"):\n86:                 with patch(\"kubernetes.client.CoreV1Api\"):\n87:                     provider = AgentCubeProvider()\n88:                     result = provider._sanitize_name(\"---test---agent---\")\n89:                     assert result == \"test-agent\"\n90: \n91:     def test_sanitize_name_empty_string(self) -> None:\n92:         with patch(\"kubernetes.config.load_kube_config\"):\n93:             with patch(\"kubernetes.client.CustomObjectsApi\"):\n94:                 with patch(\"kubernetes.client.CoreV1Api\"):\n95:                     provider = AgentCubeProvider()\n96:                     result = provider._sanitize_name(\"\")\n97:                     assert result == \"default\"\n98: \n99: \n100: class TestEnsureNamespace:\n101:     def test_ensure_namespace_exists(self) -> None:\n102:         with patch(\"kubernetes.config.load_kube_config\"):\n103:             mock_core_api = MagicMock()\n104:             mock_core_api.read_namespace.return_value = MagicMock()\n105:             \n106:             with patch(\"kubernetes.client.CustomObjectsApi\"):\n10