{"type":"tool_use","timestamp":1775846566205,"sessionID":"ses_2874c73b5ffeTv2w8vyLSfAs6g","part":{"id":"prt_d78b41d2f001X2feK2osyd0uZL","messageID":"msg_d78b40d70001mWOiR25gU54xGP","sessionID":"ses_2874c73b5ffeTv2w8vyLSfAs6g","type":"tool","tool":"read","callID":"toolu_tool-5717bb961b4e4065ad277040dc7d312f","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/server.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/server.go</path>\n<type>file</type>\n<content>\n1: package workloadmanager\n2: \n3: import (\n4: \t\"context\"\n5: \t\"net/http\"\n6: \t\"os\"\n7: \t\"os/signal\"\n8: \t\"syscall\"\n9: \n10: \t\"github.com/go-chi/chi/v5\"\n11: )\n12: \n13: // HTTPServer manages the HTTP server lifecycle including graceful shutdown.\n14: type HTTPServer struct {\n15: \tserver           *http.Server\n16: \trouter           chi.Router\n17: \tconfig           Config\n18: \thandlers         map[string]Handler\n19: \tlogger           Logger\n20: \tstopCh           chan struct{}\n21: \tlifecycleManager *SandboxLifecycleManager\n22: \tgarbageCollector *GarbageCollector\n23: \tstore            Store\n24: \tk8sClient        *K8sClient\n25: }\n26: \n27: // NewHTTPServer creates a new HTTPServer instance with the given configuration and logger.\n28: // The router is initialized with chi.NewRouter().\n29: func NewHTTPServer(cfg Config, logger Logger) *HTTPServer {\n30: \treturn &HTTPServer{\n31: \t\tserver:   &http.Server{Addr: cfg.Addr},\n32: \t\trouter:   chi.NewRouter(),\n33: \t\tconfig:   cfg,\n34: \t\thandlers: make(map[string]Handler),\n35: \t\tlogger:   logger,\n36: \t\tstopCh:   make(chan struct{}),\n37: \t\tstore:    NewMemoryStore(),\n38: \t}\n39: }\n40: \n41: func NewHTTPServerWithClients(cfg Config, logger Logger, k8sClient *K8sClient, store Store) *HTTPServer {\n42: \tlifecycleConfig := DefaultLifecycleConfig()\n43: \tlifecycleManager := NewSandboxLifecycleManager(k8sClient, store, lifecycleConfig, logger)\n44: \tgarbageCollector := NewGarbageCollector(lifecycleManager, lifecycleConfig.GCInterval, lifecycleConfig.GCOnceTimeout, logger)\n45: \n46: \treturn &HTTPServer{\n47: \t\tserver:           &http.Server{Addr: cfg.Addr},\n48: \t\trouter:           chi.NewRouter(),\n49: \t\tconfig:           cfg,\n50: \t\thandlers:         make(map[string]Handler),\n51: \t\tlogger:           logger,\n52: \t\tstopCh:           make(chan struct{}),\n53: \t\tlifecycleManager: lifecycleManager,\n54: \t\tgarbageCollector: garbageCollector,\n55: \t\tstore:            store,\n56: \t\tk8sClient:        k8sClient,\n57: \t}\n58: }\n59: \n60: // RegisterHandler stores a handler and registers its routes on the router.\n61: func (s *HTTPServer) RegisterHandler(name string, h Handler) {\n62: \ts.handlers[name] = h\n63: \th.Register(s.router)\n64: }\n65: \n66: // Start begins listening and serving HTTP requests.\n67: // It returns an error channel that receives non-ErrServerClosed errors.\n68: func (s *HTTPServer) Start() <-chan error {\n69: \terrCh := make(chan error, 1)\n70: \ts.server.ReadTimeout = s.config.ReadTimeout\n71: \ts.server.WriteTimeout = s.config.WriteTimeout\n72: \ts.server.IdleTimeout = s.config.IdleTimeout\n73: \ts.server.Handler = s.router\n74: \n75: \tif s.garbageCollector != nil {\n76: \t\ts.garbageCollector.Start()\n77: \t}\n78: \n79: \tgo func() {\n80: \t\tif err := s.server.ListenAndServe(); err != http.ErrServerClosed {\n81: \t\t\terrCh <- err\n82: \t\t}\n83: \t}()\n84: \treturn errCh\n85: }\n86: \n87: func (s *HTTPServer) Stop(ctx context.Context) error {\n88: \tif s.garbageCollector != nil {\n89: \t\ts.garbageCollector.Stop()\n90: \t}\n91: \n92: \tctx, cancel := context.WithTimeout(ctx, s.config.ShutdownTimeout)\n93: \tdefer cancel()\n94: \terr := s.server.Shutdown(ctx)\n95: \tclose(s.stopCh)\n96: \treturn err\n97: }\n98: \n99: // GracefulShutdown sets up signal handlers for SIGTERM and SIGINT.\n100: // When a signal is received, the server is stopped gracefully.\n101: func (s *HTTPServer) GracefulShutdown() {\n102: \tsigCh := make(chan os.Signal, 1)\n103: \tsignal.Notify(sigCh, syscall.SIGTERM, syscall.SIGINT)\n104: \tgo func() {\n105: \t\t<-sigCh\n106: \t\tctx := context.Background()\n107: \t\ts.Stop(ctx)\n108: \t}()\n109: }\n\n(End of file - total 109 lines)\n</content>","metadata":{"preview":"package workloadmanager\n\nimport (\n\t\"context\"\n\t\"net/http\"\n\t\"os\"\n\t\"os/signal\"\n\t\"syscall\"\n\n\t\"github.com/go-chi/chi/v5\"\n)\n\n// HTTPServer manages the HTTP server lifecycle including graceful shutdown.\ntype HTTPServer struct {\n\tserver           *http.Server\n\trouter           chi.Router\n\tconfig           Config\n\thandlers         map[string]Handler\n\tlogger           Logger\n\tstopCh           chan struct{}","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/server.go","time":{"start":1775846566183,"end":1775846566203}}}}
{"type":"tool_use","timestamp":1775846566206,"sessionID":"ses_2874c73b5ffeTv2w8vyLSfAs6g","part":{"id":"prt_d78b42103001d3q6dgz6p3cwlq","messageID":"msg_d78b40d70001mWOiR25gU54xGP","sessionID":"ses_2874c73b5ffeTv2w8vyLSfAs6g","type":"tool","tool":"read","callID":"toolu_tool-d8c49baca5dc472396049c25604825ea","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/lifecycle.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/lifecycle.go</path>\n<type>file</type>\n<content>\n1: package workloadmanager\n2: \n3: import (\n4: \t\"context\"\n5: \t\"time\"\n6: \n7: \tapierrors \"k8s.io/apimachinery/pkg/api/errors\"\n8: \tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n9: \t\"k8s.io/utils/ptr\"\n10: \n11: \t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n12: )\n13: \n14: type LifecycleConfig struct {\n15: \tDefaultTTL          time.Duration\n16: \tDefaultIdleTimeout  time.Duration\n17: \tDefaultMaxDuration  time.Duration\n18: \tGCInterval          time.Duration\n19: \tGCOnceTimeout       time.Duration\n20: \tDeletionGracePeriod int64\n21: \tDeletionTimeout     time.Duration\n22: }\n23: \n24: func DefaultLifecycleConfig() LifecycleConfig {\n25: \treturn LifecycleConfig{\n26: \t\tDefaultTTL:          DefaultSandboxTTL,\n27: \t\tDefaultIdleTimeout:  DefaultSandboxIdleTimeout,\n28: \t\tDefaultMaxDuration:  DefaultMaxSessionDuration,\n29: \t\tGCInterval:          GarbageCollectorInterval,\n30: \t\tGCOnceTimeout:       2 * time.Minute,\n31: \t\tDeletionGracePeriod: 0,\n32: \t\tDeletionTimeout:     SandboxDeleteTimeout,\n33: \t}\n34: }\n35: \n36: type SandboxLifecycleManager struct {\n37: \tk8sClient *K8sClient\n38: \tstore     Store\n39: \tconfig    LifecycleConfig\n40: \tlogger    Logger\n41: }\n42: \n43: func NewSandboxLifecycleManager(k8sClient *K8sClient, store Store, config LifecycleConfig, logger Logger) *SandboxLifecycleManager {\n44: \treturn &SandboxLifecycleManager{\n45: \t\tk8sClient: k8sClient,\n46: \t\tstore:     store,\n47: \t\tconfig:    config,\n48: \t\tlogger:    logger,\n49: \t}\n50: }\n51: \n52: func (m *SandboxLifecycleManager) DeleteSandbox(ctx context.Context, sessionID string) error {\n53: \tctx, cancel := context.WithTimeout(ctx, m.config.DeletionTimeout)\n54: \tdefer cancel()\n55: \n56: \tsandboxInfo, err := m.store.GetSandboxBySessionID(ctx, sessionID)\n57: \tif err != nil {\n58: \t\tif _, ok := err.(*NotFoundError); ok {\n59: \t\t\treturn &NotFoundError{Resource: \"session\", Name: sessionID}\n60: \t\t}\n61: \t\treturn &InternalError{Err: err}\n62: \t}\n63: \n64: \tdeleteOpts := metav1.DeleteOptions{\n65: \t\tGracePeriodSeconds: ptr.To(m.config.DeletionGracePeriod),\n66: \t}\n67: \n68: \terr = m.k8sClient.DynamicClient().Resource(SandboxGVR).\n69: \t\tNamespace(sandboxInfo.SandboxNamespace).\n70: \t\tDelete(ctx, sandboxInfo.SandboxName, deleteOpts)\n71: \n72: \tif err != nil && !apierrors.IsNotFound(err) {\n73: \t\treturn handleDeleteError(err)\n74: \t}\n75: \n76: \tif sandboxInfo.Kind == types.SandboxClaimKind {\n77: \t\terr = m.k8sClient.DynamicClient().Resource(SandboxClaimGVR).\n78: \t\t\tNamespace(sandboxInfo.SandboxNamespace).\n79: \t\t\tDelete(ctx, sandboxInfo.SandboxName, deleteOpts)\n80: \n81: \t\tif err != nil && !apierrors.IsNotFound(err) {\n82: \t\t\tm.logger.Error(\"failed to delete SandboxClaim\", \"sandboxName\", sandboxInfo.SandboxName, \"err\", err)\n83: \t\t}\n84: \t}\n85: \n86: \terr = m.store.DeleteSandboxBySessionID(ctx, sessionID)\n87: \tif err != nil {\n88: \t\tm.logger.Error(\"failed to delete from store\", \"sessionID\", sessionID, \"err\", err)\n89: \t}\n90: \n91: \treturn nil\n92: }\n93: \n94: func (m *SandboxLifecycleManager) IsExpired(sandbox *types.SandboxInfo) bool {\n95: \treturn time.Now().After(sandbox.ExpiresAt)\n96: }\n97: \n98: func (m *SandboxLifecycleManager) IsIdleExpired(sandbox *types.SandboxInfo, idleTimeout time.Duration) bool {\n99: \tif sandbox.LastActivity.IsZero() {\n100: \t\treturn false\n101: \t}\n102: \treturn time.Now().After(sandbox.LastActivity.Add(idleTimeout))\n103: }\n104: \n105: func (m *SandboxLifecycleManager) ForceDeleteSandbox(ctx context.Context, sessionID string) error {\n106: \tctx, cancel := context.WithTimeout(ctx, m.config.DeletionTimeout)\n107: \tdefer cancel()\n108: \n109: \tsandboxInfo, err := m.store.GetSandboxBySessionID(ctx, sessionID)\n110: \tif err != nil {\n111: \t\tif _, ok := err.(*NotFoundError); ok {\n112: \t\t\treturn nil\n113: \t\t}\n114: \t\treturn &InternalError{Err: err}\n115: \t}\n116: \n117: \tdeleteOpts := metav1.DeleteOptions{\n118: \t\tGracePeriodSeconds: ptr.To[int64](0),\n119: \t}\n120: \n121: \terr = m.k8sClient.DynamicClient().Resource(SandboxGVR).\n122: \t\tNamespace(sandboxInfo.SandboxNamespace).\n123: \t\tDelete(ctx, sandboxInfo.SandboxName, deleteOpts)\n124: \n125: \tif err != nil && !apierrors.IsNotFound(err) {\n126: \t\tm.logger.Error(\"force delete sandbox CR failed\", \"sandboxName\", sandboxInfo.SandboxName, \"err\", err)\n127: \t}\n128: \n129: \tif sandboxInfo.Kind == types.SandboxClaimKind {\n130: \t\tm.k8sClient.DynamicClient().Resource(SandboxClaimGVR).\n131: \t\t\tNamespace(sandboxInfo.SandboxNamespace).\n132: \t\t\tDelete(ctx, sandboxInfo.SandboxName, deleteOpts)\n133: \t}\n134: \n135: \terr = m.store.DeleteSandboxBySessionID(ctx, sessionID)\n136: \tif err != nil {\n137: \t\tm.logger.Error(\"failed to delete from store during force delete\", \"sessionID\", sessionID, \"err\", err)\n138: \t}\n139: \n140: \treturn nil\n141: }\n142: \n143: func (m *SandboxLifecycleManager) GetSandbox(ctx context.Context, sessionID string) (*types.SandboxInfo, error) {\n144: \treturn m.store.GetSandboxBySessionID(ctx, sessionID)\n145: }\n146: \n147: func (m *SandboxLifecycleManager) UpdateSandboxStatus(ctx context.Context, sessionID string, status string) error {\n148: \tsandbox, err := m.store.GetSandboxBySessionID(ctx, sessionID)\n149: \tif err != nil {\n150: \t\treturn err\n151: \t}\n152: \n153: \tsandbox.Status = status\n154: \treturn m.store.UpdateSandbox(ctx, sandbox)\n155: }\n156: \n157: func handleDeleteError(err error) error {\n158: \tif apierrors.IsNotFound(err) {\n159: \t\treturn nil\n160: \t}\n161: \tif apierrors.IsConflict(err) {\n162: \t\treturn &ConflictError{Resource: \"sandbox\", Err: err}\n163: \t}\n164: \treturn &InternalError{Err: err}\n165: }\n166: \n167: func determineDeletionReason(sandbox *types.SandboxInfo, now time.Time, idleTimeout time.Duration) DeletionReason {\n168: \tif now.After(sandbox.ExpiresAt) {\n169: \t\treturn DeletionReasonMaxDurationReached\n170: \t}\n171: \tif !sandbox.LastActivity.IsZero() && now.After(sandbox.LastActivity.Add(idleTimeout)) {\n172: \t\treturn DeletionReasonIdleTimeout\n173: \t}\n174: \treturn DeletionReasonUserRequest\n175: }\n\n(End of file - total 175 lines)\n</content>","metadata":{"preview":"package workloadmanager\n\nimport (\n\t\"context\"\n\t\"time\"\n\n\tapierrors \"k8s.io/apimachinery/pkg/api/errors\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/utils/ptr\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n)\n\ntype LifecycleConfig struct {\n\tDefaultTTL          time.Duration\n\tDefaultIdleTimeout  time.Duration\n\tDefaultMaxDuration  time.Duration\n\tGCInterval          time.Duration\n\tGCOnceTimeout       time.Duration\n\tDeletionGracePeriod int64","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/lifecycle.go","time":{"start":1775846566187,"end":1775846566205}}}}
