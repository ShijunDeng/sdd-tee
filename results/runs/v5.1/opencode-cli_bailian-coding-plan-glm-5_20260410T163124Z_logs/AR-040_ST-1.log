{"type":"tool_use","timestamp":1775900212562,"sessionID":"ses_2841a1dd4ffeaWCLhP41ngGNPw","part":{"id":"prt_d7be6afe4001xIpUqBkRbfiszJ","messageID":"msg_d7be69cb3001nqxuQvZDi1usIl","sessionID":"ses_2841a1dd4ffeaWCLhP41ngGNPw","type":"tool","tool":"read","callID":"toolu_tool-08411ecb164a4cb2b7b70b640481b973","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/sdk-python/tests/test_agent_runtime_client.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/sdk-python/tests/test_agent_runtime_client.py</path>\n<type>file</type>\n<content>\n1: import os\n2: import pytest\n3: import responses\n4: from unittest.mock import Mock, patch, MagicMock\n5: \n6: from agentcube.agent_runtime import AgentRuntimeClient\n7: from agentcube.clients.agent_runtime_data_plane import AgentRuntimeDataPlaneClient\n8: \n9: \n10: class TestAgentRuntimeClientInit:\n11:     def test_init_all_params(self):\n12:         client = AgentRuntimeClient(\n13:             agent_name=\"test-agent\",\n14:             namespace=\"test-ns\",\n15:             router_url=\"http://router.example.com\",\n16:             verbose=True,\n17:             session_id=\"test-session-123\",\n18:             timeout=60,\n19:             connect_timeout=10.0,\n20:         )\n21:         assert client.agent_name == \"test-agent\"\n22:         assert client.namespace == \"test-ns\"\n23:         assert client.router_url == \"http://router.example.com\"\n24:         assert client.session_id == \"test-session-123\"\n25:         assert client.timeout == 60\n26:         assert client.connect_timeout == 10.0\n27: \n28: \n29: class TestRouterURLRequired:\n30:     def test_router_url_required(self):\n31:         if \"ROUTER_URL\" in os.environ:\n32:             del os.environ[\"ROUTER_URL\"]\n33:         with pytest.raises(ValueError, match=\"Router URL must be provided via argument or ROUTER_URL environment variable\"):\n34:             AgentRuntimeClient(\n35:                 agent_name=\"test-agent\",\n36:             )\n37: \n38: \n39: class TestRouterURLResolution:\n40:     @responses.activate\n41:     def test_router_url_from_env(self):\n42:         responses.get(\n43:             \"http://router-env.example.com/v1/namespaces/default/agent-runtimes/test-agent/invocations/\",\n44:             headers={\"x-agentcube-session-id\": \"test-session\"},\n45:         )\n46:         os.environ[\"ROUTER_URL\"] = \"http://router-env.example.com\"\n47:         client = AgentRuntimeClient(agent_name=\"test-agent\")\n48:         assert client.router_url == \"http://router-env.example.com\"\n49:         del os.environ[\"ROUTER_URL\"]\n50: \n51:     @responses.activate\n52:     def test_router_url_explicit(self):\n53:         responses.get(\n54:             \"http://router-explicit.example.com/v1/namespaces/default/agent-runtimes/test-agent/invocations/\",\n55:             headers={\"x-agentcube-session-id\": \"test-session\"},\n56:         )\n57:         client = AgentRuntimeClient(\n58:             agent_name=\"test-agent\",\n59:             router_url=\"http://router-explicit.example.com\",\n60:         )\n61:         assert client.router_url == \"http://router-explicit.example.com\"\n62: \n63: \n64: class TestSessionReuse:\n65:     @responses.activate\n66:     def test_session_reuse(self):\n67:         responses.get(\n68:             \"http://router.example.com/v1/namespaces/default/agent-runtimes/test-agent/invocations/\",\n69:             headers={\"x-agentcube-session-id\": \"bootstrap-session\"},\n70:         )\n71:         client = AgentRuntimeClient(\n72:             agent_name=\"test-agent\",\n73:             router_url=\"http://router.example.com\",\n74:             session_id=\"provided-session\",\n75:         )\n76:         assert client.session_id == \"provided-session\"\n77:         assert len(responses.calls) == 0\n78: \n79: \n80: class TestSessionBootstrap:\n81:     @responses.activate\n82:     def test_session_bootstrap(self):\n83:         responses.get(\n84:             \"http://router.example.com/v1/namespaces/default/agent-runtimes/test-agent/invocations/\",\n85:             headers={\"x-agentcube-session-id\": \"bootstrapped-session-123\"},\n86:         )\n87:         client = AgentRuntimeClient(\n88:             agent_name=\"test-agent\",\n89:             router_url=\"http://router.example.com\",\n90:         )\n91:         assert client.session_id == \"bootstrapped-session-123\"\n92: \n93: \n94: class TestDataPlaneInit:\n95:     @responses.activate\n96:     def test_data_plane_init_success(self):\n97:         responses.get(\n98:             \"http://router.example.com/v1/namespaces/default/agent-runtimes/test-agent/invocations/\",\n99:             headers={\"x-agentcube-session-id\": \"test-session\"},\n100:         )\n101:         client = AgentRuntimeClient(\n102:             agent_name=\"test-agent\",\n103:             router_url=\"http://router.example.com\",\n104:             timeout=60,\n105:             connect_timeout=10.0,\n106:         )\n107:         assert isinstance(client.dp_client, AgentRuntimeDataPlaneClient)\n108:         assert client.dp_client.namespace == \"default\"\n109:         assert client.dp_client.agent_name == \"test-agent\"\n110:         assert client.dp_client.timeout == 60\n111:         assert client.dp_client.connect_timeout == 10.0\n112: \n113: \n114: class TestContextManager:\n115:     @responses.activate\n116:     def test_context_enter(self):\n117:         responses.get(\n118:             \"http://router.example.com/v1/namespaces/default/agent-runtimes/test-agent/invocations/\",\n119:             headers={\"x-agentcube-session-id\": \"test-session\"},\n120:         )\n121:         client = AgentRuntimeClient(\n122:             agent_name=\"test-agent\",\n123:             router_url=\"http://router.example.com\",\n124:         )\n125:         with client as ctx_client:\n126:             assert ctx_client is client\n127: \n128:     @responses.activate\n129:     def test_context_exit_calls_close(self):\n130:         responses.get(\n131:             \"http://router.example.com/v1/namespaces/default/agent-runtimes/test-agent/invocations/\",\n132:             headers={\"x-agentcube-session-id\": \"test-session\"},\n133:         )\n134:         client = AgentRuntimeClient(\n135:             agent_name=\"test-agent\",\n136:             router_url=\"http://router.example.com\",\n137:         )\n138:         close_mock = Mock()\n139:         client.close = close_mock\n140:         with client:\n141:             pass\n142:         close_mock.assert_called_once()\n143: \n144:     @responses.activate\n145:     def test_context_exit_on_exception(self):\n146:         responses.get(\n147:             \"http://router.example.com/v1/namespaces/default/agent-runtimes/test-agent/invocations/\",\n148:             headers={\"x-agentcube-session-id\": \"test-session\"},\n149:         )\n150:         client = AgentRuntimeClient(\n151:             agent_name=\"test-agent\",\n152:             router_url=\"http://router.example.com\",\n153:         )\n154:         close_mock = Mock()\n155:         client.close = close_mock\n156:         try:\n157:             with client:\n158:                 raise RuntimeError(\"Test exception\")\n159:         except RuntimeError:\n160:             pass\n161:         close_mock.assert_called_once()\n162: \n163: \n164: class TestInvoke:\n165:     @responses.activate\n166:     def test_invoke_delegation(self):\n167:         responses.get(\n168:             \"http://router.example.com/v1/namespaces/default/agent-runtimes/test-agent/invocations/\",\n169:             headers={\"x-agentcube-session-id\": \"test-session\"},\n170:         )\n171:         responses.post(\n172:             \"http://router.example.com/v1/namespaces/default/agent-runtimes/test-agent/invocations/\",\n173:             json={\"result\": \"success\"},\n174:             status=200,\n175:         )\n176:         client = AgentRuntimeClient(\n177:             agent_name=\"test-agent\",\n178:             router_url=\"http://router.example.com\",\n179:             session_id=\"test-session\",\n180:         )\n181:         result = client.invoke({\"input\": \"test\"})\n182:         assert result == {\"result\": \"success\"}\n183: \n184:     def test_invoke_without_session(self):\n185:         client = AgentRuntimeClient.__new__(AgentRuntimeClient)\n186:         client.session_id = None\n187:         client.dp_client = Mock()\n188:         with pytest.raises(ValueError, match=\"AgentRuntime session_id is not initialized\"):\n189:             client.invoke({\"input\": \"test\"})\n190: \n191:     @responses.activate\n192:     def test_invoke_timeout_passthrough(self):\n193:         responses.get(\n194:             \"http://router.example.com/v1/namespaces/default/agent-runtimes/test-agent/invocations/\",\n195:             headers={\"x-agentcube-session-id\": \"test-session\"},\n196:         )\n197:         responses.post(\n198:             \"http://router.example.com/v1/namespaces/default/agent-runtimes/test-agent/invocations/\",\n199:             json={\"result\": \"success\"},\n200:             status=200,\n201:         )\n202:         client = AgentRuntimeClient(\n203:             agent_name=\"test-agent\",\n204:             router_url=\"http://router.example.com\",\n205:             session_id=\"test-session\",\n206:         )\n207:         result = client.invoke({\"input\": \"test\"}, timeout=30)\n208:         assert result == {\"result\": \"success\"}\n209:         assert len(responses.calls) == 1\n210: \n211: \n212: class TestClose:\n213:     @responses.activate\n214:     def test_close_closes_data_plane(self):\n215:         responses.get(\n216:             \"http://router.example.com/v1/namespaces/default/agent-runtimes/test-agent/invocations/\",\n217:             headers={\"x-agentcube-session-id\": \"test-session\"},\n218:         )\n219:         client = AgentRuntimeClient(\n220:             agent_name=\"test-agent\",\n221:             router_url=\"http://router.example.com\",\n222:         )\n223:         close_mock = Mock()\n224:         client.dp_client.close = close_mock\n225:         client.close()\n226:         close_mock.assert_called_once()\n\n(End of file - total 226 lines)\n</content>","metadata":{"preview":"import os\nimport pytest\nimport responses\nfrom unittest.mock import Mock, patch, MagicMock\n\nfrom agentcube.agent_runtime import AgentRuntimeClient\nfrom agentcube.clients.agent_runtime_data_plane import AgentRuntimeDataPlaneClient\n\n\nclass TestAgentRuntimeClientInit:\n    def test_init_all_params(self):\n        client = AgentRuntimeClient(\n            agent_name=\"test-agent\",\n            namespace=\"test-ns\",\n            router_url=\"http://router.example.com\",\n            verbose=True,\n            session_id=\"test-session-123\",\n            timeout=60,\n            connect_timeout=10.0,\n        )","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/sdk-python/tests/test_agent_runtime_client.py","time":{"start":1775900212537,"end":1775900212560}}}}
