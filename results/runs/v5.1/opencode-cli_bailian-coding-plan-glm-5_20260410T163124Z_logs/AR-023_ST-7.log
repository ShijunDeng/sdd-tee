rovider\n175:             runtime = StatusRuntime(provider=\"k8s\")\n176:             runtime._k8s_provider = mock_k8s_provider\n177:             \n178:             result = runtime.get_status(tmp_path)\n179:             \n180:             assert result[\"status\"] == \"not_ready\"\n181: \n182:     def test_get_k8s_status_not_found_in_k8s(self, tmp_path: Path) -> None:\n183:         metadata_content = \"\"\"\n184: agent_name: test-agent\n185: language: python\n186: entrypoint: python main.py\n187: agent_endpoint: http://localhost:30001\n188: k8s_deployment:\n189:   type: Deployment\n190:   deployment_name: test-agent\n191:   namespace: default\n192: \"\"\"\n193:         metadata_file = tmp_path / \"agent_metadata.yaml\"\n194:         metadata_file.write_text(metadata_content)\n195:         \n196:         mock_k8s_provider = MagicMock()\n197:         mock_k8s_provider.get_agent_status.return_value = {\n198:             \"deployment\": {\n199:                 \"name\": \"test-agent\",\n200:                 \"status\": \"not_found\",\n201:             },\n202:             \"service\": {\n203:                 \"name\": \"test-agent\",\n204:                 \"status\": \"not_found\",\n205:             },\n206:         }\n207:         \n208:         with patch(\"agentcube.services.k8s_provider.KubernetesProvider\") as mock_provider_class:\n209:             mock_provider_class.return_value = mock_k8s_provider\n210:             runtime = StatusRuntime(provider=\"k8s\")\n211:             runtime._k8s_provider = mock_k8s_provider\n212:             \n213:             result = runtime.get_status(tmp_path)\n214:             \n215:             assert result[\"status\"] == \"not_found_in_k8s\"\n216: \n217:     def test_get_k8s_status_no_deployment_name(self, tmp_path: Path) -> None:\n218:         metadata_content = \"\"\"\n219: agent_name: test-agent\n220: language: python\n221: entrypoint: python main.py\n222: agent_endpoint: http://localhost:30001\n223: k8s_deployment:\n224:   type: Deployment\n225: \"\"\"\n226:         metadata_file = tmp_path / \"agent_metadata.yaml\"\n227:         metadata_file.write_text(metadata_content)\n228:         \n229:         mock_k8s_provider = MagicMock()\n230:         \n231:         with patch(\"agentcube.services.k8s_provider.KubernetesProvider\") as mock_provider_class:\n232:             mock_provider_class.return_value = mock_k8s_provider\n233:             runtime = StatusRuntime(provider=\"k8s\")\n234:             runtime._k8s_provider = mock_k8s_provider\n235:             \n236:             result = runtime.get_status(tmp_path)\n237:             \n238:             assert result[\"status\"] == \"not_published\"\n239:             assert \"No deployment found\" in result[\"message\"]\n240: \n241: \n242: class TestGetCRK8sStatus:\n243:     def test_get_cr_k8s_status_with_status(self, tmp_path: Path) -> None:\n244:         metadata_content = \"\"\"\n245: agent_name: test-agent\n246: language: python\n247: entrypoint: python main.py\n248: agent_endpoint: http://test-agent.example.com\n249: agent_id: agent-123\n250: k8s_deployment:\n251:   type: AgentRuntime\n252:   namespace: production\n253:   agent_id: agent-123\n254: \"\"\"\n255:         metadata_file = tmp_path / \"agent_metadata.yaml\"\n256:         metadata_file.write_text(metadata_content)\n257:         \n258:         mock_agentcube_provider = MagicMock()\n259:         mock_agentcube_provider.get_agent_runtime.return_value = {\n260:             \"metadata\": {\"name\": \"test-agent\"},\n261:             \"status\": {\n262:                 \"status\": \"running\",\n263:                 \"agentEndpoint\": \"http://test-agent.example.com/endpoint\",\n264:             },\n265:         }\n266:         \n267:         with patch(\"agentcube.services.agentcube_provider.AgentCubeProvider\") as mock_provider_class:\n268:             mock_provider_class.return_value = mock_agentcube_provider\n269:             runtime = StatusRuntime(provider=\"agentcube\")\n270:             runtime._agentcube_provider = mock_agentcube_provider\n271:             \n272:             result = runtime.get_status(tmp_path)\n273:             \n274:             assert result[\"status\"] == \"running\"\n275:             assert result[\"deployment_type\"] == \"AgentRuntime\"\n276:             assert result[\"namespace\"] == \"production\"\n277:             assert result[\"agent_endpoint\"] == \"http://test-agent.example.com/endpoint\"\n278: \n279:     def test_get_cr_k8s_status_created_no_status(self, tmp_path: Path) -> None:\n280:         metadata_content = \"\"\"\n281: agent_name: test-agent\n282: language: python\n283: entrypoint: python main.py\n284: agent_endpoint: http://test-agent.example.com\n285: agent_id: agent-123\n286: k8s_deployment:\n287:   type: AgentRuntime\n288:   namespace: default\n289:   agent_id: agent-123\n290: \"\"\"\n291:         metadata_file = tmp_path / \"agent_metadata.yaml\"\n292:         metadata_file.write_text(metadata_content)\n293:         \n294:         mock_agentcube_provider = MagicMock()\n295:         mock_agentcube_provider.get_agent_runtime.return_value = {\n296:             \"metadata\": {\"name\": \"test-agent\"},\n297:         }\n298:         \n299:         with patch(\"agentcube.services.agentcube_provider.AgentCubeProvider\") as mock_provider_class:\n300:             mock_provider_class.return_value = mock_agentcube_provider\n301:             runtime = StatusRuntime(provider=\"agentcube\")\n302:             runtime._agentcube_provider = mock_agentcube_provider\n303:             \n304:             result = runtime.get_status(tmp_path)\n305:             \n306:             assert result[\"status\"] == \"created_no_status\"\n307: \n308:     def test_get_cr_k8s_status_not_found_in_k8s(self, tmp_path: Path) -> None:\n309:         metadata_content = \"\"\"\n310: agent_name: test-agent\n311: language: python\n312: entrypoint: python main.py\n313: agent_endpoint: http://test-agent.example.com\n314: agent_id: agent-