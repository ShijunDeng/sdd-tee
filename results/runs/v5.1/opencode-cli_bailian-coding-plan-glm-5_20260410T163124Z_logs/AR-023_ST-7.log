t_type\"] == \"Deployment\"\n404: \n405: \n406: class TestGetStatusUnknown:\n407:     def test_get_status_unknown_deployment_type(self, tmp_path: Path) -> None:\n408:         metadata_content = \"\"\"\n409: agent_name: test-agent\n410: language: python\n411: entrypoint: python main.py\n412: agent_endpoint: http://test-agent.example.com\n413: agent_id: agent-123\n414: k8s_deployment:\n415:   type: UnknownType\n416: \"\"\"\n417:         metadata_file = tmp_path / \"agent_metadata.yaml\"\n418:         metadata_file.write_text(metadata_content)\n419:         \n420:         with patch(\"agentcube.services.agentcube_provider.AgentCubeProvider\") as mock_provider:\n421:             mock_provider.return_value = MagicMock()\n422:             runtime = StatusRuntime(provider=\"agentcube\")\n423:             result = runtime.get_status(tmp_path)\n424:             \n425:             assert result[\"status\"] == \"unknown\"\n426:             assert result[\"deployment_type\"] == \"UnknownType\"\n427: \n428: \n429: class TestGetStatusFullWorkflow:\n430:     def test_get_status_agentruntime_success(self, tmp_path: Path) -> None:\n431:         metadata_content = \"\"\"\n432: agent_name: test-agent\n433: language: python\n434: entrypoint: python main.py\n435: agent_endpoint: http://test-agent.example.com\n436: agent_id: agent-123\n437: k8s_deployment:\n438:   type: AgentRuntime\n439:   namespace: production\n440:   agent_id: agent-123\n441: \"\"\"\n442:         metadata_file = tmp_path / \"agent_metadata.yaml\"\n443:         metadata_file.write_text(metadata_content)\n444:         \n445:         mock_agentcube_provider = MagicMock()\n446:         mock_agentcube_provider.get_agent_runtime.return_value = {\n447:             \"metadata\": {\"name\": \"test-agent\", \"namespace\": \"production\"},\n448:             \"status\": {\n449:                 \"status\": \"ready\",\n450:                 \"agentEndpoint\": \"http://test-agent.example.com/api\",\n451:             },\n452:         }\n453:         \n454:         with patch(\"agentcube.services.agentcube_provider.AgentCubeProvider\") as mock_provider_class:\n455:             mock_provider_class.return_value = mock_agentcube_provider\n456:             runtime = StatusRuntime(provider=\"agentcube\")\n457:             runtime._agentcube_provider = mock_agentcube_provider\n458:             \n459:             result = runtime.get_status(tmp_path)\n460:             \n461:             assert result[\"status\"] == \"ready\"\n462:             assert result[\"agent_name\"] == \"test-agent\"\n463:             assert result[\"agent_id\"] == \"agent-123\"\n464:             assert result[\"deployment_type\"] == \"AgentRuntime\"\n465:             assert result[\"namespace\"] == \"production\"\n466: \n467:     def test_get_status_deployment_success(self, tmp_path: Path) -> None:\n468:         metadata_content = \"\"\"\n469: agent_name: test-agent\n470: language: python\n471: entrypoint: python main.py\n472: agent_endpoint: http://localhost:30001\n473: k8s_deployment:\n474:   type: Deployment\n475:   deployment_name: test-agent\n476:   namespace: default\n477: \"\"\"\n478:         metadata_file = tmp_path / \"agent_metadata.yaml\"\n479:         metadata_file.write_text(metadata_content)\n480:         \n481:         mock_k8s_provider = MagicMock()\n482:         mock_k8s_provider.get_agent_status.return_value = {\n483:             \"deployment\": {\n484:                 \"name\": \"test-agent\",\n485:                 \"replicas\": 1,\n486:                 \"available_replicas\": 1,\n487:                 \"ready_replicas\": 1,\n488:             },\n489:             \"service\": {\n490:                 \"name\": \"test-agent\",\n491:                 \"node_port\": 30001,\n492:             },\n493:         }\n494:         \n495:         with patch(\"agentcube.services.k8s_provider.KubernetesProvider\") as mock_provider_class:\n496:             mock_provider_class.return_value = mock_k8s_provider\n497:             runtime = StatusRuntime(provider=\"k8s\")\n498:             runtime._k8s_provider = mock_k8s_provider\n499:             \n500:             result = runtime.get_status(tmp_path)\n501:             \n502:             assert result[\"status\"] == \"ready\"\n503:             assert result[\"agent_name\"] == \"test-agent\"\n504:             assert result[\"deployment_type\"] == \"Deployment\"\n505:             assert result[\"replicas\"] == 1\n506:             assert result[\"available_replicas\"] == 1\n\n(End of file - total 506 lines)\n</content>","metadata":{"preview":"import pytest\nfrom pathlib import Path\nfrom unittest.mock import MagicMock, patch\nimport yaml\n\nfrom agentcube.runtime.status_runtime import StatusRuntime\nfrom agentcube.services.metadata_service import AgentMetadata\n\n\nclass TestStatusRuntimeInit:\n    def test_init_agentcube_provider(self) -> None:\n        with patch(\"agentcube.services.agentcube_provider.AgentCubeProvider\") as mock_provider:\n            mock_provider.return_value = MagicMock()\n            runtime = StatusRuntime(verbose=False, provider=\"agentcube\")\n            assert runtime.verbose == False\n            assert runtime.provider == \"agentcube\"\n\n    def test_init_k8s_provider(self) -> None:\n        with patch(\"agentcube.services.k8s_provider.KubernetesProvider\") as mock_provider:\n            mock_provider.return_value = MagicMock()","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/cmd/cli/tests/test_status_runtime.py","time":{"start":1775875407500,"end":1775875407515}}}}
{"type":"tool_use","timestamp":1775875407519,"sessionID":"ses_285942bbeffeReFZpd8UeZDuFH","part":{"id":"prt_d7a6c34470010mQE1Xf54GCbuj","messageID":"msg_d7a6c1d4c001BHdtahm51a1SeX","sessionID":"ses_285942bbeffeReFZpd8UeZDuFH","type":"tool","tool":"read","callID":"toolu_tool-8ace47875c5d4eaf8e9df07a5aab527a","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/cmd/cli/agentcube/runtime/invoke_runtime.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/cmd/cli/agentcube/runtime/invoke_runtime.py</path>\n<type>file</type>\n<content>\n1: import asyncio\n2: import json\n3: import logging\n4: from pathlib import Path\n5: from typing import Any, Dict, Optional, Tuple\n6: \n7: import httpx\n8: \n9: from agentcube.services.metadata_service import AgentMetadata, MetadataService\n10: \n11: \n12: class InvokeRuntime:\n13:     def __init__(self, verbose: bool = False, provider: str = \"agentcube\") -> None:\n14:         self.verbose = verbose\n15:         self.provider = provider\n16:         self._metadata_service = MetadataService(verbose)\n17:         self._logger = logging.getLogger(__name__)\n18: \n19:         if provider == \"k8s\":\n20:             from agentcube.services.k8s_provider import KubernetesProvider\n21:             self._k8s_provider = KubernetesProvider(verbose=verbose)\n22:         elif provider == \"agentcube\":\n23:             from agentcube.services.agentcube_provider import AgentCubeProvider\n24:             self._agentcube_provider = AgentCubeProvider(verbose=verbose)\n25:         else:\n26:             raise ValueError(f\"Invalid provider: {provider}. Must be 'agentcube' or 'k8s'\")\n27: \n28:     def invoke(\n29:         self,\n30:         workspace_path: Path,\n31:         payload: Dict[str, Any],\n32:         headers: Optional[Dict[str, str]] = None,\n33:     ) -> Any:\n34:         metadata, endpoint, namespace = self._validate_invoke_prerequisites(workspace_path)\n35:         \n36:         if self.verbose:\n37:             self._logger.debug(f\"Invoking agent at endpoint: {endpoint}\")\n38:             self._logger.debug(f\"Payload: {payload}\")\n39:         \n40:         final_headers = headers or {}\n41:         if metadata.session_id:\n42:             final_headers[\"X-Agentcube-Session-Id\"] = metadata.session_id\n43:         \n44:         k8s_deployment = metadata.k8s_deployment or {}\n45:         deployment_type = k8s_deployment.get(\"type\", \"\")\n46:         \n47:         if deployment_type == \"AgentRuntime\" and self.provider == \"agentcube\":\n48:             sanitized_name = self._agentcube_provider._sanitize_name(metadata.agent_name)\n49:             namespace = k8s_deployment.get(\"namespace\", \"default\")\n50:             base_endpoint = endpoint.rstrip(\"/\")\n51:             endpoint = f\"{base_endpoint}/v1/namespaces/{namespace}/agent-runtimes/{sanitized_name}/invocations/\"\n52:             \n53:             if self.verbose:\n54:                 self._logger.info(f\"Rewrote endpoint for AgentRuntime: {endpoint}\")\n55:         \n56:         return asyncio.run(self._direct_http_invocation(endpoint, payload, final_headers, workspace_path))\n57: \n58:     def _validate_invoke_prerequisites(self, workspace_path: Path) -> Tuple[AgentMetadata, str, str]:\n59:         metadata = self._metadata_service.load_metadata(workspace_path)\n60:         \n61:         if not metadata.agent_endpoint:\n62:             raise ValueError(\"Agent endpoint not found. Run 'publish' first.\")\n63:         \n64:         if not metadata.agent_id and self.provider == \"agentcube\":\n65:             k8s_deployment = metadata.k8s_deployment or {}\n66:             if not k8s_deployment.get(\"agent_id\"):\n67:                 raise ValueError(\"Agent not published. Run 'publish' first.\")\n68:         \n69:         namespace = \"default\"\n70:         k8s_deployment = metadata.k8s_deployment or {}\n71:         if k8s_deployment.get(\"namespace\"):\n72:             namespace = k8s_deployment[\"namespace\"]\n73:         \n74:         endpoint = metadata.agent_endpoint\n75:         return metadata, endpoint, namespace\n76: \n77:     async def _direct_http_invocation(\n78:         self,\n79:         endpoint: str,\n80:         payload: Dict[str, Any],\n81:         headers: Optional[Dict[str, str]],\n82:         workspace_path: Path,\n83:     ) -> Dict[str, Any]:\n84:         if self.verbose:\n85:             self._logger.info(f\"Sending HTTP POST to {endpoint}\")\n86:         \n87:         timeout = httpx.Timeout(60.0)\n88:         async with httpx.AsyncClient(timeout=timeout) as client:\n89:             response = await client.post(\n90:                 endpoint,\n91:                 json=payload,\n92:                 headers=headers or {},\n93:             )\n94:             \n95:             if self.verbose:\n96:                 self._logger.info(f\"Response status: {response.status_code}\")\n97:             \n98:             try:\n99:                 response_data = response.json()\n100:             except json.JSONDecodeError:\n101:                 response_data = {\"raw_response\": response.text}\n102:             \n103:             result = {\n104:                 \"status_code\": response.status_code,\n105:                 \"response\": response_data,\n106:                 \"endpoint\": endpoint,\n107:             }\n108:             \n109:             response_headers = dict(response.headers)\n110:             session_id = response_headers.get(\"x-agentcube-session-id\")\n111:             if session_id:\n112:                 metadata = self._metadata_service.load_metadata(workspace_path)\n113:                 metadata.session_id = session_id\n114:                 self._metadata_service.save_metadata(workspace_path, metadata)\n115:                 result[\"session_id\"] = session_id\n116:             \n117:             return result\n\n(End of file - total 117 lines)\n</content>","metadata":{"preview":"import asyncio\nimport json\nimport logging\nfrom pathlib import Path\nfrom typing import Any, Dict, Optional, Tuple\n\nimport httpx\n\nfrom agentcube.services.metadata_service import AgentMetadata, MetadataService\n\n\nclass InvokeRuntime:\n    def __init__(self, verbose: bool = False, provider: str = \"agentcube\") -> None:\n        self.verbose = verbose\n        self.provider = provider\n        self._metadata_service = MetadataService(verbose)\n        self._logger = logging.getLogger(__name__)\n\n        if provider == \"k8s\":\n            from agentcube.services.k8s_provider import KubernetesProvider","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/cmd/cli/agentcube/runtime/invoke_runtime.py","time":{"start":1775875407493,"end":1775875407518}}}}
{"type":"tool_use","timestamp":1775875407521,"sessionID":"ses_285942bbeffeReFZpd8UeZDuFH","part":{"id":"prt_d7a6c3790001so7u2bQUWb1vXw","messageID":"msg_d7a6c1d4c001BHdtahm51a1SeX","sessionID":"ses_285942bbeffeReFZpd8UeZDuFH","type":"tool","tool":"read","callID":"toolu_tool-590d718a06594c9d8a71b755ec3731d3","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/cmd/cli/agentcube/runtime/status_runtime.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/cmd/cli/agentcube/runtime/status_runtime.py</path>\n<type>file</type>\n<content>\n1: import logging\n2: from pathlib import Path\n3: from typing import Any, Dict, Optional\n4: \n5: from agentcube.services.metadata_service import AgentMetadata, MetadataService\n6: \n7: \n8: class StatusRuntime:\n9:     def __init__(self, verbose: bool = False, provider: str = \"agentcube\") -> None:\n10:         self.verbose = verbose\n11:         self.provider = provider\n12:         self._metadata_service = MetadataService(verbose)\n13:         self._logger = logging.getLogger(__name__)\n14: \n15:         if provider == \"k8s\":\n16:             from agentcube.services.k8s_provider import KubernetesProvider\n17:             self._k8s_provider = KubernetesProvider(verbose=verbose)\n18:         elif provider == \"agentcube\":\n19:             from agentcube.services.agentcube_provider import AgentCubeProvider\n20:             self._agentcube_provider = AgentCubeProvider(verbose=verbose)\n21:         else:\n22:             raise ValueError(f\"Invalid provider: {provider}. Must be 'agentcube' or 'k8s'\")\n23: \n24:     def get_status(self, workspace_path: Path, provider: Optional[str] = None) -> Dict[str, Any]:\n25:         use_provider = provider or self.provider\n26:         metadata = self._metadata_service.load_metadata(workspace_path)\n27:         \n28:         if self.verbose:\n29:             self._logger.info(f\"Getting status for agent: {metadata.agent_name}\")\n30:         \n31:         if not metadata.agent_id and not metadata.k8s_deployment:\n32:             return {\n33:                 \"status\": \"not_published\",\n34:                 \"agent_name\": metadata.agent_name,\n35:                 \"message\": \"Agent has not been published. Run 'publish' first.\",\n36:             }\n37:         \n38:         k8s_deployment = metadata.k8s_deployment or {}\n39:         deployment_type = k8s_deployment.get(\"type\", \"\")\n40:         namespace = k8s_deployment.get(\"namespace\", \"default\")\n41:         \n42:         if use_provider == \"agentcube\" and deployment_type == \"AgentRuntime\":\n43:             return self._get_cr_k8s_status(metadata)\n44:         elif use_provider == \"k8s\" or deployment_type == \"Deployment\":\n45:             return self._get_k8s_status(metadata)\n46:         else:\n47:             return {\n48:                 \"status\": \"unknown\",\n49:                 \"agent_name\": metadata.agent_name,\n50:                 \"deployment_type\": deployment_type,\n51:                 \"agent_endpoint\": metadata.agent_endpoint,\n52:             }\n53: \n54:     def _get_k8s_status(self, metadata: AgentMetadata) -> Dict[str, Any]:\n55:         k8s_deployment = metadata.k8s_deployment or {}\n56:         deployment_name = k8s_deployment.get(\"deployment_name\")\n57:         namespace = k8s_deployment.get(\"namespace\", \"default\")\n58:         \n59:         if not deployment_name:\n60:             return {\n61:                 \"status\": \"not_published\",\n62:                 \"agent_name\": metadata.agent_name,\n63:                 \"message\": \"No deployment found in metadata.\",\n64:             }\n65:         \n66:         self._k8s_provider.namespace = namespace\n67:         \n68:         try:\n69:             k8s_status = self._k8s_provider.get_agent_status(metadata.agent_name)\n70:             deployment_info = k8s_status.get(\"deployment\", {})\n71:             service_info = k8s_status.get(\"service\", {})\n72:             \n73:             deployment_status = \"unknown\"\n74:             if deployment_info.get(\"status\") == \"not_found\":\n75:                 deployment_status = \"not_found_in_k8s\"\n76:             elif deployment_info.get(\"available_replicas\") == deployment_info.get(\"replicas\"):\n77:                 deployment_status = \"ready\"\n78:             elif deployment_info.get(\"available_replicas\", 0) > 0:\n79:                 deployment_status = \"partial\"\n80:             else:\n81:                 deployment_status = \"not_ready\"\n82:             \n83:             service_url = None\n84:             if service_info.get(\"node_port\"):\n85:                 service_url = f\"http://localhost:{service_info['node_port']}\"\n86:             \n87:             return {\n88:                 \"status\": deployment_status,\n89:                 \"agent_name\": metadata.agent_name,\n90:                 \"deployment_type\": \"Deployment\",\n91:                 \"namespace\": namespace,\n92:                 \"deployment\": deployment_info,\n93:                 \"service\": service_info,\n94:                 \"agent_endpoint\": service_url or metadata.agent_endpoint,\n95:                 \"replicas\": deployment_info.get(\"replicas\", 1),\n96:                 \"available_replicas\": deployment_info.get(\"available_replicas\", 0),\n97:             }\n98:         except Exception as e:\n99:             if self.verbose:\n100:                 self._logger.error(f\"Error getting K8s status: {e}\")\n101:             return {\n102:                 \"status\": \"error\",\n103:                 \"agent_name\": metadata.agent_name,\n104:                 \"error\": str(e),\n105:             }\n106: \n107:     def _get_cr_k8s_status(self, metadata: AgentMetadata) -> Dict[str, Any]:\n108:         k8s_deployment = metadata.k8s_deployment or {}\n109:         namespace = k8s_deployment.get(\"namespace\", \"default\")\n110:         agent_id = k8s_deployment.get(\"agent_id\") or metadata.agent_id\n111:         \n112:         self._agentcube_provider.namespace = namespace\n113:         \n114:         try:\n115:             cr_object = self._agentcube_provider.get_agent_runtime(\n116:                 name=metadata.agent_name,\n117:                 namespace=namespace,\n118:             )\n119:             \n120:             if not cr_object:\n121:                 return {\n122:                     \"status\": \"not_found_in_k8s\",\n123:                     \"agent_name\": metadata.agent_name,\n124:                     \"agent_id\": agent_id,\n125:                     \"namespace\": namespace,\n126:                     \"message\": \"AgentRuntime CR not found in Kubernetes.\",\n127:                 }\n128:             \n129:             cr_status = cr_object.get(\"status\")\n130:             \n131:             if cr_status:\n132:                 return {\n133:                     \"status\": cr_status.get(\"status\", \"created_no_status\"),\n134:                     \"agent_name\": metadata.agent_name,\n135:                     \"agent_id\": agent_id,\n136:                     \"deployment_type\": \"AgentRuntime\",\n137:                     \"namespace\": namespace,\n138:                     \"agent_endpoint\": cr_status.get(\"agentEndpoint\") or metadata.agent_endpoint,\n139:                     \"cr_status\": cr_status,\n140:                 }\n141:             else:\n142:                 return {\n143:                     \"status\": \"created_no_status\",\n144:                     \"agent_name\": metadata.agent_name,\n145:                     \"agent_id\": agent_id,\n146:                     \"deployment_type\": \"AgentRuntime\",\n147:                     \"namespace\": namespace,\n148:                     \"agent_endpoint\": metadata.agent_endpoint,\n149:                 }\n150:         except Exception as e:\n151:             if self.verbose:\n152:                 self._logger.error(f\"Error getting AgentRuntime status: {e}\")\n153:             return {\n154:                 \"status\": \"error\",\n155:                 \"agent_name\": metadata.agent_name,\n156:                 \"error\": str(e),\n157:             }\n\n(End of file - total 157 lines)\n</content>","metadata":{"preview":"import logging\nfrom pathlib import Path\nfrom typing import Any, Dict, Optional\n\nfrom agentcube.services.metadata_service import AgentMetadata, MetadataService\n\n\nclass StatusRuntime:\n    def __init__(self, verbose: bool = False, provider: str = \"agentcube\") -> None:\n        self.verbose = verbose\n        self.provider = provider\n        self._metadata_service = MetadataService(verbose)\n        self._logger = logging.getLogger(__name__)\n\n        if provider == \"k8s\":\n            from agentcube.services.k8s_provider import KubernetesProvider\n            self._k8s_provider = KubernetesProvider(verbose=verbose)\n        elif provider == \"agentcube\":\n            from agentcube.services.agentcube_provider import AgentCubeProvider\n            self._agentcube_provider = AgentCubeProvider(verbose=verbose)","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/cmd/cli/agentcube/runtime/status_runtime.py","time":{"start":1775875407496,"end":1775875407520}}}}
