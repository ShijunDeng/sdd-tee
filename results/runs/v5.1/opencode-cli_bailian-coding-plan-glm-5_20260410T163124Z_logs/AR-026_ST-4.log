3:                 \n104:                 with patch(\"kubernetes.client.CoreV1Api\", return_value=mock_core_api):\n105:                     provider = KubernetesProvider(namespace=\"new-ns\")\n106:                     provider._core_api = mock_core_api\n107:                     provider._ensure_namespace()\n108:                     \n109:                     mock_core_api.create_namespace.assert_called_once()\n110: \n111: \n112: class TestCreateDeployment:\n113:     def test_create_deployment_basic(self) -> None:\n114:         with patch(\"kubernetes.config.load_kube_config\"):\n115:             mock_apps_api = MagicMock()\n116:             mock_apps_api.create_namespaced_deployment.return_value = MagicMock()\n117:             \n118:             with patch(\"kubernetes.client.AppsV1Api\", return_value=mock_apps_api):\n119:                 with patch(\"kubernetes.client.CoreV1Api\"):\n120:                     provider = KubernetesProvider()\n121:                     provider._apps_api = mock_apps_api\n122:                     \n123:                     result = provider._create_deployment(\n124:                         \"test-agent\",\n125:                         \"registry.example.com/test:v1.0.0\",\n126:                         8080,\n127:                         None,\n128:                         1,\n129:                         None,\n130:                     )\n131:                     \n132:                     assert result[\"name\"] == \"test-agent\"\n133:                     assert result[\"status\"] == \"created\"\n134: \n135:     def test_create_deployment_with_env_vars(self) -> None:\n136:         with patch(\"kubernetes.config.load_kube_config\"):\n137:             mock_apps_api = MagicMock()\n138:             mock_apps_api.create_namespaced_deployment.return_value = MagicMock()\n139:             \n140:             with patch(\"kubernetes.client.AppsV1Api\", return_value=mock_apps_api):\n141:                 with patch(\"kubernetes.client.CoreV1Api\"):\n142:                     provider = KubernetesProvider()\n143:                     provider._apps_api = mock_apps_api\n144:                     \n145:                     result = provider._create_deployment(\n146:                         \"test-agent\",\n147:                         \"registry.example.com/test:v1.0.0\",\n148:                         8080,\n149:                         None,\n150:                         1,\n151:                         {\"KEY\": \"value\"},\n152:                     )\n153:                     \n154:                     mock_apps_api.create_namespaced_deployment.assert_called_once()\n155:                     call_body = mock_apps_api.create_namespaced_deployment.call_args.kwargs[\"body\"]\n156:                     env_list = call_body[\"spec\"][\"template\"][\"spec\"][\"containers\"][0][\"env\"]\n157:                     assert {\"name\": \"KEY\", \"value\": \"value\"} in env_list\n158: \n159:     def test_create_deployment_with_entrypoint(self) -> None:\n160:         with patch(\"kubernetes.config.load_kube_config\"):\n161:             mock_apps_api = MagicMock()\n162:             mock_apps_api.create_namespaced_deployment.return_value = MagicMock()\n163:             \n164:             with patch(\"kubernetes.client.AppsV1Api\", return_value=mock_apps_api):\n165:                 with patch(\"kubernetes.client.CoreV1Api\"):\n166:                     provider = KubernetesProvider()\n167:                     provider._apps_api = mock_apps_api\n168:                     \n169:                     result = provider._create_deployment(\n170:                         \"test-agent\",\n171:                         \"registry.example.com/test:v1.0.0\",\n172:                         8080,\n173:                         \"python main.py\",\n174:                         1,\n175:                         None,\n176:                     )\n177:                     \n178:                     mock_apps_api.create_namespaced_deployment.assert_called_once()\n179:                     call_body = mock_apps_api.create_namespaced_deployment.call_args.kwargs[\"body\"]\n180:                     command = call_body[\"spec\"][\"template\"][\"spec\"][\"containers\"][0][\"command\"]\n181:                     assert command == [\"python\", \"main.py\"]\n182: \n183: \n184: class TestCreateService:\n185:     def test_create_service_basic(self) -> None:\n186:         with patch(\"kubernetes.config.load_kube_config\"):\n187:             mock_core_api = MagicMock()\n188:             mock_service = MagicMock()\n189:             mock_service.spec.ports = [MagicMock(node_port=30001)]\n190:             mock_core_api.create_namespaced_service.return_value = mock_service\n191:             \n192:             with patch(\"kubernetes.client.AppsV1Api\"):\n193:                 with patch(\"kubernetes.client.CoreV1Api\", return_value=mock_core_api):\n194:                     provider = KubernetesProvider()\n195:                     provider._core_api = mock_core_api\n196:                     \n197:                     result = provider._create_service(\"test-agent\", 8080, None)\n198:                     \n199:                     assert result[\"name\"] == \"test-agent\"\n200:                     assert result[\"node_port\"] == 30001\n201: \n202:     def test_create_service_with_node_port(self) -> None:\n203:         with patch(\"kubernetes.config.load_kube_config\"):\n204:             mock_core_api = MagicMock()\n205:             mock_service = MagicMock()\n206:             mock_service.spec.ports = [MagicMock(node_port=30050)]\n207:             mock_core_api.create_namespaced_service.return_value = mock_service\n208:             \n209:             with patch(\"kubernetes.client.AppsV1Api\"):\n210:                 with patch(\"kubernetes.client.CoreV1Api\", return_value=mock_core_api):\n211:                     provider = KubernetesProvider()\n212:                     provider._core_api = mock_core_api\n213:                     \n214:                     result = provider._create_service(\"test-agent\", 8080, 30050)\n215:                     \n216:                     mock_core_api.create_namespaced_service.assert_called_once()\n217:                     call_body = mock_core_api.create_namespaced_service.call_args.kwargs[\"body\"]\n218:                     assert call_body[\"spec\"][\"ports\"][0][\"nodePort\"] == 30050\n219: \n220:     def test_create_service_patch_if_exists(self) -> None:\n221:         with patch(\"kubernetes.config.load_kube_config\"):\n222:             mock_core_api = MagicMock()\n223:             mock_error = MagicMock()\n224:             mock_error.status = 409\n225:             \n226:             mock_service = MagicMock()\n227:             mock_service.spec.ports = [MagicMock(node_port=30001)]\n228:             \n229:             mock_core_api.create_namespaced_service.side_effect = mock_error\n230:             mock_core_api.patch_namespaced_service.return_value = mock_service\n231:             \n232:             with patch(\"kubernetes.client.AppsV1Api\"):\n233:                 with patch(\"kubernetes.client.CoreV1Api\", return_value=mock_core_api):\n234:                     provider = KubernetesProvider()\n235:                     provider._core_api = mock_core_api\n236:                     \n237:                     result = provider._create_service(\"test-agent\", 8080, None)\n238:                     \n239:                     assert result[\"node_port\"] == 30001\n240:                     mock_core_api.patch_namespaced_service.assert_called_once()\n241: \n242: \n243: class TestWaitForDeploymentReady:\n244:     def test_wait_for_deployment_ready_success(self) -> None:\n245:         with patch(\"kubernetes.config.load_kube_config\"):\n246:             mock_apps_api = MagicMock()\n247:             mock_deployment = MagicMock()\n248:             mock_deployment.spec.replicas = 1\n249:             mock_deployment.status.available_replicas = 1\n250:             mock_apps_api.read_namespaced_deployment.return_value = mock_deployment\n251:             \n252:             with patch(\"kubernetes.client.AppsV1Api\", return_value=mock_apps_api):\n253:                 with patch(\"kubernetes.client.CoreV1Api\"):\n254:                     provider = KubernetesProvider()\n255:                     provider._apps_api = mock_apps_api\n256:                     \n257:                     provider.wait_for_deployment_ready(\"test-agent\", timeout=10)\n258:                     \n259:                     mock_apps_api.read_namespaced_deployment.assert_called()\n260: \n261:     def test_wait_for_deployment_ready_timeout(self) -> None:\n262:         with patch(\"kubernetes.config.load_kube_config\"):\n263:             mock_apps_api = MagicMock()\n264:             mock_deployment = MagicMock()\n265:             mock_deployment.spec.replicas = 1\n266:             mock_deployment.status.available_replicas = 0\n267:             mock_apps_api.read_namespaced_deployment.return_value = mock_deployment\n268:             \n269:             with patch(\"kubernetes.client.AppsV1Api\", return_value=mock_apps_api):\n270:                 with patch(\"kubernetes.client.CoreV1Api\"):\n271:                     provider = KubernetesProvider()\n272:                     provider._apps_api = mock_apps_api\n273:                     provider.POLL_INTERVAL = 0.1\n274:                     \n275:                     with pytest.raises(TimeoutError, match=\"not ready after\"):\n276:                         provider.wait_for_deployment_ready(\"test-agent\", timeout=1)\n277: \n278: \n279: class TestDeployAgent:\n280:     def test_deploy_agent_success(self) -> None:\n281:         with patch(\"kubernetes.config.load_kube_config\"):\n282:             mock_apps_api = MagicMock()\n283:             mock_core_api = MagicMock()\n284:             \n285:             mock_deployment = MagicMock()\n286:             mock_deployment.spec.replicas = 1\n287:             mock_deployment.status.available_replicas = 1\n288:             mock_apps_api.create_namespaced_deployment.return_value = MagicMock()\n289:             mock_apps_api.read_namespaced_deployment.return_value = mock_deployment\n290:             \n291:             mock_service = MagicMock()\n292:             mock_service.spec.ports = [MagicMock(node_port=30001)]\n293:             mock_core_api.create_namespaced_service.return_value = mock_service\n294:             mock_core_api.read_namespace.return_value = MagicMock()\n295:             \n296:             with patch(\"kubernetes.client.AppsV1Api\", return_value=mock_apps_api):\n297:                 with patch(\"kubernetes.client.CoreV1Api\", return_value=mock_core_api):\n298:                     provider = KubernetesProvider()\n299:                     provider._apps_api = mock_apps_api\n300:                     provider._core_api = mock_core_api\n301:                     \n302:                     result = provider.deploy_agent(\n303:                         agent_name=\"test-agent\",\n304:                         image_url=\"registry.example.com/test:v1.0.0\",\n305:                         port=8080,\n306:                     )\n307:                     \n308:                     assert result[\"deployment_name\"] == \"test-agent\"\n309:                     assert result[\"node_port\"] == 30001\n310:                     assert result[\"service_url\"] == \"http://localhost:30001\"\n311: \n312: \n313: class TestGetAgentStatus:\n314:     def test_get_agent_status_success(self) -> None:\n315:         with patch(\"kubernetes.config.load_kube_config\"):\n316:             mock_apps_api = MagicMock()\n317:             mock_core_api = MagicMock()\n318:             \n319:             mock_deployment = MagicMock()\n320:             mock_deployment.spec.replicas = 2\n321:             mock_deployment.status.available_replicas = 2\n322:             mock_deployment.status.ready_replicas = 2\n323:             mock_apps_api.read_namespaced_deployment.return_value = mock_deployment\n324:             \n325:             mock_service = MagicMock()\n326:             mock_service.spec.ports = [MagicMock(node_port=30001)]\n327:             mock_core_api.read_namespaced_service.return_value = mock_service\n328:             \n329:             with patch(\"kubernetes.client.AppsV1Api\", return_value=mock_apps_api):\n330:                 with patch(\"kubernetes.client.CoreV1Api\", return_value=mock_core_api):\n331:                     provider = KubernetesProvider()\n332:                     provider._apps_api = mock_apps_api\n333:                     provider._core_api = mock_core_api\n334:                     \n335:                     result = provider.get_agent_status(\"test-agent\")\n336:                     \n337:                     assert result[\"deployment\"][\"replicas\"] == 2\n338:                     assert result[\"service\"][\"node_port\"] == 30001\n339: \n340: \n341: class TestDeleteAgent:\n342:     def test_delete_agent_success(self) -> None:\n343:         with patch(\"kubernetes.config.load_kube_config\"):\n344:             mock_apps_api = MagicMock()\n345:             mock_core_api = MagicMock()\n346:             \n347:             mock_apps_api.delete_namespaced_deployment.return_value = MagicMock()\n348:             mock_core_api.delete_namespaced_service.return_value = MagicMock()\n349:             \n350:             with patch(\"kubernetes.client.AppsV1Api\", return_value=mock_apps_api):\n351:                 with patch(\"kubernetes.client.CoreV1Api\", return_value=mock_core_api):\n352:                     provider = KubernetesProvider()\n353:                     provider._apps_api = mock_apps_api\n354:                     provider._core_api = mock_core_api\n355:                     \n356:                     result = provider.delete_agent(\"test-agent\")\n357:                     \n358:                     assert result[\"deployment_deleted\"] == True\n359:                     assert result[\"service_deleted\"] == True\n360: \n361: \n362: class TestNodePortValidation:\n363:     def test_node_port_min_boundary(self) -> None:\n364:         assert KubernetesProvider.NODE_PORT_MIN == 30000\n365: \n366:     def test_node_port_max_boundary(self) -> None:\n367:         assert KubernetesProvider.NODE_PORT_MAX == 32767\n368: \n369:     def test_default_timeout(self) -> None:\n370:         assert KubernetesProvider.DEFAULT_TIMEOUT == 120\n371: \n372:     def test_poll_interval(self) -> None:\n373:         assert KubernetesProvider.POLL_INTERVAL == 2\n\n(End of file - total 373 lines)\n</content>","metadata":{"preview":"import pytest\nfrom unittest.mock import MagicMock, patch\nimport time\n\nfrom agentcube.services.k8s_provider import KubernetesProvider\n\n\nclass TestKubernetesProviderInit:\n    def test_init_default_namespace(self) -> None:\n        with patch(\"kubernetes.config.load_kube_config\"):\n            with patch(\"kubernetes.client.AppsV1Api\"):\n                with patch(\"kubernetes.client.CoreV1Api\"):\n                    provider = KubernetesProvider()\n                    assert provider.namespace == \"default\"\n\n    def test_init_custom_namespace(self) -> None:\n        with patch(\"kubernetes.config.load_kube_config\"):\n            with patch(\"kubernetes.client.AppsV1Api\"):\n                with patch(\"kubernetes.client.CoreV1Api\"):\n                    provider = KubernetesProvider(namespace=\"custom-ns\")","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/cmd/cli/tests/test_k8s_provider.py","time":{"start":1775878296587,"end":1775878296602}}}}
