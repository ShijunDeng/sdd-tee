rbose == True\n29: \n30: \n31: class TestSanitizeName:\n32:     def test_sanitize_name_lowercase(self) -> None:\n33:         with patch(\"kubernetes.config.load_kube_config\"):\n34:             with patch(\"kubernetes.client.AppsV1Api\"):\n35:                 with patch(\"kubernetes.client.CoreV1Api\"):\n36:                     provider = KubernetesProvider()\n37:                     result = provider._sanitize_name(\"TestAgent\")\n38:                     assert result == \"testagent\"\n39: \n40:     def test_sanitize_name_replace_non_alphanumeric(self) -> None:\n41:         with patch(\"kubernetes.config.load_kube_config\"):\n42:             with patch(\"kubernetes.client.AppsV1Api\"):\n43:                 with patch(\"kubernetes.client.CoreV1Api\"):\n44:                     provider = KubernetesProvider()\n45:                     result = provider._sanitize_name(\"test-agent_123\")\n46:                     assert result == \"test-agent-123\"\n47: \n48:     def test_sanitize_name_truncate_to_63_chars(self) -> None:\n49:         with patch(\"kubernetes.config.load_kube_config\"):\n50:             with patch(\"kubernetes.client.AppsV1Api\"):\n51:                 with patch(\"kubernetes.client.CoreV1Api\"):\n52:                     provider = KubernetesProvider()\n53:                     long_name = \"a\" * 100\n54:                     result = provider._sanitize_name(long_name)\n55:                     assert len(result) == 63\n56: \n57:     def test_sanitize_name_strip_dashes(self) -> None:\n58:         with patch(\"kubernetes.config.load_kube_config\"):\n59:             with patch(\"kubernetes.client.AppsV1Api\"):\n60:                 with patch(\"kubernetes.client.CoreV1Api\"):\n61:                     provider = KubernetesProvider()\n62:                     result = provider._sanitize_name(\"---test---agent---\")\n63:                     assert result == \"test-agent\"\n64: \n65:     def test_sanitize_name_empty_string(self) -> None:\n66:         with patch(\"kub