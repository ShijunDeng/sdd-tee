Recorder()\n39: \n40: \tHandleError(w, req, err)\n41: \n42: \tresp := w.Result()\n43: \tif resp.StatusCode != http.StatusNotFound {\n44: \t\tt.Errorf(\"expected status %d, got %d\", http.StatusNotFound, resp.StatusCode)\n45: \t}\n46: \n47: \tvar body ErrorResponse\n48: \tif decodeErr := json.NewDecoder(resp.Body).Decode(&body); decodeErr != nil {\n49: \t\tt.Fatalf(\"failed to decode response: %v\", decodeErr)\n50: \t}\n51: \tif body.Code != \"NOT_FOUND\" {\n52: \t\tt.Errorf(\"expected code %s, got %s\", \"NOT_FOUND\", body.Code)\n53: \t}\n54: }\n55: \n56: func TestHandleError_InternalError(t *testing.T) {\n57: \terr := &InternalError{Err: errors.New(\"database connection failed\")}\n58: \treq := httptest.NewRequest(\"GET\", \"/test\", nil)\n59: \tw := httptest.NewRecorder()\n60: \n61: \tHandleError(w, req, err)\n62: \n63: \tresp := w.Result()\n64: \tif resp.StatusCode != http.StatusInternalServerError {\n65: \t\tt.Errorf(\"expected status %d, got %d\", http.StatusInternalServerError, resp.StatusCode)\n66: \t}\n67: \n68: \tvar body ErrorResponse\n69: \tif decodeErr := json.NewDecoder(resp.Body).Decode(&body); decodeErr != nil {\n70: \t\tt.Fatalf(\"failed to decode response: %v\", decodeErr)\n71: \t}\n72: \tif body.Code != \"INTERNAL_ERROR\" {\n73: \t\tt.Errorf(\"expected code %s, got %s\", \"INTERNAL_ERROR\", body.Code)\n74: \t}\n75: \tif body.Message != \"Unexpected server error\" {\n76: \t\tt.Errorf(\"expected message %s, got %s\", \"Unexpected server error\", body.Message)\n77: \t}\n78: }\n79: \n80: func TestHandleError_ServiceUnavailableError(t *testing.T) {\n81: \terr := &ServiceUnavailableError{Dependency: \"kubernetes-api\"}\n82: \treq := httptest.NewRequest(\"GET\", \"/test\", nil)\n83: \tw := httptest.NewRecorder()\n84: \n85: \tHandleError(w, req, err)\n86: \n87: \tresp := w.Result()\n88: \tif resp.StatusCode != http.StatusServiceUnavailable {\n89: \t\tt.Errorf(\"expected status %d, got %d\", http.StatusServiceUnavailable, resp.StatusCode)\n90: \t}\n91: \n92: \tvar body ErrorResponse\n93: \tif decodeErr := json.NewDecoder(resp.Body).Decode(&body); decodeErr != nil {\n94: \t\tt.Fatalf(\"failed to decode response: %v\", decodeErr)\n95: \t}\n96: \tif body.Code != \"SERVICE_UNAVAILABLE\" {\n97: \t\tt.Errorf(\"expected code %s, got %s\", \"SERVICE_UNAVAILABLE\", body.Code)\n98: \t}\n99: }\n100: \n101: func TestHandleError_UnknownError(t *testing.T) {\n102: \terr := errors.New(\"unknown error type\")\n103: \treq := httptest.NewRequest(\"GET\", \"/test\", nil)\n104: \tw := httptest.NewRecorder()\n105: \n106: \tHandleError(w, req, err)\n107: \n108: \tresp := w.Result()\n109: \tif resp.StatusCode != http.StatusInternalServerError {\n110: \t\tt.Errorf(\"expected status %d, got %d\", http.StatusInternalServerError, resp.StatusCode)\n111: \t}\n112: \n113: \tvar body ErrorResponse\n114: \tif decodeErr := json.NewDecoder(resp.Body).Decode(&body); decodeErr != nil {\n115: \t\tt.Fatalf(\"failed to decode response: %v\", decodeErr)\n116: \t}\n117: \tif body.Code != \"INTERNAL_ERROR\" {\n118: \t\tt.Errorf(\"expected code %s, got %s\", \"INTERNAL_ERROR\", body.Code)\n119: \t}\n120: }\n121: \n122: func TestHandleError_ContentType(t *testing.T) {\n123: \terr := &ValidationError{Field: \"test\", Reason: \"test\"}\n124: \treq := httptest.NewRequest(\"GET\", \"/test\", nil)\n125: \tw := httptest.NewRecorder()\n126: \n127: \tHandleError(w, req, err)\n128: \n129: \tresp := w.Result()\n130: \tct := resp.Header.Get(\"Content-Type\")\n131: \tif ct != \"application/json\" {\n132: \t\tt.Errorf(\"expected Content-Type %s, got %s\", \"application/json\", ct)\n133: \t}\n134: }\n135: \n136: func TestErrorTypes_ValidationError(t *testing.T) {\n137: \terr := &ValidationError{Field: \"name\", Reason: \"required\"}\n138: \texpected := \"validation error: name - required\"\n139: \tif err.Error() != expected {\n140: \t\tt.Errorf(\"expected %s, got %s\", expected, err.Error())\n141: \t}\n142: }\n143: \n144: func TestErrorTypes_NotFoundError(t *testing.T) {\n14