ation/json\")\n41: \tif h.checker == nil || !h.checker.IsReady() {\n42: \t\tw.WriteHeader(http.StatusServiceUnavailable)\n43: \t\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"not ready\"})\n44: \t\treturn\n45: \t}\n46: \tw.WriteHeader(http.StatusOK)\n47: \tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ready\"})\n48: }\n\n(End of file - total 48 lines)\n</content>","metadata":{"preview":"package handlers\n\nimport (\n\t\"encoding/json\"\n\t\"net/http\"\n\n\t\"github.com/go-chi/chi/v5\"\n)\n\n// HealthChecker defines the interface for health and readiness checks.\ntype HealthChecker interface {\n\tIsHealthy() bool\n\tIsReady() bool\n}\n\n// HealthHandler provides /healthz and /readyz endpoints for Kubernetes probes.\ntype HealthHandler struct {\n\tchecker HealthChecker\n}\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/handlers/health.go","time":{"start":1775895430332,"end":1775895430354}}}}
{"type":"tool_use","timestamp":1775895430356,"sessionID":"ses_28462dd76ffeppBFMumWErnXKU","part":{"id":"prt_d7b9dbce3001EpXPOZe4Vs8qiL","messageID":"msg_d7b9da2a8001Bjwxt6UeFeD9Wo","sessionID":"ses_28462dd76ffeppBFMumWErnXKU","type":"tool","tool":"read","callID":"toolu_tool-6ad40d48ff1d45d2af4b9051026f2f6a","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/middleware/cors.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/middleware/cors.go</path>\n<type>file</type>\n<content>\n1: package middleware\n2: \n3: import (\n4: \t\"net/http\"\n5: \t\"strings\"\n6: )\n7: \n8: // CORSConfig defines the CORS policy configuration.\n9: type CORSConfig struct {\n10: \tAllowedOrigins   []string\n11: \tAllowedMethods   []string\n12: \tAllowedHeaders   []string\n13: \tAllowCredentials bool\n14: }\n15: \n16: // CORSMiddleware handles Cross-Origin Resource Sharing headers.\n17: type CORSMiddleware struct {\n18: \tconfig CORSConfig\n19: }\n20: \n21: // NewCORSMiddleware creates a CORSMiddleware with the given configuration.\n22: func NewCORSMiddleware(config CORSConfig) *CORSMiddleware {\n23: \treturn &CORSMiddleware{config: config}\n24: }\n25: \n26: // Wrap returns an http.Handler that adds CORS headers to responses.\n27: func (m *CORSMiddleware) Wrap(next http.Handler) http.Handler {\n28: \treturn http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n29: \t\torigin := r.Header.Get(\"Origin\")\n30: \t\tif origin != \"\" && m.isAllowedOrigin(origin) {\n31: \t\t\tw.Header().Set(\"Access-Control-Allow-Origin\", origin)\n32: \t\t\tw.Header().Set(\"Access-Control-Allow-Methods\", strings.Join(m.config.AllowedMethods, \",\"))\n33: \t\t\tw.Header().Set(\"Access-Control-Allow-Headers\", strings.Join(m.config.AllowedHeaders, \",\"))\n34: \t\t\tif m.config.AllowCredentials {\n35: \t\t\t\tw.Header().Set(\"Access-Control-Allow-Credentials\", \"true\")\n36: \t\t\t}\n37: \t\t}\n38: \n39: \t\tif r.Method == \"OPTIONS\" {\n40: \t\t\tw.WriteHeader(http.StatusOK)\n41: \t\t\treturn\n42: \t\t}\n43: \n44: \t\tnext.ServeHTTP(w, r)\n45: \t})\n46: }\n47: \n48: func (m *CORSMiddleware) isAllowedOrigin(origin string) bool {\n49: \tfor _, o := range m.config.AllowedOrigins {\n50: \t\tif o == \"*\" || o == origin {\n51: \t\t\treturn true\n52: \t\t}\n53: \t}\n54: \treturn false\n55: }\n\n(End of file - total 55 lines)\n</content>","metadata":{"preview":"package middleware\n\nimport (\n\t\"net/http\"\n\t\"strings\"\n)\n\n// CORSConfig defines the CORS policy configuration.\ntype CORSConfig struct {\n\tAllowedOrigins   []string\n\tAllowedMethods   []string\n\tAllowedHeaders   []string\n\tAllowCredentials bool\n}\n\n// CORSMiddleware handles Cross-Origin Resource Sharing headers.\ntype CORSMiddleware struct {\n\tconfig CORSConfig\n}\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/middleware/cors.go","time":{"start":1775895430336,"end":1775895430356}}}}
{"type":"tool_use","timestamp":1775895430358,"sessionID":"ses_28462dd76ffeppBFMumWErnXKU","part":{"id":"prt_d7b9db8ef001ucrsmF2HIHmdRM","messageID":"msg_d7b9da2a8001Bjwxt6UeFeD9Wo","sessionID":"ses_28462dd76ffeppBFMumWErnXKU","type":"tool","tool":"read","callID":"toolu_tool-c93c80def95e46919e3fc210a3e66ca6","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/handlers/sandbox_delete.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/handlers/sandbox_delete.go</path>\n<type>file</type>\n<content>\n1: package handlers\n2: \n3: import (\n4: \t\"encoding/json\"\n5: \t\"net/http\"\n6: \n7: \t\"github.com/go-chi/chi/v5\"\n8: \t\"github.com/volcano-sh/agentcube/pkg/workloadmanager\"\n9: )\n10: \n11: type DeleteSandboxRequest struct {\n12: \tSessionID          string `json:\"sessionId\"`\n13: \tKind               string `json:\"kind\"`\n14: \tForce              bool   `json:\"force,omitempty\"`\n15: \tGracePeriodSeconds int64  `json:\"gracePeriodSeconds,omitempty\"`\n16: }\n17: \n18: type DeleteSandboxResponse struct {\n19: \tSessionID string `json:\"sessionId\"`\n20: \tStatus    string `json:\"status\"`\n21: \tMessage   string `json:\"message,omitempty\"`\n22: }\n23: \n24: type DeletionHandler struct {\n25: \tmanager *workloadmanager.SandboxLifecycleManager\n26: \tlogger  workloadmanager.Logger\n27: }\n28: \n29: func NewDeletionHandler(manager *workloadmanager.SandboxLifecycleManager, logger workloadmanager.Logger) *DeletionHandler {\n30: \treturn &DeletionHandler{\n31: \t\tmanager: manager,\n32: \t\tlogger:  logger,\n33: \t}\n34: }\n35: \n36: func (h *DeletionHandler) Register(r chi.Router) {\n37: \tr.Delete(\"/v1/agent-runtime/sessions/{sessionId}\", h.handleDeleteAgentRuntimeSandbox)\n38: \tr.Delete(\"/v1/code-interpreter/sessions/{sessionId}\", h.handleDeleteCodeInterpreterSandbox)\n39: }\n40: \n41: func (h *DeletionHandler) handleDeleteAgentRuntimeSandbox(w http.ResponseWriter, r *http.Request) {\n42: \tsessionID := chi.URLParam(r, \"sessionId\")\n43: \th.handleDeleteSandbox(w, r, sessionID, workloadmanager.AgentRuntimeKind)\n44: }\n45: \n46: func (h *DeletionHandler) handleDeleteCodeInterpreterSandbox(w http.ResponseWriter, r *http.Request) {\n47: \tsessionID := chi.URLParam(r, \"sessionId\")\n48: \th.handleDeleteSandbox(w, r, sessionID, workloadmanager.CodeInterpreterKind)\n49: }\n50: \n51: func (h *DeletionHandler) handleDeleteSandbox(w http.ResponseWriter, r *http.Request, sessionID string, kind string) {\n52: \tif sessionID == \"\" {\n53: \t\tworkloadmanager.HandleError(w, r, &workloadmanager.ValidationError{\n54: \t\t\tField:  \"sessionId\",\n55: \t\t\tReason: \"required\",\n56: \t\t})\n57: \t\treturn\n58: \t}\n59: \n60: \terr := h.manager.DeleteSandbox(r.Context(), sessionID)\n61: \tif err != nil {\n62: \t\th.handleDeleteError(w, r, err, sessionID)\n63: \t\treturn\n64: \t}\n65: \n66: \th.writeSuccessResponse(w, sessionID)\n67: }\n68: \n69: func (h *DeletionHandler) handleDeleteError(w http.ResponseWriter, r *http.Request, err error, sessionID string) {\n70: \tswitch e := err.(type) {\n71: \tcase *workloadmanager.NotFoundError:\n72: \t\tw.Header().Set(\"Content-Type\", \"application/json\")\n73: \t\tw.WriteHeader(http.StatusNotFound)\n74: \t\tjson.NewEncoder(w).Encode(&DeleteSandboxResponse{\n75: \t\t\tSessionID: sessionID,\n76: \t\t\tStatus:    \"not_found\",\n77: \t\t\tMessage:   e.Error(),\n78: \t\t})\n79: \tcase *workloadmanager.InternalError:\n80: \t\th.logger.Error(\"internal error during deletion\", \"sessionID\", sessionID, \"err\", e.Err)\n81: \t\tw.Header().Set(\"Content-Type\", \"application/json\")\n82: \t\tw.WriteHeader(http.StatusInternalServerError)\n83: \t\tjson.NewEncoder(w).Encode(&workloadmanager.ErrorResponse{\n84: \t\t\tCode:    \"INTERNAL_ERROR\",\n85: \t\t\tMessage: \"Failed to delete sandbox\",\n86: \t\t})\n87: \tcase *workloadmanager.ServiceUnavailableError:\n88: \t\th.logger.Error(\"service unavailable during deletion\", \"sessionID\", sessionID, \"dependency\", e.Dependency)\n89: \t\tw.Header().Set(\"Content-Type\", \"application/json\")\n90: \t\tw.WriteHeader(http.StatusServiceUnavailable)\n91: \t\tjson.NewEncoder(w).Encode(&workloadmanager.ErrorResponse{\n92: \t\t\tCode:    \"SERVICE_UNAVAILABLE\",\n93: \t\t\tMessage: e.Error(),\n94: \t\t})\n95: \tdefault:\n96: \t\th.logger.Error(\"unknown error during deletion\", \"sessionID\", sessionID, \"err\", err)\n97: \t\tw.Header().Set(\"Content-Type\", \"application/json\")\n98: \t\tw.WriteHeader(http.StatusInternalServerError)\n99: \t\tjson.NewEncoder(w).Encode(&workloadmanager.ErrorResponse{\n100: \t\t\tCode:    \"INTERNAL_ERROR\",\n101: \t\t\tMessage: \"Unexpected error during deletion\",\n102: \t\t})\n103: \t}\n104: }\n105: \n106: func (h *DeletionHandler) writeSuccessResponse(w http.ResponseWriter, sessionID string) {\n107: \tw.Header().Set(\"Content-Type\", \"application/json\")\n108: \tw.WriteHeader(http.StatusOK)\n109: \tjson.NewEncoder(w).Encode(&DeleteSandboxResponse{\n110: \t\tSessionID: sessionID,\n111: \t\tStatus:    \"deleted\",\n112: \t})\n113: }\n\n(End of file - total 113 lines)\n</content>","metadata":{"preview":"package handlers\n\nimport (\n\t\"encoding/json\"\n\t\"net/http\"\n\n\t\"github.com/go-chi/chi/v5\"\n\t\"github.com/volcano-sh/agentcube/pkg/workloadmanager\"\n)\n\ntype DeleteSandboxRequest struct {\n\tSessionID          string `json:\"sessionId\"`\n\tKind               string `json:\"kind\"`\n\tForce              bool   `json:\"force,omitempty\"`\n\tGracePeriodSeconds int64  `json:\"gracePeriodSeconds,omitempty\"`\n}\n\ntype DeleteSandboxResponse struct {\n\tSessionID string `json:\"sessionId\"`\n\tStatus    string `json:\"status\"`","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/handlers/sandbox_delete.go","time