er()\n52: \th.Register(router)\n53: \n54: \treq := httptest.NewRequest(\"GET\", \"/readyz\", nil)\n55: \tw := httptest.NewRecorder()\n56: \n57: \trouter.ServeHTTP(w, req)\n58: \n59: \tif w.Code != http.StatusOK {\n60: \t\tt.Errorf(\"expected status %d, got %d\", http.StatusOK, w.Code)\n61: \t}\n62: \n63: \tvar body map[string]string\n64: \tif err := json.NewDecoder(w.Body).Decode(&body); err != nil {\n65: \t\tt.Fatalf(\"failed to decode response: %v\", err)\n66: \t}\n67: \tif body[\"status\"] != \"ready\" {\n68: \t\tt.Errorf(\"expected status %s, got %s\", \"ready\", body[\"status\"])\n69: \t}\n70: }\n71: \n72: func TestReadyz_NotReady(t *testing.T) {\n73: \tchecker := &mockHealthChecker{ready: false}\n74: \th := NewHealthHandler(checker)\n75: \trouter := chi.NewRouter()\n76: \th.Register(router)\n77: \n78: \treq := httptest.NewRequest(\"GET\", \"/readyz\", nil)\n79: \tw := httptest.NewRecorder()\n80: \n81: \trouter.ServeHTTP(w, req)\n82: \n83: \tif w.Code != http.StatusServiceUnavailable {\n84: \t\tt.Errorf(\"expected status %d, got %d\", http.StatusServiceUnavailable, w.Code)\n85: \t}\n86: \n87: \tvar body map[string]string\n88: \tif err := json.NewDecoder(w.Body).Decode(&body); err != nil {\n89: \t\tt.Fatalf(\"failed to decode response: %v\", err)\n90: \t}\n91: \tif body[\"status\"] != \"not ready\" {\n92: \t\tt.Errorf(\"expected status %s, got %s\", \"not ready\", body[\"status\"])\n93: \t}\n94: }\n95: \n96: func TestReadyz_NoChecker(t *testing.T) {\n97: \th := NewHealthHandler(nil)\n98: \trouter := chi.NewRouter()\n99: \th.Register(router)\n100: \n101: \treq := httptest.NewRequest(\"GET\", \"/readyz\", nil)\n102: \tw := httptest.NewRecorder()\n103: \n104: \trouter.ServeHTTP(w, req)\n105: \n106: \tif w.Code != http.StatusServiceUnavailable {\n107: \t\tt.Errorf(\"expected status %d, got %d\", http.StatusServiceUnavailable, w.Code)\n108: \t}\n109: \n110: \tvar body map[string]string\n111: \tif err := json.NewDecoder(w.Body).Decode(&body); err != nil {\n112: \t\tt.Fatalf(\"failed to decode response: %v\", err)\n113: \t}\n114: \tif body[\"status\"] != \"not ready\" {\n115: \t\tt.Errorf(\"expected status %s, got %s\", \"not ready\", body[\"status\"])\n116: \t}\n117: }\n118: \n119: func TestHealthz_ContentType(t *testing.T) {\n120: \th := NewHealthHandler(nil)\n121: \trouter := chi.NewRouter()\n122: \th.Register(router)\n123: \n124: \treq := httptest.NewRequest(\"GET\", \"/healthz\", nil)\n125: \tw := httptest.NewRecorder()\n126: \n127: \trouter.ServeHTTP(w, req)\n128: \n129: \tct := w.Header().Get(\"Content-Type\")\n130: \tif ct != \"application/json\" {\n131: \t\tt.Errorf(\"expected Content-Type %s, got %s\", \"application/json\", ct)\n132: \t}\n133: }\n134: \n135: func TestReadyz_ContentType(t *testing.T) {\n136: \tchecker := &mockHealthChecker{ready: true}\n137: \th := NewHealthHandler(checker)\n138: \trouter := chi.NewRouter()\n139: \th.Register(router)\n140: \n141: \treq := httptest.NewRequest(\"GET\", \"/readyz\", nil)\n142: \tw := httptest.NewRecorder()\n143: \n144: \trouter.ServeHTTP(w, req)\n145: \n146: \tct := w.Header().Get(\"Content-Type\")\n147: \tif ct != \"application/json\" {\n148: \t\tt.Errorf(\"expected Content-Type %s, got %s\", \"application/json\", ct)\n149: \t}\n150: }\n\n(End of file - total 150 lines)\n</content>","metadata":{"preview":"package handlers\n\nimport (\n\t\"encoding/json\"\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"testing\"\n\n\t\"github.com/go-chi/chi/v5\"\n)\n\ntype mockHealthChecker struct {\n\thealthy bool\n\tready   bool\n}\n\nfunc (m *mockHealthChecker) IsHealthy() bool {\n\treturn m.healthy\n}\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/handlers/health_test.go","time":{"start":1775895451219,"end":1775895451239}}}}
{"type":"tool_use","timestamp":1775895451243,"sessionID":"ses_28462dd76ffeppBFMumWErnXKU","part":{"id":"prt_d7b9e1215001TluYjhw6Onq9kZ","messageID":"msg_d7b9df2fd0010jyqYi3nDOx2Im","sessionID":"ses_28462dd76ffeppBFMumWErnXKU","type":"tool","tool":"read","callID":"toolu_tool-e4b55cc3798a4367a7974bc8df65ca4b","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/middleware/cors_test.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/middleware/cors_test.go</path>\n<type>file</type>\n<content>\n1: package middleware\n2: \n3: import (\n4: \t\"net/http\"\n5: \t\"net/http/httptest\"\n6: \t\"testing\"\n7: )\n8: \n9: func TestCORSMiddleware_Wrap_AllowedOrigin(t *testing.T) {\n10: \tconfig := CORSConfig{\n11: \t\tAllowedOrigins:   []string{\"http://example.com\", \"http://localhost\"},\n12: \t\tAllowedMethods:   []string{\"GET\", \"POST\"},\n13: \t\tAllowedHeaders:   []string{\"Content-Type\"},\n14: \t\tAllowCredentials: true,\n15: \t}\n16: \tm := NewCORSMiddleware(config)\n17: \n18: \thandler := http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n19: \t\tw.WriteHeader(http.StatusOK)\n20: \t})\n21: \n22: \treq := httptest.NewRequest(\"GET\", \"/test\", nil)\n23: \treq.Header.Set(\"Origin\", \"http://example.com\")\n24: \tw := httptest.NewRecorder()\n25: \n26: \tm.Wrap(handler).ServeHTTP(w, req)\n27: \n28: \torigin := w.Header().Get(\"Access-Control-Allow-Origin\")\n29: \tif origin != \"http://example.com\" {\n30: \t\tt.Errorf(\"expected Allow-Origin %s, got %s\", \"http://example.com\", origin)\n31: \t}\n32: \tmethods := w.Header().Get(\"Access-Control-Allow-Methods\")\n33: \tif methods != \"GET,POST\" {\n34: \t\tt.Errorf(\"expected Allow-Methods %s, got %s\", \"GET,POST\", methods)\n35: \t}\n36: \tcreds := w.Header().Get(\"Access-Control-Allow-Credentials\")\n37: \tif creds != \"true\" {\n38: \t\tt.Errorf(\"expected Allow-Credentials %s, got %s\", \"true\", creds)\n39: \t}\n40: }\n41: \n42: func TestCORSMiddleware_Wrap_DisallowedOrigin(t *testing.T) {\n43: \tconfig := CORSConfig{\n44: \t\tAllowedOrigins: []string{\"http://example.com\"},\n45: \t\tAllowedMethods: []string{\"GET\"},\n46: \t\tAllowedHeaders: []string{\"Content-Type\"},\n47: \t}\n48: \tm := NewCORSMiddleware(config)\n49: \n50: \thandler := http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n51: \t\tw.WriteHeader(http.StatusOK)\n52: \t})\n53: \n54: \treq := httptest.NewRequest(\"GET\", \"/test\", nil)\n55: \treq.Header.Set(\"Origin\", \"http://evil.com\")\n56: \tw := httptest.NewRecorder()\n57: \n58: \tm.Wrap(handler).ServeHTTP(w, req)\n59: \n60: \torigin := w.Header().Get(\"Access-Control-Allow-Origin\")\n61: \tif origin != \"\" {\n62: \t\tt.Errorf(\"expected no Allow-Origin header, got %s\", origin)\n63: \t}\n64: }\n65: \n66: func TestCORSMiddleware_Wrap_OptionsPreflight(t *testing.T) {\n67: \tconfig := CORSConfig{\n68: \t\tAllowedOrigins:   []string{\"*\"},\n69: \t\tAllowedMethods:   []string{\"GET\", \"POST\", \"PUT\"},\n70: \t\tAllowedHeaders:   []string{\"Content-Type\", \"Authorization\"},\n71: \t\tAllowCredentials: false,\n72: \t}\n73: \tm := NewCORSMiddleware(config)\n74: \n75: \thandler := http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n76: \t\tw.WriteHeader(http.StatusOK)\n77: \t})\n78: \n79: \treq := httptest.NewRequest(\"OPTIONS\", \"/test\", nil)\n80: \treq.Header.Set(\"Origin\", \"http://example.com\")\n81: \tw := httptest.NewRecorder()\n82: \n83: \tm.Wrap(handler).ServeHTTP(w, req)\n84: \n85: \tif w.Code != http.StatusOK {\n86: \t\tt.Errorf(\"expected status %d, got %d\", http.StatusOK, w.Code)\n87: \t}\n88: }\n89: \n90: func TestCORSMiddleware_isAllowedOrigin_Wildcard(t *testing.T) {\n91: \tconfig := CORSConfig{\n92: \t\tAllowedOrigins: []string{\"*\"},\n93: \t}\n94: \tm := NewCORSMiddleware(config)\n95: \n96: \tif !m.isAllowedOrigin(\"http://any.com\") {\n97: \t\tt.Error(\"wildcard should allow any origin\")\n98: \t}\n99: }\n100: \n101: func TestCORSMiddleware_isAllowedOrigin_ExactMatch(t *testing.T) {\n102: \tconfig := CORSConfig{\n103: \t\tAllowedOrigins: []string{\"http://example.com\"},\n104: \t}\n105: \tm := NewCORSMiddleware(config)\n106: \n107: \tif !m.isAllowedOrigin(\"http://example.com\") {\n108: \t\tt.Error(\"exact match should be allowed\")\n109: \t}\n110: \tif m.isAllowedOrigin(\"http://other.com\") {\n111: \t\tt.Error(\"non-matching origin should not be allowed\")\n112: \t}\n113: }\n114: \n115: func TestCORSMiddleware_isAllowedOrigin_NoMatch(t *testing.T) {\n116: \tconfig := CORSConfig{\n117: \t\tAllowedOrigins: []string{\"http://example.com\", \"http://localhost\"},\n118: \t}\n119: \tm := NewCORSMiddleware(config)\n120: \n121: \tif m.isAllowedOrigin(\"http://evil.com\") {\n122: \t\tt.Error(\"non-matching origin should not be allowed\")\n123: \t}\n124: }\n125: \n126: func TestNewCORSMiddleware(t *testing.T) {\n127: \tconfig := CORSConfig{\n128: \t\tAllowedOrigins: []string{\"*\"},\n129: \t}\n130: \tm := NewCORSMiddleware(config)\n131: \n132: \tif m == nil {\n133: \t\tt.Fatal(\"NewCORSMiddleware returned nil\")\n134: \t}\n135: \tif m.config.AllowedOrigins[0] != \"*\" {\n136: \t\tt.Error(\"config not properly set\")\n137: \t}\n138: }\n139: \n140: func TestCORSMiddleware_NoOriginHeader(t *testing.T) {\n141: \tconfig := CORSConfig{\n142: \t\tAllowedOrigins: []string{\"*\"},\n143: \t}\n144: \tm := NewCORSMiddleware(config)\n145: \n146: \thandler := http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n147: \t\tw.WriteHeader(http.StatusOK)\n148: \t})\n149: \n150: \treq := httptest.NewRequest(\"GET\", \"/test\", nil)\n151: \tw := httptest.NewRecorder()\n152: \n153: \tm.Wrap(handler).ServeHTTP(w, req)\n154: \n155: \torigin := w.Header().Get(\"Access-Control-Allow-Origin\")\n156: \tif origin != \"\" {\n157: \t\tt.Errorf(\"expected no Allow-Origin without Origin header, got %s\", origin)\n158: \t}\n159: }\n160: \n161: func TestCORSConfig_AllFields(t *testing.T) {\n162: \tconfig := CORSConfig{\n163: \t\tAllowedOrigins:   []string{\"http://example.com\"},\n164: \t\tAllowedMethods:   []string{\"GET\", \"POST\"},\n165: \t\tAllowedHeaders:   []string{\"Content-Type\"},\n166: \t\tAllowCredentials: true,\n167: \t}\n168: \n169: \tif len(config.AllowedOrigins) != 1 {\n170: \t\tt.Errorf(\"expected 1 allowed origin, got %d\", len(config.AllowedOrigins))\n171: \t}\n172: \tif len(config.AllowedMethods) != 2 {\n173: \t\tt.Errorf(\"expected 2 allowed methods, got %d\", len(config.AllowedMethods))\n174: \t}\n175: \tif !config.AllowCredentials {\n176: \t\tt.Error(\"expected AllowCredentials to be true\")\n177: \t}\n178: }\n\n(End of file - total 178 lines)\n</content>","metadata":{"preview":"package middleware\n\nimport (\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"testing\"\n)\n\nfunc TestCORSMiddleware_Wrap_AllowedOrigin(t *testing.T) {\n\tconfig := CORSConfig{\n\t\tAllowedOrigins:   []string{\"http://example.com\", \"http://localhost\"},\n\t\tAllowedMethods:   []string{\"GET\", \"POST\"},\n\t\tAllowedHeaders:   []string{\"Content-Type\"},\n\t\tAllowCredentials: true,\n\t}\n\tm := NewCORSMiddleware(config)\n\n\thandler := http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n\t\tw.WriteHeader(http.StatusOK)\n\t})","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/middleware/cors_test.go","time":{"start":1775895451224,"end":1775895451241}}}}
