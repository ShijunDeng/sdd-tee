dboxLifecycleManager(k8sClient, store, config, logger)\n321: \n322: \tgc := NewGarbageCollector(manager, 5*time.Minute, 3*time.Minute, logger)\n323: \tgc.SetIdleTimeout(20 * time.Minute)\n324: \n325: \tstats := gc.GetStats()\n326: \n327: \tassert.Equal(t, 5*time.Minute, stats.Interval)\n328: \tassert.Equal(t, 3*time.Minute, stats.OnceTimeout)\n329: \tassert.Equal(t, 20*time.Minute, stats.IdleTimeout)\n330: }\n331: \n332: func TestGarbageCollector_ConcurrentRunOnce(t *testing.T) {\n333: \tfakeClient := fake.NewSimpleClientset()\n334: \tdynamicClient := dynamicfake.NewSimpleDynamicClient(runtime.NewScheme())\n335: \tinformerFactory := NewTestInformerFactory(fakeClient)\n336: \n337: \tk8sClient := &K8sClient{\n338: \t\tdynamicClient:   dynamicClient,\n339: \t\tcoreClient:      fakeClient,\n340: \t\tinformerFactory: informerFactory,\n341: \t}\n342: \n343: \tstore := NewMemoryStore()\n344: \tlogger := &mockLogger{}\n345: \tconfig := DefaultLifecycleConfig()\n346: \n347: \tmanager := NewSandboxLifecycleManager(k8sClient, store, config, logger)\n348: \n349: \tgc := NewGarbageCollector(manager, GarbageCollectorInterval, 2*time.Minute, logger)\n350: \n351: \tnow := time.Now()\n352: \n353: \tfor i := 0; i < 10; i++ {\n354: \t\tsandbox := &types.SandboxInfo{\n355: \t\t\tKind:             types.SandboxKind,\n356: \t\t\tSandboxID:        \"sandbox-\" + string(rune(i)),\n357: \t\t\tSandboxNamespace: \"default\",\n358: \t\t\tSandboxName:      \"sandbox-\" + string(rune(i)),\n359: \t\t\tSessionID:        \"session-\" + string(rune(i)),\n360: \t\t\tCreatedAt:        now,\n361: \t\t\tExpiresAt:        now.Add(-1 * time.Hour),\n362: \t\t\tStatus:           \"running\",\n363: \t\t}\n364: \t\terr := store.StoreSandbox(context.Background(), sandbox)\n365: \t\trequire.NoError(t, err)\n366: \t}\n367: \n368: \tvar wg sync.WaitGroup\n369: \tfor i := 0; i < 3; i++ {\n370: \t\twg.Add(1)\n371: \t\tgo func() {\n372: \t\t\tdefer wg.Done()\n373: \t\t\tgc.runOnce(context.Background())\n374: \t\t}()