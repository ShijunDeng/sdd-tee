{"type":"tool_use","timestamp":1775863067455,"sessionID":"ses_286506db5ffe00gR4RFuRuFZrC","part":{"id":"prt_d79afed9c0013xszlTH8jGv4F0","messageID":"msg_d79afd5ca001mHIdIcBhb4Ft8r","sessionID":"ses_286506db5ffe00gR4RFuRuFZrC","type":"tool","tool":"read","callID":"toolu_tool-fa6e05452b4946bb9cbb02d925685c63","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/picod/files.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/picod/files.go</path>\n<type>file</type>\n<content>\n1: package picod\n2: \n3: import (\n4: \t\"encoding/base64\"\n5: \t\"errors\"\n6: \t\"fmt\"\n7: \t\"io\"\n8: \t\"mime\"\n9: \t\"os\"\n10: \t\"path/filepath\"\n11: \t\"strconv\"\n12: \t\"strings\"\n13: \t\"time\"\n14: \n15: \t\"github.com/gin-gonic/gin\"\n16: )\n17: \n18: const (\n19: \tmaxFileMode     = 0777\n20: \tdefaultFileMode = 0644\n21: )\n22: \n23: type FileInfo struct {\n24: \tPath     string    `json:\"path\"`\n25: \tSize     int64     `json:\"size\"`\n26: \tMode     string    `json:\"mode\"`\n27: \tModified time.Time `json:\"modified\"`\n28: }\n29: \n30: type UploadFileRequest struct {\n31: \tPath    string `json:\"path\" binding:\"required\"`\n32: \tContent string `json:\"content\" binding:\"required\"`\n33: \tMode    string `json:\"mode\"`\n34: }\n35: \n36: type FileEntry struct {\n37: \tName     string    `json:\"name\"`\n38: \tSize     int64     `json:\"size\"`\n39: \tModified time.Time `json:\"modified\"`\n40: \tMode     string    `json:\"mode\"`\n41: \tIsDir    bool      `json:\"is_dir\"`\n42: }\n43: \n44: type ListFilesResponse struct {\n45: \tFiles []FileEntry `json:\"files\"`\n46: \tPath  string      `json:\"path\"`\n47: }\n48: \n49: func parseFileMode(modeStr string) (os.FileMode, error) {\n50: \tif modeStr == \"\" {\n51: \t\treturn defaultFileMode, nil\n52: \t}\n53: \n54: \tmode, err := strconv.ParseUint(modeStr, 8, 32)\n55: \tif err != nil {\n56: \t\treturn defaultFileMode, nil\n57: \t}\n58: \n59: \tif mode > maxFileMode {\n60: \t\treturn 0, errors.New(\"invalid file mode\")\n61: \t}\n62: \n63: \treturn os.FileMode(mode), nil\n64: }\n65: \n66: func (s *Server) UploadFileHandler(c *gin.Context) {\n67: \tcontentType := c.ContentType()\n68: \n69: \tvar path string\n70: \tvar content []byte\n71: \tvar modeStr string\n72: \n73: \tif contentType == \"multipart/form-data\" {\n74: \t\tpath = c.PostForm(\"path\")\n75: \t\tif path == \"\" {\n76: \t\t\tc.JSON(400, gin.H{\"error\": \"missing path parameter\"})\n77: \t\t\treturn\n78: \t\t}\n79: \n80: \t\tfileHeader, err := c.FormFile(\"file\")\n81: \t\tif err != nil {\n82: \t\t\tc.JSON(400, gin.H{\"error\": \"missing file\"})\n83: \t\t\treturn\n84: \t\t}\n85: \n86: \t\tfile, err := fileHeader.Open()\n87: \t\tif err != nil {\n88: \t\t\tc.JSON(500, gin.H{\"error\": \"failed to open file\"})\n89: \t\t\treturn\n90: \t\t}\n91: \t\tdefer file.Close()\n92: \n93: \t\tcontent, err = io.ReadAll(file)\n94: \t\tif err != nil {\n95: \t\t\tc.JSON(500, gin.H{\"error\": \"failed to read file\"})\n96: \t\t\treturn\n97: \t\t}\n98: \n99: \t\tmodeStr = c.PostForm(\"mode\")\n100: \t} else {\n101: \t\tvar req UploadFileRequest\n102: \t\tif err := c.ShouldBindJSON(&req); err != nil {\n103: \t\t\tc.JSON(400, gin.H{\"error\": \"invalid request body\"})\n104: \t\t\treturn\n105: \t\t}\n106: \n107: \t\tpath = req.Path\n108: \t\tmodeStr = req.Mode\n109: \n110: \t\tdecoded, err := base64.StdEncoding.DecodeString(req.Content)\n111: \t\tif err != nil {\n112: \t\t\tc.JSON(400, gin.H{\"error\": \"invalid base64 content\"})\n113: \t\t\treturn\n114: \t\t}\n115: \t\tcontent = decoded\n116: \t}\n117: \n118: \tsanitizedPath, err := sanitizePath(s.workspace, path)\n119: \tif err != nil {\n120: \t\tc.JSON(400, gin.H{\"error\": fmt.Sprintf(\"invalid path: %s\", err.Error())})\n121: \t\treturn\n122: \t}\n123: \n124: \tmode, err := parseFileMode(modeStr)\n125: \tif err != nil {\n126: \t\tc.JSON(400, gin.H{\"error\": err.Error()})\n127: \t\treturn\n128: \t}\n129: \n130: \tparentDir := filepath.Dir(sanitizedPath)\n131: \tif err := os.MkdirAll(parentDir, 0755); err != nil {\n132: \t\tc.JSON(500, gin.H{\"error\": \"failed to create parent directories\"})\n133: \t\treturn\n134: \t}\n135: \n136: \tif err := os.WriteFile(sanitizedPath, content, mode); err != nil {\n137: \t\tc.JSON(500, gin.H{\"error\": \"failed to write file\"})\n138: \t\treturn\n139: \t}\n140: \n141: \tinfo, err := os.Stat(sanitizedPath)\n142: \tif err != nil {\n143: \t\tc.JSON(500, gin.H{\"error\": \"failed to get file info\"})\n144: \t\treturn\n145: \t}\n146: \n147: \tc.JSON(200, FileInfo{\n148: \t\tPath:     path,\n149: \t\tSize:     info.Size(),\n150: \t\tMode:     fmt.Sprintf(\"%04o\", info.Mode().Perm()),\n151: \t\tModified: info.ModTime(),\n152: \t})\n153: }\n154: \n155: func (s *Server) ListFilesHandler(c *gin.Context) {\n156: \tpath := c.Query(\"path\")\n157: \tif path == \"\" {\n158: \t\tc.JSON(400, gin.H{\"error\": \"missing path parameter\"})\n159: \t\treturn\n160: \t}\n161: \n162: \tsanitizedPath, err := sanitizePath(s.workspace, path)\n163: \tif err != nil {\n164: \t\tc.JSON(400, gin.H{\"error\": fmt.Sprintf(\"invalid path: %s\", err.Error())})\n165: \t\treturn\n166: \t}\n167: \n168: \tentries, err := os.ReadDir(sanitizedPath)\n169: \tif err != nil {\n170: \t\tc.JSON(500, gin.H{\"error\": \"failed to read directory\"})\n171: \t\treturn\n172: \t}\n173: \n174: \tfiles := []FileEntry{}\n175: \tfor _, entry := range entries {\n176: \t\tinfo, err := entry.Info()\n177: \t\tif err != nil {\n178: \t\t\tcontinue\n179: \t\t}\n180: \n181: \t\tfiles = append(files, FileEntry{\n182: \t\t\tName:     entry.Name(),\n183: \t\t\tSize:     info.Size(),\n184: \t\t\tModified: info.ModTime(),\n185: \t\t\tMode:     fmt.Sprintf(\"%04o\", info.Mode().Perm()),\n186: \t\t\tIsDir:    entry.IsDir(),\n187: \t\t})\n188: \t}\n189: \n190: \tc.JSON(200, ListFilesResponse{\n191: \t\tFiles: files,\n192: \t\tPath:  path,\n193: \t})\n194: }\n195: \n196: func (s *Server) DownloadFileHandler(c *gin.Context) {\n197: \treqPath := c.Param(\"path\")\n198: \treqPath = strings.TrimPrefix(reqPath, \"/\")\n199: \n200: \tsanitizedPath, err := sanitizePath(s.workspace, reqPath)\n201: \tif err != nil {\n202: \t\tc.JSON(400, gin.H{\"error\": fmt.Sprintf(\"invalid path: %s\", err.Error())})\n203: \t\treturn\n204: \t}\n205: \n206: \tinfo, err := os.Stat(sanitizedPath)\n207: \tif err != nil {\n208: \t\tif os.IsNotExist(err) {\n209: \t\t\tc.JSON(404, gin.H{\"error\": \"file not found\"})\n210: \t\t} else {\n211: \t\t\tc.JSON(500, gin.H{\"error\": \"failed to stat file\"})\n212: \t\t}\n213: \t\treturn\n214: \t}\n215: \n216: \tif info.IsDir() {\n217: \t\tc.JSON(400, gin.H{\"error\": \"path is not a file\"})\n218: \t\treturn\n219: \t}\n220: \n221: \tcontentType := mime.TypeByExtension(filepath.Ext(sanitizedPath))\n222: \tif contentType == \"\" {\n223: \t\tcontentType = \"application/octet-stream\"\n224: \t}\n225: \n226: \tfilename := filepath.Base(sanitizedPath)\n227: \tc.Header(\"Content-Type\", contentType)\n228: \tc.Header(\"Content-Disposition\", fmt.Sprintf(\"attachment; filename=\\\"%s\\\"\", filename))\n229: \tc.File(sanitizedPath)\n230: }\n\n(End of file - total 230 lines)\n</content>","metadata":{"preview":"package picod\n\nimport (\n\t\"encoding/base64\"\n\t\"errors\"\n\t\"fmt\"\n\t\"io\"\n\t\"mime\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"strconv\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/gin-gonic/gin\"\n)\n\nconst (\n\tmaxFileMode     = 0777\n\tdefaultFileMode = 0644","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/picod/files.go","time":{"start":1775863067438,"end":1775863067453}}}}
{"type":"tool_use","timestamp":1775863067457,"sessionID":"ses_286506db5ffe00gR4RFuRuFZrC","part":{"id":"prt_d79aff0a3001iXZpob0mo84Fwi","messageID":"msg_d79afd5ca001mHIdIcBhb4Ft8r","sessionID":"ses_286506db5ffe00gR4RFuRuFZrC","type":"tool","tool":"read","callID":"toolu_tool-907cef0e57754f9182db73c2d0a03b2c","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/picod/server.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/picod/server.go</path>\n<type>file</type>\n<content>\n1: package picod\n2: \n3: import (\n4: \t\"context\"\n5: \t\"fmt\"\n6: \t\"net/http\"\n7: \t\"os\"\n8: \t\"path/filepath\"\n9: \t\"time\"\n10: \n11: \t\"github.com/gin-gonic/gin\"\n12: \t\"k8s.io/klog/v2\"\n13: )\n14: \n15: const readHeaderTimeout = 10 * time.Second\n16: \n17: type Server struct {\n18: \tconfig      *Config\n19: \tengine      *gin.Engine\n20: \thttpServer  *http.Server\n21: \tauthManager *AuthManager\n22: \tworkspace   string\n23: \tstartTime   time.Time\n24: }\n25: \n26: func NewServer(config *Config) (*Server, error) {\n27: \tengine := gin.New()\n28: \tgin.SetMode(gin.ReleaseMode)\n29: \tengine.Use(gin.Logger())\n30: \tengine.Use(gin.Recovery())\n31: \n32: \tworkspace := config.Workspace\n33: \tif workspace == \"\" {\n34: \t\twd, err := os.Getwd()\n35: \t\tif err != nil {\n36: \t\t\treturn nil, fmt.Errorf(\"failed to get working directory: %w\", err)\n37: \t\t}\n38: \t\tworkspace = wd\n39: \t} else {\n40: \t\tabs, err := filepath.Abs(workspace)\n41: \t\tif err != nil {\n42: \t\t\treturn nil, fmt.Errorf(\"failed to resolve workspace path: %w\", err)\n43: \t\t}\n44: \t\tworkspace = abs\n45: \t}\n46: \n47: \tauthManager, err := NewAuthManager()\n48: \tif err != nil {\n49: \t\treturn nil, fmt.Errorf(\"failed to create auth manager: %w\", err)\n50: \t}\n51: \n52: \ts := &Server{\n53: \t\tconfig:      config,\n54: \t\tengine:      engine,\n55: \t\tauthManager: authManager,\n56: \t\tworkspace:   workspace,\n57: \t\tstartTime:   time.Now(),\n58: \t\thttpServer: &http.Server{\n59: \t\t\tAddr:              fmt.Sprintf(\":%d\", config.Port),\n60: \t\t\tHandler:           engine,\n61: \t\t\tReadHeaderTimeout: readHeaderTimeout,\n62: \t\t},\n63: \t}\n64: \n65: \tengine.GET(\"/health\", s.HealthCheckHandler)\n66: \n67: \tapi := engine.Group(\"/api\")\n68: \tapi.Use(s.authManager.AuthMiddleware())\n69: \t{\n70: \t\tapi.POST(\"/execute\", s.ExecuteHandler)\n71: \t\tapi.POST(\"/files\", s.UploadFileHandler)\n72: \t\tapi.GET(\"/files\", s.ListFilesHandler)\n73: \t\tapi.GET(\"/files/*path\", s.DownloadFileHandler)\n74: \t}\n75: \n76: \treturn s, nil\n77: }\n78: \n79: func (s *Server) Run(ctx context.Context) error {\n80: \tklog.InfoS(\"PicoD started\", \"port\", s.config.Port, \"workspace\", s.workspace)\n81: \terr := s.httpServer.ListenAndServe()\n82: \tif err != nil && err != http.ErrServerClosed {\n83: \t\tklog.ErrorS(err, \"server error\")\n84: \t\treturn err\n85: \t}\n86: \treturn nil\n87: }\n88: \n89: func (s *Server) Shutdown(ctx context.Context) error {\n90: \treturn s.httpServer.Shutdown(ctx)\n91: }\n\n(End of file - total 91 lines)\n</content>","metadata":{"preview":"package picod\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"net/http\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"time\"\n\n\t\"github.com/gin-gonic/gin\"\n\t\"k8s.io/klog/v2\"\n)\n\nconst readHeaderTimeout = 10 * time.Second\n\ntype Server struct {\n\tconfig      *Config\n\tengine      *gin.Engine\n\thttpServer  *http.Server","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/picod/server.go","time":{"start":1775863067441,"end":1775863067455}}}}
{"type":"tool_use","timestamp":1775863067460,"sessionID":"ses_286506db5ffe00gR4RFuRuFZrC","part":{"id":"prt_d79aff30f001HzFjRiLh2Q0TEs","messageID":"msg_d79afd5ca001mHIdIcBhb4Ft8r","sessionID":"ses_286506db5ffe00gR4RFuRuFZrC","type":"tool","tool":"read","callID":"toolu_tool-488afd8084634a0d9bb3d61b4fd63877","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/picod/picod_test.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/picod/picod_test.go</path>\n<type>file</type>\n<content>\n1: package picod\n2: \n3: import (\n4: \t\"bytes\"\n5: \t\"context\"\n6: \t\"crypto/rand\"\n7: \t\"crypto/rsa\"\n8: \t\"crypto/x509\"\n9: \t\"encoding/base64\"\n10: \t\"encoding/json\"\n11: \t\"encoding/pem\"\n12: \t\"fmt\"\n13: \t\"io\"\n14: \t\"mime/multipart\"\n15: \t\"net/http/httptest\"\n16: \t\"os\"\n17: \t\"path/filepath\"\n18: \t\"testing\"\n19: \t\"time\"\n20: \n21: \t\"github.com/gin-gonic/gin\"\n22: \t\"github.com/golang-jwt/jwt/v5\"\n23: \t\"github.com/stretchr/testify/assert\"\n24: \t\"github.com/stretchr/testify/require\"\n25: )\n26: \n27: func setupTestServer(t *testing.T) *Server {\n28: \tt.Helper()\n29: \n30: \tworkspace := t.TempDir()\n31: \n32: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n33: \trequire.NoError(t, err)\n34: \n35: \tpublicKeyPEM := encodePublicKeyPEMForTest(&privateKey.PublicKey)\n36: \n37: \toldEnv := os.Getenv(PublicKeyEnvVar)\n38: \tos.Setenv(PublicKeyEnvVar, publicKeyPEM)\n39: \tt.Cleanup(func() {\n40: \t\tif oldEnv != \"\" {\n41: \t\t\tos.Setenv(PublicKeyEnvVar, oldEnv)\n42: \t\t} else {\n43: \t\t\tos.Unsetenv(PublicKeyEnvVar)\n44: \t\t}\n45: \t})\n46: \n47: \tserver, err := NewServer(&Config{\n48: \t\tPort:      8080,\n49: \t\tWorkspace: workspace,\n50: \t})\n51: \trequire.NoError(t, err)\n52: \n53: \treturn server\n54: }\n55: \n56: func encodePublicKeyPEMForTest(key *rsa.PublicKey) string {\n57: \tbytes, err := x509.MarshalPKIXPublicKey(key)\n58: \tif err != nil {\n59: \t\treturn \"\"\n60: \t}\n61: \tpemData := pem.EncodeToMemory(&pem.Block{\n62: \t\tType:  \"PUBLIC KEY\",\n63: \t\tBytes: bytes,\n64: \t})\n65: \treturn string(pemData)\n66: }\n67: \n68: func generateTestJWT(privateKey *rsa.PrivateKey, expired bool) string {\n69: \tnow := time.Now()\n70: \texpiry := now.Add(5 * time.Minute)\n71: \tif expired {\n72: \t\texpiry = now.Add(-5 * time.Minute)\n73: \t}\n74: \n75: \tclaims := jwt.MapClaims{\n76: \t\t\"exp\": expiry.Unix(),\n77: \t\t\"iat\": now.Unix(),\n78: \t\t\"iss\": \"test-issuer\",\n79: \t}\n80: \n81: \ttoken := jwt.NewWithClaims(jwt.SigningMethodRS256, claims)\n82: \ttokenString, _ := token.SignedString(privateKey)\n83: \treturn tokenString\n84: }\n85: \n86: func generateHS256JWT() string {\n87: \tclaims := jwt.MapClaims{\n88: \t\t\"exp\": time.Now().Add(5 * time.Minute).Unix(),\n89: \t\t\"iat\": time.Now().Unix(),\n90: \t}\n91: \n92: \ttoken := jwt.NewWithClaims(jwt.SigningMethodHS256, claims)\n93: \ttokenString, _ := token.SignedString([]byte(\"test-secret\"))\n94: \treturn tokenString\n95: }\n96: \n97: func makeAuthenticatedRequest(t *testing.T, server *Server, method, path string, body io.Reader, contentType string, jwtToken string) *httptest.ResponseRecorder {\n98: \tt.Helper()\n99: \n100: \tgin.SetMode(gin.TestMode)\n101: \tw := httptest.NewRecorder()\n102: \treq := httptest.NewRequest(method, path, body)\n103: \tif contentType != \"\" {\n104: \t\treq.Header.Set(\"Content-Type\", contentType)\n105: \t}\n106: \tif jwtToken != \"\" {\n107: \t\treq.Header.Set(\"Authorization\", \"Bearer \"+jwtToken)\n108: \t}\n109: \n110: \tserver.engine.ServeHTTP(w, req)\n111: \treturn w\n112: }\n113: \n114: func TestConfig(t *testing.T) {\n115: \tcfg := &Config{\n116: \t\tPort:      8080,\n117: \t\tWorkspace: \"/tmp/test\",\n118: \t}\n119: \n120: \tassert.Equal(t, 8080, cfg.Port)\n121: \tassert.Equal(t, \"/tmp/test\", cfg.Workspace)\n122: }\n123: \n124: func TestSanitizePathValidRelative(t *testing.T) {\n125: \tworkspace := t.TempDir()\n126: \n127: \tresult, err := sanitizePath(workspace, \"subdir/file.txt\")\n128: \trequire.NoError(t, err)\n129: \n130: \texpected := filepath.Join(workspace, \"subdir/file.txt\")\n131: \tassert.Equal(t, expected, result)\n132: }\n133: \n134: func TestSanitizePathAbsolute(t *testing.T) {\n135: \tworkspace := t.TempDir()\n136: \n137: \tresult, err := sanitizePath(workspace, \"/workspace/file.txt\")\n138: \trequire.NoError(t, err)\n139: \n140: \texpected := filepath.Join(workspace, \"workspace/file.txt\")\n141: \tassert.Equal(t, expected, result)\n142: }\n143: \n144: func TestSanitizePathTraversal(t *testing.T) {\n145: \tworkspace := t.TempDir()\n146: \n147: \t_, err := sanitizePath(workspace, \"../escape.txt\")\n148: \tassert.Error(t, err)\n149: \tassert.Contains(t, err.Error(), \"path escape\")\n150: }\n151: \n152: func TestSanitizePathDeepTraversal(t *testing.T) {\n153: \tworkspace := t.TempDir()\n154: \n155: \t_, err := sanitizePath(workspace, \"subdir/../../escape.txt\")\n156: \tassert.Error(t, err)\n157: \tassert.Contains(t, err.Error(), \"path escape\")\n158: }\n159: \n160: func TestSanitizePathNullByte(t *testing.T) {\n161: \tworkspace := t.TempDir()\n162: \n163: \tresult, err := sanitizePath(workspace, \"file\\x00.txt\")\n164: \trequire.NoError(t, err)\n165: \n166: \tassert.Contains(t, result, workspace)\n167: }\n168: \n169: func TestSanitizePathExistingSymlink(t *testing.T) {\n170: \tworkspace := t.TempDir()\n171: \n172: \ttargetDir := filepath.Join(workspace, \"target\")\n173: \trequire.NoError(t, os.MkdirAll(targetDir, 0755))\n174: \n175: \tlinkPath := filepath.Join(workspace, \"link\")\n176: \trequire.NoError(t, os.Symlink(targetDir, linkPath))\n177: \n178: \ttargetFile := filepath.Join(targetDir, \"file.txt\")\n179: \trequire.NoError(t, os.WriteFile(targetFile, []byte(\"test\"), 0644))\n180: \n181: \tresult, err := sanitizePath(workspace, \"link/file.txt\")\n182: \trequire.NoError(t, err)\n183: \n184: \tassert.Equal(t, targetFile, result)\n185: }\n186: \n187: func TestAuthMiddlewareMissingHeader(t *testing.T) {\n188: \tserver := setupTestServer(t)\n189: \n190: \tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/execute\", nil, \"application/json\", \"\")\n191: \tassert.Equal(t, 401, w.Code)\n192: \n193: \tvar resp map[string]string\n194: \trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n195: \tassert.Equal(t, \"missing authorization header\", resp[\"error\"])\n196: }\n197: \n198: func TestAuthMiddlewareInvalidFormat(t *testing.T) {\n199: \tserver := setupTestServer(t)\n200: \n201: \tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/execute\", nil, \"application/json\", \"InvalidFormat\")\n202: \tassert.Equal(t, 401, w.Code)\n203: \n204: \tvar resp map[string]string\n205: \trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n206: \tassert.Contains(t, resp[\"error\"], \"malformed\")\n207: }\n208: \n209: func TestAuthMiddlewareExpiredToken(t *testing.T) {\n210: \tserver := setupTestServer(t)\n211: \n212: \tauthMgr := server.authManager\n213: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n214: \trequire.NoError(t, err)\n215: \n216: \texpiredToken := generateTestJWT(privateKey, true)\n217: \n218: \tauthMgr.SetPublicKey(&privateKey.PublicKey)\n219: \n220: \tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/execute\", nil, \"application/json\", expiredToken)\n221: \tassert.Equal(t, 401, w.Code)\n222: \n223: \tvar resp map[string]string\n224: \trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n225: \tassert.Equal(t, \"token is expired\", resp[\"error\"])\n226: }\n227: \n228: func TestAuthMiddlewareHS256Token(t *testing.T) {\n229: \tserver := setupTestServer(t)\n230: \n231: \ths256Token := generateHS256JWT()\n232: \n233: \tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/execute\", nil, \"application/json\", hs256Token)\n234: \tassert.Equal(t, 401, w.Code)\n235: \n236: \tvar resp map[string]string\n237: \trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n238: \tassert.Equal(t, \"invalid signing method\", resp[\"error\"])\n239: }\n240: \n241: func TestAuthMiddlewareValidRS256Token(t *testing.T) {\n242: \tserver := setupTestServer(t)\n243: \n244: \tauthMgr := server.authManager\n245: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n246: \trequire.NoError(t, err)\n247: \n248: \tauthMgr.SetPublicKey(&privateKey.PublicKey)\n249: \n250: \tvalidToken := generateTestJWT(privateKey, false)\n251: \n252: \tbody := bytes.NewBufferString(`{\"command\": [\"echo\", \"hello\"]}`)\n253: \tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/execute\", body, \"application/json\", validToken)\n254: \tassert.Equal(t, 200, w.Code)\n255: }\n256: \n257: func TestExecuteHandlerValidCommand(t *testing.T) {\n258: \tserver := setupTestServer(t)\n259: \n260: \tauthMgr := server.authManager\n261: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n262: \trequire.NoError(t, err)\n263: \tauthMgr.SetPublicKey(&privateKey.PublicKey)\n264: \n265: \tvalidToken := generateTestJWT(privateKey, false)\n266: \n267: \tbody := bytes.NewBufferString(`{\"command\": [\"echo\", \"hello\"]}`)\n268: \tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/execute\", body, \"application/json\", validToken)\n269: \tassert.Equal(t, 200, w.Code)\n270: \n271: \tvar resp ExecuteResponse\n272: \trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n273: \tassert.Equal(t, \"hello\\n\", resp.Stdout)\n274: \tassert.Equal(t, 0, resp.ExitCode)\n275: \tassert.Greater(t, resp.Duration, 0.0)\n276: }\n277: \n278: func TestExecuteHandlerEmptyCommand(t *testing.T) {\n279: \tserver := setupTestServer(t)\n280: \n281: \tauthMgr := server.authManager\n282: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n283: \trequire.NoError(t, err)\n284: \tauthMgr.SetPublicKey(&privateKey.PublicKey)\n285: \n286: \tvalidToken := generateTestJWT(privateKey, false)\n287: \n288: \tbody := bytes.NewBufferString(`{\"command\": []}`)\n289: \tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/execute\", body, \"application/json\", validToken)\n290: \tassert.Equal(t, 400, w.Code)\n291: \n292: \tvar resp map[string]string\n293: \trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n294: \tassert.Equal(t, \"missing command\", resp[\"error\"])\n295: }\n296: \n297: func TestExecuteHandlerTimeout(t *testing.T) {\n298: \tserver := setupTestServer(t)\n299: \n300: \tauthMgr := server.authManager\n301: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n302: \trequire.NoError(t, err)\n303: \tauthMgr.SetPublicKey(&privateKey.PublicKey)\n304: \n305: \tvalidToken := generateTestJWT(privateKey, false)\n306: \n307: \tbody := bytes.NewBufferString(`{\"command\": [\"sleep\", \"10\"], \"timeout\": \"1s\"}`)\n308: \tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/execute\", body, \"application/json\", validToken)\n309: \tassert.Equal(t, 200, w.Code)\n310: \n311: \tvar resp ExecuteResponse\n312: \trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n313: \tassert.Equal(t, TimeoutExitCode, resp.ExitCode)\n314: \tassert.Contains(t, resp.Stderr, \"command timed out\")\n315: }\n316: \n317: func TestExecuteHandlerInvalidTimeout(t *testing.T) {\n318: \tserver := setupTestServer(t)\n319: \n320: \tauthMgr := server.authManager\n321: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n322: \trequire.NoError(t, err)\n323: \tauthMgr.SetPublicKey(&privateKey.PublicKey)\n324: \n325: \tvalidToken := generateTestJWT(privateKey, false)\n326: \n327: \tbody := bytes.NewBufferString(`{\"command\": [\"echo\", \"test\"], \"timeout\": \"invalid\"}`)\n328: \tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/execute\", body, \"application/json\", validToken)\n329: \tassert.Equal(t, 200, w.Code)\n330: \n331: \tvar resp ExecuteResponse\n332: \trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n333: \tassert.Equal(t, 0, resp.ExitCode)\n334: }\n335: \n336: func TestExecuteHandlerWorkingDirectory(t *testing.T) {\n337: \tserver := setupTestServer(t)\n338: \n339: \tsubdir := filepath.Join(server.workspace, \"subdir\")\n340: \trequire.NoError(t, os.MkdirAll(subdir, 0755))\n341: \n342: \tauthMgr := server.authManager\n343: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n344: \trequire.NoError(t, err)\n345: \tauthMgr.SetPublicKey(&privateKey.PublicKey)\n346: \n347: \tvalidToken := generateTestJWT(privateKey, false)\n348: \n349: \tbody := bytes.NewBufferString(`{\"command\": [\"pwd\"], \"working_dir\": \"subdir\"}`)\n350: \tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/execute\", body, \"application/json\", validToken)\n351: \tassert.Equal(t, 200, w.Code)\n352: \n353: \tvar resp ExecuteResponse\n354: \trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n355: \tassert.Contains(t, resp.Stdout, subdir)\n356: }\n357: \n358: func TestExecuteHandlerPathEscapeWorkingDir(t *testing.T) {\n359: \tserver := setupTestServer(t)\n360: \n361: \tauthMgr := server.authManager\n362: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n363: \trequire.NoError(t, err)\n364: \tauthMgr.SetPublicKey(&privateKey.PublicKey)\n365: \n366: \tvalidToken := generateTestJWT(privateKey, false)\n367: \n368: \tbody := bytes.NewBufferString(`{\"command\": [\"pwd\"], \"working_dir\": \"../escape\"}`)\n369: \tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/execute\", body, \"application/json\", validToken)\n370: \tassert.Equal(t, 400, w.Code)\n371: \n372: \tvar resp map[string]string\n373: \trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n374: \tassert.Contains(t, resp[\"error\"], \"invalid working directory\")\n375: }\n376: \n377: func TestExecuteHandlerEnvironmentAugmentation(t *testing.T) {\n378: \tserver := setupTestServer(t)\n379: \n380: \tauthMgr := server.authManager\n381: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n382: \trequire.NoError(t, err)\n383: 