 file content\"))\n432: \trequire.NoError(t, err)\n433: \trequire.NoError(t, writer.Close())\n434: \n435: \treq := httptest.NewRequest(\"POST\", \"/api/files\", body)\n436: \treq.Header.Set(\"Content-Type\", writer.FormDataContentType())\n437: \treq.Header.Set(\"Authorization\", \"Bearer \"+validToken)\n438: \n439: \tw := httptest.NewRecorder()\n440: \tserver.engine.ServeHTTP(w, req)\n441: \n442: \tassert.Equal(t, 200, w.Code)\n443: \n444: \tvar resp FileInfo\n445: \trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n446: \tassert.Equal(t, \"upload.txt\", resp.Path)\n447: \n448: \tfilePath := filepath.Join(server.workspace, \"upload.txt\")\n449: \tactualContent, err := os.ReadFile(filePath)\n450: \trequire.NoError(t, err)\n451: \tassert.Equal(t, []byte(\"test file content\"), actualContent)\n452: }\n453: \n454: func TestUploadFileHandlerJSON(t *testing.T) {\n455: \tserver := setupTestServer(t)\n456: \n457: \tauthMgr := server.authManager\n458: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n459: \trequire.NoError(t, err)\n460: \tauthMgr.SetPublicKey(&privateKey.PublicKey)\n461: \n462: \tvalidToken := generateTestJWT(privateKey, false)\n463: \n464: \tcontent := base64.StdEncoding.EncodeToString([]byte(\"test content\"))\n465: \tbody := bytes.NewBufferString(fmt.Sprintf(`{\"path\": \"test.txt\", \"content\": \"%s\"}`, content))\n466: \tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/files\", body, \"application/json\", validToken)\n467: \tassert.Equal(t, 200, w.Code)\n468: \n469: \tvar resp FileInfo\n470: \trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n471: \tassert.Equal(t, \"test.txt\", resp.Path)\n472: \tassert.Equal(t, int64(12), resp.Size)\n473: \n474: \tfilePath := filepath.Join(server.workspace, \"test.txt\")\n475: \tactualContent, err := os.ReadFile(filePath)\n476: \trequire.NoError(t, err)\n477: \tassert.Equal(t, []byte(\"test content\"), actualContent)\n478: }\n479: \n480: func TestUploadFileHandlerInvalidBase64(t *tes