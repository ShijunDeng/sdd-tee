ror.\ntype HandlerFunc func(w http.ResponseWriter, r *http.Request) error\n\n// ServeHTTP implements http.Handler interface, calling the handler function\n// and handling any errors via workloadmanager.HandleError.\nfunc (hf HandlerFunc) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n\tif err := hf(w, r); err != nil {\n\t\tworkloadmanager.HandleError(w, r, err)\n\t}\n}\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/handlers/handler.go","time":{"start":1775843320504,"end":1775843320543}}}}
