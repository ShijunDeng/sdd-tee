ssert provider.verbose == True\n28: \n29:     def test_init_with_kubeconfig(self) -> None:\n30:         with patch(\"kubernetes.config.load_kube_config\") as mock_load:\n31:             with patch(\"kubernetes.client.CustomObjectsApi\"):\n32:                 with patch(\"kubernetes.client.CoreV1Api\"):\n33:                     provider = AgentCubeProvider(kubeconfig=\"/path/to/kubeconfig\")\n34:                     mock_load.assert_called_once_with(config_file=\"/path/to/kubeconfig\")\n35: \n36: \n37: class TestConstants:\n38:     def test_cr_group(self) -> None:\n39:         assert AgentCubeProvider.CR_GROUP == \"runtime.agentcube.volcano.sh\"\n40: \n41:     def test_cr_version(self) -> None:\n42:         assert AgentCubeProvider.CR_VERSION == \"v1alpha1\"\n43: \n44:     def test_cr_plural(self) -> None:\n45:         assert AgentCubeProvider.CR_PLURAL == \"agentruntimes\"\n46: \n47:     def test_session_timeout(self) -> None:\n48:         assert AgentCubeProvider.SESSION_TIMEOUT == \"15m\"\n49: \n50:     def test_max_session_duration(self) -> None:\n51:         assert AgentCubeProvider.MAX_SESSION_DURATION == \"8h\"\n52: \n53:     def test_default_secret(self) -> None:\n54:         assert AgentCubeProvider.DEFAULT_SECRET == \"default-secret\"\n55: \n56: \n57: class TestSanitizeName:\n58:     def test_sanitize_name_lowercase(self) -> None:\n59:         with patch(\"kubernetes.config.load_kube_config\"):\n60:             with patch(\"kubernetes.client.CustomObjectsApi\"):\n61:                 with patch(\"kubernetes.client.CoreV1Api\"):\n62:                     provider = AgentCubeProvider()\n63:                     result = provider._sanitize_name(\"TestAgent\")\n64:                     assert result == \"testagent\"\n65: \n66:     def test_sanitize_name_replace_non_alphanumeric(self) -> None:\n67:         with patch(\"kubernetes.config.load_kube_config\"):\n68:             with patch(\"kubernetes.client.CustomObjectsApi\"):\n69:                 with patch(\"kubernetes.client.CoreV1Api\"):\n70:                     provider = AgentCubeProvider()\n71:                     result = provider._sanitize_name(\"test-agent_123\")\n72:                     assert result == \"test-agent-123\"\n73: \n74:     def test_sanitize_name_truncate_to_63_chars(self) -> None:\n75:         with patch(\"kubernetes.config.load_kube_config\"):\n76:             with patch(\"kubernetes.client.CustomObjectsApi\"):\n77:                 with patch(\"kubernetes.client.CoreV1Api\"):\n78:                     provider = AgentCubeProvider()\n79:                     long_name = \"a\" * 100\n80:                     result = provider._sanitize_name(long_name)\n81:                     assert len(result) == 63\n82: \n83:     def test_sanitize_name_strip_dashes(self) -> None:\n84:         with patch(\"kubernetes.config.load_kube_config\"):\n85:             with patch(\"kubernetes.client.CustomObjectsApi\"):\n86:                 with patch(\"kubernetes.client.CoreV1Api\"):\n87:                     provider = AgentCubeProvider()\n88:                     result = provider._sanitize_name(\"---test---agent---\")\n89:                     assert result == \"test-agent\"\n90: \n91:     def test_sanitize_name_empty_string(self) -> None:\n92:         with patch(\"kubernetes.config.load_kube_config\"):\n93:             with patch(\"kubernetes.client.CustomObjectsApi\"):\n94:                 with patch(\"kubernetes.client.CoreV1Api\"):\n95:                     provider = AgentCubeProvider()\n96:                     result = provider._sanitize_name(\"\")\n97:                     assert result == \"default\"\n98: \n99: \n100: class TestEnsureNamespace:\n101:     def test_ensure_namespace_exists(self) -> None:\n102:         with patch(\"kubernetes.config.load_kube_config\"):\n103:             mock_core_api = MagicMock()\n104:             mock_core_api.read_namespace.return_value = MagicMock()\n105:             \n106:             with patch(\"kubernetes.client.CustomObjectsApi\"):\n10