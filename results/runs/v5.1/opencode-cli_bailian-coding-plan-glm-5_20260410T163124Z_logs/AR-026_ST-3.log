{"type":"tool_use","timestamp":1775878094364,"sessionID":"ses_2856b7b11ffeOMPvSSfB4W9F8Y","part":{"id":"prt_d7a9535c30014jndOOCrmOXSgl","messageID":"msg_d7a951221001bzG9iw2lL1oWKZ","sessionID":"ses_2856b7b11ffeOMPvSSfB4W9F8Y","type":"tool","tool":"read","callID":"toolu_tool-75ae5604705444ef800e4990a5203731","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/cmd/cli/agentcube/services/k8s_provider.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/cmd/cli/agentcube/services/k8s_provider.py</path>\n<type>file</type>\n<content>\n1: import logging\n2: import re\n3: import time\n4: from typing import Any, Dict, Optional\n5: \n6: import kubernetes\n7: import kubernetes.client\n8: import kubernetes.config\n9: \n10: \n11: class KubernetesProvider:\n12:     NODE_PORT_MIN = 30000\n13:     NODE_PORT_MAX = 32767\n14:     DEFAULT_TIMEOUT = 120\n15:     POLL_INTERVAL = 2\n16: \n17:     def __init__(\n18:         self,\n19:         namespace: str = \"default\",\n20:         verbose: bool = False,\n21:         kubeconfig: Optional[str] = None,\n22:     ) -> None:\n23:         self.namespace = namespace\n24:         self.verbose = verbose\n25:         self._logger = logging.getLogger(__name__)\n26: \n27:         if kubeconfig:\n28:             kubernetes.config.load_kube_config(config_file=kubeconfig)\n29:         else:\n30:             try:\n31:                 kubernetes.config.load_kube_config()\n32:             except kubernetes.config.ConfigException:\n33:                 kubernetes.config.load_incluster_config()\n34: \n35:         self._apps_api = kubernetes.client.AppsV1Api()\n36:         self._core_api = kubernetes.client.CoreV1Api()\n37: \n38:     def deploy_agent(\n39:         self,\n40:         agent_name: str,\n41:         image_url: str,\n42:         port: int,\n43:         entrypoint: Optional[str] = None,\n44:         replicas: int = 1,\n45:         node_port: Optional[int] = None,\n46:         env_vars: Optional[Dict[str, str]] = None,\n47:     ) -> Dict[str, Any]:\n48:         sanitized_name = self._sanitize_name(agent_name)\n49:         self._ensure_namespace()\n50:         \n51:         try:\n52:             self._create_deployment(\n53:                 sanitized_name,\n54:                 image_url,\n55:                 port,\n56:                 entrypoint,\n57:                 replicas,\n58:                 env_vars,\n59:             )\n60:         except kubernetes.client.exceptions.ApiException as e:\n61:             if e.status == 409:\n62:                 self._patch_deployment(\n63:                     sanitized_name,\n64:                     image_url,\n65:                     port,\n66:                     entrypoint,\n67:                     replicas,\n68:                     env_vars,\n69:                 )\n70:             else:\n71:                 raise RuntimeError(f\"Failed to create deployment: {e}\")\n72:         \n73:         service_result = self._create_service(sanitized_name, port, node_port)\n74:         \n75:         self.wait_for_deployment_ready(sanitized_name)\n76:         \n77:         node_port_result = service_result.get(\"node_port\")\n78:         service_url = f\"http://localhost:{node_port_result}\" if node_port_result else None\n79:         \n80:         return {\n81:             \"deployment_name\": sanitized_name,\n82:             \"service_name\": sanitized_name,\n83:             \"node_port\": node_port_result,\n84:             \"service_url\": service_url,\n85:             \"replicas\": replicas,\n86:         }\n87: \n88:     def _create_deployment(\n89:         self,\n90:         name: str,\n91:         image_url: str,\n92:         port: int,\n93:         entrypoint: Optional[str],\n94:         replicas: int,\n95:         env_vars: Optional[Dict[str, str]],\n96:     ) -> Dict[str, Any]:\n97:         env_list = []\n98:         if env_vars:\n99:             for k, v in env_vars.items():\n100:                 env_list.append({\"name\": k, \"value\": v})\n101:         \n102:         command = None\n103:         if entrypoint:\n104:             parts = entrypoint.split()\n105:             command = parts\n106:         \n107:         deployment_body = {\n108:             \"apiVersion\": \"apps/v1\",\n109:             \"kind\": \"Deployment\",\n110:             \"metadata\": {\n111:                 \"name\": name,\n112:                 \"namespace\": self.namespace,\n113:                 \"labels\": {\"app\": name},\n114:             },\n115:             \"spec\": {\n116:                 \"replicas\": replicas,\n117:                 \"selector\": {\"matchLabels\": {\"app\": name}},\n118:                 \"template\": {\n119:                     \"metadata\": {\"labels\": {\"app\": name}},\n120:                     \"spec\": {\n121:                         \"containers\": [{\n122:                             \"name\": name,\n123:                             \"image\": image_url,\n124:                             \"ports\": [{\"containerPort\": port}],\n125:                             \"env\": env_list,\n126:                         }],\n127:                     },\n128:                 },\n129:             },\n130:         }\n131:         \n132:         if command:\n133:             deployment_body[\"spec\"][\"template\"][\"spec\"][\"containers\"][0][\"command\"] = command\n134:         \n135:         result = self._apps_api.create_namespaced_deployment(\n136:             namespace=self.namespace,\n137:             body=deployment_body,\n138:         )\n139:         \n140:         if self.verbose:\n141:             self._logger.info(f\"Created deployment {name} in namespace {self.namespace}\")\n142:         \n143:         return {\"name\": name, \"status\": \"created\"}\n144: \n145:     def _patch_deployment(\n146:         self,\n147:         name: str,\n148:         image_url: str,\n149:         port: int,\n150:         entrypoint: Optional[str],\n151:         replicas: int,\n152:         env_vars: Optional[Dict[str, str]],\n153:     ) -> Dict[str, Any]:\n154:         env_list = []\n155:         if env_vars:\n156:             for k, v in env_vars.items():\n157:                 env_list.append({\"name\": k, \"value\": v})\n158:         \n159:         command = None\n160:         if entrypoint:\n161:             parts = entrypoint.split()\n162:             command = parts\n163:         \n164:         deployment_body = {\n165:             \"spec\": {\n166:                 \"replicas\": replicas,\n167:                 \"template\": {\n168:                     \"spec\": {\n169:                         \"containers\": [{\n170:                             \"name\": name,\n171:                             \"image\": image_url,\n172:                             \"ports\": [{\"containerPort\": port}],\n173:                             \"env\": env_list,\n174:                         }],\n175:                     },\n176:                 },\n177:             },\n178:         }\n179:         \n180:         if command:\n181:             deployment_body[\"spec\"][\"template\"][\"spec\"][\"containers\"][0][\"command\"] = command\n182:         \n183:         result = self._apps_api.patch_namespaced_deployment(\n184:             name=name,\n185:             namespace=self.namespace,\n186:             body=deployment_body,\n187:         )\n188:         \n189:         if self.verbose:\n190:             self._logger.info(f\"Patched deployment {name} in namespace {self.namespace}\")\n191:         \n192:         return {\"name\": name, \"status\": \"updated\"}\n193: \n194:     def _create_service(\n195:         self, \n196:         name: str, \n197:         port: int, \n198:         node_port: Optional[int]\n199:     ) -> Dict[str, Any]:\n200:         service_body = {\n201:             \"apiVersion\": \"v1\",\n202:             \"kind\": \"Service\",\n203:             \"metadata\": {\n204:                 \"name\": name,\n205:                 \"namespace\": self.namespace,\n206:             },\n207:             \"spec\": {\n208:                 \"type\": \"NodePort\",\n209:                 \"selector\": {\"app\": name},\n210:                 \"ports\": [{\n211:                     \"port\": port,\n212:                     \"targetPort\": port,\n213:                 }],\n214:             },\n215:         }\n216:         \n217:         if node_port:\n218:             service_body[\"spec\"][\"ports\"][0][\"nodePort\"] = node_port\n219:         \n220:         try:\n221:             result = self._core_api.create_namespaced_service(\n222:                 namespace=self.namespace,\n223:                 body=service_body,\n224:             )\n225:             actual_node_port = result.spec.ports[0].node_port\n226:         except kubernetes.client.exceptions.ApiException as e:\n227:             if e.status == 409:\n228:                 result = self._core_api.patch_namespaced_service(\n229:                     name=name,\n230:                     namespace=self.namespace,\n231:                     body=service_body,\n232:                 )\n233:                 actual_node_port = result.spec.ports[0].node_port\n234:             else:\n235:                 raise RuntimeError(f\"Failed to create service: {e}\")\n236:         \n237:         if self.verbose:\n238:             self._logger.info(f\"Created service {name} with NodePort {actual_node_port}\")\n239:         \n240:         return {\"name\": name, \"node_port\": actual_node_port}\n241: \n242:     def wait_for_deployment_ready(self, name: str, timeout: int = 120) -> None:\n243:         start = time.time()\n244:         while time.time() - start < timeout:\n245:             try:\n246:                 deployment = self._apps_api.read_namespaced_deployment(\n247:                     name=name,\n248:                     namespace=self.namespace,\n249:                 )\n250:                 if deployment.status.available_replicas == deployment.spec.replicas:\n251:                     if self.verbose:\n252:                         self._logger.info(f\"Deployment {name} is ready\")\n253:                     return\n254:             except kubernetes.client.exceptions.ApiException as e:\n255:                 if self.verbose:\n256:                     self._logger.warning(f\"Error checking deployment status: {e}\")\n257:             time.sleep(self.POLL_INTERVAL)\n258:         raise TimeoutError(f\"Deployment {name} not ready after {timeout}s\")\n259: \n260:     def get_agent_status(self, agent_name: str) -> Dict[str, Any]:\n261:         sanitized_name = self._sanitize_name(agent_name)\n262:         \n263:         try:\n264:             deployment = self._apps_api.read_namespaced_deployment(\n265:                 name=sanitized_name,\n266:                 namespace=self.namespace,\n267:             )\n268:             deployment_status = {\n269:                 \"name\": sanitized_name,\n270:                 \"replicas\": deployment.spec.replicas,\n271:                 \"available_replicas\": deployment.status.available_replicas or 0,\n272:                 \"ready_replicas\": deployment.status.ready_replicas or 0,\n273:             }\n274:         except kubernetes.client.exceptions.ApiException:\n275:             deployment_status = {\"name\": sanitized_name, \"status\": \"not_found\"}\n276:         \n277:         try:\n278:             service = self._core_api.read_namespaced_service(\n279:                 name=sanitized_name,\n280:                 namespace=self.namespace,\n281:             )\n282:             service_status = {\n283:                 \"name\": sanitized_name,\n284:                 \"node_port\": service.spec.ports[0].node_port,\n285:             }\n286:         except kubernetes.client.exceptions.ApiException:\n287:             service_status = {\"name\": sanitized_name, \"status\": \"not_found\"}\n288:         \n289:         return {\n290:             \"deployment\": deployment_status,\n291:             \"service\": service_status,\n292:         }\n293: \n294:     def delete_agent(self, agent_name: str) -> Dict[str, Any]:\n295:         sanitized_name = self._sanitize_name(agent_name)\n296:         \n297:         try:\n298:             self._apps_api.delete_namespaced_deployment(\n299:                 name=sanitized_name,\n300:                 namespace=self.namespace,\n301:                 body=kubernetes.client.V1DeleteOptions(),\n302:             )\n303:             deployment_deleted = True\n304:         except kubernetes.client.exceptions.ApiException:\n305:             deployment_deleted = False\n306:         \n307:         try:\n308:             self._core_api.delete_namespaced_service(\n309:                 name=sanitized_name,\n310:                 namespace=self.namespace,\n311:             )\n312:             service_deleted = True\n313:         except kubernetes.client.exceptions.ApiException:\n314:             service_deleted = False\n315:         \n316:         return {\n317:             \"deployment_deleted\": deployment_deleted,\n318:             \"service_deleted\": service_deleted,\n319:         }\n320: \n321:     def _ensure_namespace(self) -> None:\n322:         try:\n323:             self._core_api.read_namespace(name=self.namespace)\n324:         except kubernetes.client.exceptions.ApiException as e:\n325:             if e.status == 404:\n326:                 namespace_body = {\n327:                     \"apiVersion\": \"v1\",\n328:                     \"kind\": \"Namespace\",\n329:                     \"metadata\": {\"name\": self.namespace},\n330:                 }\n331:                 self._core_api.create_namespace(body=namespace_body)\n332:                 if self.verbose:\n333:                     self._logger.info(f\"Created namespace {self.namespace}\")\n334:             else:\n335:                 raise\n336: \n337:     def _sanitize_name(self, name: str) -> str:\n338:         sanitized = name.lower()\n339:         sanitized = re.sub(r\"[^a-z0-9-]\", \"-\", sanitized)\n340:         sanitized = re.sub(r\"-+\", \"-\", sanitized)\n341:         sanitized = sanitized.strip(\"-\")\n342:         return sanitized[:63] if sanitized else \"default\"\n\n(End of file - total 342 lines)\n</content>","metadata":{"preview":"import logging\nimport re\nimport time\nfrom typing import Any, Dict, Optional\n\nimport kubernetes\nimport kubernetes.client\nimport kubernetes.config\n\n\nclass KubernetesProvider:\n    NODE_PORT_MIN = 30000\n    NODE_PORT_MAX = 32767\n    DEFAULT_TIMEOUT = 120\n    POLL_INTERVAL = 2\n\n    def __init__(\n        self,\n        namespace: str = \"default\",\n        verbose: bool = False,","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/cmd/cli/agentcube/services/k8s_provider.py","time":{"start":1775878094342,"end":1775878094363}}}}
{"type":"tool_use","timestamp":1775878094366,"sessionID":"ses_2856b7b11ffeOMPvSSfB4W9F8Y","part":{"id":"prt_d7a95395c001mK8s3vosI8Ng6Q","messageID":"msg_d7a951221001bzG9iw2lL1oWKZ","sessionID":"ses_2856b7b11ffeOMPvSSfB4W9F8Y","type":"tool","tool":"read","callID":"toolu_tool-86a6fc76d6d24aaf94a434dba4ea5aa5","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/cmd/cli/agentcube/services/agentcube_provider.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/cmd/cli/agentcube/services/agentcube_provider.py</path>\n<type>file</type>\n<content>\n1: import logging\n2: import re\n3: from typing import Any, Dict, Optional\n4: \n5: import kubernetes\n6: import kubernetes.client\n7: import kubernetes.config\n8: \n9: \n10: class AgentCubeProvider:\n11:     CR_GROUP = \"runtime.agentcube.volcano.sh\"\n12:     CR_VERSION = \"v1alpha1\"\n13:     CR_PLURAL = \"agentruntimes\"\n14:     SESSION_TIMEOUT = \"15m\"\n15:     MAX_SESSION_DURATION = \"8h\"\n16:     DEFAULT_SECRET = \"default-secret\"\n17: \n18:     def __init__(\n19:         self,\n20:         namespace: str = \"default\",\n21:         verbose: bool = False,\n22:         kubeconfig: Optional[str] = None,\n23:     ) -> None:\n24:         self.namespace = namespace\n25:         self.verbose = verbose\n26:         self._logger = logging.getLogger(__name__)\n27: \n28:         if kubeconfig:\n29:             kubernetes.config.load_kube_config(config_file=kubeconfig)\n30:         else:\n31:             try:\n32:                 kubernetes.config.load_kube_config()\n33:             except kubernetes.config.ConfigException:\n34:                 kubernetes.config.load_incluster_config()\n35: \n36:         self._custom_api = kubernetes.client.CustomObjectsApi()\n37:         self._core_api = kubernetes.client.CoreV1Api()\n38: \n39:     def deploy_agent_runtime(\n40:         self,\n41:         agent_name: str,\n42:         image_url: str,\n43:         port: int,\n44:         entrypoint: Optional[str] = None,\n45:         env_vars: Optional[Dict[str, str]] = None,\n46:         workload_manager_url: Optional[str] = None,\n47:         router_url: Optional[str] = None,\n48:         readiness_probe_path: Optional[str] = None,\n49:         readiness_probe_port: Optional[int] = None,\n50:     ) -> Dict[str, Any]:\n51:         sanitized_name = self._sanitize_name(agent_name)\n52:         self._ensure_namespace()\n53:         \n54:         env_list = []\n55:         if workload_manager_url:\n56:             env_list.append({\"name\": \"WORKLOAD_MANAGER_URL\", \"value\": workload_manager_url})\n57:         if router_url:\n58:             env_list.append({\"name\": \"ROUTER_URL\", \"value\": router_url})\n59:         if env_vars:\n60:             for k, v in env_vars.items():\n61:                 if k not in [\"WORKLOAD_MANAGER_URL\", \"ROUTER_URL\"]:\n62:                     env_list.append({\"name\": k, \"value\": v})\n63:         \n64:         cr_body = {\n65:             \"apiVersion\": f\"{self.CR_GROUP}/{self.CR_VERSION}\",\n66:             \"kind\": \"AgentRuntime\",\n67:             \"metadata\": {\n68:                 \"name\": sanitized_name,\n69:                 \"namespace\": self.namespace,\n70:             },\n71:             \"spec\": {\n72:                 \"image\": image_url,\n73:                 \"port\": port,\n74:                 \"sessionTimeout\": self.SESSION_TIMEOUT,\n75:                 \"maxSessionDuration\": self.MAX_SESSION_DURATION,\n76:                 \"imagePullSecrets\": [{\"name\": self.DEFAULT_SECRET}],\n77:                 \"env\": env_list,\n78:                 \"readinessProbe\": {\n79:                     \"httpGet\": {\n80:                         \"path\": readiness_probe_path or \"/health\",\n81:                         \"port\": readiness_probe_port or port,\n82:                     },\n83:                 },\n84:             },\n85:         }\n86:         \n87:         if entrypoint:\n88:             cr_body[\"spec\"][\"entrypoint\"] = entrypoint\n89:         \n90:         try:\n91:             result = self._custom_api.create_namespaced_custom_object(\n92:                 group=self.CR_GROUP,\n93:                 version=self.CR_VERSION,\n94:                 namespace=self.namespace,\n95:                 plural=self.CR_PLURAL,\n96:                 body=cr_body,\n97:             )\n98:             status = \"created\"\n99:         except kubernetes.client.exceptions.ApiException as e:\n100:             if e.status == 409:\n101:                 result = self._custom_api.patch_namespaced_custom_object(\n102:                     group=self.CR_GROUP,\n103:                     version=self.CR_VERSION,\n104:                     namespace=self.namespace,\n105:                     plural=self.CR_PLURAL,\n106:                     name=sanitized_name,\n107:                     body=cr_body,\n108:                 )\n109:                 status = \"patched\"\n110:             elif e.status == 404 and \"AgentRuntime\" in str(e):\n111:                 raise ValueError(\n112:                     \"AgentRuntime CRD not installed. Install Volcano AgentCube CRDs\"\n113:                 )\n114:             else:\n115:                 raise RuntimeError(f\"Failed to deploy AgentRuntime CR: {e}\")\n116:         \n117:         agent_id = result.get(\"metadata\", {}).get(\"name\", sanitized_name)\n118:         agent_endpoint = None\n119:         if result.get(\"status\"):\n120:             agent_endpoint = result.get(\"status\", {}).get(\"agentEndpoint\")\n121:         \n122:         if self.verbose:\n123:             self._logger.info(f\"Deployed AgentRuntime {sanitized_name} with agent_id {agent_id}\")\n124:         \n125:         return {\n126:             \"deployment_name\": sanitized_name,\n127:             \"agent_id\": agent_id,\n128:             \"agent_endpoint\": agent_endpoint,\n129:             \"status\": status,\n130:         }\n131: \n132:     def get_agent_runtime(self, name: str, namespace: Optional[str] = None) -> Optional[Dict[str, Any]]:\n133:         ns = namespace or self.namespace\n134:         sanitized_name = self._sanitize_name(name)\n135:         \n136:         try:\n137:             result = self._custom_api.get_namespaced_custom_object(\n138:                 group=self.CR_GROUP,\n139:                 version=self.CR_VERSION,\n140:                 namespace=ns,\n141:                 plural=self.CR_PLURAL,\n142:                 name=sanitized_name,\n143:             )\n144:             return result\n145:         except kubernetes.client.exceptions.ApiException as e:\n146:             if e.status == 404:\n147:                 return None\n148:             raise\n149: \n150:     def delete_agent_runtime(self, name: str, namespace: Optional[str] = None) -> Dict[str, Any]:\n151:         ns = namespace or self.namespace\n152:         sanitized_name = self._sanitize_name(name)\n153:         \n154:         try:\n155:             self._custom_api.delete_namespaced_custom_object(\n156:                 group=self.CR_GROUP,\n157:                 version=self.CR_VERSION,\n158:                 namespace=ns,\n159:                 plural=self.CR_PLURAL,\n160:                 name=sanitized_name,\n161:                 body=kubernetes.client.V1DeleteOptions(),\n162:             )\n163:             return {\"deleted\": True, \"name\": sanitized_name}\n164:         except kubernetes.client.exceptions.ApiException as e:\n165:             if e.status == 404:\n166:                 return {\"deleted\": False, \"reason\": \"not_found\"}\n167:             raise RuntimeError(f\"Failed to delete AgentRuntime: {e}\")\n168: \n169:     def _ensure_namespace(self) -> None:\n170:         try:\n171:             self._core_api.read_namespace(name=self.namespace)\n172:         except kubernetes.client.exceptions.ApiException as e:\n173:             if e.status == 404:\n174:                 namespace_body = {\n175:                     \"apiVersion\": \"v1\",\n176:                     \"kind\": \"Namespace\",\n177:                     \"metadata\": {\"name\": self.namespace},\n178:                 }\n179:                 self._core_api.create_namespace(body=namespace_body)\n180:                 if self.verbose:\n181:                     self._logger.info(f\"Created namespace {self.namespace}\")\n182:             else:\n183:                 raise\n184: \n185:     def _sanitize_name(self, name: str) -> str:\n186:         sanitized = name.lower()\n187:         sanitized = re.sub(r\"[^a-z0-9-]\", \"-\", sanitized)\n188:         sanitized = re.sub(r\"-+\", \"-\", sanitized)\n189:         sanitized = sanitized.strip(\"-\")\n190:         return sanitized[:63] if sanitized else \"default\"\n\n(End of file - total 190 lines)\n</content>","metadata":{"preview":"import logging\nimport re\nfrom typing import Any, Dict, Optional\n\nimport kubernetes\nimport kubernetes.client\nimport kubernetes.config\n\n\nclass AgentCubeProvider:\n    CR_GROUP = \"runtime.agentcube.volcano.sh\"\n    CR_VERSION = \"v1alpha1\"\n    CR_PLURAL = \"agentruntimes\"\n    SESSION_TIMEOUT = \"15m\"\n    MAX_SESSION_DURATION = \"8h\"\n    DEFAULT_SECRET = \"default-secret\"\n\n    def __init__(\n        self,\n        namespace: str = \"default\",","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/cmd/cli/agentcube/services/agentcube_provider.py","time":{"start":1775878094346,"end":1775878094365}}}}
{"type":"tool_use","timestamp":1775878094369,"sessionID":"ses_2856b7b11ffeOMPvSSfB4W9F8Y","part":{"id":"prt_d7a953dea001upxdtlCQVf3FNk","messageID":"msg_d7a951221001bzG9iw2lL1oWKZ","sessionID":"ses_2856b7b11ffeOMPvSSfB4W9F8Y","type":"tool","tool":"read","callID":"toolu_tool-7789ed365b814a7dade4c3b324932cea","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/cmd/cli/agentcube/runtime/publish_runtime.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/cmd/cli/agentcube/runtime/publish_runtime.py</path>\n<type>file</type>\n<content>\n1: import logging\n2: import time\n3: from pathlib import Path\n4: from typing import Any, Dict, Optional\n5: \n6: from agentcube.services.metadata_service import AgentMetadata, MetadataService\n7: from agentcube.services.docker_service import DockerService\n8: \n9: \n10: class PublishRuntime:\n11:     def __init__(self, verbose: bool = False, provider: str = \"agentcube\") -> None:\n12:         self.verbose = verbose\n13:         self.provider = provider\n14:         self._metadata_service = MetadataService(verbose)\n15:         self._docker_service = DockerService(verbose)\n16:         self._logger = logging.getLogger(__name__)\n17: \n18:         if provider == \"k8s\":\n19:             from agentcube.services.k8s_provider import KubernetesProvider\n20:             self._k8s_provider = KubernetesProvider(verbose=verbose)\n21:         elif provider == \"agentcube\":\n22:             from agentcube.services.agentcube_provider import AgentCubeProvider\n23:             self._agentcube_provider = AgentCubeProvider(verbose=verbose)\n24:         else:\n25:             raise ValueError(f\"Invalid provider: {provider}. Must be 'agentcube' or 'k8s'\")\n26: \n27:     def publish(self, workspace_path: Path, **options: Any) -> Dict[str, Any]:\n28:         metadata = self._metadata_service.load_metadata(workspace_path)\n29:         metadata = self._apply_option_overrides(metadata, options)\n30:         self._validate_publish_prerequisites(workspace_path, metadata, options)\n31:         \n32:         try:\n33:             image_url = self._prepare_image_for_publishing(workspace_path, metadata, options)\n34:             \n35:             if self.provider == \"agentcube\":\n36:                 result = self._publish_cr_to_k8s(workspace_path, metadata, image_url, options)\n37:             else:\n38:                 result = self._publish_k8s(workspace_path, metadata, image_url, options)\n39:             \n40:             self._update_publish_metadata(workspace_path, metadata, result)\n41:             \n42:             return {\n43:                 \"agent_name\": metadata.agent_name,\n44:                 \"agent_id\": result.get(\"agent_id\"),\n45:                 \"agent_endpoint\": result.get(\"agent_endpoint\"),\n46:                 \"deployment_type\": result.get(\"deployment_type\"),\n47:                 \"namespace\": result.get(\"namespace\"),\n48:                 \"k8s_deployment\": result.get(\"k8s_deployment\"),\n49:                 \"status\": \"success\",\n50:             }\n51:         except Exception as e:\n52:             self._record_error_in_metadata(workspace_path, str(e))\n53:             raise\n54: \n55:     def _apply_option_overrides(\n56:         self, metadata: AgentMetadata, options: Dict[str, Any]\n57:     ) -> AgentMetadata:\n58:         if options.get(\"version\"):\n59:             metadata.version = options[\"version\"]\n60:         if options.get(\"image_url\"):\n61:             if not metadata.image:\n62:                 metadata.image = {}\n63:             metadata.image[\"url\"] = options[\"image_url\"]\n64:         if options.get(\"image_username\"):\n65:             metadata.registry_username = options[\"image_username\"]\n66:         if options.get(\"image_password\"):\n67:             metadata.registry_password = options[\"image_password\"]\n68:         if options.get(\"description\"):\n69:             metadata.description = options[\"description\"]\n70:         if options.get(\"region\"):\n71:             metadata.region = options[\"region\"]\n72:         if options.get(\"namespace\"):\n73:             pass\n74:         return metadata\n75: \n76:     def _validate_publish_prerequisites(\n77:         self, workspace_path: Path, metadata: AgentMetadata, options: Dict[str, Any]\n78:     ) -> None:\n79:         if self.provider == \"agentcube\":\n80:             if not metadata.router_url and not options.get(\"router_url\"):\n81:                 raise ValueError(\"router_url is required for agentcube provider in agent_metadata.yaml\")\n82:             if not metadata.workload_manager_url and not options.get(\"workload_manager_url\"):\n83:                 raise ValueError(\"workload_manager_url is required for agentcube provider\")\n84:         \n85:         if metadata.build_mode == \"local\":\n86:             image_url = options.get(\"image_url\") or (metadata.image.get(\"url\") if metadata.image else None)\n87:             if not image_url:\n88:                 raise ValueError(\"--image-url is required for local build mode\")\n89:             \n90:             if not self._docker_service.check_docker_available():\n91:                 raise RuntimeError(\"Docker is not available or not running\")\n92: \n93:         node_port = options.get(\"node_port\")\n94:         if node_port is not None:\n95:             if not (30000 <= node_port <= 32767):\n96:                 raise ValueError(\"NodePort must be in range 30000-32767\")\n97: \n98:     def _publish_cr_to_k8s(\n99:         self, \n100:         workspace_path: Path, \n101:         metadata: AgentMetadata, \n102:         image_url: str, \n103:         options: Dict[str, Any]\n104:     ) -> Dict[str, Any]:\n105:         namespace = options.get(\"namespace\") or \"default\"\n106:         self._agentcube_provider.namespace = namespace\n107:         \n108:         env_vars = {}\n109:         workload_manager_url = options.get(\"workload_manager_url\") or metadata.workload_manager_url\n110:         router_url = options.get(\"router_url\") or metadata.router_url\n111:         \n112:         if workload_manager_url:\n113:             env_vars[\"WORKLOAD_MANAGER_URL\"] = workload_manager_url\n114:         if router_url:\n115:             env_vars[\"ROUTER_URL\"] = router_url\n116:         \n117:         result = self._agentcube_provider.deploy_agent_runtime(\n118:             agent_name=metadata.agent_name,\n119:             image_url=image_url,\n120:             port=metadata.port,\n121:             entrypoint=metadata.entrypoint,\n122:             env_vars=env_vars,\n123:             workload_manager_url=workload_manager_url,\n124:             router_url=router_url,\n125:             readiness_probe_path=metadata.readiness_probe_path or \"/health\",\n126:             readiness_probe_port=metadata.readiness_probe_port or metadata.port,\n127:         )\n128:         \n129:         return {\n130:             \"agent_id\": result.get(\"agent_id\"),\n131:             \"agent_endpoint\": result.get(\"agent_endpoint\"),\n132:             \"deployment_type\": \"AgentRuntime\",\n133:             \"namespace\": namespace,\n134:             \"k8s_deployment\": {\n135:                 \"type\": \"AgentRuntime\",\n136:                 \"deployment_name\": result.get(\"deployment_name\"),\n137:                 \"namespace\": namespace,\n138:                 \"replicas\": 1,\n139:                 \"agent_id\": result.get(\"agent_id\"),\n140:                 \"status\": \"created\",\n141:             },\n142:         }\n143: \n144:     def _publish_k8s(\n145:         self, \n146:         workspace_path: Path, \n147:         metadata: AgentMetadata, \n148:         image_url: str, \n149:         options: Dict[str, Any]\n150:     ) -> Dict[str, Any]:\n151:         namespace = options.get(\"namespace\") or \"default\"\n152:         self._k8s_provider.namespace = namespace\n153:         \n154:         replicas = options.get(\"replicas\") or 1\n155:         node_port = options.get(\"node_port\")\n156:         \n157:         env_vars = {}\n158:         if metadata.workload_manager_url:\n159:             env_vars[\"WORKLOAD_MANAGER_URL\"] = metadata.workload_manager_url\n160:         if metadata.router_url:\n161:             env_vars[\"ROUTER_URL\"] = metadata.router_url\n162:         \n163:         result = self._k8s_provider.deploy_agent(\n164:             agent_name=metadata.agent_name,\n165:             image_url=image_url,\n166:             port=metadata.port,\n167:             entrypoint=metadata.entrypoint,\n168:             replicas=replicas,\n169:             node_port=node_port,\n170:             env_vars=env_vars,\n171:         )\n172:         \n173:         return {\n174:             \"agent_endpoint\": result.get(\"service_url\"),\n175:             \"deployment_type\": \"Deployment\",\n176:             \"namespace\": namespace,\n177:             \"k8s_deployment\": {\n178:                 \"type\": \"Deployment\",\n179:                 \"deployment_name\": result.get(\"deployment_name\"),\n180:                 \"service_name\": result.get(\"service_name\"),\n181:                 \"namespace\": namespace,\n182:                 \"replicas\": replicas,\n183:                 \"node_port\": result.get(\"node_port\"),\n184:                 \"service_url\": result.get(\"service_url\"),\n185:                 \"status\": \"ready\",\n186:             },\n187:         }\n188: \n189:     def _prepare_image_for_publishing(\n190:         self, \n191:         workspace_path: Path, \n192:         metadata: AgentMetadata, \n193:         options: Dict[str, Any]\n194:     ) -> str:\n195:         if metadata.build_mode == \"cloud\":\n196:             return self._prepare_cloud_image(workspace_path, metadata, options)\n197:         return self._prepare_local_image(workspace_path, metadata, options)\n198: \n199:     def _prepare_local_image(\n200:         self, \n201:         workspace_path: Path, \n202:         metadata: AgentMetadata, \n203:         options: Dict[str, Any]\n204:     ) -> str:\n205:         image_url = options.get(\"image_url\") or (metadata.image.get(\"url\") if metadata.image else None)\n206:         if not image_url:\n207:             raise ValueError(\"--image-url is required for local build mode\")\n208:         \n209:         assert image_url is not None\n210:         \n211:         image_name = metadata.agent_name\n212:         tag = metadata.version or \"latest\"\n213:         local_image = f\"{image_name}:{tag}\"\n214:         \n215:         registry_url = image_url\n216:         if \"/\" in registry_url:\n217:             registry_url = registry_url.rsplit(\"/\", 1)[0]\n218:         \n219:         username = options.get(\"image_username\") or metadata.registry_username\n220:         password = options.get(\"image_password\") or metadata.registry_password\n221:         \n222:         if username and password:\n223:             self._docker_service._get_client().login(\n224:                 username=username,\n225:                 password=password,\n226:                 registry=registry_url,\n227:             )\n228:         \n229:         full_image_name = image_url\n230:         if not image_url.endswith(f\":{tag}\"):\n231:             full_image_name = f\"{image_url}:{tag}\"\n232:         \n233:         self._docker_service._get_client().images.push(full_image_name)\n234:         \n235:         return full_image_name\n236: \n237:     def _prepare_cloud_image(\n238:         self, \n239:         workspace_path: Path, \n240:         metadata: AgentMetadata, \n241:         options: Dict[str, Any]\n242:     ) -> str:\n243:         image_url = options.get(\"image_url\") or (metadata.image.get(\"url\") if metadata.image else None)\n244:         if not image_url:\n245:             raise ValueError(\"image_url is required for cloud build mode\")\n246:         return image_url\n247: \n248:     def _update_publish_metadata(\n249:         self, \n250:         workspace_path: Path, \n251:         metadata: AgentMetadata, \n252:         result: Dict[str, Any]\n253:     ) -> None:\n254:         if result.get(\"agent_id\"):\n255:             metadata.agent_id = result[\"agent_id\"]\n256:         if result.get(\"agent_endpoint\"):\n257:             metadata.agent_endpoint = result[\"agent_endpoint\"]\n258:         if result.get(\"k8s_deployment\"):\n259:             metadata.k8s_deployment = result[\"k8s_deployment\"]\n260:         self._metadata_service.save_metadata(workspace_path, metadata)\n261: \n262:     def _record_error_in_metadata(self, workspace_path: Path, error_msg: str) -> None:\n263:         try:\n264:             metadata = self._metadata_service.load_metadata(workspace_path)\n265:             metadata.k8s_deployment = {\n266:                 \"status\": \"error\",\n267:                 \"error\": error_msg,\n268:             }\n269:             self._metadata_service.save_metadata(workspace_path, metadata)\n270:         except Exception:\n271:             pass\n\n(End of file - total 271 lines)\n</content>","metadata":{"preview":"import logging\nimport time\nfrom pathlib import Path\nfrom typing import Any, Dict, Optional\n\nfrom agentcube.services.metadata_service import AgentMetadata, MetadataService\nfrom agentcube.services.docker_service import DockerService\n\n\nclass PublishRuntime:\n    def __init__(self, verbose: bool = False, provider: str = \"agentcube\") -> None:\n        self.verbose = verbose\n        self.provider = provider\n        self._metadata_service = MetadataService(verbose)\n        self._docker_service = DockerService(verbose)\n        self._logger = logging.getLogger(__name__)\n\n        if provider == \"k8s\":\n            from agentcube.services.k8s_provider import KubernetesProvider\n            self._k8s_provider = KubernetesProvider(verbose=verbose)","truncated"