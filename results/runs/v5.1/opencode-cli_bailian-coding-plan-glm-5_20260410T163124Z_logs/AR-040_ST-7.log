  )\n105:         assert session_id == \"session-123\"\n106:         call_args = client.session.post.call_args\n107:         assert call_args.kwargs[\"json\"][\"metadata\"] == {\"key\": \"value\"}\n108: \n109:     def test_create_session_metadata_null(self) -> None:\n110:         client = ControlPlaneClient(workload_manager_url=\"http://wm\")\n111:         mock_response = MagicMock()\n112:         mock_response.json.return_value = {\"sessionId\": \"session-123\"}\n113:         mock_response.raise_for_status = MagicMock()\n114:         client.session.post = MagicMock(return_value=mock_response)\n115: \n116:         session_id = client.create_session(name=\"test\", namespace=\"default\")\n117:         assert session_id == \"session-123\"\n118:         call_args = client.session.post.call_args\n119:         assert call_args.kwargs[\"json\"][\"metadata\"] is None\n120: \n121: \n122: class TestDeleteSession:\n123:     def test_delete_session_success(self) -> None:\n124:         client = ControlPlaneClient(workload_manager_url=\"http://wm\")\n125:         mock_response = MagicMock()\n126:         mock_response.raise_for_status = MagicMock()\n127:         client.session.delete = MagicMock(return_value=mock_response)\n128: \n129:         result = client.delete_session(\"session-123\")\n130:         assert result == True\n131: \n132:     def test_delete_session_404_returns_true(self) -> None:\n133:         client = ControlPlaneClient(workload_manager_url=\"http://wm\")\n134:         mock_response = MagicMock()\n135:         mock_response.status_code = 404\n136:         http_error = requests.HTTPError()\n137:         http_error.response = mock_response\n138:         client.session.delete = MagicMock(side_effect=http_error)\n139: \n140:         result = client.delete_session(\"session-123\")\n141:         assert result == True\n142: \n143:     def test_delete_session_other_failure(self) -> None:\n144:         client = ControlPlaneClient(workload_manager_url=\"http://wm\")\n145:         mock_response = MagicMock()\n146:         mock_response.status_code = 500\n147:         http_error = requests.HTTPError()\n148:         http_error.response = mock_response\n149:         client.session.delete = MagicMock(side_effect=http_error)\n150: \n151:         result = client.delete_session(\"session-123\")\n152:         assert result == False\n153: \n154:     def test_delete_session_request_exception(self) -> None:\n155:         client = ControlPlaneClient(workload_manager_url=\"http://wm\")\n156:         client.session.delete = MagicMock(side_effect=requests.RequestException())\n157: \n158:         result = client.delete_session(\"session-123\")\n159:         assert result == False\n160: \n161: \n162: class TestClose:\n163:     def test_close_session(self) -> None:\n164:         client = ControlPlaneClient(workload_manager_url=\"http://wm\")\n165:         mock_close = MagicMock()\n166:         client.session.close = mock_close\n167: \n168:         client.close()\n169:         mock_close.assert_called_once()\n\n(End of file - total 169 lines)\n</content>","metadata":{"preview":"import pytest\nfrom unittest.mock import MagicMock, patch, mock_open\nimport requests\n\nfrom agentcube.clients.control_plane import ControlPlaneClient\n\n\nclass TestControlPlaneClientInit:\n    def test_init_default_timeout(self) -> None:\n        with patch(\"agentcube.clients.control_plane.ControlPlaneClient._resolve_url\", return_value=\"http://wm\"):\n            with patch(\"agentcube.clients.control_plane.ControlPlaneClient._resolve_token\", return_value=\"\"):\n                client = ControlPlaneClient(workload_manager_url=\"http://wm\")\n                assert client.timeout == 120\n                assert client.connect_timeout == 5.0\n\n    def test_init_custom_timeout(self) -> None:\n        with patch(\"agentcube.clients.control_plane.ControlPlaneClient._resolve_url\", return_value=\"http://wm\"):\n            with patch(\"agentcube.clients.control_plane.ControlP