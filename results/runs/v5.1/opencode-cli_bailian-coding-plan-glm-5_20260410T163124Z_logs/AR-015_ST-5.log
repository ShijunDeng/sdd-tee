err := c.ShouldBindJSON(&req); err != nil {\n\t\t\tc.JSON(400, gin.H{\"error\": \"invalid request body\"})\n\t\t\treturn\n\t\t}\n\n\t\tpath = req.Path\n\t\tmodeStr = req.Mode\n\n\t\tdecoded, err := base64.StdEncoding.DecodeString(req.Content)\n\t\tif err != nil {\n\t\t\tc.JSON(400, gin.H{\"error\": \"invalid base64 content\"})\n\t\t\treturn\n\t\t}\n\t\tcontent = decoded\n\t}\n\n\tsanitizedPath, err := sanitizePath(s.workspace, path)\n\tif err != nil {\n\t\tc.JSON(400, gin.H{\"error\": fmt.Sprintf(\"invalid path: %s\", err.Error())})\n\t\treturn\n\t}\n\n\tmode, err := parseFileMode(modeStr)\n\tif err != nil {\n\t\tc.JSON(400, gin.H{\"error\": err.Error()})\n\t\treturn\n\t}\n\n\tparentDir := filepath.Dir(sanitizedPath)\n\tif err := os.MkdirAll(parentDir, 0755); err != nil {\n\t\tc.JSON(500, gin.H{\"error\": \"failed to create parent directories\"})\n\t\treturn\n\t}\n\n\tif err := os.WriteFile(sanitizedPath, content, mode); err != nil {\n\t\tc.JSON(500, gin.H{\"error\": \"failed to write file\"})\n\t\treturn\n\t}\n\n\tinfo, err := os.Stat(sanitizedPath)\n\tif err != nil {\n\t\tc.JSON(500, gin.H{\"error\": \"failed to get file info\"})\n\t\treturn\n\t}\n\n\tc.JSON(200, FileInfo{\n\t\tPath:     path,\n\t\tSize:     info.Size(),\n\t\tMode:     fmt.Sprintf(\"%04o\", info.Mode().Perm()),\n\t\tModified: info.ModTime(),\n\t})\n}\n\nfunc (s *Server) ListFilesHandler(c *gin.Context) {\n\tpath := c.Query(\"path\")\n\tif path == \"\" {\n\t\tc.JSON(400, gin.H{\"error\": \"missing path parameter\"})\n\t\treturn\n\t}\n\n\tsanitizedPath, err := sanitizePath(s.workspace, path)\n\tif err != nil {\n\t\tc.JSON(400, gin.H{\"error\": fmt.Sprintf(\"invalid path: %s\", err.Error())})\n\t\treturn\n\t}\n\n\tentries, err := os.ReadDir(sanitizedPath)\n\tif err != nil {\n\t\tc.JSON(500, gin.H{\"error\": \"failed to read directory\"})\n\t\treturn\n\t}\n\n\tfiles := []FileEntry{}\n\tfor _, entry := range entries {\n\t\tinfo, err := entry.Info()\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\n\t\tfil