sePKIXPublicKey(block.Bytes)\n54: \tif err != nil {\n55: \t\treturn nil, fmt.Errorf(\"failed to parse public key: %w\", err)\n56: \t}\n57: \n58: \trsaPub, ok := pub.(*rsa.PublicKey)\n59: \tif !ok {\n60: \t\treturn nil, errors.New(\"public key is not RSA\")\n61: \t}\n62: \n63: \treturn rsaPub, nil\n64: }\n65: \n66: func (a *AuthManager) AuthMiddleware() gin.HandlerFunc {\n67: \treturn func(c *gin.Context) {\n68: \t\tauthHeader := c.GetHeader(\"Authorization\")\n69: \t\tif authHeader == \"\" {\n70: \t\t\tc.JSON(401, gin.H{\"error\": \"missing authorization header\"})\n71: \t\t\tc.Abort()\n72: \t\t\treturn\n73: \t\t}\n74: \n75: \t\tif !strings.HasPrefix(authHeader, \"Bearer \") {\n76: \t\t\tc.JSON(401, gin.H{\"error\": \"invalid token format\"})\n77: \t\t\tc.Abort()\n78: \t\t\treturn\n79: \t\t}\n80: \n81: \t\ttokenString := strings.TrimPrefix(authHeader, \"Bearer \")\n82: \n83: \t\ta.mutex.RLock()\n84: \t\tpubKey := a.publicKey\n85: \t\ta.mutex.RUnlock()\n86: \n87: \t\ttoken, err := jwt.Parse(tokenString, func(token *jwt.Token) (interface{}, error) {\n88: \t\t\tif _, ok := token.Method.(*jwt.SigningMethodRSA); !ok {\n89: \t\t\t\treturn nil, fmt.Errorf(\"invalid signing method\")\n90: \t\t\t}\n91: \t\t\treturn pubKey, nil\n92: \t\t}, jwt.WithExpirationRequired(), jwt.WithIssuedAt(), jwt.WithLeeway(time.Minute))\n93: \n94: \t\tif err != nil {\n95: \t\t\tif errors.Is(err, jwt.ErrTokenExpired) {\n96: \t\t\t\tc.JSON(401, gin.H{\"error\": \"token is expired\"})\n97: \t\t\t} else if errors.Is(err, jwt.ErrTokenSignatureInvalid) {\n98: \t\t\t\tc.JSON(401, gin.H{\"error\": \"invalid signature\"})\n99: \t\t\t} else if strings.Contains(err.Error(), \"invalid signing method\") {\n100: \t\t\t\tc.JSON(401, gin.H{\"error\": \"invalid signing method\"})\n101: \t\t\t} else {\n102: \t\t\t\tc.JSON(401, gin.H{\"error\": err.Error()})\n103: \t\t\t}\n104: \t\t\tc.Abort()\n105: \t\t\treturn\n106: \t\t}\n107: \n108: \t\tif !token.Valid {\n109: \t\t\tc.JSON(401, gin.H{\"error\": \"invalid token\"})\n110: \t\t\tc.Abort()\n111: \t\t\treturn\n112: \t\t}\n113: \n114: \t\thttp.MaxBytesReader(c.Writer, c.Request.Body, MaxBodySize)\n115: \t\tc.Next()\n116: \t}\n117: }\n118: \n119: func (a *AuthManager) SetPublicKey(key *rsa.PublicKey) {\n120: \ta.mutex.Lock()\n121: \ta.publicKey = key\n122: \ta.mutex.Unlock()\n123: }\n124: \n125: func (a *AuthManager) GetPublicKey() *rsa.PublicKey {\n126: \ta.mutex.RLock()\n127: \tdefer a.mutex.RUnlock()\n128: \treturn a.publicKey\n129: }\n\n(End of file - total 129 lines)\n</content>","metadata":{"preview":"package picod\n\nimport (\n\t\"crypto/rsa\"\n\t\"crypto/x509\"\n\t\"encoding/pem\"\n\t\"errors\"\n\t\"fmt\"\n\t\"net/http\"\n\t\"strings\"\n\t\"sync\"\n\t\"time\"\n\n\t\"github.com/gin-gonic/gin\"\n\t\"github.com/golang-jwt/jwt/v5\"\n)\n\nconst (\n\tPublicKeyEnvVar = \"PICOD_AUTH_PUBLIC_KEY\"\n\tMaxBodySize     = 32 << 20","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/picod/auth.go","time":{"start":1775861009806,"end":1775861009822}}}}
