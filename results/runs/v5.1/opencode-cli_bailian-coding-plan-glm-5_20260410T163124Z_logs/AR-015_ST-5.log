g := DefaultLifecycleConfig()\n43: \tlifecycleManager := NewSandboxLifecycleManager(k8sClient, store, lifecycleConfig, logger)\n44: \tgarbageCollector := NewGarbageCollector(lifecycleManager, lifecycleConfig.GCInterval, lifecycleConfig.GCOnceTimeout, logger)\n45: \n46: \treturn &HTTPServer{\n47: \t\tserver:           &http.Server{Addr: cfg.Addr},\n48: \t\trouter:           chi.NewRouter(),\n49: \t\tconfig:           cfg,\n50: \t\thandlers:         make(map[string]Handler),\n51: \t\tlogger:           logger,\n52: \t\tstopCh:           make(chan struct{}),\n53: \t\tlifecycleManager: lifecycleManager,\n54: \t\tgarbageCollector: garbageCollector,\n55: \t\tstore:            store,\n56: \t\tk8sClient:        k8sClient,\n57: \t}\n58: }\n59: \n60: // RegisterHandler stores a handler and registers its routes on the router.\n61: func (s *HTTPServer) RegisterHandler(name string, h Handler) {\n62: \ts.handlers[name] = h\n63: \th.Register(s.router)\n64: }\n65: \n66: // Start begins listening and serving HTTP requests.\n67: // It returns an error channel that receives non-ErrServerClosed errors.\n68: func (s *HTTPServer) Start() <-chan error {\n69: \terrCh := make(chan error, 1)\n70: \ts.server.ReadTimeout = s.config.ReadTimeout\n71: \ts.server.WriteTimeout = s.config.WriteTimeout\n72: \ts.server.IdleTimeout = s.config.IdleTimeout\n73: \ts.server.Handler = s.router\n74: \n75: \tif s.garbageCollector != nil {\n76: \t\ts.garbageCollector.Start()\n77: \t}\n78: \n79: \tgo func() {\n80: \t\tif err := s.server.ListenAndServe(); err != http.ErrServerClosed {\n81: \t\t\terrCh <- err\n82: \t\t}\n83: \t}()\n84: \treturn errCh\n85: }\n86: \n87: func (s *HTTPServer) Stop(ctx context.Context) error {\n88: \tif s.garbageCollector != nil {\n89: \t\ts.garbageCollector.Stop()\n90: \t}\n91: \n92: \tctx, cancel := context.WithTimeout(ctx, s.config.ShutdownTimeout)\n93: \tdefer cancel()\n94: \terr := s.server.Shutdown(ctx)\n95: \tclose(s.stopCh)\n96: \treturn err\n97: }\n98: \n99: // GracefulShutdown sets up signal handlers for SIGTERM and SIGINT.\n100: // When a signal is received, the server is stopped gracefully.\n101: func (s *HTTPServer) GracefulShutdown() {\n102: \tsigCh := make(chan os.Signal, 1)\n103: \tsignal.Notify(sigCh, syscall.SIGTERM, syscall.SIGINT)\n104: \tgo func() {\n105: \t\t<-sigCh\n106: \t\tctx := context.Background()\n107: \t\ts.Stop(ctx)\n108: \t}()\n109: }\n\n(End of file - total 109 lines)\n</content>","metadata":{"preview":"package workloadmanager\n\nimport (\n\t\"context\"\n\t\"net/http\"\n\t\"os\"\n\t\"os/signal\"\n\t\"syscall\"\n\n\t\"github.com/go-chi/chi/v5\"\n)\n\n// HTTPServer manages the HTTP server lifecycle including graceful shutdown.\ntype HTTPServer struct {\n\tserver           *http.Server\n\trouter           chi.Router\n\tconfig           Config\n\thandlers         map[string]Handler\n\tlogger           Logger\n\tstopCh           chan struct{}","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/server.go","time":{"start":1775860907286,"end":1775860907300}}}}
