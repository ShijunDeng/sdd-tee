)\n55: \tif err != nil {\n56: \t\treturn defaultFileMode, nil\n57: \t}\n58: \n59: \tif mode > maxFileMode {\n60: \t\treturn 0, errors.New(\"invalid file mode\")\n61: \t}\n62: \n63: \treturn os.FileMode(mode), nil\n64: }\n65: \n66: func (s *Server) UploadFileHandler(c *gin.Context) {\n67: \tcontentType := c.ContentType()\n68: \n69: \tvar path string\n70: \tvar content []byte\n71: \tvar modeStr string\n72: \n73: \tif contentType == \"multipart/form-data\" {\n74: \t\tpath = c.PostForm(\"path\")\n75: \t\tif path == \"\" {\n76: \t\t\tc.JSON(400, gin.H{\"error\": \"missing path parameter\"})\n77: \t\t\treturn\n78: \t\t}\n79: \n80: \t\tfileHeader, err := c.FormFile(\"file\")\n81: \t\tif err != nil {\n82: \t\t\tc.JSON(400, gin.H{\"error\": \"missing file\"})\n83: \t\t\treturn\n84: \t\t}\n85: \n86: \t\tfile, err := fileHeader.Open()\n87: \t\tif err != nil {\n88: \t\t\tc.JSON(500, gin.H{\"error\": \"failed to open file\"})\n89: \t\t\treturn\n90: \t\t}\n91: \t\tdefer file.Close()\n92: \n93: \t\tcontent, err = io.ReadAll(file)\n94: \t\tif err != nil {\n95: \t\t\tc.JSON(500, gin.H{\"error\": \"failed to read file\"})\n96: \t\t\treturn\n97: \t\t}\n98: \n99: \t\tmodeStr = c.PostForm(\"mode\")\n100: \t} else {\n101: \t\tvar req UploadFileRequest\n102: \t\tif err := c.ShouldBindJSON(&req); err != nil {\n103: \t\t\tc.JSON(400, gin.H{\"error\": \"invalid request body\"})\n104: \t\t\treturn\n105: \t\t}\n106: \n107: \t\tpath = req.Path\n108: \t\tmodeStr = req.Mode\n109: \n110: \t\tdecoded, err := base64.StdEncoding.DecodeString(req.Content)\n111: \t\tif err != nil {\n112: \t\t\tc.JSON(400, gin.H{\"error\": \"invalid base64 content\"})\n113: \t\t\treturn\n114: \t\t}\n115: \t\tcontent = decoded\n116: \t}\n117: \n118: \tsanitizedPath, err := sanitizePath(s.workspace, path)\n119: \tif err != nil {\n120: \t\tc.JSON(400, gin.H{\"error\": fmt.Sprintf(\"invalid path: %s\", err.Error())})\n121: \t\treturn\n122: \t}\n123: \n124: \tmode, err := parseFileMode(modeStr)\n125: \tif err != nil {\n126: \t\tc.JSON(400, gin.H{\"error\": err.Error()})\n127: \t\treturn\n128: \t}\n129: \n130: \tparentDir := filepath.Dir(sanitizedPath)\n131: \tif err := os.MkdirAll(parentDir, 0755); err != nil {\n132: \t\tc.JSON(500, gin.H{\"error\": \"failed to create parent directories\"})\n133: \t\treturn\n134: \t}\n135: \n136: \tif err := os.WriteFile(sanitizedPath, content, mode); err != nil {\n137: \t\tc.JSON(500, gin.H{\"error\": \"failed to write file\"})\n138: \t\treturn\n139: \t}\n140: \n141: \tinfo, err := os.Stat(sanitizedPath)\n142: \tif err != nil {\n143: \t\tc.JSON(500, gin.H{\"error\": \"failed to get file info\"})\n144: \t\treturn\n145: \t}\n146: \n147: \tc.JSON(200, FileInfo{\n148: \t\tPath:     path,\n149: \t\tSize:     info.Size(),\n150: \t\tMode:     fmt.Sprintf(\"%04o\", info.Mode().Perm()),\n151: \t\tModified: info.ModTime(),\n152: \t})\n153: }\n154: \n155: func (s *Server) ListFilesHandler(c *gin.Context) {\n156: \tpath := c.Query(\"path\")\n157: \tif path == \"\" {\n158: \t\tc.JSON(400, gin.H{\"error\": \"missing path parameter\"})\n159: \t\treturn\n160: \t}\n161: \n162: \tsanitizedPath, err := sanitizePath(s.workspace, path)\n163: \tif err != nil {\n164: \t\tc.JSON(400, gin.H{\"error\": fmt.Sprintf(\"invalid path: %s\", err.Error())})\n165: \t\treturn\n166: \t}\n167: \n168: \tentries, err := os.ReadDir(sanitizedPath)\n169: \tif err != nil {\n170: \t\tc.JSON(500, gin.H{\"error\": \"failed to read directory\"})\n171: \t\treturn\n172: \t}\n173: \n174: \tfiles := []FileEntry{}\n175: \tfor _, entry := range entries {\n176: \t\tinfo, err := entry.Info()\n177: \t\tif err != nil {\n178: \t\t\tcontinue\n179: \t\t}\n180: \n181: \t\tfiles = append(files, FileEntry{\n182: \t\t\tName:     entry.Name(),\n183: \t\t\tSize:     info.Size(),\n184: \t\t\tModified: info.ModTime(),\n185: \t\t\tMode:     fmt.Sprintf(\"%04o\", info.Mode().Perm()),\n186: \t\t\tIsDir:    entry.IsDir(),\n187: \t\t})\n188: \t}\n189: \n190: \tc.JSON(200, ListFilesResponse{\n191: \t\tFiles: files,\n192: \t\tPath:  path,\n193: \t})\n194: }\n195: \n196: func (s *Server) DownloadFileHandler(c *gin.Context) {\n197: \treqPath := c.Param(\"path\")\n198: \treqPath = strings.TrimPrefix(reqPath, \"/\")\n199: \n200: \tsanitizedPath, err := sanitizePath(s.workspace, reqPath)\n201: \tif err != nil {\n202: \t\tc.JSON(400, gin.H{\"error\": fmt.Sprintf(\"invalid path: %s\", err.Error())})\n203: \t\treturn\n204: \t}\n205: \n206: \tinfo, err := os.Stat(sanitizedPath)\n207: \tif err != nil {\n208: \t\tif os.IsNotExist(err) {\n209: \t\t\tc.JSON(404, gin.H{\"error\": \"file not found\"})\n210: \t\t} else {\n211: \t\t\tc.JSON(500, gin.H{\"error\": \"failed to stat file\"})\n212: \t\t}\n213: \t\treturn\n214: \t}\n215: \n216: \tif info.IsDir() {\n217: \t\tc.JSON(400, gin.H{\"error\": \"path is not a file\"})\n218: \t\treturn\n219: \t}\n220: \n221: \tcontentType := mime.TypeByExtension(filepath.Ext(sanitizedPath))\n222: \tif contentType == \"\" {\n223: \t\tcontentType = \"application/octet-stream\"\n224: \t}\n225: \n226: \tfilename := filepath.Base(sanitizedPath)\n227: \tc.Header(\"Content-Type\", contentType)\n228: \tc.Header(\"Content-Disposition\", fmt.Sprintf(\"attachment; filename=\\\"%s\\\"\", filename))\n229: \tc.File(sanitizedPath)\n230: }\n\n(End of file - total 230 lines)\n</content>","metadata":{"preview":"package picod\n\nimport (\n\t\"encoding/base64\"\n\t\"errors\"\n\t\"fmt\"\n\t\"io\"\n\t\"mime\"\n\t\"net/http\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"strconv\"\n\t\"time\"\n\n\t\"github.com/gin-gonic/gin\"\n)\n\nconst (\n\tmaxFileMode     = 0777\n\tdefaultFileMode = 0644","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/picod/files.go","time":{"start":1775861009811,"end":1775861009826}}}}
