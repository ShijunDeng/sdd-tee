s{}\n42: \t\tclientConfig := clientcmd.NewNonInteractiveDeferredLoadingClientConfig(loadingRules, configOverrides)\n43: \t\tconfig, err = clientConfig.ClientConfig()\n44: \t\tif err != nil {\n45: \t\t\treturn nil, fmt.Errorf(\"failed to get kubernetes config: %w\", err)\n46: \t\t}\n47: \t}\n48: \n49: \tk8sClient, err := kubernetes.NewForConfig(config)\n50: \tif err != nil {\n51: \t\treturn nil, fmt.Errorf(\"failed to create k8s client: %w\", err)\n52: \t}\n53: \n54: \tdynamicClient, err := dynamic.NewForConfig(config)\n55: \tif err != nil {\n56: \t\treturn nil, fmt.Errorf(\"failed to create dynamic client: %w\", err)\n57: \t}\n58: \n59: \tagentCubeClient, err := versioned.NewForConfig(config)\n60: \tif err != nil {\n61: \t\treturn nil, fmt.Errorf(\"failed to create agentcube client: %w\", err)\n62: \t}\n63: \n64: \treturn &TestContext{\n65: \t\tNamespace:          namespace,\n66: \t\tWorkloadManagerURL: wmURL,\n67: \t\tRouterURL:          routerURL,\n68: \t\tAPIToken:           apiToken,\n69: \t\tK8sClient:          k8sClient,\n70: \t\tDynamicClient:      dynamicClient,\n71: \t\tRESTConfig:         config,\n72: \t\tAgentCubeClient:    agentCubeClient,\n73: \t\tTestID:             uuid.New().String()[:8],\n74: \t\tStartTime:          time.Now(),\n75: \t\tCleanupFuncs:       []func(){},\n76: \t}, nil\n77: }\n78: \n79: func (tc *TestContext) AddCleanup(fn func()) {\n80: \ttc.cleanupMutex.Lock()\n81: \tdefer tc.cleanupMutex.Unlock()\n82: \ttc.CleanupFuncs = append(tc.CleanupFuncs, fn)\n83: }\n84: \n85: func (tc *TestContext) Cleanup() {\n86: \ttc.cleanupMutex.Lock()\n87: \tdefer tc.cleanupMutex.Unlock()\n88: \tfor i := len(tc.CleanupFuncs) - 1; i >= 0; i-- {\n89: \t\ttc.CleanupFuncs[i]()\n90: \t}\n91: \ttc.CleanupFuncs = nil\n92: }\n93: \n94: func (tc *TestContext) EnsureNamespace(ctx context.Context) error {\n95: \t_, err := tc.K8sClient.CoreV1().Namespaces().Get(ctx, tc.Namespace, metav1.GetOptions{})\n96: \tif errors.IsNotFound(err) {\n97: \t\tns := &corev1.Namespace{\n98: \t\t\tObjectMeta: metav1.ObjectMeta{\n99: \t\t\t\tName: tc.Namespace,\n100: \t\t\t\tLabels: map[string]string{\n101: \t\t\t\t\t\"agentcube-e2e-test\": tc.TestID,\n102: \t\t\t\t},\n103: \t\t\t},\n104: \t\t}\n105: \t\t_, err = tc.K8sClient.CoreV1().Namespaces().Create(ctx, ns, metav1.CreateOptions{})\n106: \t\tif err != nil {\n107: \t\t\treturn fmt.Errorf(\"failed to create namespace %s: %w\", tc.Namespace, err)\n108: \t\t}\n109: \t\ttc.AddCleanup(func() {\n110: \t\t\tdeleteCtx := context.Background()\n111: \t\t\t_ = tc.K8sClient.CoreV1().Namespaces().Delete(deleteCtx, tc.Namespace, metav1.DeleteOptions{})\n112: \t\t})\n113: \t\treturn nil\n114: \t}\n115: \treturn err\n116: }\n117: \n118: func SetupTestContext(t *testing.T) *TestContext {\n119: \tnamespace := os.Getenv(\"AGENTCUBE_NAMESPACE\")\n120: \tif namespace == \"\" {\n121: \t\tnamespace = \"agentcube-e2e\"\n122: \t}\n123: \n124: \twmURL := os.Getenv(\"WORKLOAD_MANAGER_URL\")\n125: \tif wmURL == \"\" {\n126: \t\twmURL = \"http://localhost:8080\"\n127: \t}\n128: \n129: \trouterURL := os.Getenv(\"ROUTER_URL\")\n130: \tif routerURL == \"\" {\n131: \t\trouterURL = \"http://localhost:8081\"\n132: \t}\n133: \n134: \tapiToken := os.Getenv(\"API_TOKEN\")\n135: \tif apiToken == \"\" {\n136: \t\tsaToken, err := ReadServiceAccountToken()\n137: \t\tif err != nil {\n138: \t\t\tt.Logf(\"Warning: Could not read service account token: %v\", err)\n139: \t\t}\n140: \t\tapiToken = saToken\n141: \t}\n142: \n143: \ttc, err := NewTestContext(namespace, wmURL, routerURL, apiToken)\n144: \tif err != nil {\n145: \t\tt.Fatalf(\"Failed to create test context: %v\", err)\n146: \t}\n147: \n148: \tctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)\n149: \tdefer cancel()\n150: \n151: \tif err := tc.EnsureNamespace(ctx); err != nil {\n152: \t\tt.Fatalf(\"Failed to ensure namespace: %v\", err)\n153: \t}\n154: \n155: \treturn tc\n156: }\n157: \n158: func ReadServiceAccountToken() (string, error) {\n159: \ttokenPath :