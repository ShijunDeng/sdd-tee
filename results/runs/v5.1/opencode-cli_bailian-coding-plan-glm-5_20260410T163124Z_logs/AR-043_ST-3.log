n34: \t// +kubebuilder:validation:Required\n35: \tTemplate *SandboxTemplate `json:\"podTemplate\" protobuf:\"bytes,1,opt,name=podTemplate\"`\n36: \n37: \t// SessionTimeout specifies the idle timeout for a session.\n38: \t// Default is 15 minutes.\n39: \t// +kubebuilder:validation:Required\n40: \t// +kubebuilder:default=\"15m\"\n41: \tSessionTimeout *metav1.Duration `json:\"sessionTimeout,omitempty\" protobuf:\"bytes,2,opt,name=sessionTimeout\"`\n42: \n43: \t// MaxSessionDuration specifies the maximum duration a session can exist.\n44: \t// Default is 8 hours.\n45: \t// +kubebuilder:validation:Required\n46: \t// +kubebuilder:default=\"8h\"\n47: \tMaxSessionDuration *metav1.Duration `json:\"maxSessionDuration,omitempty\" protobuf:\"bytes,3,opt,name=maxSessionDuration\"`\n48: }\n49: \n50: // AgentRuntimeStatus defines the observed state of AgentRuntime.\n51: type AgentRuntimeStatus struct {\n52: \t// Conditions represents the latest available observations of the AgentRuntime's state.\n53: \t// +optional\n54: \t// +listType=atomic\n55: \tConditions []metav1.Condition `json:\"conditions,omitempty\"`\n56: }\n57: \n58: // SandboxTemplate defines the pod template for creating sandbox pods.\n59: type SandboxTemplate struct {\n60: \t// Labels are applied to the sandbox pod.\n61: \t// +optional\n62: \tLabels map[string]string `json:\"labels,omitempty\" protobuf:\"bytes,1,rep,name=labels\"`\n63: \n64: \t// Annotations are applied to the sandbox pod.\n65: \t// +optional\n66: \tAnnotations map[string]string `json:\"annotations,omitempty\" protobuf:\"bytes,2,rep,name=annotations\"`\n67: \n68: \t// Spec is the PodSpec for the sandbox pod.\n69: \t// +kubebuilder:validation:Required\n70: \tSpec corev1.PodSpec `json:\"spec\" protobuf:\"bytes,3,opt,name=spec\"`\n71: }\n72: \n73: // AgentRuntimeList contains a list of AgentRuntime resources.\n74: //\n75: // +k8s:deepcopy-gen:interfaces=k8s.io/apimachinery/pkg/runtime.Object\n76: // +kubebuilder:object:root=true\n77: type AgentRuntimeLis