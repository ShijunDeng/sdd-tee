me for this port.\n38: \t// +optional\n39: \tName string `json:\"name,omitempty\"`\n40: \n41: \t// Port is the container port number to expose.\n42: \tPort uint32 `json:\"port\"`\n43: \n44: \t// Protocol specifies the protocol for this port (HTTP or HTTPS).\n45: \t// +kubebuilder:default=HTTP\n46: \t// +kubebuilder:validation:Enum=HTTP;HTTPS\n47: \tProtocol ProtocolType `json:\"protocol\"`\n48: }\n49: \n50: // ============================================================================\n51: // Label Constants\n52: // ============================================================================\n53: \n54: const (\n55: \t// LabelKeyOwnerRuntime indicates the owning AgentRuntime/CodeInterpreter name.\n56: \tLabelKeyOwnerRuntime = \"runtime.agentcube.volcano.sh/owner-runtime\"\n57: \n58: \t// LabelKeyOwnerKind indicates the owning CRD kind (AgentRuntime/CodeInterpreter).\n59: \tLabelKeyOwnerKind = \"runtime.agentcube.volcano.sh/owner-kind\"\n60: \n61: \t// LabelKeySessionID indicates the active session identifier.\n62: \tLabelKeySessionID = \"runtime.agentcube.volcano.sh/session-id\"\n63: \n64: \t// LabelKeySandboxType indicates the sandbox type (agent/code-interpreter).\n65: \tLabelKeySandboxType = \"runtime.agentcube.volcano.sh/sandbox-type\"\n66: \n67: \t// LabelKeySandboxTypeAgent indicates an agent sandbox.\n68: \tLabelKeySandboxTypeAgent = \"agent\"\n69: \n70: \t// LabelKeySandboxTypeCodeInterpreter indicates a code interpreter sandbox.\n71: \tLabelKeySandboxTypeCodeInterpreter = \"code-interpreter\"\n72: )\n73: \n74: // ============================================================================\n75: // Annotation Constants\n76: // ============================================================================\n77: \n78: const (\n79: \t// AnnotationKeyAuthMode stores the authentication mode for the sandbox.\n80: \tAnnotationKeyAuthMode = \"runtime.agentcube.volcano.sh/auth-mode\"\n81: \n82: \t// AnnotationKeySessionStart stores the session start timestamp.\n83: \tAnnotationKeySessionStart = \"runtime.agentcube.volcano.sh/session-start\"\n84: \n85: \t// AnnotationKeySessionEnd stores the session end timestamp.\n86: \tAnnotationKeySessionEnd = \"runtime.agentcube.volcano.sh/session-end\"\n87: \n88: \t// AnnotationKeyLastActivity stores the last activity timestamp.\n89: \tAnnotationKeyLastActivity = \"runtime.agentcube.volcano.sh/last-activity\"\n90: \n91: \t// AnnotationKeyWarmPoolMember indicates if pod is part of warm pool.\n92: \tAnnotationKeyWarmPoolMember = \"runtime.agentcube.volcano.sh/warm-pool-member\"\n93: )\n94: \n95: // ============================================================================\n96: // Condition Type Constants\n97: // ============================================================================\n98: \n99: const (\n100: \t// ConditionTypeReady indicates the runtime is ready to accept sessions.\n101: \tConditionTypeReady = \"Ready\"\n102: \n103: \t// ConditionTypeAvailable indicates the runtime is available for use.\n104: \tConditionTypeAvailable = \"Available\"\n105: \n106: \t// ConditionTypeProgressing indicates the runtime is being created/updated.\n107: \tConditionTypeProgressing = \"Progressing\"\n108: \n109: \t// ConditionTypeDegraded indicates the runtime is in a degraded state.\n110: \tConditionTypeDegraded = \"Degraded\"\n111: \n112: \t// ConditionTypeSessionActive indicates an active session is running.\n113: \tConditionTypeSessionActive = \"SessionActive\"\n114: )\n115: \n116: // ============================================================================\n117: // Condition Reason Constants\n118: // ============================================================================\n119: \n120: const (\n121: \t// ConditionReasonRunning indicates the runtime is running normally.\n122: \tConditionReasonRunning = \"Running\"\n123: \n124: \t// ConditionReasonCreating indicates the runtime is being created.\n125: \tConditionReasonCreating = \"Creating\"\n126: \n127: \t// ConditionReasonUpdating indicates the runtime is being updated.\n128: \tConditionReasonUpdating = \"Updating\"\n129: \n130: \t// ConditionReasonDeleting indicates the runtime is being deleted.\n131: \tConditionReasonDeleting = \"Deleting\"\n132: \n133: \t// ConditionReasonError indicates an error occurred.\n134: \tConditionReasonError = \"Error\"\n135: \n136: \t// ConditionReasonTimeout indicates a timeout occurred.\n137: \tConditionReasonTimeout = \"Timeout\"\n138: \n139: \t// ConditionReasonSessionStarted indicates a session has started.\n140: \tConditionReasonSessionStarted = \"SessionStarted\"\n141: \n142: \t// ConditionReasonSessionEnded indicates a session has ended.\n143: \tConditionReasonSessionEnded = \"SessionEnded\"\n144: \n145: \t// ConditionReasonIdleTimeout indicates session ended due to idle timeout.\n146: \tConditionReasonIdleTimeout = \"IdleTimeout\"\n147: \n148: \t// ConditionReasonMaxDurationReached indicates session ended due to max duration.\n149: \tConditionReasonMaxDurationReached = \"MaxDurationReached\"\n150: )\n151: \n152: // ============================================================================\n153: // Default Value Constants\n154: // ============================================================================\n155: \n156: const (\n157: \t// DefaultSessionTimeout is the default idle session timeout (15 minutes).\n158: \tDefaultSessionTimeout = 15 * time.Minute\n159: \n160: \t// DefaultMaxSessionDuration is the default maximum session duration (8 hours).\n161: \tDefaultMaxSessionDuration = 8 * time.Hour\n162: \n163: \t// DefaultWarmPoolSize is the default warm pool size for CodeInterpreter.\n164: \tDefaultWarmPoolSize = 0\n165: )\n166: \n167: var (\n168: \t// DefaultAuthMode is the default authentication mode.\n169: \tDefaultAuthMode = AuthModePicoD\n170: \n171: \t// DefaultProtocol is the default protocol for TargetPort.\n172: \tDefaultProtocol = ProtocolTypeHTTP\n173: )\n\n(End of file - total 173 lines)\n</content>","metadata":{"preview":"package v1alpha1\n\nimport \"time\"\n\n// ============================================================================\n// Type Definitions\n// ============================================================================\n\n// ProtocolType defines the protocol for a target port.\n// +kubebuilder:validation:Enum=HTTP;HTTPS\ntype ProtocolType string\n\nconst (\n\t// ProtocolTypeHTTP indicates HTTP protocol.\n\tProtocolTypeHTTP ProtocolType = \"HTTP\"\n\t// ProtocolTypeHTTPS indicates HTTPS protocol.\n\tProtocolTypeHTTPS ProtocolType = \"HTTPS\"\n)\n\n// AuthModeType defines the authentication mode for a CodeInterpreter.","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/apis/runtime/v1alpha1/shared_types.go","time":{"start":1775906222468,"end":1775906222508}}}}
