3.0\n26: \n27:     def test_init_session_created(self) -> None:\n28:         with patch(\"agentcube.clients.control_plane.ControlPlaneClient._resolve_url\", return_value=\"http://wm\"):\n29:             with patch(\"agentcube.clients.control_plane.ControlPlaneClient._resolve_token\", return_value=\"\"):\n30:                 client = ControlPlaneClient(workload_manager_url=\"http://wm\")\n31:                 assert client.session is not None\n32:                 assert \"Content-Type\" in client.session.headers\n33: \n34: \n35: class TestAuthTokenResolution:\n36:     def test_auth_token_explicit(self) -> None:\n37:         client = ControlPlaneClient(\n38:             workload_manager_url=\"http://wm\",\n39:             auth_token=\"explicit-token\",\n40:         )\n41:         assert client.session.headers[\"Authorization\"] == \"Bearer explicit-token\"\n42: \n43:     def test_auth_token_from_file(self) -> None:\n44:         with patch(\"agentcube.utils.utils.read_token_from_file\", return_value=\"file-token\"):\n45:             client = ControlPlaneClient(workload_manager_url=\"http://wm\")\n46:             assert client.session.headers[\"Authorization\"] == \"Bearer file-token\"\n47: \n48:     def test_auth_token_none(self) -> None:\n49:         with patch(\"agentcube.utils.utils.read_token_from_file\", return_value=\"\"):\n50:             client = ControlPlaneClient(workload_manager_url=\"http://wm\")\n51:             assert \"Authorization\" not in client.session.headers\n52: \n53: \n54: class TestURLResolution:\n55:     def test_url_explicit(self) -> None:\n56:         client = ControlPlaneClient(workload_manager_url=\"http://explicit-url\")\n57:         assert client.base_url == \"http://explicit-url\"\n58: \n59:     def test_url_from_env(self) -> None:\n60:         import os\n61:         with patch.dict(os.environ, {\"WORKLOAD_MANAGER_URL\": \"http://env-url\"}):\n62:             client = ControlPlaneClient()\n63:             assert client.base_url == \"http://env-url\"\n64: \n65:     def test_url_required_raises(self) -> None:\n66:         import os\n67:         with patch.dict(os.environ, {}, clear=True):\n68:             with pytest.raises(ValueError, match=\"workload_manager_url must be provided\"):\n69:                 ControlPlaneClient()\n70: \n71: \n72: class TestCreateSession:\n73:     def test_create_session_success(self) -> None:\n74:         client = ControlPlaneClient(workload_manager_url=\"http://wm\")\n75:         mock_response = MagicMock()\n76:         mock_response.json.return_value = {\"sessionId\": \"session-123\"}\n77:         mock_response.raise_for_status = MagicMock()\n78:         client.session.post = MagicMock(return_value=mock_response)\n79: \n80:         session_id = client.create_session(name=\"test\", namespace=\"default\", ttl=3600)\n81:         assert session_id == \"session-123\"\n82: \n83:     def test_create_session_missing_session_id(self) -> None:\n84:         client = ControlPlaneClient(workload_manager_url=\"http://wm\")\n85:         mock_response = MagicMock()\n86:         mock_response.json.return_value = {}\n87:         mock_response.raise_for_status = MagicMock()\n88:         client.session.post = MagicMock(return_value=mock_response)\n89: \n90:         with pytest.raises(ValueError, match=\"sessionId not found\"):\n91:             client.create_session(name=\"test\", namespace=\"default\")\n92: \n93:     def test_create_session_with_metadata(self) -> None:\n94:         client = ControlPlaneClient(workload_manager_url=\"http://wm\")\n95:         mock_response = MagicMock()\n96:         mock_response.json.return_value = {\"sessionId\": \"session-123\"}\n97:         mock_response.raise_for_status = MagicMock()\n98:         client.session.post = MagicMock(return_value=mock_response)\n99: \n100:         session_id = client.create_session(\n101:             name=\"test\",\n102:             namespace=\"default\",\n103:             metadata={\"key\": \"value\"},\n104:         )\n105:         assert session_id == \"session-123\"\n106:         call_args = client.session.post.call_args\n107:         assert call_args.kwargs[\"json\"][\"metadata\"] == {\"key\": \"value\"}\n108: \n109: \n110: class TestDeleteSession:\n111:     def test_delete_session_success(self) -> None:\n112:         client = ControlPlaneClient(workload_manager_url=\"http://wm\")\n113:         mock_response = MagicMock()\n114:         mock_response.raise_for_status = MagicMock()\n115:         client.session.delete = MagicMock(return_value=mock_response)\n116: \n117:         result = client.delete_session(\"session-123\")\n118:         assert result == True\n119: \n120:     def test_delete_session_404_returns_true(self) -> None:\n121:         client = ControlPlaneClient(workload_manager_url=\"http://wm\")\n122:         mock_response = MagicMock()\n123:         mock_response.status_code = 404\n124:         http_error = requests.HTTPError()\n125:         http_error.response = mock_response\n126:         client.session.delete = MagicMock(side_effect=http_error)\n127: \n128:         result = client.delete_session(\"session-123\")\n129:         assert result == True\n130: \n131:     def test_delete_session_other_failure(self) -> None:\n132:         client = ControlPlaneClient(workload_manager_url=\"http://wm\")\n133:         mock_response = MagicMock()\n134:         mock_response.status_code = 500\n135:         http_error = requests.HTTPError()\n136:         http_error.response = mock_response\n137:         client.session.delete = MagicMock(side_effect=http_error)\n138: \n139:         result = client.delete_session(\"session-123\")\n140:         assert result == False\n141: \n142:     def test_delete_session_request_exception(self) -> None:\n143:         client = ControlPlaneClient(workload_manager_url=\"http://wm\")\n144:         client.session.delete = MagicMock(side_effect=requests.RequestException())\n145: \n146:         result = client.delete_session(\"session-123\")\n147:         assert result == False\n148: \n149: \n150: class TestClose:\n151:     def test_close_session(self) -> None:\n152:         client = ControlPlaneClient(workload_manager_url=\"http://wm\")\n153:         mock_close = MagicMock()\n154:         client.session.close = mock_close\n155: \n156:         client.close()\n157:         mock_close.assert_called_once()\n\n(End of file - total 157 lines)\n</content>","metadata":{"preview":"import pytest\nfrom unittest.mock import MagicMock, patch, mock_open\nimport requests\n\nfrom agentcube.clients.control_plane import ControlPlaneClient\n\n\nclass TestControlPlaneClientInit:\n    def test_init_default_timeout(self) -> None:\n        with patch(\"agentcube.clients.control_plane.ControlPlaneClient._resolve_url\", return_value=\"http://wm\"):\n            with patch(\"agentcube.clients.control_plane.ControlPlaneClient._resolve_token\", return_value=\"\"):\n                client = ControlPlaneClient(workload_manager_url=\"http://wm\")\n                assert client.timeout == 120\n                assert client.connect_timeout == 5.0\n\n    def test_init_custom_timeout(self) -> None:\n        with patch(\"agentcube.clients.control_plane.ControlPlaneClient._resolve_url\", return_value=\"http://wm\"):\n            with patch(\"agentcube.clients.control_plane.ControlPlaneClient._resolve_token\", return_value=\"\"):\n                client = ControlPlaneClient(\n                    workload_manager_url=\"http://wm\",","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/sdk-python/tests/test_control_plane.py","time":{"start":1775882306619,"end":1775882306629}}}}
