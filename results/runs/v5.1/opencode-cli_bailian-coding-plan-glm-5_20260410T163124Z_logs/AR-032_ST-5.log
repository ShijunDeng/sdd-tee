Version)\n42: \tklog.InfoS(\"Configuration\",\n43: \t\t\"namespace\", *namespace,\n44: \t\t\"idleCleanupInterval\", *idleCleanupInt,\n45: \t\t\"idleTimeout\", *idleTimeout,\n46: \t)\n47: \n48: \tk8sConfig, err := getK8sConfig()\n49: \tif err != nil {\n50: \t\tklog.Fatalf(\"Failed to get Kubernetes config: %v\", err)\n51: \t\tos.Exit(1)\n52: \t}\n53: \n54: \tk8sClient, err := workloadmanager.NewK8sClient(k8sConfig)\n55: \tif err != nil {\n56: \t\tklog.Fatalf(\"Failed to create Kubernetes client: %v\", err)\n57: \t\tos.Exit(1)\n58: \t}\n59: \n60: \tstoreInstance := workloadmanager.NewMemoryStore()\n61: \n62: \tlifecycleConfig := workloadmanager.DefaultLifecycleConfig()\n63: \tlifecycleManager := workloadmanager.NewSandboxLifecycleManager(k8sClient, storeInstance, lifecycleConfig, newKlogLogger())\n64: \n65: \tctrl := agentd.NewIdleCleanupController(\n66: \t\tstoreInstance,\n67: \t\tlifecycleManager,\n68: \t\t*idleCleanupInt,\n69: \t\t*idleTimeout,\n70: \t\tnewKlogLogger(),\n71: \t)\n72: \n73: \tctx := cli.SetupSignalHandler()\n74: \tk8sClient.StartInformers(ctx)\n75: \n76: \tsyncCtx, syncCancel := context.WithTimeout(ctx, workloadmanager.InformerSyncTimeout)\n77: \tdefer syncCancel()\n78: \tif !k8sClient.WaitForCacheSync(syncCtx) {\n79: \t\tklog.Warning(\"Failed to sync informer cache within timeout, continuing anyway\")\n80: \t}\n81: \n82: \tctrl.Start()\n83: \tklog.Info(\"AgentD daemon started successfully\")\n84: \n85: \t<-ctx.Done()\n86: \tklog.Info(\"Received shutdown signal, stopping agentd\")\n87: \n88: \tctrl.Stop()\n89: \n90: \tklog.Info(\"AgentD daemon stopped gracefully\")\n91: }\n92: \n93: func getK8sConfig() (*rest.Config, error) {\n94: \tif *kubeconfig != \"\" {\n95: \t\treturn clientcmd.BuildConfigFromFlags(\"\", *kubeconfig)\n96: \t}\n97: \treturn rest.InClusterConfig()\n98: }\n99: \n100: func printUsage() {\n101: \tfmt.Println(\"AgentD - AgentCube daemon for idle session cleanup\")\n102: \tfmt.Println()\n103: \tfmt.Println(\"Usage:\")\n104: \tfmt.Println(\"  agentd [flags]\")\n105: \tfmt.Println()\n106: \tfmt.Println(\"Flags:\")\n107: \tfmt.Println(\"  --version                  Show version information\")\n108: \tfmt.Println(\"  --help                     Show help information\")\n109: \tfmt.Println(\"  --idle-cleanup-interval    Cleanup check interval (default: 1m)\")\n110: \tfmt.Println(\"  --idle-timeout             Session idle timeout (default: 15m)\")\n111: \tfmt.Println(\"  --kubeconfig               Path to kubeconfig file\")\n112: \tfmt.Println(\"  --namespace                Kubernetes namespace (default: default)\")\n113: \tfmt.Println()\n114: \tfmt.Println(\"Examples:\")\n115: \tfmt.Println(\"  agentd --namespace=production --idle-timeout=30m\")\n116: \tfmt.Println(\"  agentd --kubeconfig=/path/to/config\")\n117: }\n118: \n119: type klogLogger struct{}\n120: \n121: func newKlogLogger() workloadmanager.Logger {\n122: \treturn &klogLogger{}\n123: }\n124: \n125: func (l *klogLogger) Info(msg string, args ...any) {\n126: \tklog.InfoS(msg, argsToKeysAndValues(args))\n127: }\n128: \n129: func (l *klogLogger) Error(msg string, args ...any) {\n130: \tklog.ErrorS(nil, msg, argsToKeysAndValues(args))\n131: }\n132: \n133: func argsToKeysAndValues(args []any) []any {\n134: \tif len(args) == 0 {\n135: \t\treturn nil\n136: \t}\n137: \tresult := make([]any, 0, len(args)*2)\n138: \tfor i := 0; i < len(args); i += 2 {\n139: \t\tif i+1 < len(args) {\n140: \t\t\tresult = append(result, args[i], args[i+1])\n141: \t\t}\n142: \t}\n143: \treturn result\n144: }\n\n(End of file - total 144 lines)\n</content>","metadata":{"preview":"package main\n\nimport (\n\t\"context\"\n\t\"flag\"\n\t\"fmt\"\n\t\"os\"\n\t\"time\"\n\n\t\"github.com/volcano-sh/agentcube/cmd/internal/cli\"\n\t\"github.com/volcano-sh/agentcube/pkg/agentd\"\n\t\"github.com/volcano-sh/agentcube/pkg/workloadmanager\"\n\t\"k8s.io/client-go/rest\"\n\t\"k8s.io/client-go/tools/clientcmd\"\n\t\"k8s.io/klog/v2\"\n)\n\nvar (\n\tshowVersion    = flag.Bool(\"version\", false, \"Show version information\")\n\tshowHelp       = flag.Bool(\"help\", false, \"Show help information\")","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/cmd/agentd/main.go","time":{"start":1775886565331,"end":1775886565346}}}}
