yStore) UpdateSandbox(_ context.Context, sandbox *types.SandboxInfo) error {\n50: \ts.mu.Lock()\n51: \tdefer s.mu.Unlock()\n52: \n53: \tif _, exists := s.sandboxes[sandbox.SessionID]; !exists {\n54: \t\treturn &NotFoundError{Resource: \"sandbox\", Name: sandbox.SessionID}\n55: \t}\n56: \n57: \ts.sandboxes[sandbox.SessionID] = sandbox\n58: \ts.expirationIndex[sandbox.SandboxID] = sandbox.ExpiresAt\n59: \n60: \treturn nil\n61: }\n62: \n63: func (s *MemoryStore) DeleteSandboxBySessionID(_ context.Context, sessionID string) error {\n64: \ts.mu.Lock()\n65: \tdefer s.mu.Unlock()\n66: \n67: \tsandbox, exists := s.sandboxes[sessionID]\n68: \tif !exists {\n69: \t\treturn nil\n70: \t}\n71: \n72: \tdelete(s.sandboxes, sessionID)\n73: \tdelete(s.expirationIndex, sandbox.SandboxID)\n74: \n75: \treturn nil\n76: }\n77: \n78: func (s *MemoryStore) ListSandboxes(_ context.Context) ([]*types.SandboxInfo, error) {\n79: \ts.mu.RLock()\n80: \tdefer s.mu.RUnlock()\n81: \n82: \tresult := make([]*types.SandboxInfo, 0, len(s.sandboxes))\n83: \tfor _, sandbox := range s.sandboxes {\n84: \t\tresult = append(result, sandbox)\n85: \t}\n86: \n87: \treturn result, nil\n88: }\n89: \n90: func (s *MemoryStore) ListExpiredSandboxes(_ context.Context, before time.Time, limit int) ([]*types.SandboxInfo, error) {\n91: \ts.mu.RLock()\n92: \tdefer s.mu.RUnlock()\n93: \n94: \tvar expired []*types.SandboxInfo\n95: \tfor _, sandbox := range s.sandboxes {\n96: \t\tif sandbox.ExpiresAt.Before(before) {\n97: \t\t\texpired = append(expired, sandbox)\n98: \t\t}\n99: \t}\n100: \n101: \tsort.Slice(expired, func(i, j int) bool {\n102: \t\treturn expired[i].ExpiresAt.Before(expired[j].ExpiresAt)\n103: \t})\n104: \n105: \tif limit > 0 && len(expired) > limit {\n106: \t\texpired = expired[:limit]\n107: \t}\n108: \n109: \treturn expired, nil\n110: }\n111: \n112: func (s *MemoryStore) ListInactiveSandboxes(_ context.Context, before time.Time, limit int) ([]*types.SandboxInfo, error) {\n113: \ts.mu.RLock()\n114: \tdefer s.mu.RUnlock()\n115: \n116: \tvar inactive []*types.SandboxInfo\n117: \tfor _, sandbox := range s.sandboxes {\n118: \t\tif !sandbox.LastActivity.IsZero() && sandbox.LastActivity.Before(before) {\n119: \t\t\tinactive = append(inactive, sandbox)\n120: \t\t}\n121: \t}\n122: \n123: \tsort.Slice(inactive, func(i, j int) bool {\n124: \t\treturn inactive[i].LastActivity.Before(inactive[j].LastActivity)\n125: \t})\n126: \n127: \tif limit > 0 && len(inactive) > limit {\n128: \t\tinactive = inactive[:limit]\n129: \t}\n130: \n131: \treturn inactive, nil\n132: }\n133: \n134: func (s *MemoryStore) Clear() {\n135: \ts.mu.Lock()\n136: \tdefer s.mu.Unlock()\n137: \n138: \ts.sandboxes = make(map[string]*types.SandboxInfo)\n139: \ts.expirationIndex = make(map[string]time.Time)\n140: }\n141: \n142: func (s *MemoryStore) Size() int {\n143: \ts.mu.RLock()\n144: \tdefer s.mu.RUnlock()\n145: \n146: \treturn len(s.sandboxes)\n147: }\n\n(End of file - total 147 lines)\n</content>","metadata":{"preview":"package workloadmanager\n\nimport (\n\t\"context\"\n\t\"sort\"\n\t\"sync\"\n\t\"time\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n)\n\nvar ErrSandboxNotFound = &NotFoundError{Resource: \"sandbox\", Name: \"\"}\n\ntype MemoryStore struct {\n\tmu              sync.RWMutex\n\tsandboxes       map[string]*types.SandboxInfo\n\texpirationIndex map[string]time.Time\n}\n\nfunc NewMemoryStore() *MemoryStore {","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/store.go","time":{"start":1775848609177,"end":1775848609208}}}}
{"type":"tool_use","timestamp":1775848609211,"sessionID":"ses_2872f4338ffegY4bVs7f3OXLR5","part":{"id":"prt_d78d3526c001Md07CBgVQBzaBe","messageID":"msg_d78d3306e001V6SDxld1CPzx0x","sessionID":"ses_2872f4338ffegY4bVs7f3OXLR5","type":"tool","tool":"read","callID":"toolu_tool-f71484168cdc4e0da884bc86c92065c4","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/lifecycle.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/lifecycle.go</path>\n<type>file</type>\n<content>\n1: package workloadmanager\n2: \n3: import (\n4: \t\"context\"\n5: \t\"time\"\n6: \n7: \tapierrors \"k8s.io/apimachinery/pkg/api/errors\"\n8: \tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n9: \t\"k8s.io/utils/ptr\"\n10: \n11: \t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n12: )\n13: \n14: type LifecycleConfig struct {\n15: \tDefaultTTL          time.Duration\n16: \tDefaultIdleTimeout  time.Duration\n17: \tDefaultMaxDuration  time.Duration\n18: \tGCInterval          time.Duration\n19: \tGCOnceTimeout       time.Duration\n20: \tDeletionGracePeriod int64\n21: \tDeletionTimeout     time.Duration\n22: }\n23: \n24: func DefaultLifecycleConfig() LifecycleConfig {\n25: \treturn LifecycleConfig{\n26: \t\tDefaultTTL:          DefaultSandboxTTL,\n27: \t\tDefaultIdleTimeout:  DefaultSandboxIdleTimeout,\n28: \t\tDefaultMaxDuration:  DefaultMaxSessionDuration,\n29: \t\tGCInterval:          GarbageCollectorInterval,\n30: \t\tGCOnceTimeout:       2 * time.Minute,\n31: \t\tDeletionGracePeriod: 0,\n32: \t\tDeletionTimeout:     SandboxDeleteTimeout,\n33: \t}\n34: }\n35: \n36: type SandboxLifecycleManager struct {\n37: \tk8sClient *K8sClient\n38: \tstore     Store\n39: \tconfig    LifecycleConfig\n40: \tlogger    Logger\n41: }\n42: \n43: func NewSandboxLifecycleManager(k8sClient *K8sClient, store Store, config LifecycleConfig, logger Logger) *SandboxLifecycleManager {\n44: \treturn &SandboxLifecycleManager{\n45: \t\tk8sClient: k8sClient,\n46: \t\tstore:     store,\n47: \t\tconfig:    config,\n48: \t\tlogger:    logger,\n49: \t}\n50: }\n51: \n52: func (m *SandboxLifecycleManager) DeleteSandbox(ctx context.Context, sessionID string) error {\n53: \tctx, cancel := context.WithTimeout(ctx, m.config.DeletionTimeout)\n54: \tdefer cancel()\n55: \n56: \tsandboxInfo, err := m.store.GetSandboxBySessionID(ctx, sessionID)\n57: \tif err != nil {\n58: \t\tif _, ok := err.(*NotFoundError); ok {\n59: \t\t\treturn &NotFoundError{Resource: \"session\", Name: sessionID}\n60: \t\t}\n61: \t\treturn &InternalError{Err: err}\n62: \t}\n63: \n64: \tdeleteOpts := metav1.DeleteOptions{\n65: \t\tGracePeriodSeconds: ptr.To(m.config.DeletionGracePeriod),\n66: \t}\n67: \n68: \terr = m.k8sClient.DynamicClient().Resource(SandboxGVR).\n69: \t\tNamespace(sandboxInfo.SandboxNamespace).\n70: \t\tDelete(ctx, sandboxInfo.SandboxName, deleteOpts)\n71: \n72: \tif err != nil && !apierrors.IsNotFound(err) {\n73: \t\treturn handleDeleteError(err)\n74: \t}\n75: \n76: \tif sandboxInfo.Kind == types.SandboxClaimKind {\n77: \t\terr = m.k8sClient.DynamicClient().Resource(SandboxClaimGVR).\n78: \t\t\tNamespace(sandboxInfo.SandboxNamespace).\n79: \t\t\tDelete(ctx, sandboxInfo.SandboxName, deleteOpts)\n80: \n81: \t\tif err != nil && !apierrors.IsNotFound(err) {\n82: \t\t\tm.logger.Error(\"failed to delete SandboxClaim\", \"sandboxName\", sandboxInfo.SandboxName, \"err\", err)\n83: \t\t}\n84: \t}\n85: \n86: \terr = m.store.DeleteSandboxBySessionID(ctx, sessionID)\n87: \tif err != nil {\n88: \t\tm.logger.Error(\"failed to delete from store\", \"sessionID\", sessionID, \"err\", err)\n89: \t}\n90: \n91: \treturn nil\n92: }\n93: \n94: func (m *SandboxLifecycleManager) IsExpired(sandbox *types.SandboxInfo) bool {\n95: \treturn time.Now().After(sandbox.ExpiresAt)\n96: }\n97: \n98: func (m *SandboxLifecycleManager) IsIdleExpired(sandbox *types.SandboxInfo, idleTimeout time.Duration) bool {\n99: \tif sandbox.LastActivity.IsZero() {\n100: \t\treturn false\n101: \t}\n102: \treturn time.Now().After(sandbox.LastActivity.Add(idleTimeout))\n103: }\n104: \n105: func (m *SandboxLifecycleManager) ForceDeleteSandbox(ctx context.Context, sessionID string) error {\n106: \tctx, cancel := context.WithTimeout(ctx, m.config.DeletionTimeout)\n107: \tdefer cancel()\n108: \n109: \tsandboxInfo, err := m.store.GetSandboxBySessionID(ctx, sessionID)\n110: \tif err != nil {\n111: \t\tif _, ok := err.(*NotFoundError); ok {\n112: \t\t\treturn nil\n113: \t\t}\n114: \t\treturn &InternalError{Err: err}\n115: \t}\n116: \n117: \tdeleteOpts := metav1.DeleteOptions{\n118: \t\tGracePeriodSeconds: ptr.To[int64](0),\n119: \t}\n120: \n121: \terr = m.k8sClient.DynamicClient().Resource(SandboxGVR).\n122: \t\tNamespace(sandboxInfo.SandboxNamespace).\n123: \t\tDelete(ctx, sandboxInfo.SandboxName, deleteOpts)\n124: \n125: \tif err != nil && !apierrors.IsNotFound(err) {\n126: \t\tm.logger.Error(\"force delete sandbox CR failed\", \"sandboxName\", sandboxInfo.SandboxName, \"err\", err)\n127: \t}\n128: \n129: \tif sandboxInfo.Kind == types.SandboxClaimKind {\n130: \t\tm.k8sClient.DynamicClient().Resource(SandboxClaimGVR).\n131: \t\t\tNamespace(sandboxInfo.SandboxNamespace).\n132: \t\t\tDelete(ctx, sandboxInfo.SandboxName, deleteOpts)\n133: \t}\n134: \n135: \terr = m.store.DeleteSandboxBySessionID(ctx, sessionID)\n136: \tif err != nil {\n137: \t\tm.logger.Error(\"failed to delete from store during force delete\", \"sessionID\", sessionID, \"err\", err)\n138: \t}\n139: \n140: \treturn nil\n141: }\n142: \n143: func (m *SandboxLifecycleManager) GetSandbox(ctx context.Context, sessionID string) (*types.SandboxInfo, error) {\n144: \treturn m.store.GetSandboxBySessionID(ctx, sessionID)\n145: }\n146: \n147: func (m *SandboxLifecycleManager) UpdateSandboxStatus(ctx context.Context, sessionID string, status string) error {\n148: \tsandbox, err := m.store.GetSandboxBySessionID(ctx, sessionID)\n149: \tif err != nil {\n150: \t\treturn err\n151: \t}\n152: \n153: \tsandbox.Status = status\n154: \treturn m.store.UpdateSandbox(ctx, sandbox)\n155: }\n156: \n157: func handleDeleteError(err error) error {\n158: \tif apierrors.IsNotFound(err) {\n159: \t\treturn nil\n160: \t}\n161: \tif apierrors.IsConflict(err) {\n162: \t\treturn &ConflictError{Resource: \"sandbox\", Err: err}\n163: \t}\n164: \treturn &InternalError{Err: err}\n165: }\n166: \n167: func determineDeletionReason(sandbox *types.SandboxInfo, now time.Time, idleTimeout time.Duration) DeletionReason {\n168: \tif now.After(sandbox.ExpiresAt) {\n169: \t\treturn DeletionReasonMaxDurationReached\n170: \t}\n171: \tif !sandbox.LastActivity.IsZero() && now.After(sandbox.LastActivity.Add(idleTimeout)) {\n172: \t\treturn DeletionReasonIdleTimeout\n173: \t}\n174: \treturn DeletionReasonUserRequest\n175: }\n\n(End of file - total 175 lines)\n</content>","metadata":{"preview":"package workloadmanager\n\nimport (\n\t\"context\"\n\t\"time\"\n\n\tapierrors \"k8s.io/apimachinery/pkg/api/errors\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/utils/ptr\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n)\n\ntype LifecycleConfig struct {\n\tDefaultTTL          time.Duration\n\tDefaultIdleTimeout  time.Duration\n\tDefaultMaxDuration  time.Duration\n\tGCInterval          time.Duration\n\tGCOnceTimeout       time.Duration\n\tDeletionGracePeriod int64","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/lifecycle.go","time":{"start":1775848609183,"end":1775848609210}}}}
