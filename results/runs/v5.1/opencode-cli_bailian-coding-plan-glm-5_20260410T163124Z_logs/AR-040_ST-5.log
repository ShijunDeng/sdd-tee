glm-5_20260410T163124Z/sdk-python/tests/test_code_interpreter.py","before":"import os\nimport pytest\nimport responses\nfrom unittest.mock import Mock, patch, MagicMock\n\nfrom agentcube.code_interpreter import CodeInterpreterClient\nfrom agentcube.clients.control_plane import ControlPlaneClient\nfrom agentcube.clients.code_interpreter_data_plane import CodeInterpreterDataPlaneClient\n\n\nclass TestCodeInterpreterClientInit:\n    def test_router_url_required(self) -> None:\n        if \"ROUTER_URL\" in os.environ:\n            del os.environ[\"ROUTER_URL\"]\n        with pytest.raises(ValueError, match=\"router_url must be provided\"):\n            CodeInterpreterClient.__new__(CodeInterpreterClient).__init__(\n                name=\"test\",\n                workload_manager_url=\"http://wm\",\n            )\n\n    @responses.activate\n    def test_router_url_from_env(self) -> None:\n        responses.post(\n            \"http://wm/v1/code-interpreter\",\n            json={\"sessionId\": \"session-123\"},\n        )\n        os.environ[\"ROUTER_URL\"] = \"http://router\"\n        client = CodeInterpreterClient(\n            name=\"test\",\n            workload_manager_url=\"http://wm\",\n        )\n        assert client.router_url == \"http://router\"\n        del os.environ[\"ROUTER_URL\"]\n        client.stop()\n\n    @responses.activate\n    def test_router_url_explicit(self) -> None:\n        responses.post(\n            \"http://wm/v1/code-interpreter\",\n            json={\"sessionId\": \"session-123\"},\n        )\n        client = CodeInterpreterClient(\n            name=\"test\",\n            workload_manager_url=\"http://wm\",\n            router_url=\"http://router\",\n        )\n        assert client.router_url == \"http://router\"\n        client.stop()\n\n\nclass TestSessionCreation:\n    @responses.activate\n    def test_session_created_when_not_provided(self) -> None:\n        responses.post(\n            \"http://wm/v1/code-interpreter\",\n            json={\"sessionId\": \"session-123\"},\n        )\n        client = CodeInterpreterClient(\n            name=\"test\",\n            namespace=\"default\",\n            ttl=3600,\n            workload_manager_url=\"http://wm\",\n            router_url=\"http://router\",\n        )\n        assert client._session_id == \"session-123\"\n        assert client._session_created == True\n        client.stop()\n\n    @responses.activate\n    def test_session_reused_when_provided(self) -> None:\n        client = CodeInterpreterClient(\n            name=\"test\",\n            workload_manager_url=\"http://wm\",\n            router_url=\"http://router\",\n            session_id=\"provided-session\",\n        )\n        assert client._session_id == \"provided-session\"\n        assert client._session_created == False\n        client.stop()\n\n\nclass TestContextManager:\n    @responses.activate\n    def test_context_manager_calls_stop(self) -> None:\n        responses.post(\n            \"http://wm/v1/code-interpreter\",\n            json={\"sessionId\": \"session-123\"},\n        )\n        responses.delete(\n            \"http://wm/v1/code-interpreter/sessions/session-123\",\n            status=200,\n        )\n        with CodeInterpreterClient(\n            name=\"test\",\n            workload_manager_url=\"http://wm\",\n            router_url=\"http://router\",\n        ) as client:\n            assert client._session_id == \"session-123\"\n\n    @responses.activate\n    def test_context_manager_on_exception(self) -> None:\n        responses.post(\n            \"http://wm/v1/code-interpreter\",\n            json={\"sessionId\": \"session-123\"},\n        )\n        responses.delete(\n            \"http://wm/v1/code-interpreter/sessions/session-123\",\n            status=200,\n        )\n        try:\n            with CodeInterpreterClient(\n                name=\"test\",\n                workload_manager_url=\"http://wm\",\n                router_url=\"http://router\",\n            ) as client:\n                raise RuntimeError(\"Test error\")\n        except RuntimeError:\n            pass\n\n\nclass TestStopMethod:\n    @responses.activate\n    def test_stop_closes_data_plane_and_control_plane(self) -> None:\n        responses.post(\n            \"http://wm/v1/code-interpreter\",\n            json={\"sessionId\": \"session-123\"},\n        )\n        responses.delete(\n            \"http://wm/v1/code-interpreter/sessions/session-123\",\n            status=200,\n        )\n        client = CodeInterpreterClient(\n            name=\"test\",\n            workload_manager_url=\"http://wm\",\n            router_url=\"http://router\",\n        )\n        client.stop()\n        assert client._dp_client is None\n\n    @responses.activate\n    def test_stop_only_deletes_if_session_created(self) -> None:\n        responses.delete(\n            \"http://wm/v1/code-interpreter/sessions/provided-session\",\n            status=200,\n        )\n        client = CodeInterpreterClient(\n            name=\"test\",\n            workload_manager_url=\"http://wm\",\n            router_url=\"http://router\",\n            session_id=\"provided-session\",\n        )\n        client.stop()\n\n\nclass TestExecuteCommandDelegation:\n    @responses.activate\n    def test_execute_command_delegates_to_data_plane(self) -> None:\n        responses.post(\n            \"http://wm/v1/code-interpreter\",\n            json={\"sessionId\": \"session-123\"},\n        )\n        responses.post(\n            \"http://router/v1/namespaces/default/code-interpreters/test/invocations/api/execute\",\n            json={\"exit_code\": 0, \"stdout\": \"output\"},\n        )\n        client = CodeInterpreterClient(\n            name=\"test\",\n            workload_manager_url=\"http://wm\",\n            router_url=\"http://router\",\n        )\n        result = client.execute_command(\"ls -la\")\n        assert result == \"output\"\n        client.stop()\n\n\nclass TestRunCode:\n    @responses.activate\n    def test_run_code_python(self) -> None:\n        responses.post(\n            \"http://wm/v1/code-interpreter\",\n            json={\"sessionId\": \"session-123\"},\n        )\n        responses.post(\n            \"http://router/v1/namespaces/default/code-interpreters/test/invocations/api/files\",\n            status=200,\n        )\n        responses.post(\n            \"http://router/v1/namespaces/default/code-interpreters/test/invocations/api/execute\",\n            json={\"exit_code\": 0, \"stdout\": \"Hello World\"},\n        )\n        client = CodeInterpreterClient(\n            name=\"test\",\n            workload_manager_url=\"http://wm\",\n            router_url=\"http://router\",\n        )\n        result = client.run_code(\"python\", \"print('Hello World')\")\n        assert result == \"Hello World\"\n        client.stop()\n\n    def test_run_code_unsupported_language(self) -> None:\n        client = CodeInterpreterClient.__new__(CodeInterpreterClient)\n        client._dp_client = Mock()\n        with pytest.raises(ValueError, match=\"Unsupported language\"):\n            client.run_code(\"javascript\", \"console.log('test')\")\n\n\nclass TestFileOperations:\n    @responses.activate\n    def test_write_file_delegates(self) -> None:\n        responses.post(\n            \"http://wm/v1/code-interpreter\",\n            json={\"sessionId\": \"session-123\"},\n        )\n        responses.post(\n            \"http://router/v1/namespaces/default/code-interpreters/test/invocations/api/files\",\n            status=200,\n        )\n        client = CodeInterpreterClient(\n            name=\"test\",\n            workload_manager_url=\"http://wm\",\n            router_url=\"http://router\",\n        )\n        client.write_file(\"content\", \"/workspace/test.py\")\n        client.stop()\n\n    @responses.activate\n    def test_list_files_delegates(self) -> None:\n        responses.post(\n            \"http://wm/v1/code-interpreter\",\n            json={\"sessionId\": \"session-123\"},\n        )\n        responses.get(\n            \"http://router/v1/namespaces/default/code-interpreters/test/invocations/api/files\",\n            json={\"files\": [\"file1.py\", \"file2.py\"]},\n        )\n        client = CodeInterpreterClient(\n            name=\"test\",\n            workload_manager_url=\"http://wm\",\n            router_url=\"http://router\",\n        )\n        result = client.list_files(\"/workspace\")\n        assert result == {\"files\": [\"file1.py\", \"file2.py\"]}\n        client.stop()\n\n\nclass TestVerboseMode:\n    @responses.activate\n    def test_verbose_false(self) -> None:\n        responses.post(\n            \"http://wm/v1/code-interpreter\",\n            json={\"sessionId\": \"session-123\"},\n        )\n        client = CodeInterpreterClient(\n            name=\"test\",\n            workload_manager_url=\"http://wm\",\n            router_url=\"http://router\",\n            verbose=False,\n        )\n        import logging\n        assert client._logger.level == logging.INFO\n        client.stop()\n\n    @responses.activate\n    def test_verbose_true(self) -> None:\n        responses.post(\n            \"http://wm/v1/code-interpreter\",\n            json={\"sessionId\": \"session-123\"},\n        )\n        client = CodeInterpreterClient(\n            name=\"test\",\n            workload_manager_url=\"http://wm\",\n            router_url=\"http://router\",\n            verbose=True,\n        )\n        import logging\n        assert client._logger.level == logging.DEBUG\n        client.stop()\n\n\nclass TestDataPlaneInitFailure:\n    def test_data_plane_init_failure_cleans_up_session(self) -> None:\n        mock_cp_client = Mock()\n        mock_cp_client.create_session = Mock(return_value=\"session-123\")\n        mock_cp_client.delete_session = Mock(return_value=True)\n        mock_cp_client.close = Mock()\n\n        with patch(\"agentcube.code_interpreter.ControlPlaneClient\", return_value=mock_cp_client):\n            with patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\", side_effect=RuntimeError(\"Init failed\")):\n                with patch(\"agentcube.code_interpreter.CodeInterpreterClient._resolve_router_url\", return_value=\"http://router\"):\n                    with pytest.raises(RuntimeError, match=\"Init failed\"):\n                        client = CodeInterpreterClient(\n                            name=\"test\",\n                            workload_manager_url=\"http://wm\",\n                            router_url=\"http://router\",\n                        )\n                    mock_cp_client.delete_session.assert_called_once_with(\"session-123\")","after":"import os\nimport pytest\nimport responses\nfrom unittest.mock import Mock, patch, MagicMock\n\nfrom agentcube.code_interpreter import CodeInterpreterClient\nfrom agentcube.clients.control_plane import ControlPlaneClient\nfrom agentcube.clients.code_interpreter_data_plane import CodeInterpreterDataPlaneClient\n\n\nclass TestCodeInterpreterClientInit:\n    def test_router_url_required(self) -> None:\n        if \"ROUTER_URL\" in os.environ:\n            del os.environ[\"ROUTER_URL\"]\n        with pytest.raises(ValueError, match=\"router_url must be provided\"):\n            CodeInterpreterClient.__new__(CodeInterpreterClient).__init__(\n                name=\"test\",\n                workload_manager_url=\"http://wm\",\n            )\n\n    @responses.activate\n    def test_router_url_from_env(self) -> None:\n        responses.post(\n            \"http://wm/v1/code-interpreter\",\n            json={\"sessionId\": \"session-123\"},\n        )\n        os.environ[\"ROUTER_URL\"] = \"http://router\"\n        client = CodeInterpreterClient(\n            name=\"test\",\n            workload_manager_url=\"http://wm\",\n        )\n        assert client.router_url == \"http://router\"\n        del os.environ[\"ROUTER_URL\"]\n        client.stop()\n\n    @responses.activate\n    def test_router_url_explicit(self) -> None:\n        responses.post(\n            \"http://wm/v1/code-interpreter\",\n            json={\"sessionId\": \"session-123\"},\n        )\n        client = CodeInterpreterClient(\n            name=\"test\",\n            workload_manager_url=\"http://wm\",\n            router_url=\"http://router\",\n        )\n        assert client.router_url == \"http://router\"\n        client.stop()\n\n\nclass TestSessionCreation:\n    @responses.activate\n    def test_session_created_when_not_provided(self) -> None:\n        responses.post(\n            \"http://wm/v1/code-interpreter\",\n            json={\"sessionId\": \"session-123\"},\n        )\n        client = CodeInterpreterClient(\n            name=\"test\",\n            namespace=\"default\",\n            ttl=3600,\n            workload_manager_url=\"http://wm\",\n            router_url=\"http://router\",\n        )\n        assert client._session_id == \"session-123\"\n        assert client._session_created == True\n        client.stop()\n\n    @responses.activate\n    def test_session_reused_when_provided(self) -> None:\n        client = CodeInterpreterClient(\n            name=\"test\",\n            workload_manager_url=\"http://wm\",\n            router_url=\"http://router\",\n            session_id=\"provided-session\",\n        )\n        assert client._session_id == \"provided-session\"\n        assert client._session_created == False\n        client.stop()\n\n\nclass TestContextManager:\n    @responses.activate\n    def test_context_manager_calls_stop(self) -> None:\n        responses.post(\n            \"http://wm/v1/code-interpreter\",\n            json={\"sessionId\": \"session-123\"},\n        )\n        responses.delete(\n            \"http://wm/v1/code-interpreter/sessions/session-123\",\n            status=200,\n        )\n        with CodeInterpreterClient(\n            name=\"test\",\n            workload_manager_url=\"http://wm\",\n            router_url=\"http://router\",\n        ) as client:\n            assert client._session_id == \"session-123\"\n\n    @responses.activate\n    def test_context_manager_on_exception(self) -> None:\n        responses.post(\n            \"http://wm/v1/code-interpreter\",\n            json={\"sessionId\": \"session-123\"},\n        )\n        responses.delete(\n            \"http://wm/v1/code-interpreter/sessions/session-123\",\n            status=200,\n        )\n        try:\n            with CodeInterpreterClient(\n                name=\"test\",\n                workload_manager_url=\"http://wm\",\n                router_url=\"http://router\",\n            ) as client:\n                raise RuntimeError(\"Test error\")\n        except RuntimeError:\n            pass\n\n\nclass TestStopMethod:\n    @responses.activate\n    def test_stop_closes_data_plane_and_control_plane(self) -> None:\n        responses.post(\n            \"http://wm/v1/code-interpreter\",\n            json={\"sessionId\": \"session-123\"},\n        )\n        responses.delete(\n            \"http://wm/v1/code-interpreter/sessions/session-123\",\n            status=200,\n        )\n        client = CodeInterpreterClient(\n            name=\"test\",\n            workload_manager_url=\"http://wm\",\n            router_url=\"http://router\",\n        )\n        client.stop()\n        assert client._dp_client is None\n\n    @responses.activate\n    def test_stop_only_deletes_if_session_created(self) -> None:\n        responses.delete(\n            \"http://wm/v1/code-interpreter/sessions/provided-session\",\n            status=200,\n        )\n        client = CodeInterpreterClient(\n            name=\"test\",\n            workload_manager_url=\"http://wm\",\n            router_url=\"http://router\",\n            session_id=\"provided-session\",\n        )\n        client.stop()\n\n\nclass TestExecuteCommandDelegation:\n    @responses.activate\n    def test_execute_command_delegates_to_data_plane(self) -> None:\n        responses.post(\n            \"http://wm/v1/code-interpreter\",\n            json={\"sessionId\": \"session-123\"},\n        )\n        responses.post(\n            \"http://router/v1/namespaces/default/code-interpreters/test/invocations/api/execute\",\n            json={\"exit_code\": 0, \"stdout\": \"output\"},\n        )\n        client = CodeInterpreterClient(\n            name=\"test\",\n            workload_manager_url=\"http://wm\",\n            router_url=\"http://router\",\n        )\n        result = client.execute_command(\"ls -la\")\n        assert result == \"output\"\n        client.stop()\n\n\nclass TestRunCode:\n    @responses.activate\n    def test_run_code_python(self) -> None:\n        responses.post(\n            \"http://wm/v1/code-interpreter\",\n            json={\"sessionId\": \"session-123\"},\n        )\n        responses.post(\n            \"http://router/v1/namespaces/default/code-interpreters/test/invocations/api/files\",\n            status=200,\n        )\n        responses.post(\n            \"http://router/v1/namespaces/default/code-interpreters/test/invocations/api/execute\",\n            json={\"exit_code\": 0, \"stdout\": \"Hello World\"},\n        )\n        client = CodeInterpreterClient(\n            name=\"test\",\n            workload_manager_url=\"http://wm\",\n            router_url=\"http://router\",\n        )\n        result = client.run_code(\"python\", \"print('Hello World')\")\n        assert result == \"Hello World\"\n        client.stop()\n\n    def test_run_code_unsupported_language(self) -> None:\n        client = CodeInterpreterClient.__new__(CodeInterpreterClient)\n        client._dp_client = Mock()\n        with pytest.raises(ValueError, match=\"Unsupported language\"):\n            client.run_code(\"javascript\", \"console.log('test')\")\n\n\nclass TestFileOperations:\n    @responses.activate\n    def test_write_file_delegates(self) -> None:\n        responses.post(\n            \"http://wm/v1/code-interpreter\",\n            json={\"sessionId\": \"session-123\"},\n        )\n        responses.post(\n            \"http://router/v1/namespaces/default/code-interpreters/test/invocations/api/files\",\n            status=200,\n        )\n        client = CodeInterpreterClient(\n            name=\"test\",\n            workload_manager_url=\"http://wm\",\n            router_url=\"http://router\",\n        )\n        client.write_file(\"content\", \"/workspace/test.py\")\n        client.stop()\n\n    @responses.activate\n    def test_list_files_delegates(self) -> None:\n        responses.post(\n            \"http://wm/v1/code-interpreter\",\n            json={\"sessionId\": \"session-123\"},\n        )\n        responses.get(\n            \"http://router/v1/namespaces/default/code-interpreters/test/invocations/api/files\",\n            json={\"files\": [\"file1.py\", \"file2.py\"]},\n        )\n        client = CodeInterpreterClient(\n            name=\"test\",\n            workload_manager_url=\"http://wm\",\n            router_url=\"http://router\",\n        )\n        result = client.list_files(\"/workspace\")\n        assert result == {\"files\": [\"file1.py\", \"file2.py\"]}\n        client.stop()\n\n\nclass TestVerboseMode:\n    @responses.activate\n    def test_verbose_false(self) -> None:\n        responses.post(\n            \"http://wm/v1/code-interpreter\",\n            json={\"sessionId\": \"session-123\"},\n        )\n        client = CodeInterpreterClient(\n            name=\"test\",\n            workload_manager_url=\"http://wm\",\n            router_url=\"http://router\",\n            verbose=False,\n        )\n        import logging\n        assert client._logger.level == logging.INFO\n        client.stop()\n\n    @responses.activate\n    def test_verbose_true(self) -> None:\n        responses.post(\n            \"http://wm/v1/code-interpreter\",\n            json={\"sessionId\": \"session-123\"},\n        )\n        client = CodeInterpreterClient(\n            name=\"test\",\n            workload_manager_url=\"http://wm\",\n            router_url=\"http://router\",\n            verbose=True,\n        )\n        import logging\n        assert client._logger.level == logging.DEBUG\n        client.stop()\n\n\nclass TestDataPlaneInitFailure:\n    def test_data_plane_init_failure_cleans_up_session(self) -> None:\n        mock_cp_client = Mock()\n        mock_cp_client.create_session = Mock(return_value=\"session-123\")\n        mock_cp_client.delete_session = Mock(return_value=True)\n        mock_cp_client.close = Mock()\n\n        with patch(\"agentcube.code_interpreter.ControlPlaneClient\", return_value=mock_cp_client):\n            with patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\", side_effect=RuntimeError(\"Init failed\")):\n                with patch(\"agentcube.code_interpreter.CodeInterpreterClient._resolve_router_url\", return_value=\"http://router\"):\n                    with pytest.raises(RuntimeError, match=\"Init failed\"):\n                        client = CodeInterpreterClient(\n                            name=\"test\",\n                            workload_manager_url=\"http://wm\",\n                            router_url=\"http://router\",\n                        )\n                    mock_cp_client.delete_session.assert_called_once_with(\"session-123\")\n\n\nclass TestDataPlaneNotInitialized:\n    def test_execute_command_without_data_plane(self) -> None:\n        client = CodeInterpreterClient.__new__(CodeInterpreterClient)\n        client._dp_client = None\n        with pytest.raises(RuntimeError, match=\"Data plane client not initialized\"):\n            client.execute_command(\"ls -la\")\n\n    def test_write_file_without_data_plane(self) -> None:\n        client = CodeInterpreterClient.__new__(CodeInterpreterClient)\n        client._dp_client = None\n        with pytest.raises(RuntimeError, match=\"Data plane client not initialized\"):\n            client.write_file(\"content\", \"/workspace/test.py\")\n\n    def test_upload_file_without_data_plane(self) -> None:\n        client = CodeInterpreterClient.__new__(CodeInterpreterClient)\n        client._dp_client = None\n        with pytest.raises(RuntimeError, match=\"Data plane client not initialized\"):\n            client.upload_file(\"/local/file.txt\", \"/remote/file.txt\")\n\n    def test_download_file_without_data_plane(self) -> None:\n        client = CodeInterpreterClient.__new__(CodeInterpreterClient)\n        client._dp_client = None\n        with pytest.raises(RuntimeError, match=\"Data plane client not initialized\"):\n            client.download_file(\"/remote/file.txt\", \"/local/file.txt\")\n\n    def test_list_files_without_data_plane(self) -> None:\n        client = CodeInterpreterClient.__new__(CodeInterpreterClient)\n        client._dp_client = None\n        with pytest.raises(RuntimeError, match=\"Data plane client not initialized\"):\n            client.list_files(\"/workspace\")\n\n    def test_init_data_plane_without_session_id(self) -> None:\n        client = CodeInterpreterClient.__new__(CodeInterpreterClient)\n        client._session_id = None\n        with pytest.raises(RuntimeError, match=\"session_id must be set before initializing data plane\"):\n            client._init_data_plane()\n\n\nclass TestUploadDownloadFile:\n    @responses.activate\n    def test_upload_file_delegates(self, tmp_path) -> None:\n        responses.post(\n            \"http://wm/v1/code-interpreter\",\n            json={\"sessionId\": \"session-123\"},\n        )\n        responses.post(\n            \"http://router/v1/namespaces/default/code-interpreters/test/invocations/api/files\",\n            status=200,\n        )\n        client = CodeInterpreterClient(\n            name=\"test\",\n            workload_manager_url=\"http://wm\",\n            router_url=\"http://router\",\n        )\n        local_file = tmp_path / \"upload_test.txt\"\n        local_file.write_text(\"test content\")\n        client.upload_file(str(local_file), \"/workspace/uploaded.txt\")\n        client.stop()\n\n    @responses.activate\n    def test_download_file_delegates(self, tmp_path) -> None:\n        responses.post(\n            \"http://wm/v1/code-interpreter\",\n            json={\"sessionId\": \"session-123\"},\n        )\n        responses.get(\n            \"http://router/v1/namespaces/default/code-interpreters/test/invocations/api/files/workspace/downloaded.txt\",\n            body=b\"downloaded content\",\n            status=200,\n        )\n        client = CodeInterpreterClient(\n            name=\"test\",\n            workload_manager_url=\"http://wm\",\n            router_url=\"http://router\",\n        )\n        local_file = tmp_path / \"downloaded.txt\"\n        client.download_file(\"/workspace/downloaded.txt\", str(local_file))\n        assert local_file.read_text() == \"downloaded content\"\n        client.stop()","additions":82,"deletions":1},"truncated":false},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/sdk-python/tests/test_code_interpreter.py","time":{"start":1775901030820,"end":1775901031407}}}}
