ld\"},\n190:         )\n191:         client = CodeInterpreterClient(\n192:             name=\"test\",\n193:             workload_manager_url=\"http://wm\",\n194:             router_url=\"http://router\",\n195:         )\n196:         result = client.run_code(\"python\", \"print('Hello World')\")\n197:         assert result == \"Hello World\"\n198:         client.stop()\n199: \n200:     def test_run_code_unsupported_language(self) -> None:\n201:         client = CodeInterpreterClient.__new__(CodeInterpreterClient)\n202:         client._dp_client = Mock()\n203:         with pytest.raises(ValueError, match=\"Unsupported language\"):\n204:             client.run_code(\"javascript\", \"console.log('test')\")\n205: \n206: \n207: class TestFileOperations:\n208:     @responses.activate\n209:     def test_write_file_delegates(self) -> None:\n210:         responses.post(\n211:             \"http://wm/v1/code-interpreter\",\n212:             json={\"sessionId\": \"session-123\"},\n213:         )\n214:         responses.post(\n215:             \"http://router/v1/namespaces/default/code-interpreters/test/invocations/api/files\",\n216:             status=200,\n217:         )\n218:         client = CodeInterpreterClient(\n219:             name=\"test\",\n220:             workload_manager_url=\"http://wm\",\n221:             router_url=\"http://router\",\n222:         )\n223:         client.write_file(\"content\", \"/workspace/test.py\")\n224:         client.stop()\n225: \n226:     @responses.activate\n227:     def test_list_files_delegates(self) -> None:\n228:         responses.post(\n229:             \"http://wm/v1/code-interpreter\",\n230:             json={\"sessionId\": \"session-123\"},\n231:         )\n232:         responses.get(\n233:             \"http://router/v1/namespaces/default/code-interpreters/test/invocations/api/files\",\n234:             json={\"files\": [\"file1.py\", \"file2.py\"]},\n235:         )\n236:         client = CodeInterpreterClient(\n237:             name=\"test\",\n238:             workload_manager_url=\"http://wm\",\n239:             router_url=\"http://router\",\n240:         )\n241:         result = client.list_files(\"/workspace\")\n242:         assert result == {\"files\": [\"file1.py\", \"file2.py\"]}\n243:         client.stop()\n244: \n245: \n246: class TestVerboseMode:\n247:     @responses.activate\n248:     def test_verbose_false(self) -> None:\n249:         responses.post(\n250:             \"http://wm/v1/code-interpreter\",\n251:             json={\"sessionId\": \"session-123\"},\n252:         )\n253:         client = CodeInterpreterClient(\n254:             name=\"test\",\n255:             workload_manager_url=\"http://wm\",\n256:             router_url=\"http://router\",\n257:             verbose=False,\n258:         )\n259:         import logging\n260:         assert client._logger.level == logging.INFO\n261:         client.stop()\n262: \n263:     @responses.activate\n264:     def test_verbose_true(self) -> None:\n265:         responses.post(\n266:             \"http://wm/v1/code-interpreter\",\n267:             json={\"sessionId\": \"session-123\"},\n268:         )\n269:         client = CodeInterpreterClient(\n270:             name=\"test\",\n271:             workload_manager_url=\"http://wm\",\n272:             router_url=\"http://router\",\n273:             verbose=True,\n274:         )\n275:         import logging\n276:         assert client._logger.level == logging.DEBUG\n277:         client.stop()\n278: \n279: \n280: class TestDataPlaneInitFailure:\n281:     def test_data_plane_init_failure_cleans_up_session(self) -> None:\n282:         mock_cp_client = Mock()\n283:         mock_cp_client.create_session = Mock(return_value=\"session-123\")\n284:         mock_cp_client.delete_session = Mock(return_value=True)\n285:         mock_cp_client.close = Mock()\n286: \n287:         with patch(\"agentcube.code_interpreter.ControlPlaneClient\", return_value=mock_cp_client):\n288:             with patc