{"type":"tool_use","timestamp":1775877024715,"sessionID":"ses_2857b7443ffedBYuiC1TYbZRRS","part":{"id":"prt_d7a84eb8e0016jlWBzUZTW8xji","messageID":"msg_d7a84c736001xWn1n9RjQLVa5B","sessionID":"ses_2857b7443ffedBYuiC1TYbZRRS","type":"tool","tool":"read","callID":"toolu_tool-a7aa1c365f0846da966bf93f12f84e10","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/cmd/cli/agentcube/services/metadata_service.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/cmd/cli/agentcube/services/metadata_service.py</path>\n<type>file</type>\n<content>\n1: from pathlib import Path\n2: from typing import Optional, Dict, Any\n3: \n4: import yaml\n5: from pydantic import BaseModel, Field, field_validator\n6: \n7: \n8: class AgentMetadata(BaseModel):\n9:     agent_name: str = Field(..., description=\"Unique name identifying the agent\")\n10:     description: str = Field(\"\", description=\"Human-readable summary\")\n11:     language: str = Field(\"python\", description=\"Programming language used\")\n12:     entrypoint: str = Field(..., description=\"Command to launch the agent\")\n13:     port: int = Field(8080, description=\"Port exposed by the agent runtime\")\n14:     build_mode: str = Field(\"local\", description=\"Build strategy: local or cloud\")\n15:     region: str = Field(\"\", description=\"Deployment region\")\n16:     version: str = Field(\"\", description=\"Semantic version string for publishing\")\n17:     image: Dict[str, Any] = Field(default_factory=dict, description=\"Container image information\")\n18:     auth: Dict[str, Any] = Field(default_factory=dict, description=\"Authentication configuration\")\n19:     requirements_file: str = Field(\"requirements.txt\", description=\"Python dependency file\")\n20:     registry_url: str = Field(\"\", description=\"Registry URL for image publishing\")\n21:     registry_username: str = Field(\"\", description=\"Registry username\")\n22:     registry_password: str = Field(\"\", description=\"Registry password\")\n23:     agent_endpoint: str = Field(\"\", description=\"Agent endpoint URL\")\n24:     workload_manager_url: str = Field(\"\", description=\"URL for the Workload Manager\")\n25:     router_url: str = Field(\"\", description=\"URL for the Router\")\n26:     readiness_probe_path: str = Field(\"\", description=\"Path for the readiness probe\")\n27:     readiness_probe_port: int = Field(8080, description=\"Port for the readiness probe\")\n28:     agent_id: str = Field(\"\", description=\"Agent ID assigned by AgentCube\")\n29:     session_id: str = Field(\"\", description=\"The session ID for the agent\")\n30:     k8s_deployment: Dict[str, Any] = Field(default_factory=dict, description=\"Kubernetes deployment information\")\n31: \n32:     @field_validator(\"language\")\n33:     @classmethod\n34:     def validate_language(cls, v: str) -> str:\n35:         allowed = [\"python\", \"java\"]\n36:         v_lower = v.lower()\n37:         if v_lower not in allowed:\n38:             raise ValueError(f\"language must be one of {allowed}\")\n39:         return v_lower\n40: \n41:     @field_validator(\"build_mode\")\n42:     @classmethod\n43:     def validate_build_mode(cls, v: str) -> str:\n44:         allowed = [\"local\", \"cloud\"]\n45:         v_lower = v.lower()\n46:         if v_lower not in allowed:\n47:             raise ValueError(f\"build_mode must be one of {allowed}\")\n48:         return v_lower\n49: \n50:     @field_validator(\"port\")\n51:     @classmethod\n52:     def validate_port(cls, v: int) -> int:\n53:         if not 1 <= v <= 65535:\n54:             raise ValueError(\"port must be between 1 and 65535\")\n55:         return v\n56: \n57: \n58: class MetadataService:\n59:     def __init__(self, verbose: bool = False) -> None:\n60:         self.verbose = verbose\n61: \n62:     def load_metadata(self, workspace_path: Path) -> AgentMetadata:\n63:         metadata_files = [\"agent_metadata.yaml\", \"agent.yaml\", \"metadata.yaml\"]\n64:         for filename in metadata_files:\n65:             filepath = workspace_path / filename\n66:             if filepath.exists():\n67:                 with open(filepath, \"r\", encoding=\"utf-8\") as f:\n68:                     data = yaml.safe_load(f) or {}\n69:                 return AgentMetadata(**data)\n70:         raise FileNotFoundError(\n71:             f\"No metadata file found in workspace: {workspace_path}\"\n72:         )\n73: \n74:     def save_metadata(self, workspace_path: Path, metadata: AgentMetadata) -> Path:\n75:         filepath = workspace_path / \"agent_metadata.yaml\"\n76:         data = metadata.model_dump(exclude_none=True)\n77:         with open(filepath, \"w\", encoding=\"utf-8\") as f:\n78:             yaml.dump(data, f, default_flow_style=False, indent=2, sort_keys=False)\n79:         return filepath\n\n(End of file - total 79 lines)\n</content>","metadata":{"preview":"from pathlib import Path\nfrom typing import Optional, Dict, Any\n\nimport yaml\nfrom pydantic import BaseModel, Field, field_validator\n\n\nclass AgentMetadata(BaseModel):\n    agent_name: str = Field(..., description=\"Unique name identifying the agent\")\n    description: str = Field(\"\", description=\"Human-readable summary\")\n    language: str = Field(\"python\", description=\"Programming language used\")\n    entrypoint: str = Field(..., description=\"Command to launch the agent\")\n    port: int = Field(8080, description=\"Port exposed by the agent runtime\")\n    build_mode: str = Field(\"local\", description=\"Build strategy: local or cloud\")\n    region: str = Field(\"\", description=\"Deployment region\")\n    version: str = Field(\"\", description=\"Semantic version string for publishing\")\n    image: Dict[str, Any] = Field(default_factory=dict, description=\"Container image information\")\n    auth: Dict[str, Any] = Field(default_factory=dict, description=\"Authentication configuration\")\n    requirements_file: str = Field(\"requirements.txt\", description=\"Python dependency file\")\n    registry_url: str = Field(\"\", description=\"Registry URL for image publishing\")","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/cmd/cli/agentcube/services/metadata_service.py","time":{"start":1775877024687,"end":1775877024712}}}}
