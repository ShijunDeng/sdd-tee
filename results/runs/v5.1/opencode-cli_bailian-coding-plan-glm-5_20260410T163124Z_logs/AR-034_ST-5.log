-func=coverage.out\n\n      - name: Upload coverage artifact\n        uses: actions/upload-artifact@v4\n        with:\n          name: go-coverage\n          path: coverage.out\n          retention-days: 7\n\n      - name: Upload to Codecov\n        uses: codecov/codecov-action@v4\n        with:\n          file: coverage.out\n          fail_ci_if_error: false\n          token: ${{ secrets.CODECOV_TOKEN }}"},"output":"Wrote file successfully.","metadata":{"diagnostics":{"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/.github/workflows/main.yml":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/.github/workflows/lint.yml":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/.github/workflows/test-coverage.yml":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/.github/workflows/filters.yaml":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/.github/workflows/workflows-approve.yml":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/.github/workflows/dify-plugin-publish.yml":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/.github/workflows/build-push-release.yml":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/.github/workflows/e2e.yml":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/.github/workflows/codegen-check.yml":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/.github/workflows/copyright-check.yml":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/.github/workflows/codespell.yml":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_2026041