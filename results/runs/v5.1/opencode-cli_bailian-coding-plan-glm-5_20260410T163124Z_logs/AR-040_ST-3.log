trap_session_id()\n83:         assert session_id == \"test-session-123\"\n84: \n85:     @responses.activate\n86:     def test_bootstrap_missing_header(self):\n87:         responses.get(\n88:             \"http://router.example.com/v1/namespaces/default/agent-runtimes/test-agent/invocations/\",\n89:         )\n90:         client = AgentRuntimeDataPlaneClient(\n91:             router_url=\"http://router.example.com\",\n92:             namespace=\"default\",\n93:             agent_name=\"test-agent\",\n94:         )\n95:         with pytest.raises(ValueError, match=\"Missing required response header: x-agentcube-session-id\"):\n96:             client.bootstrap_session_id()\n97: \n98: \n99: class TestInvoke:\n100:     @responses.activate\n101:     def test_invoke_with_session(self):\n102:         responses.post(\n103:             \"http://router.example.com/v1/namespaces/default/agent-runtimes/test-agent/invocations/\",\n104:             json={\"result\": \"success\"},\n105:             status=200,\n106:         )\n107:         client = AgentRuntimeDataPlaneClient(\n108:             router_url=\"http://router.example.com\",\n109:             namespace=\"default\",\n110:             agent_name=\"test-agent\",\n111:         )\n112:         resp = client.invoke(\"test-session-123\", {\"input\": \"test\"})\n113:         assert resp.status_code == 200\n114:         assert resp.json() == {\"result\": \"success\"}\n115: \n116: \n117: class TestInvokeHeaders:\n118:     @responses.activate\n119:     def test_invoke_headers_correctness(self):\n120:         responses.post(\n121:             \"http://router.example.com/v1/namespaces/default/agent-runtimes/test-agent/invocations/\",\n122:             json={\"result\": \"success\"},\n123:         )\n124:         client = AgentRuntimeDataPlaneClient(\n125:             router_url=\"http://router.example.com\",\n126:             namespace=\"default\",\n127:             agent_name=\"test-agent\",\n128:         )\n129:         client.invo