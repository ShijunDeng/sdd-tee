{"type":"tool_use","timestamp":1775900586860,"sessionID":"ses_28413df37ffeJyWAcJXCOWZImd","part":{"id":"prt_d7bec6b090016HwdAzy3zdeZaW","messageID":"msg_d7bec56fc001J4Y5MnROs6Na3B","sessionID":"ses_28413df37ffeJyWAcJXCOWZImd","type":"tool","tool":"read","callID":"toolu_tool-256db84cf25942a9a925f796ae4a660a","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/sdk-python/tests/test_code_interpreter.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/sdk-python/tests/test_code_interpreter.py</path>\n<type>file</type>\n<content>\n1: import os\n2: import pytest\n3: import responses\n4: from unittest.mock import Mock, patch, MagicMock\n5: \n6: from agentcube.code_interpreter import CodeInterpreterClient\n7: from agentcube.clients.control_plane import ControlPlaneClient\n8: from agentcube.clients.code_interpreter_data_plane import CodeInterpreterDataPlaneClient\n9: \n10: \n11: class TestCodeInterpreterClientInit:\n12:     def test_router_url_required(self) -> None:\n13:         if \"ROUTER_URL\" in os.environ:\n14:             del os.environ[\"ROUTER_URL\"]\n15:         with pytest.raises(ValueError, match=\"router_url must be provided\"):\n16:             CodeInterpreterClient.__new__(CodeInterpreterClient).__init__(\n17:                 name=\"test\",\n18:                 workload_manager_url=\"http://wm\",\n19:             )\n20: \n21:     @responses.activate\n22:     def test_router_url_from_env(self) -> None:\n23:         responses.post(\n24:             \"http://wm/v1/code-interpreter\",\n25:             json={\"sessionId\": \"session-123\"},\n26:         )\n27:         os.environ[\"ROUTER_URL\"] = \"http://router\"\n28:         client = CodeInterpreterClient(\n29:             name=\"test\",\n30:             workload_manager_url=\"http://wm\",\n31:         )\n32:         assert client.router_url == \"http://router\"\n33:         del os.environ[\"ROUTER_URL\"]\n34:         client.stop()\n35: \n36:     @responses.activate\n37:     def test_router_url_explicit(self) -> None:\n38:         responses.post(\n39:             \"http://wm/v1/code-interpreter\",\n40:             json={\"sessionId\": \"session-123\"},\n41:         )\n42:         client = CodeInterpreterClient(\n43:             name=\"test\",\n44:             workload_manager_url=\"http://wm\",\n45:             router_url=\"http://router\",\n46:         )\n47:         assert client.router_url == \"http://router\"\n48:         client.stop()\n49: \n50: \n51: class TestSessionCreation:\n52:     @responses.activate\n53:     def test_session_created_when_not_provided(self) -> None:\n54:         responses.post(\n55:             \"http://wm/v1/code-interpreter\",\n56:             json={\"sessionId\": \"session-123\"},\n57:         )\n58:         client = CodeInterpreterClient(\n59:             name=\"test\",\n60:             namespace=\"default\",\n61:             ttl=3600,\n62:             workload_manager_url=\"http://wm\",\n63:             router_url=\"http://router\",\n64:         )\n65:         assert client._session_id == \"session-123\"\n66:         assert client._session_created == True\n67:         client.stop()\n68: \n69:     @responses.activate\n70:     def test_session_reused_when_provided(self) -> None:\n71:         client = CodeInterpreterClient(\n72:             name=\"test\",\n73:             workload_manager_url=\"http://wm\",\n74:             router_url=\"http://router\",\n75:             session_id=\"provided-session\",\n76:         )\n77:         assert client._session_id == \"provided-session\"\n78:         assert client._session_created == False\n79:         client.stop()\n80: \n81: \n82: class TestContextManager:\n83:     @responses.activate\n84:     def test_context_manager_calls_stop(self) -> None:\n85:         responses.post(\n86:             \"http://wm/v1/code-interpreter\",\n87:             json={\"sessionId\": \"session-123\"},\n88:         )\n89:         responses.delete(\n90:             \"http://wm/v1/code-interpreter/sessions/session-123\",\n91:             status=200,\n92:         )\n93:         with CodeInterpreterClient(\n94:             name=\"test\",\n95:             workload_manager_url=\"http://wm\",\n96:             router_url=\"http://router\",\n97:         ) as client:\n98:             assert client._session_id == \"session-123\"\n99: \n100:     @responses.activate\n101:     def test_context_manager_on_exception(self) -> None:\n102:         responses.post(\n103:             \"http://wm/v1/code-interpreter\",\n104:             json={\"sessionId\": \"session-123\"},\n105:         )\n106:         responses.delete(\n107:             \"http://wm/v1/code-interpreter/sessions/session-123\",\n108:             status=200,\n109:         )\n110:         try:\n111:             with CodeInterpreterClient(\n112:                 name=\"test\",\n113:                 workload_manager_url=\"http://wm\",\n114:                 router_url=\"http://router\",\n115:             ) as client:\n116:                 raise RuntimeError(\"Test error\")\n117:         except RuntimeError:\n118:             pass\n119: \n120: \n121: class TestStopMethod:\n122:     @responses.activate\n123:     def test_stop_closes_data_plane_and_control_plane(self) -> None:\n124:         responses.post(\n125:             \"http://wm/v1/code-interpreter\",\n126:             json={\"sessionId\": \"session-123\"},\n127:         )\n128:         responses.delete(\n129:             \"http://wm/v1/code-interpreter/sessions/session-123\",\n130:             status=200,\n131:         )\n132:         client = CodeInterpreterClient(\n133:             name=\"test\",\n134:             workload_manager_url=\"http://wm\",\n135:             router_url=\"http://router\",\n136:         )\n137:         client.stop()\n138:         assert client._dp_client is None\n139: \n140:     @responses.activate\n141:     def test_stop_only_deletes_if_session_created(self) -> None:\n142:         responses.delete(\n143:             \"http://wm/v1/code-interpreter/sessions/provided-session\",\n144:             status=200,\n145:         )\n146:         client = CodeInterpreterClient(\n147:             name=\"test\",\n148:             workload_manager_url=\"http://wm\",\n149:             router_url=\"http://router\",\n150:             session_id=\"provided-session\",\n151:         )\n152:         client.stop()\n153: \n154: \n155: class TestExecuteCommandDelegation:\n156:     @responses.activate\n157:     def test_execute_command_delegates_to_data_plane(self) -> None:\n158:         responses.post(\n159:             \"http://wm/v1/code-interpreter\",\n160:             json={\"sessionId\": \"session-123\"},\n161:         )\n162:         responses.post(\n163:             \"http://router/v1/namespaces/default/code-interpreters/test/invocations/api/execute\",\n164:             json={\"exit_code\": 0, \"stdout\": \"output\"},\n165:         )\n166:         client = CodeInterpreterClient(\n167:             name=\"test\",\n168:             workload_manager_url=\"http://wm\",\n169:             router_url=\"http://router\",\n170:         )\n171:         result = client.execute_command(\"ls -la\")\n172:         assert result == \"output\"\n173:         client.stop()\n174: \n175: \n176: class TestRunCode:\n177:     @responses.activate\n178:     def test_run_code_python(self) -> None:\n179:         responses.post(\n180:             \"http://wm/v1/code-interpreter\",\n181:             json={\"sessionId\": \"session-123\"},\n182:         )\n183:         responses.post(\n184:             \"http://router/v1/namespaces/default/code-interpreters/test/invocations/api/files\",\n185:             status=200,\n186:         )\n187:         responses.post(\n188:             \"http://router/v1/namespaces/default/code-interpreters/test/invocations/api/execute\",\n189:             json={\"exit_code\": 0, \"stdout\": \"Hello World\"},\n190:         )\n191:         client = CodeInterpreterClient(\n192:             name=\"test\",\n193:             workload_manager_url=\"http://wm\",\n194:             router_url=\"http://router\",\n195:         )\n196:         result = client.run_code(\"python\", \"print('Hello World')\")\n197:         assert result == \"Hello World\"\n198:         client.stop()\n199: \n200:     def test_run_code_unsupported_language(self) -> None:\n201:         client = CodeInterpreterClient.__new__(CodeInterpreterClient)\n202:         client._dp_client = Mock()\n203:         with pytest.raises(ValueError, match=\"Unsupported language\"):\n204:             client.run_code(\"javascript\", \"console.log('test')\")\n205: \n206: \n207: class TestFileOperations:\n208:     @responses.activate\n209:     def test_write_file_delegates(self) -> None:\n210:         responses.post(\n211:             \"http://wm/v1/code-interpreter\",\n212:             json={\"sessionId\": \"session-123\"},\n213:         )\n214:         responses.post(\n215:             \"http://router/v1/namespaces/default/code-interpreters/test/invocations/api/files\",\n216:             status=200,\n217:         )\n218:         client = CodeInterpreterClient(\n219:             name=\"test\",\n220:             workload_manager_url=\"http://wm\",\n221:             router_url=\"http://router\",\n222:         )\n223:         client.write_file(\"content\", \"/workspace/test.py\")\n224:         client.stop()\n225: \n226:     @responses.activate\n227:     def test_list_files_delegates(self) -> None:\n228:         responses.post(\n229:             \"http://wm/v1/code-interpreter\",\n230:             json={\"sessionId\": \"session-123\"},\n231:         )\n232:         responses.get(\n233:             \"http://router/v1/namespaces/default/code-interpreters/test/invocations/api/files\",\n234:             json={\"files\": [\"file1.py\", \"file2.py\"]},\n235:         )\n236:         client = CodeInterpreterClient(\n237:             name=\"test\",\n238:             workload_manager_url=\"http://wm\",\n239:             router_url=\"http://router\",\n240:         )\n241:         result = client.list_files(\"/workspace\")\n242:         assert result == {\"files\": [\"file1.py\", \"file2.py\"]}\n243:         client.stop()\n244: \n245: \n246: class TestVerboseMode:\n247:     @responses.activate\n248:     def test_verbose_false(self) -> None:\n249:         responses.post(\n250:             \"http://wm/v1/code-interpreter\",\n251:             json={\"sessionId\": \"session-123\"},\n252:         )\n253:         client = CodeInterpreterClient(\n254:             name=\"test\",\n255:             workload_manager_url=\"http://wm\",\n256:             router_url=\"http://router\",\n257:             verbose=False,\n258:         )\n259:         import logging\n260:         assert client._logger.level == logging.INFO\n261:         client.stop()\n262: \n263:     @responses.activate\n264:     def test_verbose_true(self) -> None:\n265:         responses.post(\n266:             \"http://wm/v1/code-interpreter\",\n267:             json={\"sessionId\": \"session-123\"},\n268:         )\n269:         client = CodeInterpreterClient(\n270:             name=\"test\",\n271:             workload_manager_url=\"http://wm\",\n272:             router_url=\"http://router\",\n273:             verbose=True,\n274:         )\n275:         import logging\n276:         assert client._logger.level == logging.DEBUG\n277:         client.stop()\n278: \n279: \n280: class TestDataPlaneInitFailure:\n281:     def test_data_plane_init_failure_cleans_up_session(self) -> None:\n282:         mock_cp_client = Mock()\n283:         mock_cp_client.create_session = Mock(return_value=\"session-123\")\n284:         mock_cp_client.delete_session = Mock(return_value=True)\n285:         mock_cp_client.close = Mock()\n286: \n287:         with patch(\"agentcube.code_interpreter.ControlPlaneClient\", return_value=mock_cp_client):\n288:             with patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\", side_effect=RuntimeError(\"Init failed\")):\n289:                 with patch(\"agentcube.code_interpreter.CodeInterpreterClient._resolve_router_url\", return_value=\"http://router\"):\n290:                     with pytest.raises(RuntimeError, match=\"Init failed\"):\n291:                         client = CodeInterpreterClient(\n292:                             name=\"test\",\n293:                             workload_manager_url=\"http://wm\",\n294:                             router_url=\"http://router\",\n295:                         )\n296:                     mock_cp_client.delete_session.assert_called_once_with(\"session-123\")\n\n(End of file - total 296 lines)\n</content>","metadata":{"preview":"import os\nimport pytest\nimport responses\nfrom unittest.mock import Mock, patch, MagicMock\n\nfrom agentcube.code_interpreter import CodeInterpreterClient\nfrom agentcube.clients.control_plane import ControlPlaneClient\nfrom agentcube.clients.code_interpreter_data_plane import CodeInterpreterDataPlaneClient\n\n\nclass TestCodeInterpreterClientInit:\n    def test_router_url_required(self) -> None:\n        if \"ROUTER_URL\" in os.environ:\n            del os.environ[\"ROUTER_URL\"]\n        with pytest.raises(ValueError, match=\"router_url must be provided\"):\n            CodeInterpreterClient.__new__(CodeInterpreterClient).__init__(\n                name=\"test\",\n                workload_manager_url=\"http://wm\",\n            )\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/sdk-python/tests/test_code_interpreter.py","time":{"start":1775900586838,"end":1775900586858}}}}
{"type":"tool_use","timestamp":1775900586862,"sessionID":"ses_28413df37ffeJyWAcJXCOWZImd","part":{"id":"prt_d7bec733b001BUTXAqbmA73vpr","messageID":"msg_d7bec56fc001J4Y5MnROs6Na3B","sessionID":"ses_28413df37ffeJyWAcJXCOWZImd","type":"tool","tool":"read","callID":"toolu_tool-db1d0197b4124e7aa01d9ebc10fee1dc","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/sdk-python/tests/test_data_plane.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/sdk-python/tests/test_data_plane.py</path>\n<type>file</type>\n<content>\n1: import pytest\n2: from unittest.mock import MagicMock, patch, mock_open\n3: from pathlib import Path\n4: import base64\n5: import requests\n6: \n7: from agentcube.clients.code_interpreter_data_plane import CodeInterpreterDataPlaneClient\n8: from agentcube.exceptions import CommandExecutionError\n9: \n10: \n11: class TestDataPlaneClientInit:\n12:     def test_init_with_session_id(self) -> None:\n13:         client = CodeInterpreterDataPlaneClient(\n14:             session_id=\"session-123\",\n15:             router_url=\"http://router\",\n16:             namespace=\"default\",\n17:             cr_name=\"test-interpreter\",\n18:         )\n19:         assert client.session_id == \"session-123\"\n20: \n21:     def test_init_with_base_url(self) -> None:\n22:         client = CodeInterpreterDataPlaneClient(\n23:             session_id=\"session-123\",\n24:             base_url=\"http://router/v1/namespaces/default/code-interpreters/test/invocations/\",\n25:         )\n26:         assert client.base_url == \"http://router/v1/namespaces/default/code-interpreters/test/invocations/\"\n27: \n28:     def test_init_missing_params_raises(self) -> None:\n29:         with pytest.raises(ValueError, match=\"Either base_url or router_url\"):\n30:             CodeInterpreterDataPlaneClient(session_id=\"session-123\")\n31: \n32: \n33: class TestSessionHeader:\n34:     def test_session_header_lowercase(self) -> None:\n35:         client = CodeInterpreterDataPlaneClient(\n36:             session_id=\"session-123\",\n37:             router_url=\"http://router\",\n38:             namespace=\"default\",\n39:             cr_name=\"test\",\n40:         )\n41:         assert \"x-agentcube-session-id\" in client.session.headers\n42:         assert client.session.headers[\"x-agentcube-session-id\"] == \"session-123\"\n43: \n44: \n45: class TestBaseURLConstruction:\n46:     def test_base_url_from_router_url(self) -> None:\n47:         client = CodeInterpreterDataPlaneClient(\n48:             session_id=\"session-123\",\n49:             router_url=\"http://router.example.com\",\n50:             namespace=\"production\",\n51:             cr_name=\"my-interpreter\",\n52:         )\n53:         assert client.base_url == \"http://router.example.com/v1/namespaces/production/code-interpreters/my-interpreter/invocations/\"\n54: \n55: \n56: class TestExecuteCommand:\n57:     def test_execute_command_success(self) -> None:\n58:         client = CodeInterpreterDataPlaneClient(\n59:             session_id=\"session-123\",\n60:             base_url=\"http://router/v1/invocations/\",\n61:         )\n62:         mock_response = MagicMock()\n63:         mock_response.json.return_value = {\"exit_code\": 0, \"stdout\": \"output\"}\n64:         mock_response.raise_for_status = MagicMock()\n65:         client._request = MagicMock(return_value=mock_response)\n66: \n67:         result = client.execute_command(\"python3 script.py\")\n68:         assert result == \"output\"\n69: \n70:     def test_execute_command_json_body(self) -> None:\n71:         client = CodeInterpreterDataPlaneClient(\n72:             session_id=\"session-123\",\n73:             base_url=\"http://router/v1/invocations/\",\n74:         )\n75:         mock_response = MagicMock()\n76:         mock_response.json.return_value = {\"exit_code\": 0, \"stdout\": \"\"}\n77:         mock_response.raise_for_status = MagicMock()\n78:         client._request = MagicMock(return_value=mock_response)\n79: \n80:         client.execute_command(\"python3 script.py\", timeout=30)\n81:         call_args = client._request.call_args\n82:         import json\n83:         body = json.loads(call_args.args[2].decode())\n84:         assert body[\"command\"] == [\"python3\", \"script.py\"]\n85:         assert body[\"timeout\"] == \"30s\"\n86: \n87:     def test_execute_command_timeout_buffer(self) -> None:\n88:         client = CodeInterpreterDataPlaneClient(\n89:             session_id=\"session-123\",\n90:             base_url=\"http://router/v1/invocations/\",\n91:             timeout=60,\n92:         )\n93:         mock_response = MagicMock()\n94:         mock_response.json.return_value = {\"exit_code\": 0, \"stdout\": \"\"}\n95:         mock_response.raise_for_status = MagicMock()\n96:         client._request = MagicMock(return_value=mock_response)\n97: \n98:         client.execute_command(\"cmd\", timeout=30)\n99:         call_args = client._request.call_args\n100:         assert call_args.kwargs[\"timeout_override\"] == 32.0\n101: \n102:     def test_execute_command_nonzero_exit(self) -> None:\n103:         client = CodeInterpreterDataPlaneClient(\n104:             session_id=\"session-123\",\n105:             base_url=\"http://router/v1/invocations/\",\n106:         )\n107:         mock_response = MagicMock()\n108:         mock_response.json.return_value = {\"exit_code\": 1, \"stderr\": \"error msg\"}\n109:         mock_response.raise_for_status = MagicMock()\n110:         client._request = MagicMock(return_value=mock_response)\n111: \n112:         with pytest.raises(CommandExecutionError) as exc_info:\n113:             client.execute_command(\"python3 script.py\")\n114:         assert exc_info.value.exit_code == 1\n115:         assert exc_info.value.stderr == \"error msg\"\n116: \n117:     def test_execute_command_list_input(self) -> None:\n118:         client = CodeInterpreterDataPlaneClient(\n119:             session_id=\"session-123\",\n120:             base_url=\"http://router/v1/invocations/\",\n121:         )\n122:         mock_response = MagicMock()\n123:         mock_response.json.return_value = {\"exit_code\": 0, \"stdout\": \"\"}\n124:         mock_response.raise_for_status = MagicMock()\n125:         client._request = MagicMock(return_value=mock_response)\n126: \n127:         client.execute_command([\"python3\", \"script.py\"])\n128:         call_args = client._request.call_args\n129:         import json\n130:         body = json.loads(call_args.args[2].decode())\n131:         assert body[\"command\"] == [\"python3\", \"script.py\"]\n132: \n133:     def test_execute_command_default_timeout(self) -> None:\n134:         client = CodeInterpreterDataPlaneClient(\n135:             session_id=\"session-123\",\n136:             base_url=\"http://router/v1/invocations/\",\n137:             timeout=120,\n138:         )\n139:         mock_response = MagicMock()\n140:         mock_response.json.return_value = {\"exit_code\": 0, \"stdout\": \"\"}\n141:         mock_response.raise_for_status = MagicMock()\n142:         client._request = MagicMock(return_value=mock_response)\n143: \n144:         client.execute_command(\"ls\")\n145:         call_args = client._request.call_args\n146:         import json\n147:         body = json.loads(call_args.args[2].decode())\n148:         assert body[\"timeout\"] == \"120s\"\n149:         assert call_args.kwargs[\"timeout_override\"] == 122.0\n150: \n151: \n152: class TestWriteFile:\n153:     def test_write_file_base64(self) -> None:\n154:         client = CodeInterpreterDataPlaneClient(\n155:             session_id=\"session-123\",\n156:             base_url=\"http://router/v1/invocations/\",\n157:         )\n158:         mock_response = MagicMock()\n159:         mock_response.raise_for_status = MagicMock()\n160:         client._request = MagicMock(return_value=mock_response)\n161: \n162:         client.write_file(\"hello world\", \"/workspace/test.py\")\n163:         call_args = client._request.call_args\n164:         import json\n165:         body = json.loads(call_args.args[2].decode())\n166:         expected_content = base64.b64encode(\"hello world\".encode()).decode()\n167:         assert body[\"content\"] == expected_content\n168: \n169:     def test_write_file_mode(self) -> None:\n170:         client = CodeInterpreterDataPlaneClient(\n171:             session_id=\"session-123\",\n172:             base_url=\"http://router/v1/invocations/\",\n173:         )\n174:         mock_response = MagicMock()\n175:         mock_response.raise_for_status = MagicMock()\n176:         client._request = MagicMock(return_value=mock_response)\n177: \n178:         client.write_file(\"content\", \"/workspace/test.py\")\n179:         call_args = client._request.call_args\n180:         import json\n181:         body = json.loads(call_args.args[2].decode())\n182:         assert body[\"mode\"] == \"0644\"\n183: \n184: \n185: class TestUploadFile:\n186:     def test_upload_file_multipart(self, tmp_path: Path) -> None:\n187:         client = CodeInterpreterDataPlaneClient(\n188:             session_id=\"session-123\",\n189:             base_url=\"http://router/v1/invocations/\",\n190:         )\n191:         local_file = tmp_path / \"test.txt\"\n192:         local_file.write_text(\"content\")\n193: \n194:         mock_response = MagicMock()\n195:         mock_response.raise_for_status = MagicMock()\n196:         client.session.post = MagicMock(return_value=mock_response)\n197: \n198:         client.upload_file(str(local_file), \"/workspace/test.txt\")\n199:         call_args = client.session.post.call_args\n200:         assert \"files\" in call_args.kwargs\n201:         assert \"data\" in call_args.kwargs\n202:         assert call_args.kwargs[\"data\"][\"path\"] == \"/workspace/test.txt\"\n203: \n204:     def test_upload_file_session_header(self, tmp_path: Path) -> None:\n205:         client = CodeInterpreterDataPlaneClient(\n206:             session_id=\"session-123\",\n207:             base_url=\"http://router/v1/invocations/\",\n208:         )\n209:         local_file = tmp_path / \"test.txt\"\n210:         local_file.write_text(\"content\")\n211: \n212:         mock_response = MagicMock()\n213:         mock_response.raise_for_status = MagicMock()\n214:         client.session.post = MagicMock(return_value=mock_response)\n215: \n216:         client.upload_file(str(local_file), \"/workspace/test.txt\")\n217:         call_args = client.session.post.call_args\n218:         assert call_args.kwargs[\"headers\"][\"x-agentcube-session-id\"] == \"session-123\"\n219: \n220:     def test_upload_file_not_found(self) -> None:\n221:         client = CodeInterpreterDataPlaneClient(\n222:             session_id=\"session-123\",\n223:             base_url=\"http://router/v1/invocations/\",\n224:         )\n225: \n226:         with pytest.raises(FileNotFoundError):\n227:             client.upload_file(\"/nonexistent/file.txt\", \"/workspace/test.txt\")\n228: \n229: \n230: class TestDownloadFile:\n231:     def test_download_file_stream(self, tmp_path: Path) -> None:\n232:         client = CodeInterpreterDataPlaneClient(\n233:             session_id=\"session-123\",\n234:             base_url=\"http://router/v1/invocations/\",\n235:         )\n236:         local_file = tmp_path / \"downloaded.txt\"\n237: \n238:         mock_response = MagicMock()\n239:         mock_response.raise_for_status = MagicMock()\n240:         mock_response.iter_content = MagicMock(return_value=[b\"file content\"])\n241:         client.session.get = MagicMock(return_value=mock_response)\n242: \n243:         client.download_file(\"/workspace/source.txt\", str(local_file))\n244:         call_args = client.session.get.call_args\n245:         assert call_args.kwargs[\"stream\"] == True\n246:         assert local_file.read_text() == \"file content\"\n247: \n248:     def test_download_file_creates_parent_directory(self, tmp_path: Path) -> None:\n249:         client = CodeInterpreterDataPlaneClient(\n250:             session_id=\"session-123\",\n251:             base_url=\"http://router/v1/invocations/\",\n252:         )\n253:         local_file = tmp_path / \"subdir\" / \"downloaded.txt\"\n254: \n255:         mock_response = MagicMock()\n256:         mock_response.raise_for_status = MagicMock()\n257:         mock_response.iter_content = MagicMock(return_value=[b\"file content\"])\n258:         client.session.get = MagicMock(return_value=mock_response)\n259: \n260:         client.download_file(\"/workspace/source.txt\", str(local_file))\n261:         assert local_file.parent.exists()\n262:         assert local_file.read_text() == \"file content\"\n263: \n264:     def test_download_file_removes_leading_slash(self, tmp_path: Path) -> None:\n265:         client = CodeInterpreterDataPlaneClient(\n266:             session_id=\"session-123\",\n267:             base_url=\"http://router/v1/invocations/\",\n268:         )\n269:         local_file = tmp_path / \"downloaded.txt\"\n270: \n271:         mock_response = MagicMock()\n272:         mock_response.raise_for_status = MagicMock()\n273:         mock_response.iter_content = MagicMock(return_value=[b\"content\"])\n274:         client.session.get = MagicMock(return_value=mock_response)\n275: \n276:         client.download_file(\"/workspace/source.txt\", str(local_file))\n277:         call_args = client.session.get.call_args\n278:         assert \"source.txt\" in call_args.args[0]\n279: \n280:     def test_download_file_no_parent_dir(self, tmp_path: Path) -> None:\n281:         client = CodeInterpreterDataPlaneClient(\n282:             session_id=\"session-123\",\n283:             base_url=\"http://router/v1/invocations/\",\n284:         )\n285:         local_file = tmp_path / \"file.txt\"\n286: \n287:         mock_response = MagicMock()\n288:         mock_response.raise_for_status = MagicMock()\n289:         mock_response.iter_content = MagicMock(return_value=[b\"content\"])\n290:         client.session.get = MagicMock(return_value=mock_response)\n291: \n292:         client.download_file(\"/workspace/source.txt\", str(local_file))\n293:         assert local_file.exists()\n294:         assert local_file.read_text() == \"content\"\n295: \n296: \n297: class TestListFiles:\n298:     def test_list_files_query(self) -> None:\n299:         client = CodeInterpreterDataPlaneClient(\n300:             session_id=\"session-123\",\n301:             base_url=\"http://router/v1/invocations/\",\n302:         )\n303:         mock_response = MagicMock()\n304:         mock_response.json.return_value = {\"files\": [\"file1.py\", \"file2.py\"]}\n305:         mock_response.raise_for_status = MagicMock()\n306:         client.session.get = MagicMock(return_value=mock_response)\n307: \n308:         result = client.list_files(\"/workspace\")\n309:         call_args = client.session.get.call_args\n310:         assert call_args.kwargs[\"params\"][\"path\"] == \"/workspace\"\n311:         assert result == {\"files\": [\"file1.py\", \"file2.py\"]}\n312: \n313:     def test_list_files_default_path(self) -> None:\n314:         client = CodeInterpreterDataPlaneClient(\n315:             session_id=\"session-123\",\n316:             base_url=\"http://router/v1/invocations/\",\n317:         )\n318:         mock_response = MagicMock()\n319:         mock_response.json.return_value = {\"files\": []}\n320:         mock_response.raise_for_status = MagicMock()\n321:         client.session.get = MagicMock(return_value=mock_response)\n322: \n323:         result = client.list_files()\n324:         call_args = client.session.get.call_args\n325:         assert call_args.kwargs[\"params\"][\"path\"] == \".\"\n326: \n327: \n328: class TestClose:\n329:     def test_close_session(self) -> None:\n330:         client = CodeInterpreterDataPlaneClient(\n331:             session_id=\"session-123\",\n332:             base_url=\"http://router/v1/invocations/\",\n333:         )\n334:         mock_close = MagicMock()\n335:         client.session.close = mock_close\n336: \n337:         client.close()\n338:         mock_close.assert_called_once()\n\n(End of file - total 338 lines)\n</content>","metadata":{"preview":"import pytest\nfrom unittest.mock import MagicMock, patch, mock_open\nfrom pathlib import Path\nimport base64\nimport requests\n\nfrom agentcube.clients.code_interpreter_data_plane import CodeInterpreterDataPlaneClient\nfrom agentcube.exceptions import CommandExecutionError\n\n\nclass TestDataPlaneClientInit:\n    def test_init_with_session_id(self) -> None:\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"session-123\",\n            router_url=\"http://router\",\n            namespace=\"default\",\n            cr_name=\"test-interpreter\",\n        )\n        assert client.session_id == \"session-123\"\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/sdk-python/tests/test_data_plane.py","time":{"start":1775900586842,"end":1775900586861}}}}
