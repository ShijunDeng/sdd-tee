gent/invocations/\",\n34:             headers={\"x-agentcube-session-id\": \"test-session-456\"},\n35:         )\n36:         responses.post(\n37:             \"http://router.example.com/v1/namespaces/default/agent-runtimes/test-agent/invocations/\",\n38:             json={\"output\": \"processed\", \"status\": \"completed\"},\n39:             status=200,\n40:         )\n41:         client = AgentRuntimeClient(\n42:             agent_name=\"test-agent\",\n43:             router_url=\"http://router.example.com\",\n44:         )\n45:         result = client.invoke({\"action\": \"process\", \"data\": \"input\"})\n46:         assert result[\"output\"] == \"processed\"\n47:         assert result[\"status\"] == \"completed\"\n48:         client.close()\n49: \n50: \n51: class TestSessionReuseIntegration:\n52:     @responses.activate\n53:     def test_session_reuse_across_multiple_invokes(self):\n54:         responses.get(\n55:             \"http://router.example.com/v1/namespaces/default/agent-runtimes/test-agent/invocations/\",\n56:             headers={\"x-agentcube-session-id\": \"persistent-session\"},\n57:         )\n58:         responses.post(\n59:             \"http://router.example.com/v1/namespaces/default/agent-runtimes/test-agent/invocations/\",\n60:             json={\"result\": \"first\"},\n61:             status=200,\n62:         )\n63:         responses.post(\n64:             \"http://router.example.com/v1/namespaces/default/agent-runtimes/test-agent/invocations/\",\n65:             json={\"result\": \"second\"},\n66:             status=200,\n67:         )\n68:         client = AgentRuntimeClient(\n69:             agent_name=\"test-agent\",\n70:             router_url=\"http://router.example.com\",\n71:         )\n72:         session_id = client.session_id\n73:         result1 = client.invoke({\"call\": \"1\"})\n74:         result2 = client.invoke({\"call\": \"2\"})\n75:         assert session_id == \"persistent-session\"\n76:         assert result1[\"result\"] == \"first\"\n77:         assert result2[\"result\"] == \"second\"\n78:         assert client.session_id == session_id\n79:         client.close()\n80: \n81: \n82: class TestBootstrapFailure:\n83:     @responses.activate\n84:     def test_error_handling_on_bootstrap_failure(self):\n85:         responses.get(\n86:             \"http://router.example.com/v1/namespaces/default/agent-runtimes/test-agent/invocations/\",\n87:         )\n88:         with pytest.raises(ValueError, match=\"Missing required response header: x-agentcube-session-id\"):\n89:             AgentRuntimeClient(\n90:                 agent_name=\"test-agent\",\n91:                 router_url=\"http://router.example.com\",\n92:             )\n93: \n94: \n95: class TestInvokeFailure:\n96:     @responses.activate\n97:     def test_error_handling_on_invoke_failure(self):\n98:         responses.get(\n99:             \"http://router.example.com/v1/namespaces/default/agent-runtimes/test-agent/invocations/\",\n100:             headers={\"x-agentcube-session-id\": \"test-session\"},\n101:         )\n102:         responses.post(\n103:             \"http://router.example.com/v1/namespaces/default/agent-runtimes/test-agent/invocations/\",\n104:             json={\"error\": \"Internal Server Error\"},\n105:             status=500,\n106:         )\n107:         client = AgentRuntimeClient(\n108:             agent_name=\"test-agent\",\n109:             router_url=\"http://router.example.com\",\n110:             session_id=\"test-session\",\n111:         )\n112:         with pytest.raises(requests.HTTPError):\n113:             client.invoke({\"input\": \"test\"})\n114:         client.close()\n\n(End of file - total 114 lines)\n</content>","metadata":{"preview":"import pytest\nimport responses\nimport requests\n\nfrom agentcube.agent_runtime import AgentRuntimeClient\n\n\nclass TestSessionLifecycle:\n    @responses.activate\n    def test_full_session_lifecycle(self):\n        responses.get(\n            \"http://ro