-coding-plan-glm-5_20260410T163124Z/pkg/router/doc.go\n/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/config.go","metadata":{"count":15,"truncated":false},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z","time":{"start":1775852274819,"end":1775852274839}}}}
