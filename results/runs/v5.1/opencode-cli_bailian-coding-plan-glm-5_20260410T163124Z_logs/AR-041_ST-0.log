─────────────────────────┐\n35: │                         pkg/store                                │\n36: │  ┌──────────────┐  ┌────────────────┐  ┌─────────────────────┐   │\n37: │  │   Store      │──│   redisStore   │──│    valkeyStore      │   │\n38: │  │  Interface   │  │                │  │                     │   │\n39: │  └──────────────┘  └────────────────┘  └─────────────────────┘   │\n40: │  Keys: session:{id}, session:expiry (ZSET), session:last_activity│\n41: └─────────────────────────────────────────────────────────────────┘\n42:                               │\n43:                               ▼\n44: ┌─────────────────────────────────────────────────────────────────┐\n45: │                         pkg/picod                                │\n46: │  ┌──────────┐  ┌──────────────┐  ┌─────────────┐  ┌──────────┐  │\n47: │  │  Server  │──│ AuthManager  │──│   Execute   │──│  Files   │  │\n48: │  │          │  │              │  │  Handler    │  │ Handler  │  │\n49: │  └──────────┘  └──────────────┘  └─────────────┘  └──────────┘  │\n50: │  ┌─────────────┐  ┌────────────┐  ┌──────────────────────────┐  │\n51: │  │   sanitize  │──│   health   │──│         Config           │  │\n52: │  │             │  │            │  │                          │  │\n53: │  └─────────────┘  └────────────┘  └──────────────────────────┘  │\n54: └─────────────────────────────────────────────────────────────────┘\n55: ```\n56: \n57: ### Test Architecture\n58: \n59: ```\n60:                     ┌─────────────────────────────────────┐\n61:                     │         Test Categories             │\n62:                     └─────────────────────────────────────┘\n63:                                      │\n64:            ┌─────────────────────────┼─────────────────────────┐\n65:            │                         │                         │\n66:            ▼                         ▼                         ▼\n67:     ┌──────────────┐          ┌──────────────┐          ┌──────────────┐\n68:     │  Unit Tests  │          │ Integration  │          │  Mock Tests  │\n69:     │  (Pure)      │          │   Tests      │          │              │\n70:     └──────────────┘          └──────────────┘          └──────────────┘\n71:            │                         │                         │\n72:            ▼                         ▼                         ▼\n73:     - JWT logic                - HTTP handlers            - MockStore\n74:     - Error types              - Server init              - MockSessionMgr\n75:     - Config                   - Graceful shutdown        - MockLogger\n76:     - Path sanitization        - Route registration       - MockHTTPClient\n77:     - Key generation           - Proxy handling           - FakeK8sClient\n78: \n79:                     ┌─────────────────────────────────────┐\n80:                     │      Test Infrastructure            │\n81:                     └─────────────────────────────────────┘\n82:                                      │\n83:            ┌─────────────────────────┼─────────────────────────┐\n84:            │                         │                         │\n85:            ▼                         ▼                         ▼\n86:     ┌──────────────┐          ┌──────────────┐          ┌──────────────┐\n87:     │  miniredis   │          │ httptest     │          │  testify    │\n88:     │  (Redis mock)│          │  (HTTP mock) │          │  (assert)   │\n89:     └──────────────┘          └──────────────┘          └──────────────┘\n90: ```\n91: \n92: ---\n93: \n94: ## Data Structures\n95: \n96: ### pkg/router\n97: \n98: ```go\n99: // Server (pkg/router/server.go)\n100: type Server struct {\n101:     config         *Config\n102:     engine         *gin.Engine\n103:     httpServer     *http.Server\n104:     sessionManager SessionManager\n105:     storeClient    Store\n106:     httpTransport  *http.Transport\n107:     jwtManager     *JWTManager\n108:     logger         Logger\n109: }\n110: \n111: // Config (pkg/router/config.go)\n112: type Config struct {\n113:     Port                  string\n114:     EnableTLS             bool\n115:     TLSCert               string\n116:     TLSKey                string\n117:     MaxConcurrentRequests int\n118:     Debug                 bool\n119: }\n120: \n121: // RouterClaims (pkg/router/jwt.go)\n122: type RouterClaims struct {\n123:     SessionID string `json:\"session_id\"`\n124:     SandboxID string `json:\"sandbox_id\"`\n125:     Namespace string `json:\"namespace\"`\n126:     Name      string `json:\"name\"`\n127:     jwt.RegisteredClaims\n128: }\n129: \n130: // JWTManager (pkg/router/jwt.go)\n131: type JWTManager struct {\n132:     privateKey *rsa.PrivateKey\n133:     publicKey  *rsa.PublicKey\n134:     k8sClient  kubernetes.Interface\n135:     config     *JWTConfig\n136: }\n137: \n138: // sessionManager (pkg/router/session_manager.go)\n139: type sessionManager struct {\n140:     storeClient     Store\n141:     workloadMgrAddr string\n142:     httpClient      *http.Client\n143: }\n144: \n145: // ReverseProxyWrapper (pkg/router/reverse_proxy.go)\n146: type ReverseProxyWrapper struct {\n147:     director       func(*http.Request)\n148:     modifyResponse func(*http.Response) error\n149:     errorHandler   func(http.ResponseWriter, *http.Request, error)\n150: }\n151: ```\n152: \n153: ### pkg/store\n154: \n155: ```go\n156: // Store Interface (pkg/store/store.go)\n157: type Store interface {\n158:     Ping(ctx context.Context) error\n159:     GetSandboxBySessionID(ctx context.Context, sessionID string) (*types.SandboxInfo, error)\n160:     StoreSandbox(ctx context.Context, sandbox *types.SandboxInfo) error\n161:     UpdateSandbox(ctx context.Context, sandbox *types.SandboxInfo) error\n162:     DeleteSandboxBySessionID(ctx context.Context, sessionID string) error\n163:     ListExpiredSandboxes(ctx context.Context, before time.Time, limit int64) ([]*types.SandboxInfo, error)\n164:     ListInactiveSandboxes(ctx context.Context, before time.Time, limit int64) ([]*types.SandboxInfo, error)\n165:     UpdateSessionLastActivity(ctx context.Context, sessionID string, at time.Time) error\n166:     Close() error\n167: }\n168: \n169: // redisStore (pkg/store/store_redis.go)\n170: type redisStore struct {\n171:     cli                  *redisv9.Client\n172:     sessionPrefix        string     // Default: \"session:\"\n173:     expiryIndexKey       string     // Default: \"session:expiry\" (ZSET)\n174:     lastActivityIndexKey string     // Default: \"session:last_activity\" (ZSET)\n175: }\n176: \n177: // valkeyStore (pkg/store/store_valkey.go)\n178: type valkeyStore struct {\n179:     cli                  valkey.Client\n180:     sessionPrefix        string\n181:     expiryIndexKey       string\n182:     lastActivityIndexKey string\n183: }\n184: \n185: // Error constants\n186: var (\n187:     ErrNotFound         = errors.New(\"store: not found\")\n188:     ErrNilSandbox       = errors.New(\"store: sandbox is nil\")\n189:     ErrZeroExpiresAt    = errors.New(\"store: expiresAt is required\")\n190:     ErrEmptySessionID   = errors.New(\"store: sessionID is required\")\n191:     ErrInvalidProvider  = errors.New(\"store: invalid provider type\")\n192:     ErrPasswordRequired = errors.New(\"store: password is required\")\n193:     ErrKeyNotExists     = errors.New(\"store: key not exists\")\n194:     ErrSessionExists    = errors.New(\"store: session already exists\")\n195: )\n196: ```\n197: \n198: ### pkg/picod\n199: \n200: ```go\n201: // Server (pkg/picod/server.go)\n202: type Server struct {\n203:     config      *Config\n204:     engine      *gin.Engine\n205:     httpServer  *http.Server\n206:     authManager *AuthManager\n207:     workspace   string\n208:     startTime   time.Time\n209: }\n210: \n211: // Config (pkg/picod/config.go)\n212: type Config struct {\n213:     Port      int\n214:     Workspace string\n215: }\n216: \n217: // AuthManager (pkg/picod/auth.go)\n218: type AuthManager struct {\n219:     publicKey *rsa.PublicKey\n220:     mutex     sync.RWMutex\n221: }\n222: \n223: // ExecuteRequest/Response (pkg/picod/execute.go)\n224: type ExecuteRequest struct {\n225:     Command    []string          `json:\"command\" binding:\"required\"`\n226:     Timeout    string            `json:\"timeout\"`\n227:     WorkingDir string            `json:\"working_dir\"`\n228:     Env        map[string]string `json:\"env\"`\n229: }\n230: \n231: type ExecuteResponse struct {\n232:     Stdout    string    `json:\"stdout\"`\n233:     Stderr    string    `json:\"stderr\"`\n234:     ExitCode  int       `json:\"exit_code\"`\n235:     Duration  float64   `json:\"duration\"`\n236:     StartTime time.Time `json:\"start_time\"`\n237:     EndTime   time.Time `json:\"end_time\"`\n238: }\n239: \n240: // FileInfo/FileEntry (pkg/picod/files.go)\n241: type FileInfo struct {\n242:     Path     string    `json:\"path\"`\n243:     Size     int64     `json:\"size\"`\n244:     Mode     string    `json:\"mode\"`\n245:     Modified time.Time `json:\"modified\"`\n246: }\n247: \n248: type FileEntry struct {\n249:     Name     string    `json:\"name\"`\n250:     Size     int64     `json:\"size\"`\n251:     Modified time.Time `json:\"modified\"`\n252:     Mode     string    `json:\"mode\"`\n253:     IsDir    bool      `json:\"is_dir\"`\n254: }\n255: \n256: type ListFilesResponse struct {\n257:     Files []FileEntry `json:\"files\"`\n258:     Path  string      `json:\"path\"`\n259: }\n260: ```\n261: \n262: ### pkg/common/types\n263: \n264: ```go\n265: // SandboxInfo (pkg/common/types/sandbox.go)\n266: type SandboxInfo struct {\n267:     Kind               string              `json:\"kind\"`\n268:     SandboxID          string              `json:\"sandboxId\"`\n269:     SandboxNamespace   string              `json:\"sandboxNamespace\"`\n270:     SandboxName        string              `json:\"sandboxName\"`\n271:     Name               string              `json:\"name\"`\n272:     SessionID          string              `json:\"sessionId\"`\n273:     CreatedAt          time.Time           `json:\"createdAt\"`\n274:     ExpiresAt          time.Time           `json:\"expiresAt\"`\n275:     Status             string              `json:\"status\"`\n276:     EntryPoints        []SandboxEntryPoint `json:\"entryPoints\"`\n277:     UserToken          string              `json:\"userToken,omitempty\"`\n278:     ServiceAccount     string              `json:\"serviceAccount,omitempty\"`\n279:     ServiceAccountName string              `json:\"serviceAccountName,omitempty\"`\n280:     LastActivity       time.Time           `json:\"lastActivity,omitempty\"`\n281: }\n282: \n283: type SandboxEntryPoint struct {\n284:     Path     string `json:\"path\"`\n285:     Protocol string `json:\"protocol\"`\n286:     Endpoint string `json:\"endpoint\"`\n287: }\n288: \n289: // Kind constants\n290: const (\n291:     AgentRuntimeKind    = \"AgentRuntime\"\n292:     CodeInterpreterKind = \"CodeInterpreter\"\n293:     SandboxKind         = \"Sandbox\"\n294:     SandboxClaimKind    = \"SandboxClaim\"\n295: )\n296: ```\n297: \n298: ---\n299: \n300: ## API Contracts\n301: \n302: ### Router HTTP Endpoints\n303: \n304: | Endpoint | Method | Handler | Purpose |\n305: |----------|--------|---------|---------|\n306: | `/health/live` | GET | `handleHealthLive` | Liveness probe - returns 200 with `{\"status\": \"alive\"}` |\n307: | `/health/ready` | GET | `handleHealthReady` | Readiness probe - returns 200 if sessionManager available |\n308: | `/v1/namespaces/:namespace/agent-runtimes/:name/invocations/*path` | GET/POST | `handleAgentInvoke` | Agent runtime invocation proxy |\n309: | `/v1/namespaces/:namespace/code-interpreters/:name/invocations/*path` | GET/POST | `handleCodeInterpreterInvoke` | Code interpreter invocation proxy |\n310: \n311: **Router Request Headers:**\n312: - `x-agentcube-session-id`: Session identifier (optional, triggers new session creation if empty)\n313: \n314: **Router Response Headers (proxy):**\n315: - `x-agentcube-session-id`: Echoed session ID for client tracking\n316: \n317: ### PicoD HTTP Endpoints\n318: \n319: | Endpoint | Method | Handler | Auth Required |\n320: |----------|--------|---------|---------------|\n321: | `/health` | GET | `HealthCheckHandler` | No - returns service status |\n322: | `/api/execute` | POST | `ExecuteHandler` | Yes (RS256 JWT) |\n323: | `/api/files` | POST | `UploadFileHandler` | Yes (RS256 JWT) |\n324: | `/api/files` | GET | `ListFilesHandler` | Yes (RS256 JWT) |\n325: | `/api/files/*path` | GET | `DownloadFileHandler` | Yes (RS256 JWT) |\n326: \n327: **Execute API Contract:**\n328: ```json\n329: // Request\n330: {\n331:     \"command\": [\"echo\", \"hello\"],\n332:     \"timeout\": \"5s\",\n333:     \"working_dir\": \"subdir\",\n334:     \"env\": {\"MY_VAR\": \"value\"}\n335: }\n336: \n337: // Response (200 OK)\n338: {\n339:     \"stdout\": \"hello\\n\",\n340:     \"stderr\": \"\",\n341:     \"exit_code\": 0,\n342:     \"duration\": 0.01,\n343:     \"start_time\": \"2024-01-01T00:00:00Z\",\n344:     \"end_time\": \"2024-01-01T00:00:01Z\"\n345: }\n346: \n347: // Timeout Response (200 OK)\n348: {\n349:     \"stdout\": \"\",\n350:     \"stderr\": \"command timed out\",\n351:     \"exit_code\": 124,\n352:     ...\n353: }\n354: ```\n355: \n356: **Files Upload API Contract (JSON):**\n357: ```json\n358: // Request\n359: {\n360:     \"path\": \"test.txt\",\n361:     \"content\": \"base64-encoded-content\",\n362:     \"mode\": \"0644\"\n363: }\n364: \n365: // Response (200 OK)\n366: {\n367:     \"path\": \"test.txt\",\n368:     \"size\": 12,\n369:     \"mode\": \"0644\",\n370:     \"modified\": \"2024-01-01T00:00:00Z\"\n371: }\n372: ```\n373: \n374: **Files Upload API Contract (multipart/form-data):**\n375: - Form field `path`: Required, file destination path\n376: - Form field `file`: Required, file content\n377: - Form field `mode`: Optional, file permissions (octal string)\n378: \n379: ### Store Interface Contract\n380: \n381: | Method | Input | Output | Error Conditions |\n382: |--------|-------|--------|------------------|\n383: | `Ping` | `ctx` | `error` | Connection failure, unexpected response |\n384: | `GetSandboxBySessionID` | `ctx, sessionID` | `*SandboxInfo, error` | `ErrEmptySessionID`, `ErrNotFound`, JSON parse error |\n385: | `StoreSandbox` | `ctx, *SandboxInfo` | `error` | `ErrNilSandbox`, `ErrEmptySessionID`, `ErrZeroExpiresAt`, `ErrSessionExists` |\n386: | `UpdateSandbox` | `ctx, *SandboxInfo` | `error` | `ErrNilSandbox`, `ErrEmptySessionID`, `ErrNotFound` |\n387: | `DeleteSandboxBySessionID` | `ctx, sessionID` | `error` | `ErrEmptySessionID` |\n388: | `ListExpiredSandboxes` | `ctx, before, limit` | `[]*SandboxInfo, error` | Zero/negative limit → nil, nil |\n389: | `ListInactiveSandboxes` | `ctx, before, limit` | `[]*SandboxInfo, error` | Zero/negative limit → nil, nil |\n390: | `UpdateSessionLastActivity` | `ctx, sessionID, at` | `error` | `ErrEmptySessionID`, `ErrNotFound` |\n391: | `Close` | - | `error` | Close failure |\n392: \n393: ---\n394: \n395: ## Error Handling\n396: \n397: ### Router Error Types (pkg/router/errors.go)\n398: \n399: All router errors implement the `APIStatus` interface:\n400: \n401: ```go\n402: type APIStatus interface {\n403:     Status() int    // HTTP status code\n404:     Code() string   // Error code for client parsing\n405:     Message() string // Human-readable message\n406: }\n407: ```\n408: \n409: | Error Type | Status | Code | Condition |\n410: |------------|--------|------|-----------|\n411: | `SessionNotFoundError` | 404 | SESSION_NOT_FOUND | Session not in store |\n412: | `SandboxUnreachableError` | 502 | SANDBOX_UNREACHABLE | Connection refused to sandbox |\n413: | `SandboxTimeoutError` | 504 | SANDBOX_TIMEOUT | Request timeout to sandbox |\n414: | `JWTSigningError` | 500 | JWT_SIGNING_FAILED | Token signing failure |\n415: | `JWTValidationError` | 401 | JWT_VALIDATION_FAILED | Token validation failure |\n416: | `JWTTokenExpiredError` | 401 | JWT_TOKEN_EXPIRED | Token expired |\n417: | `JWTTokenMissingError` | 401 | JWT_TOKEN_MISSING | No Authorization header |\n418: | `JWTInvalidFormatError` | 401 | JWT_INVALID_FORMAT | Malformed auth header |\n419: | `JWTKeyLoadError` | 500 | JWT_KEY_LOAD_FAILED | RSA key load failure |\n420: | `ServerOverloadedError` | 429 | SERVER_OVERLOADED | Concurrency limit exceeded |\n421: | `NoEntryPointError` | 404 | NO_ENTRY_POINT | No entry point configured |\n422: | `WorkloadManagerError` | varies | WORKLOAD_MANAGER_ERROR | Workload manager failure |\n423: \n424: ### PicoD Error Responses\n425: \n426: | Endpoint | Status | Error Message | Condition |\n427: |----------|--------|---------------|-----------|\n428: | Auth Middleware | 401 | `missing authorization header` | No `Authorization` header |\n429: | Auth Middleware | 401 | `invalid token format` | Missing \"Bearer \" prefix |\n430: | Auth Middleware | 401 | `token is expired` | JWT `exp` claim past |\n431: | Auth Middleware | 401 | `invalid signature` | Signature verification failed |\n432: | Auth Middleware | 401 | `invalid signing method` | Non-RS256 algorithm |\n433: | Execute | 400 | `invalid request body` | JSON parse failure |\n434: | Execute | 400 | `missing command` | Empty `command` array |\n435: | Execute | 400 | `invalid working directory` | Path escape detected |\n436: | Files Upload | 400 | `missing path parameter` | No `path` field |\n437: | Files Upload | 400 | `missing file` | No multipart `file` field |\n438: | Files Upload | 400 | `invalid base64 content` | Base64 decode failure |\n439: | Files Upload | 400 | `invalid path` | Path escape detected |\n440: | Files Upload | 400 | `invalid file mode` | Mode > 0777 |\n441: | Files List | 400 | `missing path parameter` | No `path` query param |\n442: | Files List | 400 | `invalid path` | Path escape detected |\n443: | Files List | 500 | `failed to read directory` | Directory not readable |\n444: | Files Download | 400 | `invalid path` | Path escape detected |\n445: | Files Download | 400 | `path is not a file` | Path is directory |\n446: | Files Download | 404 | `file not found` | File does not exist |\n447: \n448: ### Store Error Handling\n449: \n450: | Error | Return Condition |\n451: |-------|-----------------|\n452: | `ErrNotFound` | Key not found in Redis/Valkey |\n453: | `ErrNilSandbox` | nil sandbox passed to Store/Update |\n454: | `ErrZeroExpiresAt` | ExpiresAt is time.Time{} |\n455: | `ErrEmptySessionID` | SessionID is empty string |\n456: | `ErrPasswordRequired` | Password env var missing and not optional |\n457: | `ErrSessionExists` | SetNX returned false (key already exists) |\n458: \n459: ---\n460: \n461: ## Testing Strategy\n462: \n463: ### Coverage Requirements\n464: \n465: | Module | Target Coverage | Priority |\n466: |--------|-----------------|----------|\n467: | pkg/router | 90% | High |\n468: | pkg/store | 95% | High |\n469: | pkg/picod | 90% | High |\n470: | pkg/common/types | 100% | Medium |\n471: \n472: ### Test Categories\n473: \n474: #### Unit Tests (Pure Logic)\n475: \n476: **router:**\n477: - JWT token generation/validation with various claims\n478: - Error type methods (Status, Code, Message, Error, Unwrap)\n479: - Config defaults and validation\n480: - Reverse proxy URL building logic\n481: - Entry point selection algorithm\n482: - Key generation (sessionKey)\n483: \n484: **store:**\n485: - Store interface implementation correctness\n486: - Error type equality checking\n487: - Key prefix constants\n488: - Singleton pattern (Storage/ResetStorage)\n489: - Environment variable parsing (makeRedisOptions, newValkeyStoreFromEnv)\n490: \n491: **picod:**\n492: - Path sanitization (valid paths, traversal attacks, symlinks)\n493: - File mode parsing (valid octal, invalid, too high)\n494: - JWT public key loading (PEM decode, PKIX parse)\n495: \n496: #### Integration Tests (HTTP Handlers)\n497: \n498: **router:**\n499: - Server initialization with various configs\n500: - Route registration verification\n501: - Health endpoints (live/ready with various states)\n502: - TLS configuration (missing cert/key)\n503: - Graceful shutdown behavior\n504: - Concurrency limit enforcement\n505: - Proxy request handling with mock backends\n506: \n507: **picod:**\n508: - Execute handler (success, timeout, exit codes, working dir, env)\n509: - File operations (upload, list, download)\n510: - Authentication flow (valid/expired/invalid tokens)\n511: - Health check endpoint\n512: - Concurrent operations safety\n513: \n514: #### Mock-Based Tests\n515: \n516: **Required Mock Types:**\n517: \n518: ```go\n519: // pkg/router mocks\n520: type MockStore struct {\n521:     GetSandboxBySessionIDFunc     func(ctx, sessionID) (*SandboxInfo, error)\n522:     StoreSandboxFunc              func(ctx, *SandboxInfo) error\n523:     UpdateSandboxFunc             func(ctx, *SandboxInfo) error\n524:     DeleteSandboxBySessionIDFunc  func(ctx, sessionID) error\n525:     UpdateSessionLastActivityFunc func(ctx, sessionID, time) error\n526:     ListExpiredSandboxesFunc      func(ctx, time, int64) ([]*SandboxInfo, error)\n527:     ListInactiveSandboxesFunc     func(ctx, time, int64) ([]*SandboxInfo, error)\n528:     PingFunc                     func(ctx) error\n529:     CloseFunc                    func() error\n530: }\n531: \n532: type MockSessionManager struct {\n533:     GetSandboxBySessionFunc func(ctx, sessionID, namespace, name, kind) (*SandboxInfo, error)\n534: }\n535: \n536: type MockLogger struct {\n537:     InfoCalls, ErrorCalls, WarningCalls []string\n538: }\n539: \n540: type MockHTTPClient struct {\n541:     DoFunc func(*http.Request) (*http.Response, error)\n542: }\n543: ```\n544: \n545: ### Test Helper Functions\n546: \n547: ```go\n548: // pkg/router helpers\n549: func setupTestRouter(t *testing.T, opts ...Option) *Server\n550: func makeTestRequest(method, path, body) *http.Request\n551: func makeTestSandbox(sessionID string) *types.SandboxInfo\n552: \n553: // pkg/store helpers (existing)\n554: func setupTestRedisStore(t *testing.T) *redisStore\n555: func setupTestValkeyStore(t *testing.T) *valkeyStore\n556: \n557: // pkg/picod helpers (existing)\n558: func setupTestServer(t *testing.T) *Server\n559: func generateTestRSAKey(t *testing.T) (*rsa.PrivateKey, string)\n560: func generateTestJWT(privateKey *rsa.PrivateKey, expired bool) string\n561: func makeAuthenticatedRequest(t, server, method, path, body, contentType, jwtToken)\n562: ```\n563: \n564: ### Table-Driven Test Patterns\n565: \n566: ```go\n567: // Example: StoreSandbox table-driven test\n568: func TestRedisStore_StoreSandbox(t *testing.T) {\n569:     tests := []struct {\n570:         name    string\n571:         sandbox *types.SandboxInfo\n572:         wantErr error\n573:         setup   func(*redisStore)\n574:     }{\n575:         {\"nil sandbox\", nil, ErrNilSandbox, nil},\n576:         {\"empty sessionID\", &SandboxInfo{SessionID:\"\", ExpiresAt:time.Now()}, ErrEmptySessionID, nil},\n577:         {\"zero expiresAt\", &SandboxInfo{SessionID:\"test\", ExpiresAt:time.Time{}}, ErrZeroExpiresAt, nil},\n578:         {\"duplicate\", makeTestSandbox(\"dup\"), ErrSessionExists, func(s){s.StoreSandbox(ctx, makeTestSandbox(\"dup\"))}},\n579:         {\"valid\", makeTestSandbox(\"valid\"), nil, nil},\n580:     }\n581:     \n582:     store := setupTestRedisStore(t)\n583:     ctx := context.Background()\n584:     \n585:     for _, tt := range tests {\n586:         t.Run(tt.name, func(t *testing.T) {\n587:             if tt.setup != nil { tt.setup(store) }\n588:             err := store.StoreSandbox(ctx, tt.sandbox)\n589:             if tt.wantErr != nil {\n590:                 assert.ErrorIs(t, err, tt.wantErr)\n591:             } else {\n592:                 assert.NoError(t, err)\n593:             }\n594:         })\n595:     }\n596: }\n597: ```\n598: \n599: ---\n600: \n601: ## File Structure\n602: \n603: ### Test File Organization\n604: \n605: ```\n606: pkg/\n607: ├── router/\n608: │   ├── server.go              └── server_test.go          # 380 lines, 15+ tests\n609: │   ├── config.go              └── config_test.go          # Need to add\n610: │   ├── jwt.go                 └── jwt_test.go             # Need comprehensive tests\n611: │   ├── errors.go              └── errors_test.go          # 189 lines, 14 tests (100%)\n612: │   ├── middleware.go          └── middleware_test.go      # 305 lines, 13 tests\n613: │   ├── session_manager.go     └── session_manager_test.go # 366 lines, 12 tests\n614: │   ├── reverse_proxy.go       └── reverse_proxy_test.go   # Need to add\n615: │   ├── doc.go\n616: │\n617: ├── store/\n618: │   ├── store.go               └── store_test.go           # 759 lines, 45+ tests\n619: │   ├── store_redis.go         │\n620: │   ├── store_valkey.go        └── valkey_test.go          # Need comprehensive tests\n621: │   ├── doc.go\n622: │\n623: ├── picod/\n624: │   ├── server.go              │\n625: │   ├── config.go              │\n626: │   ├── auth.go                └── auth_test.go            # Need edge cases\n627: │   ├── execute.go             └── execute_test.go         # Need edge cases\n628: │   ├── files.go               └── files_test.go           # Need edge cases\n629: │   ├── sanitize.go            └── sanitize_test.go        # Covered in picod_test.go\n630: │   ├── health.go              │\n631: │   ├── picod_test.go          # 1109 lines, 50+ tests (comprehensive)\n632: │   ├── doc.go\n633: │\n634: └── common/\n635: │   └── types/\n636: │       ├── sandbox.go         └── sandbox_test.go         # Need validation tests\n637: │       └── doc.go\n638: ```\n639: \n640: ### Current vs Required Tests\n641: \n642: | Module | File | Current Lines | Current Tests | Required Tests |\n643: |--------|------|---------------|---------------|----------------|\n644: | router | server_test.go | 380 | 15+ | ✓ Adequate |\n645: | router | config_test.go | - | 0 | Add: DefaultConfig, validation |\n646: | router | jwt_test.go | - | 0 | Add: GenerateToken, ValidateToken, Refresh, Key loading |\n647: | router | errors_test.go | 189 | 14 | ✓ Complete |\n648: | router | middleware_test.go | 305 | 13 | ✓ Adequate |\n649: | router | session_manager_test.go | 366 | 12 | ✓ Adequate |\n650: | router | reverse_proxy_test.go | - | 0 | Add: Director, ErrorHandler, URL building |\n651: | store | store_test.go | 759 | 45+ | ✓ Comprehensive |\n652: | store | valkey_test.go | - | 0 | Add: Match Redis coverage |\n653: | picod | picod_test.go | 1109 | 50+ | ✓ Comprehensive |\n654: | picod | auth_test.go | - | 0 | Add: Concurrent key update |\n655: | picod | execute_test.go | - | 0 | Add: Command not found, large output |\n656: | picod | files_test.go | - | 0 | Add: Overwrite, special chars |\n657: | types | sandbox_test.go | - | 0 | Add: Validate() tests |\n658: \n659: ---\n660: \n661: ## Dependencies\n662: \n663: ### Test Dependencies\n664: \n665: ```go\n666: // go.mod test dependencies\n667: require (\n668:     github.com/stretchr/testify v1.9.0      // assert, require\n669:     github.com/alicebob/miniredis/v2 v2.33.0 // Redis mock\n670:     github.com/gin-gonic/gin v1.10.0        // HTTP framework (test mode)\n671:     github.com/redis/go-redis/v9 v9.7.0     // Redis client\n672:     github.com/valkey-io/valkey-go v1.0.0   // Valkey client\n673:     github.com/golang-jwt/jwt/v5 v5.2.0     // JWT handling\n674: )\n675: ```\n676: \n677: ### Import Patterns\n678: \n679: ```go\n680: // Standard test imports\n681: import (\n682:     \"testing\"\n683:     \"context\"\n684:     \"time\"\n685:     \"net/http/httptest\"\n686:     \"encoding/json\"\n687:     \n688:     \"github.com/stretchr/testify/assert\"\n689:     \"github.com/stretchr/testify/require\"\n690:     \"github.com/gin-gonic/gin\"\n691:     \"github.com/alicebob/miniredis/v2\"\n692: )\n693: ```\n694: \n695: ---\n696: \n697: ## Implementation Notes\n698: \n699: ### Running Tests\n700: \n701: ```bash\n702: # Run all pkg tests\n703: go test ./pkg/... -v\n704: \n705: # Module-specific tests\n706: go test ./pkg/router/... -v\n707: go test ./pkg/store/... -v\n708: go test ./pkg/picod/... -v\n709: \n710: # With coverage\n711: go test ./pkg/... -cover -coverprofile=coverage.out\n712: go tool cover -func=coverage.out\n713: go tool cover -html=coverage.out\n714: \n715: # Race detection\n716: go test ./pkg/... -race\n717: \n718: # Specific test\n719: go test ./pkg/router -run TestJWTManager -v\n720: ```\n721: \n722: ### miniredis Usage\n723: \n724: ```go\n725: func setupTestRedisStore(t *testing.T) *redisStore {\n726:     mr := miniredis.RunT(t)  // Auto-cleanup with t.Cleanup\n727:     cli := redisv9.NewClient(&redisv9.Options{Addr: mr.Addr()})\n728:     return &redisStore{\n729:         cli: cli,\n730:         sessionPrefix: \"session:\",\n731:         expiryIndexKey: \"session:expiry\",\n732:         lastActivityIndexKey: \"session:last_activity\",\n733:     }\n734: }\n735: ```\n736: \n737: ### Gin Test Mode\n738: \n739: ```go\n740: func TestExample(t *testing.T) {\n741:     gin.SetMode(gin.TestMode)  // Required for consistent behavior\n742:     \n743:     router := gin.New()\n744:     router.GET(\"/test\", handler)\n745:     \n746:     w := httptest.NewRecorder()\n747:     req := httptest.NewRequest(\"GET\", \"/test\", nil)\n748:     router.ServeHTTP(w, req)\n749:     \n750:     assert.Equal(t, 200, w.Code)\n751: }\n752: ```\n753: \n754: ### Environment Variable Cleanup\n755: \n756: ```go\n757: func setupWithEnv(t *testing.T, key, value string) {\n758:     old := os.Getenv(key)\n759:     os.Setenv(key, value)\n760:     t.Cleanup(func() {\n761:         if old != \"\" {\n762:             os.Setenv(key, old)\n763:         } else {\n764:             os.Unsetenv(key)\n765:         }\n766:     })\n767: }\n768: ```\n769: \n770: ---\n771: \n772: ## References\n773: \n774: - Spec: `changes/AR-039/spec.md`\n775: - Delta Spec: `changes/AR-039/delta-spec.md`\n776: - Proposal: `changes/AR-039/proposal.md`\n777: - Tasks: `changes/AR-039/tasks.md`\n778: - client-go Spec: `/tmp/agentcube-ref/client-go/`\n779: - Test Files:\n780:   - `pkg/router/server_test.go` (380 lines)\n781:   - `pkg/router/errors_test.go` (189 lines)\n782:   - `pkg/router/middleware_test.go` (305 lines)\n783:   - `pkg/router/session_manager_test.go` (366 lines)\n784:   - `pkg/store/store_test.go` (759 lines)\n785:   - `pkg/picod/picod_test.go` (1109 lines)\n\n(End of file - total 785 lines)\n</content>","metadata":{"preview":"# AR-039 — Go 单元测试 (router/store/picod) Design\n\n## Overview\n\n| Item | Value |\n|------|-------|\n| AR | AR-039 — Go 单元测试 (router/store/picod) |\n| Module | pkg |\n| Language | Go |\n| Size | L |\n| Stage | ST-2 |\n\n---\n\n## Architecture\n\n### Module Dependencies\n\n```\n┌─────────────────────────────────────────────────────────────────┐","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/changes/AR-039/design.md","time":{"start":1775901263976,"end":1775901264016}}}}
{"type":"tool_use","timestamp":1775901264021,"sessionID":"ses_28409891dffeQpeIzOMTlhIUK9","part":{"id":"prt_d7bf6c0ba00151wn7AASNY9yEq","messageID":"msg_d7bf699a5001rAHBScJuB93vXN","sessionID":"ses_28409891dffeQpeIzOMTlhIUK9","type":"tool","tool":"read","callID":"toolu_tool-6d2775510222493891020f2fe2626be6","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/changes/AR-039/proposal.md"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/changes/AR-039/proposal.md</path>\n<type>file</type>\n<content>\n1: # AR-039 — Go 单元测试 (router/store/picod)\n2: \n3: ## 概述\n4: \n5: | 属性 | 值 |\n6: |------|-----|\n7: | AR | AR-039 |\n8: | Module | pkg |\n9: | Language | Go |\n10: | Size | L |\n11: \n12: ---\n13: \n14: ## 1. Purpose (目的)\n15: \n16: 为 `pkg/router`、`pkg/store`、`pkg/picod` 三个核心模块补充和完善单元测试，确保：\n17: \n18: - **代码质量保障**：通过测试覆盖关键业务逻辑，包括 HTTP 路由、JWT 认证、会话管理、存储操作、代码执行沙箱等核心功能\n19: - **回归测试支持**：建立稳定的测试基准，支持未来代码变更的安全验证\n20: - **边界条件覆盖**：补充现有测试未覆盖的边缘场景，如错误处理路径、并发安全性、资源泄漏检测\n21: - **测试基础设施完善**：提供 Mock 实现、测试辅助函数、Benchmark 测试等基础设施\n22: \n23: ---\n24: \n25: ## 2. Scope (范围)\n26: \n27: ### 2.1 In Scope\n28: \n29: | Deliverable | Description |\n30: |-------------|-------------|\n31: | `pkg/router` 测试补充 | 补充 `handleInvoke` 错误分支测试、TLS 配置验证测试、并发请求压力测试 |\n32: | `pkg/store` 测试补充 | 补充 Valkey 存储实现测试、连接失败/重试测试、数据一致性测试 |\n33: | `pkg/picod` 测试补充 | 补充 `ExecuteHandler` 命令不存在测试、`FilesHandler` 权限边界测试、并发执行安全性测试 |\n34: | 测试辅助工具 | 完善 `MockStore`、`MockSessionManager`、`MockLogger` 等测试 Mock 实现 |\n35: | Benchmark 测试 | 为 JWT 签发/验证、存储操作、命令执行等高频操作添加性能基准测试 |\n36: \n37: ### 2.2 Out of Scope\n38: \n39: | Item | Reason |\n40: |------|--------|\n41: | `pkg/workloadmanager` 模块测试 | 属于其他 AR 范围 |\n42: | `pkg/agentd` 模块测试 | 属于其他 AR 范围 |\n43: | 集成测试和端到端测试 | 本 AR 仅关注单元测试 |\n44: | 修改生产代码逻辑 | 仅添加测试，不修改业务实现 |\n45: \n46: ---\n47: \n48: ## 3. Impact Analysis (影响分析)\n49: \n50: ### 3.1 新增文件\n51: \n52: | File | Description |\n53: |------|-------------|\n54: | `pkg/router/benchmark_test.go` | 路由处理性能基准测试 |\n55: | `pkg/store/benchmark_test.go` | 存储操作性能基准测试 |\n56: | `pkg/picod/benchmark_test.go` | PicoD 性能基准测试 |\n57: \n58: ### 3.2 修改文件\n59: \n60: | File | Change |\n61: |------|--------|\n62: | `pkg/router/server_test.go` | 补充 `handleInvoke` 错误处理测试、并发请求测试 |\n63: | `pkg/router/jwt_test.go` | 补充 JWT Key 轮换测试、时钟偏差边界测试 |\n64: | `pkg/router/session_manager_test.go` | 补充网络超时测试、重试机制测试 |\n65: | `pkg/store/store_test.go` | 补充并发读写测试、连接池耗尽测试 |\n66: | `pkg/store/valkey_test.go` | 补充 Valkey 特定功能测试 |\n67: | `pkg/picod/picod_test.go` | 补充命令执行超时测试、大文件上传测试 |\n68: | `pkg/picod/auth_test.go` | 补充密钥轮换并发安全性测试 |\n69: \n70: ### 3.3 Upstream Dependencies\n71: \n72: | Dependency | Purpose |\n73: |------------|---------|\n74: | `github.com/stretchr/testify` | 测试断言和 Mock 框架 |\n75: | `github.com/alicebob/miniredis/v2` | Redis 内存模拟服务器 |\n76: | `github.com/gin-gonic/gin` | HTTP 路由框架（测试模式） |\n77: | `github.com/golang-jwt/jwt/v5` | JWT 测试辅助 |\n78: \n79: ### 3.4 Downstream Consumers\n80: \n81: | Consumer | Usage |\n82: |----------|-------|\n83: | CI/CD Pipeline | 运行单元测试验证代码质量 |\n84: | 开发团队 | 本地开发时运行测试验证 |\n85: \n86: ---\n87: \n88: ## 4. Alternatives Considered (备选方案)\n89: \n90: ### 4.1 Ginkgo/Gomega 测试框架\n91: \n92: **优点**：\n93: - 更丰富的 DSL 语法\n94: - 内置并行测试支持\n95: \n96: **缺点**：\n97: - 需要额外依赖引入\n98: - 与现有 `testing` + `testify` 风格不一致\n99: - 学习成本较高\n100: \n101: **决策**：不采用，继续使用标准 `testing` 包配合 `testify`\n102: \n103: ### 4.2 真实 Redis/Valkey 实例测试\n104: \n105: **优点**：\n106: - 更真实的存储行为验证\n107: \n108: **缺点**：\n109: - 测试环境依赖外部服务\n110: - 测试运行速度慢\n111: - CI 环境配置复杂\n112: \n113: **决策**：不采用，继续使用 `miniredis` 内存模拟\n114: \n115: ### 4.3 集成测试替代部分单元测试\n116: \n117: **优点**：\n118: - 覆盖真实交互场景\n119: \n120: **缺点**：\n121: - 测试范围超出 AR 定义\n122: - 运行时间更长\n123: - 调试困难\n124: \n125: **决策**：不采用，严格限定为单元测试范围\n126: \n127: ---\n128: \n129: ## 5. Risks\n130: \n131: | Risk | Mitigation |\n132: |------|------------|\n133: | 测试覆盖率不足遗漏边界条件 | 使用 `go test -cover` 分析覆盖率，针对性补充 |\n134: | Mock 实现与真实行为不一致 | Mock 实现基于实际接口定义，定期同步更新 |\n135: | 测试运行时间过长影响 CI | Benchmark 测试独立文件，单元测试保持快速执行 |\n136: | 并发测试不稳定性 | 使用 `t.Parallel()` 和适当的同步机制 |\n137: \n138: ---\n139: \n140: ## 6. Implementation Checklist\n141: \n142: - [ ] 补充 `pkg/router/server_test.go` 错误处理路径测试\n143: - [ ] 补充 `pkg/router/session_manager_test.go` 网络错误测试\n144: - [ ] 补充 `pkg/router/jwt_test.go` 密钥轮换边界测试\n145: - [ ] 补充 `pkg/store/store_test.go` 并发操作测试\n146: - [ ] 补充 `pkg/store/valkey_test.go` Valkey 特性测试\n147: - [ ] 补充 `pkg/picod/picod_test.go` 命令执行边界测试\n148: - [ ] 补充 `pkg/picod/auth_test.go` 并发密钥更新测试\n149: - [ ] 创建 `pkg/router/benchmark_test.go`\n150: - [ ] 创建 `pkg/store/benchmark_test.go`\n151: - [ ] 创建 `pkg/picod/benchmark_test.go`\n152: - [ ] 运行 `go test -cover ./pkg/router ./pkg/store ./pkg/picod` 验证覆盖率\n153: - [ ] 确保所有测试通过 `go test ./pkg/...`\n154: \n155: ---\n156: \n157: ## 7. References\n158: \n159: - [client-go library spec](../deployment/client-go.md)\n160: - Go Testing Best Practices: https://go.dev/doc/tutorial/add-a-test\n161: - testify Documentation: https://github.com/stretchr/testify\n162: - miniredis Documentation: https://github.com/alicebob/miniredis\n\n(End of file - total 162 lines)\n</content>","metadata":{"preview":"# AR-039 — Go 单元测试 (router/store/picod)\n\n## 概述\n\n| 属性 | 值 |\n|------|-----|\n| AR | AR-039 |\n| Module | pkg |\n| Language | Go |\n| Size | L |\n\n---\n\n## 1. Purpose (目的)\n\n为 `pkg/router`、`pkg/store`、`pkg/picod` 三个核心模块补充和完善单元测试，确保：\n\n- **代码质量保障**：通过测试覆盖关键业务逻辑，包括 HTTP 路由、JWT 认证、会话管理、存储操作、代码执行沙箱等核心功能\n- **回归测试支持**：建立稳定的测试基准，支持未来代码变更的安全验证\n- **边界条件覆盖**：补充现有测试未覆盖的边缘场景，如错误处理路径、并发安全性、资源泄漏检测","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/changes/AR-039/proposal.md","time":{"start":1775901263978,"end":1775901264019}}}}
{"type":"tool_use","timestamp":1775901264024,"sessionID":"ses_28409891dffeQpeIzOMTlhIUK9","part":{"id":"prt_d7bf6c455001LHrV11FIPCtcrp","messageID":"msg_d7bf699a5001rAHBScJuB93vXN","sessionID":"ses_28409891dffeQpeIzOMTlhIUK9","type":"tool","tool":"read","callID":"toolu_tool-36cd469778f24cf083f0bb16ff85d4fd","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/changes/AR-039/tasks.md"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/changes/AR-039/tasks.md</path>\n<type>file</type>\n<content>\n1: # AR-039 — Go 单元测试 (router/store/picod) Tasks\n2: \n3: ## Metadata\n4: \n5: | Item | Value |\n6: |------|-------|\n7: | AR | AR-039 — Go 单元测试 (router/store/picod) |\n8: | Module | pkg |\n9: | Language | Go |\n10: | Size | L |\n11: | Design | [Stage ST-3 completed] |\n12: \n13: ---\n14: \n15: ## Task Checklist\n16: \n17: ### Phase 1: Router JWT Tests Enhancement (ST-1)\n18: \n19: - [ ] **T1.1**: Add test for `NewJWTManagerWithClient` with valid k8s client\n20:   - Purpose: Test JWT manager creation with Kubernetes client\n21:   - File: `pkg/router/jwt_test.go`\n22:   - Verification: `go test -v -run TestNewJWTManagerWithClient ./pkg/router/`\n23: \n24: - [ ] **T1.2**: Add test for `TryStoreOrLoadJWTKeySecret` with mock k8s client\n25:   - Purpose: Test secret creation and loading flow\n26:   - File: `pkg/router/jwt_test.go`\n27:   - Verification: `go test -v -run TestJWTManagerTryStoreOrLoad ./pkg/router/`\n28: \n29: - [ ] **T1.3**: Add test for `StoreKeysToSecret` update existing secret scenario\n30:   - Purpose: Test secret update flow\n31:   - File: `pkg/router/jwt_test.go`\n32:   - Verification: `go test -v -run TestJWTManagerStoreKeysUpdate ./pkg/router/`\n33: \n34: - [ ] **T1.4**: Add test for `LoadKeysFromSecret` with invalid PEM data\n35:   - Purpose: Test error handling for malformed secret data\n36:   - File: `pkg/router/jwt_test.go`\n37:   - Verification: `go test -v -run TestJWTManagerLoadKeysInvalidPEM ./pkg/router/`\n38: \n39: - [ ] **T1.5**: Add test for token validation with clock skew\n40:   - Purpose: Test `ValidateTokenWithSkew` method\n41:   - File: `pkg/router/jwt_test.go`\n42:   - Verification: `go test -v -run TestJWTManagerValidateTokenWithSkew ./pkg/router/`\n43: \n44: - [ ] **T1.6**: Add benchmark for `RefreshToken` operation\n45:   - Purpose: Measure refresh token performance\n46:   - File: `pkg/router/jwt_test.go`\n47:   - Verification: `go test -bench=BenchmarkJWTRefreshToken ./pkg/router/`\n48: \n49: ### Phase 2: Router Server Tests Enhancement (ST-2)\n50: \n51: - [ ] **T2.1**: Add test for `handleInvoke` with no entry points\n52:   - Purpose: Test error response when sandbox has no entry points\n53:   - File: `pkg/router/server_test.go`\n54:   - Verification: `go test -v -run TestServerHandleInvokeNoEntryPoints ./pkg/router/`\n55: \n56: - [ ] **T2.2**: Add test for `handleInvoke` with invalid entry point path\n57:   - Purpose: Test routing with malformed invocation path\n58:   - File: `pkg/router/server_test.go`\n59:   - Verification: `go test -v -run TestServerHandleInvokeInvalidPath ./pkg/router/`\n60: \n61: - [ ] **T2.3**: Add test for `handleGetSandboxError` with various error types\n62:   - Purpose: Test error mapping for different error categories\n63:   - File: `pkg/router/server_test.go`\n64:   - Verification: `go test -v -run TestServerHandleGetSandboxError ./pkg/router/`\n65: \n66: - [ ] **T2.4**: Add test for server with TLS configuration\n67:   - Purpose: Test TLS server initialization and startup\n68:   - File: `pkg/router/server_test.go`\n69:   - Verification: `go test -v -run TestServerTLS ./pkg/router/`\n70: \n71: - [ ] **T2.5**: Add test for concurrent request handling\n72:   - Purpose: Verify concurrency limit middleware behavior under load\n73:   - File: `pkg/router/server_test.go`\n74:   - Verification: `go test -v -run TestServerConcurrentRequests ./pkg/router/`\n75: \n76: - [ ] **T2.6**: Add integration test for full request lifecycle\n77:   - Purpose: Test complete request flow from entry to proxy\n78:   - File: `pkg/router/server_test.go`\n79:   - Verification: `go test -v -run TestServerFullLifecycle ./pkg/router/`\n80: \n81: ### Phase 3: Router Session Manager Tests Enhancement (ST-3)\n82: \n83: - [ ] **T3.1**: Add test for `createSandbox` with invalid request validation\n84:   - Purpose: Test CreateSandboxRequest validation errors\n85:   - File: `pkg/router/session_manager_test.go`\n86:   - Verification: `go test -v -run TestSessionManagerCreateSandboxValidation ./pkg/router/`\n87: \n88: - [ ] **T3.2**: Add test for `createSandbox` with connection timeout\n89:   - Purpose: Test workload manager connection timeout handling\n90:   - File: `pkg/router/session_manager_test.go`\n91:   - Verification: `go test -v -run TestSessionManagerCreateSandboxTimeout ./pkg/router/`\n92: \n93: - [ ] **T3.3**: Add test for `createSandbox` with malformed response\n94:   - Purpose: Test JSON unmarshal error handling\n95:   - File: `pkg/router/session_manager_test.go`\n96:   - Verification: `go test -v -run TestSessionManagerCreateSandboxMalformed ./pkg/router/`\n97: \n98: - [ ] **T3.4**: Add test for `GetSandboxBySession` with empty namespace\n99:   - Purpose: Test empty namespace parameter handling\n100:   - File: `pkg/router/session_manager_test.go`\n101:   - Verification: `go test -v -run TestSessionManagerEmptyNamespace ./pkg/router/`\n102: \n103: - [ ] **T3.5**: Add test for `selectEntryPoint` with exact path match\n104:   - Purpose: Verify exact path matching logic\n105:   - File: `pkg/router/session_manager_test.go`\n106:   - Verification: `go test -v -run TestSelectEntryPointExact ./pkg/router/`\n107: \n108: - [ ] **T3.6**: Add test for `buildTargetURL` with WebSocket protocol\n109:   - Purpose: Test WebSocket endpoint URL building\n110:   - File: `pkg/router/session_manager_test.go`\n111:   - Verification: `go test -v -run TestBuildTargetURLWebSocket ./pkg/router/`\n112: \n113: ### Phase 4: Router Middleware Tests Enhancement (ST-4)\n114: \n115: - [ ] **T4.1**: Add test for `concurrencyLimitMiddleware` with zero limit edge case\n116:   - Purpose: Test default limit fallback behavior\n117:   - File: `pkg/router/middleware_test.go`\n118:   - Verification: `go test -v -run TestConcurrencyLimitZero ./pkg/router/`\n119: \n120: - [ ] **T4.2**: Add test for `concurrencyLimitMiddleware` with high concurrency\n121:   - Purpose: Test behavior with large concurrent request count\n122:   - File: `pkg/router/middleware_test.go`\n123:   - Verification: `go test -v -run TestConcurrencyLimitHigh ./pkg/router/`\n124: \n125: - [ ] **T4.3**: Add test for `loggingMiddleware` with request duration tracking\n126:   - Purpose: Verify duration measurement accuracy\n127:   - File: `pkg/router/middleware_test.go`\n128:   - Verification: `go test -v -run TestLoggingMiddlewareDuration ./pkg/router/`\n129: \n130: - [ ] **T4.4**: Add test for `recoveryMiddleware` with nested panic\n131:   - Purpose: Test nested panic recovery behavior\n132:   - File: `pkg/router/middleware_test.go`\n133:   - Verification: `go test -v -run TestRecoveryMiddlewareNested ./pkg/router/`\n134: \n135: - [ ] **T4.5**: Add benchmark for middleware chain execution\n136:   - Purpose: Measure middleware overhead\n137:   - File: `pkg/router/middleware_test.go`\n138:   - Verification: `go test -bench=BenchmarkMiddleware ./pkg/router/`\n139: \n140: ### Phase 5: Router Auth Middleware Tests Enhancement (ST-5)\n141: \n142: - [ ] **T5.1**: Add test for `DefaultTokenExtractor` with multiple spaces\n143:   - Purpose: Test malformed header with extra spaces\n144:   - File: `pkg/router/middleware/auth_test.go`\n145:   - Verification: `go test -v -run TestDefaultTokenExtractorMultipleSpaces ./pkg/router/middleware/`\n146: \n147: - [ ] **T5.2**: Add test for `JWTAuthMiddleware` with path prefix matching\n148:   - Purpose: Verify skip paths with prefix matching\n149:   - File: `pkg/router/middleware/auth_test.go`\n150:   - Verification: `go test -v -run TestJWTAuthMiddlewarePathPrefix ./pkg/router/middleware/`\n151: \n152: - [ ] **T5.3**: Add test for `TokenIssuanceHandler` with valid request\n153:   - Purpose: Test successful token issuance flow\n154:   - File: `pkg/router/middleware/auth_test.go`\n155:   - Verification: `go test -v -run TestTokenIssuanceValid ./pkg/router/middleware/`\n156: \n157: - [ ] **T5.4**: Add test for `TokenRefreshHandler` with valid refresh token\n158:   - Purpose: Test successful token refresh flow\n159:   - File: `pkg/router/middleware/auth_test.go`\n160:   - Verification: `go test -v -run TestTokenRefreshValid ./pkg/router/middleware/`\n161: \n162: - [ ] **T5.5**: Add test for `PublicKeyHandler` with empty key scenario\n163:   - Purpose: Test error handling when public key not available\n164:   - File: `pkg/router/middleware/auth_test.go`\n165:   - Verification: `go test -v -run TestPublicKeyHandlerEmpty ./pkg/router/middleware/`\n166: \n167: - [ ] **T5.6**: Add test for `GetClaimsFromContext` with wrong type\n168:   - Purpose: Test type assertion failure handling\n169:   - File: `pkg/router/middleware/auth_test.go`\n170:   - Verification: `go test -v -run TestGetClaimsWrongType ./pkg/router/middleware/`\n171: \n172: ### Phase 6: Router Errors Tests Enhancement (ST-6)\n173: \n174: - [ ] **T6.1**: Add test for error wrapping with `Unwrap` method\n175:   - Purpose: Verify error chain unwrapping\n176:   - File: `pkg/router/errors_test.go`\n177:   - Verification: `go test -v -run TestErrorUnwrap ./pkg/router/`\n178: \n179: - [ ] **T6.2**: Add test for error equality comparison\n180:   - Purpose: Test error equality semantics\n181:   - File: `pkg/router/errors_test.go`\n182:   - Verification: `go test -v -run TestErrorEquality ./pkg/router/`\n183: \n184: - [ ] **T6.3**: Add test for error JSON serialization\n185:   - Purpose: Verify error serialization for API responses\n186:   - File: `pkg/router/errors_test.go`\n187:   - Verification: `go test -v -run TestErrorJSON ./pkg/router/`\n188: \n189: - [ ] **T6.4**: Add test for all error codes uniqueness\n190:   - Purpose: Verify all error codes are unique strings\n191:   - File: `pkg/router/errors_test.go`\n192:   - Verification: `go test -v -run TestErrorCodeUniqueness ./pkg/router/`\n193: \n194: ### Phase 7: Router Reverse Proxy Tests Enhancement (ST-7)\n195: \n196: - [ ] **T7.1**: Add test for `Director` with query parameters preservation\n197:   - Purpose: Verify query parameter forwarding\n198:   - File: `pkg/router/reverse_proxy_test.go`\n199:   - Verification: `go test -v -run TestDirectorQueryParams ./pkg/router/`\n200: \n201: - [ ] **T7.2**: Add test for `Director` with custom headers\n202:   - Purpose: Test custom header forwarding\n203:   - File: `pkg/router/reverse_proxy_test.go`\n204:   - Verification: `go test -v -run TestDirectorCustomHeaders ./pkg/router/`\n205: \n206: - [ ] **T7.3**: Add test for `ModifyResponse` with multiple headers\n207:   - Purpose: Verify response header modification\n208:   - File: `pkg/router/reverse_proxy_test.go`\n209:   - Verification: `go test -v -run TestModifyResponseHeaders ./pkg/router/`\n210: \n211: - [ ] **T7.4**: Add test for `ErrorHandler` with various error types\n212:   - Purpose: Test error classification and status mapping\n213:   - File: `pkg/router/reverse_proxy_test.go`\n214:   - Verification: `go test -v -run TestErrorHandlerTypes ./pkg/router/`\n215: \n216: - [ ] **T7.5**: Add benchmark for proxy request handling\n217:   - Purpose: Measure proxy performance\n218:   - File: `pkg/router/reverse_proxy_test.go`\n219:   - Verification: `go test -bench=BenchmarkReverseProxy ./pkg/router/`\n220: \n221: ### Phase 8: Router Config Tests Enhancement (ST-8)\n222: \n223: - [ ] **T8.1**: Add test for `Config` validation with invalid port format\n224:   - Purpose: Test port format validation\n225:   - File: `pkg/router/config_test.go`\n226