{"type":"tool_use","timestamp":1775848869820,"sessionID":"ses_28729480cffecjf20CiBHcHbQX","part":{"id":"prt_d78d74b340012qlCT8gtb7O3A3","messageID":"msg_d78d7312e001pGCwRWQ51pYY0k","sessionID":"ses_28729480cffecjf20CiBHcHbQX","type":"tool","tool":"read","callID":"toolu_tool-1133206e18484698a490457c12b8461e","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/garbage_collector.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/garbage_collector.go</path>\n<type>file</type>\n<content>\n1: package workloadmanager\n2: \n3: import (\n4: \t\"context\"\n5: \t\"sync\"\n6: \t\"time\"\n7: )\n8: \n9: const GCBatchSize = 16\n10: \n11: type GarbageCollector struct {\n12: \tmanager     *SandboxLifecycleManager\n13: \tinterval    time.Duration\n14: \tonceTimeout time.Duration\n15: \tstopCh      chan struct{}\n16: \twg          sync.WaitGroup\n17: \tlogger      Logger\n18: \tidleTimeout time.Duration\n19: \tidleMu      sync.RWMutex\n20: }\n21: \n22: func NewGarbageCollector(manager *SandboxLifecycleManager, interval, onceTimeout time.Duration, logger Logger) *GarbageCollector {\n23: \tif interval == 0 {\n24: \t\tinterval = GarbageCollectorInterval\n25: \t}\n26: \tif onceTimeout == 0 {\n27: \t\tonceTimeout = 2 * time.Minute\n28: \t}\n29: \n30: \treturn &GarbageCollector{\n31: \t\tmanager:     manager,\n32: \t\tinterval:    interval,\n33: \t\tonceTimeout: onceTimeout,\n34: \t\tstopCh:      make(chan struct{}),\n35: \t\tlogger:      logger,\n36: \t\tidleTimeout: manager.config.DefaultIdleTimeout,\n37: \t}\n38: }\n39: \n40: func (gc *GarbageCollector) getIdleTimeout() time.Duration {\n41: \tgc.idleMu.RLock()\n42: \tdefer gc.idleMu.RUnlock()\n43: \treturn gc.idleTimeout\n44: }\n45: \n46: func (gc *GarbageCollector) Start() {\n47: \tgc.wg.Add(1)\n48: \tgo gc.runLoop()\n49: }\n50: \n51: func (gc *GarbageCollector) Stop() {\n52: \tclose(gc.stopCh)\n53: \tgc.wg.Wait()\n54: }\n55: \n56: func (gc *GarbageCollector) runLoop() {\n57: \tdefer gc.wg.Done()\n58: \n59: \tticker := time.NewTicker(gc.interval)\n60: \tdefer ticker.Stop()\n61: \n62: \tgc.runOnce(context.Background())\n63: \n64: \tfor {\n65: \t\tselect {\n66: \t\tcase <-gc.stopCh:\n67: \t\t\tgc.logger.Info(\"garbage collector stopped\")\n68: \t\t\treturn\n69: \t\tcase <-ticker.C:\n70: \t\t\tgc.runOnce(context.Background())\n71: \t\t}\n72: \t}\n73: }\n74: \n75: func (gc *GarbageCollector) runOnce(ctx context.Context) error {\n76: \tctx, cancel := context.WithTimeout(ctx, gc.onceTimeout)\n77: \tdefer cancel()\n78: \n79: \tnow := time.Now()\n80: \tidleTimeout := gc.getIdleTimeout()\n81: \n82: \texpired, err := gc.manager.store.ListExpiredSandboxes(ctx, now, GCBatchSize)\n83: \tif err != nil {\n84: \t\tgc.logger.Error(\"failed to list expired sandboxes\", \"err\", err)\n85: \t\treturn err\n86: \t}\n87: \n88: \tinactiveBefore := now.Add(-idleTimeout)\n89: \tinactive, err := gc.manager.store.ListInactiveSandboxes(ctx, inactiveBefore, GCBatchSize)\n90: \tif err != nil {\n91: \t\tgc.logger.Error(\"failed to list inactive sandboxes\", \"err\", err)\n92: \t\treturn err\n93: \t}\n94: \n95: \tallSandboxes := append(expired, inactive...)\n96: \n97: \tfor _, sb := range allSandboxes {\n98: \t\tif err := gc.manager.DeleteSandbox(ctx, sb.SessionID); err != nil {\n99: \t\t\tif _, ok := err.(*NotFoundError); ok {\n100: \t\t\t\tcontinue\n101: \t\t\t}\n102: \t\t\tgc.logger.Error(\"gc delete failed\", \"sessionID\", sb.SessionID, \"err\", err)\n103: \t\t\tcontinue\n104: \t\t}\n105: \n106: \t\treason := determineDeletionReason(sb, now, idleTimeout)\n107: \t\tgc.logger.Info(\"gc deleted sandbox\", \"sessionID\", sb.SessionID, \"sandboxName\", sb.SandboxName, \"reason\", reason)\n108: \t}\n109: \n110: \treturn nil\n111: }\n112: \n113: func (gc *GarbageCollector) SetIdleTimeout(timeout time.Duration) {\n114: \tgc.idleMu.Lock()\n115: \tdefer gc.idleMu.Unlock()\n116: \tgc.idleTimeout = timeout\n117: }\n118: \n119: func (gc *GarbageCollector) GetStats() GarbageCollectorStats {\n120: \tgc.idleMu.RLock()\n121: \tdefer gc.idleMu.RUnlock()\n122: \treturn GarbageCollectorStats{\n123: \t\tInterval:    gc.interval,\n124: \t\tOnceTimeout: gc.onceTimeout,\n125: \t\tIdleTimeout: gc.idleTimeout,\n126: \t}\n127: }\n128: \n129: type GarbageCollectorStats struct {\n130: \tInterval    time.Duration\n131: \tOnceTimeout time.Duration\n132: \tIdleTimeout time.Duration\n133: }\n\n(End of file - total 133 lines)\n</content>","metadata":{"preview":"package workloadmanager\n\nimport (\n\t\"context\"\n\t\"sync\"\n\t\"time\"\n)\n\nconst GCBatchSize = 16\n\ntype GarbageCollector struct {\n\tmanager     *SandboxLifecycleManager\n\tinterval    time.Duration\n\tonceTimeout time.Duration\n\tstopCh      chan struct{}\n\twg          sync.WaitGroup\n\tlogger      Logger\n\tidleTimeout time.Duration\n\tidleMu      sync.RWMutex\n}","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/garbage_collector.go","time":{"start":1775848869809,"end":1775848869819}}}}
{"type":"tool_use","timestamp":1775848869824,"sessionID":"ses_28729480cffecjf20CiBHcHbQX","part":{"id":"prt_d78d74f96001g5ic4v11QC5PBe","messageID":"msg_d78d7312e001pGCwRWQ51pYY0k","sessionID":"ses_28729480cffecjf20CiBHcHbQX","type":"tool","tool":"read","callID":"toolu_tool-45a47367d18f458faeb27c76001d9b42","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/garbage_collector_test.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/garbage_collector_test.go</path>\n<type>file</type>\n<content>\n1: package workloadmanager\n2: \n3: import (\n4: \t\"context\"\n5: \t\"sync\"\n6: \t\"testing\"\n7: \t\"time\"\n8: \n9: \t\"github.com/stretchr/testify/assert\"\n10: \t\"github.com/stretchr/testify/require\"\n11: \t\"k8s.io/apimachinery/pkg/runtime\"\n12: \tdynamicfake \"k8s.io/client-go/dynamic/fake\"\n13: \t\"k8s.io/client-go/kubernetes/fake\"\n14: \n15: \t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n16: )\n17: \n18: func TestNewGarbageCollector(t *testing.T) {\n19: \tfakeClient := fake.NewSimpleClientset()\n20: \tdynamicClient := dynamicfake.NewSimpleDynamicClient(runtime.NewScheme())\n21: \tinformerFactory := NewTestInformerFactory(fakeClient)\n22: \n23: \tk8sClient := &K8sClient{\n24: \t\tdynamicClient:   dynamicClient,\n25: \t\tcoreClient:      fakeClient,\n26: \t\tinformerFactory: informerFactory,\n27: \t}\n28: \n29: \tstore := NewMemoryStore()\n30: \tlogger := &mockLogger{}\n31: \tconfig := DefaultLifecycleConfig()\n32: \n33: \tmanager := NewSandboxLifecycleManager(k8sClient, store, config, logger)\n34: \n35: \tgc := NewGarbageCollector(manager, GarbageCollectorInterval, 2*time.Minute, logger)\n36: \n37: \tassert.NotNil(t, gc)\n38: \tassert.Equal(t, GarbageCollectorInterval, gc.interval)\n39: \tassert.Equal(t, 2*time.Minute, gc.onceTimeout)\n40: }\n41: \n42: func TestNewGarbageCollector_DefaultInterval(t *testing.T) {\n43: \tfakeClient := fake.NewSimpleClientset()\n44: \tdynamicClient := dynamicfake.NewSimpleDynamicClient(runtime.NewScheme())\n45: \tinformerFactory := NewTestInformerFactory(fakeClient)\n46: \n47: \tk8sClient := &K8sClient{\n48: \t\tdynamicClient:   dynamicClient,\n49: \t\tcoreClient:      fakeClient,\n50: \t\tinformerFactory: informerFactory,\n51: \t}\n52: \n53: \tstore := NewMemoryStore()\n54: \tlogger := &mockLogger{}\n55: \tconfig := DefaultLifecycleConfig()\n56: \n57: \tmanager := NewSandboxLifecycleManager(k8sClient, store, config, logger)\n58: \n59: \tgc := NewGarbageCollector(manager, 0, 0, logger)\n60: \n61: \tassert.Equal(t, GarbageCollectorInterval, gc.interval)\n62: \tassert.Equal(t, 2*time.Minute, gc.onceTimeout)\n63: }\n64: \n65: func TestGarbageCollector_StartStop(t *testing.T) {\n66: \tfakeClient := fake.NewSimpleClientset()\n67: \tdynamicClient := dynamicfake.NewSimpleDynamicClient(runtime.NewScheme())\n68: \tinformerFactory := NewTestInformerFactory(fakeClient)\n69: \n70: \tk8sClient := &K8sClient{\n71: \t\tdynamicClient:   dynamicClient,\n72: \t\tcoreClient:      fakeClient,\n73: \t\tinformerFactory: informerFactory,\n74: \t}\n75: \n76: \tstore := NewMemoryStore()\n77: \tlogger := &mockLogger{}\n78: \tconfig := DefaultLifecycleConfig()\n79: \n80: \tmanager := NewSandboxLifecycleManager(k8sClient, store, config, logger)\n81: \n82: \tgc := NewGarbageCollector(manager, 100*time.Millisecond, 1*time.Second, logger)\n83: \n84: \tgc.Start()\n85: \n86: \ttime.Sleep(50 * time.Millisecond)\n87: \n88: \tgc.Stop()\n89: \n90: \tassert.True(t, true)\n91: }\n92: \n93: func TestGarbageCollector_runOnce_Expired(t *testing.T) {\n94: \tfakeClient := fake.NewSimpleClientset()\n95: \tdynamicClient := dynamicfake.NewSimpleDynamicClient(runtime.NewScheme())\n96: \tinformerFactory := NewTestInformerFactory(fakeClient)\n97: \n98: \tk8sClient := &K8sClient{\n99: \t\tdynamicClient:   dynamicClient,\n100: \t\tcoreClient:      fakeClient,\n101: \t\tinformerFactory: informerFactory,\n102: \t}\n103: \n104: \tstore := NewMemoryStore()\n105: \tlogger := &mockLogger{}\n106: \tconfig := DefaultLifecycleConfig()\n107: \n108: \tmanager := NewSandboxLifecycleManager(k8sClient, store, config, logger)\n109: \n110: \tgc := NewGarbageCollector(manager, GarbageCollectorInterval, 2*time.Minute, logger)\n111: \n112: \tnow := time.Now()\n113: \n114: \texpiredSandbox := &types.SandboxInfo{\n115: \t\tKind:             types.SandboxKind,\n116: \t\tSandboxID:        \"sandbox-expired\",\n117: \t\tSandboxNamespace: \"default\",\n118: \t\tSandboxName:      \"sandbox-expired\",\n119: \t\tSessionID:        \"session-expired\",\n120: \t\tCreatedAt:        now.Add(-10 * time.Hour),\n121: \t\tExpiresAt:        now.Add(-2 * time.Hour),\n122: \t\tStatus:           \"running\",\n123: \t}\n124: \n125: \tactiveSandbox := &types.SandboxInfo{\n126: \t\tKind:             types.SandboxKind,\n127: \t\tSandboxID:        \"sandbox-active\",\n128: \t\tSandboxNamespace: \"default\",\n129: \t\tSandboxName:      \"sandbox-active\",\n130: \t\tSessionID:        \"session-active\",\n131: \t\tCreatedAt:        now,\n132: \t\tExpiresAt:        now.Add(8 * time.Hour),\n133: \t\tStatus:           \"running\",\n134: \t}\n135: \n136: \terr := store.StoreSandbox(context.Background(), expiredSandbox)\n137: \trequire.NoError(t, err)\n138: \terr = store.StoreSandbox(context.Background(), activeSandbox)\n139: \trequire.NoError(t, err)\n140: \n141: \tassert.Equal(t, 2, store.Size())\n142: \n143: \terr = gc.runOnce(context.Background())\n144: \trequire.NoError(t, err)\n145: \n146: \tassert.Equal(t, 1, store.Size())\n147: \n148: \t_, err = store.GetSandboxBySessionID(context.Background(), \"session-expired\")\n149: \tassert.Error(t, err)\n150: \n151: \t_, err = store.GetSandboxBySessionID(context.Background(), \"session-active\")\n152: \trequire.NoError(t, err)\n153: }\n154: \n155: func TestGarbageCollector_runOnce_Inactive(t *testing.T) {\n156: \tfakeClient := fake.NewSimpleClientset()\n157: \tdynamicClient := dynamicfake.NewSimpleDynamicClient(runtime.NewScheme())\n158: \tinformerFactory := NewTestInformerFactory(fakeClient)\n159: \n160: \tk8sClient := &K8sClient{\n161: \t\tdynamicClient:   dynamicClient,\n162: \t\tcoreClient:      fakeClient,\n163: \t\tinformerFactory: informerFactory,\n164: \t}\n165: \n166: \tstore := NewMemoryStore()\n167: \tlogger := &mockLogger{}\n168: \tconfig := DefaultLifecycleConfig()\n169: \n170: \tmanager := NewSandboxLifecycleManager(k8sClient, store, config, logger)\n171: \n172: \tgc := NewGarbageCollector(manager, GarbageCollectorInterval, 2*time.Minute, logger)\n173: \n174: \tnow := time.Now()\n175: \n176: \tinactiveSandbox := &types.SandboxInfo{\n177: \t\tKind:             types.SandboxKind,\n178: \t\tSandboxID:        \"sandbox-inactive\",\n179: \t\tSandboxNamespace: \"default\",\n180: \t\tSandboxName:      \"sandbox-inactive\",\n181: \t\tSessionID:        \"session-inactive\",\n182: \t\tCreatedAt:        now,\n183: \t\tExpiresAt:        now.Add(8 * time.Hour),\n184: \t\tLastActivity:     now.Add(-30 * time.Minute),\n185: \t\tStatus:           \"running\",\n186: \t}\n187: \n188: \tactiveSandbox := &types.SandboxInfo{\n189: \t\tKind:             types.SandboxKind,\n190: \t\tSandboxID:        \"sandbox-active\",\n191: \t\tSandboxNamespace: \"default\",\n192: \t\tSandboxName:      \"sandbox-active\",\n193: \t\tSessionID:        \"session-active\",\n194: \t\tCreatedAt:        now,\n195: \t\tExpiresAt:        now.Add(8 * time.Hour),\n196: \t\tLastActivity:     now,\n197: \t\tStatus:           \"running\",\n198: \t}\n199: \n200: \terr := store.StoreSandbox(context.Background(), inactiveSandbox)\n201: \trequire.NoError(t, err)\n202: \terr = store.StoreSandbox(context.Background(), activeSandbox)\n203: \trequire.NoError(t, err)\n204: \n205: \tassert.Equal(t, 2, store.Size())\n206: \n207: \terr = gc.runOnce(context.Background())\n208: \trequire.NoError(t, err)\n209: \n210: \tassert.Equal(t, 1, store.Size())\n211: \n212: \t_, err = store.GetSandboxBySessionID(context.Background(), \"session-inactive\")\n213: \tassert.Error(t, err)\n214: \n215: \t_, err = store.GetSandboxBySessionID(context.Background(), \"session-active\")\n216: \trequire.NoError(t, err)\n217: }\n218: \n219: func TestGarbageCollector_runOnce_Limit(t *testing.T) {\n220: \tfakeClient := fake.NewSimpleClientset()\n221: \tdynamicClient := dynamicfake.NewSimpleDynamicClient(runtime.NewScheme())\n222: \tinformerFactory := NewTestInformerFactory(fakeClient)\n223: \n224: \tk8sClient := &K8sClient{\n225: \t\tdynamicClient:   dynamicClient,\n226: \t\tcoreClient:      fakeClient,\n227: \t\tinformerFactory: informerFactory,\n228: \t}\n229: \n230: \tstore := NewMemoryStore()\n231: \tlogger := &mockLogger{}\n232: \tconfig := DefaultLifecycleConfig()\n233: \n234: \tmanager := NewSandboxLifecycleManager(k8sClient, store, config, logger)\n235: \n236: \tgc := NewGarbageCollector(manager, GarbageCollectorInterval, 2*time.Minute, logger)\n237: \n238: \tnow := time.Now()\n239: \n240: \tfor i := 0; i < 20; i++ {\n241: \t\tsandbox := &types.SandboxInfo{\n242: \t\t\tKind:             types.SandboxKind,\n243: \t\t\tSandboxID:        \"sandbox-\" + string(rune(i)),\n244: \t\t\tSandboxNamespace: \"default\",\n245: \t\t\tSandboxName:      \"sandbox-\" + string(rune(i)),\n246: \t\t\tSessionID:        \"session-\" + string(rune(i)),\n247: \t\t\tCreatedAt:        now,\n248: \t\t\tExpiresAt:        now.Add(-1 * time.Hour),\n249: \t\t\tStatus:           \"running\",\n250: \t\t}\n251: \t\terr := store.StoreSandbox(context.Background(), sandbox)\n252: \t\trequire.NoError(t, err)\n253: \t}\n254: \n255: \tassert.Equal(t, 20, store.Size())\n256: \n257: \terr := gc.runOnce(context.Background())\n258: \trequire.NoError(t, err)\n259: \n260: \tassert.LessOrEqual(t, store.Size(), 20-GCBatchSize)\n261: }\n262: \n263: func TestGarbageCollector_runOnce_ContinueOnError(t *testing.T) {\n264: \tfakeClient := fake.NewSimpleClientset()\n265: \tdynamicClient := dynamicfake.NewSimpleDynamicClient(runtime.NewScheme())\n266: \tinformerFactory := NewTestInformerFactory(fakeClient)\n267: \n268: \tk8sClient := &K8sClient{\n269: \t\tdynamicClient:   dynamicClient,\n270: \t\tcoreClient:      fakeClient,\n271: \t\tinformerFactory: informerFactory,\n272: \t}\n273: \n274: \tstore := NewMemoryStore()\n275: \tlogger := &mockLogger{}\n276: \tconfig := DefaultLifecycleConfig()\n277: \n278: \tmanager := NewSandboxLifecycleManager(k8sClient, store, config, logger)\n279: \n280: \tgc := NewGarbageCollector(manager, GarbageCollectorInterval, 2*time.Minute, logger)\n281: \n282: \tnow := time.Now()\n283: \n284: \tfor i := 0; i < 3; i++ {\n285: \t\tsandbox := &types.SandboxInfo{\n286: \t\t\tKind:             types.SandboxKind,\n287: \t\t\tSandboxID:        \"sandbox-\" + string(rune(i)),\n288: \t\t\tSandboxNamespace: \"default\",\n289: \t\t\tSandboxName:      \"sandbox-\" + string(rune(i)),\n290: \t\t\tSessionID:        \"session-\" + string(rune(i)),\n291: \t\t\tCreatedAt:        now,\n292: \t\t\tExpiresAt:        now.Add(-1 * time.Hour),\n293: \t\t\tStatus:           \"running\",\n294: \t\t}\n295: \t\terr := store.StoreSandbox(context.Background(), sandbox)\n296: \t\trequire.NoError(t, err)\n297: \t}\n298: \n299: \terr := gc.runOnce(context.Background())\n300: \trequire.NoError(t, err)\n301: \n302: \tassert.Equal(t, 0, store.Size())\n303: }\n304: \n305: func TestGarbageCollector_GetStats(t *testing.T) {\n306: \tfakeClient := fake.NewSimpleClientset()\n307: \tdynamicClient := dynamicfake.NewSimpleDynamicClient(runtime.NewScheme())\n308: \tinformerFactory := NewTestInformerFactory(fakeClient)\n309: \n310: \tk8sClient := &K8sClient{\n311: \t\tdynamicClient:   dynamicClient,\n312: \t\tcoreClient:      fakeClient,\n313: \t\tinformerFactory: informerFactory,\n314: \t}\n315: \n316: \tstore := NewMemoryStore()\n317: \tlogger := &mockLogger{}\n318: \tconfig := DefaultLifecycleConfig()\n319: \n320: \tmanager := NewSandboxLifecycleManager(k8sClient, store, config, logger)\n321: \n322: \tgc := NewGarbageCollector(manager, 5*time.Minute, 3*time.Minute, logger)\n323: \tgc.SetIdleTimeout(20 * time.Minute)\n324: \n325: \tstats := gc.GetStats()\n326: \n327: \tassert.Equal(t, 5*time.Minute, stats.Interval)\n328: \tassert.Equal(t, 3*time.Minute, stats.OnceTimeout)\n329: \tassert.Equal(t, 20*time.Minute, stats.IdleTimeout)\n330: }\n331: \n332: func TestGarbageCollector_ConcurrentRunOnce(t *testing.T) {\n333: \tfakeClient := fake.NewSimpleClientset()\n334: \tdynamicClient := dynamicfake.NewSimpleDynamicClient(runtime.NewScheme())\n335: \tinformerFactory := NewTestInformerFactory(fakeClient)\n336: \n337: \tk8sClient := &K8sClient{\n338: \t\tdynamicClient:   dynamicClient,\n339: \t\tcoreClient:      fakeClient,\n340: \t\tinformerFactory: informerFactory,\n341: \t}\n342: \n343: \tstore := NewMemoryStore()\n344: \tlogger := &mockLogger{}\n345: \tconfig := DefaultLifecycleConfig()\n346: \n347: \tmanager := NewSandboxLifecycleManager(k8sClient, store, config, logger)\n348: \n349: \tgc := NewGarbageCollector(manager, GarbageCollectorInterval, 2*time.Minute, logger)\n350: \n351: \tnow := time.Now()\n352: \n353: \tfor i := 0; i < 10; i++ {\n354: \t\tsandbox := &types.SandboxInfo{\n355: \t\t\tKind:             types.SandboxKind,\n356: \t\t\tSandboxID:        \"sandbox-\" + string(rune(i)),\n357: \t\t\tSandboxNamespace: \"default\",\n358: \t\t\tSandboxName:      \"sandbox-\" + string(rune(i)),\n359: \t\t\tSessionID:        \"session-\" + string(rune(i)),\n360: \t\t\tCreatedAt:        now,\n361: \t\t\tExpiresAt:        now.Add(-1 * time.Hour),\n362: \t\t\tStatus:           \"running\",\n363: \t\t}\n364: \t\terr := store.StoreSandbox(context.Background(), sandbox)\n365: \t\trequire.NoError(t, err)\n366: \t}\n367: \n368: \tvar wg sync.WaitGroup\n369: \tfor i := 0; i < 3; i++ {\n370: \t\twg.Add(1)\n371: \t\tgo func() {\n372: \t\t\tdefer wg.Done()\n373: \t\t\tgc.runOnce(context.Background())\n374: \t\t}()\n375: \t}\n376: \twg.Wait()\n377: \n378: \tassert.LessOrEqual(t, store.Size(), 10)\n379: }\n\n(End of file - total 379 lines)\n</content>","metadata":{"preview":"package workloadmanager\n\nimport (\n\t\"context\"\n\t\"sync\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n\t\"k8s.io/apimachinery/pkg/runtime\"\n\tdynamicfake \"k8s.io/client-go/dynamic/fake\"\n\t\"k8s.io/client-go/kubernetes/fake\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n)\n\nfunc TestNewGarbageCollector(t *testing.T) {\n\tfakeClient := fake.NewSimpleClientset()\n\tdynamicClient := dynamicfake.NewSimpleDynamicClient(runtime.NewScheme())","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/garbage_collector_test.go","time":{"start":1775848869812,"end":1775848869821}}}}
