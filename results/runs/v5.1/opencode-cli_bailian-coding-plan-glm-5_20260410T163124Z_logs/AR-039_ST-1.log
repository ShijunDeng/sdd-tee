7: \t\tw := httptest.NewRecorder()\n248: \t\trouter.ServeHTTP(w, req)\n249: \t\tif w.Code == http.StatusTooManyRequests {\n250: \t\t\tbody := w.Body.String()\n251: \t\t\tif !containsStr(body, \"SERVER_OVERLOADED\") {\n252: \t\t\t\tt.Errorf(\"expected SERVER_OVERLOADED in response body\")\n253: \t\t\t}\n254: \t\t}\n255: \t}()\n256: \n257: \twg.Wait()\n258: }\n259: \n260: func containsStr(s, substr string) bool {\n261: \tfor i := 0; i <= len(s)-len(substr); i++ {\n262: \t\tif s[i:i+len(substr)] == substr {\n263: \t\t\treturn true\n264: \t\t}\n265: \t}\n266: \treturn false\n267: }\n268: \n269: func TestNilLoggerMiddleware(t *testing.T) {\n270: \tgin.SetMode(gin.TestMode)\n271: \n272: \trouter := gin.New()\n273: \trouter.Use(loggingMiddleware(nil))\n274: \trouter.GET(\"/test\", func(c *gin.Context) {\n275: \t\tc.JSON(http.StatusOK, gin.H{\"status\": \"ok\"})\n276: \t})\n277: \n278: \treq := httptest.NewRequest(http.MethodGet, \"/test\", nil)\n279: \tw := httptest.NewRecorder()\n280: \n281: \trouter.ServeHTTP(w, req)\n282: \n283: \tif w.Code != http.StatusOK {\n284: \t\tt.Errorf(\"unexpected status code with nil logger: %d\", w.Code)\n285: \t}\n286: }\n287: \n288: func TestNilLoggerRecovery(t *testing.T) {\n289: \tgin.SetMode(gin.TestMode)\n290: \n291: \trouter := gin.New()\n292: \trouter.Use(recoveryMiddleware(nil))\n293: \trouter.GET(\"/test\", func(c *gin.Context) {\n294: \t\tpanic(\"test panic\")\n295: \t})\n296: \n297: \treq := httptest.NewRequest(http.MethodGet, \"/test\", nil)\n298: \tw := httptest.NewRecorder()\n299: \n300: \trouter.ServeHTTP(w, req)\n301: \n302: \tif w.Code != http.StatusInternalServerError {\n303: \t\tt.Errorf(\"unexpected status code: %d\", w.Code)\n304: \t}\n305: }\n\n(End of file - total 305 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"sync\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/gin-gonic/gin\"\n)\n\ntype MockLogger struct {\n\tInfoCalls    []string\n\tErrorCalls 