\n51: \t}\n52: \tif server.config.Port != \":8080\" {\n53: \t\tt.Errorf(\"expected default port, got: %s\", server.config.Port)\n54: \t}\n55: }\n56: \n57: func TestNewServerNilSessionManager(t *testing.T) {\n58: \tgin.SetMode(gin.TestMode)\n59: \n60: \tconfig := DefaultConfig()\n61: \tmockLogger := &MockLogger{}\n62: \tmockStore := &MockStore{}\n63: \tjwtMgr, _ := NewJWTManager()\n64: \n65: \tserver := NewServer(config, nil, mockStore, jwtMgr, mockLogger)\n66: \n67: \tif server.sessionManager != nil {\n68: \t\tt.Error(\"expected nil sessionManager\")\n69: \t}\n70: }\n71: \n72: func TestNewServerMaxConcurrentRequests(t *testing.T) {\n73: \tgin.SetMode(gin.TestMode)\n74: \n75: \tconfig := &Config{\n76: \t\tPort:                  \":8080\",\n77: \t\tMaxConcurrentRequests: 0,\n78: \t}\n79: \n80: \tmockLogger := &MockLogger{}\n81: \tmockStore := &MockStore{}\n82: \tmockSM := &mockSessionManager{}\n83: \tjwtMgr, _ := NewJWTManager()\n84: \n85: \tserver := NewServer(config, mockSM, mockStore, jwtMgr, mockLogger)\n86: \n87: \tif server.config.MaxConcurrentRequests != 1000 {\n88: \t\tt.Errorf(\"expected default 1000, got: %d\", server.config.MaxConcurrentRequests)\n89: \t}\n90: }\n91: \n92: func TestServerHandleHealthLive(t *testing.T) {\n93: \tgin.SetMode(gin.TestMode)\n94: \n95: \tconfig := DefaultConfig()\n96: \tmockLogger := &MockLogger{}\n97: \tmockStore := &MockStore{}\n98: \tmockSM := &mockSessionManager{}\n99: \tjwtMgr, _ := NewJWTManager()\n100: \n101: \tserver := NewServer(config, mockSM, mockStore, jwtMgr, mockLogger)\n102: \n103: \treq := httptest.NewRequest(http.MethodGet, \"/health/live\", nil)\n104: \tw := httptest.NewRecorder()\n105: \n106: \tserver.engine.ServeHTTP(w, req)\n107: \n108: \tif w.Code != http.StatusOK {\n109: \t\tt.Errorf(\"unexpected status code: %d\", w.Code)\n110: \t}\n111: \n112: \tvar resp map[string]string\n113: \tjson.Unmarshal(w.Body.Bytes(), &resp)\n114: \tif resp[\"status\"] != \"alive\" {\n115: \t\tt.Errorf(\"unexpected status: %s\", resp[\"status\"])\n116: \t}\n117: }\n118: \n119: func TestServerHandleHealthReady(t *testing.T) {\n120: \tgin.SetMode(gin.TestMode)\n121: \n122: \tconfig := DefaultConfig()\n123: \tmockLogger := &MockLogger{}\n124: \tmockStore := &MockStore{}\n125: \tmockSM := &mockSessionManager{}\n126: \tjwtMgr, _ := NewJWTManager()\n127: \n128: \tserver := NewServer(config, mockSM, mockStore, jwtMgr, mockLogger)\n129: \n130: \treq := httptest.NewRequest(http.MethodGet, \"/health/ready\", nil)\n131: \tw := httptest.NewRecorder()\n132: \n133: \tserver.engine.ServeHTTP(w, req)\n134: \n135: \tif w.Code != http.StatusOK {\n136: \t\tt.Errorf(\"unexpected status code: %d\", w.Code)\n137: \t}\n138: \n139: \tvar resp map[string]string\n140: \tjson.Unmarshal(w.Body.Bytes(), &resp)\n141: \tif resp[\"status\"] != \"ready\" {\n142: \t\tt.Errorf(\"unexpected status: %s\", resp[\"status\"])\n143: \t}\n144: }\n145: \n146: func TestServerHandleHealthReadyNoSessionManager(t *testing.T) {\n147: \tgin.SetMode(gin.TestMode)\n148: \n149: \tconfig := DefaultConfig()\n150: \tmockLogger := &MockLogger{}\n151: \tmockStore := &MockStore{}\n152: \tjwtMgr, _ := NewJWTManager()\n153: \n154: \tserver := NewServer(config, nil, mockStore, jwtMgr, mockLogger)\n155: \n156: \treq := httptest.NewRequest(http.MethodGet, \"/health/ready\", nil)\n157: \tw := httptest.NewRecorder()\n158: \n159: \tserver.engine.ServeHTTP(w, req)\n160: \n161: \tif w.Code != http.StatusServiceUnavailable {\n162: \t\tt.Errorf(\"unexpected status code: %d\", w.Code)\n163: \t}\n164: \n165: \tvar resp map[string]string\n166: \tjson.Unmarshal(w.Body.Bytes(), &resp)\n167: \tif resp[\"status\"] != \"not ready\" {\n168: \t\tt.Errorf(\"unexpected status: %s\", resp[\"status\"])\n169: \t}\n170: }\n171: \n172: func TestServerRoutesRegistered(t *testing.T) {\n173: \tgin.SetMode(gin.TestMode)\n174: \n175: \tconfig := DefaultConfig()\n176: \tmockLogger := &MockLogger{}\n177: \tmockStore := &MockStore{}\n178: \tmockSM := &mockSessionManager{}\n179: \tjwtMgr, _ := NewJWTManager()\n180: \n181: \tserver := NewServer(config, mockSM, mockStore, jwtMgr, mockLogger)\n182: \n183: \troutes := server.engine.Routes()\n184: \n185: \texpectedRoutes := []string{\n186: \t\t\"/health/live\",\n187: \t\t\"/health/ready\",\n188: \t\t\"/v1/namespaces/:namespace/agent-runtimes/:name/invocations/*path\",\n189: \t\t\"/v1/namespaces/:namespace/code-interpreters/:name/invocations/*path\",\n190: \t}\n191: \n192: \tfor _, expected := range expectedRoutes {\n193: \t\tfound := false\n194: \t\tfor _, route := range routes {\n195: \t\t\tif route.Path == expected {\n196: \t\t\t\tfound = true\n197: \t\t\t\tbreak\n198: \t\t\t}\n199: \t\t}\n200: \t\tif !found {\n201: \t\t\tt.Errorf(\"route not found: %s\", expected)\n202: \t\t}\n203: \t}\n204: }\n205: \n206: func TestServerStop(t *testing.T) {\n207: \tgin.SetMode(gin.TestMode)\n208: \n209: \tconfig := &Config{Port: \":0\"}\n210: \tmockLogger := &MockLogger{}\n211: \tmockStore := &MockStore{}\n212: \tmockSM := &mockSessionManager{}\n213: \tjwtMgr, _ := NewJWTManager()\n214: \n215: \tserver := NewServer(config, mockSM, mockStore, jwtMgr, mockLogger)\n216: \n217: \tctx, cancel := context.WithCancel(context.Background())\n218: \tgo func() {\n219: \t\ttime.Sleep(50 * time.Millisecond)\n220: \t\tcancel()\n221: \t}()\n222: \n223: \tgo server.Start(ctx)\n224: \n225: \terr := server.Stop()\n226: \tif err != nil {\n227: \t\tt.Errorf(\"unexpected error: %v\", err)\n228: \t}\n229: }\n230: \n231: func TestServerGracefulShutdown(t *testing.T) {\n232: \tgin.SetMode(gin.TestMode)\n233: \n234: \tconfig := &Config{Port: \":0\"}\n235: \tmockLogger := &MockLogger{}\n236: \tmockStore := &MockStore{}\n237: \tmockSM := &mockSessionManager{}\n238: \tjwtMgr, _ := NewJWTManager()\n239: \n240: \tserver := NewServer(config, mockSM, mockStore, jwtMgr, mockLogger)\n241: \n242: \tctx, cancel := context.WithTimeout(context.Background(), 100*time.Millisecond)\n243: \tdefer cancel()\n244: \n245: \tgo server.Start(ctx)\n246: \n247: \ttime.Sleep(50 * time.Millisecond)\n248: \n249: \terr := server.Stop()\n250: \tif err != nil {\n251: \t\tt.Logf(\"stop error (expected on already shutdown): %v\", err)\n252: \t}\n253: }\n254: \n255: func TestServerGetEngine(t *testing.T) {\n256: \tgin.SetMode(gin.TestMode)\n257: \n258: \tconfig := DefaultConfig()\n259: \tmockLogger := &MockLogger{}\n260: \tmockStore := &MockStore{}\n261: \tmockSM := &mockSessionManager{}\n262: \tjwtMgr, _ := NewJWTManager()\n263: \n264: \tserver := NewServer(config, mockSM, mockStore, jwtMgr, mockLogger)\n265: \n266: \tengine := server.GetEngine()\n267: \tif engine == nil {\n268: \t\tt.Error(\"expected engine to be returned\")\n269: \t}\n270: }\n271: \n272: func TestServerTLSRequired(t *testing.T) {\n273: \tgin.SetMode(gin.TestMode)\n274: \n275: \tconfig := &Config{\n276: \t\tPort:      \":8080\",\n277: \t\tEnableTLS: true,\n278: \t\tTLSCert:   \"\",\n279: \t\tTLSKey:    \"\",\n280: \t}\n281: \n282: \tmockLogger := &MockLogger{}\n283: \tmockStore := &MockStore{}\n284: \tmockSM := &mockSessionManager{}\n285: \tjwtMgr, _ := NewJWTManager()\n286: \n287: \tserver := NewServer(config, mockSM, mockStore, jwtMgr, mockLogger)\n288: \n289: \tctx := context.Background()\n290: \terr := server.Start(ctx)\n291: \tif err == nil {\n292: \t\tt.Error(\"expected error when TLS cert/key are missing\")\n293: \t}\n294: }\n295: \n296: func TestServerHandleAgentInvoke(t *testing.T) {\n297: \tgin.SetMode(gin.TestMode)\n298: \n299: \tconfig := DefaultConfig()\n300: \tmockLogger := &MockLogger{}\n301: \tmockStore := &MockStore{\n302: \t\tGetSandboxBySessionIDFunc: func(ctx context.Context, sessionID string) (*types.SandboxInfo, error) {\n303: \t\t\treturn &types.SandboxInfo{\n304: \t\t\t\tSessionID: \"test-session\",\n305: \t\t\t\tSandboxID: \"test-sandbox\",\n306: \t\t\t\tEntryPoints: []types.SandboxEntryPoint{\n307: \t\t\t\t\t{Path: \"/api\", Protocol: \"http\", Endpoint: \"localhost:9000\"},\n308: \t\t\t\t},\n309: \t\t\t}, nil\n310: \t\t},\n311: \t\tUpdateSessionLastActivityFunc: func(ctx context.Context, sessionID string, at time.Time) error {\n312: \t\t\treturn nil\n313: \t\t},\n314: \t}\n315: \tmockSM := &mockSessionManager{\n316: \t\tgetFunc: func(ctx context.Context, sessionID, namespace, name, kind string) (*types.SandboxInfo, error) {\n317: \t\t\treturn &types.SandboxInfo{\n318: \t\t\t\tSessionID: \"test-session\",\n319: \t\t\t\tSandboxID: \"test-sandbox\",\n320: \t\t\t\tKind:      types.AgentRuntimeKind,\n321: \t\t\t\tEntryPoints: []types.SandboxEntryPoint{\n322: \t\t\t\t\t{Path: \"/api\", Protocol: \"http\", Endpoint: \"localhost:9000\"},\n323: \t\t\t\t},\n324: \t\t\t}, nil\n325: \t\t},\n326: \t}\n327: \tjwtMgr, _ := NewJWTManager()\n328: \n329: \tserver := NewServer(config, mockSM, mockStore, jwtMgr, mockLogger)\n330: \n331: \treq := httptest.NewRequest(http.MethodGet, \"/v1/namespaces/default/agent-runtimes/test-runtime/invocations/api/test\", nil)\n332: \treq.Header.Set(\"x-agentcube-session-id\", \"test-session\")\n333: \tw := httptest.NewRecorder()\n334: \n335: \tserver.engine.ServeHTTP(w, req)\n336: }\n337: \n338: func TestServerHandleCodeInterpreterInvoke(t *testing.T) {\n339: \tgin.SetMode(gin.TestMode)\n340: \n341: \tconfig := DefaultConfig()\n342: \tmockLogger := &MockLogger{}\n343: \tmockStore := &MockStore{\n344: \t\tUpdateSessionLastActivityFunc: func(ctx context.Context, sessionID string, at time.Time) error {\n345: \t\t\treturn nil\n346: \t\t},\n347: \t}\n348: \tmockSM := &mockSessionManager{\n349: \t\tgetFunc: func(ctx context.Context, sessionID, namespace, name, kind string) (*types.SandboxInfo, error) {\n350: \t\t\treturn &types.SandboxInfo{\n351: \t\t\t\tSessionID: \"ci-session\",\n352: \t\t\t\tSandboxID: \"ci-sandbox\",\n353: \t\t\t\tKind:      types.CodeInterpreterKind,\n354: \t\t\t\tEntryPoints: []types.SandboxEntryPoint{\n355: \t\t\t\t\t{Path: \"/execute\", Protocol: \"http\", Endpoint: \"localhost:9000\"},\n356: \t\t\t\t},\n357: \t\t\t}, nil\n358: \t\t},\n359: \t}\n360: \tjwtMgr, _ := NewJWTManager()\n361: \n362: \tserver := NewServer(config, mockSM, mockStore, jwtMgr, mockLogger)\n363: \n364: \treq := httptest.NewRequest(http.MethodPost, \"/v1/namespaces/default/code-interpreters/test-ci/invocations/execute/code\", nil)\n365: \treq.Header.Set(\"x-agentcube-session-id\", \"ci-session\")\n366: \tw := httptest.NewRecorder()\n367: \n368: \tserver.engine.ServeHTTP(w, req)\n369: }\n370: \n371: type mockSessionManager struct {\n372: \tgetFunc func(ctx context.Context, sessionID, namespace, name, kind string) (*types.SandboxInfo, error)\n373: }\n374: \n375: func (m *mockSessionManager) GetSandboxBySession(ctx context.Context, sessionID, namespace, name, kind string) (*types.SandboxInfo, error) {\n376: \tif m.getFunc != nil {\n377: \t\treturn m.getFunc(ctx, sessionID, namespace, name, kind)\n378: \t}\n379: \treturn nil, nil\n380: }\n\n(End of file - total 380 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/gin-gonic/gin\"\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n)\n\nfunc TestNewServer(t *testing.T) {\n\tgin.SetMode(gin.TestMode)\n\n\tconfig := DefaultConfig()\n\tconfig.Debug = true\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/server_test.go","time":{"start":1775897113374,"end":1775897113409}}}}
