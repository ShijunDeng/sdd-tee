arer test-jwt\" {\n44: \t\tt.Errorf(\"unexpected Authorization header: %s\", req.Header.Get(\"Authorization\"))\n45: \t}\n46: \tif req.Header.Get(\"X-Forwarded-Host\") != \"original-host\" {\n47: \t\tt.Errorf(\"unexpected X-Forwarded-Host: %s\", req.Header.Get(\"X-Forwarded-Host\"))\n48: \t}\n49: \tif req.Header.Get(\"X-Forwarded-Proto\") != \"http\" {\n50: \t\tt.Errorf(\"unexpected X-Forwarded-Proto: %s\", req.Header.Get(\"X-Forwarded-Proto\"))\n51: \t}\n52: \tif !strings.Contains(req.Header.Get(\"X-Forwarded-For\"), \"192.168.1.1\") {\n53: \t\tt.Errorf(\"unexpected X-Forwarded-For: %s\", req.Header.Get(\"X-Forwarded-For\"))\n54: \t}\n55: }\n56: \n57: func TestDirectorNoJWT(t *testing.T) {\n58: \ttarget, _ := url.Parse(\"http://sandbox-host:9000\")\n59: \trpw := newReverseProxy(target, \"\", \"test-session\")\n60: \n61: \treq := httptest.NewRequest(http.MethodGet, \"http://original-host/api\", nil)\n62: \trpw.Director(req)\n63: \n64: \tif req.Header.Get(\"Authorization\") != \"\" {\n65: \t\tt.Errorf(\"expected empty Authorization header, got: %s\", req.Header.Get(\"Authorization\"))\n66: \t}\n67: }\n68: \n69: func TestDirectorPathNormalization(t *testing.T) {\n70: \ttarget, _ := url.Parse(\"http://sandbox-host:9000\")\n71: \trpw := newReverseProxy(target, \"jwt\", \"session\")\n72: \n73: \treq := httptest.NewRequest(http.MethodGet, \"http://host\", nil)\n74: \treq.URL.Path = \"api/v1/resource\"\n75: \trpw.Director(req)\n76: \n77: \tif req.URL.Path != \"/api/v1/resource\" {\n78: \t\tt.Errorf(\"unexpected path: %s\", req.URL.Path)\n79: \t}\n80: }\n81: \n82: func TestModifyResponse(t *testing.T) {\n83: \ttarget, _ := url.Parse(\"http://localhost:8080\")\n84: \trpw := newReverseProxy(target, \"jwt\", \"test-session-id\")\n85: \n86: \tresp := &http.Response{\n87: \t\tHeader: http.Header{},\n88: \t}\n89: \n90: \terr := rpw.ModifyResponse(resp)\n91: \tif err != nil {\n92: \t\tt.Errorf(\"unexpected error: %v\", err)\n93: \t}\n94: \n95: \tif resp.Header.Get(\"x-agentcube-session-id\") != \"test-session-id\" {\n96: \t\tt.Errorf(\"unexpected x-agentcube-session-id header: %s\", resp.Header.Get(\"x-agentcube-session-id\"))\n97: \t}\n98: }\n99: \n100: func TestErrorHandlerConnectionRefused(t *testing.T) {\n101: \ttarget, _ := url.Parse(\"http://localhost:8080\")\n102: \trpw := newReverseProxy(target, \"jwt\", \"session\")\n103: \n104: \tw := httptest.NewRecorder()\n105: \treq := httptest.NewRequest(http.MethodGet, \"/test\", nil)\n106: \terr := &url.Error{Err: &testError{msg: \"connection refused\"}}\n107: \n108: \trpw.ErrorHandler(w, req, err)\n109: \n110: \tif w.Code != http.StatusBadGateway {\n111: \t\tt.Errorf(\"unexpected status code: %d\", w.Code)\n112: \t}\n113: \n114: \tvar resp map[string]string\n115: \tjson.Unmarshal(w.Body.Bytes(), &resp)\n116: \tif resp[\"error\"] != \"sandbox unreachable\" {\n117: \t\tt.Errorf(\"unexpected error message: %s\", resp[\"error\"])\n118: \t}\n119: }\n120: \n121: func TestErrorHandlerTimeout(t *testing.T) {\n122: \ttarget, _ := url.Parse(\"http://localhost:8080\")\n123: \trpw := newReverseProxy(target, \"jwt\", \"session\")\n124: \n125: \tw := httptest.NewRecorder()\n126: \treq := httptest.NewRequest(http.MethodGet, \"/test\", nil)\n127: \terr := &testError{msg: \"timeout occurred\"}\n128: \n129: \trpw.ErrorHandler(w, req, err)\n130: \n131: \tif w.Code != http.StatusGatewayTimeout {\n132: \t\tt.Errorf(\"unexpected status code: %d\", w.Code)\n133: \t}\n134: \n135: \tvar resp map[string]string\n136: \tjson.Unmarshal(w.Body.Bytes(), &resp)\n137: \tif resp[\"error\"] != \"sandbox timeout\" {\n138: \t\tt.Errorf(\"unexpected error message: %s\", resp[\"error\"])\n139: \t}\n140: }\n141: \n142: func TestErrorHandlerGeneric(t *testing.T) {\n143: \ttarget, _ := url.Parse(\"http://localhost:8080\")\n144: \trpw := newReverseProxy(target, \"jwt\", \"session\")\n145: \n146: \tw := httptest.NewRecorder()\n147: \treq := httptest.NewRequest(http.MethodGet, \"/test\", nil)\n148: \terr := &testError{msg: \"some other error\"}\n149: \n150: \trpw.ErrorHandler(w, req, err)\n151: \n152: \tif w.Code != http.StatusBadGateway {\n153: \t\tt.Errorf(\"unexpected status code: %d\", w.Code)\n154: \t}\n155: }\n156: \n157: func TestSelectEntryPointByPrefix(t *testing.T) {\n158: \tentryPoints := []types.SandboxEntryPoint{\n159: \t\t{Path: \"/api/v1\", Protocol: \"http\", Endpoint: \"host1:8080\"},\n160: \t\t{Path: \"/api/v2\", Protocol: \"http\", Endpoint: \"host2:8080\"},\n161: \t\t{Path: \"/execute\", Protocol: \"http\", Endpoint: \"host3:9000\"},\n162: \t}\n163: \n164: \tep := selectEntryPoint(entryPoints, \"/api/v1/users\")\n165: \tif ep == nil || ep.Endpoint != \"host1:8080\" {\n166: \t\tt.Errorf(\"expected host1:8080 endpoint\")\n167: \t}\n168: \n169: \tep = selectEntryPoint(entryPoints, \"/api/v2/items\")\n170: \tif ep == nil || ep.Endpoint != \"host2:8080\" {\n171: \t\tt.Errorf(\"expected host2:8080 endpoint\")\n172: \t}\n173: \n174: \tep = selectEntryPoint(entryPoints, \"/execute/code\")\n175: \tif ep == nil || ep.Endpoint != \"host3:9000\" {\n176: \t\tt.Errorf(\"expected host3:9000 endpoint\")\n177: \t}\n178: }\n179: \n180: func TestSelectEntryPointDefault(t *testing.T) {\n181: \tentryPoints := []types.SandboxEntryPoint{\n182: \t\t{Path: \"/api\", Protocol: \"http\", Endpoint: \"host1:8080\"},\n183: \t\t{Path: \"/execute\", Protocol: \"http\", Endpoint: \"host2:9000\"},\n184: \t}\n185: \n186: \tep := selectEntryPoint(entryPoints, \"/unknown/path\")\n187: \tif ep == nil || ep.Endpoint != \"host1:8080\" {\n188: \t\tt.Errorf(\"expected first entry point as default\")\n189: \t}\n190: }\n191: \n192: func TestSelectEntryPointEmpty(t *testing.T) {\n193: \tep := selectEntryPoint([]types.SandboxEntryPoint{}, \"/any/path\")\n194: \tif ep != nil {\n195: \t\tt.Errorf(\"expected nil for empty entry points\")\n196: \t}\n197: }\n198: \n199: func TestBuildTargetURLWithProtocol(t *testing.T) {\n200: \tep := &types.SandboxEntryPoint{\n201: \t\tPath:     \"/api\",\n202: \t\tProtocol: \"http\",\n203: \t\tEndpoint: \"sandbox-host:8080\",\n204: \t}\n205: \n206: \tu, err := buildTargetURL(ep)\n207: \tif err != nil {\n208: \t\tt.Fatalf(\"unexpected error: %v\", err)\n209: \t}\n210: \n211: \tif u.Scheme != \"http\" {\n212: \t\tt.Errorf(\"unexpected scheme: %s\", u.Scheme)\n213: \t}\n214: \tif u.Host != \"sandbox-host:8080\" {\n215: \t\tt.Errorf(\"unexpected host: %s\", u.Host)\n216: \t}\n217: }\n218: \n219: func TestBuildTargetURLNoProtocol(t *testing.T) {\n220: \tep := &types.SandboxEntryPoint{\n221: \t\tPath:     \"/api\",\n222: \t\tProtocol: \"\",\n223: \t\tEndpoint: \"http://sandbox-host:8080\",\n224: \t}\n225: \n226: \tu, err := buildTargetURL(ep)\n227: \tif err != nil {\n228: \t\tt.Fatalf(\"unexpected error: %v\", err)\n229: \t}\n230: \n231: \tif u.Scheme != \"http\" {\n232: \t\tt.Errorf(\"unexpected scheme: %s\", u.Scheme)\n233: \t}\n234: }\n235: \n236: func TestBuildTargetURLHTTPS(t *testing.T) {\n237: \tep := &types.SandboxEntryPoint{\n238: \t\tPath:     \"/api\",\n239: \t\tProtocol: \"https\",\n240: \t\tEndpoint: \"sandbox-host:8443\",\n241: \t}\n242: \n243: \tu, err := buildTargetURL(ep)\n244: \tif err != nil {\n245: \t\tt.Fatalf(\"unexpected error: %v\", err)\n246: \t}\n247: \n248: \tif u.Scheme != \"https\" {\n249: \t\tt.Errorf(\"unexpected scheme: %s\", u.Scheme)\n250: \t}\n251: }\n252: \n253: func TestBuildTargetURLInvalid(t *testing.T) {\n254: \tep := &types.SandboxEntryPoint{\n255: \t\tPath:     \"/api\",\n256: \t\tProtocol: \"http\",\n257: \t\tEndpoint: \":::invalid-host\",\n258: \t}\n259: \n260: \t_, err := buildTargetURL(ep)\n261: \tif err == nil {\n262: \t\tt.Error(\"expected error for invalid endpoint\")\n263: \t}\n264: }\n265: \n266: func TestDirectorTLSRequest(t *testing.T) {\n267: \ttarget, _ := url.Parse(\"http://sandbox-host:9000\")\n268: \trpw := newReverseProxy(target, \"jwt\", \"session\")\n269: \n270: \treq := httptest.NewRequest(http.MethodGet, \"https://original-host/api\", nil)\n271: \treq.TLS = &tls.ConnectionState{}\n272: \trpw.Director(req)\n273: \n274: \tif req.Header.Get(\"X-Forwarded-Proto\") != \"https\" {\n275: \t\tt.Errorf(\"unexpected X-Forwarded-Proto for TLS request: %s\", req.Header.Get(\"X-Forwarded-Proto\"))\n276: \t}\n277: }\n278: \n279: func TestDirectorExistingXFF(t *testing.T) {\n280: \ttarget, _ := url.Parse(\"http://sandbox-host:9000\")\n281: \trpw := newReverseProxy(target, \"jwt\", \"session\")\n282: \n283: \treq := httptest.NewRequest(http.MethodGet, \"http://host/api\", nil)\n284: \treq.Header.Set(\"X-Forwarded-For\", \"10.0.0.1\")\n285: \treq.RemoteAddr = \"192.168.1.1:12345\"\n286: \trpw.Director(req)\n287: \n288: \txff := req.Header.Get(\"X-Forwarded-For\")\n289: \tif !strings.Contains(xff, \"10.0.0.1\") || !strings.Contains(xff, \"192.168.1.1\") {\n290: \t\tt.Errorf(\"unexpected X-Forwarded-For: %s\", xff)\n291: \t}\n292: }\n293: \n294: type testError struct {\n295: \tmsg string\n296: }\n297: \n298: func (e *testError) Error() string {\n299: \treturn e.msg\n300: }\n\n(End of file - total 300 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"crypto/tls\"\n\t\"encoding/json\"\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"net/url\"\n\t\"strings\"\n\t\"testing\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n)\n\nfunc TestNewReverseProxy(t *testing.T) {\n\ttarget, _ := url.Parse(\"http://localhost:8080\")\n\trpw := newReverseProxy(target, \"test-jwt\", \"test-session\")\n\n\tif rpw == nil {\n\t\tt.Fatal(\"expected ReverseProxyWrapper\")","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/reverse_proxy_test.go","time":{"start":1775897127908,"end":1775897127935}}}}
{"type":"tool_use","timestamp":1775897127938,"sessionID":"ses_28448f185ffehh0S7VCtwI6VcR","part":{"id":"prt_d7bb7a8c3001rzASRcwzyEuXXl","messageID":"msg_d7bb77384001MDaDnJdej6rlf6","sessionID":"ses_28448f185ffehh0S7VCtwI6VcR","type":"tool","tool":"read","callID":"toolu_tool-d995640763074ab696c1ad2b260095a2","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/jwt.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/jwt.go</path>\n<type>file</type>\n<content>\n1: package router\n2: \n3: import (\n4: \t\"context\"\n5: \t\"crypto/rand\"\n6: \t\"crypto/rsa\"\n7: \t\"crypto/x509\"\n8: \t\"encoding/pem\"\n9: \t\"errors\"\n10: \t\"fmt\"\n11: \t\"os\"\n12: \t\"strings\"\n13: \t\"time\"\n14: \n15: \t\"github.com/golang-jwt/jwt/v5\"\n16: \tcorev1 \"k8s.io/api/core/v1\"\n17: \tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n18: \t\"k8s.io/client-go/kubernetes\"\n19: \t\"k8s.io/klog/v2\"\n20: )\n21: \n22: const (\n23: \trsaKeySize         = 2048\n24: \tjwtExpiration      = 5 * time.Minute\n25: \trefreshExpiration  = 30 * time.Minute\n26: \tIdentitySecretName = \"picod-router-identity\"\n27: \tPrivateKeyDataKey  = \"private.pem\"\n28: \tPublicKeyDataKey   = \"public.pem\"\n29: \tjwtIssuer          = \"agentcube-router\"\n30: \tdefaultClockSkew   = 30 * time.Second\n31: )\n32: \n33: var IdentityNamespace = \"default\"\n34: \n35: func init() {\n36: \tif ns := os.Getenv(\"AGENTCUBE_NAMESPACE\"); ns != \"\" {\n37: \t\tIdentityNamespace = ns\n38: \t}\n39: }\n40: \n41: type RouterClaims struct {\n42: \tSessionID string `json:\"session_id\"`\n43: \tSandboxID string `json:\"sandbox_id\"`\n44: \tNamespace string `json:\"namespace\"`\n45: \tName      string `json:\"name\"`\n46: \tjwt.RegisteredClaims\n47: }\n48: \n49: type JWTConfig struct {\n50: \tTokenExpiry   time.Duration\n51: \tRefreshExpiry time.Duration\n52: \tIssuer        string\n53: \tClockSkew     time.Duration\n54: }\n55: \n56: func DefaultJWTConfig() *JWTConfig {\n57: \treturn &JWTConfig{\n58: \t\tTokenExpiry:   jwtExpiration,\n59: \t\tRefreshExpiry: refreshExpiration,\n60: \t\tIssuer:        jwtIssuer,\n61: \t\tClockSkew:     defaultClockSkew,\n62: \t}\n63: }\n64: \n65: type TokenPair struct {\n66: \tAccessToken  string `json:\"access_token\"`\n67: \tRefreshToken string `json:\"refresh_token\"`\n68: \tExpiresIn    int64  `json:\"expires_in\"`\n69: \tTokenType    string `json:\"token_type\"`\n70: }\n71: \n72: type JWTManager struct {\n73: \tprivateKey *rsa.PrivateKey\n74: \tpublicKey  *rsa.PublicKey\n75: \tk8sClient  kubernetes.Interface\n76: \tconfig     *JWTConfig\n77: }\n78: \n79: func NewJWTManager() (*JWTManager, error) {\n80: \tprivateKey, err := rsa.GenerateKey(rand.Reader, rsaKeySize)\n81: \tif err != nil {\n82: \t\treturn nil, fmt.Errorf(\"failed to generate RSA key: %w\", err)\n83: \t}\n84: \n85: \treturn &JWTManager{\n86: \t\tprivateKey: privateKey,\n87: \t\tpublicKey:  &privateKey.PublicKey,\n88: \t\tconfig:     DefaultJWTConfig(),\n89: \t}, nil\n90: }\n91: \n92: func NewJWTManagerWithConfig(config *JWTConfig) (*JWTManager, error) {\n93: \tif config == nil {\n94: \t\tconfig = DefaultJWTConfig()\n95: \t}\n96: \tprivateKey, err := rsa.GenerateKey(rand.Reader, rsaKeySize)\n97: \tif err != nil {\n98: \t\treturn nil, fmt.Errorf(\"failed to generate RSA key: %w\", err)\n99: \t}\n100: \n101: \treturn &JWTManager{\n102: \t\tprivateKey: privateKey,\n103: \t\tpublicKey:  &privateKey.PublicKey,\n104: \t\tconfig:     config,\n105: \t}, nil\n106: }\n107: \n108: func NewJWTManagerWithClient(k8sClient kubernetes.Interface) (*JWTManager, error) {\n109: \tjwtMgr, err := NewJWTManager()\n110: \tif err != nil {\n111: \t\treturn nil, err\n112: \t}\n113: \tjwtMgr.k8sClient = k8sClient\n114: \treturn jwtMgr, nil\n115: }\n116: \n117: func NewJWTManagerFromPrivateKey(privateKey *rsa.PrivateKey) (*JWTManager, error) {\n118: \tif privateKey == nil {\n119: \t\treturn nil, &JWTKeyLoadError{Err: errors.New(\"private key is nil\")}\n120: \t}\n121: \treturn &JWTManager{\n122: \t\tprivateKey: privateKey,\n123: \t\tpublicKey:  &privateKey.PublicKey,\n124: \t\tconfig:     DefaultJWTConfig(),\n125: \t}, nil\n126: }\n127: \n128: func (j *JWTManager) GenerateToken(claims map[string]interface{}) (string, error) {\n129: \tnow := time.Now()\n130: \texpiry := jwtExpiration\n131: \tif j.config != nil && j.config.TokenExpiry > 0 {\n132: \t\texpiry = j.config.TokenExpiry\n133: \t}\n134: \tissuer := jwtIssuer\n135: \tif j.config != nil && j.config.Issuer != \"\" {\n136: \t\tissuer = j.config.Issuer\n137: \t}\n138: \n139: \ttokenClaims := jwt.MapClaims{\n140: \t\t\"exp\": now.Add(expiry).Unix(),\n141: \t\t\"iat\": now.Unix(),\n142: \t\t\"iss\": issuer,\n143: \t}\n144: \n145: \tfor k, v := range claims {\n146: \t\ttokenClaims[k] = v\n147: \t}\n148: \n149: \ttoken := jwt.NewWithClaims(jwt.SigningMethodRS256, tokenClaims)\n150: \n151: \ttokenString, err := token.SignedString(j.privateKey)\n152: \tif err != nil {\n153: \t\treturn \"\", &JWTSigningError{Err: err}\n154: \t}\n155: \n156: \treturn tokenString, nil\n157: }\n158: \n159: func (j *JWTManager) GenerateTokenWithClaims(claims *RouterClaims) (string, error) {\n160: \tnow := time.Now()\n161: \texpiry := jwtExpiration\n162: \tif j.config != nil && j.config.TokenExpiry > 0 {\n163: \t\texpiry = j.config.TokenExpiry\n164: \t}\n165: \tissuer := jwtIssuer\n166: \tif j.config != nil && j.config.Issuer != \"\" {\n167: \t\tissuer = j.config.Issuer\n168: \t}\n169: \n170: \tclaims.RegisteredClaims = jwt.RegisteredClaims{\n171: \t\tExpiresAt: jwt.NewNumericDate(now.Add(expiry)),\n172: \t\tIssuedAt:  jwt.NewNumericDate(now),\n173: \t\tIssuer:    issuer,\n174: \t}\n175: \n176: \ttoken := jwt.NewWithClaims(jwt.SigningMethodRS256, claims)\n177: \n178: \ttokenString, err := token.SignedString(j.privateKey)\n179: \tif err != nil {\n180: \t\treturn \"\", &JWTSigningError{Err: err}\n181: \t}\n182: \n183: \treturn tokenString, nil\n184: }\n185: \n186: func (j *JWTManager) GenerateTokenPair(claims *RouterClaims) (*TokenPair, error) {\n187: \taccessToken, err := j.GenerateTokenWithClaims(claims)\n188: \tif err != nil {\n189: \t\treturn nil, err\n190: \t}\n191: \n192: \tnow := time.Now()\n193: \trefreshExpiry := refreshExpiration\n194: \tif j.config != nil && j.config.RefreshExpiry > 0 {\n195: \t\trefreshExpiry = j.config.RefreshExpiry\n196: \t}\n197: \tissuer := jwtIssuer\n198: \tif j.config != nil && j.config.Issuer != \"\" {\n199: \t\tissuer = j.config.Issuer\n200: \t}\n201: \n202: \trefreshClaims := &RouterClaims{\n203: \t\tSessionID: claims.SessionID,\n204: \t\tSandboxID: claims.SandboxID,\n205: \t\tNamespace: claims.Namespace,\n206: \t\tName:      claims.Name,\n207: \t\tRegisteredClaims: jwt.RegisteredClaims{\n208: \t\t\tExpiresAt: jwt.NewNumericDate(now.Add(refreshExpiry)),\n209: \t\t\tIssuedAt:  jwt.NewNumericDate(now),\n210: \t\t\tIssuer:    issuer,\n211: \t\t\tID:        fmt.Sprintf(\"refresh-%s\", claims.SessionID),\n212: \t\t},\n213: \t}\n214: \n215: \trefreshToken := jwt.NewWithClaims(jwt.SigningMethodRS256, refreshClaims)\n216: \trefreshTokenString, err := refreshToken.SignedString(j.privateKey)\n217: \tif err != nil {\n218: \t\treturn nil, &JWTSigningError{Err: err}\n219: \t}\n220: \n221: \ttokenExpiry := jwtExpiration\n222: \tif j.config != nil && j.config.TokenExpiry > 0 {\n223: \t\ttokenExpiry = j.config.TokenExpiry\n224: \t}\n225: \n226: \treturn &TokenPair{\n227: \t\tAccessToken:  accessToken,\n228: \t\tRefreshToken: refreshTokenString,\n229: \t\tExpiresIn:    int64(tokenExpiry.Seconds()),\n230: \t\tTokenType:    \"Bearer\",\n231: \t}, nil\n232: }\n233: \n234: func (j *JWTManager) ValidateToken(tokenString string) (*RouterClaims, error) {\n235: \ttoken, err := jwt.ParseWithClaims(tokenString, &RouterClaims{}, func(token *jwt.Token) (interface{}, error) {\n236: \t\tif _, ok := token.Method.(*jwt.SigningMethodRSA); !ok {\n237: \t\t\treturn nil, &JWTValidationError{Err: fmt.Errorf(\"unexpected signing method: %v\", token.Header[\"alg\"])}\n238: \t\t}\n239: \t\treturn j.publicKey, nil\n240: \t})\n241: \n242: \tif err != nil {\n243: \t\tif errors.Is(err, jwt.ErrTokenExpired) {\n244: \t\t\treturn nil, &JWTTokenExpiredError{TokenID: tokenString}\n245: \t\t}\n246: \t\tif errors.Is(err, jwt.ErrTokenSignatureInvalid) {\n247: \t\t\treturn nil, &JWTValidationError{Err: err}\n248: \t\t}\n249: \t\tif errors.Is(err, jwt.ErrTokenMalformed) {\n250: \t\t\treturn nil, &JWTValidationError{Err: err}\n251: \t\t}\n252: \t\tif errors.Is(err, jwt.ErrTokenNotValidYet) {\n253: \t\t\treturn nil, &JWTValidationError{Err: err}\n254: \t\t}\n255: \t\treturn nil, &JWTValidationError{Err: err}\n256: \t}\n257: \n258: \tif !token.Valid {\n259: \t\treturn nil, &JWTValidationError{Err: errors.New(\"token is not valid\")}\n260: \t}\n261: \n262: \tclaims, ok := token.Claims.(*RouterClaims)\n263: \tif !ok {\n264: \t\treturn nil, &JWTValidationError{Err: errors.New(\"failed to extract claims\")}\n265: \t}\n266: \n267: \treturn claims, nil\n268: }\n269: \n270: func (j *JWTManager) RefreshToken(refreshTokenString string) (*TokenPair, error) {\n271: \tclaims, err := j.ValidateToken(refreshTokenString)\n272: \tif err != nil {\n273: \t\treturn nil, err\n274: \t}\n275: \n276: \tif claims.RegisteredClaims.ID == \"\" || !strings.HasPrefix(claims.RegisteredClaims.ID, \"refresh-\") {\n277: \t\treturn nil, &JWTValidationError{Err: errors.New(\"not a refresh token\")}\n278: \t}\n279: \n280: \treturn j.GenerateTokenPair(claims)\n281: }\n282: \n283: func (j *JWTManager) ValidateTokenWithSkew(tokenString string) (*RouterClaims, error) {\n284: \tclaims, err := j.ValidateToken(tokenString)\n285: \tif err != nil {\n286: \t\treturn claims, err\n287: \t}\n288: \treturn claims, nil\n289: }\n290: \n291: func (j *JWTManager) TryStoreOrLoadJWTKeySecret(ctx context.Context) error {\n292: \tif j.k8sClient == nil {\n293: \t\tklog.Warningf(\"k8s client not configured, skipping secret persistence\")\n294: \t\treturn nil\n295: \t}\n296: \n297: \tsecretClient := j.k8sClient.CoreV1().Secrets(IdentityNamespace)\n298: \n299: \texistingSecret, err := secretClient.Get(ctx, IdentitySecretName, metav1.GetOptions{})\n300: \tif err == nil {\n301: \t\tprivateKeyData := existingSecret.Data[PrivateKeyDataKey]\n302: \t\tif len(privateKeyData) == 0 {\n303: \t\t\tklog.Warningf(\"secret exists but private key data is empty\")\n304: \t\t\treturn nil\n305: \t\t}\n306: \n307: \t\tprivateKey, err := loadPrivateKeyPEM(privateKeyData)\n308: \t\tif err != nil {\n309: \t\t\treturn &JWTKeyLoadError{Err: err}\n310: \t\t}\n311: \n312: \t\tj.privateKey = privateKey\n313: \t\tj.publicKey = &privateKey.PublicKey\n314: \t\tklog.Infof(\"loaded existing JWT keys from secret %s/%s\", IdentityNamespace, IdentitySecretName)\n315: \t\treturn nil\n316: \t}\n317: \n318: \tprivateKeyPEM := encodePrivateKeyPEM(j.privateKey)\n319: \tpublicKeyPEM := encodePublicKeyPEM(j.publicKey)\n320: \n321: \tsecret := &corev1.Secret{\n322: \t\tObjectMeta: metav1.ObjectMeta{\n323: \t\t\tName:      IdentitySecretName,\n324: \t\t\tNamespace: IdentityNamespace,\n325: \t\t},\n326: \t\tType: corev1.SecretTypeOpaque,\n327: \t\tData: map[string][]byte{\n328: \t\t\tPrivateKeyDataKey: privateKeyPEM,\n329: \t\t\tPublicKeyDataKey:  publicKeyPEM,\n330: \t\t},\n331: \t}\n332: \n333: \t_, err = secretClient.Create(ctx, secret, metav1.CreateOptions{})\n334: \tif err != nil {\n335: \t\tklog.Warningf(\"failed to create secret for JWT keys: %v\", err)\n336: \t\treturn nil\n337: \t}\n338: \n339: \tklog.Infof(\"stored JWT keys in secret %s/%s\", IdentityNamespace, IdentitySecretName)\n340: \treturn nil\n341: }\n342: \n343: func (j *JWTManager) LoadKeysFromSecret(ctx context.Context) error {\n344: \tif j.k8sClient == nil {\n345: \t\treturn &JWTKeyLoadError{Err: errors.New(\"k8s client not configured\")}\n346: \t}\n347: \n348: \tsecretClient := j.k8sClient.CoreV1().Secrets(IdentityNamespace)\n349: \n350: \texistingSecret, err := secretClient.Get(ctx, IdentitySecretName, metav1.GetOptions{})\n351: \tif err != nil {\n352: \t\treturn &JWTKeyLoadError{Err: fmt.Errorf(\"failed to get secret: %w\", err)}\n353: \t}\n354: \n355: \tprivateKeyData := existingSecret.Data[PrivateKeyDataKey]\n356: \tif len(privateKeyData) == 0 {\n357: \t\treturn &JWTKeyLoadError{Err: errors.New(\"private key data is empty\")}\n358: \t}\n359: \n360: \tprivateKey, err := loadPrivateKeyPEM(privateKeyData)\n361: \tif err != nil {\n362: \t\treturn &JWTKeyLoadError{Err: err}\n363: \t}\n364: \n365: \tj.privateKey = privateKey\n366: \tj.publicKey = &privateKey.PublicKey\n367: \treturn nil\n368: }\n369: \n370: func (j *JWTManager) StoreKeysToSecret(ctx context.Context) error {\n371: \tif j.k8sClient == nil {\n372: \t\treturn &JWTKeyLoadError{Err: errors.New(\"k8s client not configured\")}\n373: \t}\n374: \n375: \tprivateKeyPEM := encodePrivateKeyPEM(j.privateKey)\n376: \tpublicKeyPEM := encodePublicKeyPEM(j.publicKey)\n377: \n378: \tsecret := &corev1.Secret{\n379: \t\tObjectMeta: metav1.ObjectMeta{\n380: \t\t\tName:      IdentitySecretName,\n381: \t\t\tNamespace: IdentityNamespace,\n382: \t\t},\n383: \t\tType: corev1.SecretTypeOpaque,\n384: \t\tData: map[string][]byte{\n385: \t\t\tPrivateKeyDataKey: privateKeyPEM,\n386: \t\t\tPublicKeyDataKey:  publicKeyPEM,\n387: \t\t},\n388: \t}\n389: \n390: \tsecretClient := j.k8sClient.CoreV1().Secrets(IdentityNamespace)\n391: \n392: \texistingSecret, err := secretClient.Get(ctx, IdentitySecretName, metav1.GetOptions{})\n393: \tif err == nil {\n394: \t\texistingSecret.Data = secret.Data\n395: \t\t_, err = secretClient.Update(ctx, existingSecret, metav1.UpdateOptions{})\n396: \t\tif err != nil {\n397: \t\t\treturn &JWTKeyLoadError{Err: fmt.Errorf(\"failed to update secret: %w\", err)}\n398: \t\t}\n399: \t\treturn nil\n400: \t}\n401: \n402: \t_, err = secretClient.Create(ctx, secret, metav1.CreateOptions{})\n403: \tif err != nil {\n404: \t\treturn &JWTKeyLoadError{Err: fmt.Errorf(\"failed to create secret: %w\", err)}\n405: \t}\n406: \treturn nil\n407: }\n408: \n409: func (j *JWTManager) GetPublicKeyPEM() string {\n410: \tpemData := encodePublicKeyPEM(j.publicKey)\n411: \tif pemData == nil {\n412: \t\treturn \"\"\n413: \t}\n414: \treturn string(pemData)\n415: }\n416: \n417: func encodePrivateKeyPEM(key *rsa.PrivateKey) []byte {\n418: \treturn pem.EncodeToMemory(&pem.Block{\n419: \t\tType:  \"RSA PRIVATE KEY\",\n420: \t\tBytes: x509.MarshalPKCS1PrivateKey(key),\n421: \t})\n422: }\n423: \n424: func encodePublicKeyPEM(key *rsa.PublicKey) []byte {\n425: \tbytes, err := x509.MarshalPKIXPublicKey(key)\n426: \tif err != nil {\n427: \t\treturn nil\n428: \t}\n429: \treturn pem.EncodeToMemory(&pem.Block{\n430: \t\tType:  \"PUBLIC KEY\",\n431: \t\tBytes: bytes,\n432: \t})\n433: }\n434: \n435: func loadPrivateKeyPEM(data []byte) (*rsa.PrivateKey, error) {\n436: \tblock, _ := pem.Decode(data)\n437: \tif block == nil {\n438: \t\treturn nil, fmt.Errorf(\"failed to decode PEM block\")\n439: \t}\n440: \n441: \tkey, err := x509.ParsePKCS1PrivateKey(block.Bytes)\n442: \tif err != nil {\n443: \t\treturn nil, fmt.Errorf(\"failed to parse private key: %w\", err)\n444: \t}\n445: \n446: \treturn key, nil\n447: }\n448: \n449: func (j *JWTManager) GetPublicKey() *rsa.PublicKey {\n450: \treturn j.publicKey\n451: }\n\n(End of file - total 451 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"context\"\n\t\"crypto/rand\"\n\t\"crypto/rsa\"\n\t\"crypto/x509\"\n\t\"encoding/pem\"\n\t\"errors\"\n\t\"fmt\"\n\t\"os\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/golang-jwt/jwt/v5\"\n\tcorev1 \"k8s.io/api/core/v1\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/client-go/kubernetes\"\n\t\"k8s.io/klog/v2\"\n)","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/jwt.go","time":{"start":1775897127911,"end":1775897127937}}}}
{"type":"tool_use","timestamp":1775897127941,"sessionID":"ses_28448f185ffehh0S7VCtwI6VcR","part":{"id":"prt_d7bb7ab83001BOCK6zA46GHVQs","messageID":"msg_d7bb77384001MDaDnJdej6rlf6","sessionID":"ses_28448f185ffehh0S7VCtwI6VcR","type":"tool","tool":"read","callID":"toolu_tool-d036a63ae1274828b5f6a422e585242f","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/jwt_test.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/jwt_test.go</path>\n<type>file</type>\n<content>\n1: package router\n2: \n3: import (\n4: \t\"context\"\n5: \t\"crypto/rand\"\n6: \t\"crypto/rsa\"\n7: \t\"testing\"\n8: \t\"time\"\n9: \n10: \t\"github.com/golang-jwt/jwt/v5\"\n11: \t\"github.com/stretchr/testify/assert\"\n12: \t\"github.com/stretchr/testify/require\"\n13: )\n14: \n15: func TestNewJWTManager(t *testing.T) {\n16: \tjwtMgr, err := NewJWTManager()\n17: \trequire.NoError(t, err)\n18: \trequire.NotNil(t, jwtMgr.privateKey)\n19: \trequire.NotNil(t, jwtMgr.publicKey)\n20: \trequire.NotNil(t, jwtMgr.config)\n21: }\n22: \n23: func TestNewJWTManagerWithConfig(t *testing.T) {\n24: \tconfig := &JWTConfig{\n25: \t\tTokenExpiry:   10 * time.Minute,\n26: \t\tRefreshExpiry: 60 * time.Minute,\n27: \t\tIssuer:        \"custom-issuer\",\n28: \t}\n29: \tjwtMgr, err := NewJWTManagerWithConfig(config)\n30: \trequire.NoError(t, err)\n31: \trequire.NotNil(t, jwtMgr.config)\n32: \tassert.Equal(t, 10*time.Minute, jwtMgr.config.TokenExpiry)\n33: }\n34: \n35: func TestNewJWTManagerWithConfigNil(t *testing.T) {\n36: \tjwtMgr, err := NewJWTManagerWithConfig(nil)\n37: \trequire.NoError(t, err)\n38: \trequire.NotNil(t, jwtMgr.config)\n39: \tassert.Equal(t, jwtExpiration, jwtMgr.config.TokenExpiry)\n40: }\n41: \n42: func TestNewJWTManagerFromPrivateKey(t *testing.T) {\n43: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n44: \trequire.NoError(t, err)\n45: \n46: \tjwtMgr, err := NewJWTManagerFromPrivateKey(privateKey)\n47: \trequire.NoError(t, err)\n48: \trequire.NotNil(t, jwtMgr.privateKey)\n49: \tassert.Equal(t, privateKey.N, jwtMgr.privateKey.N)\n50: }\n51: \n52: func TestNewJWTManagerFromPrivateKeyNil(t *testing.T) {\n53: \t_, err := NewJWTManagerFromPrivateKey(nil)\n54: \trequire.Error(t, err)\n55: \tassert.IsType(t, &JWTKeyLoadError{}, err)\n56: }\n57: \n58: func TestJWTManagerGenerateToken(t *testing.T) {\n59: \tjwtMgr, err := NewJWTManager()\n60: \trequire.NoError(t, err)\n61: \n62: \tclaims := map[string]interface{}{\n63: \t\t\"session_id\": \"test-session\",\n64: \t\t\"sandbox_id\": \"test-sandbox\",\n65: \t}\n66: \n67: \ttokenStr, err := jwtMgr.GenerateToken(claims)\n68: \trequire.NoError(t, err)\n69: \tassert.NotEmpty(t, tokenStr)\n70: \n71: \ttoken, err := jwt.Parse(tokenStr, func(token *jwt.Token) (interface{}, error) {\n72: \t\tif _, ok := token.Method.(*jwt.SigningMethodRSA); !ok {\n73: \t\t\treturn nil, jwt.ErrSignatureInvalid\n74: \t\t}\n75: \t\treturn jwtMgr.publicKey, nil\n76: \t})\n77: \n78: \trequire.NoError(t, err)\n79: \tassert.True(t, token.Valid)\n80: \n81: \tmapClaims, ok := token.Claims.(jwt.MapClaims)\n82: \trequire.True(t, ok)\n83: \tassert.Equal(t, \"agentcube-router\", mapClaims[\"iss\"])\n84: \tassert.Equal(t, \"test-session\", mapClaims[\"session_id\"])\n85: }\n86: \n87: func TestJWTManagerGenerateTokenWithClaims(t *testing.T) {\n88: \tjwtMgr, err := NewJWTManager()\n89: \trequire.NoError(t, err)\n90: \n91: \tclaims := &RouterClaims{\n92: \t\tSessionID: \"test-session\",\n93: \t\tSandboxID: \"test-sandbox\",\n94: \t\tNamespace: \"test-namespace\",\n95: \t\tName:      \"test-name\",\n96: \t}\n97: \n98: \ttokenStr, err := jwtMgr.GenerateTokenWithClaims(claims)\n99: \trequire.NoError(t, err)\n100: \tassert.NotEmpty(t, tokenStr)\n101: \n102: \tvalidatedClaims, err := jwtMgr.ValidateToken(tokenStr)\n103: \trequire.NoError(t, err)\n104: \tassert.Equal(t, \"test-session\", validatedClaims.SessionID)\n105: \tassert.Equal(t, \"test-sandbox\", validatedClaims.SandboxID)\n106: \tassert.Equal(t, \"test-namespace\", validatedClaims.Namespace)\n107: \tassert.Equal(t, \"test-name\", validatedClaims.Name)\n108: }\n109: \n110: func TestJWTManagerGenerateTokenPair(t *testing.T) {\n111: \tjwtMgr, err := NewJWTManager()\n112: \trequire.NoError(t, err)\n113: \n114: \tclaims := &RouterClaims{\n115: \t\tSessionID: \"test-session\",\n116: \t\tSandboxID: \"test-sandbox\",\n117: \t\tNamespace: \"test-namespace\",\n118: \t\tName:      \"test-name\",\n119: \t}\n120: \n121: \ttokenPair, err := jwtMgr.GenerateTokenPair(claims)\n122: \trequire.NoError(t, err)\n123: \trequire.NotNil(t, tokenPair)\n124: \tassert.NotEmpty(t, tokenPair.AccessToken)\n125: \tassert.NotEmpty(t, tokenPair.RefreshToken)\n126: \tassert.Equal(t, \"Bearer\", tokenPair.TokenType)\n127: \tassert.Equal(t, int64(jwtExpiration.Seconds()), tokenPair.ExpiresIn)\n128: \n129: \taccessClaims, err := jwtMgr.ValidateToken(tokenPair.AccessToken)\n130: \trequire.NoError(t, err)\n131: \tassert.Equal(t, \"test-session\", accessClaims.SessionID)\n132: \n133: \trefreshClaims, err := jwtMgr.ValidateToken(tokenPair.RefreshToken)\n134: \trequire.NoError(t, err)\n135: \tassert.Equal(t, \"test-session\", refreshClaims.SessionID)\n136: \tassert.NotEmpty(t, refreshClaims.RegisteredClaims.ID)\n137: }\n138: \n139: func TestJWTManagerValidateToken(t *testing.T) {\n140: \tjwtMgr, err := NewJWTManager()\n141: \trequire.NoError(t, err)\n142: \n143: \ttoken, err := jwtMgr.GenerateToken(map[string]interface{}{\n144: \t\t\"session_id\": \"validate-session\",\n145: \t\t\"sandbox_id\": \"validate-sandbox\",\n146: \t\t\"namespace\":  \"validate-namespace\",\n147: \t\t\"name\":       \"validate-name\",\n148: \t})\n149: \trequire.NoError(t, err)\n150: \n151: \tclaims, err := jwtMgr.ValidateToken(token)\n152: \trequire.NoError(t, err)\n153: \tassert.Equal(t, \"validate-session\", claims.SessionID)\n154: \tassert.Equal(t, \"validate-sandbox\", claims.SandboxID)\n155: \tassert.Equal(t, \"validate-namespace\", claims.Namespace)\n156: \tassert.Equal(t, \"validate-name\", claims.Name)\n157: }\n158: \n159: func TestJWTManagerValidateTokenInvalid(t *testing.T) {\n160: \tjwtMgr, err := NewJWTManager()\n161: \trequire.NoError(t, err)\n162: \n163: \t_, err = jwtMgr.ValidateToken(\"invalid-token-string\")\n164: \trequire.Error(t, err)\n165: \tassert.IsType(t, &JWTValidationError{}, err)\n166: }\n167: \n168: func TestJWTManagerValidateTokenWrongKey(t *testing.T) {\n169: \tjwtMgr1, err := NewJWTManager()\n170: \trequire.NoError(t, err)\n171: \n172: \tjwtMgr2, err := NewJWTManager()\n173: \trequire.NoError(t, err)\n174: \n175: \ttoken, err := jwtMgr1.GenerateToken(map[string]interface{}{\n176: \t\t\"session_id\": \"wrong-key-session\",\n177: \t})\n178: \trequire.NoError(t, err)\n179: \n180: \t_, err = jwtMgr2.ValidateToken(token)\n181: \trequire.Error(t, err)\n182: \tassert.IsType(t, &JWTValidationError{}, err)\n183: }\n184: \n185: func TestJWTManagerRefreshToken(t *testing.T) {\n186: \tjwtMgr, err := NewJWTManager()\n187: \trequire.NoError(t, err)\n188: \n189: \tclaims := &RouterClaims{\n190: \t\tSessionID: \"refresh-session\",\n191: \t\tSandboxID: \"refresh-sandbox\",\n192: \t\tNamespace: \"refresh-namespace\",\n193: \t\tName:      \"refresh-name\",\n194: \t}\n195: \n196: \ttokenPair, err := jwtMgr.GenerateTokenPair(claims)\n197: \trequire.NoError(t, err)\n198: \n199: \tnewTokenPair, err := jwtMgr.RefreshToken(tokenPair.RefreshToken)\n200: \trequire.NoError(t, err)\n201: \trequire.NotNil(t, newTokenPair)\n202: \tassert.NotEmpty(t, newTokenPair.AccessToken)\n203: \tassert.NotEmpty(t, newTokenPair.RefreshToken)\n204: \n205: \tnewClaims, err := jwtMgr.ValidateToken(newTokenPair.AccessToken)\n206: \trequire.NoError(t, err)\n207: \tassert.Equal(t, \"refresh-session\", newClaims.SessionID)\n208: }\n209: \n210: func TestJWTManagerRefreshTokenWithAccessToken(t *testing.T) {\n211: \tjwtMgr, err := NewJWTManager()\n212: \trequire.NoError(t, err)\n213: \n214: \tclaims := &RouterClaims{\n215: \t\tSessionID: \"access-session\",\n216: \t}\n217: \n218: \ttoken, err := jwtMgr.GenerateTokenWithClaims(claims)\n219: \trequire.NoError(t, err)\n220: \n221: \t_, err = jwtMgr.RefreshToken(token)\n222: \trequire.Error(t, err)\n223: \tassert.IsType(t, &JWTValidationError{}, err)\n224: }\n225: \n226: func TestJWTManagerGetPublicKeyPEM(t *testing.T) {\n227: \tjwtMgr, err := NewJWTManager()\n228: \trequire.NoError(t, err)\n229: \n230: \tpemStr := jwtMgr.GetPublicKeyPEM()\n231: \tassert.NotEmpty(t, pemStr)\n232: \tassert.Contains(t, pemStr, \"PUBLIC KEY\")\n233: }\n234: \n235: func TestJWTManagerTokenExpiration(t *testing.T) {\n236: \tjwtMgr, err := NewJWTManager()\n237: \trequire.NoError(t, err)\n238: \n239: \ttokenStr, err := jwtMgr.GenerateToken(map[string]interface{}{})\n240: \trequire.NoError(t, err)\n241: \n242: \ttoken, err := jwt.Parse(tokenStr, func(token *jwt.Token) (interface{}, error) {\n243: \t\treturn jwtMgr.publicKey, nil\n244: \t})\n245: \trequire.NoError(t, err)\n246: \n247: \tmapClaims, ok := token.Claims.(jwt.MapClaims)\n248: \trequire.True(t, ok)\n249: \n250: \texp, ok := mapClaims[\"exp\"].(float64)\n251: \trequire.True(t, ok)\n252: \n253: \tnow := time.Now().Unix()\n254: \texpectedExp := now + int64(jwtExpiration.Seconds())\n255: \n256: \tassert.GreaterOrEqual(t, int64(exp), now)\n257: \tassert.LessOrEqual(t, int64(exp), expectedExp+5)\n258: \tassert.GreaterOrEqual(t, int64(exp), expectedExp-5)\n259: }\n260: \n261: func TestJWTManagerGetPublicKey(t *testing.T) {\n262: \tjwtMgr, err := NewJWTManager()\n263: \trequire.NoError(t, err)\n264: \n265: \tpubKey := jwtMgr.GetPublicKey()\n266: \trequire.NotNil(t, pubKey)\n267: \tassert.Equal(t, 2048/8, pubKey.Size())\n268: }\n269: \n270: func TestDefaultJWTConfig(t *testing.T) {\n271: \tconfig := DefaultJWTConfig()\n272: \trequire.NotNil(t, config)\n273: \tassert.Equal(t, jwtExpiration, config.TokenExpiry)\n274: \tassert.Equal(t, refreshExpiration, config.RefreshExpiry)\n275: \tassert.Equal(t, jwtIssuer, config.Issuer)\n276: \tassert.Equal(t, defaultClockSkew, config.ClockSkew)\n277: }\n278: \n279: func TestEncodePrivateKeyPEM(t *testing.T) {\n280: \tjwtMgr, err := NewJWTManager()\n281: \trequire.NoError(t, err)\n282: \n283: \tpemData := encodePrivateKeyPEM(jwtMgr.privateKey)\n284: \trequire.NotNil(t, pemData)\n285: \tassert.Contains(t, string(pemData), \"RSA PRIVATE KEY\")\n286: }\n287: \n288: func TestEncodePublicKeyPEM(t *testing.T) {\n289: \tjwtMgr, err := NewJWTManager()\n290: \trequire.NoError(t, err)\n291: \n292: \tpemData := encodePublicKeyPEM(jwtMgr.publicKey)\n293: \trequire.NotNil(t, pemData)\n294: \tassert.Contains(t, string(pemData), \"PUBLIC KEY\")\n295: }\n296: \n297: func TestLoadPrivateKeyPEM(t *testing.T) {\n298: \tjwtMgr, err := NewJWTManager()\n299: \trequire.NoError(t, err)\n300: \n301: \tpemData := encodePrivateKeyPEM(jwtMgr.privateKey)\n302: \tloadedKey, err := loadPrivateKeyPEM(pemData)\n303: \trequire.NoError(t, err)\n304: \tassert.Equal(t, 0, loadedKey.N.Cmp(jwtMgr.privateKey.N))\n305: }\n306: \n307: func TestLoadPrivateKeyPEMInvalid(t *testing.T) {\n308: \t_, err := loadPrivateKeyPEM([]byte(\"invalid pem data\"))\n309: \trequire.Error(t, err)\n310: }\n311: \n312: func TestLoadPrivateKeyPEMInvalidBlock(t *testing.T) {\n313: \t_, err := loadPrivateKeyPEM([]byte(\"-----BEGIN CERTIFICATE-----\\ninvalid\\n-----END CERTIFICATE-----\"))\n314: \trequire.Error(t, err)\n315: }\n316: \n317: func TestJWTManagerTryStoreOrLoadJWTKeySecretNoClient(t *testing.T) {\n318: \tjwtMgr, err := NewJWTManager()\n319: \trequire.NoError(t, err)\n320: \n321: \terr = jwtMgr.TryStoreOrLoadJWTKeySecret(context.Background())\n322: \tassert.NoError(t, err)\n323: }\n324: \n325: func TestJWTManagerLoadKeysFromSecretNoClient(t *testing.T) {\n326: \tjwtMgr, err := NewJWTManager()\n327: \trequire.NoError(t, err)\n328: \n329: \terr = jwtMgr.LoadKeysFromSecret(context.Background())\n330: \trequire.Error(t, err)\n331: \tassert.IsType(t, &JWTKeyLoadError{}, err)\n332: }\n333: \n334: func TestJWTManagerStoreKeysToSecretNoClient(t *testing.T) {\n335: \tjwtMgr, err := NewJWTManager()\n336: \trequire.NoError(t, err)\n337: \n338: \terr = jwtMgr.StoreKeysToSecret(context.Background())\n339: \trequire.Error(t, err)\n340: \tassert.IsType(t, &JWTKeyLoadError{}, err)\n341: }\n342: \n343: func TestRouterClaims(t *testing.T) {\n344: \tclaims := &RouterClaims{\n345: \t\tSessionID: \"claim-session\",\n346: \t\tSandboxID: \"claim-sandbox\",\n347: \t\tNamespace: \"claim-namespace\",\n348: \t\tName:      \"claim-name\",\n349: \t}\n350: \n351: \tjwtMgr, err := NewJWTManager()\n352: \trequire.NoError(t, err)\n353: \n354: \ttoken, err := jwtMgr.GenerateTokenWithClaims(claims)\n355: \trequire.NoError(t, err)\n356: \n357: \tvalidated, err := jwtMgr.ValidateToken(token)\n358: \trequire.NoError(t, err)\n359: \tassert.Equal(t, claims.SessionID, validated.SessionID)\n360: \tassert.Equal(t, claims.SandboxID, validated.SandboxID)\n361: \tassert.Equal(t, claims.Namespace, validated.Namespace)\n362: \tassert.Equal(t, claims.Name, validated.Name)\n363: }\n364: \n365: func TestTokenPair(t *testing.T) {\n366: \ttokenPair := &TokenPair{\n367: \t\tAccessToken:  \"access-token\",\n368: \t\tRefreshToken: \"refresh-token\",\n369: \t\tExpiresIn:    300,\n370: \t\tTokenType:    \"Bearer\",\n371: \t}\n372: \n373: \tassert.Equal(t, \"access-token\", tokenPair.AccessToken)\n374: \tassert.Equal(t, \"refresh-token\", tokenPair.RefreshToken)\n375: \tassert.Equal(t, int64(300), tokenPair.ExpiresIn)\n376: \tassert.Equal(t, \"Bearer\", tokenPair.TokenType)\n377: }\n378: \n379: func TestJWTManagerValidateTokenEmpty(t *testing.T) {\n380: \tjwtMgr, err := NewJWTManager()\n381: \trequire.NoError(t, err)\n382: \n383: \t_, err = jwtMgr.ValidateToken(\"\")\n384: \trequire.Error(t, err)\n385: }\n386: \n387: func BenchmarkJWTGenerateToken(b *testing.B) {\n388: \tjwtMgr, err := NewJWTManager()\n389: \tif err != nil {\n390: \t\tb.Fatalf(\"failed to create JWT manager: %v\", err)\n391: \t}\n392: \n393: \tclaims := map[string]interface{}{\n394: \t\t\"session_id\": \"bench-session\",\n395: \t\t\"sandbox_id\": \"bench-sandbox\",\n396: \t}\n397: \n398: \tb.ResetTimer()\n399: \tfor i := 0; i < b.N; i++ {\n400: \t\t_, _ = jwtMgr.GenerateToken(claims)\n401: \t}\n402: }\n403: \n404: func BenchmarkJWTValidateToken(b *testing.B) {\n405: \tjwtMgr, err := NewJWTManager()\n406: \tif err != nil {\n407: \t\tb.Fatalf(\"failed to create JWT manager: %v\", err)\n408: \t}\n409: \n410: \ttoken, err := jwtMgr.GenerateToken(map[string]interface{}{\n411: \t\t\"session_id\": \"bench-session\",\n412: \t})\n413: \tif err != nil {\n414: \t\tb.Fatalf(\"failed to generate token: %v\", err)\n415: \t}\n416: \n417: \tb.ResetTimer()\n418: \tfor i := 0; i < b.N; i++ {\n419: \t\t_, _ = jwtMgr.ValidateToken(token)\n420: \t}\n421: }\n422: \n423: func BenchmarkJWTGenerateTokenPair(b *testing.B) {\n424: \tjwtMgr, err := NewJWTManager()\n425: \tif err != nil {\n426: \t\tb.Fatalf(\"failed to create JWT manager: %v\", err)\n427: \t}\n428: \n429: \tclaims := &RouterClaims{\n430: \t\tSessionID: \"bench-session\",\n431: \t\tSandboxID: \"bench-sandbox\",\n432: \t}\n433: \n434: \tb.ResetTimer()\n435: \tfor i := 0; i < b.N; i++ {\n436: \t\t_, _ = jwtMgr.GenerateTokenPair(claims)\n437: \t}\n438: }\n439: \n440: func contains(s, substr string) bool {\n441: \treturn len(s) > 0 && len(substr) > 0 && len(s) >= len(substr)\n442: }\n\n(End of file - total 442 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"context\"\n\t\"crypto/rand\"\n\t\"crypto/rsa\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/golang-jwt/jwt/v5\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n)\n\nfunc TestNewJWTManager(t *testing.T) {\n\tjwtMgr, err := NewJWTManager()\n\trequire.NoError(t, err)\n\trequire.NotNil(t, jwtMgr.privateKey)\n\trequire.NotNil(t, jwtMgr.publicKey)\n\trequire.NotNil(t, jwtMgr.confi