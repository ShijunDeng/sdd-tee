: \t\treturn m.UpdateSessionLastActivityFunc(ctx, sessionID, at)\n39: \t}\n40: \treturn errors.New(\"not implemented\")\n41: }\n42: \n43: type MockHTTPClient struct {\n44: \tDoFunc func(req *http.Request) (*http.Response, error)\n45: }\n46: \n47: func (m *MockHTTPClient) Do(req *http.Request) (*http.Response, error) {\n48: \tif m.DoFunc != nil {\n49: \t\treturn m.DoFunc(req)\n50: \t}\n51: \treturn nil, errors.New(\"not implemented\")\n52: }\n53: \n54: func TestNewSessionManagerRequiresWorkloadManagerURL(t *testing.T) {\n55: \tmockStore := &MockStore{}\n56: \t_, err := NewSessionManager(mockStore)\n57: \tif err == nil {\n58: \t\tt.Error(\"expected error when WORKLOAD_MANAGER_URL is not set\")\n59: \t}\n60: \tif err.Error() != \"WORKLOAD_MANAGER_URL environment variable is required\" {\n61: \t\tt.Errorf(\"unexpected error message: %s\", err.Error())\n62: \t}\n63: }\n64: \n65: func TestSessionManagerGetSandboxBySessionWithExistingSession(t *testing.T) {\n66: \tmockStore := &MockStore{\n67: \t\tGetSandboxBySessionIDFunc: func(ctx context.Context, sessionID string) (*types.SandboxInfo, error) {\n68: \t\t\treturn &types.SandboxInfo{\n69: \t\t\t\tSessionID:   sessionID,\n70: \t\t\t\tSandboxID:   \"sandbox-123\",\n71: \t\t\t\tSandboxName: \"test-sandbox\",\n72: \t\t\t\tEntryPoints: []types.SandboxEntryPoint{\n73: \t\t\t\t\t{Path: \"/api\", Protocol: \"http\", Endpoint: \"localhost:8080\"},\n74: \t\t\t\t},\n75: \t\t\t}, nil\n76: \t\t},\n77: \t}\n78: \n79: \tsm := &sessionManager{\n80: \t\tstoreClient:     mockStore,\n81: \t\tworkloadMgrAddr: \"http://localhost:9090\",\n82: \t\thttpClient:      &http.Client{},\n83: \t}\n84: \n85: \tctx := context.Background()\n86: \tsandbox, err := sm.GetSandboxBySession(ctx, \"existing-session\", \"default\", \"test\", types.AgentRuntimeKind)\n87: \tif err != nil {\n88: \t\tt.Fatalf(\"unexpected error: %v\", err)\n89: \t}\n90: \tif sandbox.SessionID != \"existing-session\" {\n91: \t\tt.Errorf(\"unexpected session ID: %s\", sandbox.SessionID)\n92: \t}\n93: }\n94: \n95: func TestSessionManagerGetSandboxBySessionNotFound(t *testing.T) {\n96: \tmockStore := &MockStore{\n97: \t\tGetSandboxBySessionIDFunc: func(ctx context.Context, sessionID string) (*types.SandboxInfo, error) {\n98: \t\t\treturn nil, errors.New(\"session not found\")\n99: \t\t},\n100: \t}\n101: \n102: \tsm := &sessionManager{\n103: \t\tstoreClient:     mockStore,\n104: \t\tworkloadMgrAddr: \"http://localhost:9090\",\n105: \t\thttpClient:      &http.Client{},\n106: \t}\n107: \n108: \tctx := context.Background()\n109: \t_, err := sm.GetSandboxBySession(ctx, \"nonexistent-session\", \"default\", \"test\", types.AgentRuntimeKind)\n110: \tif err == nil {\n111: \t\tt.Error(\"expected error for nonexistent session\")\n112: \t}\n113: \tif _, ok := err.(*SessionNotFoundError); !ok {\n114: \t\tt.Errorf(\"expected SessionNotFoundError, got %T\", err)\n115: \t}\n116: }\n117: \n118: func TestSessionManagerCreateSandbox(t *testing.T) {\n119: \trespBody := types.CreateSandboxResponse{\n120: \t\tSessionID:   \"new-session-123\",\n121: \t\tSandboxID:   \"sandbox-456\",\n122: \t\tSandboxName: \"new-sandbox\",\n123: \t\tEntryPoints: []types.SandboxEntryPoint{\n124: \t\t\t{Path: \"/api\", Protocol: \"http\", Endpoint: \"localhost:8080\"},\n125: \t\t},\n126: \t}\n127: \trespBytes, _ := json.Marshal(respBody)\n128: \n129: \tserver := httptest.NewServer(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n130: \t\tif r.URL.Path != \"/v1/agent-runtime\" {\n131: \t\t\tt.Errorf(\"unexpected path: %s\", r.URL.Path)\n132: \t\t}\n133: \t\tif r.Method != http.MethodPost {\n134: \t\t\tt.Errorf(\"unexpected method: %s\", r.Method)\n135: \t\t}\n136: \n137: \t\tbody, _ := io.ReadAll(r.Body)\n138: \t\tvar req types.CreateSandboxRequest\n139: \t\tjson.Unmarshal(body, &req)\n140: \t\tif req.Kind != types.AgentRuntimeKind {\n141: \t\t\tt.Errorf(\"unexpected kind: %s\", req.Kind)\n142: \t\t}\n143: \n144: \t\tw.WriteHeader(http.StatusOK)\n145: \t\tw.Write(respBytes)\n