lse)\n287: \n288: \tbody := bytes.NewBufferString(`{\"command\": []}`)\n289: \tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/execute\", body, \"application/json\", validToken)\n290: \tassert.Equal(t, 400, w.Code)\n291: \n292: \tvar resp map[string]string\n293: \trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n294: \tassert.Equal(t, \"missing command\", resp[\"error\"])\n295: }\n296: \n297: func TestExecuteHandlerTimeout(t *testing.T) {\n298: \tserver := setupTestServer(t)\n299: \n300: \tauthMgr := server.authManager\n301: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n302: \trequire.NoError(t, err)\n303: \tauthMgr.SetPublicKey(&privateKey.PublicKey)\n304: \n305: \tvalidToken := generateTestJWT(privateKey, false)\n306: \n307: \tbody := bytes.NewBufferString(`{\"command\": [\"sleep\", \"10\"], \"timeout\": \"1s\"}`)\n308: \tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/execute\", body, \"application/json\", validToken)\n309: \tassert.Equal(t, 200, w.Code)\n310: \n311: \tvar resp ExecuteResponse\n312: \trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n313: \tassert.Equal(t, TimeoutExitCode, resp.ExitCode)\n314: \tassert.Contains(t, resp.Stderr, \"command timed out\")\n315: }\n316: \n317: func TestExecuteHandlerInvalidTimeout(t *testing.T) {\n318: \tserver := setupTestServer(t)\n319: \n320: \tauthMgr := server.authManager\n321: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n322: \trequire.NoError(t, err)\n323: \tauthMgr.SetPublicKey(&privateKey.PublicKey)\n324: \n325: \tvalidToken := generateTestJWT(privateKey, false)\n326: \n327: \tbody := bytes.NewBufferString(`{\"command\": [\"echo\", \"test\"], \"timeout\": \"invalid\"}`)\n328: \tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/execute\", body, \"application/json\", validToken)\n329: \tassert.Equal(t, 200, w.Code)\n330: \n331: \tvar resp ExecuteResponse\n332: \trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n333: \tassert.Equal(t, 0, resp.ExitCode)\n334: }\n335: \n336: func TestExecuteHandlerWorkingDirectory(t *testing.T) {\n337: \tserver := setupTestServer(t)\n338: \n339: \tsubdir := filepath.Join(server.workspace, \"subdir\")\n340: \trequire.NoError(t, os.MkdirAll(subdir, 0755))\n341: \n342: \tauthMgr := server.authManager\n343: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n344: \trequire.NoError(t, err)\n345: \tauthMgr.SetPublicKey(&privateKey.PublicKey)\n346: \n347: \tvalidToken := generateTestJWT(privateKey, false)\n348: \n349: \tbody := bytes.NewBufferString(`{\"command\": [\"pwd\"], \"working_dir\": \"subdir\"}`)\n350: \tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/execute\", body, \"application/json\", validToken)\n351: \tassert.Equal(t, 200, w.Code)\n352: \n353: \tvar resp ExecuteResponse\n354: \trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n355: \tassert.Contains(t, resp.Stdout, subdir)\n356: }\n357: \n358: func TestExecuteHandlerPathEscapeWorkingDir(t *testing.T) {\n359: \tserver := setupTestServer(t)\n360: \n361: \tauthMgr := server.authManager\n362: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n363: \trequire.NoError(t, err)\n364: \tauthMgr.SetPublicKey(&privateKey.PublicKey)\n365: \n366: \tvalidToken := generateTestJWT(privateKey, false)\n367: \n368: \tbody := bytes.NewBufferString(`{\"command\": [\"pwd\"], \"working_dir\": \"../escape\"}`)\n369: \tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/execute\", body, \"application/json\", validToken)\n370: \tassert.Equal(t, 400, w.Code)\n371: \n372: \tvar resp map[string]string\n373: \trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n374: \tassert.Contains(t, resp[\"error\"], \"invalid working directory\")\n375: }\n376: \n377: func TestExecuteHandlerEnvironmentAugmentation(t *testing.T) {\n378: \tserver := setupTestServer(t)\n379: \n380: \tauthMgr := server.authManager\n381: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n382: \trequire.NoError(t, err)\n383: \tauthMgr.SetPublicKey(&privateKey.PublicKey)\n384: \n385: \tvalidToken := generateTestJWT(privateKey, false)\n386: \n387: \tbody := bytes.NewBufferString(`{\"command\": [\"sh\", \"-c\", \"echo $MY_VAR\"], \"env\": {\"MY_VAR\": \"test_value\"}}`)\n388: \tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/execute\", body, \"application/json\", validToken)\n389: \tassert.Equal(t, 200, w.Code)\n390: \n391: \tvar resp ExecuteResponse\n392: \trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n393: \tassert.Contains(t, resp.Stdout, \"test_value\")\n394: }\n395: \n396: func TestExecuteHandlerExitCodePropagation(t *testing.T) {\n397: \tserver := setupTestServer(t)\n398: \n399: \tauthMgr := server.authManager\n400: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n401: \trequire.NoError(t, err)\n402: \tauthMgr.SetPublicKey(&privateKey.PublicKey)\n403: \n404: \tvalidToken := generateTestJWT(privateKey, false)\n405: \n406: \tbody := bytes.NewBufferString(`{\"command\": [\"sh\", \"-c\", \"exit 42\"]}`)\n407: \tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/execute\", body, \"application/json\", validToken)\n408: \tassert.Equal(t, 200, w.Code)\n409: \n410: \tvar resp ExecuteResponse\n411: \trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n412: \tassert.Equal(t, 42, resp.ExitCode)\n413: }\n414: \n415: func TestUploadFileHandlerMultipart(t *testing.T) {\n416: \tserver := setupTestServer(t)\n417: \n418: \tauthMgr := server.authManager\n419: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n420: \trequire.NoError(t, err)\n421: \tauthMgr.SetPublicKey(&privateKey.PublicKey)\n422: \n423: \tvalidToken := generateTestJWT(privateKey, false)\n424: \n425: \tbody := &bytes.Buffer{}\n426: \twriter := multipart.NewWriter(body)\n427: \n428: \trequire.NoError(t, writer.WriteField(\"path\", \"upload.txt\"))\n429: \tpart, err := writer.CreateFormFile(\"file\", \"upload.txt\")\n430: \trequire.NoError(t, err)\n431: \t_, err = part.Write([]byte(\"test file content\"))\n432: \trequire.NoError(t, err)\n433: \trequire.NoError(t, writer.Close())\n434: \n435: \treq := httptest.NewRequest(\"POST\", \"/api/files\", body)\n436: \treq.Header.Set(\"Content-Type\", writer.FormDataContentType())\n437: \treq.Header.Set(\"Authorization\", \"Bearer \"+validToken)\n438: \n439: \tw := httptest.NewRecorder()\n440: \tserver.engine.ServeHTTP(w, req)\n441: \n442: \tassert.Equal(t, 200, w.Code)\n443: \n444: \tvar resp FileInfo\n445: \trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n446: \tassert.Equal(t, \"upload.txt\", resp.Path)\n447: \n448: \tfilePath := filepath.Join(server.workspace, \"upload.txt\")\n449: \tactualContent, err := os.ReadFile(filePath)\n450: \trequire.NoError(t, err)\n451: \tassert.Equal(t, []byte(\"test file content\"), actualContent)\n452: }\n453: \n454: func TestUploadFileHandlerJSON(t *testing.T) {\n455: \tserver := setupTestServer(t)\n456: \n457: \tauthMgr := server.authManager\n458: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n459: \trequire.NoError(t, err)\n460: \tauthMgr.SetPublicKey(&privateKey.PublicKey)\n461: \n462: \tvalidToken := generateTestJWT(privateKey, false)\n463: \n464: \tcontent := base64.StdEncoding.EncodeToString([]byte(\"test content\"))\n465: \tbody := bytes.NewBufferString(fmt.Sprintf(`{\"path\": \"test.txt\", \"content\": \"%s\"}`, content))\n466: \tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/files\", body, \"application/json\", validToken)\n467: \tassert.Equal(t, 200, w.Code)\n468: \n469: \tvar resp FileInfo\n470: \trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n471: \tassert.Equal(t, \"test.txt\", resp.Path)\n472: \tassert.Equal(t, int64(12), resp.Size)\n473: \n474: \tfilePath := filepath.Join(server.workspace, \"test.txt\")\n475: \tactualContent, err := os.ReadFile(filePath)\n476: \trequire.NoError(t, err)\n477: \tassert.Equal(t, []byte(\"test content\"), actualContent)\n478: }\n479: \n480: func TestUploadFileHandlerInvalidBase64(t *testing.T) {\n481: \tserver := setupTestServer(t)\n482: \n483: \tauthMgr := server.authManager\n484: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n485: \trequire.NoError(t, err)\n486: \tauthMgr.SetPublicKey(&privateKey.PublicKey)\n487: \n488: \tvalidToken := generateTestJWT(privateKey, false)\n489: \n490: \tbody := bytes.NewBufferString(`{\"path\": \"test.txt\", \"content\": \"!!invalid\"}`)\n491: \tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/files\", body, \"application/json\", validToken)\n492: \tassert.Equal(t, 400, w.Code)\n493: \n494: \tvar resp map[string]string\n495: \trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n496: \tassert.Equal(t, \"invalid base64 content\", resp[\"error\"])\n497: }\n498: \n499: func TestUploadFileHandlerPathEscape(t *testing.T) {\n500: \tserver := setupTestServer(t)\n501: \n502: \tauthMgr := server.authManager\n503: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n504: \trequire.NoError(t, err)\n505: \tauthMgr.SetPublicKey(&privateKey.PublicKey)\n506: \n507: \tvalidToken := generateTestJWT(privateKey, false)\n508: \n509: \tcontent := base64.StdEncoding.EncodeToString([]byte(\"test\"))\n510: \tbody := bytes.NewBufferString(fmt.Sprintf(`{\"path\": \"../escape.txt\", \"content\": \"%s\"}`, content))\n511: \tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/files\", body, \"application/json\", validToken)\n512: \tassert.Equal(t, 400, w.Code)\n513: \n514: \tvar resp map[string]string\n515: \trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n516: \tassert.Contains(t, resp[\"error\"], \"invalid path\")\n517: }\n518: \n519: func TestUploadFileHandlerInvalidMode(t *testing.T) {\n520: \tserver := setupTestServer(t)\n521: \n522: \tauthMgr := server.authManager\n523: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n524: \trequire.NoError(t, err)\n525: \tauthMgr.SetPublicKey(&privateKey.PublicKey)\n526: \n527: \tvalidToken := generateTestJWT(privateKey, false)\n528: \n529: \tcontent := base64.StdEncoding.EncodeToString([]byte(\"test\"))\n530: \tbody := bytes.NewBufferString(fmt.Sprintf(`{\"path\": \"test.txt\", \"content\": \"%s\", \"mode\": \"9999\"}`, content))\n531: \tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/files\", body, \"application/json\", validToken)\n532: \tassert.Equal(t, 200, w.Code)\n533: \n534: \tvar resp FileInfo\n535: \trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n536: \tassert.Equal(t, \"test.txt\", resp.Path)\n537: }\n538: \n539: func TestUploadFileHandlerModeTooHigh(t *testing.T) {\n540: \tserver := setupTestServer(t)\n541: \n542: \tauthMgr := server.authManager\n543: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n544: \trequire.NoError(t, err)\n545: \tauthMgr.SetPublicKey(&privateKey.PublicKey)\n546: \n547: \tvalidToken := generateTestJWT(privateKey, false)\n548: \n549: \tcontent := base64.StdEncoding.EncodeToString([]byte(\"test\"))\n550: \tbody := bytes.NewBufferString(fmt.Sprintf(`{\"path\": \"test.txt\", \"content\": \"%s\", \"mode\": \"1000\"}`, content))\n551: \tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/files\", body, \"application/json\", validToken)\n552: \tassert.Equal(t, 400, w.Code)\n553: \n554: \tvar resp map[string]string\n555: \trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n556: \tassert.Equal(t, \"invalid file mode\", resp[\"error\"])\n557: }\n558: \n559: func TestUploadFileHandlerParentDirectoryCreation(t *testing.T) {\n560: \tserver := setupTestServer(t)\n561: \n562: \tauthMgr := server.authManager\n563: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n564: \trequire.NoError(t, err)\n565: \tauthMgr.SetPublicKey(&privateKey.PublicKey)\n566: \n567: \tvalidToken := generateTestJWT(privateKey, false)\n568: \n569: \tcontent := base64.StdEncoding.EncodeToString([]byte(\"test\"))\n570: \tbody := bytes.NewBufferString(fmt.Sprintf(`{\"path\": \"new/dir/file.txt\", \"content\": \"%s\"}`, content))\n571: \tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/files\", body, \"application/json\", validToken)\n572: \tassert.Equal(t, 200, w.Code)\n573: \n574: \tfilePath := filepath.Join(server.workspace, \"new/dir/file.txt\")\n575: \t_, err = os.Stat(filePath)\n576: \trequire.NoError(t, err)\n577: }\n578: \n579: func TestListFilesHandlerValidDirectory(t *testing.T) {\n580: \tserver := setupTestServer(t)\n581: \n582: \tsubdir := filepath.Join(server.workspace, \"testdir\")\n583: \trequire.NoError(t, os.MkdirAll(subdir, 0755))\n584: \trequire.NoError(t, os.WriteFile(filepath.Join(subdir, \"file1.txt\"), []byte(\"content\"), 0644))\n585: \n586: \tauthMgr := server.authManager\n587: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n588: \trequire.NoError(t, err)\n589: \tauthMgr.SetPublicKey(&privateKey.PublicKey)\n590: \n591: \tvalidToken := generateTestJWT(privateKey, false)\n592: \n593: \tw := makeAuthenticatedRequest(t, server, \"GET\", \"/api/files?path=testdir\", nil, \"\", validToken)\n594: \tassert.Equal(t, 200, w.Code)\n595: \n596: \tvar resp ListFilesResponse\n597: \trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n598: \tassert.Equal(t, \"testdir\", resp.Path)\n599: \tassert.Len(t, resp.Files, 1)\n600: \tassert.Equal(t, \"file1.txt\", resp.Files[0].Name)\n601: \tassert.False(t, resp.Files[0].IsDir)\n602: }\n603: \n604: func TestListFilesHandlerMissingPath(t *testing.T) {\n605: \tserver := setupTestServer(t)\n606: \n607: \tauthMgr := server.authManager\n608: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n609: \trequire.NoError(t, err)\n610: \tauthMgr.SetPublicKey(&privateKey.PublicKey)\n611: \n612: \tvalidToken := generateTestJWT(privateKey, false)\n613: \n614: \tw := makeAuthenticatedRequest(t, server, \"GET\", \"/api/files\", nil, \"\", validToken)\n615: \tassert.Equal(t, 400, w.Code)\n616: \n617: \tvar resp map[string]string\n618: \trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n619: \tassert.Equal(t, \"missing path parameter\", resp[\"error\"])\n620: }\