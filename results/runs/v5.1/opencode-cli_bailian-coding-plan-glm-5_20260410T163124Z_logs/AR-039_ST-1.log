r)\n35: \tListInactiveSandboxes(ctx context.Context, before time.Time, limit int64) ([]*types.SandboxInfo, error)\n36: \tUpdateSessionLastActivity(ctx context.Context, sessionID string, at time.Time) error\n37: \tClose() error\n38: }\n39: \n40: var (\n41: \tinitStoreOnce sync.Once\n42: \tprovider      Store\n43: )\n44: \n45: func Storage() Store {\n46: \tinitStoreOnce.Do(initStore)\n47: \treturn provider\n48: }\n49: \n50: func ResetStorage() {\n51: \tinitStoreOnce = sync.Once{}\n52: \tprovider = nil\n53: }\n\n(End of file - total 53 lines)\n</content>","metadata":{"preview":"package store\n\nimport (\n\t\"context\"\n\t\"errors\"\n\t\"sync\"\n\t\"time\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n)\n\nvar (\n\tErrNotFound         = errors.New(\"store: not found\")\n\tErrNilSandbox       = errors.New(\"store: sandbox is nil\")\n\tErrZeroExpiresAt    = errors.New(\"store: expiresAt is required\")\n\tErrEmptySessionID   = errors.New(\"store: sessionID is required\")\n\tErrInvalidProvider  = errors.New(\"store: invalid provider type\")\n\tErrPasswordRequired = errors.New(\"store: password is required\")\n\tErrKeyNotExists     = errors.New(\"store: key not exists\")\n\tErrSessionExists    = errors.New(\"store: session already exists\")","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/store/store.go","time":{"start":1775897113375,"end":1775897113413}}}}
{"type":"tool_use","timestamp":1775897113417,"sessionID":"ses_28448f185ffehh0S7VCtwI6VcR","part":{"id":"prt_d7bb772fb0017xHgFpqVELbIYO","messageID":"msg_d7bb74b280014jtWLpKRwETcoz","sessionID":"ses_28448f185ffehh0S7VCtwI6VcR","type":"tool","tool":"read","callID":"toolu_tool-121efae776024410be39b2396b348767","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/picod/picod_test.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/picod/picod_test.go</path>\n<type>file</type>\n<content>\n1: package picod\n2: \n3: import (\n4: \t\"bytes\"\n5: \t\"context\"\n6: \t\"crypto/rand\"\n7: \t\"crypto/rsa\"\n8: \t\"crypto/x509\"\n9: \t\"encoding/base64\"\n10: \t\"encoding/json\"\n11: \t\"encoding/pem\"\n12: \t\"fmt\"\n13: \t\"io\"\n14: \t\"mime/multipart\"\n15: \t\"net/http/httptest\"\n16: \t\"os\"\n17: \t\"path/filepath\"\n18: \t\"testing\"\n19: \t\"time\"\n20: \n21: \t\"github.com/gin-gonic/gin\"\n22: \t\"github.com/golang-jwt/jwt/v5\"\n23: \t\"github.com/stretchr/testify/assert\"\n24: \t\"github.com/stretchr/testify/require\"\n25: )\n26: \n27: func setupTestServer(t *testing.T) *Server {\n28: \tt.Helper()\n29: \n30: \tworkspace := t.TempDir()\n31: \n32: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n33: \trequire.NoError(t, err)\n34: \n35: \tpublicKeyPEM := encodePublicKeyPEMForTest(&privateKey.PublicKey)\n36: \n37: \toldEnv := os.Getenv(PublicKeyEnvVar)\n38: \tos.Setenv(PublicKeyEnvVar, publicKeyPEM)\n39: \tt.Cleanup(func() {\n40: \t\tif oldEnv != \"\" {\n41: \t\t\tos.Setenv(PublicKeyEnvVar, oldEnv)\n42: \t\t} else {\n43: \t\t\tos.Unsetenv(PublicKeyEnvVar)\n44: \t\t}\n45: \t})\n46: \n47: \tserver, err := NewServer(&Config{\n48: \t\tPort:      8080,\n49: \t\tWorkspace: workspace,\n50: \t})\n51: \trequire.NoError(t, err)\n52: \n53: \treturn server\n54: }\n55: \n56: func encodePublicKeyPEMForTest(key *rsa.PublicKey) string {\n57: \tbytes, err := x509.MarshalPKIXPublicKey(key)\n58: \tif err != nil {\n59: \t\treturn \"\"\n60: \t}\n61: \tpemData := pem.EncodeToMemory(&pem.Block{\n62: \t\tType:  \"PUBLIC KEY\",\n63: \t\tBytes: bytes,\n64: \t})\n65: \treturn string(pemData)\n66: }\n67: \n68: func generateTestJWT(privateKey *rsa.PrivateKey, expired bool) string {\n69: \tnow := time.Now()\n70: \texpiry := now.Add(5 * time.Minute)\n71: \tif expired {\n72: \t\texpiry = now.Add(-5 * time.Minute)\n73: \t}\n74: \n75: \tclaims := jwt.MapClaims{\n76: \t\t\"exp\": expiry.Unix(),\n77: \t\t\"iat\": now.Unix(),\n78: \t\t\"iss\": \"test-issuer\",\n79: \t}\n80: \n81: \ttoken := jwt.NewWithClaims(jwt.SigningMethodRS256, claims)\n82: \ttokenString, _ := token.SignedString(privateKey)\n83: \treturn tokenString\n84: }\n85: \n86: func generateHS256JWT() string {\n87: \tclaims := jwt.MapClaims{\n88: \t\t\"exp\": time.Now().Add(5 * time.Minute).Unix(),\n89: \t\t\"iat\": time.Now().Unix(),\n90: \t}\n91: \n92: \ttoken := jwt.NewWithClaims(jwt.SigningMethodHS256, claims)\n93: \ttokenString, _ := token.SignedString([]byte(\"test-secret\"))\n94: \treturn tokenString\n95: }\n96: \n97: func makeAuthenticatedRequest(t *testing.T, server *Server, method, path string, body io.Reader, contentType string, jwtToken string) *httptest.ResponseRecorder {\n98: \tt.Helper()\n99: \n100: \tgin.SetMode(gin.TestMode)\n101: \tw := httptest.NewRecorder()\n102: \treq := httptest.NewRequest(method, path, body)\n103: \tif contentType != \"\" {\n104: \t\treq.Header.Set(\"Content-Type\", contentType)\n105: \t}\n106: \tif jwtToken != \"\" {\n107: \t\treq.Header.Set(\"Authorization\", \"Bearer \"+jwtToken)\n108: \t}\n109: \n110: \tserver.engine.ServeHTTP(w, req)\n111: \treturn w\n112: }\n113: \n114: func TestConfig(t *testing.T) {\n115: \tcfg := &Config{\n116: \t\tPort:      8080,\n117: \t\tWorkspace: \"/tmp/test\",\n118: \t}\n119: \n120: \tassert.Equal(t, 8080, cfg.Port)\n121: \tassert.Equal(t, \"/tmp/test\", cfg.Workspace)\n122: }\n123: \n124: func TestSanitizePathValidRelative(t *testing.T) {\n125: \tworkspace := t.TempDir()\n126: \n127: \tresult, err := sanitizePath(workspace, \"subdir/file.txt\")\n128: \trequire.NoError(t, err)\n129: \n130: \texpected := filepath.Join(workspace, \"subdir/file.txt\")\n131: \tassert.Equal(t, expected, result)\n132: }\n133: \n134: func TestSanitizePathAbsolute(t *testing.T) {\n135: \tworkspace := t.TempDir()\n136: \n137: \tresult, err := sanitizePath(workspace, \"/workspace/file.txt\")\n138: \trequire.NoError(t, err)\n139: \n140: \texpected := filepath.Join(workspace, \"workspace/file.txt\")\n141: \tassert.Equal(t, expected, result)\n142: }\n143: \n144: func TestSanitizePathTraversal(t *testing.T) {\n145: \tworkspace := t.TempDir()\n146: \n147: \t_, err := sanitizePath(workspace, \"../escape.txt\")\n148: \tassert.Error(t, err)\n149: \tassert.Contains(t, err.Error(), \"path escape\")\n150: }\n151: \n152: func TestSanitizePathDeepTraversal(t *testing.T) {\n153: \tworkspace := t.TempDir()\n154: \n155: \t_, err := sanitizePath(workspace, \"subdir/../../escape.txt\")\n156: \tassert.Error(t, err)\n157: \tassert.Contains(t, err.Error(), \"path escape\")\n158: }\n159: \n160: func TestSanitizePathNullByte(t *testing.T) {\n161: \tworkspace := t.TempDir()\n162: \n163: \tresult, err := sanitizePath(workspace, \"file\\x00.txt\")\n164: \trequire.NoError(t, err)\n165: \n166: \tassert.Contains(t, result, workspace)\n167: }\n168: \n169: func TestSanitizePathExistingSymlink(t *testing.T) {\n170: \tworkspace := t.TempDir()\n171: \n172: \ttargetDir := filepath.Join(workspace, \"target\")\n173: \trequire.NoError(t, os.MkdirAll(targetDir, 0755))\n174: \n175: \tlinkPath := filepath.Join(workspace, \"link\")\n176: \trequire.NoError(t, os.Symlink(targetDir, linkPath))\n177: \n178: \ttargetFile := filepath.Join(targetDir, \"file.txt\")\n179: \trequire.NoError(t, os.WriteFile(targetFile, []byte(\"test\"), 0644))\n180: \n181: \tresult, err := sanitizePath(workspace, \"link/file.txt\")\n182: \trequire.NoError(t, err)\n183: \n184: \tassert.Equal(t, targetFile, result)\n185: }\n186: \n187: func TestAuthMiddlewareMissingHeader(t *testing.T) {\n188: \tserver := setupTestServer(t)\n189: \n190: \tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/execute\", nil, \"application/json\", \"\")\n191: \tassert.Equal(t, 401, w.Code)\n192: \n193: \tvar resp map[string]string\n194: \trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n195: \tassert.Equal(t, \"missing authorization header\", resp[\"error\"])\n196: }\n197: \n198: func TestAuthMiddlewareInvalidFormat(t *testing.T) {\n199: \tserver := setupTestServer(t)\n200: \n201: \tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/execute\", nil, \"application/json\", \"InvalidFormat\")\n202: \tassert.Equal(t, 401, w.Code)\n203: \n204: \tvar resp map[string]string\n205: \trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n206: \tassert.Contains(t, resp[\"error\"], \"malformed\")\n207: }\n208: \n209: func TestAuthMiddlewareExpiredToken(t *testing.T) {\n210: \tserver := setupTestServer(t)\n211: \n212: \tauthMgr := server.authManager\n213: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n214: \trequire.NoError(t, err)\n215: \n216: \texpiredToken := generateTestJWT(privateKey, true)\n217: \n218: \tauthMgr.SetPublicKey(&privateKey.PublicKey)\n219: \n220: \tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/execute\", nil, \"application/json\", expiredToken)\n221: \tassert.Equal(t, 401, w.Code)\n222: \n223: \tvar resp map[string]string\n224: \trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n225: \tassert.Equal(t, \"token is expired\", resp[\"error\"])\n226: }\n227: \n228: func TestAuthMiddlewareHS256Token(t *testing.T) {\n229: \tserver := setupTestServer(t)\n230: \n231: \ths256Token := generateHS256JWT()\n232: \n233: \tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/execute\", nil, \"application/json\", hs256Token)\n234: \tassert.Equal(t, 401, w.Code)\