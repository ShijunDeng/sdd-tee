FoundError{SessionID: \"inner\"}\n37: \terr := &JWTSigningError{Err: innerErr}\n38: \tassert.Equal(t, 500, err.Status())\n39: \tassert.Equal(t, \"JWT_SIGNING_FAILED\", err.Code())\n40: \tassert.Equal(t, \"jwt signing failed\", err.Message())\n41: \tassert.Contains(t, err.Error(), \"jwt signing failed\")\n42: }\n43: \n44: func TestJWTValidationError(t *testing.T) {\n45: \tinnerErr := errors.New(\"validation failed\")\n46: \terr := &JWTValidationError{Err: innerErr}\n47: \tassert.Equal(t, 401, err.Status())\n48: \tassert.Equal(t, \"JWT_VALIDATION_FAILED\", err.Code())\n49: \tassert.Equal(t, \"jwt validation failed\", err.Message())\n50: \tassert.Contains(t, err.Error(), \"jwt validation failed\")\n51: }\n52: \n53: func TestJWTValidationErrorNil(t *testing.T) {\n54: \terr := &JWTValidationError{Err: nil}\n55: \tassert.Equal(t, 401, err.Status())\n56: \tassert.Equal(t, \"JWT_VALIDATION_FAILED\", err.Code())\n57: \tassert.Equal(t, \"jwt validation failed\", err.Message())\n58: \tassert.Equal(t, \"jwt validation failed\", err.Error())\n59: }\n60: \n61: func TestJWTValidationErrorUnwrap(t *testing.T) {\n62: \tinnerErr := errors.New(\"inner error\")\n63: \terr := &JWTValidationError{Err: innerErr}\n64: \tunwrapped := err.Unwrap()\n65: \trequire.NotNil(t, unwrapped)\n66: \tassert.Equal(t, \"inner error\", unwrapped.Error())\n67: }\n68: \n69: func TestJWTTokenExpiredError(t *testing.T) {\n70: \terr := &JWTTokenExpiredError{TokenID: \"expired-token-id\"}\n71: \tassert.Equal(t, \"jwt token expired: expired-token-id\", err.Error())\n72: \tassert.Equal(t, 401, err.Status())\n73: \tassert.Equal(t, \"JWT_TOKEN_EXPIRED\", err.Code())\n74: \tassert.Equal(t, \"jwt token expired\", err.Message())\n75: }\n76: \n77: func TestJWTTokenMissingError(t *testing.T) {\n78: \terr := &JWTTokenMissingError{}\n79: \tassert.Equal(t, \"jwt token missing\", err.Error())\n80: \tassert.Equal(t, 401, err.Status())\n81: \tassert.Equal(t, \"JWT_TOKEN_MISSING\", err.Code())\n82: \tassert.Equal(t, \"jwt token missing\", err.Message())\n83: }\n84: \n85: func TestJWTInvalidFormatError(t *testing.T) {\n86: \terr := &JWTInvalidFormatError{Reason: \"missing bearer prefix\"}\n87: \tassert.Equal(t, \"invalid authorization header format: missing bearer prefix\", err.Error())\n88: \tassert.Equal(t, 401, err.Status())\n89: \tassert.Equal(t, \"JWT_INVALID_FORMAT\", err.Code())\n90: \tassert.Equal(t, \"invalid authorization header format\", err.Message())\n91: }\n92: \n93: func TestJWTInvalidFormatErrorEmptyReason(t *testing.T) {\n94: \terr := &JWTInvalidFormatError{Reason: \"\"}\n95: \tassert.Equal(t, \"invalid authorization header format\", err.Error())\n96: \tassert.Equal(t, 401, err.Status())\n97: \tassert.Equal(t, \"JWT_INVALID_FORMAT\", err.Code())\n98: \tassert.Equal(t, \"invalid authorization header format\", err.Message())\n99: }\n100: \n101: func TestJWTKeyLoadError(t *testing.T) {\n102: \tinnerErr := errors.New(\"key load failed\")\n103: \terr := &JWTKeyLoadError{Err: innerErr}\n104: \tassert.Equal(t, 500, err.Status())\n105: \tassert.Equal(t, \"JWT_KEY_LOAD_FAILED\", err.Code())\n106: \tassert.Equal(t, \"jwt key load failed\", err.Message())\n107: \tassert.Contains(t, err.Error(), \"jwt key load failed\")\n108: }\n109: \n110: func TestJWTKeyLoadErrorNil(t *testing.T) {\n111: \terr := &JWTKeyLoadError{Err: nil}\n112: \tassert.Equal(t, 500, err.Status())\n113: \tassert.Equal(t, \"JWT_KEY_LOAD_FAILED\", err.Code())\n114: \tassert.Equal(t, \"jwt key load failed\", err.Message())\n115: \tassert.Equal(t, \"jwt key load failed\", err.Error())\n116: }\n117: \n118: func TestJWTKeyLoadErrorUnwrap(t *testing.T) {\n119: \tinnerErr := errors.New(\"inner error\")\n120: \terr := &JWTKeyLoadError{Err: innerErr}\n121: \tunwrapped := err.Unwrap()\n122: \trequire.NotNil(t, unwrapped)\n123: \tassert.Equal(t, \"inner error\", unwrapped.Error())\n124: }\n125: \n126: func TestServerOverloadedError(t *testing.T) {\n127: \terr := &ServerOverloadedError{}\n128: \tassert.Equal(t, \"server overloaded\", err.Error())\n129: \tassert.Equal(t, 429, err.Status())\n130: \tassert.Equal(t, \"SERVER_OVERLOADED\", err.Code())\n131: \tassert.Equal(t, \"server overloaded, please try again later\", err.Message())\n132: }\n133: \n134: func TestNoEntryPointError(t *testing.T) {\n135: \terr := &NoEntryPointError{SandboxID: \"test-sandbox\"}\n136: \tassert.Equal(t, \"no entry point for sandbox: test-sandbox\", err.Error())\n137: \tassert.Equal(t, 404, err.Status())\n138: \tassert.Equal(t, \"NO_ENTRY_POINT\", err.Code())\n139: \tassert.Equal(t, \"no entry point configured\", err.Message())\n140: }\n141: \n142: func TestWorkloadManagerError(t *testing.T) {\n143: \terr := &WorkloadManagerError{StatusCode: 500, Msg: \"test message\"}\n144: \tassert.Equal(t, \"test message\", err.Error())\n145: \tassert.Equal(t, 500, err.Status())\n146: \tassert.Equal(t, \"WORKLOAD_MANAGER_ERROR\", err.Code())\n147: \tassert.Equal(t, \"test message\", err.Message())\n148: }\n149: \n150: func TestAPIStatusInterface(t *testing.T) {\n151: \tapiErrors := []APIStatus{\n152: \t\t&SessionNotFoundError{SessionID: \"test\"},\n153: \t\t&SandboxUnreachableError{SandboxID: \"test\"},\n154: \t\t&SandboxTimeoutError{SandboxID: \"test\"},\n155: \t\t&JWTSigningError{Err: nil},\n156: \t\t&JWTValidationError{Err: nil},\n157: \t\t&JWTTokenExpiredError{TokenID: \"test\"},\n158: \t\t&JWTTokenMissingError{},\n159: \t\t&JWTInvalidFormatError{Reason: \"test\"},\n160: \t\t&JWTKeyLoadError{Err: nil},\n161: \t\t&ServerOverloadedError{},\n162: \t\t&NoEntryPointError{SandboxID: \"test\"},\n163: \t\t&WorkloadManagerError{StatusCode: 500, Msg: \"test\"},\n164: \t}\n165: \n166: \tfor _, err := range apiErrors {\n167: \t\tassert.NotZero(t, err.Status(), \"Status() returned 0 for %T\", err)\n168: \t\tassert.NotEmpty(t, err.Code(), \"Code() returned empty string for %T\", err)\n169: \t\tassert.NotEmpty(t, err.Message(), \"Message() returned empty string for %T\", err)\n170: \t\tasErr, ok := err.(error)\n171: \t\trequire.True(t, ok, \"APIStatus %T does not implement error interface\", err)\n172: \t\tassert.NotEmpty(t, asErr.Error(), \"Error() returned empty string for %T\", err)\n173: \t}\n174: }\n175: \n176: func TestJWTErrorInterface(t *testing.T) {\n177: \tjwtErrors := []APIStatus{\n178: \t\t&JWTSigningError{Err: errors.New(\"test\")},\n179: \t\t&JWTValidationError{Err: errors.New(\"test\")},\n180: \t\t&JWTTokenExpiredError{TokenID: \"test\"},\n181: \t\t&JWTTokenMissingError{},\n182: \t\t&JWTInvalidFormatError{Reason: \"test\"},\n183: \t\t&JWTKeyLoadError{Err: errors.New(\"test\")},\n184: \t}\n185: \n186: \tfor _, err := range jwtErrors {\n187: \t\tassert.IsType(t, err, err)\n188: \t}\n189: }\n\n(End of file - total 189 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"errors\"\n\t\"testing\"\n\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n)\n\nfunc TestSessionNotFoundError(t *testing.T) {\n\terr := &SessionNotFoundError{SessionID: \"test-session\"}\n\tassert.Equal(t, \"session not found: test-session\", err.Error())\n\tassert.Equal(t, 404, err.Status())\n\tassert.Equal(t, \"SESSION_NOT_FOUND\", err.Code())\n\tassert.Equal(t, \"session not found\", err.Message())\n}\n\nfunc TestSandboxUnreachableError(t *testing.T) {\n\terr := &SandboxUnreachableError{SandboxID: \"test-sandbox\"}","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/errors_test.go","time":{"start":1775897138886,"end":1775897138906}}}}
