{"type":"tool_use","timestamp":1775897127935,"sessionID":"ses_28448f185ffehh0S7VCtwI6VcR","part":{"id":"prt_d7bb79e6f001Z25ExQKUk19xwi","messageID":"msg_d7bb77384001MDaDnJdej6rlf6","sessionID":"ses_28448f185ffehh0S7VCtwI6VcR","type":"tool","tool":"read","callID":"toolu_tool-6cca85a9622149cb805dae2c26e7ce28","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/reverse_proxy.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/reverse_proxy.go</path>\n<type>file</type>\n<content>\n1: package router\n2: \n3: import (\n4: \t\"encoding/json\"\n5: \t\"net/http\"\n6: \t\"net/url\"\n7: \t\"strings\"\n8: \n9: \t\"github.com/gin-gonic/gin\"\n10: \t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n11: )\n12: \n13: func newReverseProxy(target *url.URL, jwt string, sessionID string) *ReverseProxyWrapper {\n14: \tdirector := func(req *http.Request) {\n15: \t\tpath := req.URL.Path\n16: \t\tif path != \"\" && path[0] != '/' {\n17: \t\t\tpath = \"/\" + path\n18: \t\t}\n19: \n20: \t\treq.URL.Scheme = target.Scheme\n21: \t\treq.URL.Host = target.Host\n22: \t\treq.URL.Path = path\n23: \t\treq.URL.RawPath = \"\"\n24: \t\treq.Host = target.Host\n25: \n26: \t\treq.Header.Set(\"X-Forwarded-Host\", req.Header.Get(\"Host\"))\n27: \n28: \t\tproto := \"http\"\n29: \t\tif req.TLS != nil {\n30: \t\t\tproto = \"https\"\n31: \t\t}\n32: \t\treq.Header.Set(\"X-Forwarded-Proto\", proto)\n33: \n34: \t\texistingXFF := req.Header.Get(\"X-Forwarded-For\")\n35: \t\tclientIP := req.RemoteAddr\n36: \t\tif existingXFF != \"\" {\n37: \t\t\tclientIP = existingXFF + \",\" + clientIP\n38: \t\t}\n39: \t\treq.Header.Set(\"X-Forwarded-For\", clientIP)\n40: \n41: \t\tif jwt != \"\" {\n42: \t\t\treq.Header.Set(\"Authorization\", \"Bearer \"+jwt)\n43: \t\t}\n44: \t}\n45: \n46: \tmodifyResponse := func(resp *http.Response) error {\n47: \t\tresp.Header.Set(\"x-agentcube-session-id\", sessionID)\n48: \t\treturn nil\n49: \t}\n50: \n51: \terrorHandler := func(resp http.ResponseWriter, req *http.Request, err error) {\n52: \t\terrMsg := err.Error()\n53: \t\tvar statusCode int\n54: \t\tvar message string\n55: \n56: \t\tif strings.Contains(errMsg, \"connection refused\") {\n57: \t\t\tstatusCode = http.StatusBadGateway\n58: \t\t\tmessage = \"sandbox unreachable\"\n59: \t\t} else if strings.Contains(errMsg, \"timeout\") {\n60: \t\t\tstatusCode = http.StatusGatewayTimeout\n61: \t\t\tmessage = \"sandbox timeout\"\n62: \t\t} else {\n63: \t\t\tstatusCode = http.StatusBadGateway\n64: \t\t\tmessage = \"sandbox unreachable\"\n65: \t\t}\n66: \n67: \t\tresp.Header().Set(\"Content-Type\", \"application/json\")\n68: \t\tresp.WriteHeader(statusCode)\n69: \t\tjson.NewEncoder(resp).Encode(gin.H{\"error\": message})\n70: \t}\n71: \n72: \treturn &ReverseProxyWrapper{\n73: \t\tdirector:       director,\n74: \t\tmodifyResponse: modifyResponse,\n75: \t\terrorHandler:   errorHandler,\n76: \t}\n77: }\n78: \n79: type ReverseProxyWrapper struct {\n80: \tdirector       func(*http.Request)\n81: \tmodifyResponse func(*http.Response) error\n82: \terrorHandler   func(http.ResponseWriter, *http.Request, error)\n83: }\n84: \n85: func (rpw *ReverseProxyWrapper) Director(req *http.Request) {\n86: \trpw.director(req)\n87: }\n88: \n89: func (rpw *ReverseProxyWrapper) ModifyResponse(resp *http.Response) error {\n90: \treturn rpw.modifyResponse(resp)\n91: }\n92: \n93: func (rpw *ReverseProxyWrapper) ErrorHandler(resp http.ResponseWriter, req *http.Request, err error) {\n94: \trpw.errorHandler(resp, req, err)\n95: }\n96: \n97: func selectEntryPoint(entryPoints []types.SandboxEntryPoint, invocationPath string) *types.SandboxEntryPoint {\n98: \tif len(entryPoints) == 0 {\n99: \t\treturn nil\n100: \t}\n101: \n102: \tfor _, ep := range entryPoints {\n103: \t\tif strings.HasPrefix(invocationPath, ep.Path) {\n104: \t\t\treturn &ep\n105: \t\t}\n106: \t}\n107: \n108: \treturn &entryPoints[0]\n109: }\n110: \n111: func buildTargetURL(ep *types.SandboxEntryPoint) (*url.URL, error) {\n112: \tendpoint := ep.Endpoint\n113: \tif ep.Protocol != \"\" && !strings.Contains(endpoint, \"://\") {\n114: \t\tendpoint = strings.ToLower(ep.Protocol) + \"://\" + endpoint\n115: \t}\n116: \treturn url.Parse(endpoint)\n117: }\n\n(End of file - total 117 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"encoding/json\"\n\t\"net/http\"\n\t\"net/url\"\n\t\"strings\"\n\n\t\"github.com/gin-gonic/gin\"\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n)\n\nfunc newReverseProxy(target *url.URL, jwt string, sessionID string) *ReverseProxyWrapper {\n\tdirector := func(req *http.Request) {\n\t\tpath := req.URL.Path\n\t\tif path != \"\" && path[0] != '/' {\n\t\t\tpath = \"/\" + path\n\t\t}\n\n\t\treq.URL.Scheme = target.Scheme","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/reverse_proxy.go","time":{"start":1775897127906,"end":1775897127934}}}}
