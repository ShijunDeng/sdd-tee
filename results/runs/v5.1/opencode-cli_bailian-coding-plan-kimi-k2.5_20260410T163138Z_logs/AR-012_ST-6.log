{"type":"tool_use","timestamp":1775865681055,"sessionID":"ses_286289c44ffeoJBcO7yVHd6sSt","part":{"id":"prt_d79d7c719001R8wdai4oscE466","messageID":"msg_d79d7a624001s2MdjpxY2UM8k8","sessionID":"ses_286289c44ffeoJBcO7yVHd6sSt","type":"tool","tool":"read","callID":"toolu_functions.read:4","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/store/redis.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/store/redis.go</path>\n<type>file</type>\n<content>\n1: /*\n2: Copyright 2026 The Volcano Authors.\n3: \n4: Licensed under the Apache License, Version 2.0 (the \"License\");\n5: you may not use this file except in compliance with the License.\n6: You may obtain a copy of the License at\n7: \n8:     http://www.apache.org/licenses/LICENSE-2.0\n9: \n10: Unless required by applicable law or agreed to in writing, software\n11: distributed under the License is distributed on an \"AS IS\" BASIS,\n12: WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n13: See the License for the specific language governing permissions and\n14: limitations under the License.\n15: */\n16: \n17: package store\n18: \n19: import (\n20: \t\"context\"\n21: \t\"encoding/json\"\n22: \t\"fmt\"\n23: \t\"time\"\n24: \n25: \tredisv9 \"github.com/redis/go-redis/v9\"\n26: \t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n27: )\n28: \n29: // redisStore implements Store interface using Redis backend.\n30: type redisStore struct {\n31: \tcli                  *redisv9.Client\n32: \tsessionPrefix        string\n33: \texpiryIndexKey       string\n34: \tlastActivityIndexKey string\n35: }\n36: \n37: // newRedisStore creates a new Redis-backed Store instance.\n38: func newRedisStore() (Store, error) {\n39: \topts, err := makeRedisOptions()\n40: \tif err != nil {\n41: \t\treturn nil, err\n42: \t}\n43: \n44: \tclient := redisv9.NewClient(&redisv9.Options{\n45: \t\tAddr:     opts.Addr,\n46: \t\tPassword: opts.Password,\n47: \t})\n48: \n49: \treturn &redisStore{\n50: \t\tcli:                  client,\n51: \t\tsessionPrefix:        sessionPrefix,\n52: \t\texpiryIndexKey:       expiryIndexKey,\n53: \t\tlastActivityIndexKey: lastActivityIndexKey,\n54: \t}, nil\n55: }\n56: \n57: // sessionKey constructs the Redis key for a session.\n58: func (s *redisStore) sessionKey(sessionID string) string {\n59: \treturn s.sessionPrefix + sessionID\n60: }\n61: \n62: // Ping verifies connectivity to the Redis backend.\n63: // Returns nil on success, error on failure.\n64: func (s *redisStore) Ping(ctx context.Context) error {\n65: \tresult, err := s.cli.Ping(ctx).Result()\n66: \tif err != nil {\n67: \t\treturn err\n68: \t}\n69: \tif result != \"PONG\" {\n70: \t\treturn fmt.Errorf(\"unexpected ping response: %s\", result)\n71: \t}\n72: \treturn nil\n73: }\n74: \n75: // GetSandboxBySessionID retrieves sandbox info by session ID.\n76: // Returns ErrNotFound if the session does not exist.\n77: func (s *redisStore) GetSandboxBySessionID(ctx context.Context, sessionID string) (*types.SandboxInfo, error) {\n78: \tif sessionID == \"\" {\n79: \t\treturn nil, fmt.Errorf(\"sessionID is empty\")\n80: \t}\n81: \n82: \tkey := s.sessionKey(sessionID)\n83: \tdata, err := s.cli.Get(ctx, key).Result()\n84: \tif err == redisv9.Nil {\n85: \t\treturn nil, ErrNotFound\n86: \t}\n87: \tif err != nil {\n88: \t\treturn nil, err\n89: \t}\n90: \n91: \tvar sandbox types.SandboxInfo\n92: \tif err := json.Unmarshal([]byte(data), &sandbox); err != nil {\n93: \t\treturn nil, fmt.Errorf(\"failed to unmarshal sandbox: %w\", err)\n94: \t}\n95: \n96: \treturn &sandbox, nil\n97: }\n98: \n99: // StoreSandbox creates a new sandbox entry with atomic index updates.\n100: // Validates sandbox is non-nil and has valid ExpiresAt.\n101: // Uses SETNX to prevent overwriting existing keys.\n102: func (s *redisStore) StoreSandbox(ctx context.Context, sandbox *types.SandboxInfo) error {\n103: \tif sandbox == nil {\n104: \t\treturn fmt.Errorf(\"sandbox is nil\")\n105: \t}\n106: \tif sandbox.SessionID == \"\" {\n107: \t\treturn fmt.Errorf(\"sessionID is empty\")\n108: \t}\n109: \tif sandbox.ExpiresAt.IsZero() {\n110: \t\treturn fmt.Errorf(\"expiresAt is zero\")\n111: \t}\n112: \n113: \tkey := s.sessionKey(sandbox.SessionID)\n114: \tdata, err := json.Marshal(sandbox)\n115: \tif err != nil {\n116: \t\treturn fmt.Errorf(\"failed to marshal sandbox: %w\", err)\n117: \t}\n118: \n119: \t// Use pipeline for atomic operations\n120: \tpipe := s.cli.Pipeline()\n121: \tsetCmd := pipe.SetNX(ctx, key, data, 0)\n122: \tzaddExpiryCmd := pipe.ZAdd(ctx, s.expiryIndexKey, redisv9.Z{\n123: \t\tScore:  float64(sandbox.ExpiresAt.Unix()),\n124: \t\tMember: sandbox.SessionID,\n125: \t})\n126: \tzaddActivityCmd := pipe.ZAdd(ctx, s.lastActivityIndexKey, redisv9.Z{\n127: \t\tScore:  float64(time.Now().Unix()),\n128: \t\tMember: sandbox.SessionID,\n129: \t})\n130: \n131: \t_, err = pipe.Exec(ctx)\n132: \tif err != nil {\n133: \t\treturn err\n134: \t}\n135: \n136: \t// Check if SETNX succeeded\n137: \tif !setCmd.Val() {\n138: \t\treturn fmt.Errorf(\"session already exists\")\n139: \t}\n140: \n141: \t// Check ZADD results\n142: \tif zaddExpiryCmd.Err() != nil {\n143: \t\treturn zaddExpiryCmd.Err()\n144: \t}\n145: \tif zaddActivityCmd.Err() != nil {\n146: \t\treturn zaddActivityCmd.Err()\n147: \t}\n148: \n149: \treturn nil\n150: }\n151: \n152: // UpdateSandbox updates an existing sandbox's JSON data.\n153: // Uses SET with XX flag (key must exist).\n154: // Does NOT modify expiry or last-activity indexes.\n155: func (s *redisStore) UpdateSandbox(ctx context.Context, sandbox *types.SandboxInfo) error {\n156: \tif sandbox == nil {\n157: \t\treturn fmt.Errorf(\"sandbox is nil\")\n158: \t}\n159: \tif sandbox.SessionID == \"\" {\n160: \t\treturn fmt.Errorf(\"sessionID is empty\")\n161: \t}\n162: \n163: \tkey := s.sessionKey(sandbox.SessionID)\n164: \tdata, err := json.Marshal(sandbox)\n165: \tif err != nil {\n166: \t\treturn fmt.Errorf(\"failed to marshal sandbox: %w\", err)\n167: \t}\n168: \n169: \t// SET with XX flag - only set if key exists\n170: \tresult, err := s.cli.SetXX(ctx, key, data, 0).Result()\n171: \tif err != nil {\n172: \t\treturn err\n173: \t}\n174: \tif !result {\n175: \t\treturn fmt.Errorf(\"key not exists\")\n176: \t}\n177: \n178: \treturn nil\n179: }\n180: \n181: // DeleteSandboxBySessionID removes a sandbox and its indexes.\n182: // Uses atomic pipeline: DEL + ZREM expiry + ZREM last_activity.\n183: func (s *redisStore) DeleteSandboxBySessionID(ctx context.Context, sessionID string) error {\n184: \tif sessionID == \"\" {\n185: \t\treturn fmt.Errorf(\"sessionID is empty\")\n186: \t}\n187: \n188: \tkey := s.sessionKey(sessionID)\n189: \n190: \tpipe := s.cli.Pipeline()\n191: \tdelCmd := pipe.Del(ctx, key)\n192: \tzremExpiryCmd := pipe.ZRem(ctx, s.expiryIndexKey, sessionID)\n193: \tzremActivityCmd := pipe.ZRem(ctx, s.lastActivityIndexKey, sessionID)\n194: \n195: \t_, err := pipe.Exec(ctx)\n196: \tif err != nil {\n197: \t\treturn err\n198: \t}\n199: \n200: \t// We don't need to check the results - deletion is idempotent\n201: \t_ = delCmd.Val()\n202: \t_ = zremExpiryCmd.Val()\n203: \t_ = zremActivityCmd.Val()\n204: \n205: \treturn nil\n206: }\n207: \n208: // ListExpiredSandboxes returns sessions with ExpiresAt <= before.\n209: // Queries session:expiry ZSET with ZRANGEBYSCORE.\n210: // Returns nil, nil if limit <= 0.\n211: func (s *redisStore) ListExpiredSandboxes(ctx context.Context, before time.Time, limit int64) ([]*types.SandboxInfo, error) {\n212: \tif limit <= 0 {\n213: \t\treturn nil, nil\n214: \t}\n215: \n216: \t// Get expired session IDs from the ZSET\n217: \tmemberArgs := redisv9.ZRangeArgs{\n218: \t\tKey:     s.expiryIndexKey,\n219: \t\tStart:   \"-inf\",\n220: \t\tStop:    float64(before.Unix()),\n221: \t\tByScore: true,\n222: \t\tCount:   limit,\n223: \t}\n224: \n225: \tsessionIDs, err := s.cli.ZRangeArgs(ctx, memberArgs).Result()\n226: \tif err != nil {\n227: \t\treturn nil, err\n228: \t}\n229: \n230: \treturn s.loadSandboxesBySessionIDs(ctx, sessionIDs)\n231: }\n232: \n233: // ListInactiveSandboxes returns sessions with last activity <= before.\n234: // Queries session:last_activity ZSET with ZRANGEBYSCORE.\n235: // Returns nil, nil if limit <= 0.\n236: func (s *redisStore) ListInactiveSandboxes(ctx context.Context, before time.Time, limit int64) ([]*types.SandboxInfo, error) {\n237: \tif limit <= 0 {\n238: \t\treturn nil, nil\n239: \t}\n240: \n241: \t// Get inactive session IDs from the ZSET\n242: \tmemberArgs := redisv9.ZRangeArgs{\n243: \t\tKey:     s.lastActivityIndexKey,\n244: \t\tStart:   \"-inf\",\n245: \t\tStop:    float64(before.Unix()),\n246: \t\tByScore: true,\n247: \t\tCount:   limit,\n248: \t}\n249: \n250: \tsessionIDs, err := s.cli.ZRangeArgs(ctx, memberArgs).Result()\n251: \tif err != nil {\n252: \t\treturn nil, err\n253: \t}\n254: \n255: \treturn s.loadSandboxesBySessionIDs(ctx, sessionIDs)\n256: }\n257: \n258: // loadSandboxesBySessionIDs loads sandbox info for the given session IDs.\n259: // Skips entries where the session key is missing (orphaned ZSET entries).\n260: func (s *redisStore) loadSandboxesBySessionIDs(ctx context.Context, sessionIDs []string) ([]*types.SandboxInfo, error) {\n261: \tif len(sessionIDs) == 0 {\n262: \t\treturn []*types.SandboxInfo{}, nil\n263: \t}\n264: \n265: \t// Build keys for all session IDs\n266: \tkeys := make([]string, len(sessionIDs))\n267: \tfor i, id := range sessionIDs {\n268: \t\tkeys[i] = s.sessionKey(id)\n269: \t}\n270: \n271: \t// Use MGET to fetch all sessions in one call\n272: \tresults, err := s.cli.MGet(ctx, keys...).Result()\n273: \tif err != nil {\n274: \t\treturn nil, err\n275: \t}\n276: \n277: \t// Parse results, skipping nil entries (orphaned ZSET members)\n278: \tsandboxes := make([]*types.SandboxInfo, 0, len(results))\n279: \tfor i, result := range results {\n280: \t\tif result == nil {\n281: \t\t\t// Orphaned ZSET entry - skip\n282: \t\t\tcontinue\n283: \t\t}\n284: \n285: \t\tdata, ok := result.(string)\n286: \t\tif !ok || data == \"\" {\n287: \t\t\t// Invalid data - skip\n288: \t\t\tcontinue\n289: \t\t}\n290: \n291: \t\tvar sandbox types.SandboxInfo\n292: \t\tif err := json.Unmarshal([]byte(data), &sandbox); err != nil {\n293: \t\t\t// Failed to parse - skip this entry but continue\n294: \t\t\tcontinue\n295: \t\t}\n296: \n297: \t\tsandboxes = append(sandboxes, &sandbox)\n298: \t}\n299: \n300: \treturn sandboxes, nil\n301: }\n302: \n303: // UpdateSessionLastActivity updates the last activity timestamp for a session.\n304: // Returns ErrNotFound if session does not exist.\n305: // If at is zero time, uses time.Now().\n306: func (s *redisStore) UpdateSessionLastActivity(ctx context.Context, sessionID string, at time.Time) error {\n307: \tif sessionID == \"\" {\n308: \t\treturn fmt.Errorf(\"sessionID is empty\")\n309: \t}\n310: \n311: \t// Verify session exists before updating\n312: \tkey := s.sessionKey(sessionID)\n313: \texists, err := s.cli.Exists(ctx, key).Result()\n314: \tif err != nil {\n315: \t\treturn err\n316: \t}\n317: \tif exists == 0 {\n318: \t\treturn ErrNotFound\n319: \t}\n320: \n321: \t// Use current time if at is zero\n322: \tif at.IsZero() {\n323: \t\tat = time.Now()\n324: \t}\n325: \n326: \t// Update the activity index\n327: \t_, err = s.cli.ZAdd(ctx, s.lastActivityIndexKey, redisv9.Z{\n328: \t\tScore:  float64(at.Unix()),\n329: \t\tMember: sessionID,\n330: \t}).Result()\n331: \tif err != nil {\n332: \t\treturn err\n333: \t}\n334: \n335: \treturn nil\n336: }\n337: \n338: // Close closes the Redis connection.\n339: func (s *redisStore) Close() error {\n340: \treturn s.cli.Close()\n341: }\n\n(End of file - total 341 lines)\n</content>","metadata":{"preview":"/*\nCopyright 2026 The Volcano Authors.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\npackage store\n\nimport (\n\t\"context\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/store/redis.go","time":{"start":1775865681024,"end":1775865681053}}}}
{"type":"tool_use","timestamp":1775865681057,"sessionID":"ses_286289c44ffeoJBcO7yVHd6sSt","part":{"id":"prt_d79d7cb85001JgsAiK6e7QnKML","messageID":"msg_d79d7a624001s2MdjpxY2UM8k8","sessionID":"ses_286289c44ffeoJBcO7yVHd6sSt","type":"tool","tool":"read","callID":"toolu_functions.read:5","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/store/valkey.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/store/valkey.go</path>\n<type>file</type>\n<content>\n1: /*\n2: Copyright 2026 The Volcano Authors.\n3: \n4: Licensed under the Apache License, Version 2.0 (the \"License\");\n5: you may not use this file except in compliance with the License.\n6: You may obtain a copy of the License at\n7: \n8:     http://www.apache.org/licenses/LICENSE-2.0\n9: \n10: Unless required by applicable law or agreed to in writing, software\n11: distributed under the License is distributed on an \"AS IS\" BASIS,\n12: WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n13: See the License for the specific language governing permissions and\n14: limitations under the License.\n15: */\n16: \n17: package store\n18: \n19: import (\n20: \t\"context\"\n21: \t\"encoding/json\"\n22: \t\"fmt\"\n23: \t\"time\"\n24: \n25: \t\"github.com/valkey-io/valkey-go\"\n26: \t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n27: )\n28: \n29: // valkeyStore implements Store interface using Valkey backend.\n30: type valkeyStore struct {\n31: \tcli                  valkey.Client\n32: \tsessionPrefix        string\n33: \texpiryIndexKey       string\n34: \tlastActivityIndexKey string\n35: }\n36: \n37: // newValkeyStore creates a new Valkey-backed Store instance.\n38: func newValkeyStore() (Store, error) {\n39: \topts, err := makeValkeyOptions()\n40: \tif err != nil {\n41: \t\treturn nil, err\n42: \t}\n43: \n44: \tclientOption := valkey.ClientOption{\n45: \t\tInitAddress:       opts.InitAddress,\n46: \t\tDisableCache:      opts.DisableCache,\n47: \t\tForceSingleClient: opts.ForceSingleClient,\n48: \t}\n49: \n50: \t// Configure password if provided\n51: \tif opts.Password != \"\" {\n52: \t\tclientOption.Password = opts.Password\n53: \t}\n54: \n55: \tclient, err := valkey.NewClient(clientOption)\n56: \tif err != nil {\n57: \t\treturn nil, fmt.Errorf(\"failed to create valkey client: %w\", err)\n58: \t}\n59: \n60: \treturn &valkeyStore{\n61: \t\tcli:                  client,\n62: \t\tsessionPrefix:        sessionPrefix,\n63: \t\texpiryIndexKey:       expiryIndexKey,\n64: \t\tlastActivityIndexKey: lastActivityIndexKey,\n65: \t}, nil\n66: }\n67: \n68: // sessionKey constructs the Valkey key for a session.\n69: func (s *valkeyStore) sessionKey(sessionID string) string {\n70: \treturn s.sessionPrefix + sessionID\n71: }\n72: \n73: // Ping verifies connectivity to the Valkey backend.\n74: // Returns nil on success, error on failure.\n75: func (s *valkeyStore) Ping(ctx context.Context) error {\n76: \tresult := s.cli.Do(ctx, s.cli.B().Ping().Build())\n77: \tif result.Error() != nil {\n78: \t\treturn result.Error()\n79: \t}\n80: \n81: \tpong, err := result.ToString()\n82: \tif err != nil {\n83: \t\treturn fmt.Errorf(\"failed to parse ping response: %w\", err)\n84: \t}\n85: \tif pong != \"PONG\" {\n86: \t\treturn fmt.Errorf(\"unexpected ping response: %s\", pong)\n87: \t}\n88: \treturn nil\n89: }\n90: \n91: // GetSandboxBySessionID retrieves sandbox info by session ID.\n92: // Returns ErrNotFound if the session does not exist.\n93: func (s *valkeyStore) GetSandboxBySessionID(ctx context.Context, sessionID string) (*types.SandboxInfo, error) {\n94: \tif sessionID == \"\" {\n95: \t\treturn nil, fmt.Errorf(\"sessionID is empty\")\n96: \t}\n97: \n98: \tkey := s.sessionKey(sessionID)\n99: \tresult := s.cli.Do(ctx, s.cli.B().Get().Key(key).Build())\n100: \tif result.Error() != nil {\n101: \t\tif valkey.IsValkeyNil(result.Error()) {\n102: \t\t\treturn nil, ErrNotFound\n103: \t\t}\n104: \t\treturn nil, result.Error()\n105: \t}\n106: \n107: \tdata, err := result.ToString()\n108: \tif err != nil {\n109: \t\treturn nil, fmt.Errorf(\"failed to get session data: %w\", err)\n110: \t}\n111: \n112: \tvar sandbox types.SandboxInfo\n113: \tif err := json.Unmarshal([]byte(data), &sandbox); err != nil {\n114: \t\treturn nil, fmt.Errorf(\"failed to unmarshal sandbox: %w\", err)\n115: \t}\n116: \n117: \treturn &sandbox, nil\n118: }\n119: \n120: // StoreSandbox creates a new sandbox entry with atomic index updates.\n121: // Validates sandbox is non-nil and has valid ExpiresAt.\n122: // Uses SETNX to prevent overwriting existing keys.\n123: func (s *valkeyStore) StoreSandbox(ctx context.Context, sandbox *types.SandboxInfo) error {\n124: \tif sandbox == nil {\n125: \t\treturn fmt.Errorf(\"sandbox is nil\")\n126: \t}\n127: \tif sandbox.SessionID == \"\" {\n128: \t\treturn fmt.Errorf(\"sessionID is empty\")\n129: \t}\n130: \tif sandbox.ExpiresAt.IsZero() {\n131: \t\treturn fmt.Errorf(\"expiresAt is zero\")\n132: \t}\n133: \n134: \tkey := s.sessionKey(sandbox.SessionID)\n135: \tdata, err := json.Marshal(sandbox)\n136: \tif err != nil {\n137: \t\treturn fmt.Errorf(\"failed to marshal sandbox: %w\", err)\n138: \t}\n139: \n140: \tnow := time.Now().Unix()\n141: \n142: \t// Use DoMulti for atomic operations\n143: \tresults := s.cli.DoMulti(ctx,\n144: \t\ts.cli.B().Set().Key(key).Value(data).Nx().Build(),\n145: \t\ts.cli.B().Zadd().Key(s.expiryIndexKey).ScoreMember().\n146: \t\t\tScoreMember(float64(sandbox.ExpiresAt.Unix()), sandbox.SessionID).Build(),\n147: \t\ts.cli.B().Zadd().Key(s.lastActivityIndexKey).ScoreMember().\n148: \t\t\tScoreMember(float64(now), sandbox.SessionID).Build(),\n149: \t)\n150: \n151: \t// Check for errors in any of the results\n152: \tfor i, r := range results {\n153: \t\tif r.Error() != nil {\n154: \t\t\t// Clean up already executed commands on error (best effort)\n155: \t\t\treturn r.Error()\n156: \t\t}\n157: \n158: \t\t// First command is SET NX - check if it succeeded\n159: \t\tif i == 0 {\n160: \t\t\tsetResult, err := r.ToString()\n161: \t\t\tif err != nil {\n162: \t\t\t\treturn fmt.Errorf(\"session already exists\")\n163: \t\t\t}\n164: \t\t\tif setResult != \"OK\" {\n165: \t\t\t\treturn fmt.Errorf(\"session already exists\")\n166: \t\t\t}\n167: \t\t}\n168: \t}\n169: \n170: \treturn nil\n171: }\n172: \n173: // UpdateSandbox updates an existing sandbox's JSON data.\n174: // Uses SET with XX flag (key must exist).\n175: // Does NOT modify expiry or last-activity indexes.\n176: func (s *valkeyStore) UpdateSandbox(ctx context.Context, sandbox *types.SandboxInfo) error {\n177: \tif sandbox == nil {\n178: \t\treturn fmt.Errorf(\"sandbox is nil\")\n179: \t}\n180: \tif sandbox.SessionID == \"\" {\n181: \t\treturn fmt.Errorf(\"sessionID is empty\")\n182: \t}\n183: \n184: \tkey := s.sessionKey(sandbox.SessionID)\n185: \tdata, err := json.Marshal(sandbox)\n186: \tif err != nil {\n187: \t\treturn fmt.Errorf(\"failed to marshal sandbox: %w\", err)\n188: \t}\n189: \n190: \t// SET with XX flag - only set if key exists\n191: \tresult := s.cli.Do(ctx, s.cli.B().Set().Key(key).Value(data).Xx().Build())\n192: \tif result.Error() != nil {\n193: \t\treturn result.Error()\n194: \t}\n195: \n196: \t// Check if the operation succeeded (XX returns nil/empty if key doesn't exist)\n197: \tstrResult, err := result.ToString()\n198: \tif err != nil {\n199: \t\treturn fmt.Errorf(\"key not exists\")\n200: \t}\n201: \tif strResult != \"OK\" {\n202: \t\treturn fmt.Errorf(\"key not exists\")\n203: \t}\n204: \n205: \treturn nil\n206: }\n207: \n208: // DeleteSandboxBySessionID removes a sandbox and its indexes.\n209: // Uses atomic pipeline: DEL + ZREM expiry + ZREM last_activity.\n210: func (s *valkeyStore) DeleteSandboxBySessionID(ctx context.Context, sessionID string) error {\n211: \tif sessionID == \"\" {\n212: \t\treturn fmt.Errorf(\"sessionID is empty\")\n213: \t}\n214: \n215: \tkey := s.sessionKey(sessionID)\n216: \n217: \t// Use DoMulti for atomic operations\n218: \tresults := s.cli.DoMulti(ctx,\n219: \t\ts.cli.B().Del().Key(key).Build(),\n220: \t\ts.cli.B().Zrem().Key(s.expiryIndexKey).Member(sessionID).Build(),\n221: \t\ts.cli.B().Zrem().Key(s.lastActivityIndexKey).Member(sessionID).Build(),\n222: \t)\n223: \n224: \t// Check for errors\n225: \tfor _, r := range results {\n226: \t\tif r.Error() != nil {\n227: \t\t\treturn r.Error()\n228: \t\t}\n229: \t}\n230: \n231: \treturn nil\n232: }\n233: \n234: // ListExpiredSandboxes returns sessions with ExpiresAt <= before.\n235: // Queries session:expiry ZSET with ZRANGEBYSCORE.\n236: // Returns nil, nil if limit <= 0.\n237: func (s *valkeyStore) ListExpiredSandboxes(ctx context.Context, before time.Time, limit int64) ([]*types.SandboxInfo, error) {\n238: \tif limit <= 0 {\n239: \t\treturn nil, nil\n240: \t}\n241: \n242: \t// Get expired session IDs from the ZSET\n243: \tzrangeResult := s.cli.Do(ctx, s.cli.B().Zrangebyscore().Key(s.expiryIndexKey).\n244: \t\tMin(\"-inf\").Max(fmt.Sprintf(\"%d\", before.Unix())).Limit(0, limit).Build())\n245: \tif zrangeResult.Error() != nil {\n246: \t\treturn nil, zrangeResult.Error()\n247: \t}\n248: \n249: \tsessionIDs, err := zrangeResult.ToStringSlice()\n250: \tif err != nil {\n251: \t\treturn nil, fmt.Errorf(\"failed to parse zrange result: %w\", err)\n252: \t}\n253: \n254: \treturn s.loadSandboxesBySessionIDs(ctx, sessionIDs)\n255: }\n256: \n257: // ListInactiveSandboxes returns sessions with last activity <= before.\n258: // Queries session:last_activity ZSET with ZRANGEBYSCORE.\n259: // Returns nil, nil if limit <= 0.\n260: func (s *valkeyStore) ListInactiveSandboxes(ctx context.Context, before time.Time, limit int64) ([]*types.SandboxInfo, error) {\n261: \tif limit <= 0 {\n262: \t\treturn nil, nil\n263: \t}\n264: \n265: \t// Get inactive session IDs from the ZSET\n266: \tzrangeResult := s.cli.Do(ctx, s.cli.B().Zrangebyscore().Key(s.lastActivityIndexKey).\n267: \t\tMin(\"-inf\").Max(fmt.Sprintf(\"%d\", before.Unix())).Limit(0, limit).Build())\n268: \tif zrangeResult.Error() != nil {\n269: \t\treturn nil, zrangeResult.Error()\n270: \t}\n271: \n272: \tsessionIDs, err := zrangeResult.ToStringSlice()\n273: \tif err != nil {\n274: \t\treturn nil, fmt.Errorf(\"failed to parse zrange result: %w\", err)\n275: \t}\n276: \n277: \treturn s.loadSandboxesBySessionIDs(ctx, sessionIDs)\n278: }\n279: \n280: // loadSandboxesBySessionIDs loads sandbox info for the given session IDs.\n281: // Skips entries where the session key is missing (orphaned ZSET entries).\n282: func (s *valkeyStore) loadSandboxesBySessionIDs(ctx context.Context, sessionIDs []string) ([]*types.SandboxInfo, error) {\n283: \tif len(sessionIDs) == 0 {\n284: \t\treturn []*types.SandboxInfo{}, nil\n285: \t}\n286: \n287: \t// Build keys for all session IDs\n288: \tkeys := make([]string, len(sessionIDs))\n289: \tfor i, id := range sessionIDs {\n290: \t\tkeys[i] = s.sessionKey(id)\n291: \t}\n292: \n293: \t// Use MGET to fetch all sessions in one call\n294: \tmgetResult := s.cli.Do(ctx, s.cli.B().Mget().Key(keys...).Build())\n295: \tif mgetResult.Error() != nil {\n296: \t\treturn nil, mgetResult.Error()\n297: \t}\n298: \n299: \tresults, err := mgetResult.ToStringSlice()\n300: \tif err != nil {\n301: \t\treturn nil, fmt.Errorf(\"failed to parse mget result: %w\", err)\n302: \t}\n303: \n304: \t// Parse results, skipping empty entries (orphaned ZSET members)\n305: \tsandboxes := make([]*types.SandboxInfo, 0, len(results))\n306: \tfor i, data := range results {\n307: \t\tif data == \"\" {\n308: \t\t\t// Orphaned ZSET entry - skip\n309: \t\t\tcontinue\n310: \t\t}\n311: \n312: \t\t// Check if this is a nil/empty response (valkey returns empty string for missing keys)\n313: \t\tif len(data) == 0 {\n314: \t\t\tcontinue\n315: \t\t}\n316: \n317: \t\tvar sandbox types.SandboxInfo\n318: \t\tif err := json.Unmarshal([]byte(data), &sandbox); err != nil {\n319: \t\t\t// Failed to parse - skip this entry but continue\n320: \t\t\tcontinue\n321: \t\t}\n322: \n323: \t\tsandboxes = append(sandboxes, &sandbox)\n324: \t}\n325: \n326: \treturn sandboxes, nil\n327: }\n328: \n329: // UpdateSessionLastActivity updates the last activity timestamp for a session.\n330: // Returns ErrNotFound if session does not exist.\n331: // If at is zero time, uses time.Now().\n332: func (s *valkeyStore) UpdateSessionLastActivity(ctx context.Context, sessionID string, at time.Time) error {\n333: \tif sessionID == \"\" {\n334: \t\treturn fmt.Errorf(\"sessionID is empty\")\n335: \t}\n336: \n337: \t// Verify session exists before updating\n338: \tkey := s.sessionKey(sessionID)\n339: \texistsResult := s.cli.Do(ctx, s.cli.B().Exists().Key(key).Build())\n340: \tif existsResult.Error() != nil {\n341: \t\treturn existsResult.Error()\n342: \t}\n343: \n344: \texists, err := existsResult.ToInt64()\n345: \tif err != nil {\n346: \t\treturn fmt.Errorf(\"failed to check session existence: %w\", err)\n347: \t}\n348: \tif exists == 0 {\n349: \t\treturn ErrNotFound\n350: \t}\n351: \n352: \t// Use current time if at is zero\n353: \tif at.IsZero() {\n354: \t\tat = time.Now()\n355: \t}\n356: \n357: \t// Update the activity index\n358: \tzaddResult := s.cli.Do(ctx, s.cli.B().Zadd().Key(s.lastActivityIndexKey).ScoreMember().\n359: \t\tScoreMember(float64(at.Unix()), sessionID).Build())\n360: \tif zaddResult.Error() != nil {\n361: \t\treturn zaddResult.Error()\n362: \t}\n363: \n364: \treturn nil\n365: }\n366: \n367: // Close closes the Valkey connection.\n368: func (s *valkeyStore) Close() error {\n369: \ts.cli.Close()\n370: \treturn nil\n371: }\n\n(End of file - total 371 lines)\n</content>","metadata":{"preview":"/*\nCopyright 2026 The Volcano Authors.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\npackage store\n\nimport (\n\t\"context\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/store/valkey.go","time":{"start":1775865681026,"end":1775865681055}}}}
