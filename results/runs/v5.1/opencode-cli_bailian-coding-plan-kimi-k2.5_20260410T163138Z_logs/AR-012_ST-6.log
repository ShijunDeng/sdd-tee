{"type":"tool_use","timestamp":1775865903650,"sessionID":"ses_286289c44ffeoJBcO7yVHd6sSt","part":{"id":"prt_d79db3076001zXn10AlGa73WGF","messageID":"msg_d79db13df001hKlQVefhnjCV23","sessionID":"ses_286289c44ffeoJBcO7yVHd6sSt","type":"tool","tool":"read","callID":"toolu_functions.read:16","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/apis/runtime/v1alpha1/agentruntime_types.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/apis/runtime/v1alpha1/agentruntime_types.go</path>\n<type>file</type>\n<content>\n1: /*\n2: Copyright 2026 The Volcano Authors.\n3: \n4: Licensed under the Apache License, Version 2.0 (the \"License\");\n5: you may not use this file except in compliance with the License.\n6: You may obtain a copy of the License at\n7: \n8:     http://www.apache.org/licenses/LICENSE-2.0\n9: \n10: Unless required by applicable law or agreed to in writing, software\n11: distributed under the License is distributed on an \"AS IS\" BASIS,\n12: WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n13: See the License for the specific language governing permissions and\n14: limitations under the License.\n15: */\n16: \n17: package v1alpha1\n18: \n19: import (\n20: \tcorev1 \"k8s.io/api/core/v1\"\n21: \tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n22: )\n23: \n24: // AgentRuntimePhase represents the current phase of an AgentRuntime.\n25: // +kubebuilder:validation:Enum=Pending;Running;Succeeded;Failed;Unknown\n26: // +kubebuilder:validation:Type=string\n27: type AgentRuntimePhase string\n28: \n29: const (\n30: \t// AgentRuntimePhasePending indicates the sandbox is being created.\n31: \tAgentRuntimePhasePending AgentRuntimePhase = \"Pending\"\n32: \n33: \t// AgentRuntimePhaseRunning indicates the sandbox is active and running.\n34: \tAgentRuntimePhaseRunning AgentRuntimePhase = \"Running\"\n35: \n36: \t// AgentRuntimePhaseSucceeded indicates the sandbox completed successfully.\n37: \tAgentRuntimePhaseSucceeded AgentRuntimePhase = \"Succeeded\"\n38: \n39: \t// AgentRuntimePhaseFailed indicates the sandbox failed.\n40: \tAgentRuntimePhaseFailed AgentRuntimePhase = \"Failed\"\n41: \n42: \t// AgentRuntimePhaseUnknown indicates the sandbox state is unknown.\n43: \tAgentRuntimePhaseUnknown AgentRuntimePhase = \"Unknown\"\n44: )\n45: \n46: // AgentRuntimeConditionType represents a condition type for AgentRuntime.\n47: // +kubebuilder:validation:Enum=Ready;SandboxCreated;SandboxReady;Failed\n48: // +kubebuilder:validation:Type=string\n49: type AgentRuntimeConditionType string\n50: \n51: const (\n52: \t// AgentRuntimeConditionReady indicates the AgentRuntime is ready to accept requests.\n53: \tAgentRuntimeConditionReady AgentRuntimeConditionType = \"Ready\"\n54: \n55: \t// AgentRuntimeConditionSandboxCreated indicates the sandbox has been created.\n56: \tAgentRuntimeConditionSandboxCreated AgentRuntimeConditionType = \"SandboxCreated\"\n57: \n58: \t// AgentRuntimeConditionSandboxReady indicates the sandbox is ready for use.\n59: \tAgentRuntimeConditionSandboxReady AgentRuntimeConditionType = \"SandboxReady\"\n60: \n61: \t// AgentRuntimeConditionFailed indicates the AgentRuntime has failed.\n62: \tAgentRuntimeConditionFailed AgentRuntimeConditionType = \"Failed\"\n63: )\n64: \n65: // AgentRuntimeSpec defines the desired state of AgentRuntime.\n66: // This specification describes the configuration for a sandbox instance\n67: // that will run an AI agent.\n68: type AgentRuntimeSpec struct {\n69: \t// Image is the container image to use for the sandbox.\n70: \t// This field is required and must be a valid container image reference.\n71: \t// +kubebuilder:validation:Required\n72: \t// +kubebuilder:validation:MinLength=1\n73: \tImage string `json:\"image\"`\n74: \n75: \t// Resources defines the compute resources (CPU, memory) for the sandbox.\n76: \t// If not specified, default resource limits will be applied.\n77: \t// +kubebuilder:validation:Optional\n78: \tResources *corev1.ResourceRequirements `json:\"resources,omitempty\"`\n79: \n80: \t// Env defines environment variables to set in the sandbox container.\n81: \t// These variables will be available to the running agent.\n82: \t// +kubebuilder:validation:Optional\n83: \t// +listType=map\n84: \t// +listMapKey=name\n85: \tEnv []corev1.EnvVar `json:\"env,omitempty\"`\n86: \n87: \t// Command overrides the default container entrypoint.\n88: \t// If not specified, the image's default entrypoint will be used.\n89: \t// +kubebuilder:validation:Optional\n90: \tCommand []string `json:\"command,omitempty\"`\n91: \n92: \t// Args provides arguments to the command or the default entrypoint.\n93: \t// +kubebuilder:validation:Optional\n94: \tArgs []string `json:\"args,omitempty\"`\n95: \n96: \t// WorkingDir specifies the working directory for the container.\n97: \t// If not specified, the container's default working directory will be used.\n98: \t// +kubebuilder:validation:Optional\n99: \tWorkingDir string `json:\"workingDir,omitempty\"`\n100: \n101: \t// Ports defines the ports to expose from the sandbox container.\n102: \t// +kubebuilder:validation:Optional\n103: \t// +listType=map\n104: \t// +listMapKey=containerPort\n105: \tPorts []corev1.ContainerPort `json:\"ports,omitempty\"`\n106: \n107: \t// VolumeMounts defines volumes to mount into the sandbox container.\n108: \t// +kubebuilder:validation:Optional\n109: \t// +listType=map\n110: \t// +listMapKey=name\n111: \tVolumeMounts []corev1.VolumeMount `json:\"volumeMounts,omitempty\"`\n112: \n113: \t// Volumes defines the volumes that can be mounted by the sandbox.\n114: \t// +kubebuilder:validation:Optional\n115: \t// +listType=map\n116: \t// +listMapKey=name\n117: \tVolumes []corev1.Volume `json:\"volumes,omitempty\"`\n118: \n119: \t// ServiceAccountName specifies the service account to use for the sandbox pod.\n120: \t// If not specified, the default service account will be used.\n121: \t// +kubebuilder:validation:Optional\n122: \tServiceAccountName string `json:\"serviceAccountName,omitempty\"`\n123: \n124: \t// NodeSelector specifies node labels for pod scheduling.\n125: \t// The pod will only be scheduled on nodes matching these labels.\n126: \t// +kubebuilder:validation:Optional\n127: \t// +mapType=atomic\n128: \tNodeSelector map[string]string `json:\"nodeSelector,omitempty\"`\n129: \n130: \t// Tolerations allow the pod to be scheduled on nodes with matching taints.\n131: \t// +kubebuilder:validation:Optional\n132: \t// +listType=atomic\n133: \tTolerations []corev1.Toleration `json:\"tolerations,omitempty\"`\n134: \n135: \t// Affinity defines the scheduling constraints for the pod.\n136: \t// +kubebuilder:validation:Optional\n137: \tAffinity *corev1.Affinity `json:\"affinity,omitempty\"`\n138: \n139: \t// TTLSecondsAfterFinished specifies the time to live (in seconds) after\n140: \t// the sandbox has finished (succeeded or failed). The sandbox will be\n141: \t// automatically deleted after this time.\n142: \t// If not specified, the sandbox will not be automatically deleted.\n143: \t// +kubebuilder:validation:Optional\n144: \t// +kubebuilder:validation:Minimum=0\n145: \tTTLSecondsAfterFinished *int32 `json:\"ttlSecondsAfterFinished,omitempty\"`\n146: \n147: \t// IdleTimeoutSeconds specifies the maximum time (in seconds) the sandbox\n148: \t// can be idle before being terminated. If not specified, no idle timeout\n149: \t// is enforced.\n150: \t// +kubebuilder:validation:Optional\n151: \t// +kubebuilder:validation:Minimum=1\n152: \tIdleTimeoutSeconds *int32 `json:\"idleTimeoutSeconds,omitempty\"`\n153: \n154: \t// MaxLifetimeSeconds specifies the maximum lifetime (in seconds) of the sandbox.\n155: \t// The sandbox will be terminated after this duration regardless of activity.\n156: \t// If not specified, no maximum lifetime is enforced.\n157: \t// +kubebuilder:validation:Optional\n158: \t// +kubebuilder:validation:Minimum=1\n159: \tMaxLifetimeSeconds *int32 `json:\"maxLifetimeSeconds,omitempty\"`\n160: }\n161: \n162: // AgentRuntimeStatus defines the observed state of AgentRuntime.\n163: // This status is updated by the controller to reflect the current\n164: // state of the sandbox instance.\n165: type AgentRuntimeStatus struct {\n166: \t// Phase represents the current phase of the AgentRuntime.\n167: \t// Possible values: Pending, Running, Succeeded, Failed, Unknown.\n168: \t// +kubebuilder:validation:Optional\n169: \tPhase AgentRuntimePhase `json:\"phase,omitempty\"`\n170: \n171: \t// Conditions represents the latest available observations of the AgentRuntime's state.\n172: \t// +kubebuilder:validation:Optional\n173: \t// +listType=map\n174: \t// +listMapKey=type\n175: \t// +patchMergeKey=type\n176: \t// +patchStrategy=merge\n177: \tConditions []AgentRuntimeCondition `json:\"conditions,omitempty\"`\n178: \n179: \t// SandboxID is the unique identifier of the created sandbox pod.\n180: \t// This is set once the sandbox pod has been successfully created.\n181: \t// +kubebuilder:validation:Optional\n182: \tSandboxID string `json:\"sandboxId,omitempty\"`\n183: \n184: \t// PodName is the name of the pod running the sandbox.\n185: \t// +kubebuilder:validation:Optional\n186: \tPodName string `json:\"podName,omitempty\"`\n187: \n188: \t// PodIP is the IP address assigned to the sandbox pod.\n189: \t// +kubebuilder:validation:Optional\n190: \tPodIP string `json:\"podIP,omitempty\"`\n191: \n192: \t// StartTime is the time when the sandbox was started.\n193: \t// +kubebuilder:validation:Optional\n194: \tStartTime *metav1.Time `json:\"startTime,omitempty\"`\n195: \n196: \t// CompletionTime is the time when the sandbox completed (succeeded or failed).\n197: \t// +kubebuilder:validation:Optional\n198: \tCompletionTime *metav1.Time `json:\"completionTime,omitempty\"`\n199: \n200: \t// LastActivityTime is the time of the last activity in the sandbox.\n201: \t// Used for idle timeout tracking.\n202: \t// +kubebuilder:validation:Optional\n203: \tLastActivityTime *metav1.Time `json:\"lastActivityTime,omitempty\"`\n204: \n205: \t// Message provides a human-readable description of the current status.\n206: \t// This may contain error messages or other status information.\n207: \t// +kubebuilder:validation:Optional\n208: \tMessage string `json:\"message,omitempty\"`\n209: \n210: \t// Reason provides a brief reason for the current phase.\n211: \t// This is typically a CamelCase string indicating why the phase is set.\n212: \t// +kubebuilder:validation:Optional\n213: \tReason string `json:\"reason,omitempty\"`\n214: \n215: \t// ObservedGeneration is the most recent generation observed by the controller.\n216: \t// This is used to determine if the spec has been processed.\n217: \t// +kubebuilder:validation:Optional\n218: \t// +kubebuilder:validation:Minimum=0\n219: \tObservedGeneration int64 `json:\"observedGeneration,omitempty\"`\n220: }\n221: \n222: // AgentRuntimeCondition represents a condition of an AgentRuntime.\n223: type AgentRuntimeCondition struct {\n224: \t// Type is the type of the condition.\n225: \t// +kubebuilder:validation:Required\n226: \tType AgentRuntimeConditionType `json:\"type\"`\n227: \n228: \t// Status is the status of the condition (True, False, Unknown).\n229: \t// +kubebuilder:validation:Required\n230: \t// +kubebuilder:validation:Enum=True;False;Unknown\n231: \tStatus corev1.ConditionStatus `json:\"status\"`\n232: \n233: \t// LastTransitionTime is the last time the condition transitioned.\n234: \t// +kubebuilder:validation:Optional\n235: \tLastTransitionTime metav1.Time `json:\"lastTransitionTime,omitempty\"`\n236: \n237: \t// Reason is a brief reason for the condition's last transition.\n238: \t// +kubebuilder:validation:Optional\n239: \tReason string `json:\"reason,omitempty\"`\n240: \n241: \t// Message is a human-readable message indicating details about the transition.\n242: \t// +kubebuilder:validation:Optional\n243: \tMessage string `json:\"message,omitempty\"`\n244: }\n245: \n246: // +genclient\n247: // +genclient:noStatus\n248: // +k8s:deepcopy-gen:interfaces=k8s.io/apimachinery/pkg/runtime.Object\n249: // +kubebuilder:object:root=true\n250: // +kubebuilder:resource:path=agentruntimes,shortName=ar;ars,singular=agentruntime,categories={agentcube,all}\n251: // +kubebuilder:subresource:status\n252: // +kubebuilder:printcolumn:name=\"Phase\",type=string,JSONPath=`.status.phase`,description=\"Current phase of the agent runtime\"\n253: // +kubebuilder:printcolumn:name=\"Sandbox\",type=string,JSONPath=`.status.sandboxId`,description=\"ID of the sandbox pod\"\n254: // +kubebuilder:printcolumn:name=\"Age\",type=date,JSONPath=`.metadata.creationTimestamp`,description=\"Time since creation\"\n255: // +kubebuilder:printcolumn:name=\"Message\",type=string,JSONPath=`.status.message`,priority=1\n256: \n257: // AgentRuntime is the Schema for the agentruntimes API.\n258: // An AgentRuntime represents a sandbox instance for running AI agents.\n259: // The controller creates and manages the lifecycle of the underlying\n260: // sandbox pod based on this resource.\n261: type AgentRuntime struct {\n262: \tmetav1.TypeMeta   `json:\",inline\"`\n263: \tmetav1.ObjectMeta `json:\"metadata,omitempty\"`\n264: \n265: \t// Spec defines the desired state of the AgentRuntime.\n266: \t// +kubebuilder:validation:Required\n267: \tSpec AgentRuntimeSpec `json:\"spec,omitempty\"`\n268: \n269: \t// Status defines the observed state of the AgentRuntime.\n270: \t// +kubebuilder:validation:Optional\n271: \tStatus AgentRuntimeStatus `json:\"status,omitempty\"`\n272: }\n273: \n274: // +k8s:deepcopy-gen:interfaces=k8s.io/apimachinery/pkg/runtime.Object\n275: // +kubebuilder:object:root=true\n276: \n277: // AgentRuntimeList contains a list of AgentRuntime resources.\n278: type AgentRuntimeList struct {\n279: \tmetav1.TypeMeta `json:\",inline\"`\n280: \tmetav1.ListMeta `json:\"metadata,omitempty\"`\n281: \n282: \t// Items is the list of AgentRuntime resources.\n283: \t// +kubebuilder:validation:Required\n284: \tItems []AgentRuntime `json:\"items\"`\n285: }\n\n(End of file - total 285 lines)\n</content>","metadata":{"preview":"/*\nCopyright 2026 The Volcano Authors.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\npackage v1alpha1\n\nimport (\n\tcorev1 \"k8s.io/api/core/v1\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/apis/runtime/v1alpha1/agentruntime_types.go","time":{"start":1775865903619,"end":1775865903649}}}}
{"type":"tool_use","timestamp":1775865903653,"sessionID":"ses_286289c44ffeoJBcO7yVHd6sSt","part":{"id":"prt_d79db3537001iQMFCv3Cx2ncLP","messageID":"msg_d79db13df001hKlQVefhnjCV23","sessionID":"ses_286289c44ffeoJBcO7yVHd6sSt","type":"tool","tool":"read","callID":"toolu_functions.read:17","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/apis/runtime/v1alpha1/codeinterpreter_types.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/apis/runtime/v1alpha1/codeinterpreter_types.go</path>\n<type>file</type>\n<content>\n1: /*\n2: Copyright 2026 The Volcano Authors.\n3: \n4: Licensed under the Apache License, Version 2.0 (the \"License\");\n5: you may not use this file except in compliance with the License.\n6: You may obtain a copy of the License at\n7: \n8:     http://www.apache.org/licenses/LICENSE-2.0\n9: \n10: Unless required by applicable law or agreed to in writing, software\n11: distributed under the License is distributed on an \"AS IS\" BASIS,\n12: WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n13: See the License for the specific language governing permissions and\n14: limitations under the License.\n15: */\n16: \n17: package v1alpha1\n18: \n19: import (\n20: \tcorev1 \"k8s.io/api/core/v1\"\n21: \tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n22: )\n23: \n24: // ProtocolType represents the protocol for a target port.\n25: // +kubebuilder:validation:Enum=HTTP;HTTPS\n26: // +kubebuilder:validation:Type=string\n27: type ProtocolType string\n28: \n29: const (\n30: \t// ProtocolHTTP represents the HTTP protocol.\n31: \tProtocolHTTP ProtocolType = \"HTTP\"\n32: \n33: \t// ProtocolHTTPS represents the HTTPS protocol.\n34: \tProtocolHTTPS ProtocolType = \"HTTPS\"\n35: )\n36: \n37: // AuthModeType represents the authentication mode for the CodeInterpreter.\n38: // +kubebuilder:validation:Enum=picod;none\n39: // +kubebuilder:validation:Type=string\n40: type AuthModeType string\n41: \n42: const (\n43: \t// AuthModePicoD represents authentication using PicoD.\n44: \tAuthModePicoD AuthModeType = \"picod\"\n45: \n46: \t// AuthModeNone represents no authentication.\n47: \tAuthModeNone AuthModeType = \"none\"\n48: )\n49: \n50: // TargetPort defines a port to expose from the sandbox container.\n51: // This is used to configure entry points for accessing the sandbox.\n52: type TargetPort struct {\n53: \t// PathPrefix is an optional URL path prefix for this port.\n54: \t// +kubebuilder:validation:Optional\n55: \tPathPrefix string `json:\"pathPrefix,omitempty\"`\n56: \n57: \t// Name is an optional name for this port.\n58: \t// +kubebuilder:validation:Optional\n59: \tName string `json:\"name,omitempty\"`\n60: \n61: \t// Port is the port number to expose.\n62: \t// This field is required.\n63: \t// +kubebuilder:validation:Required\n64: \t// +kubebuilder:validation:Minimum=1\n65: \t// +kubebuilder:validation:Maximum=65535\n66: \tPort uint32 `json:\"port\"`\n67: \n68: \t// Protocol is the protocol for this port.\n69: \t// Defaults to HTTP if not specified.\n70: \t// +kubebuilder:validation:Optional\n71: \t// +kubebuilder:default=\"HTTP\"\n72: \tProtocol ProtocolType `json:\"protocol,omitempty\"`\n73: }\n74: \n75: // CodeInterpreterSandboxTemplate defines the template for creating a CodeInterpreter sandbox.\n76: // It contains the Pod specification and optional metadata.\n77: type CodeInterpreterSandboxTemplate struct {\n78: \t// Labels are optional labels to apply to the sandbox pod.\n79: \t// +kubebuilder:validation:Optional\n80: \t// +mapType=atomic\n81: \tLabels map[string]string `json:\"labels,omitempty\"`\n82: \n83: \t// Annotations are optional annotations to apply to the sandbox pod.\n84: \t// +kubebuilder:validation:Optional\n85: \t// +mapType=atomic\n86: \tAnnotations map[string]string `json:\"annotations,omitempty\"`\n87: \n88: \t// Spec is the Pod specification for the sandbox.\n89: \t// This field is required.\n90: \t// +kubebuilder:validation:Required\n91: \tSpec corev1.PodSpec `json:\"spec\"`\n92: }\n93: \n94: // CodeInterpreterSpec defines the desired state of CodeInterpreter.\n95: // This specification describes the configuration for a code interpreter sandbox instance\n96: type CodeInterpreterSpec struct {\n97: \t// Ports defines the ports to expose from the sandbox container.\n98: \t// +kubebuilder:validation:Optional\n99: \t// +listType=map\n100: \t// +listMapKey=port\n101: \tPorts []TargetPort `json:\"ports,omitempty\"`\n102: \n103: \t// Template is the sandbox template containing the pod specification.\n104: \t// This field is required.\n105: \t// +kubebuilder:validation:Required\n106: \tTemplate *CodeInterpreterSandboxTemplate `json:\"template\"`\n107: \n108: \t// SessionTimeout specifies the session timeout duration.\n109: \t// Defaults to \"15m\" if not specified.\n110: \t// +kubebuilder:validation:Optional\n111: \t// +kubebuilder:default=\"15m\"\n112: \tSessionTimeout *metav1.Duration `json:\"sessionTimeout,omitempty\"`\n113: \n114: \t// MaxSessionDuration specifies the maximum session duration.\n115: \t// Defaults to \"8h\" if not specified.\n116: \t// +kubebuilder:validation:Optional\n117: \t// +kubebuilder:default=\"8h\"\n118: \tMaxSessionDuration *metav1.Duration `json:\"maxSessionDuration,omitempty\"`\n119: \n120: \t// WarmPoolSize specifies the number of warm sandbox instances to maintain.\n121: \t// If not specified, no warm pool is maintained.\n122: \t// +kubebuilder:validation:Optional\n123: \t// +kubebuilder:validation:Minimum=0\n124: \tWarmPoolSize *int32 `json:\"warmPoolSize,omitempty\"`\n125: \n126: \t// AuthMode specifies the authentication mode for the sandbox.\n127: \t// Defaults to \"picod\" if not specified.\n128: \t// +kubebuilder:validation:Optional\n129: \t// +kubebuilder:default=\"picod\"\n130: \tAuthMode AuthModeType `json:\"authMode,omitempty\"`\n131: }\n132: \n133: // CodeInterpreterConditionType represents a condition type for CodeInterpreter.\n134: // +kubebuilder:validation:Enum=Ready;SandboxCreated;SandboxReady;Failed\n135: // +kubebuilder:validation:Type=string\n136: type CodeInterpreterConditionType string\n137: \n138: const (\n139: \t// CodeInterpreterConditionReady indicates the CodeInterpreter is ready to accept requests.\n140: \tCodeInterpreterConditionReady CodeInterpreterConditionType = \"Ready\"\n141: \n142: \t// CodeInterpreterConditionSandboxCreated indicates the sandbox has been created.\n143: \tCodeInterpreterConditionSandboxCreated CodeInterpreterConditionType = \"SandboxCreated\"\n144: \n145: \t// CodeInterpreterConditionSandboxReady indicates the sandbox is ready for use.\n146: \tCodeInterpreterConditionSandboxReady CodeInterpreterConditionType = \"SandboxReady\"\n147: \n148: \t// CodeInterpreterConditionFailed indicates the CodeInterpreter has failed.\n149: \tCodeInterpreterConditionFailed CodeInterpreterConditionType = \"Failed\"\n150: )\n151: \n152: // CodeInterpreterCondition represents a condition of a CodeInterpreter.\n153: type CodeInterpreterCondition struct {\n154: \t// Type is the type of the condition.\n155: \t// +kubebuilder:validation:Required\n156: \tType CodeInterpreterConditionType `json:\"type\"`\n157: \n158: \t// Status is the status of the condition (True, False, Unknown).\n159: \t// +kubebuilder:validation:Required\n160: \t// +kubebuilder:validation:Enum=True;False;Unknown\n161: \tStatus corev1.ConditionStatus `json:\"status\"`\n162: \n163: \t// LastTransitionTime is the last time the condition transitioned.\n164: \t// +kubebuilder:validation:Optional\n165: \tLastTransitionTime metav1.Time `json:\"lastTransitionTime,omitempty\"`\n166: \n167: \t// Reason is a brief reason for the condition's last transition.\n168: \t// +kubebuilder:validation:Optional\n169: \tReason string `json:\"reason,omitempty\"`\n170: \n171: \t// Message is a human-readable message indicating details about the transition.\n172: \t// +kubebuilder:validation:Optional\n173: \tMessage string `json:\"message,omitempty\"`\n174: }\n175: \n176: // CodeInterpreterStatus defines the observed state of CodeInterpreter.\n177: // This status is updated by the controller to reflect the current\n178: // state of the sandbox instance.\n179: type CodeInterpreterStatus struct {\n180: \t// Conditions represents the latest available observations of the CodeInterpreter's state.\n181: \t// +kubebuilder:validation:Optional\n182: \t// +listType=map\n183: \t// +listMapKey=type\n184: \t// +patchMergeKey=type\n185: \t// +patchStrategy=merge\n186: \tConditions []CodeInterpreterCondition `json:\"conditions,omitempty\"`\n187: \n188: \t// Ready indicates whether the CodeInterpreter is ready to accept requests.\n189: \t// +kubebuilder:validation:Optional\n190: \tReady *bool `json:\"ready,omitempty\"`\n191: }\n192: \n193: // +genclient\n194: // +genclient:noStatus\n195: // +k8s:deepcopy-gen:interfaces=k8s.io/apimachinery/pkg/runtime.Object\n196: // +kubebuilder:object:root=true\n197: // +kubebuilder:resource:path=codeinterpreters,shortName=ci;cis,singular=codeinterpreter,categories={agentcube,all}\n198: // +kubebuilder:subresource:status\n199: // +kubebuilder:printcolumn:name=\"Age\",type=date,JSONPath=`.metadata.creationTimestamp`,description=\"Time since creation\"\n200: \n201: // CodeInterpreter is the Schema for the codeinterpreters API.\n202: // A CodeInterpreter represents a sandbox instance for running code interpretation workloads.\n203: // The controller creates and manages the lifecycle of the underlying\n204: // sandbox pod based on this resource.\n205: type CodeInterpreter struct {\n206: \tmetav1.TypeMeta   `json:\",inline\"`\n207: \tmetav1.ObjectMeta `json:\"metadata,omitempty\"`\n208: \n209: \t// Spec defines the desired state of the CodeInterpreter.\n210: \t// +kubebuilder:validation:Required\n211: \tSpec CodeInterpreterSpec `json:\"spec,omitempty\"`\n212: \n213: \t// Status defines the observed state of the CodeInterpreter.\n214: \t// +kubebuilder:validation:Optional\n215: \tStatus CodeInterpreterStatus `json:\"status,omitempty\"`\n216: }\n217: \n218: // +k8s:deepcopy-gen:interfaces=k8s.io/apimachinery/pkg/runtime.Object\n219: // +kubebuilder:object:root=true\n220: \n221: // CodeInterpreterList contains a list of CodeInterpreter resources.\n222: type CodeInterpreterList struct {\n223: \tmetav1.TypeMeta `json:\",inline\"`\n224: \tmetav1.ListMeta `json:\"metadata,omitempty\"`\n225: \n226: \t// Items is the list of CodeInterpreter resources.\n227: \t// +kubebuilder:validation:Required\n228: \tItems []CodeInterpreter `json:\"items\"`\n229: }\n\n(End of file - total 229 lines)\n</content>","metadata":{"preview":"/*\nCopyright 2026 The Volcano Authors.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\npackage v1alpha1\n\nimport (\n\tcorev1 \"k8s.io/api/core/v1\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/apis/runtime/v1alpha1/codeinterpreter_types.go","time":{"start":1775865903621,"end":1775865903651}}}}
