\n37: \n38: \t// EntryPoints define how to access the sandbox\n39: \tEntryPoints []SandboxEntryPoint `json:\"entryPoints\"`\n40: \n41: \t// SessionID is the unique session identifier\n42: \tSessionID string `json:\"sessionId\"`\n43: \n44: \t// CreatedAt is when the sandbox was created\n45: \tCreatedAt time.Time `json:\"createdAt\"`\n46: \n47: \t// ExpiresAt is when the sandbox expires\n48: \tExpiresAt time.Time `json:\"expiresAt\"`\n49: \n50: \t// Status is the current status of the sandbox (e.g., \"Running\", \"Pending\")\n51: \tStatus string `json:\"status\"`\n52: \n53: \t// PodIP is the IP address of the sandbox pod\n54: \tPodIP string `json:\"podIp,omitempty\"`\n55: \n56: \t// PodName is the name of the sandbox pod\n57: \tPodName string `json:\"podName,omitempty\"`\n58: }\n59: \n60: // SandboxEntryPoint defines an access point to the sandbox.\n61: type SandboxEntryPoint struct {\n62: \t// Path is the URL path prefix for this entry point\n63: \tPath string `json:\"path\"`\n64: \n65: \t// Protocol is the communication protocol (e.g., \"http\", \"https\")\n66: \tProtocol string `json:\"protocol\"`\n67: \n68: \t// Endpoint is the host:port address\n69: \tEndpoint string `json:\"endpoint\"`\n70: }\n71: \n72: // CreateSandboxRequest is sent to the Workload Manager to create a new sandbox.\n73: type CreateSandboxRequest struct {\n74: \t// Kind is the type of sandbox to create\n75: \tKind string `json:\"kind\"`\n76: \n77: \t// Name is the name of the runtime resource\n78: \tName string `json:\"name\"`\n79: \n80: \t// Namespace is the Kubernetes namespace\n81: \tNamespace string `json:\"namespace\"`\n82: }\n83: \n84: // CreateSandboxResponse is received from the Workload Manager after creating a sandbox.\n85: type CreateSandboxResponse struct {\n86: \t// SessionID is the unique session identifier\n87: \tSessionID string `json:\"sessionId\"`\n88: \n89: \t// SandboxID is the unique sandbox identifier\n90: \tSandboxID string `json:\"sandboxId\"`\n91: \n92: \t// Name is the name of the runtime resource\n93: \tName string `json:\"name\"`\n94: \n95: \t// Namespace is the Kubernetes namespace\n96: \tNamespace string `json:\"namespace\"`\n97: \n98: \t// EntryPoints define how to access the sandbox\n99: \tEntryPoints []SandboxEntryPoint `json:\"entryPoints\"`\n100: \n101: \t// Status is the initial status of the sandbox\n102: \tStatus string `json:\"status\"`\n103: }\n104: \n105: // EntryPoint is an alias for SandboxEntryPoint for backward compatibility.\n106: // Deprecated: Use SandboxEntryPoint instead.\n107: type EntryPoint = SandboxEntryPoint\n\n(End of file - total 107 lines)\n</content>","metadata":{"preview":"/*\nCopyright 2026 The Volcano Authors.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\npackage types\n\nimport (\n\t\"time\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/common/types/types.go","time":{"start":1775865694900,"end":1775865695023}}}}
