{"type":"tool_use","timestamp":1775848741939,"sessionID":"ses_2872b5c06ffeMNcifE3NGwSW9i","part":{"id":"prt_d78d55163001pjeMLJyuaHUPNn","messageID":"msg_d78d5111b001JKscoCxKgyRwSk","sessionID":"ses_2872b5c06ffeMNcifE3NGwSW9i","type":"tool","tool":"read","callID":"toolu_functions.read:7","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/workloadmanager/types/response.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/workloadmanager/types/response.go</path>\n<type>file</type>\n<content>\n1: /*\n2: Copyright 2026 The Volcano Authors.\n3: \n4: Licensed under the Apache License, Version 2.0 (the \"License\");\n5: you may not use this file except in compliance with the License.\n6: You may obtain a copy of the License at\n7: \n8:     http://www.apache.org/licenses/LICENSE-2.0\n9: \n10: Unless required by applicable law or agreed to in writing, software\n11: distributed under the License is distributed on an \"AS IS\" BASIS,\n12: WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n13: See the License for the specific language governing permissions and\n14: limitations under the License.\n15: */\n16: \n17: package types\n18: \n19: // Response is the standard API response wrapper.\n20: type Response struct {\n21: \t// Success indicates if the request was successful\n22: \tSuccess bool `json:\"success\"`\n23: \n24: \t// Data contains the response payload (nil if error)\n25: \tData interface{} `json:\"data,omitempty\"`\n26: \n27: \t// Error contains error details if Success is false\n28: \tError *ErrorDetail `json:\"error,omitempty\"`\n29: \n30: \t// RequestID is the unique request identifier\n31: \tRequestID string `json:\"requestId\"`\n32: \n33: \t// Timestamp is the response timestamp in RFC3339 format\n34: \tTimestamp string `json:\"timestamp\"`\n35: }\n36: \n37: // ErrorDetail contains error information.\n38: type ErrorDetail struct {\n39: \t// Code is the machine-readable error code\n40: \tCode string `json:\"code\"`\n41: \n42: \t// Message is the human-readable error message\n43: \tMessage string `json:\"message\"`\n44: \n45: \t// Details contains additional error context\n46: \tDetails map[string]interface{} `json:\"details,omitempty\"`\n47: }\n48: \n49: // WorkloadResponse represents a single workload in API responses.\n50: type WorkloadResponse struct {\n51: \t// Type is the workload type\n52: \tType WorkloadType `json:\"type\"`\n53: \n54: \t// Namespace is the workload namespace\n55: \tNamespace string `json:\"namespace\"`\n56: \n57: \t// Name is the workload name\n58: \tName string `json:\"name\"`\n59: \n60: \t// UID is the workload unique identifier\n61: \tUID string `json:\"uid\"`\n62: \n63: \t// CreatedAt is the creation timestamp\n64: \tCreatedAt string `json:\"createdAt\"`\n65: \n66: \t// ResourceVersion is the Kubernetes resource version\n67: \tResourceVersion string `json:\"resourceVersion,omitempty\"`\n68: \n69: \t// Labels are workload labels\n70: \tLabels map[string]string `json:\"labels,omitempty\"`\n71: \n72: \t// Annotations are workload annotations\n73: \tAnnotations map[string]string `json:\"annotations,omitempty\"`\n74: \n75: \t// Spec contains the workload specification\n76: \tSpec interface{} `json:\"spec\"`\n77: \n78: \t// Status contains the workload status\n79: \tStatus interface{} `json:\"status,omitempty\"`\n80: }\n81: \n82: // ListWorkloadsResponse represents a paginated list of workloads.\n83: type ListWorkloadsResponse struct {\n84: \t// Items is the list of workloads\n85: \tItems []WorkloadResponse `json:\"items\"`\n86: \n87: \t// Total is the total number of workloads (may be estimated)\n88: \tTotal int `json:\"total\"`\n89: \n90: \t// Continue is the continuation token for the next page\n91: \tContinue string `json:\"continue,omitempty\"`\n92: \n93: \t// RemainingItemCount is the number of remaining items (if known)\n94: \tRemainingItemCount *int64 `json:\"remainingItemCount,omitempty\"`\n95: }\n96: \n97: // HealthResponse represents the health check response.\n98: type HealthResponse struct {\n99: \t// Status is the health status: \"healthy\", \"degraded\", or \"unhealthy\"\n100: \tStatus string `json:\"status\"`\n101: \n102: \t// Checks contains individual health check results\n103: \tChecks map[string]HealthCheck `json:\"checks,omitempty\"`\n104: \n105: \t// Version is the server version\n106: \tVersion string `json:\"version\"`\n107: }\n108: \n109: // HealthCheck represents an individual health check.\n110: type HealthCheck struct {\n111: \t// Status is the check status: \"pass\", \"fail\", or \"warn\"\n112: \tStatus string `json:\"status\"`\n113: \n114: \t// Message provides additional context\n115: \tMessage string `json:\"message,omitempty\"`\n116: \n117: \t// LastChecked is the timestamp of the last check\n118: \tLastChecked string `json:\"lastChecked\"`\n119: }\n120: \n121: // DeleteWorkloadResponse represents a delete workload response.\n122: type DeleteWorkloadResponse struct {\n123: \t// Deleted indicates if the workload was successfully deleted\n124: \tDeleted bool `json:\"deleted\"`\n125: \n126: \t// Namespace is the namespace of the deleted workload\n127: \tNamespace string `json:\"namespace\"`\n128: \n129: \t// Name is the name of the deleted workload\n130: \tName string `json:\"name\"`\n131: \n132: \t// Type is the type of the deleted workload\n133: \tType WorkloadType `json:\"type\"`\n134: }\n\n(End of file - total 134 lines)\n</content>","metadata":{"preview":"/*\nCopyright 2026 The Volcano Authors.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\npackage types\n\n// Response is the standard API response wrapper.\ntype Response struct {","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/workloadmanager/types/response.go","time":{"start":1775848741925,"end":1775848741938}}}}
{"type":"tool_use","timestamp":1775848741941,"sessionID":"ses_2872b5c06ffeMNcifE3NGwSW9i","part":{"id":"prt_d78d55739001iMoIcbvaSMeUWX","messageID":"msg_d78d5111b001JKscoCxKgyRwSk","sessionID":"ses_2872b5c06ffeMNcifE3NGwSW9i","type":"tool","tool":"read","callID":"toolu_functions.read:8","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/workloadmanager/errors/errors.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/workloadmanager/errors/errors.go</path>\n<type>file</type>\n<content>\n1: /*\n2: Copyright 2026 The Volcano Authors.\n3: \n4: Licensed under the Apache License, Version 2.0 (the \"License\");\n5: you may not use this file except in compliance with the License.\n6: You may obtain a copy of the License at\n7: \n8:     http://www.apache.org/licenses/LICENSE-2.0\n9: \n10: Unless required by applicable law or agreed to in writing, software\n11: distributed under the License is distributed on an \"AS IS\" BASIS,\n12: WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n13: See the License for the specific language governing permissions and\n14: limitations under the License.\n15: */\n16: \n17: // Package errors provides HTTP error types and error handling utilities.\n18: package errors\n19: \n20: import (\n21: \t\"context\"\n22: \t\"errors\"\n23: \t\"fmt\"\n24: \t\"net/http\"\n25: \t\"time\"\n26: )\n27: \n28: // Service-level errors.\n29: var (\n30: \tErrWorkloadNotFound      = errors.New(\"workload not found\")\n31: \tErrWorkloadAlreadyExists = errors.New(\"workload already exists\")\n32: \tErrValidationFailed      = errors.New(\"validation failed\")\n33: \tErrInvalidRequest        = errors.New(\"invalid request\")\n34: \tErrUnauthorized          = errors.New(\"unauthorized\")\n35: \tErrForbidden             = errors.New(\"forbidden\")\n36: \tErrRateLimited           = errors.New(\"rate limited\")\n37: \tErrServiceUnavailable    = errors.New(\"service unavailable\")\n38: )\n39: \n40: // HTTPError represents an HTTP error response.\n41: type HTTPError struct {\n42: \t// Code is the machine-readable error code\n43: \tCode string `json:\"code\"`\n44: \n45: \t// Message is the human-readable error message\n46: \tMessage string `json:\"message\"`\n47: \n48: \t// StatusCode is the HTTP status code (not serialized to JSON)\n49: \tStatusCode int `json:\"-\"`\n50: \n51: \t// Details contains additional error context\n52: \tDetails map[string]interface{} `json:\"details,omitempty\"`\n53: \n54: \t// RequestID is the unique request identifier\n55: \tRequestID string `json:\"requestId\"`\n56: }\n57: \n58: // Error implements the error interface.\n59: func (e *HTTPError) Error() string {\n60: \treturn fmt.Sprintf(\"[%s] %s: %s\", e.Code, e.Message, e.RequestID)\n61: }\n62: \n63: // NewNotFoundError creates a new NOT_FOUND error.\n64: func NewNotFoundError(resource, name, namespace, requestID string) *HTTPError {\n65: \treturn &HTTPError{\n66: \t\tCode:       \"NOT_FOUND\",\n67: \t\tMessage:    fmt.Sprintf(\"%s '%s' not found in namespace '%s'\", resource, name, namespace),\n68: \t\tStatusCode: http.StatusNotFound,\n69: \t\tDetails: map[string]interface{}{\n70: \t\t\t\"resource\":  resource,\n71: \t\t\t\"name\":      name,\n72: \t\t\t\"namespace\": namespace,\n73: \t\t},\n74: \t\tRequestID: requestID,\n75: \t}\n76: }\n77: \n78: // NewValidationError creates a new VALIDATION_FAILED error.\n79: func NewValidationError(field, message, requestID string) *HTTPError {\n80: \treturn &HTTPError{\n81: \t\tCode:       \"VALIDATION_FAILED\",\n82: \t\tMessage:    fmt.Sprintf(\"Validation failed for field '%s': %s\", field, message),\n83: \t\tStatusCode: http.StatusUnprocessableEntity,\n84: \t\tDetails: map[string]interface{}{\n85: \t\t\t\"field\":   field,\n86: \t\t\t\"message\": message,\n87: \t\t},\n88: \t\tRequestID: requestID,\n89: \t}\n90: }\n91: \n92: // NewConflictError creates a new CONFLICT error.\n93: func NewConflictError(message, requestID string) *HTTPError {\n94: \treturn &HTTPError{\n95: \t\tCode:       \"CONFLICT\",\n96: \t\tMessage:    message,\n97: \t\tStatusCode: http.StatusConflict,\n98: \t\tRequestID:  requestID,\n99: \t}\n100: }\n101: \n102: // NewInternalError creates a new INTERNAL_ERROR.\n103: func NewInternalError(err error, requestID string) *HTTPError {\n104: \treturn &HTTPError{\n105: \t\tCode:       \"INTERNAL_ERROR\",\n106: \t\tMessage:    \"Internal server error\",\n107: \t\tStatusCode: http.StatusInternalServerError,\n108: \t\tDetails: map[string]interface{}{\n109: \t\t\t\"error\": err.Error(),\n110: \t\t},\n111: \t\tRequestID: requestID,\n112: \t}\n113: }\n114: \n115: // NewTimeoutError creates a new TIMEOUT error.\n116: func NewTimeoutError(duration time.Duration, requestID string) *HTTPError {\n117: \treturn &HTTPError{\n118: \t\tCode:       \"TIMEOUT\",\n119: \t\tMessage:    fmt.Sprintf(\"Request timeout after %v\", duration),\n120: \t\tStatusCode: http.StatusGatewayTimeout,\n121: \t\tDetails: map[string]interface{}{\n122: \t\t\t\"timeout\": duration.String(),\n123: \t\t},\n124: \t\tRequestID: requestID,\n125: \t}\n126: }\n127: \n128: // NewBadRequestError creates a new BAD_REQUEST error.\n129: func NewBadRequestError(message, requestID string) *HTTPError {\n130: \treturn &HTTPError{\n131: \t\tCode:       \"INVALID_REQUEST\",\n132: \t\tMessage:    message,\n133: \t\tStatusCode: http.StatusBadRequest,\n134: \t\tRequestID:  requestID,\n135: \t}\n136: }\n137: \n138: // NewUnauthorizedError creates a new UNAUTHORIZED error.\n139: func NewUnauthorizedError(message, requestID string) *HTTPError {\n140: \treturn &HTTPError{\n141: \t\tCode:       \"UNAUTHORIZED\",\n142: \t\tMessage:    message,\n143: \t\tStatusCode: http.StatusUnauthorized,\n144: \t\tRequestID:  requestID,\n145: \t}\n146: }\n147: \n148: // NewForbiddenError creates a new FORBIDDEN error.\n149: func NewForbiddenError(message, requestID string) *HTTPError {\n150: \treturn &HTTPError{\n151: \t\tCode:       \"FORBIDDEN\",\n152: \t\tMessage:    message,\n153: \t\tStatusCode: http.StatusForbidden,\n154: \t\tRequestID:  requestID,\n155: \t}\n156: }\n157: \n158: // NewRateLimitError creates a new RATE_LIMITED error.\n159: func NewRateLimitError(message, requestID string) *HTTPError {\n160: \treturn &HTTPError{\n161: \t\tCode:       \"RATE_LIMITED\",\n162: \t\tMessage:    message,\n163: \t\tStatusCode: http.StatusTooManyRequests,\n164: \t\tRequestID:  requestID,\n165: \t}\n166: }\n167: \n168: // NewServiceUnavailableError creates a new SERVICE_UNAVAILABLE error.\n169: func NewServiceUnavailableError(message, requestID string) *HTTPError {\n170: \treturn &HTTPError{\n171: \t\tCode:       \"SERVICE_UNAVAILABLE\",\n172: \t\tMessage:    message,\n173: \t\tStatusCode: http.StatusServiceUnavailable,\n174: \t\tRequestID:  requestID,\n175: \t}\n176: }\n177: \n178: // MapServiceError maps service errors to HTTP errors.\n179: func MapServiceError(err error, requestID string) *HTTPError {\n180: \tif err == nil {\n181: \t\treturn nil\n182: \t}\n183: \n184: \tswitch {\n185: \tcase errors.Is(err, ErrWorkloadNotFound):\n186: \t\treturn &HTTPError{\n187: \t\t\tCode:       \"NOT_FOUND\",\n188: \t\t\tMessage:    err.Error(),\n189: \t\t\tStatusCode: http.StatusNotFound,\n190: \t\t\tRequestID:  requestID,\n191: \t\t}\n192: \tcase errors.Is(err, ErrWorkloadAlreadyExists):\n193: \t\treturn &HTTPError{\n194: \t\t\tCode:       \"CONFLICT\",\n195: \t\t\tMessage:    err.Error(),\n196: \t\t\tStatusCode: http.StatusConflict,\n197: \t\t\tRequestID:  requestID,\n198: \t\t}\n199: \tcase errors.Is(err, ErrValidationFailed):\n200: \t\treturn &HTTPError{\n201: \t\t\tCode:       \"VALIDATION_FAILED\",\n202: \t\t\tMessage:    err.Error(),\n203: \t\t\tStatusCode: http.StatusUnprocessableEntity,\n204: \t\t\tRequestID:  requestID,\n205: \t\t}\n206: \tcase errors.Is(err, ErrInvalidRequest):\n207: \t\treturn &HTTPError{\n208: \t\t\tCode:       \"INVALID_REQUEST\",\n209: \t\t\tMessage:    err.Error(),\n210: \t\t\tStatusCode: http.StatusBadRequest,\n211: \t\t\tRequestID:  requestID,\n212: \t\t}\n213: \tcase errors.Is(err, ErrUnauthorized):\n214: \t\treturn &HTTPError{\n215: \t\t\tCode:       \"UNAUTHORIZED\",\n216: \t\t\tMessage:    err.Error(),\n217: \t\t\tStatusCode: http.StatusUnauthorized,\n218: \t\t\tRequestID:  requestID,\n219: \t\t}\n220: \tcase errors.Is(err, ErrForbidden):\n221: \t\treturn &HTTPError{\n222: \t\t\tCode:       \"FORBIDDEN\",\n223: \t\t\tMessage:    err.Error(),\n224: \t\t\tStatusCode: http.StatusForbidden,\n225: \t\t\tRequestID:  requestID,\n226: \t\t}\n227: \tcase errors.Is(err, ErrRateLimited):\n228: \t\treturn &HTTPError{\n229: \t\t\tCode:       \"RATE_LIMITED\",\n230: \t\t\tMessage:    err.Error(),\n231: \t\t\tStatusCode: http.StatusTooManyRequests,\n232: \t\t\tRequestID:  requestID,\n233: \t\t}\n234: \tcase errors.Is(err, ErrServiceUnavailable):\n235: \t\treturn &HTTPError{\n236: \t\t\tCode:       \"SERVICE_UNAVAILABLE\",\n237: \t\t\tMessage:    err.Error(),\n238: \t\t\tStatusCode: http.StatusServiceUnavailable,\n239: \t\t\tRequestID:  requestID,\n240: \t\t}\n241: \tcase errors.Is(err, context.DeadlineExceeded):\n242: \t\treturn &HTTPError{\n243: \t\t\tCode:       \"TIMEOUT\",\n244: \t\t\tMessage:    \"Request timeout\",\n245: \t\t\tStatusCode: http.StatusGatewayTimeout,\n246: \t\t\tRequestID:  requestID,\n247: \t\t}\n248: \tdefault:\n249: \t\treturn &HTTPError{\n250: \t\t\tCode:       \"INTERNAL_ERROR\",\n251: \t\t\tMessage:    \"Internal server error\",\n252: \t\t\tStatusCode: http.StatusInternalServerError,\n253: \t\t\tRequestID:  requestID,\n254: \t\t}\n255: \t}\n256: }\n\n(End of file - total 256 lines)\n</content>","metadata":{"preview":"/*\nCopyright 2026 The Volcano Authors.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\n// Package errors provides HTTP error types and error handling utilities.\npackage errors\n\nimport (","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/workloadmanager/errors/errors.go","time":{"start":1775848741927,"end":1775848741940}}}}
{"type":"tool_use","timestamp":1775848741944,"sessionID":"ses_2872b5c06ffeMNcifE3NGwSW9i","part":{"id":"prt_d78d54a9500165355C07t6yPtQ","messageID":"msg_d78d5111b001JKscoCxKgyRwSk","sessionID":"ses_2872b5c06ffeMNcifE3NGwSW9i","type":"tool","tool":"read","callID":"toolu_functions.read:6","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/workloadmanager/types/request.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/workloadmanager/types/request.go</path>\n<type>file</type>\n<content>\n1: /*\n2: Copyright 2026 The Volcano Authors.\n3: \n4: Licensed under the Apache License, Version 2.0 (the \"License\");\n5: you may not use this file except in compliance with the License.\n6: You may obtain a copy of the License at\n7: \n8:     http://www.apache.org/licenses/LICENSE-2.0\n9: \n10: Unless required by applicable law or agreed to in writing, software\n11: distributed under the License is distributed on an \"AS IS\" BASIS,\n12: WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n13: See the License for the specific language governing permissions and\n14: limitations under the License.\n15: */\n16: \n17: package types\n18: \n19: import (\n20: \t\"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1\"\n21: )\n22: \n23: // WorkloadType defines the type of workload.\n24: type WorkloadType string\n25: \n26: const (\n27: \t// WorkloadTypeAgentRuntime represents an AgentRuntime workload.\n28: \tWorkloadTypeAgentRuntime WorkloadType = \"agentruntime\"\n29: \n30: \t// WorkloadTypeCodeInterpreter represents a CodeInterpreter workload.\n31: \tWorkloadTypeCodeInterpreter WorkloadType = \"codeinterpreter\"\n32: )\n33: \n34: // CreateWorkloadRequest represents a request to create a new workload.\n35: type CreateWorkloadRequest struct {\n36: \t// Namespace is the Kubernetes namespace (default: default)\n37: \tNamespace string `json:\"namespace,omitempty\" validate:\"omitempty,k8sNamespace\"`\n38: \n39: \t// Name is the workload name (optional, auto-generated if not provided)\n40: \tName string `json:\"name,omitempty\" validate:\"omitempty,k8sName\"`\n41: \n42: \t// Type is the workload type: \"agentruntime\" or \"codeinterpreter\"\n43: \tType WorkloadType `json:\"type\" validate:\"required,oneof=agentruntime codeinterpreter\"`\n44: \n45: \t// AgentRuntimeSpec is the specification for AgentRuntime workloads\n46: \tAgentRuntimeSpec *v1alpha1.AgentRuntimeSpec `json:\"agentRuntimeSpec,omitempty\" validate:\"required_if=Type agentruntime\"`\n47: \n48: \t// CodeInterpreterSpec is the specification for CodeInterpreter workloads\n49: \tCodeInterpreterSpec *v1alpha1.CodeInterpreterSpec `json:\"codeInterpreterSpec,omitempty\" validate:\"required_if=Type codeinterpreter\"`\n50: \n51: \t// Labels are workload labels\n52: \tLabels map[string]string `json:\"labels,omitempty\"`\n53: \n54: \t// Annotations are workload annotations\n55: \tAnnotations map[string]string `json:\"annotations,omitempty\"`\n56: }\n57: \n58: // UpdateWorkloadRequest represents a request to update an existing workload.\n59: type UpdateWorkloadRequest struct {\n60: \t// AgentRuntimeSpec is the updated specification for AgentRuntime workloads\n61: \tAgentRuntimeSpec *v1alpha1.AgentRuntimeSpec `json:\"agentRuntimeSpec,omitempty\"`\n62: \n63: \t// CodeInterpreterSpec is the updated specification for CodeInterpreter workloads\n64: \tCodeInterpreterSpec *v1alpha1.CodeInterpreterSpec `json:\"codeInterpreterSpec,omitempty\"`\n65: \n66: \t// Labels are updated workload labels (merged with existing)\n67: \tLabels map[string]string `json:\"labels,omitempty\"`\n68: \n69: \t// Annotations are updated workload annotations (merged with existing)\n70: \tAnnotations map[string]string `json:\"annotations,omitempty\"`\n71: }\n72: \n73: // ListWorkloadsRequest represents parameters for listing workloads.\n74: type ListWorkloadsRequest struct {\n75: \t// Namespace filters by namespace (default: all namespaces)\n76: \tNamespace string `query:\"namespace\"`\n77: \n78: \t// Type filters by workload type\n79: \tType WorkloadType `query:\"type\" validate:\"omitempty,oneof=agentruntime codeinterpreter\"`\n80: \n81: \t// LabelSelector filters by label selector\n82: \tLabelSelector string `query:\"labelSelector\"`\n83: \n84: \t// FieldSelector filters by field selector\n85: \tFieldSelector string `query:\"fieldSelector\"`\n86: \n87: \t// Limit is the maximum number of results to return (default: 100, max: 1000)\n88: \tLimit int `query:\"limit\" validate:\"min=1,max=1000\"`\n89: \n90: \t// Continue is the continuation token for pagination\n91: \tContinue string `query:\"continue\"`\n92: }\n93: \n94: // WatchOptions contains options for watching workloads.\n95: type WatchOptions struct {\n96: \t// Namespace filters by namespace\n97: \tNamespace string\n98: \n99: \t// Type filters by workload type\n100: \tType WorkloadType\n101: \n102: \t// LabelSelector filters by label selector\n103: \tLabelSelector string\n104: \n105: \t// ResourceVersion watches from specific resource version\n106: \tResourceVersion string\n107: }\n108: \n109: // WatchStream represents a stream of workload events.\n110: type WatchStream interface {\n111: \t// Next returns the next event or error\n112: \tNext() (*WorkloadEvent, error)\n113: \n114: \t// Stop stops the watch stream\n115: \tStop()\n116: }\n117: \n118: // WorkloadEvent represents a workload watch event.\n119: type WorkloadEvent struct {\n120: \t// Type is the event type: \"ADDED\", \"MODIFIED\", \"DELETED\"\n121: \tType string `json:\"type\"`\n122: \n123: \t// Workload is the workload data\n124: \tWorkload *WorkloadResponse `json:\"workload\"`\n125: }\n\n(End of file - total 125 lines)\n</content>","metadata":{"preview":"/*\nCopyright 2026 The Volcano Authors.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\npackage types\n\nimport (\n\t\"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/workloadmanager/types/request.go","time":{"start":1775848741921,"end":1775848741942}}}}
