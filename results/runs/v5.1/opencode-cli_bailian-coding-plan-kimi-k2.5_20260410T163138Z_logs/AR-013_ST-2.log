tring\n47: \tPassword          string\n48: \tDisableCache      bool\n49: \tForceSingleClient bool\n50: }\n51: \n52: var (\n53: \tinitStoreOnce sync.Once\n54: \tstoreInstance Store\n55: \tinitError     error\n56: )\n57: \n58: // Storage returns the singleton Store instance.\n59: // Initializes on first call using sync.Once for thread safety.\n60: // Fatals via klog.Fatal if initialization fails.\n61: func Storage() Store {\n62: \tinitStoreOnce.Do(func() {\n63: \t\tstoreInstance, initError = initStore()\n64: \t\tif initError != nil {\n65: \t\t\tklog.Fatalf(\"init store failed: %v\", initError)\n66: \t\t}\n67: \t})\n68: \treturn storeInstance\n69: }\n70: \n71: // initStore creates the appropriate Store implementation based on STORE_TYPE env var.\n72: // Returns an error if the store type is unsupported or if required environment\n73: // variables are missing.\n74: func initStore() (Store, error) {\n75: \tstoreType := strings.ToLower(strings.TrimSpace(os.Getenv(\"STORE_TYPE\")))\n76: \tif storeType == \"\" {\n77: \t\tstoreType = redisStoreType\n78: \t}\n79: \n80: \tswitch storeType {\n81: \tcase redisStoreType:\n82: \t\treturn newRedisStore()\n83: \tcase valkeyStoreType:\n84: \t\treturn newValkeyStore()\n85: \tdefault:\n86: \t\treturn nil, fmt.Errorf(\"unsupported store type: %s (supported: redis, valkey)\", storeType)\n87: \t}\n88: }\n89: \n90: // makeRedisOptions creates redis.Options from environment variables.\n91: // Required: REDIS_ADDR\n92: // Required: REDIS_PASSWORD (unless REDIS_PASSWORD_REQUIRED=false)\n93: func makeRedisOptions() (*redisOptions, error) {\n94: \taddr := strings.TrimSpace(os.Getenv(\"REDIS_ADDR\"))\n95: \tif addr == \"\" {\n96: \t\treturn nil, fmt.Errorf(\"REDIS_ADDR is required\")\n97: \t}\n98: \n99: \tpassword := os.Getenv(\"REDIS_PASSWORD\")\n100: \tpasswordRequiredStr := strings.ToLower(strings.TrimSpace(os.Getenv(\"REDIS_PASSWORD_REQUIRED\")))\n101: \tpasswordRequired := true\n102: \tif passwordRequiredStr != \"\" {\n103: \t\tparsed, err := strconv.ParseBool(passwordRequiredStr)\n104: \t\tif err == nil {\n105: \t\t\tpasswordRequired = parsed\n106: \t\t}\n107: \t}\n108: \n109: \tif passwordRequired && password == \"\" {\n110: \t\treturn nil, fmt.Errorf(\"REDIS_PASSWORD is required (set REDIS_PASSWORD_REQUIRED=false to disable)\")\n111: \t}\n112: \n113: \treturn &redisOptions{\n114: \t\tAddr:     addr,\n115: \t\tPassword: password,\n116: \t}, nil\n117: }\n118: \n119: // makeValkeyOptions creates valkey.ClientOption from environment variables.\n120: // Required: VALKEY_ADDR (comma-separated addresses)\n121: // Required: VALKEY_PASSWORD (unless VALKEY_PASSWORD_REQUIRED=false)\n122: // Optional: VALKEY_DISABLE_CACHE, VALKEY_FORCE_SINGLE\n123: func makeValkeyOptions() (*valkeyOptions, error) {\n124: \taddrStr := strings.TrimSpace(os.Getenv(\"VALKEY_ADDR\"))\n125: \tif addrStr == \"\" {\n126: \t\treturn nil, fmt.Errorf(\"VALKEY_ADDR is required\")\n127: \t}\n128: \n129: \taddresses := strings.Split(addrStr, \",\")\n130: \tfor i, addr := range addresses {\n131: \t\taddresses[i] = strings.TrimSpace(addr)\n132: \t}\n133: \n134: \tpassword := os.Getenv(\"VALKEY_PASSWORD\")\n135: \tpasswordRequiredStr := strings.ToLower(strings.TrimSpace(os.Getenv(\"VALKEY_PASSWORD_REQUIRED\")))\n136: \tpasswordRequired := true\n137: \tif passwordRequiredStr != \"\" {\n138: \t\tparsed, err := strconv.ParseBool(passwordRequiredStr)\n139: \t\tif err == nil {\n140: \t\t\tpasswordRequired = parsed\n141: \t\t}\n142: \t}\n143: \n144: \tif passwordRequired && password == \"\" {\n145: \t\treturn nil, fmt.Errorf(\"VALKEY_PASSWORD is required (set VALKEY_PASSWORD_REQUIRED=false to disable)\")\n146: \t}\n147: \n148: \topts := &valkeyOptions{\n149: \t\tInitAddress: addresses,\n150: \t\tPassword:    password,\n151: \t}\n152: \n153: \tdisableCacheStr := strings.TrimSpace(os.Getenv(\"VALKEY_DISABLE_CACHE\"))\n154: \tif disableCacheStr != \"\" {\n155: \t\tparsed, err := strconv.ParseBool(disableCacheStr)\n156: \t\tif err == nil {\n157: \t\t\topts.DisableCache = parsed\n158: \t\t}\n159: \t}\n160: \n161: \tforceSingleStr := strings.TrimSpace(os.Getenv(\"VALKEY_FORCE_SINGLE\"))\n162: \tif forceSingleStr != \"\" {\n163: \t\tparsed, err := strconv.ParseBool(forceSingleStr)\n164: \t\tif err == nil {\n165: \t\t\topts.ForceSingleClient = parsed\n166: \t\t}\n167: \t}\n168: \n169: \treturn opts, nil\n170: }\n\n(End of file - total 170 lines)\n</content>","metadata":{"preview":"/*\nCopyright 2026 The Volcano Authors.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\npackage store\n\nimport (\n\t\"fmt\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/store/singleton.go","time":{"start":1775866671527,"end":1775866671555}}}}
