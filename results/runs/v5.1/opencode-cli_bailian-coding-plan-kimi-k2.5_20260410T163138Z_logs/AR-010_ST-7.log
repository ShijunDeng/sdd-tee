{"type":"tool_use","timestamp":1775861397679,"sessionID":"ses_28669f6f9ffeDVJ8DxCnviSVss","part":{"id":"prt_d79966aad001h7M2j650lnT1Uh","messageID":"msg_d79963fd700128wg03tFKS0fjF","sessionID":"ses_28669f6f9ffeDVJ8DxCnviSVss","type":"tool","tool":"read","callID":"toolu_functions.read:7","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/router/session_manager.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/router/session_manager.go</path>\n<type>file</type>\n<content>\n1: /*\n2: Copyright 2026 The Volcano Authors.\n3: \n4: Licensed under the Apache License, Version 2.0 (the \"License\");\n5: you may not use this file except in compliance with the License.\n6: You may obtain a copy of the License at\n7: \n8:     http://www.apache.org/licenses/LICENSE-2.0\n9: \n10: Unless required by applicable law or agreed to in writing, software\n11: distributed under the License is distributed on an \"AS IS\" BASIS,\n12: WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n13: See the License for the specific language governing permissions and\n14: limitations under the License.\n15: */\n16: \n17: package router\n18: \n19: import (\n20: \t\"bytes\"\n21: \t\"context\"\n22: \t\"encoding/json\"\n23: \t\"fmt\"\n24: \t\"io\"\n25: \t\"net/http\"\n26: \t\"os\"\n27: \t\"strings\"\n28: \t\"time\"\n29: \n30: \t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n31: \t\"github.com/volcano-sh/agentcube/pkg/store\"\n32: \t\"golang.org/x/net/http2\"\n33: \t\"k8s.io/klog/v2\"\n34: )\n35: \n36: // SessionManager defines the interface for session resolution and sandbox lookup.\n37: type SessionManager interface {\n38: \tGetSandboxBySession(ctx context.Context, sessionID string, namespace string, name string, kind string) (*types.SandboxInfo, error)\n39: }\n40: \n41: // manager implements SessionManager.\n42: type manager struct {\n43: \tstoreClient     store.Store\n44: \tworkloadMgrAddr string\n45: \thttpClient      *http.Client\n46: \tauthToken       string\n47: }\n48: \n49: // NewSessionManager creates a new SessionManager instance.\n50: // Requires WORKLOAD_MANAGER_URL environment variable to be set.\n51: func NewSessionManager(storeClient store.Store) (SessionManager, error) {\n52: \tworkloadMgrURL := os.Getenv(\"WORKLOAD_MANAGER_URL\")\n53: \tif workloadMgrURL == \"\" {\n54: \t\treturn nil, fmt.Errorf(\"WORKLOAD_MANAGER_URL environment variable is not set\")\n55: \t}\n56: \n57: \t// Load auth token if available\n58: \tauthToken := loadWorkloadManagerAuthToken()\n59: \n60: \t// Create HTTP client with custom transport\n61: \ttransport := &http.Transport{\n62: \t\tMaxIdleConnsPerHost: 100,\n63: \t\tDisableCompression:  false,\n64: \t}\n65: \n66: \t// Configure HTTP/2\n67: \thttp2Transport, err := http2.ConfigureTransports(transport)\n68: \tif err != nil {\n69: \t\treturn nil, fmt.Errorf(\"failed to configure HTTP/2 transport: %w\", err)\n70: \t}\n71: \thttp2Transport.ReadIdleTimeout = 30 * time.Second\n72: \thttp2Transport.PingTimeout = 15 * time.Second\n73: \n74: \thttpClient := &http.Client{\n75: \t\tTimeout:   2 * time.Minute,\n76: \t\tTransport: transport,\n77: \t}\n78: \n79: \treturn &manager{\n80: \t\tstoreClient:     storeClient,\n81: \t\tworkloadMgrAddr: workloadMgrURL,\n82: \t\thttpClient:      httpClient,\n83: \t\tauthToken:       authToken,\n84: \t}, nil\n85: }\n86: \n87: // loadWorkloadManagerAuthToken reads the Kubernetes service account token.\n88: func loadWorkloadManagerAuthToken() string {\n89: \ttokenPath := \"/var/run/secrets/kubernetes.io/serviceaccount/token\"\n90: \tdata, err := os.ReadFile(tokenPath)\n91: \tif err != nil {\n92: \t\tif !os.IsNotExist(err) {\n93: \t\t\tklog.Warningf(\"Failed to read service account token: %v\", err)\n94: \t\t}\n95: \t\treturn \"\"\n96: \t}\n97: \treturn strings.TrimSpace(string(data))\n98: }\n99: \n100: // GetSandboxBySession resolves a sandbox by session ID or creates a new one.\n101: func (m *manager) GetSandboxBySession(ctx context.Context, sessionID string, namespace string, name string, kind string) (*types.SandboxInfo, error) {\n102: \t// If session ID is provided, try to load from store\n103: \tif sessionID != \"\" {\n104: \t\tsandbox, err := m.storeClient.GetSandboxBySessionID(ctx, sessionID)\n105: \t\tif err == nil {\n106: \t\t\treturn sandbox, nil\n107: \t\t}\n108: \t\tif err != store.ErrNotFound {\n109: \t\t\tklog.Warningf(\"Failed to get sandbox from store: %v\", err)\n110: \t\t}\n111: \t\t// Session not found, will create a new one\n112: \t}\n113: \n114: \t// Create a new sandbox via workload manager\n115: \treturn m.createSandbox(ctx, namespace, name, kind)\n116: }\n117: \n118: func (m *manager) createSandbox(ctx context.Context, namespace string, name string, kind string) (*types.SandboxInfo, error) {\n119: \t// Build request\n120: \treqBody := types.CreateSandboxRequest{\n121: \t\tKind:      kind,\n122: \t\tName:      name,\n123: \t\tNamespace: namespace,\n124: \t}\n125: \n126: \tjsonBody, err := json.Marshal(reqBody)\n127: \tif err != nil {\n128: \t\treturn nil, fmt.Errorf(\"failed to marshal create sandbox request: %w\", err)\n129: \t}\n130: \n131: \t// Determine endpoint based on kind\n132: \tendpoint := m.getEndpointForKind(kind)\n133: \turl := fmt.Sprintf(\"%s%s\", m.workloadMgrAddr, endpoint)\n134: \n135: \t// Create HTTP request\n136: \treq, err := http.NewRequestWithContext(ctx, http.MethodPost, url, bytes.NewReader(jsonBody))\n137: \tif err != nil {\n138: \t\treturn nil, fmt.Errorf(\"failed to create request: %w\", err)\n139: \t}\n140: \n141: \treq.Header.Set(\"Content-Type\", \"application/json\")\n142: \tif m.authToken != \"\" {\n143: \t\treq.Header.Set(\"Authorization\", \"Bearer \"+m.authToken)\n144: \t}\n145: \n146: \t// Execute request\n147: \tresp, err := m.httpClient.Do(req)\n148: \tif err != nil {\n149: \t\treturn nil, fmt.Errorf(\"failed to call workload manager: %w\", err)\n150: \t}\n151: \tdefer resp.Body.Close()\n152: \n153: \t// Handle response\n154: \tif resp.StatusCode != http.StatusOK {\n155: \t\tbody, _ := io.ReadAll(resp.Body)\n156: \t\tif resp.StatusCode == http.StatusNotFound {\n157: \t\t\treturn nil, NewSandboxTemplateNotFoundError(namespace, name, kind)\n158: \t\t}\n159: \t\treturn nil, fmt.Errorf(\"workload manager returned %d: %s\", resp.StatusCode, string(body))\n160: \t}\n161: \n162: \t// Parse response\n163: \tvar createResp types.CreateSandboxResponse\n164: \tif err := json.NewDecoder(resp.Body).Decode(&createResp); err != nil {\n165: \t\treturn nil, fmt.Errorf(\"failed to decode create sandbox response: %w\", err)\n166: \t}\n167: \n168: \t// Validate response\n169: \tif createResp.SessionID == \"\" {\n170: \t\treturn nil, fmt.Errorf(\"workload manager returned empty session ID\")\n171: \t}\n172: \n173: \t// Build SandboxInfo from response\n174: \tsandbox := &types.SandboxInfo{\n175: \t\tKind:             kind,\n176: \t\tSandboxID:        createResp.SandboxID,\n177: \t\tName:             name,\n178: \t\tSandboxNamespace: namespace,\n179: \t\tSessionID:        createResp.SessionID,\n180: \t\tEntryPoints:      createResp.EntryPoints,\n181: \t\tStatus:           createResp.Status,\n182: \t\tCreatedAt:        time.Now(),\n183: \t}\n184: \n185: \t// Store the sandbox info\n186: \tif err := m.storeClient.StoreSandbox(ctx, sandbox); err != nil {\n187: \t\tklog.Warningf(\"Failed to store sandbox info: %v\", err)\n188: \t}\n189: \n190: \treturn sandbox, nil\n191: }\n192: \n193: func (m *manager) getEndpointForKind(kind string) string {\n194: \tswitch kind {\n195: \tcase \"AgentRuntime\":\n196: \t\treturn \"/v1/agent-runtime\"\n197: \tcase \"CodeInterpreter\":\n198: \t\treturn \"/v1/code-interpreter\"\n199: \tdefault:\n200: \t\t// Default to agent-runtime for unknown kinds\n201: \t\treturn \"/v1/agent-runtime\"\n202: \t}\n203: }\n\n(End of file - total 203 lines)\n</content>","metadata":{"preview":"/*\nCopyright 2026 The Volcano Authors.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\npackage router\n\nimport (\n\t\"bytes\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/router/session_manager.go","time":{"start":1775861397631,"end":1775861397676}}}}
