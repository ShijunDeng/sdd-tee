{"type":"tool_use","timestamp":1775906773222,"sessionID":"ses_283b61b66ffesarH0IS4Kgh6IJ","part":{"id":"prt_d7c4acc5a001xxSRVqiLjGxot5","messageID":"msg_d7c4ab5c6001mD4PgolxdeIwNy","sessionID":"ses_283b61b66ffesarH0IS4Kgh6IJ","type":"tool","tool":"read","callID":"toolu_functions.read:19","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/tests/test_utils_http.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/tests/test_utils_http.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Unit tests for HTTP utilities.\"\"\"\n2: \n3: import os\n4: import tempfile\n5: from unittest import mock\n6: \n7: import pytest\n8: from requests.adapters import HTTPAdapter\n9: \n10: from agentcube.utils.http import (\n11:     SERVICE_ACCOUNT_TOKEN_PATH,\n12:     create_session,\n13:     get_service_account_token,\n14:     read_token_from_file,\n15: )\n16: \n17: \n18: class TestCreateSession:\n19:     \"\"\"Tests for create_session function.\"\"\"\n20: \n21:     def test_returns_requests_session(self):\n22:         \"\"\"Test that create_session returns a requests.Session.\"\"\"\n23:         import requests\n24: \n25:         session = create_session()\n26:         assert isinstance(session, requests.Session)\n27: \n28:     def test_session_has_adapter_for_http(self):\n29:         \"\"\"Test that session has adapter mounted for http://\"\"\"\n30:         session = create_session()\n31:         adapter = session.get_adapter(\"http://example.com\")\n32:         assert isinstance(adapter, HTTPAdapter)\n33: \n34:     def test_session_has_adapter_for_https(self):\n35:         \"\"\"Test that session has adapter mounted for https://\"\"\"\n36:         session = create_session()\n37:         adapter = session.get_adapter(\"https://example.com\")\n38:         assert isinstance(adapter, HTTPAdapter)\n39: \n40:     def test_default_pool_settings(self):\n41:         \"\"\"Test default pool connection settings.\"\"\"\n42:         session = create_session()\n43:         adapter = session.get_adapter(\"http://example.com\")\n44:         assert adapter.config[\"pool_connections\"] == 10\n45:         assert adapter.config[\"pool_maxsize\"] == 10\n46: \n47:     def test_custom_pool_settings(self):\n48:         \"\"\"Test custom pool connection settings.\"\"\"\n49:         session = create_session(pool_connections=5, pool_maxsize=20)\n50:         adapter = session.get_adapter(\"http://example.com\")\n51:         assert adapter.config[\"pool_connections\"] == 5\n52:         assert adapter.config[\"pool_maxsize\"] == 20\n53: \n54: \n55: class TestReadTokenFromFile:\n56:     \"\"\"Tests for read_token_from_file function.\"\"\"\n57: \n58:     def test_reads_token_from_file(self):\n59:         \"\"\"Test reading token from existing file.\"\"\"\n60:         with tempfile.NamedTemporaryFile(mode=\"w\", delete=False) as f:\n61:             f.write(\"my-secret-token\")\n62:             temp_path = f.name\n63: \n64:         try:\n65:             token = read_token_from_file(temp_path)\n66:             assert token == \"my-secret-token\"\n67:         finally:\n68:             os.unlink(temp_path)\n69: \n70:     def test_strips_whitespace(self):\n71:         \"\"\"Test that token is stripped of whitespace.\"\"\"\n72:         with tempfile.NamedTemporaryFile(mode=\"w\", delete=False) as f:\n73:             f.write(\"  token-with-spaces  \\n\")\n74:             temp_path = f.name\n75: \n76:         try:\n77:             token = read_token_from_file(temp_path)\n78:             assert token == \"token-with-spaces\"\n79:         finally:\n80:             os.unlink(temp_path)\n81: \n82:     def test_returns_empty_string_for_missing_file(self):\n83:         \"\"\"Test that missing file returns empty string.\"\"\"\n84:         token = read_token_from_file(\"/nonexistent/path/to/token\")\n85:         assert token == \"\"\n86: \n87:     def test_returns_empty_string_for_unreadable_file(self):\n88:         \"\"\"Test that unreadable file returns empty string.\"\"\"\n89:         with tempfile.NamedTemporaryFile(delete=False) as f:\n90:             temp_path = f.name\n91:             f.write(b\"token\")\n92: \n93:         try:\n94:             # Remove read permissions\n95:             os.chmod(temp_path, 0o000)\n96:             token = read_token_from_file(temp_path)\n97:             assert token == \"\"\n98:         finally:\n99:             os.chmod(temp_path, 0o644)\n100:             os.unlink(temp_path)\n101: \n102: \n103: class TestGetServiceAccountToken:\n104:     \"\"\"Tests for get_service_account_token function.\"\"\"\n105: \n106:     @mock.patch(\"agentcube.utils.http.read_token_from_file\")\n107:     def test_reads_from_service_account_path(self, mock_read):\n108:         \"\"\"Test that it reads from the service account token path.\"\"\"\n109:         mock_read.return_value = \"sa-token\"\n110:         token = get_service_account_token()\n111:         mock_read.assert_called_once_with(SERVICE_ACCOUNT_TOKEN_PATH)\n112:         assert token == \"sa-token\"\n113: \n114:     @mock.patch(\"agentcube.utils.http.read_token_from_file\")\n115:     def test_returns_none_for_empty_token(self, mock_read):\n116:         \"\"\"Test that empty token returns None.\"\"\"\n117:         mock_read.return_value = \"\"\n118:         token = get_service_account_token()\n119:         assert token is None\n120: \n121:     @mock.patch(\"agentcube.utils.http.read_token_from_file\")\n122:     def test_returns_none_for_whitespace_only_token(self, mock_read):\n123:         \"\"\"Test that whitespace-only token returns None.\"\"\"\n124:         mock_read.return_value = \"   \\n  \"\n125:         token = get_service_account_token()\n126:         assert token is None\n127: \n128:     @mock.patch(\"agentcube.utils.http.read_token_from_file\")\n129:     def test_strips_token(self, mock_read):\n130:         \"\"\"Test that token is stripped.\"\"\"\n131:         mock_read.return_value = \"  token  \"\n132:         token = get_service_account_token()\n133:         assert token == \"token\"\n\n(End of file - total 133 lines)\n</content>","metadata":{"preview":"\"\"\"Unit tests for HTTP utilities.\"\"\"\n\nimport os\nimport tempfile\nfrom unittest import mock\n\nimport pytest\nfrom requests.adapters import HTTPAdapter\n\nfrom agentcube.utils.http import (\n    SERVICE_ACCOUNT_TOKEN_PATH,\n    create_session,\n    get_service_account_token,\n    read_token_from_file,\n)\n\n\nclass TestCreateSession:\n    \"\"\"Tests for create_session function.\"\"\"\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/tests/test_utils_http.py","time":{"start":1775906773185,"end":1775906773220}}}}
