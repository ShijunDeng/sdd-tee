{"type":"tool_use","timestamp":1775906773227,"sessionID":"ses_283b61b66ffesarH0IS4Kgh6IJ","part":{"id":"prt_d7c4ad4a8001bC3dnaB8mS5xi9","messageID":"msg_d7c4ab5c6001mD4PgolxdeIwNy","sessionID":"ses_283b61b66ffesarH0IS4Kgh6IJ","type":"tool","tool":"read","callID":"toolu_functions.read:21","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/tests/test_control_plane.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/tests/test_control_plane.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Unit tests for ControlPlaneClient.\"\"\"\n2: \n3: import json\n4: from unittest import mock\n5: \n6: import pytest\n7: import responses\n8: \n9: from agentcube.clients.control_plane import ControlPlaneClient\n10: \n11: \n12: class TestControlPlaneClientInit:\n13:     \"\"\"Tests for ControlPlaneClient initialization.\"\"\"\n14: \n15:     def test_init_with_url_argument(self):\n16:         \"\"\"Test initialization with URL argument.\"\"\"\n17:         client = ControlPlaneClient(workload_manager_url=\"http://wm.example.com\")\n18:         assert client.base_url == \"http://wm.example.com\"\n19: \n20:     @mock.patch.dict(\"os.environ\", {\"WORKLOAD_MANAGER_URL\": \"http://wm.env.com\"})\n21:     def test_init_with_env_variable(self):\n22:         \"\"\"Test initialization with environment variable.\"\"\"\n23:         client = ControlPlaneClient()\n24:         assert client.base_url == \"http://wm.env.com\"\n25: \n26:     def test_init_requires_url(self):\n27:         \"\"\"Test that initialization requires URL.\"\"\"\n28:         with mock.patch.dict(\"os.environ\", {}, clear=True):\n29:             with pytest.raises(ValueError) as exc_info:\n30:                 ControlPlaneClient()\n31:             assert \"Workload Manager URL must be provided\" in str(exc_info.value)\n32: \n33:     def test_init_argument_overrides_env(self):\n34:         \"\"\"Test that argument overrides environment variable.\"\"\"\n35:         with mock.patch.dict(\"os.environ\", {\"WORKLOAD_MANAGER_URL\": \"http://wm.env.com\"}):\n36:             client = ControlPlaneClient(workload_manager_url=\"http://wm.arg.com\")\n37:             assert client.base_url == \"http://wm.arg.com\"\n38: \n39:     def test_default_timeouts(self):\n40:         \"\"\"Test default timeout values.\"\"\"\n41:         client = ControlPlaneClient(workload_manager_url=\"http://wm.example.com\")\n42:         assert client.timeout == 120\n43:         assert client.connect_timeout == 5.0\n44: \n45:     def test_custom_timeouts(self):\n46:         \"\"\"Test custom timeout values.\"\"\"\n47:         client = ControlPlaneClient(\n48:             workload_manager_url=\"http://wm.example.com\",\n49:             timeout=60,\n50:             connect_timeout=10.0,\n51:         )\n52:         assert client.timeout == 60\n53:         assert client.connect_timeout == 10.0\n54: \n55:     @mock.patch(\"agentcube.clients.control_plane.get_service_account_token\")\n56:     def test_uses_service_account_token(self, mock_get_token):\n57:         \"\"\"Test that it uses service account token when auth_token not provided.\"\"\"\n58:         mock_get_token.return_value = \"sa-token\"\n59:         client = ControlPlaneClient(workload_manager_url=\"http://wm.example.com\")\n60:         assert client.session.headers.get(\"Authorization\") == \"Bearer sa-token\"\n61: \n62:     def test_uses_provided_auth_token(self):\n63:         \"\"\"Test that it uses provided auth token.\"\"\"\n64:         client = ControlPlaneClient(\n65:             workload_manager_url=\"http://wm.example.com\",\n66:             auth_token=\"provided-token\",\n67:         )\n68:         assert client.session.headers.get(\"Authorization\") == \"Bearer provided-token\"\n69: \n70:     def test_provided_token_overrides_sa_token(self):\n71:         \"\"\"Test that provided token overrides service account token.\"\"\"\n72:         with mock.patch(\n73:             \"agentcube.clients.control_plane.get_service_account_token\",\n74:             return_value=\"sa-token\",\n75:         ):\n76:             client = ControlPlaneClient(\n77:                 workload_manager_url=\"http://wm.example.com\",\n78:                 auth_token=\"provided-token\",\n79:             )\n80:             assert client.session.headers.get(\"Authorization\") == \"Bearer provided-token\"\n81: \n82: \n83: class TestControlPlaneClientCreateSession:\n84:     \"\"\"Tests for ControlPlaneClient.create_session.\"\"\"\n85: \n86:     @responses.activate\n87:     def test_create_session_success(self):\n88:         \"\"\"Test successful session creation.\"\"\"\n89:         responses.add(\n90:             responses.POST,\n91:             \"http://wm.example.com/v1/code-interpreter\",\n92:             json={\"sessionId\": \"abc-123\"},\n93:             status=200,\n94:         )\n95: \n96:         client = ControlPlaneClient(workload_manager_url=\"http://wm.example.com\")\n97:         session_id = client.create_session(name=\"test\", namespace=\"default\")\n98: \n99:         assert session_id == \"abc-123\"\n100:         assert len(responses.calls) == 1\n101: \n102:     @responses.activate\n103:     def test_create_session_with_metadata(self):\n104:         \"\"\"Test session creation with metadata.\"\"\"\n105:         responses.add(\n106:             responses.POST,\n107:             \"http://wm.example.com/v1/code-interpreter\",\n108:             json={\"sessionId\": \"abc-123\"},\n109:             status=200,\n110:         )\n111: \n112:         client = ControlPlaneClient(workload_manager_url=\"http://wm.example.com\")\n113:         client.create_session(\n114:             name=\"test\",\n115:             namespace=\"default\",\n116:             metadata={\"key\": \"value\"},\n117:             ttl=7200,\n118:         )\n119: \n120:         request_body = json.loads(responses.calls[0].request.body)\n121:         assert request_body[\"name\"] == \"test\"\n122:         assert request_body[\"namespace\"] == \"default\"\n123:         assert request_body[\"metadata\"] == {\"key\": \"value\"}\n124:         assert request_body[\"ttl\"] == 7200\n125: \n126:     @responses.activate\n127:     def test_create_session_missing_session_id_raises(self):\n128:         \"\"\"Test that missing sessionId in response raises ValueError.\"\"\"\n129:         responses.add(\n130:             responses.POST,\n131:             \"http://wm.example.com/v1/code-interpreter\",\n132:             json={\"otherField\": \"value\"},\n133:             status=200,\n134:         )\n135: \n136:         client = ControlPlaneClient(workload_manager_url=\"http://wm.example.com\")\n137:         with pytest.raises(ValueError) as exc_info:\n138:             client.create_session(name=\"test\", namespace=\"default\")\n139:         assert \"sessionId\" in str(exc_info.value)\n140: \n141:     @responses.activate\n142:     def test_create_session_empty_session_id_raises(self):\n143:         \"\"\"Test that empty sessionId in response raises ValueError.\"\"\"\n144:         responses.add(\n145:             responses.POST,\n146:             \"http://wm.example.com/v1/code-interpreter\",\n147:             json={\"sessionId\": \"\"},\n148:             status=200,\n149:         )\n150: \n151:         client = ControlPlaneClient(workload_manager_url=\"http://wm.example.com\")\n152:         with pytest.raises(ValueError) as exc_info:\n153:             client.create_session(name=\"test\", namespace=\"default\")\n154:         assert \"sessionId\" in str(exc_info.value)\n155: \n156:     @responses.activate\n157:     def test_create_session_http_error(self):\n158:         \"\"\"Test that HTTP errors are propagated.\"\"\"\n159:         responses.add(\n160:             responses.POST,\n161:             \"http://wm.example.com/v1/code-interpreter\",\n162:             json={\"error\": \"Internal Server Error\"},\n163:             status=500,\n164:         )\n165: \n166:         client = ControlPlaneClient(workload_manager_url=\"http://wm.example.com\")\n167:         with pytest.raises(Exception):  # requests.HTTPError\n168:             client.create_session(name=\"test\", namespace=\"default\")\n169: \n170: \n171: class TestControlPlaneClientDeleteSession:\n172:     \"\"\"Tests for ControlPlaneClient.delete_session.\"\"\"\n173: \n174:     @responses.activate\n175:     def test_delete_session_success_returns_true(self):\n176:         \"\"\"Test successful deletion returns True.\"\"\"\n177:         responses.add(\n178:             responses.DELETE,\n179:             \"http://wm.example.com/v1/code-interpreter/sessions/abc-123\",\n180:             status=200,\n181:         )\n182: \n183:         client = ControlPlaneClient(workload_manager_url=\"http://wm.example.com\")\n184:         result = client.delete_session(\"abc-123\")\n185: \n186:         assert result is True\n187: \n188:     @responses.activate\n189:     def test_delete_session_404_returns_true(self):\n190:         \"\"\"Test that 404 returns True (already deleted).\"\"\"\n191:         responses.add(\n192:             responses.DELETE,\n193:             \"http://wm.example.com/v1/code-interpreter/sessions/abc-123\",\n194:             status=404,\n195:         )\n196: \n197:         client = ControlPlaneClient(workload_manager_url=\"http://wm.example.com\")\n198:         result = client.delete_session(\"abc-123\")\n199: \n200:         assert result is True\n201: \n202:     @responses.activate\n203:     def test_delete_session_error_returns_false(self):\n204:         \"\"\"Test that other errors return False.\"\"\"\n205:         responses.add(\n206:             responses.DELETE,\n207:             \"http://wm.example.com/v1/code-interpreter/sessions/abc-123\",\n208:             status=500,\n209:         )\n210: \n211:         client = ControlPlaneClient(workload_manager_url=\"http://wm.example.com\")\n212:         result = client.delete_session(\"abc-123\")\n213: \n214:         assert result is False\n215: \n216: \n217: class TestControlPlaneClientContextManager:\n218:     \"\"\"Tests for ControlPlaneClient context manager.\"\"\"\n219: \n220:     def test_context_manager_closes_session(self):\n221:         \"\"\"Test that context manager closes the session.\"\"\"\n222:         client = ControlPlaneClient(workload_manager_url=\"http://wm.example.com\")\n223: \n224:         with mock.patch.object(client.session, \"close\") as mock_close:\n225:             with client:\n226:                 pass\n227:             mock_close.assert_called_once()\n228: \n229:     def test_context_manager_closes_on_exception(self):\n230:         \"\"\"Test that context manager closes even on exception.\"\"\"\n231:         client = ControlPlaneClient(workload_manager_url=\"http://wm.example.com\")\n232: \n233:         with mock.patch.object(client.session, \"close\") as mock_close:\n234:             with pytest.raises(ValueError):\n235:                 with client:\n236:                     raise ValueError(\"Test error\")\n237:             mock_close.assert_called_once()\n238: \n239: \n240: class TestControlPlaneClientClose:\n241:     \"\"\"Tests for ControlPlaneClient.close.\"\"\"\n242: \n243:     def test_close_closes_session(self):\n244:         \"\"\"Test that close closes the HTTP session.\"\"\"\n245:         client = ControlPlaneClient(workload_manager_url=\"http://wm.example.com\")\n246: \n247:         with mock.patch.object(client.session, \"close\") as mock_close:\n248:             client.close()\n249:             mock_close.assert_called_once()\n\n(End of file - total 249 lines)\n</content>","metadata":{"preview":"\"\"\"Unit tests for ControlPlaneClient.\"\"\"\n\nimport json\nfrom unittest import mock\n\nimport pytest\nimport responses\n\nfrom agentcube.clients.control_plane import ControlPlaneClient\n\n\nclass TestControlPlaneClientInit:\n    \"\"\"Tests for ControlPlaneClient initialization.\"