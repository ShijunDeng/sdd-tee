ce}/codeinterpreters/{name}` | Delete |\n371: | GET | `/apis/runtime.agentcube.volcano.sh/v1alpha1/namespaces/{namespace}/codeinterpreters/{name}/status` | Get Status |\n372: | PUT | `/apis/runtime.agentcube.volcano.sh/v1alpha1/namespaces/{namespace}/codeinterpreters/{name}/status` | Update Status |\n373: \n374: ### Generic Resource Routing\n375: \n376: ```go\n377: // ForResource returns a GenericInformer for the specified resource.\n378: func (f *sharedInformerFactory) ForResource(resource schema.GroupVersionResource) (GenericInformer, error) {\n379:     switch resource {\n380:     case v1alpha1.SchemeGroupVersion.WithResource(\"agentruntimes\"):\n381:         return &genericInformer{resource: resource.GroupResource(), informer: f.Runtime().V1alpha1().AgentRuntimes().Informer()}, nil\n382:     case v1alpha1.SchemeGroupVersion.WithResource(\"codeinterpreters\"):\n383:         return &genericInformer{resource: resource.GroupResource(), informer: f.Runtime().V1alpha1().CodeInterpreters().Informer()}, nil\n384:     default:\n385:         return nil, fmt.Errorf(\"no informer found for %v\", resource)\n386:     }\n387: }\n388: ```\n389: \n390: ---\n391: \n392: ## Error Handling\n393: \n394: ### Error Categories\n395: \n396: | Category | Source | Handling Strategy |\n397: |----------|--------|-------------------|\n398: | **Connection Errors** | REST client, network layer | Retry with exponential backoff |\n399: | **API Errors** | Kubernetes API server | Check error type with `apierrors` helpers |\n400: | **Validation Errors** | API server validation | Return 422, examine error details |\n401: | **Not Found** | Resource doesn't exist | Check `apierrors.IsNotFound(err)` |\n402: | **Conflict** | Resource version mismatch | Retry after re-fetching resource |\n403: | **Forbidden** | RBAC denied | Log and alert, escalate permissions |\n404: \n405: ### Error Handling Patterns\n406: \n407: #### Typed Client Error Handling\n408: \n409: ```go\n410: // Example: Handling errors from AgentRuntime client\n411: func (c *Controller) reconcileAgentRuntime(ctx context.Context, name, namespace string) error {\n412:     ar, err := c.client.AgentRuntimes(namespace).Get(ctx, name, metav1.GetOptions{})\n413:     if err != nil {\n414:         if apierrors.IsNotFound(err) {\n415:             // Resource was deleted - clean up\n416:             return c.handleDeleted(name)\n417:         }\n418:         if apierrors.IsTimeout(err) {\n419:             // Temporary error - retry later\n420:             return fmt.Errorf(\"timeout fetching AgentRuntime: %w\", err)\n421:         }\n422:         // Other errors - wrap and return\n423:         return fmt.Errorf(\"failed to get AgentRuntime: %w\", err)\n424:     }\n425: \n426:     // Process the resource\n427:     return c.processAgentRuntime(ar)\n428: }\n429: ```\n430: \n431: #### Informer Error Handling\n432: \n433: ```go\n434: // Example: Setting up error handlers for informers\n435: func (c *Controller) setupInformers() {\n436:     agentRuntimeInformer := c.informerFactory.Runtime().V1alpha1().AgentRuntimes().Informer()\n437:     \n438:     // Add event handlers\n439:     agentRuntimeInformer.AddEventHandler(cache.ResourceEventHandlerFuncs{\n440:         AddFunc: c.onAgentRuntimeAdd,\n441:         UpdateFunc: c.onAgentRuntimeUpdate,\n442:         DeleteFunc: c.onAgentRuntimeDelete,\n443:     })\n444: \n445:     // Handle informer errors\n446:     agentRuntimeInformer.SetWatchErrorHandler(func(r *cache.Reflector, err error) {\n447:         klog.Errorf(\"AgentRuntime watch error: %v\", err)\n448:         // Metrics and alerting\n449:         metrics.RecordWatchError(\"agentruntime\", err)\n450:     })\n451: }\n452: ```\n453: \n454: #### Lister Error Handling\n455: \n456: ```go\n457: // Example: Handling lister errors (should be rare, usually cache is synced)\n458: func (c *Controller) listAgentRuntimes(selector labels.Selector) ([]*v1alpha1.AgentRuntime, error) {\n459:     runtimes, err := c.agentRuntimeLister.List(selector)\n460:     if err != nil {\n461:         // This is typically a programming error or cache not synced\n462:         return nil, fmt.Errorf(\"failed to list AgentRuntimes from cache: %w\", err)\n463:     }\n464:     return runtimes, nil\n465: }\n466: ```\n467: \n468: ### Error Propagation Best Practices\n469: \n470: 1. **Always wrap errors** with context using `fmt.Errorf(\"...: %w\", err)`\n471: 2. **Check specific error types** using `apierrors` helpers before wrapping\n472: 3. **Log at appropriate levels** - debug for retryable, error for permanent\n473: 4. **Use structured logging** with resource identifiers\n474: 5. **Return early** on unrecoverable errors\n475: \n476: ---\n477: \n478: ## Testing Strategy\n479: \n480: ### Unit Tests\n481: \n482: #### Fake Clientset Tests\n483: \n484: ```go\n485: // Test using fake clientset for AgentRuntime operations\n486: func TestAgentRuntimeCreate(t *testing.T) {\n487:     // Create fake clientset\n488:     client := fake.NewSimpleClientset()\n489: \n490:     // Create a test AgentRuntime\n491:     ar := &v1alpha1.AgentRuntime{\n492:         ObjectMeta: metav1.ObjectMeta{\n493:             Name:      \"test-ar\",\n494:             Namespace: \"default\",\n495:         },\n496:         Spec: v1alpha1.AgentRuntimeSpec{\n497:             Image: \"agent:latest\",\n498:         },\n499:     }\n500: \n501:     // Create the resource\n502:     created, err := client.RuntimeV1alpha1().AgentRuntimes(\"default\").Create(context.Background(), ar, metav1.CreateOptions{})\n503:     require.NoError(t, err)\n504:     assert.Equal(t, \"test-ar\", created.Name)\n505:     assert.Equal(t, \"agent:latest\", created.Spec.Image)\n506: \n507:     // Verify it exists\n508:     fetched, err := client.RuntimeV1alpha1().AgentRuntimes(\"default\").Get(context.Background(), \"test-ar\", metav1.GetOptions{})\n509:     require.NoError(t, err)\n510:     assert.Equal(t, created.UID, fetched.UID)\n511: }\n512: ```\n513: \n514: #### Fake Lister Tests\n515: \n516: ```go\n517: // Test using fake listers\n518: func TestAgentRuntimeLister(t *testing.T) {\n519:     // Create fake objects\n520:     ar1 := &v1alpha1.AgentRuntime{ObjectMeta: metav1.ObjectMeta{Name: \"ar1\", Namespace: \"ns1\"}}\n521:     ar2 := &v1alpha1.AgentRuntime{ObjectMeta: metav1.ObjectMeta{Name: \"ar2\", Namespace: \"ns1\"}}\n522:     ar3 := &v1alpha1.AgentRuntime{ObjectMeta: metav1.ObjectMeta{Name: \"ar3\", Namespace: \"ns2\"}}\n523: \n524:     // Create indexer\n525:     indexer := cache.NewIndexer(cache.MetaNamespaceKeyFunc, cache.Indexers{cache.NamespaceIndex: cache.MetaNamespaceIndexFunc})\n526:     indexer.Add(ar1)\n527:     indexer.Add(ar2)\n528:     indexer.Add(ar3)\n529: \n530:     // Create lister\n531:     lister := runtimev1alpha1.NewAgentRuntimeLister(indexer)\n532: \n533:     // Test List all\n534:     all, err := lister.List(labels.Everything())\n535:     require.NoError(t, err)\n536:     assert.Len(t, all, 3)\n537: \n538:     // Test List by namespace\n539:     ns1Runtimes, err := lister.AgentRuntimes(\"ns1\").List(labels.Everything())\n540:     require.NoError(t, err)\n541:     assert.Len(t, ns1Runtimes, 2)\n542: \n543:     // Test Get\n544:     ar, err := lister.AgentRuntimes(\"ns1\").Get(\"ar1\")\n545:     require.NoError(t, err)\n546:     assert.Equal(t, \"ar1\", ar.Name)\n547: }\n548: ```\n549: \n550: ### Integration Tests\n551: \n552: ```go\n553: // Integration test using real API server (envtest)\n554: func TestAgentRuntimeLifecycle(t *testing.T) {\n555:     // Setup envtest\n556:     testEnv := &envtest.Environment{\n557:         CRDDirectoryPaths: []string{\"../../config/crd/bases\"},\n558:     }\n559:     cfg, err := testEnv.Start()\n560:     require.NoError(t, err)\n561:     defer testEnv.Stop()\n562: \n563:     // Create clientset\n564:     client, err := clientset.NewForConfig(cfg)\n565:     require.NoError(t, err)\n566: \n567:     ctx := context.Background()\n568: \n569:     // Create namespace\n570:     k8sClient, err := kubernetes.NewForConfig(cfg)\n571:     require.NoError(t, err)\n572:     _, err = k8sClient.CoreV1().Namespaces().Create(ctx, &corev1.Namespace{\n573:         ObjectMeta: metav1.ObjectMeta{Name: \"test-ns\"},\n574:     }, metav1.CreateOptions{})\n575:     require.NoError(t, err)\n576: \n577:     // Create AgentRuntime\n578:     ar := &v1alpha1.AgentRuntime{\n579:         ObjectMeta: metav1.ObjectMeta{\n580:             Name:      \"test-ar\",\n581:             Namespace: \"test-ns\",\n582:         },\n583:         Spec: v1alpha1.AgentRuntimeSpec{\n584:             Image: \"test-image:latest\",\n585:         },\n586:     }\n587:     created, err := client.RuntimeV1alpha1().AgentRuntimes(\"test-ns\").Create(ctx, ar, metav1.CreateOptions{})\n588:     require.NoError(t, err)\n589: \n590:     // Update status\n591:     created.Status.Phase = v1alpha1.AgentRuntimePhaseRunning\n592:     updated, err := client.RuntimeV1alpha1().AgentRuntimes(\"test-ns\").UpdateStatus(ctx, created, metav1.UpdateOptions{})\n593:     require.NoError(t, err)\n594:     assert.Equal(t, v1alpha1.AgentRuntimePhaseRunning, updated.Status.Phase)\n595: \n596:     // Delete\n597:     err = client.RuntimeV1alpha1().AgentRuntimes(\"test-ns\").Delete(ctx, \"test-ar\", metav1.DeleteOptions{})\n598:     require.NoError(t, err)\n599: \n600:     // Verify deletion\n601:     _, err = client.RuntimeV1alpha1().AgentRuntimes(\"test-ns\").Get(ctx, \"test-ar\", metav1.GetOptions{})\n602:     assert.True(t, apierrors.IsNotFound(err))\n603: }\n604: ```\n605: \n606: ### Code Generation Verification\n607: \n608: ```bash\n609: #!/bin/bash\n610: # verify-codegen.sh\n611: \n612: set -e\n613: \n614: echo \"=== Verifying client-go code generation ===\"\n615: \n616: # Generate code\n617: echo \"Running code generation...\"\n618: make gen-client\n619: \n620: # Build to verify compilation\n621: echo \"Building generated code...\"\n622: go build ./client-go/...\n623: \n624: # Run tests\n625: echo \"Running client-go tests...\"\n626: go test ./client-go/...\n627: \n628: # Check for uncommitted changes\n629: if [[ -n $(git status --porcelain client-go/) ]]; then\n630:     echo \"ERROR: Generated code is out of date. Run 'make gen-client' and commit changes.\"\n631:     git diff client-go/\n632:     exit 1\n633: fi\n634: \n635: echo \"=== Verification passed ===\"\n636: ```\n637: \n638: ### Test Coverage Requirements\n639: \n640: | Component | Coverage Target | Testing Method |\n641: |-----------|-----------------|----------------|\n642: | Clientset Interface | 90%+ | Unit tests with fakes |\n643: | Typed Clients | 85%+ | Unit tests with fakes |\n644: | Scheme Registration | 100% | Integration tests |\n645: | Informers | 80%+ | Integration tests |\n646: | Listers | 100% | Unit tests with fake indexers |\n647: | Fake Clientset | 100% | Self-testing via usage |\n648: \n649: ### Continuous Integration\n650: \n651: ```yaml\n652: # .github/workflows/client-go.yaml\n653: name: client-go\n654: \n655: on:\n656:   push:\n657:     paths:\n658:       - 'pkg/apis/**'\n659:       - 'client-go/**'\n660:       - 'hack/**'\n661:   pull_request:\n662:     paths:\n663:       - 'pkg/apis/**'\n664:       - 'client-go/**'\n665:       - 'hack/**'\n666: \n667: jobs:\n668:   verify:\n669:     runs-on: ubuntu-latest\n670:     steps:\n671:       - uses: actions/checkout@v4\n672: \n673:       - name: Set up Go\n674:         uses: actions/setup-go@v5\n675:         with:\n676:           go-version: '1.23'\n677: \n678:       - name: Verify code generation\n679:         run: make verify-codegen\n680: \n681:       - name: Build client-go\n682:         run: go build ./client-go/...\n683: \n684:       - name: Test client-go\n685:         run: go test -v -race ./client-go/...\n686: \n687:       - name: Test with real types\n688:         run: go test -v ./pkg/apis/runtime/v1alpha1/...\n689: ```\n690: \n691: ---\n692: \n693: ## File Layout\n694: \n695: ```\n696: client-go/\n697: ├── clientset/\n698: │   └── versioned/\n699: │       ├── clientset.go                    # Clientset struct and Interface\n700: │       ├── scheme/\n701: │       │   ├── doc.go                      # Package documentation\n702: │       │   └── register.go                 # Scheme registration\n703: │       ├── typed/\n704: │       │   └── runtime/\n705: │       │       └── v1alpha1/\n706: │       │           ├── doc.go              # Package documentation\n707: │       │           ├── runtime_client.go   # RuntimeV1alpha1Client\n708: │       │           ├── agentruntime.go     # AgentRuntimeInterface\n709: │       │           ├── codeinterpreter.go  # CodeInterpreterInterface\n710: │       │           ├── generated_expansion.go  # Expansion interfaces\n711: │       │           └── fake/\n712: │       │               ├── doc.go\n713: │       │               ├── fake_runtime_client.go\n714: │       │               ├── fake_agentruntime.go\n715: │       │               └── fake_codeinterpreter.go\n716: │       └── fake/\n717: │           ├── doc.go\n718: │           ├── clientset_generated.go      # Fake Clientset\n719: │           └── register.go\n720: ├── informers/\n721: │   └── externalversions/\n722: │       ├── factory.go                      # SharedInformerFactory\n723: │       ├── generic.go                      # Generic informer routing\n724: │       ├── internalinterfaces/\n725: │       │   └── factory_interfaces.go       # Internal interfaces\n726: │       └── runtime/\n727: │           ├── interface.go                # Group interface\n728: │           └── v1alpha1/\n729: │               ├── interface.go            # Version interface\n730: │               ├── agentruntime.go         # AgentRuntimeInformer\n731: │               └── codeinterpreter.go      # CodeInterpreterInformer\n732: └── listers/\n733:     └── runtime/\n734:         └── v1alpha1/\n735:             ├── agentruntime.go             # AgentRuntimeLister\n736:             ├── codeinterpreter.go          # CodeInterpreterLister\n737:             └── expansion_generated.go      # Lister expansion interfaces\n738: ```\n739: \n740: ---\n741: \n742: ## Code Generation\n743: \n744: ### Generation Tool: k8s.io/code-generator\n745: \n746: ```bash\n747: # Makefile target for client generation\n748: gen-client:\n749:     ./hack/update-codegen.sh\n750: \n751: # Verification target\n752: verify-codegen:\n753:     ./hack/verify-codegen.sh\n754: ```\n755: \n756: ### Generation Script\n757: \n758: ```bash\n759: #!/bin/bash\n760: # hack/update-codegen.sh\n761: \n762: set -euo pipefail\n763: \n764: SCRIPT_ROOT=$(dirname \"${BASH_SOURCE[0]}\")/..\n765: CODEGEN_PKG=${CODEGEN_PKG:-$(cd \"${SCRIPT_ROOT}\"; go list -m -f '{{.Dir}}' k8s.io/code-generator)}\n766: \n767: # Generate clientset, informers, listers\n768: \"${CODEGEN_PKG}/generate-groups.sh\" \\\n769:     \"client,informer,lister\" \\\n770:     github.com/volcano-sh/agentcube/client-go \\\n771:     github.com/volcano-sh/agentcube/pkg/apis \\\n772:     \"runtime:v1alpha1\" \\\n773:     --go-header-file \"${SCRIPT_ROOT}/hack/boilerplate.go.txt\" \\\n774:     --output-base \"${SCRIPT_ROOT}\" \\\n775:     --with-watch\n776: ```\n777: \n778: ### Generation Parameters\n779: \n780: | Parameter | Value | Description |\n781: |-----------|-------|-------------|\n782: | Generators | `client,informer,lister` | What to generate |\n783: | Output Package | `github.com/volcano-sh/agentcube/client-go` | Go import path |\n784: | API Package | `github.com/volcano-sh/agentcube/pkg/apis` | Source types location |\n785: | Groups | `runtime:v1alpha1` | Group:version pairs |\n786: | Flags | `--with-watch` | Enable Watch support |\n787: \n788: ---\n789: \n790: ## Dependencies\n791: \n792: | Dependency | Version | Purpose |\n793: |------------|---------|---------|\n794: | `k8s.io/apimachinery` | `v0.34.1` | TypeMeta, ObjectMeta, runtime.Object |\n795: | `k8s.io/client-go` | `v0.34.1` | REST client, informers, listers |\n796: | `k8s.io/code-generator` | `v0.34.1` | Code generation tools |\n797: | `github.com/volcano-sh/agentcube/pkg/apis` | Local | Source API types |\n798: \n799: ---\n800: \n801: ## Design Decisions\n802: \n803: ### 1. Separate client-go Module\n804: \n805: **Decision**: Place generated code in `client-go/` directory with its own go.mod (optional).\n806: \n807: **Rationale**:\n808: - Consumers can depend only on the client without pulling in controller dependencies\n809: - Aligns with Kubernetes ecosystem conventions (e.g., `k8s.io/client-go`)\n810: - Cleaner dependency graph for external tools\n811: \n812: ### 2. Standard Code Generator\n813: \n814: **Decision**: Use `k8s.io/code-generator` instead of custom tooling.\n815: \n816: **Rationale**:\n817: - Industry standard for Kubernetes CRD clients\n818: - Automatic updates with Kubernetes version bumps\n819: - Well-tested and maintained by the community\n820: - Supports all required features (watch, informers, listers)\n821: \n822: ### 3. Expansion Interfaces\n823: \n824: **Decision**: Generate empty expansion interfaces for all typed clients and listers.\n825: \n826: **Rationale**:\n827: - Allows extending generated interfaces without modifying generated code\n828: - Follows Kubernetes client-go pattern\n829: - Enables custom helper methods while maintaining interface compatibility\n830: \n831: ### 4. Fake Clientset\n832: \n833: **Decision**: Include complete fake implementation for all interfaces.\n834: \n835: **Rationale**:\n836: - Essential for unit testing controllers\n837: - Provides in-memory object tracking\n838: - Supports all CRUD operations including Watch\n839: - No external dependencies required for testing\n840: \n841: ---\n842: \n843: ## References\n844: \n845: - [Kubernetes client-go](https://github.com/kubernetes/client-go)\n846: - [code-generator](https://github.com/kubernetes/code-generator)\n847: - [sample-controller](https://github.com/kubernetes/sample-controller) - Example usage pattern\n848: - [Kubernetes Custom Resources](https://kubernetes.io/docs/concepts/extend-kubernetes/api-extension/custom-resources/)\n849: \n850: ---\n851: \n852: ## Change Log\n853: \n854: | Version | Date | Changes |\n855: |---------|------|---------|\n856: | 1.0 | 2026-04-11 | Initial design for AR-003 client-go library |\n\n(End of file - total 856 lines)\n</content>","metadata":{"preview":"# AR-003 Design: CRD Shared Types and Constants (client-go)\n\n## Overview\n\n**AR ID:** AR-003  \n**Module:** `pkg/apis`  \n**Language:** Go  \n**Size:** Small  \n\nGenerate the Kubernetes client-go library for the API group `runtime.agentcube.volcano.sh/v1alpha1`. The generated client provides programmatic access to `AgentRuntime` and `CodeInterpreter` CRDs, including typed clients, informers, and listers.\n\n---\n\n## Architecture\n\n### High-Level Design\n\nThe client-go library follows the standard Kubernetes code-generation pattern, providing a layered architecture for interacting with custom resources:\n\n```","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/design.md","time":{"start":1775842061124,"end":1775842061143}}}}
