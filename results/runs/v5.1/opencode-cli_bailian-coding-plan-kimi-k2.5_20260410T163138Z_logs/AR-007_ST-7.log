ference{\n38: \t\tAPIVersion:         apiVersion,\n39: \t\tKind:               kind,\n40: \t\tName:               owner.GetName(),\n41: \t\tUID:                owner.GetUID(),\n42: \t\tController:         &trueVal,\n43: \t\tBlockOwnerDeletion: &trueVal,\n44: \t}, nil\n45: }\n46: \n47: // NewOwnerReferenceFromObject creates an OwnerReference from a runtime object.\n48: func NewOwnerReferenceFromObject(owner runtime.Object, scheme *runtime.Scheme, ownerMeta metav1.Object) (*metav1.OwnerReference, error) {\n49: \tif owner == nil || scheme == nil || ownerMeta == nil {\n50: \t\treturn nil, nil\n51: \t}\n52: \n53: \tgvks, _, err := scheme.ObjectKinds(owner)\n54: \tif err != nil {\n55: \t\treturn nil, err\n56: \t}\n57: \n58: \tif len(gvks) == 0 {\n59: \t\treturn nil, nil\n60: \t}\n61: \n62: \tgvk := gvks[0]\n63: \ttrueVal := true\n64: \n65: \treturn &metav1.OwnerReference{\n66: \t\tAPIVersion:         gvk.GroupVersion().String(),\n67: \t\tKind:               gvk.Kind,\n68: \t\tName:               ownerMeta.GetName(),\n69: \t\tUID:                ownerMeta.GetUID(),\n70: \t\tController:         &trueVal,\n71: \t\tBlockOwnerDeletion: &trueVal,\n72: \t}, nil\n73: }\n74: \n75: // SetOwnerReference sets the OwnerReference on the object.\n76: // If an OwnerReference with the same UID already exists, it will be replaced.\n77: func SetOwnerReference(obj metav1.Object, ownerRef *metav1.OwnerReference) {\n78: \tif obj == nil || ownerRef == nil {\n79: \t\treturn\n80: \t}\n81: \n82: \trefs := obj.GetOwnerReferences()\n83: \n84: \t// Check if an OwnerReference with the same UID already exists\n85: \tfor i, ref := range refs {\n86: \t\tif ref.UID == ownerRef.UID {\n87: \t\t\trefs[i] = *ownerRef\n88: \t\t\tobj.SetOwnerReferences(refs)\n89: \t\t\treturn\n90: \t\t}\n91: \t}\n92: \n93: \t// Add new OwnerReference\n94: \trefs = append(refs, *ownerRef)\n95: \tobj.SetOwnerReferences(refs)\n96: }\n97: \n98: // HasOwnerReference checks if the object has an OwnerReference with the given UID.\n99: func HasOwnerReference(obj metav1.Object, ownerUID types.UID) bool {\n100: \tif obj == nil || ownerUID == \"\" {\n101: \t\treturn false\n102: \t}\n103: \n104: \trefs := obj.GetOwnerReferences()\n105: \tfor _, ref := range refs {\n106: \t\tif ref.UID == ownerUID {\n107: \t\t\treturn true\n108: \t\t}\n109: \t}\n110: \treturn false\n111: }\n112: \n113: // HasControllerOwner checks if the object has a controller owner reference.\n114: func HasControllerOwner(obj metav1.Object) bool {\n115: \tif obj == nil {\n116: \t\treturn false\n117: \t}\n118: \n119: \trefs := obj.GetOwnerReferences()\n120: \tfor _, ref := range refs {\n121: \t\tif ref.Controller != nil && *ref.Controller {\n122: \t\t\treturn true\n123: \t\t}\n124: \t}\n125: \treturn false\n126: }\n127: \n128: // GetControllerOwner returns the controller OwnerReference, or nil if none exists.\n129: func GetControllerOwner(obj metav1.Object) *metav1.OwnerReference {\n130: \tif obj == nil {\n131: \t\treturn nil\n132: \t}\n133: \n134: \trefs := obj.GetOwnerReferences()\n135: \tfor _, ref := range refs {\n136: \t\tif ref.Controller != nil && *ref.Controller {\n137: \t\t\treturn &ref\n138: \t\t}\n139: \t}\n140: \treturn nil\n141: }\n142: \n143: // RemoveOwnerReference removes the OwnerReference with the given UID from the object.\n144: // Returns true if an OwnerReference was removed.\n145: func RemoveOwnerReference(obj metav1.Object, ownerUID types.UID) bool {\n146: \tif obj == nil || ownerUID == \"\" {\n147: \t\treturn false\n148: \t}\n149: \n150: \trefs := obj.GetOwnerReferences()\n151: \tfor i, ref := range refs {\n152: \t\tif ref.UID == ownerUID {\n153: \t\t\t// Remove this reference\n154: \t\t\tnewRefs := append(refs[:i], refs[i+1:]...)\n155: \t\t\tobj.SetOwnerReferences(newRefs)\n156: \t\t\treturn true\n157: \t\t}\n158: \t}\n159: \treturn false\n160: }\n161: \n162: // IsOwnedBy checks if the dependent object is owned by the owner object.\n163: func IsOwnedBy(dependent metav1.Object, ownerUID types.UID) bool {\n164: \tif dependent == nil || ownerUID == \"\" {\n165: \t\treturn false\n166: \t}\n167: \n168: \treturn HasOwnerReference(dependent, ownerUID)\n169: }\n170: \n171: // GetOwnerUIDs returns all owner UIDs for the object.\n172: func GetOwnerUIDs(obj metav1.Object) []types.UID {\n173: \tif obj == nil {\n174: \t\treturn nil\n175: \t}\n176: \n177: \trefs := obj.GetOwnerReferences()\n178: \tuids := make([]types.UID, len(refs))\n179: \tfor i, ref := range refs {\n180: \t\tuids[i] = ref.UID\n181: \t}\n182: \treturn uids\n183: }\n\n(End of file - total 183 lines)\n</content>","metadata":{"preview":"/*\nCopyright 2026 The Volcano Authors.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\npackage controller\n\nimport (\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/workloadmanager/controller/ownerref.go","time":{"start":1775853427986,"end":1775853428006}}}}
{"type":"tool_use","timestamp":1775853428010,"sessionID":"ses_286e3dfd6ffeQx7CUBHQTDRBo3","part":{"id":"prt_d791cd89c001xL7k4jwEPPcmpE","messageID":"msg_d791caa060012cH0xpkh5bSVCW","sessionID":"ses_286e3dfd6ffeQx7CUBHQTDRBo3","type":"tool","tool":"read","callID":"toolu_functions.read:20","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/workloadmanager/controller/conditions.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/workloadmanager/controller/conditions.go</path>\n<type>file</type>\n<content>\n1: /*\n2: Copyright 2026 The Volcano Authors.\n3: \n4: Licensed under the Apache License, Version 2.0 (the \"License\");\n5: you may not use this file except in compliance with the License.\n6: You may obtain a copy of the License at\n7: \n8:     http://www.apache.org/licenses/LICENSE-2.0\n9: \n10: Unless required by applicable law or agreed to in writing, software\n11: distributed under the License is distributed on an \"AS IS\" BASIS,\n12: WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n13: See the License for the specific language governing permissions and\n14: limitations under the License.\n15: */\n16: \n17: package controller\n18: \n19: import (\n20: \tcorev1 \"k8s.io/api/core/v1\"\n21: \tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n22: \n23: \truntimev1alpha1 \"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1\"\n24: )\n25: \n26: // SetCondition updates or adds a condition to the conditions slice.\n27: // Updates existing condition if type matches.\n28: // Appends new condition if type doesn't exist.\n29: // Updates LastTransitionTime only when status changes.\n30: // Returns true if condition was modified.\n31: func SetCondition(conditions *[]runtimev1alpha1.Condition, condition runtimev1alpha1.Condition) bool {\n32: \tif conditions == nil {\n33: \t\treturn false\n34: \t}\n35: \n36: \tnow := metav1.Now()\n37: \n38: \tfor i, existing := range *conditions {\n39: \t\tif existing.Type == condition.Type {\n40: \t\t\t// Update existing condition\n41: \t\t\tif existing.Status != condition.Status {\n42: \t\t\t\tcondition.LastTransitionTime = now\n43: \t\t\t} else {\n44: \t\t\t\tcondition.LastTransitionTime = existing.LastTransitionTime\n45: \t\t\t}\n46: \t\t\t// Preserve ObservedGeneration if not set\n47: \t\t\tif condition.ObservedGeneration == 0 {\n48: \t\t\t\tcondition.ObservedGeneration = existing.ObservedGeneration\n49: \t\t\t}\n50: \t\t\t(*conditions)[i] = condition\n51: \t\t\treturn true\n52: \t\t}\n53: \t}\n54: \n55: \t// Add new condition\n56: \tcondition.LastTransitionTime = now\n57: \t*conditions = append(*conditions, condition)\n58: \treturn true\n59: }\n60: \n61: // GetCondition returns the condition with the given type, or nil if not found.\n62: func GetCondition(conditions []runtimev1alpha1.Condition, conditionType runtimev1alpha1.ConditionType) *runtimev1alpha1.Condition {\n63: \tfor i, condition := range conditions {\n64: \t\tif condition.Type == conditionType {\n65: \t\t\treturn &conditions[i]\n66: \t\t}\n67: \t}\n68: \treturn nil\n69: }\n70: \n71: // RemoveCondition removes the condition with the given type from the conditions slice.\n72: // Returns true if condition was removed.\n73: func RemoveCondition(conditions *[]runtimev1alpha1.Condition, conditionType runtimev1alpha1.ConditionType) bool {\n74: \tif conditions == nil {\n75: \t\treturn false\n76: \t}\n77: \n78: \tfor i, condition := range *conditions {\n79: \t\tif condition.Type == conditionType {\n80: \t\t\t*conditions = append((*conditions)[:i], (*conditions)[i+1:]...)\n81: \t\t\treturn true\n82: \t\t}\n83: \t}\n84: \treturn false\n85: }\n86: \n87: // IsConditionTrue checks if the condition with the given type has status True.\n88: func IsConditionTrue(conditions []runtimev1alpha1.Condition, conditionType runtimev1alpha1.ConditionType) bool {\n89: \tcondition := GetCondition(conditions, conditionType)\n90: \tif condition == nil {\n91: \t\treturn false\n92: \t}\n93: \treturn condition.Status == corev1.ConditionTrue\n94: }\n95: \n96: // IsConditionFalse checks if the condition with the given type has status False.\n97: func IsConditionFalse(conditions []runtimev1alpha1.Condition, conditionType runtimev1alpha1.ConditionType) bool {\n98: \tcondition := GetCondition(conditions, conditionType)\n99: \tif condition == nil {\n100: \t\treturn false\n101: \t}\n102: \treturn condition.Status == corev1.ConditionFalse\n103: }\n104: \n105: // IsConditionUnknown checks if the condition with the given type has status Unknown.\n106: func IsConditionUnknown(conditions []runtimev1alpha1.Condition, conditionType runtimev1alpha1.ConditionType) bool {\n107: \tcondition := GetCondition(conditions, conditionType)\n108: \tif condition == nil {\n109: \t\treturn true\n110: \t}\n111: \treturn condition.Status == corev1.ConditionUnknown\n112: }\n113: \n114: // NewCondition creates a new condition with the given parameters.\n115: func NewCondition(\n116: \tconditionType runtimev1alpha1.ConditionType,\n117: \tstatus corev1.ConditionStatus,\n118: \treason string,\n119: \tmessage string,\n120: ) runtimev1alpha1.Condition {\n121: \treturn runtimev1alpha1.Condition{\n122: \t\tType:               conditionType,\n123: \t\tStatus:             status,\n124: \t\tLastTransitionTime: metav1.Now(),\n125: \t\tReason:             reason,\n126: \t\tMessage:            message,\n127: \t}\n128: }\n129: \n130: // SetStatusConditionTrue sets a condition to True with the given type.\n131: // Returns true if the condition was modified.\n132: func SetStatusConditionTrue(\n133: \tconditions *[]runtimev1alpha1.Condition,\n134: \tconditionType runtimev1alpha1.ConditionType,\n135: \treason string,\n136: \tmessage string,\n137: ) bool {\n138: \tcondition := NewCondition(conditionType, corev1.ConditionTrue, reason, message)\n139: \treturn SetCondition(conditions, condition)\n140: }\n141: \n142: // SetStatusConditionFalse sets a condition to False with the given type.\n143: // Returns true if the condition was modified.\n144: func SetStatusConditionFalse(\n145: \tconditions *[]runtimev1alpha1.Condition,\n146: \tconditionType runtimev1alpha1.ConditionType,\n147: \treason string,\n148: \tmessage string,\n149: ) bool {\n150: \tcondition := NewCondition(conditionType, corev1.ConditionFalse, reason, message)\n151: \treturn SetCondition(conditions, condition)\n152: }\n153: \n154: // SetStatusConditionUnknown sets a condition to Unknown with the given type.\n155: // Returns true if the condition was modified.\n156: func SetStatusConditionUnknown(\n157: \tconditions *[]runtimev1alpha1.Condition,\n158: \tconditionType runtimev1alpha1.ConditionType,\n159: \treason string,\n160: \tmessage string,\n161: ) bool {\n162: \tcondition := NewCondition(conditionType, corev1.ConditionUnknown, reason, message)\n163: \treturn SetCondition(conditions, condition)\n164: }\n165: \n166: // UpdateConditionObservedGeneration updates the ObservedGeneration for all conditions.\n167: func UpdateConditionObservedGeneration(conditions *[]runtimev1alpha1.Condition, observedGeneration int64) {\n168: \tif conditions == nil {\n169: \t\treturn\n170: \t}\n171: \n172: \tfor i := range *conditions {\n173: \t\t(*conditions)[i].ObservedGeneration = observedGeneration\n174: \t}\n175: }\n176: \n177: // FindConditionStatus returns the status of the condition with the given type.\n178: // Returns Unknown if the condition is not found.\n179: func FindConditionStatus(conditions []runtimev1alpha1.Condition, conditionType runtimev1alpha1.ConditionType) corev1.ConditionStatus {\n180: \tcondition := GetCondition(conditions, conditionType)\n181: \tif condition == nil {\n182: \t\treturn corev1.ConditionUnknown\n183: \t}\n184: \treturn condition.Status\n185: }\n186: \n187: // CountConditionsByStatus returns the number of conditions with the given status.\n188: func CountConditionsByStatus(conditions []runtimev1alpha1.Condition, status corev1.ConditionStatus) int {\n189: \tcount := 0\n190: \tfor _, condition := range conditions {\n191: \t\tif condition.Status == status {\n192: \t\t\tcount++\n193: \t\t}\n194: \t}\n195: \treturn count\n196: }\n197: \n198: // HasCondition checks if a condition with the given type exists.\n199: func HasCondition(conditions []runtimev1alpha1.Condition, conditionType runtimev1alpha1.ConditionType) bool {\n200: \treturn GetCondition(conditions, conditionType) != nil\n201: }\n\n(End of file - total 201 lines)\n</content>","metadata":{"preview":"/*\nCopyright 2026 The Volcano Authors.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\npackage controller\n\nimport (\n\tcorev1 \"k8s.io/api/core/v1\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/workloadmanager/controller/conditions.go","time":{"start":1775853427988,"end":1775853428007}}}}
