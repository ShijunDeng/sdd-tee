{"type":"tool_use","timestamp":1775853458157,"sessionID":"ses_286e3dfd6ffeQx7CUBHQTDRBo3","part":{"id":"prt_d791d43500015PZbHeuwGyHz0t","messageID":"msg_d791cdd77001Kq0QcS1VTI6KIC","sessionID":"ses_286e3dfd6ffeQx7CUBHQTDRBo3","type":"tool","tool":"read","callID":"toolu_functions.read:21","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/workloadmanager/controller/metrics.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/workloadmanager/controller/metrics.go</path>\n<type>file</type>\n<content>\n1: /*\n2: Copyright 2026 The Volcano Authors.\n3: \n4: Licensed under the Apache License, Version 2.0 (the \"License\");\n5: you may not use this file except in compliance with the License.\n6: You may obtain a copy of the License at\n7: \n8:     http://www.apache.org/licenses/LICENSE-2.0\n9: \n10: Unless required by applicable law or agreed to in writing, software\n11: distributed under the License is distributed on an \"AS IS\" BASIS,\n12: WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n13: See the License for the specific language governing permissions and\n14: limitations under the License.\n15: */\n16: \n17: package controller\n18: \n19: import (\n20: \t\"time\"\n21: \n22: \t\"github.com/prometheus/client_golang/prometheus\"\n23: \t\"sigs.k8s.io/controller-runtime/pkg/metrics\"\n24: )\n25: \n26: const (\n27: \t// ControllerLabel is the label name for the controller type.\n28: \tControllerLabel = \"controller\"\n29: \n30: \t// ResultLabel is the label name for the reconciliation result.\n31: \tResultLabel = \"result\"\n32: \n33: \t// SuccessValue is the value for successful reconciliation.\n34: \tSuccessValue = \"success\"\n35: \n36: \t// ErrorValue is the value for failed reconciliation.\n37: \tErrorValue = \"error\"\n38: )\n39: \n40: var (\n41: \t// reconcileLatency tracks the latency of reconciliation operations.\n42: \treconcileLatency = prometheus.NewHistogramVec(\n43: \t\tprometheus.HistogramOpts{\n44: \t\t\tName:    \"agentcube_controller_reconcile_latency_seconds\",\n45: \t\t\tHelp:    \"Latency of reconciliation operations in seconds\",\n46: \t\t\tBuckets: prometheus.DefBuckets,\n47: \t\t},\n48: \t\t[]string{ControllerLabel, ResultLabel},\n49: \t)\n50: \n51: \t// reconcileTotal counts the total number of reconciliation operations.\n52: \treconcileTotal = prometheus.NewCounterVec(\n53: \t\tprometheus.CounterOpts{\n54: \t\t\tName: \"agentcube_controller_reconcile_total\",\n55: \t\t\tHelp: \"Total number of reconciliation operations\",\n56: \t\t},\n57: \t\t[]string{ControllerLabel, ResultLabel},\n58: \t)\n59: \n60: \t// reconcileQueueDepth tracks the depth of the reconciliation queue.\n61: \treconcileQueueDepth = prometheus.NewGaugeVec(\n62: \t\tprometheus.GaugeOpts{\n63: \t\t\tName: \"agentcube_controller_reconcile_queue_depth\",\n64: \t\t\tHelp: \"Current depth of the reconciliation queue\",\n65: \t\t},\n66: \t\t[]string{ControllerLabel},\n67: \t)\n68: \n69: \t// reconcileRetriesTotal counts the total number of reconciliation retries.\n70: \treconcileRetriesTotal = prometheus.NewCounterVec(\n71: \t\tprometheus.CounterOpts{\n72: \t\t\tName: \"agentcube_controller_reconcile_retries_total\",\n73: \t\t\tHelp: \"Total number of reconciliation retries\",\n74: \t\t},\n75: \t\t[]string{ControllerLabel},\n76: \t)\n77: \n78: \t// reconcilePanicsTotal counts the total number of reconciliation panics.\n79: \treconcilePanicsTotal = prometheus.NewCounterVec(\n80: \t\tprometheus.CounterOpts{\n81: \t\t\tName: \"agentcube_controller_reconcile_panics_total\",\n82: \t\t\tHelp: \"Total number of reconciliation panics\",\n83: \t\t},\n84: \t\t[]string{ControllerLabel},\n85: \t)\n86: \n87: \t// reconcileErrorsTotal counts the total number of reconciliation errors.\n88: \treconcileErrorsTotal = prometheus.NewCounterVec(\n89: \t\tprometheus.CounterOpts{\n90: \t\t\tName: \"agentcube_controller_reconcile_errors_total\",\n91: \t\t\tHelp: \"Total number of reconciliation errors\",\n92: \t\t},\n93: \t\t[]string{ControllerLabel, \"error_type\"},\n94: \t)\n95: )\n96: \n97: // init registers the metrics with the controller-runtime metrics registry.\n98: func init() {\n99: \tmetrics.Registry.MustRegister(\n100: \t\treconcileLatency,\n101: \t\treconcileTotal,\n102: \t\treconcileQueueDepth,\n103: \t\treconcileRetriesTotal,\n104: \t\treconcilePanicsTotal,\n105: \t\treconcileErrorsTotal,\n106: \t)\n107: }\n108: \n109: // RecordReconcileLatency records the latency of a reconciliation operation.\n110: func RecordReconcileLatency(controller string, duration time.Duration, success bool) {\n111: \tresult := ErrorValue\n112: \tif success {\n113: \t\tresult = SuccessValue\n114: \t}\n115: \treconcileLatency.WithLabelValues(controller, result).Observe(duration.Seconds())\n116: }\n117: \n118: // RecordReconcile records a reconciliation operation.\n119: func RecordReconcile(controller string, success bool) {\n120: \tresult := ErrorValue\n121: \tif success {\n122: \t\tresult = SuccessValue\n123: \t}\n124: \treconcileTotal.WithLabelValues(controller, result).Inc()\n125: }\n126: \n127: // SetQueueDepth sets the current queue depth for a controller.\n128: func SetQueueDepth(controller string, depth int) {\n129: \treconcileQueueDepth.WithLabelValues(controller).Set(float64(depth))\n130: }\n131: \n132: // RecordRetry records a retry for a controller.\n133: func RecordRetry(controller string) {\n134: \treconcileRetriesTotal.WithLabelValues(controller).Inc()\n135: }\n136: \n137: // RecordPanic records a panic during reconciliation.\n138: func RecordPanic(controller string) {\n139: \treconcilePanicsTotal.WithLabelValues(controller).Inc()\n140: }\n141: \n142: // RecordError records an error during reconciliation.\n143: func RecordError(controller string, errorType string) {\n144: \treconcileErrorsTotal.WithLabelValues(controller, errorType).Inc()\n145: }\n146: \n147: // RegisterMetrics registers all controller metrics with the provided registerer.\n148: func RegisterMetrics(reg prometheus.Registerer) error {\n149: \tif reg == nil {\n150: \t\treturn nil\n151: \t}\n152: \n153: \treturn reg.Register(prometheus.NewRegistry())\n154: }\n155: \n156: // GetRegisteredMetrics returns the list of registered metrics collectors.\n157: func GetRegisteredMetrics() []prometheus.Collector {\n158: \treturn []prometheus.Collector{\n159: \t\treconcileLatency,\n160: \t\treconcileTotal,\n161: \t\treconcileQueueDepth,\n162: \t\treconcileRetriesTotal,\n163: \t\treconcilePanicsTotal,\n164: \t\treconcileErrorsTotal,\n165: \t}\n166: }\n167: \n168: // ResetMetrics resets all metrics to their initial state.\n169: // This is useful for testing.\n170: func ResetMetrics() {\n171: \treconcileLatency.Reset()\n172: \treconcileTotal.Reset()\n173: \treconcileQueueDepth.Reset()\n174: \treconcileRetriesTotal.Reset()\n175: \treconcilePanicsTotal.Reset()\n176: \treconcileErrorsTotal.Reset()\n177: }\n\n(End of file - total 177 lines)\n</content>","metadata":{"preview":"/*\nCopyright 2026 The Volcano Authors.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\npackage controller\n\nimport (\n\t\"time\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/workloadmanager/controller/metrics.go","time":{"start":1775853458138,"end":1775853458155}}}}
{"type":"tool_use","timestamp":1775853458158,"sessionID":"ses_286e3dfd6ffeQx7CUBHQTDRBo3","part":{"id":"prt_d791d4863001ZqzOVTXeA4EfTk","messageID":"msg_d791cdd77001Kq0QcS1VTI6KIC","sessionID":"ses_286e3dfd6ffeQx7CUBHQTDRBo3","type":"tool","tool":"read","callID":"toolu_functions.read:22","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/workloadmanager/controller/ratelimiter.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/workloadmanager/controller/ratelimiter.go</path>\n<type>file</type>\n<content>\n1: /*\n2: Copyright 2026 The Volcano Authors.\n3: \n4: Licensed under the Apache License, Version 2.0 (the \"License\");\n5: you may not use this file except in compliance with the License.\n6: You may obtain a copy of the License at\n7: \n8:     http://www.apache.org/licenses/LICENSE-2.0\n9: \n10: Unless required by applicable law or agreed to in writing, software\n11: distributed under the License is distributed on an \"AS IS\" BASIS,\n12: WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n13: See the License for the specific language governing permissions and\n14: limitations under the License.\n15: */\n16: \n17: package controller\n18: \n19: import (\n20: \t\"math\"\n21: \t\"math/rand\"\n22: \t\"time\"\n23: \n24: \t\"k8s.io/client-go/util/workqueue\"\n25: )\n26: \n27: // NewRateLimiter creates a new rate limiter with exponential backoff.\n28: func NewRateLimiter(baseDelay, maxDelay time.Duration) workqueue.RateLimiter {\n29: \treturn workqueue.NewItemExponentialFailureRateLimiter(baseDelay, maxDelay)\n30: }\n31: \n32: // NewControllerRateLimiter creates a rate limiter with jitter to prevent thundering herd.\n33: func NewControllerRateLimiter(config ReconcilerConfig) workqueue.RateLimiter {\n34: \t// Add ±10% jitter to base delay to prevent thundering herd\n35: \tjitter := 0.1\n36: \tjitteredBase := addJitter(config.RateLimiterBaseDelay, jitter)\n37: \tjitteredMax := addJitter(config.RateLimiterMaxDelay, jitter)\n38: \n39: \treturn workqueue.NewItemExponentialFailureRateLimiter(jitteredBase, jitteredMax)\n40: }\n41: \n42: // addJitter adds random jitter to a duration.\n43: // jitter is the fraction of the duration to vary (e.g., 0.1 for 10%).\n44: func addJitter(duration time.Duration, jitter float64) time.Duration {\n45: \tif jitter <= 0 {\n46: \t\treturn duration\n47: \t}\n48: \n49: \t// Calculate the jitter range\n50: \tjitterAmount := float64(duration) * jitter\n51: \tvariation := (rand.Float64()*2 - 1) * jitterAmount // Random value between -jitterAmount and +jitterAmount\n52: \n53: \tresult := duration + time.Duration(variation)\n54: \tif result < 0 {\n55: \t\treturn 0\n56: \t}\n57: \treturn result\n58: }\n59: \n60: // CalculateBackoff calculates the backoff duration for a given retry count.\n61: func CalculateBackoff(baseDelay, maxDelay time.Duration, retryCount int) time.Duration {\n62: \tif retryCount <= 0 {\n63: \t\treturn 0\n64: \t}\n65: \n66: \t// Exponential backoff: baseDelay * 2^(retryCount-1)\n67: \tbackoff := float64(baseDelay) * math.Pow(2, float64(retryCount-1))\n68: \n69: \t// Cap at maxDelay\n70: \tif backoff > float64(maxDelay) {\n71: \t\tbackoff = float64(maxDelay)\n72: \t}\n73: \n74: \treturn time.Duration(backoff)\n75: }\n76: \n77: // MaxOf returns the maximum of two durations.\n78: func MaxOf(a, b time.Duration) time.Duration {\n79: \tif a > b {\n80: \t\treturn a\n81: \t}\n82: \treturn b\n83: }\n84: \n85: // MinOf returns the minimum of two durations.\n86: func MinOf(a, b time.Duration) time.Duration {\n87: \tif a < b {\n88: \t\treturn a\n89: \t}\n90: \treturn b\n91: }\n\n(End of file - total 91 lines)\n</content>","metadata":{"preview":"/*\nCopyright 2026 The Volcano Authors.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\npackage controller\n\nimport (\n\t\"math\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/workloadmanager/controller/ratelimiter.go","time":{"start":1775853458140,"end":1775853458157}}}}
{"type":"tool_use","timestamp":1775853458160,"sessionID":"ses_286e3dfd6ffeQx7CUBHQTDRBo3","part":{"id":"prt_d791d4d72001J6mMUNeKBtpehp","messageID":"msg_d791cdd77001Kq0QcS1VTI6KIC","sessionID":"ses_286e3dfd6ffeQx7CUBHQTDRBo3","type":"tool","tool":"read","callID":"toolu_functions.read:23","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/workloadmanager/controller/errors.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/workloadmanager/controller/errors.go</path>\n<type>file</type>\n<content>\n1: /*\n2: Copyright 2026 The Volcano Authors.\n3: \n4: Licensed under the Apache License, Version 2.0 (the \"License\");\n5: you may not use this file except in compliance with the License.\n6: You may obtain a copy of the License at\n7: \n8:     http://www.apache.org/licenses/LICENSE-2.0\n9: \n10: Unless required by applicable law or agreed to in writing, software\n11: distributed under the License is distributed on an \"AS IS\" BASIS,\n12: WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n13: See the License for the specific language governing permissions and\n14: limitations under the License.\n15: */\n16: \n17: package controller\n18: \n19: import (\n20: \t\"context\"\n21: \t\"errors\"\n22: \t\"net/http\"\n23: \t\"strings\"\n24: \n25: \tk8serrors \"k8s.io/apimachinery/pkg/api/errors\"\n26: )\n27: \n28: // ErrorReason represents the reason for an error.\n29: type ErrorReason string\n30: \n31: const (\n32: \t// ErrorReasonAPIUnavailable indicates the API server is unavailable.\n33: \tErrorReasonAPIUnavailable ErrorReason = \"APIUnavailable\"\n34: \n35: \t// ErrorReasonNetworkTimeout indicates a network timeout.\n36: \tErrorReasonNetworkTimeout ErrorReason = \"NetworkTimeout\"\n37: \n38: \t// ErrorReasonConflict indicates a resource conflict.\n39: \tErrorReasonConflict ErrorReason = \"Conflict\"\n40: \n41: \t// ErrorReasonNotFound indicates the resource was not found.\n42: \tErrorReasonNotFound ErrorReason = \"NotFound\"\n43: \n44: \t// ErrorReasonForbidden indicates the operation is forbidden.\n45: \tErrorReasonForbidden ErrorReason = \"Forbidden\"\n46: \n47: \t// ErrorReasonInvalid indicates the spec is invalid.\n48: \tErrorReasonInvalid ErrorReason = \"Invalid\"\n49: \n50: \t// ErrorReasonTimeout indicates a general timeout.\n51: \tErrorReasonTimeout ErrorReason = \"Timeout\"\n52: \n53: \t// ErrorReasonUnknown indicates an unknown error.\n54: \tErrorReasonUnknown ErrorReason = \"Unknown\"\n55: \n56: \t// ErrorReasonInternal indicates an internal error.\n57: \tErrorReasonInternal ErrorReason = \"Internal\"\n58: )\n59: \n60: // IsRetryableError determines if an error should be retried.\n61: // Returns true for transient errors like API server unavailable, network timeout, conflict.\n62: // Returns false for non-retryable errors like RBAC forbidden, invalid spec, not found.\n63: func IsRetryableError(err error) bool {\n64: \tif err == nil {\n65: \t\treturn false\n66: \t}\n67: \n68: \t// Check if it's a Kubernetes API error\n69: \tif k8sErr, ok := err.(*k8serrors.StatusError); ok {\n70: \t\treturn IsRetryableStatusCode(k8sErr.ErrStatus.Code)\n71: \t}\n72: \n73: \t// Check for context timeout/cancellation\n74: \tif errors.Is(err, context.DeadlineExceeded) {\n75: \t\treturn true\n76: \t}\n77: \n78: \t// Check for temporary errors\n79: \tif IsTemporaryError(err) {\n80: \t\treturn true\n81: \t}\n82: \n83: \t// Network errors are typically retryable\n84: \tif IsNetworkError(err) {\n85: \t\treturn true\n86: \t}\n87: \n88: \treturn false\n89: }\n90: \n91: // IsRetryableStatusCode checks if an HTTP status code indicates a retryable error.\n92: func IsRetryableStatusCode(code int32) bool {\n93: \tswitch code {\n94: \tcase http.StatusRequestTimeout: // 408\n95: \tcase http.StatusTooManyRequests: // 429\n96: \tcase http.StatusInternalServerError: // 500\n97: \tcase http.StatusBadGateway: // 502\n98: \tcase http.StatusServiceUnavailable: // 503\n99: \tcase http.StatusGatewayTimeout: // 504\n100: \t\treturn true\n101: \tcase http.StatusConflict: // 409\n102: \t\treturn true\n103: \tcase http.StatusNotFound: // 404\n104: \t\treturn false\n105: \tcase http.StatusForbidden: // 403\n106: \t\treturn false\n107: \tcase http.StatusUnauthorized: // 401\n108: \t\treturn false\n109: \tcase http.StatusBadRequest: // 400\n110: \t\treturn false\n111: \tcase http.StatusUnprocessableEntity: // 422\n112: \t\treturn false\n113: \tdefault:\n114: \t\tif code >= 500 {\n115: \t\t\treturn true // All 5xx errors are retryable\n116: \t\t}\n117: \t\treturn false\n118: \t}\n119: \treturn false\n120: }\n121: \n122: // ClassifyError classifies an error and returns whether it's retryable and the reason.\n123: func ClassifyError(err error) (retryable bool, reason ErrorReason) {\n124: \tif err == nil {\n125: \t\treturn false, \"\"\n126: \t}\n127: \n128: \t// Check Kubernetes API errors\n129: \tif k8sErr, ok := err.(*k8serrors.StatusError); ok {\n130: \t\tcode := k8sErr.ErrStatus.Code\n131: \t\tswitch code {\n132: \t\tcase http.StatusNotFound:\n133: \t\t\treturn false, ErrorReasonNotFound\n134: \t\tcase http.StatusConflict:\n135: \t\t\treturn true, ErrorReasonConflict\n136: \t\tcase http.StatusForbidden:\n137: \t\t\treturn false, ErrorReasonForbidden\n138: \t\tcase http.StatusUnauthorized:\n139: \t\t\treturn false, ErrorReasonForbidden\n140: \t\tcase http.StatusBadRequest:\n141: \t\t\treturn false, ErrorReasonInvalid\n142: \t\tcase http.StatusUnprocessableEntity:\n143: \t\t\treturn false, ErrorReasonInvalid\n144: \t\tcase http.StatusRequestTimeout:\n145: \t\t\treturn true, ErrorReasonTimeout\n146: \t\tcase http.StatusTooManyRequests:\n147: \t\t\treturn true, ErrorReasonTimeout\n148: \t\tcase http.StatusGatewayTimeout:\n149: \t\t\treturn true, ErrorReasonTimeout\n150: \t\tcase http.StatusInternalServerError:\n151: \t\t\treturn true, ErrorReasonInternal\n152: \t\tcase http.StatusBadGateway:\n153: \t\t\treturn true, ErrorReasonAPIUnavailable\n154: \t\tcase http.StatusServiceUnavailable:\n155: \t\t\treturn true, ErrorReasonAPIUnavailable\n156: \t\tdefault:\n157: \t\t\tif code >= 500 {\n158: \t\t\t\treturn true, ErrorReasonInternal\n159: \t\t\t}\n160: \t\t\treturn false, ErrorReasonUnknown\n161: \t\t}\n162: \t}\n163: \n164: \t// Check for context errors\n165: \tif errors.Is(err, context.DeadlineExceeded) {\n166: \t\treturn true, ErrorReasonTimeout\n167: \t}\n168: \tif errors.Is(err, context.Canceled) {\n169: \t\treturn false, ErrorReasonUnknown\n170: \t}\n171: \n172: \t// Check for temporary errors\n173: \tif IsTemporaryError(err) {\n174: \t\treturn true, ErrorReasonNetworkTimeout\n175: \t}\n176: \n177: \t// Check for network errors\n178: \tif IsNetworkError(err) {\n179: \t\treturn true, ErrorReasonNetworkTimeout\n180: \t}\n181: \n182: \treturn false, ErrorReasonUnknown\n183: }\n184: \n185: // IsTemporaryError checks if an error is temporary.\n186: func IsTemporaryError(err error) bool {\n187: \ttype temporary interface {\n188: \t\tTemporary() bool\n189: \t}\n190: \n191: \tif te, ok := err.(temporary); ok {\n192: \t\treturn te.Temporary()\n193: \t}\n194: \n195: \treturn false\n196: }\n197: \n198: // IsNetworkError checks if an error is a network error.\n199: func IsNetworkError(err error) bool {\n200: \tif err == nil {\n201: \t\treturn false\n202: \t}\n203: \n204: \terrStr := err.Error()\n205: \tnetworkErrors := []string{\n206: \t\t\"connection refused\",\n207: \t\t\"connection reset\",\n208: \t\t\"no such host\",\n209: \t\t\"timeout\",\n210: \t\t\"temporary failure\",\n211: \t\t\"i/o timeout\",\n212: \t\t\"TLS handshake timeout\",\n213: \t\t\"network is unreachable\",\n214: \t\t\"connection timed out\",\n215: \t}\n216: \n217: \tfor _, ne := range networkErrors {\n218: \t\tif containsIgnoreCase(errStr, ne) {\n219: \t\t\treturn true\n220: \t\t}\n221: \t}\n222: \n223: \treturn false\n224: }\n225: \n226: // containsIgnoreCase checks if s contains substr, ignoring case.\n227: func containsIgnoreCase(s, substr string) bool {\n228: \treturn strings.Contains(strings.ToLower(s), strings.ToLower(substr))\n229: }\n230: \n231: // GetErrorReason returns the ErrorReason for an error.\n232: func GetErrorReason(err error) ErrorReason {\n233: \t_, reason := ClassifyError(err)\n234: \treturn reason\n235: }\n236: \n237: // GetRetryCount returns the recommended retry count for an error.\n238: func GetRetryCount(err error, config ReconcilerConfig) int {\n239: \tif !IsRetryableError(err) {\n240: \t\treturn 0\n241: \t}\n242: \treturn config.MaxRetries\n243: }\n\n(End of file - total 243 lines)\n</content>","metadata":{"preview":"/*\nCopyright 2026 The Volcano Authors.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\npackage controller\n\nimport (\n\t\"context\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/workloadmanager/controller/errors.go","time":{"start":1775853458142,"end":1775853458159}}}}
