 == finalizer {\n36: \t\t\treturn true\n37: \t\t}\n38: \t}\n39: \treturn false\n40: }\n41: \n42: // AddFinalizer adds the finalizer to the object if it doesn't already exist.\n43: // Returns true if the finalizer was added (was not already present).\n44: func AddFinalizer(obj metav1.Object, finalizer string) bool {\n45: \tif HasFinalizer(obj, finalizer) {\n46: \t\treturn false\n47: \t}\n48: \n49: \tfinalizers := obj.GetFinalizers()\n50: \tfinalizers = append(finalizers, finalizer)\n51: \tobj.SetFinalizers(finalizers)\n52: \treturn true\n53: }\n54: \n55: // RemoveFinalizer removes the finalizer from the object if it exists.\n56: // Returns true if the finalizer was removed (was present).\n57: func RemoveFinalizer(obj metav1.Object, finalizer string) bool {\n58: \tif !HasFinalizer(obj, finalizer) {\n59: \t\treturn false\n60: \t}\n61: \n62: \tfinalizers := obj.GetFinalizers()\n63: \tnewFinalizers := make([]string, 0, len(finalizers)-1)\n64: \tfor _, f := range finalizers {\n65: \t\tif f != finalizer {\n66: \t\t\tnewFinalizers = append(newFinalizers, f)\n67: \t\t}\n68: \t}\n69: \tobj.SetFinalizers(newFinalizers)\n70: \treturn true\n71: }\n72: \n73: // ContainsFinalizer is an alias for HasFinalizer for compatibility.\n74: func ContainsFinalizer(obj metav1.Object, finalizer string) bool {\n75: \treturn HasFinalizer(obj, finalizer)\n76: }\n77: \n78: // SetFinalizer sets the finalizers on the object.\n79: func SetFinalizer(obj metav1.Object, finalizers []string) {\n80: \tobj.SetFinalizers(finalizers)\n81: }\n82: \n83: // GetFinalizers returns the finalizers of the object.\n84: func GetFinalizers(obj metav1.Object) []string {\n85: \treturn obj.GetFinalizers()\n86: }\n\n(End of file - total 86 lines)\n</content>","metadata":{"preview":"/*\nCopyright 2026 The Volcano Authors.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org