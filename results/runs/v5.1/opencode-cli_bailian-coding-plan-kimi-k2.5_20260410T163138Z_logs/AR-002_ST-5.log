t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\n\tdata, err := json.Marshal(list)\n\tif err != nil {\n\t\tt.Fatalf(\"Failed to marshal CodeInterpreterList: %v\", err)\n\t}\n\n\tvar unmarshaled CodeInterpreterList\n\terr = json.Unmarshal(data, &unmarshaled)\n\tif err != nil {\n\t\tt.Fatalf(\"Failed to unmarshal CodeInterpreterList: %v\", err)\n\t}\n\n\tif len(unmarshaled.Items) != 1 {\n\t\tt.Errorf(\"Expected 1 item, got %d\", len(unmarshaled.Items))\n\t}\n}\n\nfunc TestDeepCopyObject(t *testing.T) {\n\tci := &CodeInterpreter{\n\t\tTypeMeta: metav1.TypeMeta{\n\t\t\tAPIVersion: \"runtime.agentcube.volcano.sh/v1alpha1\",\n\t\t\tKind:       \"CodeInterpreter\",\n\t\t},\n\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\tName: \"test\",\n\t\t},\n\t\tSpec: CodeInterpreterSpec{\n\t\t\tTemplate: &CodeInterpreterSandboxTemplate{\n\t\t\t\tSpec: corev1.PodSpec{\n\t\t\t\t\tContainers: []corev1.Container{\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\tName:  \"code-interpreter\",\n\t\t\t\t\t\t\tImage: \"python:3.11\",\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\n\tobj := ci.DeepCopyObject()\n\tif obj == nil {\n\t\tt.Fatal(\"DeepCopyObject returned nil\")\n\t}\n\n\t// Verify it's the correct type\n\tcopiedCI, ok := obj.(*CodeInterpreter)\n\tif !ok {\n\t\tt.Fatalf(\"DeepCopyObject returned wrong type: %T\", obj)\n\t}\n\n\tif copiedCI.Name != ci.Name {\n\t\tt.Errorf(\"Expected name '%s', got '%s'\", ci.Name, copiedCI.Name)\n\t}\n\n\t// Test with nil\n\tvar nilCI *CodeInterpreter\n\tnilObj := nilCI.DeepCopyObject()\n\tif nilObj != nil {\n\t\tt.Error(\"DeepCopyObject of nil should return nil\")\n\t}\n\n\t// Test CodeInterpreterList\n\tlist := &CodeInterpreterList{\n\t\tItems: []CodeInterpreter{\n\t\t\t{ObjectMeta: metav1.ObjectMeta{Name: \"test\"}},\n\t\t},\n\t}\n\tlistObj := list.DeepCopyObject()\n\tif listObj == nil {\n\t\tt.Fatal(\"DeepCopyObject returned nil for list\")\n\t}\n\n\tcopiedList, ok := listObj.(*CodeInterpreterList)\n\tif !ok {\n\t\tt.Fatalf(\"DeepCopyObject returned wrong type for list: %T\", listObj)\n\t}\n\n\tif len(copiedList.Items) != 1 {\n\t\tt.Errorf(\"Expected 1 item, got %d\", len(copiedList.Items))\n\t}\n\n\t// Test with nil list\n\tvar nilList *CodeInterpreterList\n\tnilListObj := nilList.DeepCopyObject()\n\tif nilListObj != nil {\n\t\tt.Error(\"DeepCopyObject of nil list should return nil\")\n\t}\n}\n\n// Helper function\nfunc boolPtr(b bool) *bool {\n\treturn &b\n}\n\n// Helper function for resource.Quantity\nfunc resourceQuantity(s string) corev1.ResourceQuantity {\n\treturn corev1.ResourceQuantity(s)\n}\n\nfunc containsStr(s, substr string) bool {\n\treturn len(s) >= len(substr) && (s == substr || len(s) > len(substr) && containsAtStr(s, substr))\n}\n\nfunc containsAtStr(s, substr string) bool {\n\tfor i := 0; i <= len(s)-len(substr); i++ {\n\t\tif s[i:i+len(substr)] == substr {\n\t\t\treturn true\n\t\t}\n\t}\n\treturn false\n}\n","additions":4,"deletions":4},"truncated":false},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/apis/runtime/v1alpha1/codeinterpreter_types_test.go","time":{"start":1775841304103,"end":1775841304308}}}}
