:= &CodeInterpreterSpec{\n\t\tPorts: []TargetPort{\n\t\t\t{\n\t\t\t\tName:     \"http\",\n\t\t\t\tPort:     8080,\n\t\t\t\tProtocol: ProtocolHTTP,\n\t\t\t},\n\t\t},\n\t\tTemplate: &CodeInterpreterSandboxTemplate{\n\t\t\tLabels: map[string]string{\n\t\t\t\t\"app\": \"code-interpreter\",\n\t\t\t},\n\t\t\tSpec: corev1.PodSpec{\n\t\t\t\tContainers: []corev1.Container{\n\t\t\t\t\t{\n\t\t\t\t\t\tName:  \"code-interpreter\",\n\t\t\t\t\t\tImage: \"python:3.11\",\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t\tSessionTimeout:     &duration15m,\n\t\tMaxSessionDuration: &duration8h,\n\t\tWarmPoolSize:       int32Ptr(5),\n\t\tAuthMode:           AuthModePicoD,\n\t}\n\n\tcopied := original.DeepCopy()\n\n\tif copied == nil {\n\t\tt.Fatal(\"DeepCopy returned nil\")\n\t}\n\n\tif copied.AuthMode != original.AuthMode {\n\t\tt.Errorf(\"Expected auth mode '%s', got '%s'\", original.AuthMode, copied.AuthMode)\n\t}\n\n\t// Verify independence of template\n\toriginal.Template.Labels[\"new-label\"] = \"value\"\n\tif _, exists := copied.Template.Labels[\"new-label\"]; exists {\n\t\tt.Error(\"Template should be independent\")\n\t}\n\n\t// Verify independence of ports\n\toriginal.Ports[0].Port = 9090\n\tif copied.Ports[0].Port == 9090 {\n\t\tt.Error(\"Ports should be independent\")\n\t}\n}\n\nfunc TestCodeInterpreterStatusDeepCopy(t *testing.T) {\n\tnow := metav1.NewTime(time.Now())\n\n\toriginal := &CodeInterpreterStatus{\n\t\tReady: boolPtr(true),\n\t\tConditions: []CodeInterpreterCondition{\n\t\t\t{\n\t\t\t\tType:   CodeInterpreterConditionReady,\n\t\t\t\tStatus: corev1.ConditionTrue,\n\t\t\t\tLastTransitionTime: metav1.Time{\n\t\t\t\t\tTime: now.Time,\n\t\t\t\t},\n\t\t\t\tReason: \"CodeInterpreterReady\",\n\t\t\t},\n\t\t},\n\t}\n\n\tcopied := original.DeepCopy()\n\n\tif copied == nil {\n\t\tt.Fatal(\"DeepCopy returned nil\")\n\t}\n\n\tif *copied.Ready != *original.Ready {\n\t\tt.Errorf(\"Expected ready '%v', got '%v'\", *original.Ready, *copied.Ready)\n\t}\n\n\t// Verify independence of 