may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\npackage v1alpha1\n\nimport (\n\t\"encoding/json\"\n\t\"testing\"\n\t\"time\"\n\n\tcorev1 \"k8s.io/api/core/v1\"\n\t\"k8s.io/apimachinery/pkg/api/resource\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n)\n\nfunc TestProtocolTypeValues(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\tprotocol ProtocolType\n\t\texpected string\n\t}{\n\t\t{\"HTTP\", ProtocolHTTP, \"HTTP\"},\n\t\t{\"HTTPS\", ProtocolHTTPS, \"HTTPS\"},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tif string(tt.protocol) != tt.expected {\n\t\t\t\tt.Errorf(\"Expected protocol %s, got %s\", tt.expected, tt.protocol)\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestAuthModeTypeValues(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\tauthMode AuthModeType\n\t\texpected string\n\t}{\n\t\t{\"PicoD\", AuthModePicoD, \"picod\"},\n\t\t{\"None\", AuthModeNone, \"none\"},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tif string(tt.authMode) != tt.expected {\n\t\t\t\tt.Errorf(\"Expected auth mode %s, got %s\", tt.expected, tt.authMode)\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestTargetPort(t *testing.T) {\n\ttests := []struct {\n\t\tname       string\n\t\ttargetPort TargetPort\n\t}{\n\t\t{\n\t\t\tname: \"minimal target port\",\n\t\t\ttargetPort: TargetPort{\n\t\t\t\tPort:     8080,\n\t\t\t\tProtocol: ProtocolHTTP,\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"target port with all fields\",\n\t\t\ttargetPort: TargetPort{\n\t\t\t\tPathPrefix: \"/api\",\n\t\t\t\tName:       \"http-port\",\n\t\t\t\tPort:       443,\n\t\t\t\tProtocol:   ProtocolHTTPS,\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"target port without protocol (uses default)\",\n\t\t\ttargetPort: TargetPort{\n\t\t\t\tPort: 3000,\n\t\t\t},\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tif tt.targetPort.Port == 0 {\n\t\t\t\tt.Error(\"Port should not be 0\")\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestCodeInterpreterSandboxTemplate(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\ttemplate CodeInterpreterSandboxTemplate\n\t}{\n\t\t{\n\t\t\tname: \"template with pod spec\",\n\t\t\ttemplate: CodeInterpreterSandboxTemplate{\n\t\t\t\tSpec: corev1.PodSpec{\n\t\t\t\t\tContainers: []corev1.Container{\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\tName:  \"code-interpreter\",\n\t\t\t\t\t\t\tImage: \"python:3.11\",\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"template with labels and annotations\",\n\t\t\ttemplate: CodeInterpreterSandboxTemplate{\n\t\t\t\tLabels: map[string]string{\n\t\t\t\t\t\"app\": \"code-interpreter\",\n\t\t\t\t},\n\t\t\t\tAnnotations: map[string]string{\n\t\t\t\t\t\"description\": \"Code interpreter sandbox\",\n\t\t\t\t},\n\t\t\t\tSpec: corev1.PodSpec{\n\t\t\t\t\tContainers: []corev1.Container{\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\tName:  \"code-interpreter\",\n\t\t\t\t\t\t\tImage: \"node:18\",\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"template with full pod spec\",\n\t\t\ttemplate: CodeInterpreterSandboxTemplate{\n\t\t\t\tLabels: map[string]string{\n\t\t\t\t\t\"app\":     \"code-interpreter\",\n\t\t\t\t\t\"version\": \"v1\",\n\t\t\t\t},\n\t\t\t\tAnnotations: map[string]string{\n\t\t\t\t\t\"prometheus.io/scrape\": \"true\",\n\t\t\t\t},\n\t\t\t\tSpec: corev1.PodSpec{\n\t\t\t\t\tContainers: []corev1.Container{\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\tName:    \"code-interpreter\",\n\t\t\t\t\t\t\tImage:   \"jupyter/scipy-notebook:latest\",\n\t\t\t\t\t\t\tCommand: []string{\"jupyter\", \"notebook\"},\n\t\t\t\t\t\t\tArgs:    []string{\"--ip=0.0.0.0\"},\n\t\t\t\t\t\t\tPorts: []corev1.ContainerPort{\n\t\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\t\tName:          \"notebook\",\n\t\t\t\t\t\t\t\t\tContainerPort: 8888,\n\t\t\t\t\t\t\t\t\tProtocol:      corev1.ProtocolTCP,\n\t\t\t\t\t\t\t\t},\n\t\t\t\t\t\t\t},\n\t\t\t\t\t\t\tResources: corev1.ResourceRequirements{\n\t\t\t\t\t\t\t\tRequests: corev1.ResourceList{\n\t\t\t\t\t\t\t\t\tcorev1.ResourceCPU:    resource.MustParse(\"500m\"),\n\t\t\t\t\t\t\t\t\tcorev1.ResourceMemory: resource.MustParse(\"512Mi\"),\n\t\t\t\t\t\t\t\t},\n\t\t\t\t\t\t\t\tLimits: corev1.ResourceList{\n\t\t\t\t\t\t\t\t\tcorev1.ResourceCPU:    resource.MustParse(\"1000m\"),\n\t\t\t\t\t\t\t\t\tcorev1.ResourceMemory: resource.MustParse(\"1Gi\"),\n\t\t\t\t\t\t\t\t},\n\t\t\t\t\t\t\t},\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t\tServiceAccountName: \"code-interpreter-sa\",\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tif len(tt.template.Spec.Containers) == 0 {\n\t\t\t\tt.Error(\"Template should have at least one container\")\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestCodeInterpreterSpec(t *testing.T) {\n\tduration15m := metav1.Duration{Duration: 15 * time.Minute}\n\tduration8h := metav1.Duration{Duration: 8 * time.Hour}\n\n\ttests := []struct {\n\t\tname string\n\t\tspec CodeInterpreterSpec\n\t}{\n\t\t{\n\t\t\tname: \"minimal spec with template\",\n\t\t\tspec: CodeInterpreterSpec{\n\t\t\t\tTemplate: &CodeInterpreterSandboxTemplate{\n\t\t\t\t\tSpec: corev1.PodSpec{\n\t\t\t\t\t\tContainers: []corev1.Container{\n\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\tName:  \"code-interpreter\",\n\t\t\t\t\t\t\t\tImage: \"python:3.11\",\n\t\t\t\t\t\t\t},\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"spec with ports\",\n\t\t\tspec: CodeInterpreterSpec{\n\t\t\t\tPorts: []TargetPort{\n\t\t\t\t\t{\n\t\t\t\t\t\tName:       \"http\",\n\t\t\t\t\t\tPort:       8080,\n\t\t\t\t\t\tProtocol:   ProtocolHTTP,\n\t\t\t\t\t\tPathPrefix: \"/api\",\n\t\t\t\t\t},\n\t\t\t\t\t{\n\t\t\t\t\t\tName:     \"https\",\n\t\t\t\t\t\tPort:     8443,\n\t\t\t\t\t\tProtocol: ProtocolHTTPS,\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t\tTemplate: &CodeInterpreterSandboxTemplate{\n\t\t\t\t\tSpec: corev1.PodSpec{\n\t\t\t\t\t\tContainers: []corev1.Container{\n\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\tName:  \"code-interpreter\",\n\t\t\t\t\t\t\t\tImage: \"nginx:latest\",\n\t\t\t\t\t\t\t},\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"spec with timeouts\",\n\t\t\tspec: CodeInterpreterSpec{\n\t\t\t\tTemplate: &CodeInterpreterSandboxTemplate{\n\t\t\t\t\tSpec: corev1.PodSpec{\n\t\t\t\t\t\tContainers: []corev1.Container{\n\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\tName:  \"code-interpreter\",\n\t\t\t\t\t\t\t\tImage: \"busybox:latest\",\n\t\t\t\t\t\t\t},\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t\tSessionTimeout:     &duration15m,\n\t\t\t\tMaxSessionDuration: &duration8h,\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"spec with warm pool\",\n\t\t\tspec: CodeInterpreterSpec{\n\t\t\t\tTemplate: &CodeInterpreterSandboxTemplate{\n\t\t\t\t\tSpec: corev1.PodSpec{\n\t\t\t\t\t\tContainers: []corev1.Container{\n\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\tName:  \"code-interpreter\",\n\t\t\t\t\t\t\t\tImage: \"busybox:latest\",\n\t\t\t\t\t\t\t},\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t\tWarmPoolSize: int32Ptr(5),\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"spec with auth mode\",\n\t\t\tspec: CodeInterpreterSpec{\n\t\t\t\tTemplate: &CodeInterpreterSandboxTemplate{\n\t\t\t\t\tSpec: corev1.PodSpec{\n\t\t\t\t\t\tContainers: []corev1.Container{\n\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\tName:  \"code-interpreter\",\n\t\t\t\t\t\t\t\tImage: \"busybox:latest\",\n\t\t\t\t\t\t\t},\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t\tAuthMode: AuthModePicoD,\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"spec with auth mode none\",\n\t\t\tspec: CodeInterpreterSpec{\n\t\t\t\tTemplate: &CodeInterpreterSandboxTemplate{\n\t\t\t\t\tSpec: corev1.PodSpec{\n\t\t\t\t\t\tContainers: []corev1.Container{\n\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\tName:  \"code-interpreter\",\n\t\t\t\t\t\t\t\tImage: \"busybox:latest\",\n\t\t\t\t\t\t\t},\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t\tAuthMode: AuthModeNone,\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"full spec\",\n\t\t\tspec: CodeInterpreterSpec{\n\t\t\t\tPorts: []TargetPort{\n\t\t\t\t\t{\n\t\t\t\t\t\tName:     \"jupyter\",\n\t\t\t\t\t\tPort:     8888,\n\t\t\t\t\t\tProtocol: ProtocolHTTP,\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t\tTemplate: &CodeInterpreterSandboxTemplate{\n\t\t\t\t\tLabels: map[string]string{\n\t\t\t\t\t\t\"app\": \"code-interpreter\",\n\t\t\t\t\t},\n\t\t\t\t\tSpec: corev1.PodSpec{\n\t\t\t\t\t\tContainers: []corev1.Container{\n\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\tName:  \"code-interpreter\",\n\t\t\t\t\t\t\t\tImage: \"jupyter/scipy-notebook:latest\",\n\t\t\t\t\t\t\t},\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t\tSessionTimeout:     &duration15m,\n\t\t\t\tMaxSessionDuration: &duration8h,\n\t\t\t\tWarmPoolSize:       int32Ptr(3),\n\t\t\t\tAuthMode:           AuthModePicoD,\n\t\t\t},\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tif tt.spec.Template == nil {\n\t\t\t\tt.Error(\"Template should not be nil\")\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestCodeInterpreterConditionTypeValues(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\tcondType CodeInterpreterConditionType\n\t\texpected string\n\t}{\n\t\t{\"Ready\", CodeInterpreterConditionReady, \"Ready\"},\n\t\t{\"SandboxCreated\", CodeInterpreterConditionSandboxCreated, \"SandboxCreated\"},\n\t\t{\"SandboxReady\", CodeInterpreterConditionSandboxReady, \"SandboxReady\"},\n\t\t{\"Failed\", CodeInterpreterConditionFailed, \"Failed\"},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tif string(tt.condType) != tt.expected {\n\t\t\t\tt.Errorf(\"Expected condition type %s, got %s\", tt.expected, tt.condType)\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestCodeInterpreterCondition(t *testing.T) {\n\tcond := CodeInterpreterCondition{\n\t\tType:   CodeInterpreterConditionReady,\n\t\tStatus: corev1.ConditionTrue,\n\t\tLastTransitionTime: metav1.Time{\n\t\t\tTime: time.Now(),\n\t\t},\n\t\tReason:  \"CodeInterpreterReady\",\n\t\tMessage: \"CodeInterpreter is ready\",\n\t}\n\n\tif cond.Type != CodeInterpreterConditionReady {\n\t\tt.Errorf(\"Expected condition type %s, got %s\", CodeInterpreterConditionReady, cond.Type)\n\t}\n\n\tif cond.Status != corev1.ConditionTrue {\n\t\tt.Errorf(\"Expected status %s, got %s\", corev1.ConditionTrue, cond.Status)\n\t}\n\n\tif cond.Reason != \"CodeInterpreterReady\" {\n\t\tt.Errorf(\"Expected reason 'CodeInterpreterReady', got %s\", cond.Reason)\n\t}\n\n\tif cond.Message != \"CodeInterpreter is ready\" {\n\t\tt.Errorf(\"Expected message 'CodeInterpreter is ready', got %s\", cond.Message)\n\t}\n}\n\nfunc TestCodeInterpreterStatus(t *testing.T) {\n\ttests := []struct {\n\t\tname   string\n\t\tstatus CodeInterpreterStatus\n\t}{\n\t\t{\n\t\t\tname:   \"empty status\",\n\t\t\tstatus: CodeInterpreterStatus{},\n\t\t},\n\t\t{\n\t\t\tname: \"status with ready\",\n\t\t\tstatus: CodeInterpreterStatus{\n\t\t\t\tReady: boolPtr(true),\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"status with conditions\",\n\t\t\tstatus: CodeInterpreterStatus{\n\t\t\t\tConditions: []CodeInterpreterCondition{\n\t\t\t\t\t{\n\t\t\t\t\t\tType:   CodeInterpreterConditionReady,\n\t\t\t\t\t\tStatus: corev1.ConditionTrue,\n\t\t\t\t\t\tLastTransitionTime: metav1.Time{\n\t\t\t\t\t\t\tTime: time.Now(),\n\t\t\t\t\t\t},\n\t\t\t\t\t\tReason:  \"CodeInterpreterReady\",\n\t\t\t\t\t\tMessage: \"CodeInterpreter is ready\",\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"full status\",\n\t\t\tstatus: CodeInterpreterStatus{\n\t\t\t\tReady: boolPtr(true),\n\t\t\t\tConditions: []CodeInterpreterCondition{\n\t\t\t\t\t{\n\t\t\t\t\t\tType:   CodeInterpreterConditionReady,\n\t\t\t\t\t\tStatus: corev1.ConditionTrue,\n\t\t\t\t\t\tLastTransitionTime: metav1.Time{\n\t\t\t\t\t\t\tTime: time.Now(),\n\t\t\t\t\t\t},\n\t\t\t\t\t\tReason:  \"CodeInterpreterReady\",\n\t\t\t\t\t\tMessage: \"CodeInterpreter is ready to accept requests\",\n\t\t\t\t\t},\n\t\t\t\t\t{\n\t\t\t\t\t\tType:   CodeInterpreterConditionSandboxReady,\n\t\t\t\t\t\tStatus: corev1.ConditionTrue,\n\t\t\t\t\t\tLastTransitionTime: metav1.Time{\n\t\t\t\t\t\t\tTime: time.Now(),\n\t\t\t\t\t\t},\n\t\t\t\t\t\tReason:  \"SandboxCreated\",\n\t\t\t\t\t\tMessage: \"Sandbox pod is running\",\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\t// Validate conditions if present\n\t\t\tfor _, cond := range tt.status.Conditions {\n\t\t\t\tif cond.Type == \"\" {\n\t\t\t\t\tt.Error(\"Condition type should not be empty\")\n\t\t\t\t}\n\t\t\t\tif cond.Status == \"\" {\n\t\t\t\t\tt.Error(\"Condition status should not be empty\")\n\t\t\t\t}\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestCodeInterpreter(t *testing.T) {\n\tnow := metav1.NewTime(time.Now())\n\tduration15m := metav1.Duration{Duration: 15 * time.Minute}\n\n\tci := CodeInterpreter{\n\t\tTypeMeta: metav1.TypeMeta{\n\t\t\tAPIVersion: \"runtime.agentcube.volcano.sh/v1alpha1\",\n\t\t\tKind:       \"CodeInterpreter\",\n\t\t},\n\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\tName:      \"test-code-interpreter\",\n\t\t\tNamespace: \"default\",\n\t\t\tLabels: map[string]string{\n\t\t\t\t\"app\": \"code-interpreter\",\n\t\t\t},\n\t\t\tAnnotations: map[string]string{\n\t\t\t\t\"description\": \"Test code interpreter\",\n\t\t\t},\n\t\t},\n\t\tSpec: CodeInterpreterSpec{\n\t\t\tPorts: []TargetPort{\n\t\t\t\t{\n\t\t\t\t\tName:     \"jupyter\",\n\t\t\t\t\tPort:     8888,\n\t\t\t\t\tProtocol: ProtocolHTTP,\n\t\t\t\t},\n\t\t\t},\n\t\t\tTemplate: &CodeInterpreterSandboxTemplate{\n\t\t\t\tSpec: corev1.PodSpec{\n\t\t\t\t\tContainers: []corev1.Container{\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\tName:  \"code-interpreter\",\n\t\t\t\t\t\t\tImage: \"jupyter/scipy-notebook:latest\",\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t\tSessionTimeout: &duration15m,\n\t\t\tAuthMode:       AuthModePicoD,\n\t\t},\n\t\tStatus: CodeInterpreterStatus{\n\t\t\tReady: boolPtr(true),\n\t\t\tConditions: []CodeInterpreterCondition{\n\t\t\t\t{\n\t\t\t\t\tType:   CodeInterpreterConditionReady,\n\t\t\t\t\tStatus: corev1.ConditionTrue,\n\t\t\t\t\tLastTransitionTime: metav1.Time{\n\t\t\t\t\t\tTime: now.Time,\n\t\t\t\t\t},\n\t\t\t\t\tReason:  \"CodeInterpreterReady\",\n\t\t\t\t\tMessage: \"CodeInterpreter is ready\",\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\n\t// Validate TypeMeta\n\tif ci.APIVersion != \"runtime.agentcube.volcano.sh/v1alpha1\" {\n\t\tt.Errorf(\"Expected APIVersion 'runtime.agentcube.volcano.sh/v1alpha1', got %s\", ci.APIVersion)\n\t}\n\n\tif ci.Kind != \"CodeInterpreter\" {\n\t\tt.Errorf(\"Expected Kind 'CodeInterpreter', got %s\", ci.Kind)\n\t}\n\n\t// Validate ObjectMeta\n\tif ci.Name != \"test-code-interpreter\" {\n\t\tt.Errorf(\"Expected name 'test-code-interpreter', got %s\", ci.Name)\n\t}\n\n\tif ci.Namespace != \"default\" {\n\t\tt.Errorf(\"Expected namespace 'default', got %s\", ci.Namespace)\n\t}\n\n\t// Validate Spec\n\tif len(ci.Spec.Ports) != 1 {\n\t\tt.Errorf(\"Expected 1 port, got %d\", len(ci.Spec.Ports))\n\t}\n\n\tif ci.Spec.Ports[0].Port != 8888 {\n\t\tt.Errorf(\"Expected port 8888, got %d\", ci.Spec.Ports[0].Port)\n\t}\n\n\tif ci.Spec.Template == nil {\n\t\tt.Error(\"Expected Template to be set\")\n\t}\n\n\tif ci.Spec.AuthMode != AuthModePicoD {\n\t\tt.Errorf(\"Expected auth mode %s, got %s\", AuthModePicoD, ci.Spec.AuthMode)\n\t}\n\n\t// Validate Status\n\tif ci.Status.Ready == nil || !*ci.Status.Ready {\n\t\tt.Error(\"Expected Ready to be true\")\n\t}\n\n\tif len(ci.Status.Conditions) != 1 {\n\t\tt.Errorf(\"Expected 1 condition, got %d\", len(ci.Status.Conditions))\n\t}\n}\n\nfunc TestCodeInterpreterList(t *testing.T) {\n\tlist := CodeInterpreterList{\n\t\tTypeMeta: metav1.TypeMeta{\n\t\t\tAPIVersion: \"runtime.agentcube.volcano.sh/v1alpha1\",\n\t\t\tKind:       \"CodeInterpreterList\",\n\t\t},\n\t\tListMeta: metav1.ListMeta{\n\t\t\tResourceVersion: \"12345\",\n\t\t\tContinue:        \"\",\n\t\t},\n\t\tItems: []CodeInterpreter{\n\t\t\t{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\t\t\tName:      \"ci-1\",\n\t\t\t\t\tNamespace: \"default\",\n\t\t\t\t},\n\t\t\t\tSpec: CodeInterpreterSpec{\n\t\t\t\t\tTemplate: &CodeInterpreterSandboxTemplate{\n\t\t\t\t\t\tSpec: corev1.PodSpec{\n\t\t\t\t\t\t\tContainers: []corev1.Container{\n\t\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\t\tName:  \"code-interpreter\",\n\t\t\t\t\t\t\t\t\tImage: \"python:3.11\",\n\t\t\t\t\t\t\t\t},\n\t\t\t\t\t\t\t},\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t\t{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\t\t\tName:      \"ci-2\",\n\t\t\t\t\tNamespace: \"default\",\n\t\t\t\t},\n\t\t\t\tSpec: CodeInterpreterSpec{\n\t\t\t\t\tTemplate: &CodeInterpreterSandboxTemplate{\n\t\t\t\t\t\tSpec: corev1.PodSpec{\n\t\t\t\t\t\t\tContainers: []corev1.Container{\n\t\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\t\tName:  \"code-interpreter\",\n\t\t\t\t\t\t\t\t\tImage: \"node:18\",\n\t\t\t\t\t\t\t\t},\n\t\t\t\t\t\t\t},\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\n\tif len(list.Items) != 2 {\n\t\tt.Errorf(\"Expected 2 items, got %d\", len(list.Items))\n\t}\n\n\tif list.Items[0].Name != \"ci-1\" {\n\t\tt.Errorf(\"Expected first item name 'ci-1', got %s\", list.Items[0].Name)\n\t}\n\n\tif list.Items[1].Name != \"ci-2\" {\n\t\tt.Errorf(\"Expected second item name 'ci-2', got %s\", list.Items[1].Name)\n\t}\n}\n\nfunc TestCodeInterpreterDeepCopy(t *testing.T) {\n\tnow := metav1.NewTime(time.Now())\n\tduration15m := metav1.Duration{Duration: 15 * time.Minute}\n\n\toriginal := &CodeInterpreter{\n\t\tTypeMeta: metav1.TypeMeta{\n\t\t\tAPIVersion: \"runtime.agentcube.volcano.sh/v1alpha1\",\n\t\t\tKind:       \"CodeInterpreter\",\n\t\t},\n\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\tName:      \"original\",\n\t\t\tNamespace: \"default\",\n\t\t\tLabels: map[string]string{\n\t\t\t\t\"key\": \"value\",\n\t\t\t},\n\t\t},\n\t\tSpec: CodeInterpreterSpec{\n\t\t\tPorts: []TargetPort{\n\t\t\t\t{\n\t\t\t\t\tName:     \"http\",\n\t\t\t\t\tPort:     8080,\n\t\t\t\t\tProtocol: ProtocolHTTP,\n\t\t\t\t},\n\t\t\t},\n\t\t\tTemplate: &CodeInterpreterSandboxTemplate{\n\t\t\t\tLabels: map[string]string{\n\t\t\t\t\t\"app\": \"code-interpreter\",\n\t\t\t\t},\n\t\t\t\tSpec: corev1.PodSpec{\n\t\t\t\t\tContainers: []corev1.Container{\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\tName:  \"code-interpreter\",\n\t\t\t\t\t\t\tImage: \"python:3.11\",\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t\tSessionTimeout: &duration15m,\n\t\t\tWarmPoolSize:   int32Ptr(5),\n\t\t\tAuthMode:       AuthModePicoD,\n\t\t},\n\t\tStatus: CodeInterpreterStatus{\n\t\t\tReady: boolPtr(true),\n\t\t\tConditions: []CodeInterpreterCondition{\n\t\t\t\t{\n\t\t\t\t\tType:   CodeInterpreterConditionReady,\n\t\t\t\t\tStatus: corev1.ConditionTrue,\n\t\t\t\t\tLastTransitionTime: metav1.Time{\n\t\t\t\t\t\tTime: now.Time,\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\n\t// Test DeepCopy\n\tcopied := original.DeepCopy()\n\n\t// Ensure copied is not nil\n\tif copied == nil {\n\t\tt.Fatal(\"DeepCopy returned nil\")\n\t}\n\n\t// Verify basic fields are equal\n\tif copied.Name != original.Name {\n\t\tt.Errorf(\"Expected name '%s', got '%s'\", original.Name, copied.Name)\n\t}\n\n\tif copied.Spec.AuthMode != original.Spec.AuthMode {\n\t\tt.Errorf(\"Expected auth mode '%s', got '%s'\", original.Spec.AuthMode, copied.Spec.AuthMode)\n\t}\n\n\t// Verify that slices are independent (modifying original doesn't affect copy)\n\toriginal.Labels[\"new-key\"] = \"new-value\"\n\tif _, exists := copied.Labels[\"new-key\"]; exists {\n\t\tt.Error(\"Labels should be independent between original and copy\")\n\t}\n\n\t// Modify original ports\n\toriginal.Spec.Ports[0].Port = 9090\n\tif copied.Spec.Ports[0].Port == 9090 {\n\t\tt.Error(\"Ports should be independent between original and copy\")\n\t}\n\n\t// Modify original template labels\n\toriginal.Spec.Template.Labels[\"new-label\"] = \"value\"\n\tif _, exists := copied.Spec.Template.Labels[\"new-label\"]; exists {\n\t\tt.Error(\"Template labels should be independent between original and copy\")\n\t}\n\n\t// Modify original session timeout\n\toriginal.Spec.SessionTimeout.Duration = 30 * time.Minute\n\tif copied.Spec.SessionTimeout.Duration == 30*time.Minute {\n\t\tt.Error(\"SessionTimeout should be independent between original and copy\")\n\t}\n\n\t// Modify original warm pool size\n\t*original.Spec.WarmPoolSize = 10\n\tif *copied.Spec.WarmPoolSize == 10 {\n\t\tt.Error(\"WarmPoolSize should be independent between original and copy\")\n\t}\n\n\t// Modify original conditions\n\toriginal.Status.Conditions[0].Type = CodeInterpreterConditionFailed\n\tif copied.Status.Conditions[0].Type == CodeInterpreterConditionFailed {\n\t\tt.Error(\"Conditions should be independent between original and copy\")\n\t}\n\n\t// Modify original ready\n\t*original.Status.Ready = false\n\tif *copied.Status.Ready == false {\n\t\tt.Error(\"Ready should be independent between original and copy\")\n\t}\n\n\t// Test DeepCopyInto\n\tvar into CodeInterpreter\n\toriginal.DeepCopyInto(&into)\n\n\tif into.Name != original.Name {\n\t\tt.Errorf(\"Expected name '%s', got '%s'\", original.Name, into.Name)\n\t}\n}\n\nfunc TestCodeInterpreterListDeepCopy(t *testing.T) {\n\toriginal := &CodeInterpreterList{\n\t\tTypeMeta: metav1.TypeMeta{\n\t\t\tAPIVersion: \"runtime.agentcube.volcano.sh/v1alpha1\",\n\t\t\tKind:       \"CodeInterpreterList\",\n\t\t},\n\t\tListMeta: metav1.ListMeta{\n\t\t\tResourceVersion: \"12345\",\n\t\t},\n\t\tItems: []CodeInterpreter{\n\t\t\t{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\t\t\tName: \"ci-1\",\n\t\t\t\t},\n\t\t\t\tSpec: CodeInterpreterSpec{\n\t\t\t\t\tTemplate: &CodeInterpreterSandboxTemplate{\n\t\t\t\t\t\tSpec: corev1.PodSpec{\n\t\t\t\t\t\t\tContainers: []corev1.Container{\n\t\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\t\tName:  \"code-interpreter