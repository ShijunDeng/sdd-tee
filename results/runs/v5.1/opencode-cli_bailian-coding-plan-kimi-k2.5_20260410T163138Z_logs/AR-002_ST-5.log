ntime-2\" {\n564: \t\tt.Errorf(\"Expected second item name 'runtime-2', got %s\", list.Items[1].Name)\n565: \t}\n566: \n567: \tif list.Items[0].Spec.Image != \"busybox:latest\" {\n568: \t\tt.Errorf(\"Expected first item image 'busybox:latest', got %s\", list.Items[0].Spec.Image)\n569: \t}\n570: \n571: \tif list.Items[1].Spec.Image != \"ubuntu:22.04\" {\n572: \t\tt.Errorf(\"Expected second item image 'ubuntu:22.04', got %s\", list.Items[1].Spec.Image)\n573: \t}\n574: }\n575: \n576: func TestAgentRuntimeDeepCopy(t *testing.T) {\n577: \tnow := metav1.NewTime(time.Now())\n578: \n579: \toriginal := &AgentRuntime{\n580: \t\tTypeMeta: metav1.TypeMeta{\n581: \t\t\tAPIVersion: \"runtime.agentcube.volcano.sh/v1alpha1\",\n582: \t\t\tKind:       \"AgentRuntime\",\n583: \t\t},\n584: \t\tObjectMeta: metav1.ObjectMeta{\n585: \t\t\tName:      \"original\",\n586: \t\t\tNamespace: \"default\",\n587: \t\t\tLabels: map[string]string{\n588: \t\t\t\t\"key\": \"value\",\n589: \t\t\t},\n590: \t\t},\n591: \t\tSpec: AgentRuntimeSpec{\n592: \t\t\tImage: \"ubuntu:22.04\",\n593: \t\t\tResources: &corev1.ResourceRequirements{\n594: \t\t\t\tLimits: corev1.ResourceList{\n595: \t\t\t\t\tcorev1.ResourceCPU: resource.MustParse(\"1000m\"),\n596: \t\t\t\t},\n597: \t\t\t},\n598: \t\t\tEnv: []corev1.EnvVar{\n599: \t\t\t\t{Name: \"FOO\", Value: \"bar\"},\n600: \t\t\t},\n601: \t\t\tNodeSelector: map[string]string{\n602: \t\t\t\t\"node-type\": \"sandbox\",\n603: \t\t\t},\n604: \t\t},\n605: \t\tStatus: AgentRuntimeStatus{\n606: \t\t\tPhase:     AgentRuntimePhaseRunning,\n607: \t\t\tSandboxID: \"sandbox-abc123\",\n608: \t\t\tStartTime: &now,\n609: \t\t\tConditions: []AgentRuntimeCondition{\n610: \t\t\t\t{\n611: \t\t\t\t\tType:   AgentRuntimeConditionReady,\n612: \t\t\t\t\tStatus: corev1.ConditionTrue,\n613: \t\t\t\t},\n614: \t\t\t},\n615: \t\t},\n616: \t}\n617: \n618: \t// Test DeepCopy\n619: \tcopied := original.DeepCopy()\n620: \n621: \t// Ensure copied is not nil\n622: \tif copied == nil {\n623: \t\tt.Fata