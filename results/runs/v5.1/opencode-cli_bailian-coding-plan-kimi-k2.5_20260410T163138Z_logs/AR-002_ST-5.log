{\"HTTPS\", ProtocolHTTPS, \"HTTPS\"},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tif string(tt.protocol) != tt.expected {\n\t\t\t\tt.Errorf(\"Expected protocol %s, got %s\", tt.expected, tt.protocol)\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestAuthModeTypeValues(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\tauthMode AuthModeType\n\t\texpected string\n\t}{\n\t\t{\"PicoD\", AuthModePicoD, \"picod\"},\n\t\t{\"None\", AuthModeNone, \"none\"},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tif string(tt.authMode) != tt.expected {\n\t\t\t\tt.Errorf(\"Expected auth mode %s, got %s\", tt.expected, tt.authMode)\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestTargetPort(t *testing.T) {\n\ttests := []struct {\n\t\tname       string\n\t\ttargetPort TargetPort\n\t}{\n\t\t{\n\t\t\tname: \"minimal target port\",\n\t\t\ttargetPort: TargetPort{\n\t\t\t\tPort:     8080,\n\t\t\t\tProtocol: ProtocolHTTP,\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"target port with all fields\",\n\t\t\ttargetPort: TargetPort{\n\t\t\t\tPathPrefix: \"/api\",\n\t\t\t\tName:       \"http-port\",\n\t\t\t\tPort:       443,\n\t\t\t\tProtocol:   ProtocolHTTPS,\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"target port without protocol (uses default)\",\n\t\t\ttargetPort: TargetPort{\n\t\t\t\tPort: 3000,\n\t\t\t},\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tif tt.targetPort.Port == 0 {\n\t\t\t\tt.Error(\"Port should not be 0\")\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestCodeInterpreterSandboxTemplate(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\ttemplate CodeInterpreterSandboxTemplate\n\t}{\n\t\t{\n\t\t\tname: \"template with pod spec\",\n\t\t\ttemplate: CodeInterpreterSandboxTemplate{\n\t\t\t\tSpec: corev1.PodSpec{\n\t\t\t\t\tContainers: []corev1.Container{\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\tName:  \"code-interpreter\",\n\t\t\t\t\t\t\tImage: \"python:3.11\",\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"template with labels and annotations\",\n\t\t\ttemplate: CodeInterpreterSandboxTemplate{\n\t\t\t\tLabels: map[string]string{\n\t\t\t\t\t\"app\": \"code-interpreter\",\n\t\t\t\t},\n\t\t\t\tAnnotations: map[string]string{\n\t\t\t\t\t\"description\": \"Code interpreter sandbox\",\n\t\t\t\t},\n\t\t\t\tSpec: corev1.PodSpec{\n\t\t\t\t\tContainers: []corev1.Container{\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\tName:  \"code-interpreter\",\n\t\t\t\t\t\t\tImage: \"node:18\",\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"template with full pod spec\",\n\t\t\ttemplate: CodeInterpreterSandboxTemplate{\n\t\t\t\tLabels: map[string]string{\n\t\t\t\t\t\"app\":     \"code-interpreter\",\n\t\t\t\t\t\"version\": \"v1\",\n\t\t\t\t},\n\t\t\t\tAnnotations: map[string]string{\n\t\t\t\t\t\"prometheus.io/scrape\": \"true\",\n\t\t\t\t},\n\t\t\t\tSpec: corev1.PodSpec{\n\t\t\t\t\tContainers: []corev1.Container{\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\tName:    \"code-interpreter\",\n\t\t\t\t\t\t\tImage:   \"jupyter/scipy-notebook:latest\",\n\t\t\t\t\t\t\tCommand: []string{\"jupyter\", \"notebook\"},\n\t\t\t\t\t\t\tArgs:    []string{\"--ip=0.0.0.0\"},\n\t\t\t\t\t\t\tPorts: []corev1.ContainerPort{\n\t\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\t\tName:          \"notebook\",\n\t\t\t\t\t\t\t\t\tContainerPort: 8888,\n\t\t\t\t\t\t\t\t\tProtocol:      corev1.ProtocolTCP,\n\t\t\t\t\t\t\t\t},\n\t\t\t\t\t\t\t},\n\t\t\t\t\t\t\tResources: corev1.ResourceRequirements{\n\t\t\t\t\t\t\t\tRequests: corev1.ResourceList{\n\t\t\t\t\t\t\t\t\tcorev1.ResourceCPU:    resource.MustParse(\"500m\"),\n\t\t\t\t\t\t\t\t\tcorev1.ResourceMemory: resource.MustParse(\"512Mi\"),\n\t\t\t\t\t\t\t\t},\n\t\t\t\t\t\t\t\tLimits: corev1.ResourceList{\n\t\t\t\t\t\t\t\t\tcorev1.ResourceCPU:    resource.MustParse(\"1000m\"),\n\t\t\t\t\t\t\t\t\tcorev1.ResourceMemory: resource.MustParse(\"1Gi\"),\n\t\t\t\t\t\t\t\t},\n\t\t\t\t\t\t\t},\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t\tServiceAccountName: \"code-interpreter-sa\",\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tif len(tt.template.Spec.Containers) == 0 {\n\t\t\t\tt.Error(\"Template should have at least one container\")\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestCodeInterpreterSpec(t *testing.T) {\n\tduration15m := metav1.Duration{Duration: 15 * time.Minute}\n\tduration8h := metav1.Duration{Duration: 8 * time.Hour}\n\n\ttests := []struct {\n\t\tname string\n\t\tspec CodeInterpreterSpec\n\t}{\n\t\t{\n\t\t\tname: \"minimal spec with template\",\n\t\t\tspec: CodeInterpreterSpec{\n\t\t\t\tTemplate: &CodeInterpreterSandboxTemplate{\n\t\t\t\t\tSpec: corev1.PodSpec{\n\t\t\t\t\t\tContainers: []corev1.Container{\n\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\tName:  \"code-interpreter\",\n\t\t\t\t\t\t\t\tImage: \"python:3.11\",\n\t\t\t\t\t\t\t},\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"spec with ports\",\n\t\t\tspec: CodeInterpreterSpec{\n\t\t\t\tPorts: []TargetPort{\n\t\t\t\t\t{\n\t\t\t\t\t\tName:       \"http\",\n\t\t\t\t\t\tPort:       8080,\n\t\t\t\t\t\tProtocol:   ProtocolHTTP,\n\t\t\t\t\t\tPathPrefix: \"/api\",\n\t\t\t\t\t},\n\t\t\t\t\t{\n\t\t\t\t\t\tName:     \"https\",\n\t\t\t\t\t\tPort:     8443,\n\t\t\t\t\t\tProtocol: ProtocolHTTPS,\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t\tTemplate: &CodeInterpreterSandboxTemplate{\n\t\t\t\t\tSpec: corev1.PodSpec{\n\t\t\t\t\t\tContainers: []corev1.Container{\n\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\tName:  \"code-interpreter\",\n\t\t\t\t\t\t\t\tImage: \"nginx:latest\",\n\t\t\t\t\t\t\t},\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"spec with timeouts\",\n\t\t\tspec: CodeInterpreterSpec{\n\t\t\t\tTemplate: &CodeInterpreterSandboxTemplate{\n\t\t\t\t\tSpec: corev1.PodSpec{\n\t\t\t\t\t\tContainers: []corev1.Container{\n\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\tName:  \"code-interpreter\",\n\t\t\t\t\t\t\t\tImage: \"busybox:latest\",\n\t\t\t\t\t\t\t},\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t\tSessionTimeout:     &duration15m,\n\t\t\t\tMaxSessionDuration: &duration8h,\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"spec with warm pool\",\n\t\t\tspec: CodeInterpreterSpec{\n\t\t\t\tTemplate: &CodeInterpreterSandboxTemplate{\n\t\t\t\t\tSpec: corev1.PodSpec{\n\t\t\t\t\t\tContainers: []corev1.Container{\n\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\tName:  \"code-interpreter\",\n\t\t\t\t\t\t\t\tImage: \"busybox:latest\",\n\t\t\t\t\t\t\t},\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t\tWarmPoolSize: int32Ptr(5),\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"spec with auth mode\",\n\t\t\tspec: CodeInterpreterSpec{\n\t\t\t\tTemplate: &CodeInterpreterSandboxTemplate{\n\t\t\t\t\tSpec: corev1.PodSpec{\n\t\t\t\t\t\tContainers: []corev1.Container{\n\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\tName:  \"code-interpreter\",\n\t\t\t\t\t\t\t\tImage: \"busybox:latest\",\n\t\t\t\t\t\t\t},\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t\tAuthMode: AuthModePicoD,\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"spec with auth mode none\",\n\t\t\tspec: CodeInterpreterSpec{\n\t\t\t\tTemplate: &CodeInterpreterSandboxTemplate{\n\t\t\t\t\tSpec: corev1.PodSpec{\n\t\t\t\t\t\tContainers: []corev1.Container{\n\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\tName:  \"code-interpreter\",\n\t\t\t\t\t\t\t\tImage: \"busybox:latest\",\n\t\t\t\t\t\t\t},\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t\tAuthMode: AuthModeNone,\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"full spec\",\n\t\t\tspec: CodeInterpreterSpec{\n\t\t\t\tPorts: []TargetPort{\n\t\t\t\t\t{\n\t\t\t\t\t\tName:     \"jupyter\",\n\t\t\t\t\t\tPort:     8888,\n\t\t\t\t\t\tProtocol: ProtocolHTTP,\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t\tTemplate: &CodeInterpreterSandboxTemplate{\n\t\t\t\t\tLabels: map[string]string{\n\t\t\t\t\t\t\"app\": \"code-interpreter\",\n\t\t\t\t\t},\n\t\t\t\t\tSpec: corev1.PodSpec{\n\t\t\t\t\t\tContainers: []corev1.Container{\n\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\tName:  \"code-interpreter\",\n\t\t\t\t\t\t\t\tImage: \"jupyter/scipy-notebook:latest\",\n\t\t\t\t\t\t\t},\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t\tSessionTimeout:     &duration15m,\n\t\t\t\tMaxSessionDuration: &duration8h,\n\t\t\t\tWarmPoolSize:       int32Ptr(3),\n\t\t\t\tAuthMode:           AuthModePicoD,\n\t\t\t},\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tif tt.spec.Template == nil {\n\t\t\t\tt.Error(\"Template should not be nil\")\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestCodeInterpreterConditionTypeValues(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\tcondType CodeInterpreterConditionType\n\t\texpected string\n\t}{\n\t\t{\"Ready\", CodeInterpreterConditionReady, \"Ready\"},\n\t\t{\"SandboxCreated\", CodeInterpreterConditionSandboxCreated, \"SandboxCreated\"},\n\t\t{\"SandboxReady\", CodeInterpreterConditionSandboxReady, \"SandboxReady\"},\n\t\t{\"Failed\", CodeInterpreterConditionFailed, \"Failed\"},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tif string(tt.condType) != tt.expected {\n\t\t\t\tt.Errorf(\"Expected condition type %s, got %s\", tt.expected, tt.condType)\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestCodeInterpreterCondition(t *testing.T) {\n\tcond := CodeInterpreterCondition{\n\t\tType:   CodeInterpreterConditionReady,\n\t\tStatus: corev1.ConditionTrue,\n\t\tLastTransitionTime: metav1.Time{\n\t\t\tTime: time.Now(),\n\t\t},\n\t\tReason:  \"CodeInterpreterReady\",\n\t\tMessage: \"CodeInterpreter is ready\",\n\t}\n\n\tif cond.Type != CodeInterpreterConditionReady {\n\t\tt.Errorf(\"Expected condition type %s, got %s\", CodeInterpreterConditionReady, cond.Type)\n\t}\n\n\tif cond.Status != corev1.ConditionTrue {\n\t\tt.Errorf(\"Expected status %s, got %s\", corev1.ConditionTrue, cond.Status)\n\t}\n\n\tif cond.Reason != \"CodeInterpreterReady\" {\n\t\tt.Errorf(\"Expected reason 'CodeInterpreterReady', got %s\", cond.Reason)\n\t}\n\n\tif cond.Message != \"CodeInterpreter is ready\" {\n\t\tt.Errorf(\"Expected message 'CodeInterpreter is ready', got %s\", cond.Message)\n\t}\n}\n\nfunc TestCodeInterpreterStatus(t *testing.T) {\n\ttests := []struct {\n\t\tname   string\n\t\tstatus CodeInterpreterStatus\n\t}{\n\t\t{\n\t\t\tname:   \"empty status\",\n\t\t\tstatus: CodeInterpreterStatus{},\n\t\t},\n\t\t{\n\t\t\tname: \"status with ready\",\n\t\t\tstatus: CodeInterpreterStatus{\n\t\t\t\tReady: boolPtr(true),\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"status with conditions\",\n\t\t\tstatus: CodeInterpreterStatus{\n\t\t\t\tConditions: []CodeInterpreterCondition{\n\t\t\t\t\t{\n\t\t\t\t\t\tType:   CodeInterpreterConditionReady,\n\t\t\t\t\t\tStatus: corev1.ConditionTrue,\n\t\t\t\t\t\tLastTransitionTime: metav1.Time{\n\t\t\t\t\t\t\tTime: time.Now(),\n\t\t\t\t\t\t},\n\t\t\t\t\t\tReason:  \"CodeInterpreterReady\",\n\t\t\t\t\t\tMessage: \"CodeInterpreter is ready\",\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"full status\",\n\t\t\tstatus: CodeInterpreterStatus{\n\t\t\t\tReady: boolPtr(true),\n\t\t\t\tConditions: []CodeInterpreterCondition{\n\t\t\t\t\t{\n\t\t\t\t\t\tType:   CodeInterpreterConditionReady,\n\t\t\t\t\t\tStatus: corev1.ConditionTrue,\n\t\t\t\t\t\tLastTransitionTime: metav1.Time{\n\t\t\t\t\t\t\tTime: time.Now(),\n\t\t\t\t\t\t},\n\t\t\t\t\t\tReason:  \"CodeInterpreterReady\",\n\t\t\t\t\t\tMessage: \"CodeInterpreter is ready to accept requests\",\n\t\t\t\t\t},\n\t\t\t\t\t{\n\t\t\t\t\t\tType:   CodeInterpreterConditionSandboxReady,\n\t\t\t\t\t\tStatus: corev1.ConditionTrue,\n\t\t\t\t\t\tLastTransitionTime: metav1.Time{\n\t\t\t\t\t\t\tTime: time.Now(),\n\t\t\t\t\t\t},\n\t\t\t\t\t\tReason:  \"SandboxCreated\",\n\t\t\t\t\t\tMessage: \"Sandbox pod is running\",\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\t// Validate conditions if present\n\t\t\tfor _, cond := range tt.status.Conditions {\n\t\t\t\tif cond.Type == \"\" {\n\t\t\t\t\tt.Error(\"Condition type should not be empty\")\n\t\t\t\t}\n\t\t\t\tif cond