rpreter sandbox\",\n\t\t},\n\t\tSpec: corev1.PodSpec{\n\t\t\tContainers: []corev1.Container{\n\t\t\t\t{\n\t\t\t\t\tName:  \"code-interpreter\",\n\t\t\t\t\tImage: \"python:3.11\",\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\n\tcopied := original.DeepCopy()\n\n\tif copied == nil {\n\t\tt.Fatal(\"DeepCopy returned nil\")\n\t}\n\n\t// Verify independence of labels\n\toriginal.Labels[\"new-label\"] = \"value\"\n\tif _, exists := copied.Labels[\"new-label\"]; exists {\n\t\tt.Error(\"Labels should be independent\")\n\t}\n\n\t// Verify independence of annotations\n\toriginal.Annotations[\"new-annotation\"] = \"value\"\n\tif _, exists := copied.Annotations[\"new-annotation\"]; exists {\n\t\tt.Error(\"Annotations should be independent\")\n\t}\n\n\t// Verify independence of spec\n\toriginal.Spec.Containers[0].Name = \"modified\"\n\tif copied.Spec.Containers[0].Name == \"modified\" {\n\t\tt.Error(\"Spec should be independent\")\n\t}\n}\n\nfunc TestTargetPortDeepCopy(t *testing.T) {\n\toriginal := &TargetPort{\n\t\tPathPrefix: \"/api\",\n\t\tName:       \"http\",\n\t\tPort:       8080,\n\t\tProtocol:   ProtocolHTTP,\n\t}\n\n\tcopied := original.DeepCopy()\n\n\tif copied == nil {\n\t\tt.Fatal(\"DeepCopy returned nil\")\n\t}\n\n\tif copied.Port != original.Port {\n\t\tt.Errorf(\"Expected port %d, got %d\", original.Port, copied.Port)\n\t}\n\n\tif copied.Protocol != original.Protocol {\n\t\tt.Errorf(\"Expected protocol '%s', got '%s'\", original.Protocol, copied.Protocol)\n\t}\n\n\tif copied.PathPrefix != original.PathPrefix {\n\t\tt.Errorf(\"Expected path prefix '%s', got '%s'\", original.PathPrefix, copied.PathPrefix)\n\t}\n\n\tif copied.Name != original.Name {\n\t\tt.Errorf(\"Expected name '%s', got '%s'\", original.Name, copied.Name)\n\t}\n}\n\nfunc TestCodeInterpreterJSONMarshal(t *testing.T) {\n\tci := CodeInterpreter{\n\t\tTypeMeta: metav1.TypeMeta{\n\t\t\tAPIVersion: \"runtime.agentcube.volcano.sh/v1alpha1\",\n\t\t\tKind:       \"CodeInterpreter\",\n\t\t},\n\t\tObjectMeta: metav1.