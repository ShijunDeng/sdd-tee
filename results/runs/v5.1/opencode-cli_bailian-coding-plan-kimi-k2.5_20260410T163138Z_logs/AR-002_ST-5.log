(substr) && containsAtStr(s, substr))\n}\n\nfunc containsAtStr(s, substr string) bool {\n\tfor i := 0; i <= len(s)-len(substr); i++ {\n\t\tif s[i:i+len(substr)] == substr {\n\t\t\treturn true\n\t\t}\n\t}\n\treturn false\n}\n","additions":1,"deletions":1},"truncated":false},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/apis/runtime/v1alpha1/codeinterpreter_types_test.go","time":{"start":1775841324613,"end":1775841324835}}}}
