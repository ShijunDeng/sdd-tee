n38: \t// RequeueAfter tells the controller to requeue the resource after the specified duration.\n39: \tRequeueAfter time.Duration\n40: }\n41: \n42: // Result returns a controller-runtime Result from a ReconcileResult.\n43: func (r ReconcileResult) Result() reconcile.Result {\n44: \treturn reconcile.Result{\n45: \t\tRequeue:      r.Requeue,\n46: \t\tRequeueAfter: r.RequeueAfter,\n47: \t}\n48: }\n49: \n50: // Requeue returns a ReconcileResult that requeues immediately.\n51: func Requeue() ReconcileResult {\n52: \treturn ReconcileResult{\n53: \t\tRequeue: true,\n54: \t}\n55: }\n56: \n57: // RequeueAfter returns a ReconcileResult that requeues after the specified duration.\n58: func RequeueAfter(duration time.Duration) ReconcileResult {\n59: \treturn ReconcileResult{\n60: \t\tRequeueAfter: duration,\n61: \t}\n62: }\n63: \n64: // RequeueWithDelay returns a ReconcileResult that requeues after the specified duration.\n65: // This is an alias for RequeueAfter.\n66: func RequeueWithDelay(duration time.Duration) ReconcileResult {\n67: \treturn RequeueAfter(duration)\n68: }\n69: \n70: // Done returns a ReconcileResult indicating reconciliation is complete.\n71: func Done() ReconcileResult {\n72: \treturn ReconcileResult{}\n73: }\n74: \n75: // RequeueError returns a ReconcileResult that requeues after a calculated delay based on error.\n76: func RequeueError(err error, baseDelay time.Duration, retryCount int) ReconcileResult {\n77: \tif err == nil {\n78: \t\treturn Done()\n79: \t}\n80: \n81: \t// Calculate exponential backoff\n82: \tdelay := CalculateBackoff(baseDelay, 1000*time.Second, retryCount)\n83: \n84: \treturn ReconcileResult{\n85: \t\tRequeueAfter: delay,\n86: \t}\n87: }\n88: \n89: // IsRequeue returns true if the result indicates a requeue.\n90: func IsRequeue(r ReconcileResult) bool {\n91: \treturn r.Requeue || r.RequeueAfter > 0\n92: }\n93: \n94: // IsImmediateRequeue returns true if the result indicates an immediate requeue.\n95: func IsImmediateRequeue(r ReconcileResult) bool {\n96: \treturn r.Requeue && r.RequeueAfter == 0\n97: }\n\n(End of file - total 97 lines)\n</content>","metadata":{"preview":"/*\nCopyright 2026 The Volcano Authors.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\npackage controller\n\nimport (\n\t\"context\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/workloadmanager/controller/reconciler.go","time":{"start":1775853162509,"end":1775853162527}}}}
