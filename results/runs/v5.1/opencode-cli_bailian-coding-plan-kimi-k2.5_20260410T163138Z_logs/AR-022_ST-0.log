nces\n49: references:\n50:   - https://docs.python.org/3/library/tarfile.html\n51:   - https://docs.python.org/3/library/zipfile.html\n52: \n53: # Estimation\n54: estimation:\n55:   size: M\n56:   story_points: 5\n57:   days: 3\n\n(End of file - total 57 lines)\n</content>","metadata":{"preview":"id: AR-020\ntitle: CLI pack 命令\nmodule: cmd/cli\nlanguage: Python\nsize: M\nstatus: open\n\n# AR-020: CLI pack 命令\n# Module: cmd/cli\n# Language: Python\n# Size: M\n\n# OpenSpec Metadata\nopenspec:\n  version: \"1.0\"\n  project: agentcube\n\n# Architecture Requirement\nrequirement:\n  type: cli-command","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/changes/AR-020/spec.yaml","time":{"start":1775888703246,"end":1775888703267}}}}
