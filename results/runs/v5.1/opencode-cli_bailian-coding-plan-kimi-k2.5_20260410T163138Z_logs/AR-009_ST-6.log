{"type":"tool_use","timestamp":1775858953989,"sessionID":"ses_2868fbe40ffeEtJV6RkRLyNBrq","part":{"id":"prt_d797124c1001Nfln9n5xQ3CdrV","messageID":"msg_d7971083e001CeauQcwCIDx4KG","sessionID":"ses_2868fbe40ffeEtJV6RkRLyNBrq","type":"tool","tool":"read","callID":"toolu_functions.read:14","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/apis/runtime/v1alpha1/agentruntime_types_test.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/apis/runtime/v1alpha1/agentruntime_types_test.go</path>\n<type>file</type>\n<content>\n1: /*\n2: Copyright 2026 The Volcano Authors.\n3: \n4: Licensed under the Apache License, Version 2.0 (the \"License\");\n5: you may not use this file except in compliance with the License.\n6: You may obtain a copy of the License at\n7: \n8:     http://www.apache.org/licenses/LICENSE-2.0\n9: \n10: Unless required by applicable law or agreed to in writing, software\n11: distributed under the License is distributed on an \"AS IS\" BASIS,\n12: WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n13: See the License for the specific language governing permissions and\n14: limitations under the License.\n15: */\n16: \n17: package v1alpha1\n18: \n19: import (\n20: \t\"encoding/json\"\n21: \t\"testing\"\n22: \t\"time\"\n23: \n24: \tcorev1 \"k8s.io/api/core/v1\"\n25: \t\"k8s.io/apimachinery/pkg/api/resource\"\n26: \tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n27: )\n28: \n29: func TestAgentRuntimePhaseValues(t *testing.T) {\n30: \ttests := []struct {\n31: \t\tname     string\n32: \t\tphase    AgentRuntimePhase\n33: \t\texpected string\n34: \t}{\n35: \t\t{\"Pending\", AgentRuntimePhasePending, \"Pending\"},\n36: \t\t{\"Running\", AgentRuntimePhaseRunning, \"Running\"},\n37: \t\t{\"Succeeded\", AgentRuntimePhaseSucceeded, \"Succeeded\"},\n38: \t\t{\"Failed\", AgentRuntimePhaseFailed, \"Failed\"},\n39: \t\t{\"Unknown\", AgentRuntimePhaseUnknown, \"Unknown\"},\n40: \t}\n41: \n42: \tfor _, tt := range tests {\n43: \t\tt.Run(tt.name, func(t *testing.T) {\n44: \t\t\tif string(tt.phase) != tt.expected {\n45: \t\t\t\tt.Errorf(\"Expected phase %s, got %s\", tt.expected, tt.phase)\n46: \t\t\t}\n47: \t\t})\n48: \t}\n49: }\n50: \n51: func TestAgentRuntimeConditionTypeValues(t *testing.T) {\n52: \ttests := []struct {\n53: \t\tname     string\n54: \t\tcondType AgentRuntimeConditionType\n55: \t\texpected string\n56: \t}{\n57: \t\t{\"Ready\", AgentRuntimeConditionReady, \"Ready\"},\n58: \t\t{\"SandboxCreated\", AgentRuntimeConditionSandboxCreated, \"SandboxCreated\"},\n59: \t\t{\"SandboxReady\", AgentRuntimeConditionSandboxReady, \"SandboxReady\"},\n60: \t\t{\"Failed\", AgentRuntimeConditionFailed, \"Failed\"},\n61: \t}\n62: \n63: \tfor _, tt := range tests {\n64: \t\tt.Run(tt.name, func(t *testing.T) {\n65: \t\t\tif string(tt.condType) != tt.expected {\n66: \t\t\t\tt.Errorf(\"Expected condition type %s, got %s\", tt.expected, tt.condType)\n67: \t\t\t}\n68: \t\t})\n69: \t}\n70: }\n71: \n72: func TestAgentRuntimeSpec(t *testing.T) {\n73: \ttests := []struct {\n74: \t\tname string\n75: \t\tspec AgentRuntimeSpec\n76: \t}{\n77: \t\t{\n78: \t\t\tname: \"minimal spec with only image\",\n79: \t\t\tspec: AgentRuntimeSpec{\n80: \t\t\t\tImage: \"busybox:latest\",\n81: \t\t\t},\n82: \t\t},\n83: \t\t{\n84: \t\t\tname: \"spec with resources\",\n85: \t\t\tspec: AgentRuntimeSpec{\n86: \t\t\t\tImage: \"ubuntu:22.04\",\n87: \t\t\t\tResources: &corev1.ResourceRequirements{\n88: \t\t\t\t\tLimits: corev1.ResourceList{\n89: \t\t\t\t\t\tcorev1.ResourceCPU:    resource.MustParse(\"1000m\"),\n90: \t\t\t\t\t\tcorev1.ResourceMemory: resource.MustParse(\"1Gi\"),\n91: \t\t\t\t\t},\n92: \t\t\t\t\tRequests: corev1.ResourceList{\n93: \t\t\t\t\t\tcorev1.ResourceCPU:    resource.MustParse(\"500m\"),\n94: \t\t\t\t\t\tcorev1.ResourceMemory: resource.MustParse(\"512Mi\"),\n95: \t\t\t\t\t},\n96: \t\t\t\t},\n97: \t\t\t},\n98: \t\t},\n99: \t\t{\n100: \t\t\tname: \"spec with environment variables\",\n101: \t\t\tspec: AgentRuntimeSpec{\n102: \t\t\t\tImage: \"python:3.11\",\n103: \t\t\t\tEnv: []corev1.EnvVar{\n104: \t\t\t\t\t{\n105: \t\t\t\t\t\tName:  \"FOO\",\n106: \t\t\t\t\t\tValue: \"bar\",\n107: \t\t\t\t\t},\n108: \t\t\t\t\t{\n109: \t\t\t\t\t\tName: \"SECRET\",\n110: \t\t\t\t\t\tValueFrom: &corev1.EnvVarSource{\n111: \t\t\t\t\t\t\tSecretKeyRef: &corev1.SecretKeySelector{\n112: \t\t\t\t\t\t\t\tLocalObjectReference: corev1.LocalObjectReference{\n113: \t\t\t\t\t\t\t\t\tName: \"my-secret\",\n114: \t\t\t\t\t\t\t\t},\n115: \t\t\t\t\t\t\t\tKey: \"password\",\n116: \t\t\t\t\t\t\t},\n117: \t\t\t\t\t\t},\n118: \t\t\t\t\t},\n119: \t\t\t\t},\n120: \t\t\t},\n121: \t\t},\n122: \t\t{\n123: \t\t\tname: \"spec with command and args\",\n124: \t\t\tspec: AgentRuntimeSpec{\n125: \t\t\t\tImage:   \"python:3.11\",\n126: \t\t\t\tCommand: []string{\"python\", \"-m\", \"http.server\"},\n127: \t\t\t\tArgs:    []string{\"8080\"},\n128: \t\t\t},\n129: \t\t},\n130: \t\t{\n131: \t\t\tname: \"spec with working directory\",\n132: \t\t\tspec: AgentRuntimeSpec{\n133: \t\t\t\tImage:      \"node:18\",\n134: \t\t\t\tWorkingDir: \"/app\",\n135: \t\t\t},\n136: \t\t},\n137: \t\t{\n138: \t\t\tname: \"spec with ports\",\n139: \t\t\tspec: AgentRuntimeSpec{\n140: \t\t\t\tImage: \"nginx:latest\",\n141: \t\t\t\tPorts: []corev1.ContainerPort{\n142: \t\t\t\t\t{\n143: \t\t\t\t\t\tName:          \"http\",\n144: \t\t\t\t\t\tContainerPort: 80,\n145: \t\t\t\t\t\tProtocol:      corev1.ProtocolTCP,\n146: \t\t\t\t\t},\n147: \t\t\t\t\t{\n148: \t\t\t\t\t\tName:          \"https\",\n149: \t\t\t\t\t\tContainerPort: 443,\n150: \t\t\t\t\t\tProtocol:      corev1.ProtocolTCP,\n151: \t\t\t\t\t},\n152: \t\t\t\t},\n153: \t\t\t},\n154: \t\t},\n155: \t\t{\n156: \t\t\tname: \"spec with volume mounts and volumes\",\n157: \t\t\tspec: AgentRuntimeSpec{\n158: \t\t\t\tImage: \"busybox:latest\",\n159: \t\t\t\tVolumeMounts: []corev1.VolumeMount{\n160: \t\t\t\t\t{\n161: \t\t\t\t\t\tName:      \"data\",\n162: \t\t\t\t\t\tMountPath: \"/data\",\n163: \t\t\t\t\t},\n164: \t\t\t\t},\n165: \t\t\t\tVolumes: []corev1.Volume{\n166: \t\t\t\t\t{\n167: \t\t\t\t\t\tName: \"data\",\n168: \t\t\t\t\t\tVolumeSource: corev1.VolumeSource{\n169: \t\t\t\t\t\t\tEmptyDir: &corev1.EmptyDirVolumeSource{},\n170: \t\t\t\t\t\t},\n171: \t\t\t\t\t},\n172: \t\t\t\t},\n173: \t\t\t},\n174: \t\t},\n175: \t\t{\n176: \t\t\tname: \"spec with service account\",\n177: \t\t\tspec: AgentRuntimeSpec{\n178: \t\t\t\tImage:              \"busybox:latest\",\n179: \t\t\t\tServiceAccountName: \"sandbox-sa\",\n180: \t\t\t},\n181: \t\t},\n182: \t\t{\n183: \t\t\tname: \"spec with node selector\",\n184: \t\t\tspec: AgentRuntimeSpec{\n185: \t\t\t\tImage: \"busybox:latest\",\n186: \t\t\t\tNodeSelector: map[string]string{\n187: \t\t\t\t\t\"node-type\": \"sandbox\",\n188: \t\t\t\t\t\"gpu\":       \"nvidia\",\n189: \t\t\t\t},\n190: \t\t\t},\n191: \t\t},\n192: \t\t{\n193: \t\t\tname: \"spec with tolerations\",\n194: \t\t\tspec: AgentRuntimeSpec{\n195: \t\t\t\tImage: \"busybox:latest\",\n196: \t\t\t\tTolerations: []corev1.Toleration{\n197: \t\t\t\t\t{\n198: \t\t\t\t\t\tKey:      \"special\",\n199: \t\t\t\t\t\tOperator: corev1.TolerationOpEqual,\n200: \t\t\t\t\t\tValue:    \"true\",\n201: \t\t\t\t\t\tEffect:   corev1.TaintEffectNoSchedule,\n202: \t\t\t\t\t},\n203: \t\t\t\t},\n204: \t\t\t},\n205: \t\t},\n206: \t\t{\n207: \t\t\tname: \"spec with affinity\",\n208: \t\t\tspec: AgentRuntimeSpec{\n209: \t\t\t\tImage: \"busybox:latest\",\n210: \t\t\t\tAffinity: &corev1.Affinity{\n211: \t\t\t\t\tNodeAffinity: &corev1.NodeAffinity{\n212: \t\t\t\t\t\tRequiredDuringSchedulingIgnoredDuringExecution: &corev1.NodeSelector{\n213: \t\t\t\t\t\t\tNodeSelectorTerms: []corev1.NodeSelectorTerm{\n214: \t\t\t\t\t\t\t\t{\n215: \t\t\t\t\t\t\t\t\tMatchExpressions: []corev1.NodeSelectorRequirement{\n216: \t\t\t\t\t\t\t\t\t\t{\n217: \t\t\t\t\t\t\t\t\t\t\tKey:      \"kubernetes.io/os\",\n218: \t\t\t\t\t\t\t\t\t\t\tOperator: corev1.NodeSelectorOpIn,\n219: \t\t\t\t\t\t\t\t\t\t\tValues:   []string{\"linux\"},\n220: \t\t\t\t\t\t\t\t\t\t},\n221: \t\t\t\t\t\t\t\t\t},\n222: \t\t\t\t\t\t\t\t},\n223: \t\t\t\t\t\t\t},\n224: \t\t\t\t\t\t},\n225: \t\t\t\t\t},\n226: \t\t\t\t},\n227: \t\t\t},\n228: \t\t},\n229: \t\t{\n230: \t\t\tname: \"spec with timeouts\",\n231: \t\t\tspec: AgentRuntimeSpec{\n232: \t\t\t\tImage:                   \"busybox:latest\",\n233: \t\t\t\tTTLSecondsAfterFinished: int32Ptr(3600),\n234: \t\t\t\tIdleTimeoutSeconds:      int32Ptr(300),\n235: \t\t\t\tMaxLifetimeSeconds:      int32Ptr(7200),\n236: \t\t\t},\n237: \t\t},\n238: \t\t{\n239: \t\t\tname: \"full spec\",\n240: \t\t\tspec: AgentRuntimeSpec{\n241: \t\t\t\tImage:              \"ubuntu:22.04\",\n242: \t\t\t\tCommand:            []string{\"/bin/bash\", \"-c\"},\n243: \t\t\t\tArgs:               []string{\"sleep infinity\"},\n244: \t\t\t\tWorkingDir:         \"/workspace\",\n245: \t\t\t\tServiceAccountName: \"sandbox-sa\",\n246: \t\t\t\tResources: &corev1.ResourceRequirements{\n247: \t\t\t\t\tLimits: corev1.ResourceList{\n248: \t\t\t\t\t\tcorev1.ResourceCPU:    resource.MustParse(\"2000m\"),\n249: \t\t\t\t\t\tcorev1.ResourceMemory: resource.MustParse(\"4Gi\"),\n250: \t\t\t\t\t},\n251: \t\t\t\t},\n252: \t\t\t\tEnv: []corev1.EnvVar{\n253: \t\t\t\t\t{Name: \"ENV\", Value: \"production\"},\n254: \t\t\t\t},\n255: \t\t\t\tTTLSecondsAfterFinished: int32Ptr(600),\n256: \t\t\t\tIdleTimeoutSeconds:      int32Ptr(60),\n257: \t\t\t\tMaxLifetimeSeconds:      int32Ptr(3600),\n258: \t\t\t},\n259: \t\t},\n260: \t}\n261: \n262: \tfor _, tt := range tests {\n263: \t\tt.Run(tt.name, func(t *testing.T) {\n264: \t\t\tif tt.spec.Image == \"\" {\n265: \t\t\t\tt.Error(\"Image should not be empty\")\n266: \t\t\t}\n267: \t\t})\n268: \t}\n269: }\n270: \n271: func TestAgentRuntimeStatus(t *testing.T) {\n272: \tnow := metav1.NewTime(time.Now())\n273: \n274: \ttests := []struct {\n275: \t\tname   string\n276: \t\tstatus AgentRuntimeStatus\n277: \t}{\n278: \t\t{\n279: \t\t\tname:   \"empty status\",\n280: \t\t\tstatus: AgentRuntimeStatus{},\n281: \t\t},\n282: \t\t{\n283: \t\t\tname: \"status with phase\",\n284: \t\t\tstatus: AgentRuntimeStatus{\n285: \t\t\t\tPhase: AgentRuntimePhaseRunning,\n286: \t\t\t},\n287: \t\t},\n288: \t\t{\n289: \t\t\tname: \"status with sandbox info\",\n290: \t\t\tstatus: AgentRuntimeStatus{\n291: \t\t\t\tPhase:     AgentRuntimePhaseRunning,\n292: \t\t\t\tSandboxID: \"sandbox-abc123\",\n293: \t\t\t\tPodName:   \"agent-runtime-abc123\",\n294: \t\t\t\tPodIP:     \"10.244.0.5\",\n295: \t\t\t},\n296: \t\t},\n297: \t\t{\n298: \t\t\tname: \"status with timestamps\",\n299: \t\t\tstatus: AgentRuntimeStatus{\n300: \t\t\t\tPhase:            AgentRuntimePhaseSucceeded,\n301: \t\t\t\tStartTime:        &now,\n302: \t\t\t\tCompletionTime:   &now,\n303: \t\t\t\tLastActivityTime: &now,\n304: \t\t\t},\n305: \t\t},\n306: \t\t{\n307: \t\t\tname: \"status with conditions\",\n308: \t\t\tstatus: AgentRuntimeStatus{\n309: \t\t\t\tPhase: AgentRuntimePhaseRunning,\n310: \t\t\t\tConditions: []AgentRuntimeCondition{\n311: \t\t\t\t\t{\n312: \t\t\t\t\t\tType:   AgentRuntimeConditionReady,\n313: \t\t\t\t\t\tStatus: corev1.ConditionTrue,\n314: \t\t\t\t\t\tLastTransitionTime: metav1.Time{\n315: \t\t\t\t\t\t\tTime: time.Now(),\n316: \t\t\t\t\t\t},\n317: \t\t\t\t\t\tReason:  \"AgentRuntimeReady\",\n318: \t\t\t\t\t\tMessage: \"AgentRuntime is ready\",\n319: \t\t\t\t\t},\n320: \t\t\t\t\t{\n321: \t\t\t\t\t\tType:   AgentRuntimeConditionSandboxReady,\n322: \t\t\t\t\t\tStatus: corev1.ConditionTrue,\n323: \t\t\t\t\t\tLastTransitionTime: metav1.Time{\n324: \t\t\t\t\t\t\tTime: time.Now(),\n325: \t\t\t\t\t\t},\n326: \t\t\t\t\t\tReason:  \"SandboxCreated\",\n327: \t\t\t\t\t\tMessage: \"Sandbox pod is running\",\n328: \t\t\t\t\t},\n329: \t\t\t\t},\n330: \t\t\t},\n331: \t\t},\n332: \t\t{\n333: \t\t\tname: \"full status\",\n334: \t\t\tstatus: AgentRuntimeStatus{\n335: \t\t\t\tPhase:              AgentRuntimePhaseRunning,\n336: \t\t\t\tSandboxID:          \"sandbox-abc123\",\n337: \t\t\t\tPodName:            \"agent-runtime-abc123\",\n338: \t\t\t\tPodIP:              \"10.244.0.5\",\n339: \t\t\t\tStartTime:          &now,\n340: \t\t\t\tLastActivityTime:   &now,\n341: \t\t\t\tMessage:            \"Sandbox is running and ready\",\n342: \t\t\t\tReason:             \"SandboxRunning\",\n343: \t\t\t\tObservedGeneration: 1,\n344: \t\t\t\tConditions: []AgentRuntimeCondition{\n345: \t\t\t\t\t{\n346: \t\t\t\t\t\tType:   AgentRuntimeConditionReady,\n347: \t\t\t\t\t\tStatus: corev1.ConditionTrue,\n348: \t\t\t\t\t\tLastTransitionTime: metav1.Time{\n349: \t\t\t\t\t\t\tTime: time.Now(),\n350: \t\t\t\t\t\t},\n351: \t\t\t\t\t\tReason:  \"AgentRuntimeReady\",\n352: \t\t\t\t\t\tMessage: \"AgentRuntime is ready to accept requests\",\n353: \t\t\t\t\t},\n354: \t\t\t\t},\n355: \t\t\t},\n356: \t\t},\n357: \t}\n358: \n359: \tfor _, tt := range tests {\n360: \t\tt.Run(tt.name, func(t *testing.T) {\n361: \t\t\t// Validate phase if set\n362: \t\t\tif tt.status.Phase != \"\" {\n363: \t\t\t\tvalidPhases := []AgentRuntimePhase{\n364: \t\t\t\t\tAgentRuntimePhasePending,\n365: \t\t\t\t\tAgentRuntimePhaseRunning,\n366: \t\t\t\t\tAgentRuntimePhaseSucceeded,\n367: \t\t\t\t\tAgentRuntimePhaseFailed,\n368: \t\t\t\t\tAgentRuntimePhaseUnknown,\n369: \t\t\t\t}\n370: \t\t\t\tvalid := false\n371: \t\t\t\tfor _, p := range validPhases {\n372: \t\t\t\t\tif tt.status.Phase == p {\n373: \t\t\t\t\t\tvalid = true\n374: \t\t\t\t\t\tbreak\n375: \t\t\t\t\t}\n376: \t\t\t\t}\n377: \t\t\t\tif !valid {\n378: \t\t\t\t\tt.Errorf(\"Invalid phase: %s\", tt.status.Phase)\n379: \t\t\t\t}\n380: \t\t\t}\n381: \n382: \t\t\t// Validate conditions if present\n383: \t\t\tfor _, cond := range tt.status.Conditions {\n384: \t\t\t\tif cond.Type == \"\" {\n385: \t\t\t\t\tt.Error(\"Condition type should not be empty\")\n386: \t\t\t\t}\n387: \t\t\t\tif cond.Status == \"\" {\n388: \t\t\t\t\tt.Error(\"Condition status should not be empty\")\n389: \t\t\t\t}\n390: \t\t\t}\n391: \t\t})\n392: \t}\n393: }\n394: \n395: func TestAgentRuntimeCondition(t *testing.T) {\n396: \tcond := AgentRuntimeCondition{\n397: \t\tType:   AgentRuntimeConditionReady,\n398: \t\tStatus: corev1.ConditionTrue,\n399: \t\tLastTransitionTime: metav1.Time{\n400: \t\t\tTime: time.Now(),\n401: \t\t},\n402: \t\tReason:  \"AgentRuntimeReady\",\n403: \t\tMessage: \"AgentRuntime is ready\",\n404: \t}\n405: \n406: \tif cond.Type != AgentRuntimeConditionReady {\n407: \t\tt.Errorf(\"Expected condition type %s, got %s\", AgentRuntimeConditionReady, cond.Type)\n408: \t}\n409: \n410: \tif cond.Status != corev1.ConditionTrue {\n411: \t\tt.Errorf(\"Expected status %s, got %s\", corev1.ConditionTrue, cond.Status)\n412: \t}\n413: \n414: \tif cond.Reason != \"AgentRuntimeReady\" {\n415: \t\tt.Errorf(\"Expected reason 'AgentRuntimeReady', got %s\", cond.Reason)\n416: \t}\n417: \n418: \tif cond.Message != \"AgentRuntime is ready\" {\n419: \t\tt.Errorf(\"Expected message 'AgentRuntime is ready', got %s\", cond.Message)\n420: \t}\n421: }\n422: \n423: func TestAgentRuntime(t *testing.T) {\n424: \tnow := metav1.NewTime(time.Now())\n425: \n426: \truntime := AgentRuntime{\n427: \t\tTypeMeta: metav1.TypeMeta{\n428: \t\t\tAPIVersion: \"runtime.agentcube.volcano.sh/v1alpha1\",\n429: \t\t\tKind:       \"AgentRuntime\",\n430: \t\t},\n431: \t\tObjectMeta: metav1.ObjectMeta{\n432: \t\t\tName:      \"test-runtime\",\n433: \t\t\tNamespace: \"default\",\n434: \t\t\tLabels: map[string]string{\n435: \t\t\t\t\"app\": \"agent-runtime\",\n436: \t\t\t},\n437: \t\t\tAnnotations: map[string]string{\n438: \t\t\t\t\"description\": \"Test agent runtime\",\n439: \t\t\t},\n440: \t\t},\n441: \t\tSpec: AgentRuntimeSpec{\n442: \t\t\tImage: \"ubuntu:22.04\",\n443: \t\t\tResources: &corev1.ResourceRequirements{\n444: \t\t\t\tLimits: corev1.ResourceList{\n445: \t\t\t\t\tcorev1.ResourceCPU:    resource.MustParse(\"1000m\"),\n446: \t\t\t\t\tcorev1.ResourceMemory: resource.MustParse(\"1Gi\"),\n447: \t\t\t\t},\n448: \t\t\t},\n449: \t\t\tEnv: []corev1.EnvVar{\n450: \t\t\t\t{Name: \"FOO\", Value: \"bar\"},\n451: \t\t\t},\n452: \t\t\tTTLSecondsAfterFinished: int32Ptr(3600),\n453: \t\t},\n454: \t\tStatus: AgentRuntimeStatus{\n455: \t\t\tPhase:     AgentRuntimePhaseRunning,\n456: \t\t\tSandboxID: \"sandbox-abc123\",\n457: \t\t\tPodName:   \"test-runtime-abc123\",\n458: \t\t\tPodIP:     \"10.244.0.5\",\n459: \t\t\tStartTime: &now,\n460: \t\t\tConditions: []AgentRuntimeCondition{\n461: \t\t\t\t{\n462: \t\t\t\t\tType:   AgentRuntimeConditionReady,\n463: \t\t\t\t\tStatus: corev1.ConditionTrue,\n464: \t\t\t\t\tLastTransitionTime: metav1.Time{\n465: \t\t\t\t\t\tTime: time.Now(),\n466: \t\t\t\t\t},\n467: \t\t\t\t\tReason:  \"AgentRuntimeReady\",\n468: \t\t\t\t\tMessage: \"AgentRuntime is ready\",\n469: \t\t\t\t},\n470: \t\t\t},\n471: \t\t},\n472: \t}\n473: \n474: \t// Validate TypeMeta\n475: \tif runtime.APIVersion != \"runtime.agentcube.volcano.sh/v1alpha1\" {\n476: \t\tt.Errorf(\"Expected APIVersion 'runtime.agentcube.volcano.sh/v1alpha1', got %s\", runtime.APIVersion)\n477: \t}\n478: \n479: \tif runtime.Kind != \"AgentRuntime\" {\n480: \t\tt.Errorf(\"Expected Kind 'AgentRuntime', got %s\", runtime.Kind)\n481: \t}\n482: \n483: \t// Validate ObjectMeta\n484: \tif runtime.Name != \"test-runtime\" {\n485: \t\tt.Errorf(\"Expected name 'test-runtime', got %s\", runtime.Name)\n486: \t}\n487: \n488: \tif runtime.Namespace != \"default\" {\n489: \t\tt.Errorf(\"Expected namespace 'default', got %s\", runtime.Namespace)\n490: \t}\n491: \n492: \t// Validate Spec\n493: \tif runtime.Spec.Image != \"ubuntu:22.04\" {\n494: \t\tt.Errorf(\"Expected image 'ubuntu:22.04', got %s\", runtime.Spec.Image)\n495: \t}\n496: \n497: \tif runtime.Spec.Resources == nil {\n498: \t\tt.Error(\"Expected Resources to be set\")\n499: \t}\n500: \n501: \tif len(runtime.Spec.Env) != 1 {\n502: \t\tt.Errorf(\"Expected 1 env var, got %d\", len(runtime.Spec.Env))\n503: \t}\n504: \n