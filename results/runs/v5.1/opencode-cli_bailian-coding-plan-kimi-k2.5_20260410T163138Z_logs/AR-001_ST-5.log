{"type":"tool_use","timestamp":1775839856036,"sessionID":"ses_287b9a654ffeytIXZNa7Q03JxB","part":{"id":"prt_d784aa94a001Qfl9ICKdCjnITs","messageID":"msg_d784a9a29001PG6011MeC5Pv19","sessionID":"ses_287b9a654ffeytIXZNa7Q03JxB","type":"tool","tool":"write","callID":"toolu_functions.write:20","state":{"status":"completed","input":{"content":"/*\nCopyright 2026 The Volcano Authors.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\npackage v1alpha1\n\nimport (\n\t\"encoding/json\"\n\t\"testing\"\n\t\"time\"\n\n\tcorev1 \"k8s.io/api/core/v1\"\n\t\"k8s.io/apimachinery/pkg/api/resource\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n)\n\nfunc TestAgentRuntimePhaseValues(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\tphase    AgentRuntimePhase\n\t\texpected string\n\t}{\n\t\t{\"Pending\", AgentRuntimePhasePending, \"Pending\"},\n\t\t{\"Running\", AgentRuntimePhaseRunning, \"Running\"},\n\t\t{\"Succeeded\", AgentRuntimePhaseSucceeded, \"Succeeded\"},\n\t\t{\"Failed\", AgentRuntimePhaseFailed, \"Failed\"},\n\t\t{\"Unknown\", AgentRuntimePhaseUnknown, \"Unknown\"},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tif string(tt.phase) != tt.expected {\n\t\t\t\tt.Errorf(\"Expected phase %s, got %s\", tt.expected, tt.phase)\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestAgentRuntimeConditionTypeValues(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\tcondType AgentRuntimeConditionType\n\t\texpected string\n\t}{\n\t\t{\"Ready\", AgentRuntimeConditionReady, \"Ready\"},\n\t\t{\"SandboxCreated\", AgentRuntimeConditionSandboxCreated, \"SandboxCreated\"},\n\t\t{\"SandboxReady\", AgentRuntimeConditionSandboxReady, \"SandboxReady\"},\n\t\t{\"Failed\", AgentRuntimeConditionFailed, \"Failed\"},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tif string(tt.condType) != tt.expected {\n\t\t\t\tt.Errorf(\"Expected condition type %s, got %s\", tt.expected, tt.condType)\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestAgentRuntimeSpec(t *testing.T) {\n\ttests := []struct {\n\t\tname string\n\t\tspec AgentRuntimeSpec\n\t}{\n\t\t{\n\t\t\tname: \"minimal spec with only image\",\n\t\t\tspec: AgentRuntimeSpec{\n\t\t\t\tImage: \"busybox:latest\",\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"spec with resources\",\n\t\t\tspec: AgentRuntimeSpec{\n\t\t\t\tImage: \"ubuntu:22.04\",\n\t\t\t\tResources: &corev1.ResourceRequirements{\n\t\t\t\t\tLimits: corev1.ResourceList{\n\t\t\t\t\t\tcorev1.ResourceCPU:    resource.MustParse(\"1000m\"),\n\t\t\t\t\t\tcorev1.ResourceMemory: resource.MustParse(\"1Gi\"),\n\t\t\t\t\t},\n\t\t\t\t\tRequests: corev1.ResourceList{\n\t\t\t\t\t\tcorev1.ResourceCPU:    resource.MustParse(\"500m\"),\n\t\t\t\t\t\tcorev1.ResourceMemory: resource.MustParse(\"512Mi\"),\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"spec with environment variables\",\n\t\t\tspec: AgentRuntimeSpec{\n\t\t\t\tImage: \"python:3.11\",\n\t\t\t\tEnv: []corev1.EnvVar{\n\t\t\t\t\t{\n\t\t\t\t\t\tName:  \"FOO\",\n\t\t\t\t\t\tValue: \"bar\",\n\t\t\t\t\t},\n\t\t\t\t\t{\n\t\t\t\t\t\tName: \"SECRET\",\n\t\t\t\t\t\tValueFrom: &corev1.EnvVarSource{\n\t\t\t\t\t\t\tSecretKeyRef: &corev1.SecretKeySelector{\n\t\t\t\t\t\t\t\tLocalObjectReference: corev1.LocalObjectReference{\n\t\t\t\t\t\t\t\t\tName: \"my-secret\",\n\t\t\t\t\t\t\t\t},\n\t\t\t\t\t\t\t\tKey: \"password\",\n\t\t\t\t\t\t\t},\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"spec with command and args\",\n\t\t\tspec: AgentRuntimeSpec{\n\t\t\t\tImage:   \"python:3.11\",\n\t\t\t\tCommand: []string{\"python\", \"-m\", \"http.server\"},\n\t\t\t\tArgs:    []string{\"8080\"},\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"spec with working directory\",\n\t\t\tspec: AgentRuntimeSpec{\n\t\t\t\tImage:      \"node:18\",\n\t\t\t\tWorkingDir: \"/app\",\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"spec with ports\",\n\t\t\tspec: AgentRuntimeSpec{\n\t\t\t\tImage: \"nginx:latest\",\n\t\t\t\tPorts: []corev1.ContainerPort{\n\t\t\t\t\t{\n\t\t\t\t\t\tName:          \"http\",\n\t\t\t\t\t\tContainerPort: 80,\n\t\t\t\t\t\tProtocol:      corev1.ProtocolTCP,\n\t\t\t\t\t},\n\t\t\t\t\t{\n\t\t\t\t\t\tName:          \"https\",\n\t\t\t\t\t\tContainerPort: 443,\n\t\t\t\t\t\tProtocol:      corev1.ProtocolTCP,\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"spec with volume mounts and volumes\",\n\t\t\tspec: AgentRuntimeSpec{\n\t\t\t\tImage: \"busybox:latest\",\n\t\t\t\tVolumeMounts: []corev1.VolumeMount{\n\t\t\t\t\t{\n\t\t\t\t\t\tName:      \"data\",\n\t\t\t\t\t\tMountPath: \"/data\",\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t\tVolumes: []corev1.Volume{\n\t\t\t\t\t{\n\t\t\t\t\t\tName: \"data\",\n\t\t\t\t\t\tVolumeSource: corev1.VolumeSource{\n\t\t\t\t\t\t\tEmptyDir: &corev1.EmptyDirVolumeSource{},\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"spec with service account\",\n\t\t\tspec: AgentRuntimeSpec{\n\t\t\t\tImage:              \"busybox:latest\",\n\t\t\t\tServiceAccountName: \"sandbox-sa\",\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"spec with node selector\",\n\t\t\tspec: AgentRuntimeSpec{\n\t\t\t\tImage: \"busybox:latest\",\n\t\t\t\tNodeSelector: map[string]string{\n\t\t\t\t\t\"node-type\": \"sandbox\",\n\t\t\t\t\t\"gpu\":       \"nvidia\",\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"spec with tolerations\",\n\t\t\tspec: AgentRuntimeSpec{\n\t\t\t\tImage: \"busybox:latest\",\n\t\t\t\tTolerations: []corev1.Toleration{\n\t\t\t\t\t{\n\t\t\t\t\t\tKey:      \"special\",\n\t\t\t\t\t\tOperator: corev1.TolerationOpEqual,\n\t\t\t\t\t\tValue:    \"true\",\n\t\t\t\t\t\tEffect:   corev1.TaintEffectNoSchedule,\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"spec with affinity\",\n\t\t\tspec: AgentRuntimeSpec{\n\t\t\t\tImage: \"busybox:latest\",\n\t\t\t\tAffinity: &corev1.Affinity{\n\t\t\t\t\tNodeAffinity: &corev1.NodeAffinity{\n\t\t\t\t\t\tRequiredDuringSchedulingIgnoredDuringExecution: &corev1.NodeSelector{\n\t\t\t\t\t\t\tNodeSelectorTerms: []corev1.NodeSelectorTerm{\n\t\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\t\tMatchExpressions: []corev1.NodeSelectorRequirement{\n\t\t\t\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\t\t\t\tKey:      \"kubernetes.io/os\",\n\t\t\t\t\t\t\t\t\t\t\tOperator: corev1.NodeSelectorOpIn,\n\t\t\t\t\t\t\t\t\t\t\tValues:   []string{\"linux\"},\n\t\t\t\t\t\t\t\t\t\t},\n\t\t\t\t\t\t\t\t\t},\n\t\t\t\t\t\t\t\t},\n\t\t\t\t\t\t\t},\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"spec with timeouts\",\n\t\t\tspec: AgentRuntimeSpec{\n\t\t\t\tImage:                   \"busybox:latest\",\n\t\t\t\tTTLSecondsAfterFinished: int32Ptr(3600),\n\t\t\t\tIdleTimeoutSeconds:      int32Ptr(300),\n\t\t\t\tMaxLifetimeSeconds:      int32Ptr(7200),\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"full spec\",\n\t\t\tspec: AgentRuntimeSpec{\n\t\t\t\tImage:       \"ubuntu:22.04\",\n\t\t\t\tCommand:     []string{\"/bin/bash\", \"-c\"},\n\t\t\t\tArgs:        []string{\"sleep infinity\"},\n\t\t\t\tWorkingDir:  \"/workspace\",\n\t\t\t\tServiceAccountName: \"sandbox-sa\",\n\t\t\t\tResources: &corev1.ResourceRequirements{\n\t\t\t\t\tLimits: corev1.ResourceList{\n\t\t\t\t\t\tcorev1.ResourceCPU:    resource.MustParse(\"2000m\"),\n\t\t\t\t\t\tcorev1.ResourceMemory: resource.MustParse(\"4Gi\"),\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t\tEnv: []corev1.EnvVar{\n\t\t\t\t\t{Name: \"ENV\", Value: \"production\"},\n\t\t\t\t},\n\t\t\t\tTTLSecondsAfterFinished: int32Ptr(600),\n\t\t\t\tIdleTimeoutSeconds:      int32Ptr(60),\n\t\t\t\tMaxLifetimeSeconds:      int32Ptr(3600),\n\t\t\t},\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tif tt.spec.Image == \"\" {\n\t\t\t\tt.Error(\"Image should not be empty\")\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestAgentRuntimeStatus(t *testing.T) {\n\tnow := metav1.NewTime(time.Now())\n\n\ttests := []struct {\n\t\tname   string\n\t\tstatus AgentRuntimeStatus\n\t}{\n\t\t{\n\t\t\tname:   \"empty status\",\n\t\t\tstatus: AgentRuntimeStatus{},\n\t\t},\n\t\t{\n\t\t\tname: \"status with phase\",\n\t\t\tstatus: AgentRuntimeStatus{\n\t\t\t\tPhase: AgentRuntimePhaseRunning,\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"status with sandbox info\",\n\t\t\tstatus: AgentRuntimeStatus{\n\t\t\t\tPhase:     AgentRuntimePhaseRunning,\n\t\t\t\tSandboxID: \"sandbox-abc123\",\n\t\t\t\tPodName:   \"agent-runtime-abc123\",\n\t\t\t\tPodIP:     \"10.244.0.5\",\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"status with timestamps\",\n\t\t\tstatus: AgentRuntimeStatus{\n\t\t\t\tPhase:            AgentRuntimePhaseSucceeded,\n\t\t\t\tStartTime:        &now,\n\t\t\t\tCompletionTime:   &now,\n\t\t\t\tLastActivityTime: &now,\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"status with conditions\",\n\t\t\tstatus: AgentRuntimeStatus{\n\t\t\t\tPhase: AgentRuntimePhaseRunning,\n\t\t\t\tConditions: []AgentRuntimeCondition{\n\t\t\t\t\t{\n\t\t\t\t\t\tType:   AgentRuntimeConditionReady,\n\t\t\t\t\t\tStatus: corev1.ConditionTrue,\n\t\t\t\t\t\tLastTransitionTime: metav1.Time{\n\t\t\t\t\t\t\tTime: time.Now(),\n\t\t\t\t\t\t},\n\t\t\t\t\t\tReason:  \"AgentRuntimeReady\",\n\t\t\t\t\t\tMessage: \"AgentRuntime is ready\",\n\t\t\t\t\t},\n\t\t\t\t\t{\n\t\t\t\t\t\tType:   AgentRuntimeConditionSandboxReady,\n\t\t\t\t\t\tStatus: corev1.ConditionTrue,\n\t\t\t\t\t\tLastTransitionTime: metav1.Time{\n\t\t\t\t\t\t\tTime: time.Now(),\n\t\t\t\t\t\t},\n\t\t\t\t\t\tReason:  \"SandboxCreated\",\n\t\t\t\t\t\tMessage: \"Sandbox pod is running\",\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"full status\",\n\t\t\tstatus: AgentRuntimeStatus{\n\t\t\t\tPhase:              AgentRuntimePhaseRunning,\n\t\t\t\tSandboxID:          \"sandbox-abc123\",\n\t\t\t\tPodName:            \"agent-runtime-abc123\",\n\t\t\t\tPodIP:              \"10.244.0.5\",\n\t\t\t\tStartTime:          &now,\n\t\t\t\tLastActivityTime:   &now,\n\t\t\t\tMessage:            \"Sandbox is running and ready\",\n\t\t\t\tReason:             \"SandboxRunning\",\n\t\t\t\tObservedGeneration: 1,\n\t\t\t\tConditions: []AgentRuntimeCondition{\n\t\t\t\t\t{\n\t\t\t\t\t\tType:   AgentRuntimeConditionReady,\n\t\t\t\t\t\tStatus: corev1.ConditionTrue,\n\t\t\t\t\t\tLastTransitionTime: metav1.Time{\n\t\t\t\t\t\t\tTime: time.Now(),\n\t\t\t\t\t\t},\n\t\t\t\t\t\tReason:  \"AgentRuntimeReady\",\n\t\t\t\t\t\tMessage: \"AgentRuntime is ready to accept requests\",\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\t// Validate phase if set\n\t\t\tif tt.status.Phase != \"\" {\n\t\t\t\tvalidPhases := []AgentRuntimePhase{\n\t\t\t\t\tAgentRuntimePhasePending,\n\t\t\t\t\tAgentRuntimePhaseRunning,\n\t\t\t\t\tAgentRuntimePhaseSucceeded,\n\t\t\t\t\tAgentRuntimePhaseFailed,\n\t\t\t\t\tAgentRuntimePhaseUnknown,\n\t\t\t\t}\n\t\t\t\tvalid := false\n\t\t\t\tfor _, p := range validPhases {\n\t\t\t\t\tif tt.status.Phase == p {\n\t\t\t\t\t\tvalid = true\n\t\t\t\t\t\tbreak\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t\tif !valid {\n\t\t\t\t\tt.Errorf(\"Invalid phase: %s\", tt.status.Phase)\n\t\t\t\t}\n\t\t\t}\n\n\t\t\t// Validate conditions if present\n\t\t\tfor _, cond := range tt.status.Conditions {\n\t\t\t\tif cond.Type == \"\" {\n\t\t\t\t\tt.Error(\"Condition type should not be empty\")\n\t\t\t\t}\n\t\t\t\tif cond.Status == \"\" {\n\t\t\t\t\tt.Error(\"Condition status should not be empty\")\n\t\t\t\t}\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestAgentRuntimeCondition(t *testing.T) {\n\tcond := AgentRuntimeCondition{\n\t\tType:   AgentRuntimeConditionReady,\n\t\tStatus: corev1.ConditionTrue,\n\t\tLastTransitionTime: metav1.Time{\n\t\t\tTime: time.Now(),\n\t\t},\n\t\tReason:  \"AgentRuntimeReady\",\n\t\tMessage: \"AgentRuntime is ready\",\n\t}\n\n\tif cond.Type != AgentRuntimeConditionReady {\n\t\tt.Errorf(\"Expected condition type %s, got %s\", AgentRuntimeConditionReady, cond.Type)\n\t}\n\n\tif cond.Status != corev1.ConditionTrue {\n\t\tt.Errorf(\"Expected status %s, got %s\", corev1.ConditionTrue, cond.Status)\n\t}\n\n\tif cond.Reason != \"AgentRuntimeReady\" {\n\t\tt.Errorf(\"Expected reason 'AgentRuntimeReady', got %s\", cond.Reason)\n\t}\n\n\tif cond.Message != \"AgentRuntime is ready\" {\n\t\tt.Errorf(\"Expected message 'AgentRuntime is ready', got %s\", cond.Message)\n\t}\n}\n\nfunc TestAgentRuntime(t *testing.T) {\n\tnow := metav1.NewTime(time.Now())\n\n\truntime := AgentRuntime{\n\t\tTypeMeta: metav1.TypeMeta{\n\t\t\tAPIVersion: \"runtime.agentcube.volcano.sh/v1alpha1\",\n\t\t\tKind:       \"AgentRuntime\",\n\t\t},\n\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\tName:      \"test-runtime\",\n\t\t\tNamespace: \"default\",\n\t\t\tLabels: map[string]string{\n\t\t\t\t\"app\": \"agent-runtime\",\n\t\t\t},\n\t\t\tAnnotations: map[string]string{\n\t\t\t\t\"description\": \"Test agent runtime\",\n\t\t\t},\n\t\t},\n\t\tSpec: AgentRuntimeSpec{\n\t\t\tImage: \"ubuntu:22.04\",\n\t\t\tResources: &corev1.ResourceRequirements{\n\t\t\t\tLimits: corev1.ResourceList{\n\t\t\t\t\tcorev1.ResourceCPU:    resource.MustParse(\"1000m\"),\n\t\t\t\t\tcorev1.ResourceMemory: resource.MustParse(\"1Gi\"),\n\t\t\t\t},\n\t\t\t},\n\t\t\tEnv: []corev1.EnvVar{\n\t\t\t\t{Name: \"FOO\", Value: \"bar\"},\n\t\t\t},\n\t\t\tTTLSecondsAfterFinished: int32Ptr(3600),\n\t\t},\n\t\tStatus: AgentRuntimeStatus{\n\t\t\tPhase:     AgentRuntimePhaseRunning,\n\t\t\tSandboxID: \"sandbox-abc123\",\n\t\t\tPodName:   \"test-runtime-abc123\",\n\t\t\tPodIP:     \"10.244.0.5\",\n\t\t\tStartTime: &now,\n\t\t\tConditions: []AgentRuntimeCondition{\n\t\t\t\t{\n\t\t\t\t\tType:   AgentRuntimeConditionReady,\n\t\t\t\t\tStatus: corev1.ConditionTrue,\n\t\t\t\t\tLastTransitionTime: metav1.Time{\n\t\t\t\t\t\tTime: time.Now(),\n\t\t\t\t\t},\n\t\t\t\t\tReason:  \"AgentRuntimeReady\",\n\t\t\t\t\tMessage: \"AgentRuntime is ready\",\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\n\t// Validate TypeMeta\n\tif runtime.APIVersion != \"runtime.agentcube.volcano.sh/v1alpha1\" {\n\t\tt.Errorf(\"Expected APIVersion 'runtime.agentcube.volcano.sh/v1alpha1', got %s\", runtime.APIVersion)\n\t}\n\n\tif runtime.Kind != \"AgentRuntime\" {\n\t\tt.Errorf(\"Expected Kind 'AgentRuntime', got %s\", runtime.Kind)\n\t}\n\n\t// Validate ObjectMeta\n\tif runtime.Name != \"test-runtime\" {\n\t\tt.Errorf(\"Expected name 'test-runtime', got %s\", runtime.Name)\n\t}\n\n\tif runtime.Namespace != \"default\" {\n\t\tt.Errorf(\"Expected namespace 'default', got %s\", runtime.Namespace)\n\t}\n\n\t// Validate Spec\n\tif runtime.Spec.Image != \"ubuntu:22.04\" {\n\t\tt.Errorf(\"Expected image 'ubuntu:22.04', got %s\", runtime.Spec.Image)\n\t}\n\n\tif runtime.Spec.Resources == nil {\n\t\tt.Error(\"Expected Resources to be set\")\n\t}\n\n\tif len(runtime.Spec.Env) != 1 {\n\t\tt.Errorf(\"Expected 1 env var, got %d\", len(runtime.Spec.Env))\n\t}\n\n\tif *runtime.Spec.TTLSecondsAfterFinished != 3600 {\n\t\tt.Errorf(\"Expected TTLSecondsAfterFinished 3600, got %d\", *runtime.Spec.TTLSecondsAfterFinished)\n\t}\n\n\t// Validate Status\n\tif runtime.Status.Phase != AgentRuntimePhaseRunning {\n\t\tt.Errorf(\"Expected phase %s, got %s\", AgentRuntimePhaseRunning, runtime.Status.Phase)\n\t}\n\n\tif runtime.Status.SandboxID != \"sandbox-abc123\" {\n\t\tt.Errorf(\"Expected sandboxId 'sandbox-abc123', got %s\", runtime.Status.SandboxID)\n\t}\n\n\tif len(runtime.Status.Conditions) != 1 {\n\t\tt.Errorf(\"Expected 1 condition, got %d\", len(runtime.Status.Conditions))\n\t}\n}\n\nfunc TestAgentRuntimeList(t *testing.T) {\n\tlist := AgentRuntimeList{\n\t\tTypeMeta: metav1.TypeMeta{\n\t\t\tAPIVersion: \"runtime.agentcube.volcano.sh/v1alpha1\",\n\t\t\tKind:       \"AgentRuntimeList\",\n\t\t},\n\t\tListMeta: metav1.ListMeta{\n\t\t\tResourceVersion: \"12345\",\n\t\t\tContinue:        \"\",\n\t\t},\n\t\tItems: []AgentRuntime{\n\t\t\t{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\t\t\tName:      \"runtime-1\",\n\t\t\t\t\tNamespace: \"default\",\n\t\t\t\t},\n\t\t\t\tSpec: AgentRuntimeSpec{\n\t\t\t\t\tImage: \"busybox:latest\",\n\t\t\t\t},\n\t\t\t},\n\t\t\t{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\t\t\tName:      \"runtime-2\",\n\t\t\t\t\tNamespace: \"default\",\n\t\t\t\t},\n\t\t\t\tSpec: AgentRuntimeSpec{\n\t\t\t\t\tImage: \"ubuntu:22.04\",\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\n\tif len(list.Items) != 2 {\n\t\tt.Errorf(\"Expected 2 items, got %d\", len(list.Items))\n\t}\n\n\tif list.Items[0].Name != \"runtime-1\" {\n\t\tt.Errorf(\"Expected first item name 'runtime-1', got %s\", list.Items[0].Name)\n\t}\n\n\tif list.Items[1].Name != \"runtime-2\" {\n\t\tt.Errorf(\"Expected second item name 'runtime-2', got %s\", list.Items[1].Name)\n\t}\n\n\tif list.Items[0].Spec.Image != \"busybox:latest\" {\n\t\tt.Errorf(\"Expected first item image 'busybox:latest', got %s\", list.Items[0].Spec.Image)\n\t}\n\n\tif list.Items[1].Spec.Image != \"ubuntu:22.04\" {\n\t\tt.Errorf(\"Expected second item image 'ubuntu:22.04', got %s\", list.Items[1].Spec.Image)\n\t}\n}\n\nfunc TestAgentRuntimeDeepCopy(t *testing.T) {\n\tnow := metav1.NewTime(time.Now())\n\n\toriginal := &AgentRuntime{\n\t\tTypeMeta: metav1.TypeMeta{\n\t\t\tAPIVersion: \"runtime.agentcube.volcano.sh/v1alpha1\",\n\t\t\tKind:       \"AgentRuntime\",\n\t\t},\n\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\tName:      \"original\",\n\t\t\tNamespace: \"default\",\n\t\t\tLabels: map[string]string{\n\t\t\t\t\"key\": \"value\",\n\t\t\t},\n\t\t},\n\t\tSpec: AgentRuntimeSpec{\n\t\t\tImage: \"ubuntu:22.04\",\n\t\t\tResources: &corev1.ResourceRequirements{\n\t\t\t\tLimits: corev1.ResourceList{\n\t\t\t\t\tcorev1.ResourceCPU: resource.MustParse(\"1000m\"),\n\t\t\t\t},\n\t\t\t},\n\t\t\tEnv: []corev1.EnvVar{\n\t\t\t\t{Name: \"FOO\", Value: \"bar\"},\n\t\t\t},\n\t\t\tNodeSelector: map[string]string{\n\t\t\t\t\"node-type\": \"sandbox\",\n\t\t\t},\n\t\t},\n\t\tStatus: AgentRuntimeStatus{\n\t\t\tPhase:     AgentRuntimePhaseRunning,\n\t\t\tSandboxID: \"sandbox-abc123\",\n\t\t\tStartTime: &now,\n\t\t\tConditions: []AgentRuntimeCondition{\n\t\t\t\t{\n\t\t\t\t\tType:   AgentRuntimeConditionReady,\n\t\t\t\t\tStatus: corev1.ConditionTrue,\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\n\t// Test DeepCopy\n\tcopied := original.DeepCopy()\n\n\t// Ensure copied is not nil\n\tif copied == nil {\n\t\tt.Fatal(\"DeepCopy returned nil\")\n\t}\n\n\t// Verify basic fields are equal\n\tif copied.Name != original.Name {\n\t\tt.Errorf(\"Expected name '%s', got '%s'\", original.Name, copied.Name)\n\t}\n\n\tif copied.Spec.Image != original.Spec.Image {\n\t\tt.Errorf(\"Expected image '%s', got '%s'\", original.Spec.Image, copied.Spec.Image)\n\t}\n\n\t// Verify that slices are independent (modifying original doesn't affect copy)\n\toriginal.Labels[\"new-key\"] = \"new-value\"\n\tif _, exists := copied.Labels[\"new-key\"]; exists {\n\t\tt.Error(\"Labels should be independent between original and copy\")\n\t}\n\n\t// Modify original env\n\toriginal.Spec.Env[0].Value = \"modified\"\n\tif copied.Spec.Env[0].Value == \"modified\" {\n\t\tt.Error(\"Env should be independent between original and copy\")\n\t}\n\n\t// Modify original node selector\n\toriginal.Spec.NodeSelector[\"new-node\"] = \"true\"\n\tif _, exists := copied.Spec.NodeSelector[\"new-node\"]; exists {\n\t\tt.Error(\"NodeSelector should be independent between original and copy\")\n\t}\n\n\t// Modify original resources\n\toriginal.Spec.Resources.Limits[corev1.ResourceCPU] = resource.MustParse(\"2000m\")\n\tif copied.Spec.Resources.Limits.Cpu().MilliValue() == 2000 {\n\t\tt.Error(\"Resources should be independent between original and copy\")\n\t}\n\n\t// Test DeepCopyInto\n\tvar into AgentRuntime\n\toriginal.DeepCopyInto(&int