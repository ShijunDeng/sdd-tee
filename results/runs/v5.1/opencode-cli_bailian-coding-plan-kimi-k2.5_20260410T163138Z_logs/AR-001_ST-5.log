ubernetes/api-extension/custom-resources/\n49:   - https://github.com/kubernetes-sigs/controller-runtime\n50: \n51: # Estimation\n52: estimation:\n53:   size: S\n54:   story_points: 2\n55:   days: 1\n\n(End of file - total 55 lines)\n</content>","metadata":{"preview":"id: AR-001\ntitle: CRD AgentRuntime 类型定义\nmodule: pkg/apis\nlanguage: Go\nsize: S\nstatus: open\n\n# AR-001: CRD AgentRuntime Type Definitions\n# Module: pkg/apis\n# Language: Go\n# Size: S\n\n# OpenSpec Metadata\nopenspec:\n  version: \"1.0\"\n  project: agentcube\n\n# Architecture Requirement\nrequirement:\n  type: crd-definition","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/changes/AR-001/spec.yaml","time":{"start":1775839391402,"end":1775839391438}}}}
