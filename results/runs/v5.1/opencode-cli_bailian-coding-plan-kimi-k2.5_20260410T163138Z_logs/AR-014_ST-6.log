{"type":"tool_use","timestamp":1775870552862,"sessionID":"ses_285de29deffekAmJtPJ8nwlQSR","part":{"id":"prt_d7a2220b3001dVLXplRxvH82vJ","messageID":"msg_d7a21feb5001ER6sf80MH9tZqJ","sessionID":"ses_285de29deffekAmJtPJ8nwlQSR","type":"tool","tool":"read","callID":"toolu_functions.read:5","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/store/valkey_test.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/store/valkey_test.go</path>\n<type>file</type>\n<content>\n1: /*\n2: Copyright 2026 The Volcano Authors.\n3: \n4: Licensed under the Apache License, Version 2.0 (the \"License\");\n5: you may not use this file except in compliance with the License.\n6: You may obtain a copy of the License at\n7: \n8:     http://www.apache.org/licenses/LICENSE-2.0\n9: \n10: Unless required by applicable law or agreed to in writing, software\n11: distributed under the License is distributed on an \"AS IS\" BASIS,\n12: WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n13: See the License for the specific language governing permissions and\n14: limitations under the License.\n15: */\n16: \n17: package store\n18: \n19: import (\n20: \t\"context\"\n21: \t\"encoding/json\"\n22: \t\"fmt\"\n23: \t\"os\"\n24: \t\"strings\"\n25: \t\"testing\"\n26: \t\"time\"\n27: \n28: \t\"github.com/alicebob/miniredis/v2\"\n29: \t\"github.com/valkey-io/valkey-go\"\n30: \t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n31: )\n32: \n33: // setupTestValkey creates a new miniredis instance for testing.\n34: // Since Valkey is Redis-compatible, we can use miniredis for testing.\n35: func setupTestValkey(t *testing.T) *miniredis.Miniredis {\n36: \treturn miniredis.RunT(t)\n37: }\n38: \n39: // createTestValkeyStore creates a valkeyStore instance connected to the test server.\n40: func createTestValkeyStore(t *testing.T, m *miniredis.Miniredis) *valkeyStore {\n41: \tclient, err := valkey.NewClient(valkey.ClientOption{\n42: \t\tInitAddress:       []string{m.Addr()},\n43: \t\tDisableCache:      true,\n44: \t\tForceSingleClient: true,\n45: \t})\n46: \tif err != nil {\n47: \t\tt.Fatalf(\"Failed to create valkey client: %v\", err)\n48: \t}\n49: \treturn &valkeyStore{\n50: \t\tcli:                  client,\n51: \t\tsessionPrefix:        sessionPrefix,\n52: \t\texpiryIndexKey:       expiryIndexKey,\n53: \t\tlastActivityIndexKey: lastActivityIndexKey,\n54: \t}\n55: }\n56: \n57: // createTestSandboxForValkey creates a test sandbox with the given sessionID.\n58: func createTestSandboxForValkey(sessionID string, expiresAt time.Time) *types.SandboxInfo {\n59: \treturn &types.SandboxInfo{\n60: \t\tKind:             \"AgentRuntime\",\n61: \t\tSandboxID:        fmt.Sprintf(\"sb-%s\", sessionID),\n62: \t\tSandboxNamespace: \"default\",\n63: \t\tName:             fmt.Sprintf(\"runtime-%s\", sessionID),\n64: \t\tEntryPoints: []types.SandboxEntryPoint{\n65: \t\t\t{\n66: \t\t\t\tPath:     \"/api\",\n67: \t\t\t\tProtocol: \"http\",\n68: \t\t\t\tEndpoint: \"localhost:8080\",\n69: \t\t\t},\n70: \t\t},\n71: \t\tSessionID: sessionID,\n72: \t\tCreatedAt: time.Now().UTC(),\n73: \t\tExpiresAt: expiresAt,\n74: \t\tStatus:    \"Running\",\n75: \t\tPodIP:     \"10.0.0.1\",\n76: \t\tPodName:   fmt.Sprintf(\"pod-%s\", sessionID),\n77: \t}\n78: }\n79: \n80: func TestValkeyStore_Ping(t *testing.T) {\n81: \tm := setupTestValkey(t)\n82: \tdefer m.Close()\n83: \n84: \ts := createTestValkeyStore(t, m)\n85: \tdefer s.Close()\n86: \n87: \tctx := context.Background()\n88: \terr := s.Ping(ctx)\n89: \tif err != nil {\n90: \t\tt.Fatalf(\"Ping() error = %v\", err)\n91: \t}\n92: }\n93: \n94: func TestValkeyStore_Ping_Failure(t *testing.T) {\n95: \t// Create a client to a non-existent server\n96: \tclient, err := valkey.NewClient(valkey.ClientOption{\n97: \t\tInitAddress:       []string{\"127.0.0.1:63791\"},\n98: \t\tDisableCache:      true,\n99: \t\tForceSingleClient: true,\n100: \t})\n101: \tif err != nil {\n102: \t\t// Client creation might fail for some invalid addresses\n103: \t\tt.Skipf(\"valkey client creation failed (may not be supported for unreachable addresses): %v\", err)\n104: \t}\n105: \n106: \ts := &valkeyStore{\n107: \t\tcli:                  client,\n108: \t\tsessionPrefix:        sessionPrefix,\n109: \t\texpiryIndexKey:       expiryIndexKey,\n110: \t\tlastActivityIndexKey: lastActivityIndexKey,\n111: \t}\n112: \tdefer s.Close()\n113: \n114: \tctx, cancel := context.WithTimeout(context.Background(), 100*time.Millisecond)\n115: \tdefer cancel()\n116: \n117: \terr = s.Ping(ctx)\n118: \tif err == nil {\n119: \t\tt.Error(\"Ping() expected error for unreachable server\")\n120: \t}\n121: }\n122: \n123: func TestValkeyStore_GetSandboxBySessionID(t *testing.T) {\n124: \tm := setupTestValkey(t)\n125: \tdefer m.Close()\n126: \n127: \ts := createTestValkeyStore(t, m)\n128: \tdefer s.Close()\n129: \n130: \tctx := context.Background()\n131: \n132: \t// Test case: empty sessionID\n133: \t_, err := s.GetSandboxBySessionID(ctx, \"\")\n134: \tif err == nil {\n135: \t\tt.Error(\"GetSandboxBySessionID(\\\"\\\") expected error\")\n136: \t}\n137: \n138: \t// Test case: not found\n139: \t_, err = s.GetSandboxBySessionID(ctx, \"non-existent\")\n140: \tif !strings.Contains(err.Error(), \"not found\") && err != ErrNotFound {\n141: \t\tt.Errorf(\"GetSandboxBySessionID() expected ErrNotFound, got %v\", err)\n142: \t}\n143: \n144: \t// Store a sandbox first\n145: \tsandbox := createTestSandboxForValkey(\"test-session\", time.Now().Add(time.Hour))\n146: \tif err := s.StoreSandbox(ctx, sandbox); err != nil {\n147: \t\tt.Fatalf(\"StoreSandbox() error = %v\", err)\n148: \t}\n149: \n150: \t// Test case: found\n151: \tresult, err := s.GetSandboxBySessionID(ctx, \"test-session\")\n152: \tif err != nil {\n153: \t\tt.Fatalf(\"GetSandboxBySessionID() error = %v\", err)\n154: \t}\n155: \tif result.SessionID != sandbox.SessionID {\n156: \t\tt.Errorf(\"GetSandboxBySessionID() SessionID = %v, want %v\", result.SessionID, sandbox.SessionID)\n157: \t}\n158: }\n159: \n160: func TestValkeyStore_StoreSandbox(t *testing.T) {\n161: \tm := setupTestValkey(t)\n162: \tdefer m.Close()\n163: \n164: \ts := createTestValkeyStore(t, m)\n165: \tdefer s.Close()\n166: \n167: \tctx := context.Background()\n168: \n169: \t// Test case: nil sandbox\n170: \terr := s.StoreSandbox(ctx, nil)\n171: \tif err == nil {\n172: \t\tt.Error(\"StoreSandbox(nil) expected error\")\n173: \t}\n174: \n175: \t// Test case: empty sessionID\n176: \tsandbox := createTestSandboxForValkey(\"\", time.Now().Add(time.Hour))\n177: \terr = s.StoreSandbox(ctx, sandbox)\n178: \tif err == nil {\n179: \t\tt.Error(\"StoreSandbox() with empty sessionID expected error\")\n180: \t}\n181: \n182: \t// Test case: zero ExpiresAt\n183: \tsandbox = createTestSandboxForValkey(\"test-session\", time.Time{})\n184: \terr = s.StoreSandbox(ctx, sandbox)\n185: \tif err == nil {\n186: \t\tt.Error(\"StoreSandbox() with zero ExpiresAt expected error\")\n187: \t}\n188: \n189: \t// Test case: valid sandbox\n190: \tsandbox = createTestSandboxForValkey(\"test-session\", time.Now().Add(time.Hour))\n191: \tif err := s.StoreSandbox(ctx, sandbox); err != nil {\n192: \t\tt.Fatalf(\"StoreSandbox() error = %v\", err)\n193: \t}\n194: \n195: \t// Verify the sandbox was stored\n196: \tkey := s.sessionKey(\"test-session\")\n197: \tdata, err := m.Get(key)\n198: \tif err != nil {\n199: \t\tt.Fatalf(\"Failed to get stored data: %v\", err)\n200: \t}\n201: \n202: \tvar stored types.SandboxInfo\n203: \tif err := json.Unmarshal([]byte(data), &stored); err != nil {\n204: \t\tt.Fatalf(\"Failed to unmarshal stored data: %v\", err)\n205: \t}\n206: \tif stored.SessionID != sandbox.SessionID {\n207: \t\tt.Errorf(\"Stored SessionID = %v, want %v\", stored.SessionID, sandbox.SessionID)\n208: \t}\n209: \n210: \t// Verify indexes were created\n211: \texpiryScore, err := m.ZScore(s.expiryIndexKey, \"test-session\")\n212: \tif err != nil || expiryScore == 0 {\n213: \t\tt.Error(\"Expiry index not created\")\n214: \t}\n215: \n216: \tactivityScore, err := m.ZScore(s.lastActivityIndexKey, \"test-session\")\n217: \tif err != nil || activityScore == 0 {\n218: \t\tt.Error(\"Activity index not created\")\n219: \t}\n220: \n221: \t// Test case: duplicate session\n222: \terr = s.StoreSandbox(ctx, sandbox)\n223: \tif err == nil {\n224: \t\tt.Error(\"StoreSandbox() duplicate session expected error\")\n225: \t}\n226: }\n227: \n228: func TestValkeyStore_UpdateSandbox(t *testing.T) {\n229: \tm := setupTestValkey(t)\n230: \tdefer m.Close()\n231: \n232: \ts := createTestValkeyStore(t, m)\n233: \tdefer s.Close()\n234: \n235: \tctx := context.Background()\n236: \n237: \t// Test case: nil sandbox\n238: \terr := s.UpdateSandbox(ctx, nil)\n239: \tif err == nil {\n240: \t\tt.Error(\"UpdateSandbox(nil) expected error\")\n241: \t}\n242: \n243: \t// Test case: empty sessionID\n244: \tsandbox := createTestSandboxForValkey(\"\", time.Now().Add(time.Hour))\n245: \terr = s.UpdateSandbox(ctx, sandbox)\n246: \tif err == nil {\n247: \t\tt.Error(\"UpdateSandbox() with empty sessionID expected error\")\n248: \t}\n249: \n250: \t// Test case: non-existent sandbox\n251: \tsandbox = createTestSandboxForValkey(\"non-existent\", time.Now().Add(time.Hour))\n252: \terr = s.UpdateSandbox(ctx, sandbox)\n253: \tif err == nil {\n254: \t\tt.Error(\"UpdateSandbox() non-existent sandbox expected error\")\n255: \t}\n256: \n257: \t// Store a sandbox first\n258: \tsandbox = createTestSandboxForValkey(\"test-session\", time.Now().Add(time.Hour))\n259: \tif err := s.StoreSandbox(ctx, sandbox); err != nil {\n260: \t\tt.Fatalf(\"StoreSandbox() error = %v\", err)\n261: \t}\n262: \n263: \t// Update the sandbox\n264: \tsandbox.Status = \"Updated\"\n265: \tif err := s.UpdateSandbox(ctx, sandbox); err != nil {\n266: \t\tt.Fatalf(\"UpdateSandbox() error = %v\", err)\n267: \t}\n268: \n269: \t// Verify the update\n270: \tresult, err := s.GetSandboxBySessionID(ctx, \"test-session\")\n271: \tif err != nil {\n272: \t\tt.Fatalf(\"GetSandboxBySessionID() error = %v\", err)\n273: \t}\n274: \tif result.Status != \"Updated\" {\n275: \t\tt.Errorf(\"Status = %v, want Updated\", result.Status)\n276: \t}\n277: }\n278: \n279: func TestValkeyStore_DeleteSandboxBySessionID(t *testing.T) {\n280: \tm := setupTestValkey(t)\n281: \tdefer m.Close()\n282: \n283: \ts := createTestValkeyStore(t, m)\n284: \tdefer s.Close()\n285: \n286: \tctx := context.Background()\n287: \n288: \t// Test case: empty sessionID\n289: \terr := s.DeleteSandboxBySessionID(ctx, \"\")\n290: \tif err == nil {\n291: \t\tt.Error(\"DeleteSandboxBySessionID(\\\"\\\") expected error\")\n292: \t}\n293: \n294: \t// Store a sandbox first\n295: \tsandbox := createTestSandboxForValkey(\"test-session\", time.Now().Add(time.Hour))\n296: \tif err := s.StoreSandbox(ctx, sandbox); err != nil {\n297: \t\tt.Fatalf(\"StoreSandbox() error = %v\", err)\n298: \t}\n299: \n300: \t// Delete the sandbox\n301: \tif err := s.DeleteSandboxBySessionID(ctx, \"test-session\"); err != nil {\n302: \t\tt.Fatalf(\"DeleteSandboxBySessionID() error = %v\", err)\n303: \t}\n304: \n305: \t// Verify deletion\n306: \t_, err = s.GetSandboxBySessionID(ctx, \"test-session\")\n307: \tif err == nil {\n308: \t\tt.Error(\"GetSandboxBySessionID() after delete expected error\")\n309: \t}\n310: \n311: \t// Verify indexes were removed\n312: \t_, err = m.ZScore(s.expiryIndexKey, \"test-session\")\n313: \tif err == nil {\n314: \t\tt.Error(\"Expiry index not removed\")\n315: \t}\n316: \t_, err = m.ZScore(s.lastActivityIndexKey, \"test-session\")\n317: \tif err == nil {\n318: \t\tt.Error(\"Activity index not removed\")\n319: \t}\n320: \n321: \t// Test case: delete non-existent (idempotent)\n322: \terr = s.DeleteSandboxBySessionID(ctx, \"non-existent\")\n323: \tif err != nil {\n324: \t\tt.Errorf(\"DeleteSandboxBySessionID() non-existent expected no error, got %v\", err)\n325: \t}\n326: }\n327: \n328: func TestValkeyStore_ListExpiredSandboxes(t *testing.T) {\n329: \tm := setupTestValkey(t)\n330: \tdefer m.Close()\n331: \n332: \ts := createTestValkeyStore(t, m)\n333: \tdefer s.Close()\n334: \n335: \tctx := context.Background()\n336: \tnow := time.Now()\n337: \n338: \t// Test case: limit <= 0\n339: \tresult, err := s.ListExpiredSandboxes(ctx, now, 0)\n340: \tif err != nil {\n341: \t\tt.Fatalf(\"ListExpiredSandboxes() error = %v\", err)\n342: \t}\n343: \tif result != nil {\n344: \t\tt.Error(\"ListExpiredSandboxes() with limit=0 expected nil\")\n345: \t}\n346: \n347: \t// Store expired sandboxes\n348: \tsandbox1 := createTestSandboxForValkey(\"expired-1\", now.Add(-time.Hour))\n349: \tsandbox2 := createTestSandboxForValkey(\"expired-2\", now.Add(-30*time.Minute))\n350: \tsandbox3 := createTestSandboxForValkey(\"active-1\", now.Add(time.Hour))\n351: \n352: \tif err := s.StoreSandbox(ctx, sandbox1); err != nil {\n353: \t\tt.Fatalf(\"StoreSandbox() error = %v\", err)\n354: \t}\n355: \tif err := s.StoreSandbox(ctx, sandbox2); err != nil {\n356: \t\tt.Fatalf(\"StoreSandbox() error = %v\", err)\n357: \t}\n358: \tif err := s.StoreSandbox(ctx, sandbox3); err != nil {\n359: \t\tt.Fatalf(\"StoreSandbox() error = %v\", err)\n360: \t}\n361: \n362: \t// List expired sandboxes\n363: \texpired, err := s.ListExpiredSandboxes(ctx, now, 10)\n364: \tif err != nil {\n365: \t\tt.Fatalf(\"ListExpiredSandboxes() error = %v\", err)\n366: \t}\n367: \n368: \tif len(expired) != 2 {\n369: \t\tt.Errorf(\"ListExpiredSandboxes() returned %d sandboxes, want 2\", len(expired))\n370: \t}\n371: \n372: \t// Test with limit\n373: \texpiredLimited, err := s.ListExpiredSandboxes(ctx, now, 1)\n374: \tif err != nil {\n375: \t\tt.Fatalf(\"ListExpiredSandboxes() error = %v\", err)\n376: \t}\n377: \tif len(expiredLimited) != 1 {\n378: \t\tt.Errorf(\"ListExpiredSandboxes() with limit=1 returned %d sandboxes, want 1\", len(expiredLimited))\n379: \t}\n380: }\n381: \n382: func TestValkeyStore_ListInactiveSandboxes(t *testing.T) {\n383: \tm := setupTestValkey(t)\n384: \tdefer m.Close()\n385: \n386: \ts := createTestValkeyStore(t, m)\n387: \tdefer s.Close()\n388: \n389: \tctx := context.Background()\n390: \tnow := time.Now()\n391: \n392: \t// Test case: limit <= 0\n393: \tresult, err := s.ListInactiveSandboxes(ctx, now, 0)\n394: \tif err != nil {\n395: \t\tt.Fatalf(\"ListInactiveSandboxes() error = %v\", err)\n396: \t}\n397: \tif result != nil {\n398: \t\tt.Error(\"ListInactiveSandboxes() with limit=0 expected nil\")\n399: \t}\n400: \n401: \t// Store sandbox and update activity\n402: \tsandbox := createTestSandboxForValkey(\"test-session\", now.Add(time.Hour))\n403: \tif err := s.StoreSandbox(ctx, sandbox); err != nil {\n404: \t\tt.Fatalf(\"StoreSandbox() error = %v\", err)\n405: \t}\n406: \n407: \t// Manually set activity to past time by manipulating the sorted set\n408: \t// (since StoreSandbox sets activity to now)\n409: \tm.ZRem(s.lastActivityIndexKey, \"test-session\")\n410: \tm.ZAdd(s.lastActivityIndexKey, float64(now.Add(-time.Hour).Unix()), \"test-session\")\n411: \n412: \t// List inactive sandboxes\n413: \tinactive, err := s.ListInactiveSandboxes(ctx, now.Add(-30*time.Minute), 10)\n414: \tif err != nil {\n415: \t\tt.Fatalf(\"ListInactiveSandboxes() error = %v\", err)\n416: \t}\n417: \n418: \tif len(inactive) != 1 {\n419: \t\tt.Errorf(\"ListInactiveSandboxes() returned %d sandboxes, want 1\", len(inactive))\n420: \t}\n421: }\n422: \n423: func TestValkeyStore_UpdateSessionLastActivity(t *testing.T) {\n424: \tm := setupTestValkey(t)\n425: \tdefer m.Close()\n426: \n427: \ts := createTestValkeyStore(t, m)\n428: \tdefer s.Close()\n429: \n430: \tctx := context.Background()\n431: \tnow := time.Now()\n432: \n433: \t// Test case: empty sessionID\n434: \terr := s.UpdateSessionLastActivity(ctx, \"\", now)\n435: \tif err == nil {\n436: \t\tt.Error(\"UpdateSessionLastActivity(\\\"\\\") expected error\")\n437: \t}\n438: \n439: \t// Test case: non-existent session\n440: \terr = s.UpdateSessionLastActivity(ctx, \"non-existent\", now)\n441: \tif err == nil {\n442: \t\tt.Error(\"UpdateSessionLastActivity() non-existent expected error\")\n443: \t}\n444: \n445: \t// Store a sandbox first\n446: \tsandbox := createTestSandboxForValkey(\"test-session\", now.Add(time.Hour))\n447: \tif err := s.StoreSandbox(ctx, sandbox); err != nil {\n448: \t\tt.Fatalf(\"StoreSandbox() error = %v\", err)\n449: \t}\n450: \n451: \t// Get initial activity score\n452: \tinitialScore, err := m.ZScore(s.lastActivityIndexKey, \"test-session\")\n453: \tif err != nil {\n454: \t\tt.Fatalf(\"ZScore() error = %v\", err)\n455: \t}\n456: \n457: \t// Wait to ensure different Unix timestamp (ZAdd uses Unix() which is in seconds)\n458: \ttime.Sleep(1100 * time.Millisecond)\n459: \n460: \t// Update activity with zero time (should use Now)\n461: \tif err := s.UpdateSessionLastActivity(ctx, \"test-session\", time.Time{}); err != nil {\n462: \t\tt.Fatalf(\"UpdateSessionLastActivity() error = %v\", err)\n463: \t}\n464: \n465: \t// Verify activity was updated\n466: \tnewScore, err := m.ZScore(s.lastActivityIndexKey, \"test-session\")\n467: \tif err != nil {\n468: \t\tt.Fatalf(\"ZScore() error = %v\", err)\n469: \t}\n470: \tif newScore <= initialScore {\n471: \t\tt.Error(\"Activity timestamp was not updated\")\n472: \t}\n473: \n474: \t// Update activity with specific time\n475: \tfuture := now.Add(time.Hour)\n476: \tif err := s.UpdateSessionLastActivity(ctx, \"test-session\", future); err != nil {\n477: \t\tt.Fatalf(\"UpdateSessionLastActivity() error = %v\", err)\n478: \t}\n479: \n480: \t// Verify specific time was used\n481: \tscore, err := m.ZScore(s.lastActivityIndexKey, \"test-session\")\n482: \tif err != nil {\n483: \t\tt.Fatalf(\"ZScore() error = %v\", err)\n484: \t}\n485: \tif score != float64(future.Unix()) {\n486: \t\tt.Errorf(\"Activity timestamp = %v, want %v\", score, float64(future.Unix()))\n487: \t}\n488: }\n489: \n490: func TestValkeyStore_Close(t *testing.T) {\n491: \tm := setupTestValkey(t)\n492: \tdefer m.Close()\n493: \n494: \ts := createTestValkeyStore(t, m)\n495: \n496: \terr := s.Close()\n497: \tif err != nil {\n498: \t\tt.Errorf(\"Close() error = %v\", err)\n499: \t}\n500: }\n501: \n502: func TestValkeyStore_LoadSandboxesBySessionIDs(t *testing.T) {\n503: \tm := setupTestValkey(t)\n504: \tdefer m.Close()\n505: \n506: \ts := createTestValkeyStore(t, m)\n507: \tdefer s.Close()\n508: \n509: \tctx := context.Background()\n510: \n511: \t// Test case: empty sessionIDs\n512: \tresult, err := s.loadSandboxesBySessionIDs(ctx, []string{})\n513: \tif err != nil {\n514: \t\tt.Fatalf(\"loadSandboxesBySessionIDs() error = %v\", err)\n515: \t}\n516: \tif len(result) != 0 {\n517: \t\tt.Errorf(\"loadSandboxesBySessionIDs() returned %d sandboxes, want 0\", len(result))\n518: \t}\n519: \n520: \t// Store multiple sandboxes\n521: \tsandbox1 := createTestSandboxForValkey(\"session-1\", time.Now().Add(time.Hour))\n522: \tsandbox2 := createTestSandboxForValkey(\"session-2\", time.Now().Add(time.Hour))\n523: \n524: \tif err := s.StoreSandbox(ctx, sandbox1); err != nil {\n525: \t\tt.Fatalf(\"StoreSandbox() error = %v\", err)\n526: \t}\n527: \tif err := s.StoreSandbox(ctx, sandbox2); err != nil {\n528: \t\tt.Fatalf(\"StoreSandbox() error = %v\", err)\n529: \t}\n530: \n531: \t// Load by session IDs\n532: \tsessionIDs := []string{\"session-1\", \"session-2\", \"non-existent\"}\n533: \tsandboxes, err := s.loadSandboxesBySessionIDs(ctx, sessionIDs)\n534: \tif err != nil {\n535: \t\tt.Fatalf(\"loadSandboxesBySessionIDs() error = %v\", err)\n536: \t}\n537: \tif len(sandboxes) != 2 {\n538: \t\tt.Errorf(\"loadSandboxesBySessionIDs() returned %d sandboxes, want 2\", len(sandboxes))\n539: \t}\n540: }\n541: \n542: func TestValkeyStore_LoadSandboxesWithOrphanedIndex(t *testing.T) {\n543: \tm := setupTestValkey(t)\n544: \tdefer m.Close()\n545: \n546: \ts := createTestValkeyStore(t, m)\n547: \tdefer s.Close()\n548: \n549: \tctx := context.Background()\n550: \n551: \t// Store a sandbox\n552: \tsandbox := createTestSandboxForValkey(\"test-session\", time.Now().Add(time.Hour))\n553: \tif err := s.StoreSandbox(ctx, sandbox); err != nil {\n554: \t\tt.Fatalf(\"StoreSandbox() error = %v\", err)\n555: \t}\n556: \n557: \t// Delete the session data but keep the index (simulate orphaned index)\n558: \tm.Del(s.sessionKey(\"test-session\"))\n559: \n560: \t// List expired sandboxes should handle orphaned entries gracefully\n561: \texpired, err := s.ListExpiredSandboxes(ctx, time.Now().Add(time.Hour*2), 10)\n562: \tif err != nil {\n563: \t\tt.Fatalf(\"ListExpiredSandboxes() error = %v\", err)\n564: \t}\n565: \tif len(expired) != 0 {\n566: \t\tt.Errorf(\"ListExpiredSandboxes() returned %d sandboxes, want 0 (orphaned entries should be skipped)\", len(expired))\n567: \t}\n568: }\n569: \n570: func TestValkeyStore_SessionKey(t *testing.T) {\n571: \ts := &valkeyStore{\n572: \t\tsessionPrefix: \"session:\",\n573: \t}\n574: \n575: \tkey := s.sessionKey(\"test-id\")\n576: \tif key != \"session:test-id\" {\n577: \t\tt.Errorf(\"sessionKey() = %v, want session:test-id\", key)\n578: \t}\n579: }\n580: \n581: func TestMakeValkeyOptions(t *testing.T) {\n582: \t// Clean up environment after test\n583: \toriginalAddr := os.Getenv(\"VALKEY_ADDR\")\n584: \toriginalPassword := os.Getenv(\"VALKEY_PASSWORD\")\n585: \toriginalRequired := os.Getenv(\"VALKEY_PASSWORD_REQUIRED\")\n586: \toriginalDisableCache := os.Getenv(\"VALKEY_DISABLE_CACHE\")\n587: \toriginalForceSingle := os.Getenv(\"VALKEY_FORCE_SINGLE\")\n588: \tdefer func() {\n589: \t\tos.Setenv(\"VALKEY_ADDR\", originalAddr)\n590: \t\tos.Setenv(\"VALKEY_PASSWORD\", originalPassword)\n591: \t\tos.Setenv(\"VALKEY_PASSWORD_REQUIRED\", originalRequired)\n592: \t\tos.Setenv(\"VALKEY_DISABLE_CACHE\", originalDisableCache)\n593: \t\tos.Setenv(\"VALKEY_FORCE_SINGLE\", originalForceSingle)\n594: \t}()\n595: \n596: \t// Test case: missing VALKEY_ADDR\n597: \tos.Unsetenv(\"VALKEY_ADDR\")\n598: \tos.Setenv(\"VALKEY_PASSWORD\", \"secret\")\n599: \t_, err := makeValkeyOptions()\n600: \tif err == nil {\n601: \t\tt.Error(\"makeValkeyOptions() without VALKEY_ADDR expected error\")\n602: \t}\n603: \n604: \t// Test case: missing VALKEY_PASSWORD when required\n605: \tos.Setenv(\"VALKEY_ADDR\", \"localhost:6379\")\n606: \tos.Setenv(\"VALKEY_PASSWORD\", \"\")\n607: \tos.Unsetenv(\"VALKEY_PASSWORD_REQUIRED\")\n608: \t_, err = makeValkeyOptions()\n609: \tif err == nil {\n610: \t\tt.Error(\"makeValkeyOptions() without password when required expected error\")\n611: \t}\n612: \n613: \t// Test case: password not required\n614: \tos.Setenv(\"VALKEY_ADDR\", \"localhost:6379\")\n615: \tos.Setenv(\"VALKEY_PASSWORD\", \"\")\n616: \tos.Setenv(\"VALKEY_PASSWORD_REQUIRED\", \"false\")\n617: \tos.Unsetenv(\"VALKEY_DISABLE_CACHE\")\n618: \tos.Unsetenv(\"VALKEY_FORCE_SINGLE\")\n619: \topts, err := makeValkeyOptions()\n620: \tif err != nil {\n621: \t\tt.Fatalf(\"makeValkeyOptions() error = %v\", err)\n622: \t}\n623: \tif len(opts.InitAddress) != 1 || opts.InitAddress[0] != \"localhost:6379\" {\n624: \t\tt.Errorf(\"InitAddress = %v, want [localhost:6379]\", opts.InitAddress)\n625: \t}\n626: \tif opts.Password != \"\" {\n627: \t\tt.Errorf(\"Password = %v, want empty\", opts.Password)\n628: \t}\n629: \tif opts.DisableCache != false {\n630: \t\tt.Errorf(\"DisableCache = %v, want false\", opts.DisableCache)\n631: \t}\n632: \tif opts.ForceSingleClient != false {\n633: \t\tt.Errorf(\"ForceSingleClient = %v, want false\", opts.ForceSingleClient)\n634: \t}\n635: \n636: \t// Test case: password required and provided\n637: \tos.Setenv(\"VALKEY_ADDR\", \"valkey:6379\")\n638: \tos.Setenv(\"VALKEY_PASSWORD\", \"mysecret\")\n639: \tos.Setenv(\"VALKEY_PASSWORD_REQUIRED\", \"true\")\n640: \topts, err = makeValkeyOptions()\n641: \tif err != nil {\n642: \t\tt.Fatalf(\"makeValkeyOptions() error = %v\", err)\n643: \t}\n644: \tif len(opts.InitAddress) != 1 || opts.InitAddress[0] != \"valkey:6379\" {\n645: \t\tt.Errorf(\"InitAddress = %v, want [valkey:6379]\", opts.InitAddress)\n646: \t}\n647: \tif opts.Password != \"mysecret\" {\n648: \t\tt.Errorf(\"Password = %v, want mysecret\", opts.Password)\n649: \t}\n650: \n651: \t// Test case: multiple addresses\n652: \tos.Setenv(\"VALKEY_ADDR\", \"valkey-1:6379, valkey-2:6379, valkey-3:6379\")\n653: \tos.Setenv(\"VALKEY_PASSWORD\", \"secret\")\n654: \topts, err = makeValkeyOptions()\n655: \tif err != nil {\n656: \t\tt.Fatalf(\"makeValkeyOptions() error = %v\", err)\n657: \t}\n658: \tif len(opts.InitAddress) != 3 {\n659: \t\tt.Errorf(\"InitAddress length = %v, want 3\", len(opts.InitAddress))\n660: \t}\n661: \n662: \t// Test case: optional flags\n663: \tos.Setenv(\"VALKEY_ADDR\", \"localhost:6379\")\n664: \tos.Setenv(\"VALKEY_PASSWORD\", \"secret\")\n665: \tos.Setenv(\"VALKEY_DISABLE_CACHE\", \"true\")\n666: \tos.Setenv(\"VALKEY_FORCE_SINGLE\", \"true\")\n667: \topts, err = makeValkeyOptions()\n668: \tif err != nil {\n669: \t\tt.Fatalf(\"makeValkeyOptions() error = %v\", err)\n670: \t}\n671: \tif opts.DisableCache != true {\n672: \t\tt.Errorf(\"DisableCache = %v, want true\", opts.DisableCache)\n673: \t}\n674: \tif opts.ForceSingleClient != true {\n675: \t\tt.Errorf(\"ForceSingleClient = %v, want true\", opts.ForceSingleClient)\n676: \t}\n677: \n678: \t// Test case: whitespace trimming\n679: \tos.Setenv(\"VALKEY_ADDR\", \"  localhost:6379  \")\n680: \tos.Setenv(\"VALKEY_PASSWORD\", \"  secret  \")\n681: \tos.Unsetenv(\"VALKEY_DISABLE_CACHE\")\n682: \tos.Unsetenv(\"VALKEY_FORCE_SINGLE\")\n683: \topts, err = makeValkeyOptions()\n684: \tif err != nil {\n685: \t\tt.Fatalf(\"makeValkeyOptions() error = %v\", err)\n686: \t}\n687: \tif len(opts.InitAddress) != 1 || opts.InitAddress[0] != \"localhost:6379\" {\n688: \t\tt.Errorf(\"InitAddress = %v, want [localhost:6379] (trimmed)\", opts.InitAddress)\n689: \t}\n690: \tif opts.Password != \"  secret  \" {\n691: \t\tt.Errorf(\"Password = %v, want \\\"  secret  \\\" (not trimmed)\", opts.Password)\n692: \t}\n693: }\n694: \n695: func TestMakeValkeyOptions_InvalidBool(t *testing.T) {\n696: \t// Clean up environment after test\n697: \toriginalAddr := os.Getenv(\"VALKEY_ADDR\")\n698: \toriginalPassword := os.Getenv(\"VALKEY_PASSWORD\")\n699: \toriginalRequired := os.Getenv(\"VALKEY_PASSWORD_REQUIRED\")\n700: \toriginalDisableCache := os.Getenv(\"VALKEY_DISABLE_CACHE\")\n701: \toriginalForceSingle := os.Getenv(\"VALKEY_FORCE_SINGLE\")\n702: \tdefer func() {\n703: \t\tos.Setenv(\"VALKEY_ADDR\", originalAddr)\n704: \t\tos.Setenv(\"VALKEY_PASSWORD\", originalPassword)\n705: \t\tos.Setenv(\"VALKEY_PASSWORD_REQUIRED\", originalRequired)\n706: \t\tos.Setenv(\"VALKEY_DISABLE_CACHE\", originalDisableCache)\n707: \t\tos.Setenv(\"VALKEY_FORCE_SINGLE\", originalForceSingle)\n708: \t}()\n709: \n710: \tos.Setenv(\"VALKEY_ADDR\", \"localhost:6379\")\n711: \tos.Setenv(\"VALKEY_PASSWORD\", \"secret\")\n712: \tos.Setenv(\"VALKEY_PASSWORD_REQUIRED\", \"invalid\")\n713: \tos.Setenv(\"VALKEY_DISABLE_CACHE\", \"invalid\")\n714: \tos.Setenv(\"VALKEY_FORCE_SINGLE\", \"invalid\")\n715: \n716: \t// Should use defaults when parsing fails\n717: \topts, err := makeValkeyOptions()\n718: \tif err != nil {\n719: \t\tt.Errorf(\"makeValkeyOptions() with invalid bools should use defaults, got error: %v\", err)\n720: \t}\n721: \tif opts.DisableCache != false {\n722: \t\tt.Errorf(\"DisableCache = %v, want false (default)\", opts.DisableCache)\n723: \t}\n724: \tif opts.ForceSingleClient != false {\n725: \t\tt.Errorf(\"ForceSingleClient = %v, want false (default)\", opts.ForceSingleClient)\n726: \t}\n727: }\n728: \n729: func TestNewValkeyStore(t *testing.T) {\n730: \tm := setupTestValkey(t)\n731: \tdefer m.Close()\n732: \n733: \t// Clean up environment after test\n734: \toriginalAddr := os.Getenv(\"VALKEY_ADDR\")\n735: \toriginalPassword := os.Getenv(\"VALKEY_PASSWORD\")\n736: \toriginalRequired := os.Getenv(\"VALKEY_PASSWORD_REQUIRED\")\n737: \tdefer func() {\n738: \t\tos.Setenv(\"VALKEY_ADDR\", originalAddr)\n739: \t\tos.Setenv(\"VALKEY_PASSWORD\", originalPassword)\n740: \t\tos.Setenv(\"VALKEY_PASSWORD_REQUIRED\", originalRequired)\n741: \t}()\n742: \n743: \tos.Setenv(\"VALKEY_ADDR\", m.Addr())\n744: \tos.Setenv(\"VALKEY_PASSWORD\", \"\")\n745: \tos.Setenv(\"VALKEY_PASSWORD_REQUIRED\", \"false\")\n746: \n747: \tstore, err := newValkeyStore()\n748: \tif err != nil {\n749: \t\tt.Fatalf(\"newValkeyStore() error = %v\", err)\n750: \t}\n751: \tif store == nil {\n752: \t\tt.Fatal(\"newValkeyStore() returned nil\")\n753: \t}\n754: \tdefer store.Close()\n755: \n756: \t// Test that it implements Store interface\n757: \tvar _ Store = store\n758: }\n759: \n760: func TestNewValkeyStore_MissingAddr(t *testing.T) {\n761: \t// Clean up environment\n762: \toriginalAddr := os.Getenv(\"VALKEY_ADDR\")\n763: \tdefer func() {\n764: \t\tos.Setenv(\"VALKEY_ADDR\", originalAddr)\n765: \t}()\n766: \n767: \tos.Unsetenv(\"VALKEY_ADDR\")\n768: \n769: \t_, err := newValkeyStore()\n770: \tif err == nil {\n771: \t\tt.Error(\"newValkeyStore() without VALKEY_ADDR expected error\")\n772: \t}\n773: }\n774: \n775: func TestNewValkeyStore_InvalidAddress(t *testing.T) {\n776: \t// Clean up environment\n777: \toriginalAddr := os.Getenv(\"VALKEY_ADDR\")\n778: \toriginalPassword := os.Getenv(\"VALKEY_PASSWORD\")\n779: \toriginalRequired := os.Getenv(\"VALKEY_PASSWORD_REQUIRED\")\n780: \tdefer func() {\n781: \t\tos.Setenv(\"VALKEY_ADDR\", originalAddr)\n782: \t\tos.Setenv(\"VALKEY_PASSWORD\", originalPassword)\n783: \t\tos.Setenv(\"VALKEY_PASSWORD_REQUIRED\", originalRequired)\n784: \t}()\n785: \n786: \t// Use an invalid address format that will fail client creation\n787: \tos.Setenv(\"VALKEY_ADDR\", \"invalid-address-format\")\n788: \tos.Setenv(\"VALKEY_PASSWORD\", \"\")\n789: \tos.Setenv(\"VALKEY_PASSWORD_REQUIRED\", \"false\")\n790: \n791: \t// This may or may not fail depending on how valkey-go handles invalid addresses\n792: \t// The client might be created successfully but fail on actual operations\n793: \t_, err := newValkeyStore()\n794: \t// We don't assert on error here because valkey-go may allow client creation\n795: \t// with invalid addresses and only fail on actual operations\n796: \tif err == nil {\n797: \t\tt.Log(\"newValkeyStore() with invalid address did not error (client may be lazy)\")\n798: \t}\n799: }\n800: \n801: func TestValkeyStore_Ping_WrongResponse(t *testing.T) {\n802: \tm := setupTestValkey(t)\n803: \tdefer m.Close()\n804: \n805: \ts := createTestValkeyStore(t, m)\n806: \tdefer s.Close()\n807: \n808: \tctx := context.Background()\n809: \n810: \t// Normal ping should succeed\n811: \terr := s.Ping(ctx)\n812: \tif err != nil {\n813: \t\tt.Fatalf(\"Ping() error = %v\", err)\n814: \t}\n815: }\n816: \n817: func TestValkeyStore_StoreSandbox_MarshalError(t *testing.T) {\n818: \tm := setupTestValkey(t)\n819: \tdefer m.Close()\n820: \n821: \ts := createTestValkeyStore(t, m)\n822: \tdefer s.Close()\n823: \n824: \tctx := context.Background()\n825: \n826: \t// Create a sandbox that can be marshaled normally\n827: \tsandbox := createTestSandboxForValkey(\"test-session\", time.Now().Add(time.Hour))\n828: \n829: \t// This should succeed with valid sandbox\n830: \terr := s.StoreSandbox(ctx, sandbox)\n831: \tif err != nil {\n832: \t\tt.Fatalf(\"StoreSandbox() error = %v\", err)\n833: \t}\n834: }\n835: \n836: func TestValkeyStore_UpdateSandbox_MarshalError(t *testing.T) {\n837: \tm := setupTestValkey(t)\n838: \tdefer m.Close()\n839: \n840: \ts := createTestValkeyStore(t, m)\n841: \tdefer s.Close()\n842: \n843: \tctx := context.Background()\n844: \n845: \t// First store a valid sandbox\n846: \tsandbox := createTestSandboxForValkey(\"test-session\", time.Now().Add(time.Hour))\n847: \tif err := s.StoreSandbox(ctx, sandbox); err != nil {\n848: \t\tt.Fatalf(\"StoreSandbox() error = %v\", err)\n849: \t}\n850: \n851: \t// Now update with a normal sandbox - should work\n852: \tsandbox.Status = \"Updated\"\n853: \terr := s.UpdateSandbox(ctx, sandbox)\n854: \tif err != nil {\n855: \t\tt.Fatalf(\"UpdateSandbox() error = %v\", err)\n856: \t}\n857: }\n858: \n859: func TestValkeyStore_GetSandboxBySessionID_UnmarshalError(t *testing.T) {\n860: \tm := setupTestValkey(t)\n861: \tdefer m.Close()\n862: \n863: \ts := createTestValkeyStore(t, m)\n864: \tdefer s.Close()\n865: \n866: \tctx := context.Background()\n867: \n868: \t// Store invalid JSON data directly\n869: \tkey := s.sessionKey(\"bad-session\")\n870: \tm.Set(key, \"not-valid-json\")\n871: \n872: \t// Try to get the sandbox - should fail to unmarshal\n873: \t_, err := s.GetSandboxBySessionID(ctx, \"bad-session\")\n874: \tif err == nil {\n875: \t\tt.Error(\"GetSandboxBySessionID() with invalid JSON expected error\")\n876: \t}\n877: }\n878: \n879: func TestValkeyStore_ListExpiredSandboxes_EdgeCases(t *testing.T) {\n880: \tm := setupTestValkey(t)\n881: \tdefer m.Close()\n882: \n883: \ts := createTestValkeyStore(t, m)\n884: \tdefer s.Close()\n885: \n886: \tctx := context.Background()\n887: \tnow := time.Now()\n888: \n889: \t// Store sandbox with exact boundary time\n890: \tsandbox := createTestSandboxForValkey(\"boundary-session\", now)\n891: \tif err := s.StoreSandbox(ctx, sandbox); err != nil {\n892: \t\tt.Fatalf(\"StoreSandbox() error = %v\", err)\n893: \t}\n894: \n895: \t// List with before = now should include this session (ExpiresAt <= before)\n896: \texpired, err := s.ListExpiredSandboxes(ctx, now, 10)\n897: \tif err != nil {\n898: \t\tt.Fatalf(\"ListExpiredSandboxes() error = %v\", err)\n899: \t}\n900: \tif len(expired) != 1 {\n901: \t\tt.Errorf(\"ListExpiredSandboxes() returned %d sandboxes, want 1\", len(expired))\n902: \t}\n903: }\n904: \n905: func TestValkeyStore_ConcurrentOperations(t *testing.T) {\n906: \tm := setupTestValkey(t)\n907: \tdefer m.Close()\n908: \n909: \ts := createTestValkeyStore(t, m)\n910: \tdefer s.Close()\n911: \n912: \tctx := context.Background()\n913: \tnow := time.Now()\n914: \n915: \t// Store multiple sandboxes concurrently\n916: \tdone := make(chan bool, 5)\n917: \tfor i := 0; i < 5; i++ {\n918: \t\tgo func(idx int) {\n919: \t\t\tsessionID := fmt.Sprintf(\"concurrent-%d\", idx)\n920: \t\t\tsandbox := createTestSandboxForValkey(sessionID, now.Add(time.Hour))\n921: \t\t\terr := s.StoreSandbox(ctx, sandbox)\n922: \t\t\tif err != nil {\n923: \t\t\t\tt.Errorf(\"Concurrent StoreSandbox() error = %v\", err)\n924: \t\t\t}\n925: \t\t\tdone <- true\n926: \t\t}(i)\n927: \t}\n928: \n929: \t// Wait for all goroutines\n930: \tfor i := 0; i < 5; i++ {\n931: \t\t<-done\n932: \t}\n933: \n934: \t// Verify all sandboxes were stored\n935: \tfor i := 0; i < 5; i++ {\n936: \t\tsessionID := fmt.Sprintf(\"concurrent-%d\", i)\n937: \t\t_, err := s.GetSandboxBySessionID(ctx, sessionID)\n938: \t\tif err != nil {\n939: \t\t\tt.Errorf(\"GetSandboxBySessionID(%s) error = %v\", sessionID, err)\n940: \t\t}\n941: \t}\n942: }\n\n(End of file - total 942 lines)\n</content>","metadata":{"preview":"/*\nCopyright 2026 The Volcano Authors.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\npackage store\n\nimport (\n\t\"context\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/store/valkey_test.go","time":{"start":1775870552828,"end":1775870552859}}}}
{"type":"tool_use","timestamp":1775870552864,"sessionID":"ses_285de29deffekAmJtPJ8nwlQSR","part":{"id":"prt_d7a221635001GjXVqE7sofCX1U","messageID":"msg_d7a21feb5001ER6sf80MH9tZqJ","sessionID":"ses_285de29deffekAmJtPJ8nwlQSR","type":"tool","tool":"read","callID":"toolu_functions.read:3","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/store/valkey.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/store/valkey.go</path>\n<type>file</type>\n<content>\n1: /*\n2: Copyright 2026 The Volcano Authors.\n3: \n4: Licensed under the Apache License, Version 2.0 (the \"License\");\n5: you may not use this file except in compliance with the License.\n6: You may obtain a copy of the License at\n7: \n8:     http://www.apache.org/licenses/LICENSE-2.0\n9: \n10: Unless required by applicable law or agreed to in writing, software\n11: distributed under the License is distributed on an \"AS IS\" BASIS,\n12: WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n13: See the License for the specific language governing permissions and\n14: limitations under the License.\n15: */\n16: \n17: package store\n18: \n19: import (\n20: \t\"context\"\n21: \t\"encoding/json\"\n22: \t\"fmt\"\n23: \t\"time\"\n24: \n25: \t\"github.com/valkey-io/valkey-go\"\n26: \t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n27: )\n28: \n29: // valkeyStore implements Store interface using Valkey backend.\n30: type valkeyStore struct {\n31: \tcli                  valkey.Client\n32: \tsessionPrefix        string\n33: \texpiryIndexKey       string\n34: \tlastActivityIndexKey string\n35: }\n36: \n37: // newValkeyStore creates a new Valkey-backed Store instance.\n38: func newValkeyStore() (Store, error) {\n39: \topts, err := makeValkeyOptions()\n40: \tif err != nil {\n41: \t\treturn nil, err\n42: \t}\n43: \n44: \tclientOption := valkey.ClientOption{\n45: \t\tInitAddress:       opts.InitAddress,\n46: \t\tDisableCache:      opts.DisableCache,\n47: \t\tForceSingleClient: opts.ForceSingleClient,\n48: \t}\n49: \n50: \t// Configure password if provided\n51: \tif opts.Password != \"\" {\n52: \t\tclientOption.Password = opts.Password\n53: \t}\n54: \n55: \tclient, err := valkey.NewClient(clientOption)\n56: \tif err != nil {\n57: \t\treturn nil, fmt.Errorf(\"failed to create valkey client: %w\", err)\n58: \t}\n59: \n60: \treturn &valkeyStore{\n61: \t\tcli:                  client,\n62: \t\tsessionPrefix:        sessionPrefix,\n63: \t\texpiryIndexKey:       expiryIndexKey,\n64: \t\tlastActivityIndexKey: lastActivityIndexKey,\n65: \t}, nil\n66: }\n67: \n68: // sessionKey constructs the Valkey key for a session.\n69: func (s *valkeyStore) sessionKey(sessionID string) string {\n70: \treturn s.sessionPrefix + sessionID\n71: }\n72: \n73: // Ping verifies connectivity to the Valkey backend.\n74: // Returns nil on success, error on failure.\n75: func (s *valkeyStore) Ping(ctx context.Context) error {\n76: \tresult := s.cli.Do(ctx, s.cli.B().Ping().Build())\n77: \tif result.Error() != nil {\n78: \t\treturn result.Error()\n79: \t}\n80: \n81: \tpong, err := result.ToString()\n82: \tif err != nil {\n83: \t\treturn fmt.Errorf(\"failed to parse ping response: %w\", err)\n84: \t}\n85: \tif pong != \"PONG\" {\n86: \t\treturn fmt.Errorf(\"unexpected ping response: %s\", pong)\n87: \t}\n88: \treturn nil\n89: }\n90: \n91: // GetSandboxBySessionID retrieves sandbox info by session ID.\n92: // Returns ErrNotFound if the session does not exist.\n93: func (s *valkeyStore) GetSandboxBySessionID(ctx context.Context, sessionID string) (*types.SandboxInfo, error) {\n94: \tif sessionID == \"\" {\n95: \t\treturn nil, fmt.Errorf(\"sessionID is empty\")\n96: \t}\n97: \n98: \tkey := s.sessionKey(sessionID)\n99: \tresult := s.cli.Do(ctx, s.cli.B().Get().Key(key).Build())\n100: \tif result.Error() != nil {\n101: \t\tif valkey.IsValkeyNil(result.Error()) {\n102: \t\t\treturn nil, ErrNotFound\n103: \t\t}\n104: \t\treturn nil, result.Error()\n105: \t}\n106: \n107: \tdata, err := result.ToString()\n108: \tif err != nil {\n109: \t\treturn nil, fmt.Errorf(\"failed to get session data: %w\", err)\n110: \t}\n111: \n112: \tvar sandbox types.SandboxInfo\n113: \tif err := json.Unmarshal([]byte(data), &sandbox); err != nil {\n114: \t\treturn nil, fmt.Errorf(\"failed to unmarshal sandbox: %w\", err)\n115: \t}\n116: \n117: \treturn &sandbox, nil\n118: }\n119: \n120: // StoreSandbox creates a new sandbox entry with atomic index updates.\n121: // Validates sandbox is non-nil and has valid ExpiresAt.\n122: // Uses SETNX to prevent overwriting existing keys.\n123: func (s *valkeyStore) StoreSandbox(ctx context.Context, sandbox *types.SandboxInfo) error {\n124: \tif sandbox == nil {\n125: \t\treturn fmt.Errorf(\"sandbox is nil\")\n126: \t}\n127: \tif sandbox.SessionID == \"\" {\n128: \t\treturn fmt.Errorf(\"sessionID is empty\")\n129: \t}\n130: \tif sandbox.ExpiresAt.IsZero() {\n131: \t\treturn fmt.Errorf(\"expiresAt is zero\")\n132: \t}\n133: \n134: \tkey := s.sessionKey(sandbox.SessionID)\n135: \tdata, err := json.Marshal(sandbox)\n136: \tif err != nil {\n137: \t\treturn fmt.Errorf(\"failed to marshal sandbox: %w\", err)\n138: \t}\n139: \n140: \tnow := time.Now().Unix()\n141: \n142: \t// Use DoMulti for atomic operations\n143: \tresults := s.cli.DoMulti(ctx,\n144: \t\ts.cli.B().Set().Key(key).Value(string(data)).Nx().Build(),\n145: \t\ts.cli.B().Zadd().Key(s.expiryIndexKey).ScoreMember().\n146: \t\t\tScoreMember(float64(sandbox.ExpiresAt.Unix()), sandbox.SessionID).Build(),\n147: \t\ts.cli.B().Zadd().Key(s.lastActivityIndexKey).ScoreMember().\n148: \t\t\tScoreMember(float64(now), sandbox.SessionID).Build(),\n149: \t)\n150: \n151: \t// Check for errors in any of the results\n152: \tfor i, r := range results {\n153: \t\tif r.Error() != nil {\n154: \t\t\t// Clean up already executed commands on error (best effort)\n155: \t\t\treturn r.Error()\n156: \t\t}\n157: \n158: \t\t// First command is SET NX - check if it succeeded\n159: \t\tif i == 0 {\n160: \t\t\tsetResult, err := r.ToString()\n161: \t\t\tif err != nil {\n162: \t\t\t\treturn fmt.Errorf(\"session already exists\")\n163: \t\t\t}\n164: \t\t\tif setResult != \"OK\" {\n165: \t\t\t\treturn fmt.Errorf(\"session already exists\")\n166: \t\t\t}\n167: \t\t}\n168: \t}\n169: \n170: \treturn nil\n171: }\n172: \n173: // UpdateSandbox updates an existing sandbox's JSON data.\n174: // Uses SET with XX flag (key must exist).\n175: // Does NOT modify expiry or last-activity indexes.\n176: func (s *valkeyStore) UpdateSandbox(ctx context.Context, sandbox *types.SandboxInfo) error {\n177: \tif sandbox == nil {\n178: \t\treturn fmt.Errorf(\"sandbox is nil\")\n179: \t}\n180: \tif sandbox.SessionID == \"\" {\n181: \t\treturn fmt.Errorf(\"sessionID is empty\")\n182: \t}\n183: \n184: \tkey := s.sessionKey(sandbox.SessionID)\n185: \tdata, err := json.Marshal(sandbox)\n186: \tif err != nil {\n187: \t\treturn fmt.Errorf(\"failed to marshal sandbox: %w\", err)\n188: \t}\n189: \n190: \t// SET with XX flag - only set if key exists\n191: \tresult := s.cli.Do(ctx, s.cli.B().Set().Key(key).Value(string(data)).Xx().Build())\n192: \tif result.Error() != nil {\n193: \t\treturn result.Error()\n194: \t}\n195: \n196: \t// Check if the operation succeeded (XX returns nil/empty if key doesn't exist)\n197: \tstrResult, err := result.ToString()\n198: \tif err != nil {\n199: \t\treturn fmt.Errorf(\"key not exists\")\n200: \t}\n201: \tif strResult != \"OK\" {\n202: \t\treturn fmt.Errorf(\"key not exists\")\n203: \t}\n204: \n205: \treturn nil\n206: }\n207: \n208: // DeleteSandboxBySessionID removes a sandbox and its indexes.\n209: // Uses atomic pipeline: DEL + ZREM expiry + ZREM last_activity.\n210: func (s *valkeyStore) DeleteSandboxBySessionID(ctx context.Context, sessionID string) error {\n211: \tif sessionID == \"\" {\n212: \t\treturn fmt.Errorf(\"sessionID is empty\")\n213: \t}\n214: \n215: \tkey := s.sessionKey(sessionID)\n216: \n217: \t// Use DoMulti for atomic operations\n218: \tresults := s.cli.DoMulti(ctx,\n219: \t\ts.cli.B().Del().Key(key).Build(),\n220: \t\ts.cli.B().Zrem().Key(s.expiryIndexKey).Member(sessionID).Build(),\n221: \t\ts.cli.B().Zrem().Key(s.lastActivityIndexKey).Member(sessionID).Build(),\n222: \t)\n223: \n224: \t// Check for errors\n225: \tfor _, r := range results {\n226: \t\tif r.Error() != nil {\n227: \t\t\treturn r.Error()\n228: \t\t}\n229: \t}\n230: \n231: \treturn nil\n232: }\n233: \n234: // ListExpiredSandboxes returns sessions with ExpiresAt <= before.\n235: // Queries session:expiry ZSET with ZRANGEBYSCORE.\n236: // Returns nil, nil if limit <= 0.\n237: func (s *valkeyStore) ListExpiredSandboxes(ctx context.Context, before time.Time, limit int64) ([]*types.SandboxInfo, error) {\n238: \tif limit <= 0 {\n239: \t\treturn nil, nil\n240: \t}\n241: \n242: \t// Get expired session IDs from the ZSET\n243: \tzrangeResult := s.cli.Do(ctx, s.cli.B().Zrangebyscore().Key(s.expiryIndexKey).\n244: \t\tMin(\"-inf\").Max(fmt.Sprintf(\"%d\", before.Unix())).Limit(0, limit).Build())\n245: \tif zrangeResult.Error() != nil {\n246: \t\treturn nil, zrangeResult.Error()\n247: \t}\n248: \n249: \tarr, err := zrangeResult.ToArray()\n250: \tif err != nil {\n251: \t\treturn nil, fmt.Errorf(\"failed to parse zrange result: %w\", err)\n252: \t}\n253: \n254: \tsessionIDs := make([]string, 0, len(arr))\n255: \tfor _, v := range arr {\n256: \t\tid, err := v.ToString()\n257: \t\tif err != nil {\n258: \t\t\tcontinue\n259: \t\t}\n260: \t\tsessionIDs = append(sessionIDs, id)\n261: \t}\n262: \n263: \treturn s.loadSandboxesBySessionIDs(ctx, sessionIDs)\n264: }\n265: \n266: // ListInactiveSandboxes returns sessions with last activity <= before.\n267: // Queries session:last_activity ZSET with ZRANGEBYSCORE.\n268: // Returns nil, nil if limit <= 0.\n269: func (s *valkeyStore) ListInactiveSandboxes(ctx context.Context, before time.Time, limit int64) ([]*types.SandboxInfo, error) {\n270: \tif limit <= 0 {\n271: \t\treturn nil, nil\n272: \t}\n273: \n274: \t// Get inactive session IDs from the ZSET\n275: \tzrangeResult := s.cli.Do(ctx, s.cli.B().Zrangebyscore().Key(s.lastActivityIndexKey).\n276: \t\tMin(\"-inf\").Max(fmt.Sprintf(\"%d\", before.Unix())).Limit(0, limit).Build())\n277: \tif zrangeResult.Error() != nil {\n278: \t\treturn nil, zrangeResult.Error()\n279: \t}\n280: \n281: \tarr, err := zrangeResult.ToArray()\n282: \tif err != nil {\n283: \t\treturn nil, fmt.Errorf(\"failed to parse zrange result: %w\", err)\n284: \t}\n285: \n286: \tsessionIDs := make([]string, 0, len(arr))\n287: \tfor _, v := range arr {\n288: \t\tid, err := v.ToString()\n289: \t\tif err != nil {\n290: \t\t\tcontinue\n291: \t\t}\n292: \t\tsessionIDs = append(sessionIDs, id)\n293: \t}\n294: \n295: \treturn s.loadSandboxesBySessionIDs(ctx, sessionIDs)\n296: }\n297: \n298: // loadSandboxesBySessionIDs loads sandbox info for the given session IDs.\n299: // Skips entries where the session key is missing (orphaned ZSET entries).\n300: func (s *valkeyStore) loadSandboxesBySessionIDs(ctx context.Context, sessionIDs []string) ([]*types.SandboxInfo, error) {\n301: \tif len(sessionIDs) == 0 {\n302: \t\treturn []*types.SandboxInfo{}, nil\n303: \t}\n304: \n305: \t// Build keys for all session IDs\n306: \tkeys := make([]string, len(sessionIDs))\n307: \tfor i, id := range sessionIDs {\n308: \t\tkeys[i] = s.sessionKey(id)\n309: \t}\n310: \n311: \t// Use MGET to fetch all sessions in one call\n312: \tmgetResult := s.cli.Do(ctx, s.cli.B().Mget().Key(keys...).Build())\n313: \tif mgetResult.Error() != nil {\n314: \t\treturn nil, mgetResult.Error()\n315: \t}\n316: \n317: \tarr, err := mgetResult.ToArray()\n318: \tif err != nil {\n319: \t\treturn nil, fmt.Errorf(\"failed to parse mget result: %w\", err)\n320: \t}\n321: \n322: \t// Parse results, skipping empty entries (orphaned ZSET members)\n323: \tsandboxes := make([]*types.SandboxInfo, 0, len(arr))\n324: \tfor _, v := range arr {\n325: \t\tdata, err := v.ToString()\n326: \t\tif err != nil {\n327: \t\t\t// Nil value or error - skip\n328: \t\t\tcontinue\n329: \t\t}\n330: \n331: \t\tif data == \"\" {\n332: \t\t\t// Orphaned ZSET entry - skip\n333: \t\t\tcontinue\n334: \t\t}\n335: \n336: \t\tvar sandbox types.SandboxInfo\n337: \t\tif err := json.Unmarshal([]byte(data), &sandbox); err != nil {\n338: \t\t\t// Failed to parse - skip this entry but continue\n339: \t\t\tcontinue\n340: \t\t}\n341: \n342: \t\tsandboxes = append(sandboxes, &sandbox)\n343: \t}\n344: \n345: \treturn sandboxes, nil\n346: }\n347: \n348: // UpdateSessionLastActivity updates the last activity timestamp for a session.\n349: // Returns ErrNotFound if session does not exist.\n350: // If at is zero time, uses time.Now().\n351: func (s *valkeyStore) UpdateSessionLastActivity(ctx context.Context, sessionID string, at time.Time) error {\n352: \tif sessionID == \"\" {\n353: \t\treturn fmt.Errorf(\"sessionID is empty\")\n354: \t}\n355: \n356: \t// Verify session exists before updating\n357: \tkey := s.sessionKey(sessionID)\n358: \texistsResult := s.cli.Do(ctx, s.cli.B().Exists().Key(key).Build())\n359: \tif existsResult.Error() != nil {\n360: \t\treturn existsResult.Error()\n361: \t}\n362: \n363: \texists, err := existsResult.ToInt64()\n364: \tif err != nil {\n365: \t\treturn fmt.Errorf(\"failed to check session existence: %w\", err)\n366: \t}\n367: \tif exists == 0 {\n368: \t\treturn ErrNotFound\n369: \t}\n370: \n371: \t// Use current time if at is zero\n372: \tif at.IsZero() {\n373: \t\tat = time.Now()\n374: \t}\n375: \n376: \t// Update the activity index\n377: \tzaddResult := s.cli.Do(ctx, s.cli.B().Zadd().Key(s.lastActivityIndexKey).ScoreMember().\n378: \t\tScoreMember(float64(at.Unix()), sessionID).Build())\n379: \tif zaddResult.Error() != nil {\n380: \t\treturn zaddResult.Error()\n381: \t}\n382: \n383: \treturn nil\n384: }\n385: \n386: // Close closes the Valkey connection.\n387: func (s *valkeyStore) Close() error {\n388: \ts.cli.Close()\n389: \treturn nil\n390: }\n\n(End of file - total 390 lines)\n</content>","metadata":{"preview":"/*\nCopyright 2026 The Volcano Authors.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\npackage store\n\nimport (\n\t\"context\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/store/valkey.go","time":{"start":1775870552821,"end":1775870552862}}}}
{"type":"tool_use","timestamp":1775870552865,"sessionID":"ses_285de29deffekAmJtPJ8nwlQSR","part":{"id":"prt_d7a221b8d001X97C0BHYzGS4An","messageID":"msg_d7a21feb5001ER6sf80MH9tZqJ","sessionID":"ses_285de29deffekAmJtPJ8nwlQSR","type":"tool","tool":"read","callID":"toolu_functions.read:4","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/store/store.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/store/store.go</path>\n<type>file</type>\n<content>\n1: /*\n2: Copyright 2026 The Volcano Authors.\n3: \n4: Licensed under the Apache License, Version 2.0 (the \"License\");\n5: you may not use this file except in compliance with the License.\n6: You may obtain a copy of the License at\n7: \n8:     http://www.apache.org/licenses/LICENSE-2.0\n9: \n10: Unless required by applicable law or agreed to in writing, software\n11: distributed under the License is distributed on an \"AS IS\" BASIS,\n12: WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n13: See the License for the specific language governing permissions and\n14: limitations under the License.\n15: */\n16: \n17: package store\n18: \n19: import (\n20: \t\"context\"\n21: \t\"errors\"\n22: \t\"time\"\n23: \n24: \t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n25: )\n26: \n27: // ErrNotFound is returned when a session is not found in the store.\n28: var ErrNotFound = errors.New(\"store: not found\")\n29: \n30: // Store defines the interface for session storage backends.\n31: // Implementations include Redis and Valkey providers.\n32: type Store interface {\n33: \t// Ping checks connectivity to the store.\n34: \tPing(ctx context.Context) error\n35: \n36: \t// GetSandboxBySessionID retrieves sandbox information by session ID.\n37: \t// Returns ErrNotFound if the session does not exist.\n38: \tGetSandboxBySessionID(ctx context.Context, sessionID string) (*types.SandboxInfo, error)\n39: \n40: \t// StoreSandbox stores sandbox information in the store.\n41: \tStoreSandbox(ctx context.Context, sandboxStore *types.SandboxInfo) error\n42: \n43: \t// UpdateSandbox updates existing sandbox information.\n44: \tUpdateSandbox(ctx context.Context, sandboxStore *types.SandboxInfo) error\n45: \n46: \t// DeleteSandboxBySessionID removes a sandbox from the store.\n47: \tDeleteSandboxBySessionID(ctx context.Context, sessionID string) error\n48: \n49: \t// ListExpiredSandboxes returns sandboxes that have expired before the given time.\n50: \tListExpiredSandboxes(ctx context.Context, before time.Time, limit int64) ([]*types.SandboxInfo, error)\n51: \n52: \t// ListInactiveSandboxes returns sandboxes inactive since before the given time.\n53: \tListInactiveSandboxes(ctx context.Context, before time.Time, limit int64) ([]*types.SandboxInfo, error)\n54: \n55: \t// UpdateSessionLastActivity updates the last activity timestamp for a session.\n56: \tUpdateSessionLastActivity(ctx context.Context, sessionID string, at time.Time) error\n57: \n58: \t// Close closes the store connection.\n59: \tClose() error\n60: }\n\n(End of file - total 60 lines)\n</content>","metadata":{"preview":"/*\nCopyright 2026 The Volcano Authors.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\npackage store\n\nimport (\n\t\"context\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/store/store.go","time":{"start":1775870552826,"end":1775870552864}}}}
{"type":"tool_use","timestamp":1775870552868,"sessionID":"ses_285de29deffekAmJtPJ8nwlQSR","part":{"id":"prt_d7a22260e001VvplGhfRLglkTV","messageID":"msg_d7a21feb5001ER6sf80MH9tZqJ","sessionID":"ses_285de29deffekAmJtPJ8nwlQSR","type":"tool","tool":"read","callID":"toolu_functions.read:6","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/store/doc.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/store/doc.go</path>\n<type>file</type>\n<content>\n1: /*\n2: Copyright 2026 The Volcano Authors.\n3: \n4: Licensed under the Apache License, Version 2.0 (the \"License\");\n5: you may not use this file except in compliance with the License.\n6: You may obtain a copy of the License at\n7: \n8:     http://www.apache.org/licenses/LICENSE-2.0\n9: \n10: Unless required by applicable law or agreed to in writing, software\n11: distributed under the License is distributed on an \"AS IS\" BASIS,\n12: WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n13: See the License for the specific language governing permissions and\n14: limitations under the License.\n15: */\n16: \n17: // Package store provides a unified storage abstraction for persisting sandbox session metadata.\n18: // It supports both Redis and Valkey backends, enabling CRUD operations on sandbox information\n19: // with indexes for expiry and last activity times to support garbage collection.\n20: //\n21: // The Store interface defines the contract for all storage operations:\n22: //   - Ping: Verify connectivity to the backend\n23: //   - GetSandboxBySessionID: Retrieve sandbox information\n24: //   - StoreSandbox: Create new sandbox entries with atomic index updates\n25: //   - UpdateSandbox: Update existing sandbox data\n26: //   - DeleteSandboxBySessionID: Remove sandbox and clean up indexes\n27: //   - ListExpiredSandboxes: Query expired sessions for garbage collection\n28: //   - ListInactiveSandboxes: Query inactive sessions for idle detection\n29: //   - UpdateSessionLastActivity: Bump activity timestamps\n30: //   - Close: Clean up connections\n31: //\n32: // Provider Selection:\n33: //\n34: // The storage provider is selected via the STORE_TYPE environment variable:\n35: //   - \"redis\" (default): Uses Redis backend via go-redis/v9\n36: //   - \"valkey\": Uses Valkey backend via valkey-go\n37: //\n38: // Thread-Safe Singleton Access:\n39: //\n40: // Use the Storage() function to get the singleton Store instance:\n41: //\n42: //\tstore := store.Storage()\n43: //\tsandbox, err := store.GetSandboxBySessionID(ctx, \"session-id\")\n44: //\n45: // The singleton is initialized once using sync.Once and is safe for concurrent use.\n46: //\n47: // Key Naming:\n48: //\n49: // Session data is stored with the key pattern: \"session:{sessionID}\"\n50: // The store maintains two sorted set indexes:\n51: //   - \"session:expiry\": ZSET with score = ExpiresAt Unix timestamp\n52: //   - \"session:last_activity\": ZSET with score = last activity Unix timestamp\n53: //\n54: // Error Handling:\n55: //\n56: // The package defines ErrNotFound for missing session keys. All implementations\n57: // translate their specific \"not found\" errors (redis.Nil, IsValkeyNil) to this\n58: // sentinel error for consistent handling.\n59: //\n60: // Environment Variables:\n61: //\n62: // Redis Configuration:\n63: //   - REDIS_ADDR: Redis server address (required)\n64: //   - REDIS_PASSWORD: Authentication password (required unless REDIS_PASSWORD_REQUIRED=false)\n65: //   - REDIS_PASSWORD_REQUIRED: Set to \"false\" to allow empty password\n66: //\n67: // Valkey Configuration:\n68: //   - VALKEY_ADDR: Comma-separated list of Valkey addresses (required)\n69: //   - VALKEY_PASSWORD: Authentication password (required unless VALKEY_PASSWORD_REQUIRED=false)\n70: //   - VALKEY_PASSWORD_REQUIRED: Set to \"false\" to allow empty password\n71: //   - VALKEY_DISABLE_CACHE: Set to \"true\" to disable client cache\n72: //   - VALKEY_FORCE_SINGLE: Set to \"true\" for single client mode\n73: //\n74: // Example Usage:\n75: //\n76: //\tctx := context.Background()\n77: //\tstore := store.Storage()\n78: //\n79: //\t// Create a sandbox\n80: //\tsandbox := &types.SandboxInfo{\n81: //\t    SessionID: \"sess-123\",\n82: //\t    SandboxID: \"sb-456\",\n83: //\t    ExpiresAt: time.Now().Add(time.Hour),\n84: //\t}\n85: //\tif err := store.StoreSandbox(ctx, sandbox); err != nil {\n86: //\t    // handle error\n87: //\t}\n88: //\n89: //\t// Retrieve sandbox\n90: //\tinfo, err := store.GetSandboxBySessionID(ctx, \"sess-123\")\n91: //\tif err != nil {\n92: //\t    if errors.Is(err, store.ErrNotFound) {\n93: //\t        // session not found\n94: //\t    }\n95: //\t    // handle other errors\n96: //\t}\n97: //\n98: //\t// Clean up\n99: //\tdefer store.Close()\n100: package store\n\n(End of file - total 100 lines)\n</content>","metadata":{"preview":"/*\nCopyright 2026 The Volcano Authors.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\n// Package store provides a unified storage abstraction for persisting sandbox session metadata.\n// It supports both Redis and Valkey backends, enabling CRUD operations on sandbox information\n// with indexes for expiry and last activity times to support garbage collection.\n//","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/store/doc.go","time":{"start":1775870552830,"end":1775870552866}}}}
