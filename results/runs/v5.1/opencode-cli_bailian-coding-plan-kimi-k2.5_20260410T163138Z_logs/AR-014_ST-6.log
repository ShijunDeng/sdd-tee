nv(\"VALKEY_ADDR\", m.Addr())\n\tos.Setenv(\"VALKEY_PASSWORD\", \"\")\n\tos.Setenv(\"VALKEY_PASSWORD_REQUIRED\", \"false\")\n\tos.Setenv(\"VALKEY_DISABLE_CACHE\", \"true\")\n\n\tstore, err := newValkeyStore()\n\tif err != nil {\n\t\tt.Fatalf(\"newValkeyStore() error = %v\", err)\n\t}\n\tif store == nil {\n\t\tt.Fatal(\"newValkeyStore() returned nil\")\n\t}\n\tdefer store.Close()\n\n\t// Test that it implements Store interface\n\tvar _ Store = store\n}"},"output":"Edit applied successfully.","metadata":{"diagnostics":{"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/store/valkey.go":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/store/doc.go":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/store/store.go":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/go.mod":[{"range":{"start":{"line":18,"character":42},"end":{"line":18,"character":53}},"severity":2,"source":"go mod tidy","message":"github.com/alicebob/miniredis/v2 should be direct"}],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/store/valkey_test.go":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/store/redis_test.go":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/store/singleton.go":[]},"diff":"Index: /home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/store/valkey_test.go\n===================================================================\n--- /home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/store/valkey_test.go\n+++ /home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/store/valkey_test.go\n@@ -733,17 +733,20 @@\n // Clean up environment after test\n originalAddr := os.Getenv(\"VALKEY_ADDR\")\n originalPassword := os.Getenv(\"VALKEY_PASSWORD\")\n originalRequired := os.Getenv(\"VALKEY_PASSWORD_REQUIRED\")\n+originalDisableCache := os.Getenv(\"VALKEY_DISABLE_CACHE\")\n defer func() {\n \tos.Setenv(\"VALKEY_ADDR\", originalAddr)\n \tos.Setenv(\"VALKEY_PASSWORD\", originalPassword)\n \tos.Setenv(\"VALKEY_PASSWORD_REQUIRED\", originalRequired)\n+\tos.Setenv(\"VALKEY_DISABLE_CACHE\", originalDisableCache)\n }()\n \n os.Setenv(\"VALKEY_ADDR\", m.Addr())\n os.Setenv(\"VALKEY_PASSWORD\", \"\")\n os.Setenv(\"VALKEY_PASSWORD_REQUIRED\", \"false\")\n+os.Setenv(\"VALKEY_DISABLE_CACHE\", \"true\")\n \n store, err := newValkeyStore()\n if err != nil {\n \tt.Fatalf(\"newValkeyStore() error = %v\", err)\n","filediff":{"file":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/store/valkey_test.go","before":"/*\nCopyright 2026 The Volcano Authors.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\npackage store\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"os\"\n\t\"strings\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/alicebob/miniredis/v2\"\n\t\"github.com/valkey-io/valkey-go\"\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n)\n\n// setupTestValkey creates a new miniredis instance for testing.\n// Since Valkey is Redis-compatible, we can use miniredis for testing.\nfunc setupTestValkey(t *testing.T) *miniredis.Miniredis {\n\treturn miniredis.RunT(t)\n}\n\n// createTestValkeyStore creates a valkeyStore instance connected to the test server.\nfunc createTestValkeyStore(t *testing.T, m *miniredis.Miniredis) *valkeyStore {\n\tclient, err := valkey.NewClient(valkey.ClientOption{\n\t\tInitAddress:       []string{m.Addr()},\n\t\tDisableCache:      true,\n\t\tForceSingleClient: true,\n\t})\n\tif err != nil {\n\t\tt.Fatalf(\"Failed to create valkey client: %v\", err)\n\t}\n\treturn &valkeyStore{\n\t\tcli:                  client,\n\t\tsessionPrefix:        sessionPrefix,\n\t\texpiryIndexKey:       expiryIndexKey,\n\t\tlastActivityIndexKey: lastActivityIndexKey,\n\t}\n}\n\n// createTestSandboxForValkey creates a test sandbox with the given sessionID.\nfunc createTestSandboxForValkey(sessionID string, expiresAt time.Time) *types.SandboxInfo {\n\treturn &types.SandboxInfo{\n\t\tKind:             \"AgentRuntime\",\n\t\tSandboxID:        fmt.Sprintf(\"sb-%s\", sessionID),\n\t\tSandboxNamespace: \"default\",\n\t\tName:             fmt.Sprintf(\"runtime-%s\", sessionID),\n\t\tEntryPoints: []types.SandboxEntryPoint{\n\t\t\t{\n\t\t\t\tPath:     \"/api\",\n\t\t\t\tProtocol: \"http\",\n\t\t\t\tEndpoint: \"localhost:8080\",\n\t\t\t},\n\t\t},\n\t\tSessionID: sessionID,\n\t\tCreatedAt: time.Now().UTC(),\n\t\tExpiresAt: expiresAt,\n\t\tStatus:    \"Running\",\n\t\tPodIP:     \"10.0.0.1\",\n\t\tPodName:   fmt.Sprintf(\"pod-%s\", sessionID),\n\t}\n}\n\nfunc TestValkeyStore_Ping(t *testing.T) {\n\tm := setupTestValkey(t)\n\tdefer m.Close()\n\n\ts := createTestValkeyStore(t, m)\n\tdefer s.Close()\n\n\tctx := context.Background()\n\terr := s.Ping(ctx)\n\tif err != nil {\n\t\tt.Fatalf(\"Ping() error = %v\", err)\n\t}\n}\n\nfunc TestValkeyStore_Ping_Failure(t *testing.T) {\n\t// Create a client to a non-existent server\n\tclient, err := valkey.NewClient(valkey.ClientOption{\n\t\tInitAddress:       []string{\"127.0.0.1:63791\"},\n\t\tDisableCache:      true,\n\t\tForceSingleClient: true,\n\t})\n\tif err != nil {\n\t\t// Client creation might fail for some invalid addresses\n\t\tt.Skipf(\"valkey client creation failed (may not be supported for unreachable addresses): %v\", err)\n\t}\n\n\ts := &valkeyStore{\n\t\tcli:                  client,\n\t\tsessionPrefix:        sessionPrefix,\n\t\texpiryIndexKey:       expiryIndexKey,\n\t\tlastActivityIndexKey: lastActivityIndexKey,\n\t}\n\tdefer s.Close()\n\n\tctx, cancel := context.WithTimeout(context.Background(), 100*time.Millisecond)\n\tdefer cancel()\n\n\terr = s.Ping(ctx)\n\tif err == nil {\n\t\tt.Error(\"Ping() expected error for unreachable server\")\n\t}\n}\n\nfunc TestValkeyStore_GetSandboxBySessionID(t *testing.T) {\n\tm := setupTestValkey(t)\n\tdefer m.Close()\n\n\ts := createTestValkeyStore(t, m)\n\tdefer s.Close()\n\n\tctx := context.Background()\n\n\t// Test case: empty sessionID\n\t_, err := s.GetSandboxBySessionID(ctx, \"\")\n\tif err == nil {\n\t\tt.Error(\"GetSandboxBySessionID(\\\"\\\") expected error\")\n\t}\n\n\t// Test case: not found\n\t_, err = s.GetSandboxBySessionID(ctx, \"non-existent\")\n\tif !strings.Contains(err.Error(), \"not found\") && err != ErrNotFound {\n\t\tt.Errorf(\"GetSandboxBySessionID() expected ErrNotFound, got %v\", err)\n\t}\n\n\t// Store a sandbox first\n\tsandbox := createTestSandboxForValkey(\"test-session\", time.Now().Add(time.Hour))\n\tif err := s.StoreSandbox(ctx, sandbox); err != nil {\n\t\tt.Fatalf(\"StoreSandbox() error = %v\", err)\n\t}\n\n\t// Test case: found\n\tresult, err := s.GetSandboxBySessionID(ctx, \"test-session\")\n\tif err != nil {\n\t\tt.Fatalf(\"GetSandboxBySessionID() error = %v\", err)\n\t}\n\tif result.SessionID != sandbox.SessionID {\n\t\tt.Errorf(\"GetSandboxBySessionID() SessionID = %v, want %v\", result.SessionID, sandbox.SessionID)\n\t}\n}\n\nfunc TestValkeyStore_StoreSandbox(t *testing.T) {\n\tm := setupTestValkey(t)\n\tdefer m.Close()\n\n\ts := createTestValkeyStore(t, m)\n\tdefer s.Close()\n\n\tctx := context.Background()\n\n\t// Test case: nil sandbox\n\terr := s.StoreSandbox(ctx, nil)\n\tif err == nil {\n\t\tt.Error(\"StoreSandbox(nil) expected error\")\n\t}\n\n\t// Test case: empty sessionID\n\tsandbox := createTestSandboxForValkey(\"\", time.Now().Add(time.Hour))\n\terr = s.StoreSandbox(ctx, sandbox)\n\tif err == nil {\n\t\tt.Error(\"StoreSandbox() with empty sessionID expected error\")\n\t}\n\n\t// Test case: zero ExpiresAt\n\tsandbox = createTestSandboxForValkey(\"test-session\", time.Time{})\n\terr = s.StoreSandbox(ctx, sandbox)\n\tif err == nil {\n\t\tt.Error(\"StoreSandbox() with zero ExpiresAt expected error\")\n\t}\n\n\t// Test case: valid sandbox\n\tsandbox = createTestSandboxForValkey(\"test-session\", time.Now().Add(time.Hour))\n\tif err := s.StoreSandbox(ctx, sandbox); err != nil {\n\t\tt.Fatalf(\"StoreSandbox() error = %v\", err)\n\t}\n\n\t// Verify the sandbox was stored\n\tkey := s.sessionKey(\"test-session\")\n\tdata, err := m.Get(key)\n\tif err != nil {\n\t\tt.Fatalf(\"Failed to get stored data: %v\", err)\n\t}\n\n\tvar stored types.SandboxInfo\n\tif err := json.Unmarshal([]byte(data), &stored); err != nil {\n\t\tt.Fatalf(\"Failed to unmarshal stored data: %v\", err)\n\t}\n\tif stored.SessionID != sandbox.SessionID {\n\t\tt.Errorf(\"Stored SessionID = %v, want %v\", stored.SessionID, sandbox.SessionID)\n\t}\n\n\t// Verify indexes were created\n\texpiryScore, err := m.ZScore(s.expiryIndexKey, \"test-session\")\n\tif err != nil || expiryScore == 0 {\n\t\tt.Error(\"Expiry index not created\")\n\t}\n\n\tactivityScore, err := m.ZScore(s.lastActivityIndexKey, \"test-session\")\n\tif err != nil || activityScore == 0 {\n\t\tt.Error(\"Activity index not created\")\n\t}\n\n\t// Test case: duplicate session\n\terr = s.StoreSandbox(ctx, sandbox)\n\tif err == nil {\n\t\tt.Error(\"StoreSandbox() duplicate session expected error\")\n\t}\n}\n\nfunc TestValkeyStore_UpdateSandbox(t *testing.T) {\n\tm := setupTestValkey(t)\n\tdefer m.Close()\n\n\ts := createTestValkeyStore(t, m)\n\tdefer s.Close()\n\n\tctx := context.Background()\n\n\t// Test case: nil sandbox\n\terr := s.UpdateSandbox(ctx, nil)\n\tif err == nil {\n\t\tt.Error(\"UpdateSandbox(nil) expected error\")\n\t}\n\n\t// Test case: empty sessionID\n\tsandbox := createTestSandboxForValkey(\"\", time.Now().Add(time.Hour))\n\terr = s.UpdateSandbox(ctx, sandbox)\n\tif err == nil {\n\t\tt.Error(\"UpdateSandbox() with empty sessionID expected error\")\n\t}\n\n\t// Test case: non-existent sandbox\n\tsandbox = createTestSandboxForValkey(\"non-existent\", time.Now().Add(time.Hour))\n\terr = s.UpdateSandbox(ctx, sandbox)\n\tif err == nil {\n\t\tt.Error(\"UpdateSandbox() non-existent sandbox expected error\")\n\t}\n\n\t// Store a sandbox first\n\tsandbox = createTestSandboxForValkey(\"test-session\", time.Now().Add(time.Hour))\n\tif err := s.StoreSandbox(ctx, sandbox); err != nil {\n\t\tt.Fatalf(\"StoreSandbox() error = %v\", err)\n\t}\n\n\t// Update the sandbox\n\tsandbox.Status = \"Updated\"\n\tif err := s.UpdateSandbox(ctx, sandbox); err != nil {\n\t\tt.Fatalf(\"UpdateSandbox() error = %v\", err)\n\t}\n\n\t// Verify the update\n\tresult, err := s.GetSandboxBySessionID(ctx, \"test-session\")\n\tif err != nil {\n\t\tt.Fatalf(\"GetSandboxBySessionID() error = %v\", err)\n\t}\n\tif result.Status != \"Updated\" {\n\t\tt.Errorf(\"Status = %v, want Updated\", result.Status)\n\t}\n}\n\nfunc TestValkeyStore_DeleteSandboxBySessionID(t *testing.T) {\n\tm := setupTestValkey(t)\n\tdefer m.Close()\n\n\ts := createTestValkeyStore(t, m)\n\tdefer s.Close()\n\n\tctx := context.Background()\n\n\t// Test case: empty sessionID\n\terr := s.DeleteSandboxBySessionID(ctx, \"\")\n\tif err == nil {\n\t\tt.Error(\"DeleteSandboxBySessionID(\\\"\\\") expected error\")\n\t}\n\n\t// Store a sandbox first\n\tsandbox := createTestSandboxForValkey(\"test-session\", time.Now().Add(time.Hour))\n\tif err := s.StoreSandbox(ctx, sandbox); err != nil {\n\t\tt.Fatalf(\"StoreSandbox() error = %v\", err)\n\t}\n\n\t// Delete the sandbox\n\tif err := s.DeleteSandboxBySessionID(ctx, \"test-session\"); err != nil {\n\t\tt.Fatalf(\"DeleteSandboxBySessionID() error = %v\", err)\n\t}\n\n\t// Verify deletion\n\t_, err = s.GetSandboxBySessionID(ctx, \"test-session\")\n\tif err == nil {\n\t\tt.Error(\"GetSandboxBySessionID() after delete expected error\")\n\t}\n\n\t// Verify indexes were removed\n\t_, err = m.ZScore(s.expiryIndexKey, \"test-session\")\n\tif err == nil {\n\t\tt.Error(\"Expiry index not removed\")\n\t}\n\t_, err = m.ZScore(s.lastActivityIndexKey, \"test-session\")\n\tif err == nil {\n\t\tt.Error(\"Activity index not removed\")\n\t}\n\n\t// Test case: delete non-existent (idempotent)\n\terr = s.DeleteSandboxBySessionID(ctx, \"non-existent\")\n\tif err != nil {\n\t\tt.Errorf(\"DeleteSandboxBySessionID() non-existent expected no error, got %v\", err)\n\t}\n}\n\nfunc TestValkeyStore_ListExpiredSandboxes(t *testing.T) {\n\tm := setupTestValkey(t)\n\tdefer m.Close()\n\n\ts := createTestValkeyStore(t, m)\n\tdefer s.Close()\n\n\tctx := context.Background()\n\tnow := time.Now()\n\n\t// Test case: limit <= 0\n\tresult, err := s.ListExpiredSandboxes(ctx, now, 0)\n\tif err != nil {\n\t\tt.Fatalf(\"ListExpiredSandboxes() error = %v\", err)\n\t}\n\tif result != nil {\n\t\tt.Error(\"ListExpiredSandboxes() with limit=0 expected nil\")\n\t}\n\n\t// Store expired sandboxes\n\tsandbox1 := createTestSandboxForValkey(\"expired-1\", now.Add(-time.Hour))\n\tsandbox2 := createTestSandboxForValkey(\"expired-2\", now.Add(-30*time.Minute))\n\tsandbox3 := createTestSandboxForValkey(\"active-1\", now.Add(time.Hour))\n\n\tif err := s.StoreSandbox(ctx, sandbox1); err != nil {\n\t\tt.Fatalf(\"StoreSandbox() error = %v\", err)\n\t}\n\tif err := s.StoreSandbox(ctx, sandbox2); err != nil {\n\t\tt.Fatalf(\"StoreSandbox() error = %v\", err)\n\t}\n\tif err := s.StoreSandbox(ctx, sandbox3); err != nil {\n\t\tt.Fatalf(\"StoreSandbox() error = %v\", err)\n\t}\n\n\t// List expired sandboxes\n\texpired, err := s.ListExpiredSandboxes(ctx, now, 10)\n\tif err != nil {\n\t\tt.Fatalf(\"ListExpiredSandboxes() error = %v\", err)\n\t}\n\n\tif len(expired) != 2 {\n\t\tt.Errorf(\"ListExpiredSandboxes() returned %d sandboxes, want 2\", len(expired))\n\t}\n\n\t// Test with limit\n\texpiredLimited, err := s.ListExpiredSandboxes(ctx, now, 1)\n\tif err != nil {\n\t\tt.Fatalf(\"ListExpiredSandboxes() error = %v\", err)\n\t}\n\tif len(expiredLimited) != 1 {\n\t\tt.Errorf(\"ListExpiredSandboxes() with limit=1 returned %d sandboxes, want 1\", len(expiredLimited))\n\t}\n}\n\nfunc TestValkeyStore_ListInactiveSandboxes(t *testing.T) {\n\tm := setupTestValkey(t)\n\tdefer m.Close()\n\n\ts := createTestValkeyStore(t, m)\n\tdefer s.Close()\n\n\tctx := context.Background()\n\tnow := time.Now()\n\n\t// Test case: limit <= 0\n\tresult, err := s.ListInactiveSandboxes(ctx, now, 0)\n\tif err != nil {\n\t\tt.Fatalf(\"ListInactiveSandboxes() error = %v\", err)\n\t}\n\tif result != nil {\n\t\tt.Error(\"ListInactiveSandboxes() with limit=0 expected nil\")\n\t}\n\n\t// Store sandbox and update activity\n\tsandbox := createTestSandboxForValkey(\"test-session\", now.Add(time.Hour))\n\tif err := s.StoreSandbox(ctx, sandbox); err != nil {\n\t\tt.Fatalf(\"StoreSandbox() error = %v\", err)\n\t}\n\n\t// Manually set activity to past time by manipulating the sorted set\n\t// (since StoreSandbox sets activity to now)\n\tm.ZRem(s.lastActivityIndexKey, \"test-session\")\n\tm.ZAdd(s.lastActivityIndexKey, float64(now.Add(-time.Hour).Unix()), \"test-session\")\n\n\t// List inactive sandboxes\n\tinactive, err := s.ListInactiveSandboxes(ctx, now.Add(-30*time.Minute), 10)\n\tif err != nil {\n\t\tt.Fatalf(\"ListInactiveSandboxes() error = %v\", err)\n\t}\n\n\tif len(inactive) != 1 {\n\t\tt.Errorf(\"ListInactiveSandboxes() returned %d sandboxes, want 1\", len(inactive))\n\t}\n}\n\nfunc TestValkeyStore_UpdateSessionLastActivity(t *testing.T) {\n\tm := setupTestValkey(t)\n\tdefer m.Close()\n\n\ts := createTestValkeyStore(t, m)\n\tdefer s.Close()\n\n\tctx := context.Background()\n\tnow := time.Now()\n\n\t// Test case: empty sessionID\n\terr := s.UpdateSessionLastActivity(ctx, \"\", now)\n\tif err == nil {\n\t\tt.Error(\"UpdateSessionLastActivity(\\\"\\\") expected error\")\n\t}\n\n\t// Test case: non-existent session\n\terr = s.UpdateSessionLastActivity(ctx, \"non-existent\", now)\n\tif err == nil {\n\t\tt.Error(\"UpdateSessionLastActivity() non-existent expected error\")\n\t}\n\n\t// Store a sandbox first\n\tsandbox := createTestSandboxForValkey(\"test-session\", now.Add(time.Hour))\n\tif err := s.StoreSandbox(ctx, sandbox); err != nil {\n\t\tt.Fatalf(\"StoreSandbox() error = %v\", err)\n\t}\n\n\t// Get initial activity score\n\tinitialScore, err := m.ZScore(s.lastActivityIndexKey, \"test-session\")\n\tif err != nil {\n\t\tt.Fatalf(\"ZScore() error = %v\", err)\n\t}\n\n\t// Wait to ensure different Unix timestamp (ZAdd uses Unix() which is in seconds)\n\ttime.Sleep(1100 * time.Millisecond)\n\n\t// Update activity with zero time (should use Now)\n\tif err := s.UpdateSessionLastActivity(ctx, \"test-session\", time.Time{}); err != nil {\n\t\tt.Fatalf(\"UpdateSessionLastActivity() error = %v\", err)\n\t}\n\n\t// Verify activity was updated\n\tnewScore, err := m.ZScore(s.lastActivityIndexKey, \"test-session\")\n\tif err != nil {\n\t\tt.Fatalf(\"ZScore() error = %v\", err)\n\t}\n\tif newScore <= initialScore {\n\t\tt.Error(\"Activity timestamp was not updated\")\n\t}\n\n\t// Update activity with specific time\n\tfuture := now.Add(time.Hour)\n\tif err := s.UpdateSessionLastActivity(ctx, \"test-session\", future); err != nil {\n\t\tt.Fatalf(\"UpdateSessionLastActivity() error = %v\", err)\n\t}\n\n\t// Verify specific time was used\n\tscore, err := m.ZScore(s.lastActivityIndexKey, \"test-session\")\n\tif err != nil {\n\t\tt.Fatalf(\"ZScore() error = %v\", err)\n\t}\n\tif score != float64(future.Unix()) {\n\t\tt.Errorf(\"Activity timestamp = %v, want %v\", score, float64(future.Unix()))\n\t}\n}\n\nfunc TestValkeyStore_Close(t *testing.T) {\n\tm := setupTestValkey(t)\n\tdefer m.Close()\n\n\ts := createTestValkeyStore(t, m)\n\n\terr := s.Close()\n\tif err != nil {\n\t\tt.Errorf(\"Close() error = %v\", err)\n\t}\n}\n\nfunc TestValkeyStore_LoadSandboxesBySessionIDs(t *testing.T) {\n\tm := setupTestValkey(t)\n\tdefer m.Close()\n\n\ts := createTestValkeyStore(t, m)\n\tdefer s.Close()\n\n\tctx := context.Background()\n\n\t// Test case: empty sessionIDs\n\tresult, err := s.loadSandboxesBySessionIDs(ctx, []string{})\n\tif err != nil {\n\t\tt.Fatalf(\"loadSandboxesBySessionIDs() error = %v\", err)\n\t}\n\tif len(result) != 0 {\n\t\tt.Errorf(\"loadSandboxesBySessionIDs() returned %d sandboxes, want 0\", len(result))\n\t}\n\n\t// Store multiple sandboxes\n\tsandbox1 := createTestSandboxForValkey(\"session-1\", time.Now().Add(time.Hour))\n\tsandbox2 := createTestSandboxForValkey(\"session-2\", time.Now().Add(time.Hour))\n\n\tif err := s.StoreSandbox(ctx, sandbox1); err != nil {\n\t\tt.Fatalf(\"StoreSandbox() error = %v\", err)\n\t}\n\tif err := s.StoreSandbox(ctx, sandbox2); err != nil {\n\t\tt.Fatalf(\"StoreSandbox() error = %v\", err)\n\t}\n\n\t// Load by session IDs\n\tsessionIDs := []string{\"session-1\", \"session-2\", \"non-existent\"}\n\tsandboxes, err := s.loadSandboxesBySessionIDs(ctx, sessionIDs)\n\tif err != nil {\n\t\tt.Fatalf(\"loadSandboxesBySessionIDs() error = %v\", err)\n\t}\n\tif len(sandboxes) != 2 {\n\t\tt.Errorf(\"loadSandboxesBySessionIDs() returned %d sandboxes, want 2\", len(sandboxes))\n\t}\n}\n\nfunc TestValkeyStore_LoadSandboxesWithOrphanedIndex(t *testing.T) {\n\tm := setupTestValkey(t)\n\tdefer m.Close()\n\n\ts := createTestValkeyStore(t, m)\n\tdefer s.Close()\n\n\tctx := context.Background()\n\n\t// Store a sandbox\n\tsandbox := createTestSandboxForValkey(\"test-session\", time.Now().Add(time.Hour))\n\tif err := s.StoreSandbox(ctx, sandbox); err != nil {\n\t\tt.Fatalf(\"StoreSandbox() error = %v\", err)\n\t}\n\n\t// Delete the session data but keep the index (simulate orphaned index)\n\tm.Del(s.sessionKey(\"test-session\"))\n\n\t// List expired sandboxes should handle orphaned entries gracefully\n\texpired, err := s.ListExpiredSandboxes(ctx, time.Now().Add(time.Hour*2), 10)\n\tif err != nil {\n\t\tt.Fatalf(\"ListExpiredSandboxes() error = %v\", err)\n\t}\n\tif len(expired) != 0 {\n\t\tt.Errorf(\"ListExpiredSandboxes() returned %d sandboxes, want 0 (orphaned entries should be skipped)\", len(expired))\n\t}\n}\n\nfunc TestValkeyStore_SessionKey(t *testing.T) {\n\ts := &valkeyStore{\n\t\tsessionPrefix: \"session:\",\n\t}\n\n\tkey := s.sessionKey(\"test-id\")\n\tif key != \"session:test-id\" {\n\t\tt.Errorf(\"sessionKey() = %v, want session:test-id\", key)\n\t}\n}\n\nfunc TestMakeValkeyOptions(t *testing.T) {\n\t// Clean up environment after test\n\toriginalAddr := os.Getenv(\"VALKEY_ADDR\")\n\toriginalPassword := os.Getenv(\"VALKEY_PASSWORD\")\n\toriginalRequired := os.Getenv(\"VALKEY_PASSWORD_REQUIRED\")\n\toriginalDisableCache := os.Getenv(\"VALKEY_DISABLE_CACHE\")\n\toriginalForceSingle := os.Getenv(\"VALKEY_FORCE_SINGLE\")\n\tdefer func() {\n\t\tos.Setenv(\"VALKEY_ADDR\", originalAddr)\n\t\tos.Setenv(\"VALKEY_PASSWORD\", originalPassword)\n\t\tos.Setenv(\"VALKEY_PASSWORD_REQUIRED\", originalRequired)\n\t\tos.Setenv(\"VALKEY_DISABLE_CACHE\", originalDisableCache)\n\t\tos.Setenv(\"VALKEY_FORCE_SINGLE\", originalForceSingle)\n\t}()\n\n\t// Test case: missing VALKEY_ADDR\n\tos.Unsetenv(\"VALKEY_ADDR\")\n\tos.Setenv(\"VALKEY_PASSWORD\", \"secret\")\n\t_, err := makeValkeyOptions()\n\tif err == nil {\n\t\tt.Error(\"makeValkeyOptions() without VALKEY_ADDR expected error\")\n\t}\n\n\t// Test case: missing VALKEY_PASSWORD when required\n\tos.Setenv(\"VALKEY_ADDR\", \"localhost:6379\")\n\tos.Setenv(\"VALKEY_PASSWORD\", \"\")\n\tos.Unsetenv(\"VALKEY_PASSWORD_REQUIRED\")\n\t_, err = makeValkeyOptions()\n\tif err == nil {\n\t\tt.Error(\"makeValkeyOptions() without password when required expected error\")\n\t}\n\n\t// Test case: password not required\n\tos.Setenv(\"VALKEY_ADDR\", \"localhost:6379\")\n\tos.Setenv(\"VALKEY_PASSWORD\", \"\")\n\tos.Setenv(\"VALKEY_PASSWORD_REQUIRED\", \"false\")\n\tos.Unsetenv(\"VALKEY_DISABLE_CACHE\")\n\tos.Unsetenv(\"VALKEY_FORCE_SINGLE\")\n\topts, err := makeValkeyOptions()\n\tif err != nil {\n\t\tt.Fatalf(\"makeValkeyOptions() error = %v\", err)\n\t}\n\tif len(opts.InitAddress) != 1 || opts.InitAddress[0] != \"localhost:6379\" {\n\t\tt.Errorf(\"InitAddress = %v, want [localhost:6379]\", opts.InitAddress)\n\t}\n\tif opts.Password != \"\" {\n\t\tt.Errorf(\"Password = %v, want empty\", opts.Password)\n\t}\n\tif opts.DisableCache != false {\n\t\tt.Errorf(\"DisableCache = %v, want false\", opts.DisableCache)\n\t}\n\tif opts.ForceSingleClient != false {\n\t\tt.Errorf(\"ForceSingleClient = %v, want false\", opts.ForceSingleClient)\n\t}\n\n\t// Test case: password required and provided\n\tos.Setenv(\"VALKEY_ADDR\", \"valkey:6379\")\n\tos.Setenv(\"VALKEY_PASSWORD\", \"mysecret\")\n\tos.Setenv(\"VALKEY_PASSWORD_REQUIRED\", \"true\")\n\topts, err = makeValkeyOptions()\n\tif err != nil {\n\t\tt.Fatalf(\"makeValkeyOptions() error = %v\", err)\n\t}\n\tif len(opts.InitAddress) != 1 || opts.InitAddress[0] != \"valkey:6379\" {\n\t\tt.Errorf(\"InitAddress = %v, want [valkey:6379]\", opts.InitAddress)\n\t}\n\tif opts.Password != \"mysecret\" {\n\t\tt.Errorf(\"Password = %v, want mysecret\", opts.Password)\n\t}\n\n\t// Test case: multiple addresses\n\tos.Setenv(\"VALKEY_ADDR\", \"valkey-1:6379, valkey-2:6379, valkey-3:6379\")\n\tos.Setenv(\"VALKEY_PASSWORD\", \"secret\")\n\topts, err = makeValkeyOptions()\n\tif err != nil {\n\t\tt.Fatalf(\"makeValkeyOptions() error = %v\", err)\n\t}\n\tif len(opts.InitAddress) != 3 {\n\t\tt.Errorf(\"InitAddress length = %v, want 3\", len(opts.InitAddress))\n\t}\n\n\t// Test case: optional flags\n\tos.Setenv(\"VALKEY_ADDR\", \"localhost:6379\")\n\tos.Setenv(\"VALKEY_PASSWORD\", \"secret\")\n\tos.Setenv(\"VALKEY_DISABLE_CACHE\", \"true\")\n\tos.Setenv(\"VALKEY_FORCE_SINGLE\", \"true\")\n\topts, err = makeValkeyOptions()\n\tif err != nil {\n\t\tt.Fatalf(\"makeValkeyOptions() error = %v\", err)\n\t}\n\tif opts.DisableCache != true {\n\t\tt.Errorf(\"DisableCache = %v, want true\", opts.DisableCache)\n\t}\n\tif opts.ForceSingleClient != true {\n\t\tt.Errorf(\"ForceSingleClient = %v, want true\", opts.ForceSingleClient)\n\t}\n\n\t// Test case: whitespace trimming\n\tos.Setenv(\"VALKEY_ADDR\", \"  localhost:6379  \")\n\tos.Setenv(\"VALKEY_PASSWORD\", \"  secret  \")\n\tos.Unsetenv(\"VALKEY_DISABLE_CACHE\")\n\tos.Unsetenv(\"VALKEY_FORCE_SINGLE\")\n\topts, err = makeValkeyOptions()\n\tif err != nil {\n\t\tt.Fatalf(\"makeValkeyOptions() error = %v\", err)\n\t}\n\tif len(opts.InitAddress) != 1 || opts.InitAddress[0] != \"localhost:6379\" {\n\t\tt.Errorf(\"InitAddress = %v, want [localhost:6379] (trimmed)\", opts.InitAddress)\n\t}\n\tif opts.Password != \"  secret  \" {\n\t\tt.Errorf(\"Password = %v, want \\\"  secret  \\\" (not trimmed)\", opts.Password)\n\t}\n}\n\nfunc TestMakeValkeyOptions_InvalidBool(t *testing.T) {\n\t// Clean up environment after test\n\toriginalAddr := os.Getenv(\"VALKEY_ADDR\")\n\toriginalPassword := os.Getenv(\"VALKEY_PASSWORD\")\n\toriginalRequired := os.Getenv(\"VALKEY_PASSWORD_REQUIRED\")\n\toriginalDisableCache := os.Getenv(\"VALKEY_DISABLE_CACHE\")\n\toriginalForceSingle := os.Getenv(\"VALKEY_FORCE_SINGLE\")\n\tdefer func() {\n\t\tos.Setenv(\"VALKEY_ADDR\", originalAddr)\n\t\tos.Setenv(\"VALKEY_PASSWORD\", originalPassword)\n\t\tos.Setenv(\"VALKEY_PASSWORD_REQUIRED\", originalRequired)\n\t\tos.Setenv(\"VALKEY_DISABLE_CACHE\", originalDisableCache)\n\t\tos.Setenv(\"VALKEY_FORCE_SINGLE\", originalForceSingle)\n\t}()\n\n\tos.Setenv(\"VALKEY_ADDR\", \"localhost:6379\")\n\tos.Setenv(\"VALKEY_PASSWORD\", \"secret\")\n\tos.Setenv(\"VALKEY_PASSWORD_REQUIRED\", \"invalid\")\n\tos.Setenv(\"VALKEY_DISABLE_CACHE\", \"invalid\")\n\tos.Setenv(\"VALKEY_FORCE_SINGLE\", \"invalid\")\n\n\t// Should use defaults when parsing fails\n\topts, err := makeValkeyOptions()\n\tif err != nil {\n\t\tt.Errorf(\"makeValkeyOptions() with invalid bools should use defaults, got error: %v\", err)\n\t}\n\tif opts.DisableCache != false {\n\t\tt.Errorf(\"DisableCache = %v, want false (default)\", opts.DisableCache)\n\t}\n\tif opts.ForceSingleClient != false {\n\t\tt.Errorf(\"ForceSingleClient = %v, want false (default)\", opts.ForceSingleClient)\n\t}\n}\n\nfunc TestNewValkeyStore(t *testing.T) {\n\tm := setupTestValkey(t)\n\tdefer m.Close()\n\n\t// Clean up environment after test\n\toriginalAddr := os.Getenv(\"VALKEY_ADDR\")\n\toriginalPassword := os.Getenv(\"VALKEY_PASSWORD\")\n\toriginalRequired := os.Getenv(\"VALKEY_PASSWORD_REQUIRED\")\n\tdefer func() {\n\t\tos.Setenv(\"VALKEY_ADDR\", originalAddr)\n\t\tos.Setenv(\"VALKEY_PASSWORD\", originalPassword)\n\t\tos.Setenv(\"VALKEY_PASSWORD_REQUIRED\", originalRequired)\n\t}()\n\n\tos.Setenv(\"VALKEY_ADDR\", m.Addr())\n\tos.Setenv(\"VALKEY_PASSWORD\", \"\")\n\tos.Setenv(\"VALKEY_PASSWORD_REQUIRED\", \"false\")\n\n\tstore, err := newValkeyStore()\n\tif err != nil {\n\t\tt.Fatalf(\"newValkeyStore() error = %v\", err)\n\t}\n\tif store == nil {\n\t\tt.Fatal(\"newValkeyStore() returned nil\")\n\t}\n\tdefer store.Close()\n\n\t// Test that it implements Store interface\n\tvar _ Store = store\n}\n\nfunc TestNewValkeyStore_MissingAddr(t *testing.T) {\n\t// Clean up environment\n\toriginalAddr := os.Getenv(\"VALKEY_ADDR\")\n\tdefer func() {\n\t\tos.Setenv(\"VALKEY_ADDR\", originalAddr)\n\t}()\n\n\tos.Unsetenv(\"VALKEY_ADDR\")\n\n\t_, err := newValkeyStore()\n\tif err == nil {\n\t\tt.Error(\"newValkeyStore() without VALKEY_ADDR expected error\")\n\t}\n}\n\nfunc TestNewValkeyStore_InvalidAddress(t *testing.T) {\n\t// Clean up environment\n\toriginalAddr := os.Getenv(\"VALKEY_ADDR\")\n\toriginalPassword := os.Getenv(\"VALKEY_PASSWORD\")\n\toriginalRequired := os.Getenv(\"VALKEY_PASSWORD_REQUIRED\")\n\tdefer func() {\n\t\tos.Setenv(\"VALKEY_ADDR\", originalAddr)\n\t\tos.Setenv(\"VALKEY_PASSWORD\", originalPassword)\n\t\tos.Setenv(\"VALKEY_PASSWORD_REQUIRED\", originalRequired)\n\t}()\n\n\t// Use an invalid address format that will fail client creation\n\tos.Setenv(\"VALKEY_ADDR\", \"invalid-address-format\")\n\tos.Setenv(\"VALKEY_PASSWORD\", \"\")\n\tos.Setenv(\"VALKEY_PASSWORD_REQUIRED\", \"false\")\n\n\t// This may or may not fail depending on how valkey-go handles invalid addresses\n\t// The client might be created successfully but fail on actual operations\n\t_, err := newValkeyStore()\n\t// We don't assert on error here because valkey-go may allow client creation\n\t// with invalid addresses and only fail on actual operations\n\tif err == nil {\n\t\tt.Log(\"newValkeyStore() with invalid address did not error (client may be lazy)\")\n\t}\n}\n\nfunc TestValkeyStore_Ping_WrongResponse(t *testing.T) {\n\tm := setupTestValkey(t)\n\tdefer m.Close()\n\n\ts := createTestValkeyStore(t, m)\n\tdefer s.Close()\n\n\tctx := context.Background()\n\n\t// Normal ping should succeed\n\terr := s.Ping(ctx)\n\tif err != nil {\n\t\tt.Fatalf(\"Ping() error = %v\", err)\n\t}\n}\n\nfunc TestValkeyStore_StoreSandbox_MarshalError(t *testing.T) {\n\tm := setupTestValkey(t)\n\tdefer m.Close()\n\n\ts := createTestValkeyStore(t, m)\n\tdefer s.Close()\n\n\tctx := context.Background()\n\n\t// Create a sandbox that can be marshaled normally\n\tsandbox := createTestSandboxForValkey(\"test-session\", time.Now().Add(time.Hour))\n\n\t// This should succeed with valid sandbox\n\terr := s.StoreSandbox(ctx, sandbox)\n\tif err != nil {\n\t\tt.Fatalf(\"StoreSandbox() error = %v\", err)\n\t}\n}\n\nfunc TestValkeyStore_UpdateSandbox_MarshalError(t *testing.T) {\n\tm := setupTestValkey(t)\n\tdefer m.Close()\n\n\ts := createTestValkeyStore(t, m)\n\tdefer s.Close()\n\n\tctx := context.Background()\n\n\t// First store a valid sandbox\n\tsandbox := createTestSandboxForValkey(\"test-session\", time.Now().Add(time.Hour))\n\tif err := s.StoreSandbox(ctx, sandbox); err != nil {\n\t\tt.Fatalf(\"StoreSandbox() error = %v\", err)\n\t}\n\n\t// Now update with a normal sandbox - should work\n\tsandbox.Status = \"Updated\"\n\terr := s.UpdateSandbox(ctx, sandbox)\n\tif err != nil {\n\t\tt.Fatalf(\"UpdateSandbox() error = %v\", err)\n\t}\n}\n\nfunc TestValkeyStore_GetSandboxBySessionID_UnmarshalError(t *testing.T) {\n\tm := setupTestValkey(t)\n\tdefer m.Close()\n\n\ts := createTestValkeyStore(t, m)\n\tdefer s.Close()\n\n\tctx := context.Background()\n\n\t// Store invalid JSON data directly\n\tkey := s.sessionKey(\"bad-session\")\n\tm.Set(key, \"not-valid-json\")\n\n\t// Try to get the sandbox - should fail to unmarshal\n\t_, err := s.GetSandboxBySessionID(ctx, \"bad-session\")\n\tif err == nil {\n\t\tt.Error(\"GetSandboxBySessionID() with invalid JSON expected error\")\n\t}\n}\n\nfunc TestValkeyStore_ListExpiredSandboxes_EdgeCases(t *testing.T) {\n\tm := setupTestValkey(t)\n\tdefer m.Close()\n\n\ts := createTestValkeyStore(t, m)\n\tdefer s.Close()\n\n\tctx := context.Background()\n\tnow := time.Now()\n\n\t// Store sandbox with exact boundary time\n\tsandbox := createTestSandboxForValkey(\"boundary-session\", now)\n\tif err := s.StoreSandbox(ctx, sandbox); err != nil {\n\t\tt.Fatalf(\"StoreSandbox() error = %v\", err)\n\t}\n\n\t// List with before = now should include this session (ExpiresAt <= before)\n\texpired, err := s.ListExpiredSandboxes(ctx, now, 10)\n\tif err != nil {\n\t\tt.Fatalf(\"ListExpiredSandboxes() error = %v\", err)\n\t}\n\tif len(expired) != 1 {\n\t\tt.Errorf(\"ListExpiredSandboxes() returned %d sandboxes, want 1\", len(expired))\n\t}\n}\n\nfunc TestValkeyStore_ConcurrentOperations(t *testing.T) {\n\tm := setupTestValkey(t)\n\tdefer m.Close()\n\n\ts := createTestValkeyStore(t, m)\n\tdefer s.Close()\n\n\tctx := context.Background()\n\tnow := time.Now()\n\n\t// Store multiple sandboxes concurrently\n\tdone := make(chan bool, 5)\n\tfor i := 0; i < 5; i++ {\n\t\tgo func(idx int) {\n\t\t\tsessionID := fmt.Sprintf(\"concurrent-%d\", idx)\n\t\t\tsandbox := createTestSandboxForValkey(sessionID, now.Add(time.Hour))\n\t\t\terr := s.StoreSandbox(ctx, sandbox)\n\t\t\tif err != nil {\n\t\t\t\tt.Errorf(\"Concurrent StoreSandbox() error = %v\", err)\n\t\t\t}\n\t\t\tdone <- true\n\t\t}(i)\n\t}\n\n\t// Wait for all goroutines\n\tfor i := 0; i < 5; i++ {\n\t\t<-done\n\t}\n\n\t// Verify all sandboxes were stored\n\tfor i := 0; i < 5; i++ {\n\t\tsessionID := fmt.Sprintf(\"concurrent-%d\", i)\n\t\t_, err := s.GetSandboxBySessionID(ctx, sessionID)\n\t\tif err != nil {\n\t\t\tt.Errorf(\"GetSandboxBySessionID(%s) error = %v\", sessionID, err)\n\t\t}\n\t}\n}\n","after":"/*\nCopyright 2026 The Volcano Authors.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\npackage store\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"os\"\n\t\"strings\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/alicebob/miniredis/v2\"\n\t\"github.com/valkey-io/valkey-go\"\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n)\n\n// setupTestValkey creates a new miniredis instance for testing.\n// Since Valkey is Redis-compatible, we can use miniredis for testing.\nfunc setupTestValkey(t *testing.T) *miniredis.Miniredis {\n\treturn miniredis.RunT(t)\n}\n\n// createTestValkeyStore creates a valkeyStore instance connected to the test server.\nfunc createTestValkeyStore(t *testing.T, m *miniredis.Miniredis) *valkeyStore {\n\tclient, err := valkey.NewClient(valkey.ClientOption{\n\t\tInitAddress:       []string{m.Addr()},\n\t\tDisableCache:      true,\n\t\tForceSingleClient: true,\n\t})\n\tif err != nil {\n\t\tt.Fatalf(\"Failed to create valkey client: %v\", err)\n\t}\n\treturn &valkeyStore{\n\t\tcli:                  client,\n\t\tsessionPrefix:        sessionPrefix,\n\t\texpiryIndexKey:       expiryIndexKey,\n\t\tlastActivityIndexKey: lastActivityIndexKey,\n\t}\n}\n\n// createTestSandboxForValkey creates a test sandbox with the given sessionID.\nfunc createTestSandboxForValkey(sessionID string, expiresAt time.Time) *types.SandboxInfo {\n\treturn &types.SandboxInfo{\n\t\tKind:             \"AgentRuntime\",\n\t\tSandboxID:        fmt.Sprintf(\"sb-%s\", sessionID),\n\t\tSandboxNamespace: \"default\",\n\t\tName:             fmt.Sprintf(\"runtime-%s\", sessionID),\n\t\tEntryPoints: []types.SandboxEntryPoint{\n\t\t\t{\n\t\t\t\tPath:     \"/api\",\n\t\t\t\tProtocol: \"http\",\n\t\t\t\tEndpoint: \"localhost:8080\",\n\t\t\t},\n\t\t},\n\t\tSessionID: sessionID,\n\t\tCreatedAt: time.Now().UTC(),\n\t\tExpiresAt: expiresAt,\n\t\tStatus:    \"Running\",\n\t\tPodIP:     \"10.0.0.1\",\n\t\tPodName:   fmt.Sprintf(\"pod-%s\", sessionID),\n\t}\n}\n\nfunc TestValkeyStore_Ping(t *testing.T) {\n\tm := setupTestValkey(t)\n\tdefer m.Close()\n\n\ts := createTestValkeyStore(t, m)\n\tdefer s.Close()\n\n\tctx := context.Background()\n\terr := s.Ping(ctx)\n\tif err != nil {\n\t\tt.Fatalf(\"Ping() error = %v\", err)\n\t}\n}\n\nfunc TestValkeyStore_Ping_Failure(t *testing.T) {\n\t// Create a client to a non-existent server\n\tclient, err := valkey.NewClient(valkey.ClientOption{\n\t\tInitAddress:       []string{\"127.0.0.1:63791\"},\n\t\tDisableCache:      true,\n\t\tForceSingleClient: true,\n\t})\n\tif err != nil {\n\t\t// Client creation might fail for some invalid addresses\n\t\tt.Skipf(\"valkey client creation failed (may not be supported for unreachable addresses): %v\", err)\n\t}\n\n\ts := &valkeyStore{\n\t\tcli:                  client,\n\t\tsessionPrefix:        sessionPrefix,\n\t\texpiryIndexKey:       expiryIndexKey,\n\t\tlastActivityIndexKey: lastActivityIndexKey,\n\t}\n\tdefer s.Close()\n\n\tctx, cancel := context.WithTimeout(context.Background(), 100*time.Millisecond)\n\tdefer cancel()\n\n\terr = s.Ping(ctx)\n\tif err == nil {\n\t\tt.Error(\"Ping() expected error for unreachable server\")\n\t}\n}\n\nfunc TestValkeyStore_GetSandboxBySessionID(t *testing.T) {\n\tm := setupTestValkey(t)\n\tdefer m.Close()\n\n\ts := createTestValkeyStore(t, m)\n\tdefer s.Close()\n\n\tctx := context.Background()\n\n\t// Test case: empty sessionID\n\t_, err := s.GetSandboxBySessionID(ctx, \"\")\n\tif err == nil {\n\t\tt.Error(\"GetSandboxBySessionID(\\\"\\\") expected error\")\n\t}\n\n\t// Test case: not found\n\t_, err = s.GetSandboxBySessionID(ctx, \"non-existent\")\n\tif !strings.Contains(err.Error(), \"not found\") && err != ErrNotFound {\n\t\tt.Errorf(\"GetSandboxBySessionID() expected ErrNotFound, got %v\", err)\n\t}\n\n\t// Store a sandbox first\n\tsandbox := createTestSandboxForValkey(\"test-session\", time.Now().Add(time.Hour))\n\tif err := s.StoreSandbox(ctx, sandbox); err != nil {\n\t\tt.Fatalf(\"StoreSandbox() error = %v\", err)\n\t}\n\n\t// Test case: found\n\tresult, err := s.GetSandboxBySessionID(ctx, \"test-session\")\n\tif err != nil {\n\t\tt.Fatalf(\"GetSandboxBySessionID() error = %v\", err)\n\t}\n\tif result.SessionID != sandbox.SessionID {\n\t\tt.Errorf(\"GetSandboxBySessionID() SessionID = %v, want %v\", result.SessionID, sandbox.SessionID)\n\t}\n}\n\nfunc TestValkeyStore_StoreSandbox(t *testing.T) {\n\tm := setupTestValkey(t)\n\tdefer m.Close()\n\n\ts := createTestValkeyStore(t, m)\n\tdefer s.Close()\n\n\tctx := context.Background()\n\n\t// Test case: nil sandbox\n\terr := s.StoreSandbox(ctx, nil)\n\tif err == nil {\n\t\tt.Error(\"StoreSandbox(nil) expected error\")\n\t}\n\n\t// Test case: empty sessionID\n\tsandbox := createTestSandboxForValkey(\"\", time.Now().Add(time.Hour))\n\terr = s.StoreSandbox(ctx, sandbox)\n\tif err == nil {\n\t\tt.Error(\"StoreSandbox() with empty sessionID expected error\")\n\t}\n\n\t// Test case: zero ExpiresAt\n\tsandbox = createTestSandboxForValkey(\"test-session\", time.Time{})\n\terr = s.StoreSandbox(ctx, sandbox)\n\tif err == nil {\n\t\tt.Error(\"StoreSandbox() with zero ExpiresAt expected error\")\n\t}\n\n\t// Test case: valid sandbox\n\tsandbox = createTestSandboxForValkey(\"test-session\", time.Now().Add(time.Hour))\n\tif err := s.StoreSandbox(ctx, sandbox); err != nil {\n\t\tt.Fatalf(\"StoreSandbox() error = %v\", err)\n\t}\n\n\t// Verify the sandbox was stored\n\tkey := s.sessionKey(\"test-session\")\n\tdata, err := m.Get(key)\n\tif err != nil {\n\t\tt.Fatalf(\"Failed to get stored data: %v\", err)\n\t}\n\n\tvar stored types.SandboxInfo\n\tif err := json.Unmarshal([]byte(data), &stored); err != nil {\n\t\tt.Fatalf(\"Failed to unmarshal stored data: %v\", err)\n\t}\n\tif stored.SessionID != sandbox.SessionID {\n\t\tt.Errorf(\"Stored SessionID = %v, want %v\", stored.SessionID, sandbox.SessionID)\n\t}\n\n\t// Verify indexes were created\n\texpiryScore, err := m.ZScore(s.expiryIndexKey, \"test-session\")\n\tif err != nil || expiryScore == 0 {\n\t\tt.Error(\"Expiry index not created\")\n\t}\n\n\tactivityScore, err := m.ZScore(s.lastActivityIndexKey, \"test-session\")\n\tif err != nil || activityScore == 0 {\n\t\tt.Error(\"Activity index not created\")\n\t}\n\n\t// Test case: duplicate session\n\terr = s.StoreSandbox(ctx, sandbox)\n\tif err == nil {\n\t\tt.Error(\"StoreSandbox() duplicate session expected error\")\n\t}\n}\n\nfunc TestValkeyStore_UpdateSandbox(t *testing.T) {\n\tm := setupTestValkey(t)\n\tdefer m.Close()\n\n\ts := createTestValkeyStore(t, m)\n\tdefer s.Close()\n\n\tctx := context.Background()\n\n\t// Test case: nil sandbox\n\terr := s.UpdateSandbox(ctx, nil)\n\tif err == nil {\n\t\tt.Error(\"UpdateSandbox(nil) expected error\")\n\t}\n\n\t// Test case: empty sessionID\n\tsandbox := createTestSandboxForValkey(\"\", time.Now().Add(time.Hour))\n\terr = s.UpdateSandbox(ctx, sandbox)\n\tif err == nil {\n\t\tt.Error(\"UpdateSandbox() with empty sessionID expected error\")\n\t}\n\n\t// Test case: non-existent sandbox\n\tsandbox = createTestSandboxForValkey(\"non-existent\", time.Now().Add(time.Hour))\n\terr = s.UpdateSandbox(ctx, sandbox)\n\tif err == nil {\n\t\tt.Error(\"UpdateSandbox() non-existent sandbox expected error\")\n\t}\n\n\t// Store a sandbox first\n\tsandbox = createTestSandboxForValkey(\"test-session\", time.Now().Add(time.Hour))\n\tif err := s.StoreSandbox(ctx, sandbox); err != nil {\n\t\tt.Fatalf(\"StoreSandbox() error = %v\", err)\n\t}\n\n\t// Update the sandbox\n\tsandbox.Status = \"Updated\"\n\tif err := s.UpdateSandbox(ctx, sandbox); err != nil {\n\t\tt.Fatalf(\"UpdateSandbox() error = %v\", err)\n\t}\n\n\t// Verify the update\n\tresult, err := s.GetSandboxBySessionID(ctx, \"test-session\")\n\tif err != nil {\n\t\tt.Fatalf(\"GetSandboxBySessionID() error = %v\", err)\n\t}\n\tif result.Status != \"Updated\" {\n\t\tt.Errorf(\"Status = %v, want Updated\", result.Status)\n\t}\n}\n\nfunc TestValkeyStore_DeleteSandboxBySessionID(t *testing.T) {\n\tm := setupTestValkey(t)\n\tdefer m.Close()\n\n\ts := createTestValkeyStore(t, m)\n\tdefer s.Close()\n\n\tctx := context.Background()\n\n\t// Test case: empty sessionID\n\terr := s.DeleteSandboxBySessionID(ctx, \"\")\n\tif err == nil {\n\t\tt.Error(\"DeleteSandboxBySessionID(\\\"\\\") expected error\")\n\t}\n\n\t// Store a sandbox first\n\tsandbox := createTestSandboxForValkey(\"test-session\", time.Now().Add(time.Hour))\n\tif err := s.StoreSandbox(ctx, sandbox); err != nil {\n\t\tt.Fatalf(\"StoreSandbox() error = %v\", err)\n\t}\n\n\t// Delete the sandbox\n\tif err := s.DeleteSandboxBySessionID(ctx, \"test-session\"); err != nil {\n\t\tt.Fatalf(\"DeleteSandboxBySessionID() error = %v\", err)\n\t}\n\n\t// Verify deletion\n\t_, err = s.GetSandboxBySessionID(ctx, \"test-session\")\n\tif err == nil {\n\t\tt.Error(\"GetSandboxBySessionID() after delete expected error\")\n\t}\n\n\t// Verify indexes were removed\n\t_, err = m.ZScore(s.expiryIndexKey, \"test-session\")\n\tif err == nil {\n\t\tt.Error(\"Expiry index not removed\")\n\t}\n\t_, err = m.ZScore(s.lastActivityIndexKey, \"test-session\")\n\tif err == nil {\n\t\tt.Error(\"Activity index not removed\")\n\t}\n\n\t// Test case: delete non-existent (idempotent)\n\terr = s.DeleteSandboxBySessionID(ctx, \"non-existent\")\n\tif err != nil {\n\t\tt.Errorf(\"DeleteSandboxBySessionID() non-existent expected no error, got %v\", err)\n\t}\n}\n\nfunc TestValkeyStore_ListExpiredSandboxes(t *testing.T) {\n\tm := setupTestValkey(t)\n\tdefer m.Close()\n\n\ts := createTestValkeyStore(t, m)\n\tdefer s.Close()\n\n\tctx := context.Background()\n\tnow := time.Now()\n\n\t// Test case: limit <= 0\n\tresult, err := s.ListExpiredSandboxes(ctx, now, 0)\n\tif err != nil {\n\t\tt.Fatalf(\"ListExpiredSandboxes() error = %v\", err)\n\t}\n\tif result != nil {\n\t\tt.Error(\"ListExpiredSandboxes() with limit=0 expected nil\")\n\t}\n\n\t// Store expired sandboxes\n\tsandbox1 := createTestSandboxForValkey(\"expired-1\", now.Add(-time.Hour))\n\tsandbox2 := createTestSandboxForValkey(\"expired-2\", now.Add(-30*time.Minute))\n\tsandbox3 := createTestSandboxForValkey(\"active-1\", now.Add(time.Hour))\n\n\tif err := s.StoreSandbox(ctx, sandbox1); err != nil {\n\t\tt.Fatalf(\"StoreSandbox() error = %v\", err)\n\t}\n\tif err := s.StoreSandbox(ctx, sandbox2); err != nil {\n\t\tt.Fatalf(\"StoreSandbox() error = %v\", err)\n\t}\n\tif err := s.StoreSandbox(ctx, sandbox3); err != nil {\n\t\tt.Fatalf(\"StoreSandbox() error = %v\", err)\n\t}\n\n\t// List expired sandboxes\n\texpired, err := s.ListExpiredSandboxes(ctx, now, 10)\n\tif err != nil {\n\t\tt.Fatalf(\"ListExpiredSandboxes() error = %v\", err)\n\t}\n\n\tif len(expired) != 2 {\n\t\tt.Errorf(\"ListExpiredSandboxes() returned %d sandboxes, want 2\", len(expired))\n\t}\n\n\t// Test with limit\n\texpiredLimited, err := s.ListExpiredSandboxes(ctx, now, 1)\n\tif err != nil {\n\t\tt.Fatalf(\"ListExpiredSandboxes() error = %v\", err)\n\t}\n\tif len(expiredLimited) != 1 {\n\t\tt.Errorf(\"ListExpiredSandboxes() with limit=1 returned %d sandboxes, want 1\", len(expiredLimited))\n\t}\n}\n\nfunc TestValkeyStore_ListInactiveSandboxes(t *testing.T) {\n\tm := setupTestValkey(t)\n\tdefer m.Close()\n\n\ts := createTestValkeyStore(t, m)\n\tdefer s.Close()\n\n\tctx := context.Background()\n\tnow := time.Now()\n\n\t// Test case: limit <= 0\n\tresult, err := s.ListInactiveSandboxes(ctx, now, 0)\n\tif err != nil {\n\t\tt.Fatalf(\"ListInactiveSandboxes() error = %v\", err)\n\t}\n\tif result != nil {\n\t\tt.Error(\"ListInactiveSandboxes() with limit=0 expected nil\")\n\t}\n\n\t// Store sandbox and update activity\n\tsandbox := createTestSandboxForValkey(\"test-session\", now.Add(time.Hour))\n\tif err := s.StoreSandbox(ctx, sandbox); err != nil {\n\t\tt.Fatalf(\"StoreSandbox() error = %v\", err)\n\t}\n\n\t// Manually set activity to past time by manipulating the sorted set\n\t// (since StoreSandbox sets activity to now)\n\tm.ZRem(s.lastActivityIndexKey, \"test-session\")\n\tm.ZAdd(s.lastActivityIndexKey, float64(now.Add(-time.Hour).Unix()), \"test-session\")\n\n\t// List inactive sandboxes\n\tinactive, err := s.ListInactiveSandboxes(ctx, now.Add(-30*time.Minute), 10)\n\tif err != nil {\n\t\tt.Fatalf(\"ListInactiveSandboxes() error = %v\", err)\n\t}\n\n\tif len(inactive) != 1 {\n\t\tt.Errorf(\"ListInactiveSandboxes() returned %d sandboxes, want 1\", len(inactive))\n\t}\n}\n\nfunc TestValkeyStore_UpdateSessionLastActivity(t *testing.T) {\n\tm := setupTestValkey(t)\n\tdefer m.Close()\n\n\ts := createTestValkeyStore(t, m)\n\tdefer s.Close()\n\n\tctx := context.Background()\n\tnow := time.Now()\n\n\t// Test case: empty sessionID\n\terr := s.UpdateSessionLastActivity(ctx, \"\", now)\n\tif err == nil {\n\t\tt.Error(\"UpdateSessionLastActivity(\\\"\\\") expected error\")\n\t}\n\n\t// Test case: non-existent session\n\terr = s.UpdateSessionLastActivity(ctx, \"non-existent\", now)\n\tif err == nil {\n\t\tt.Error(\"UpdateSessionLastActivity() non-existent expected error\")\n\t}\n\n\t// Store a sandbox first\n\tsandbox := createTestSandboxForValkey(\"test-session\", now.Add(time.Hour))\n\tif err := s.StoreSandbox(ctx, sandbox); err != nil {\n\t\tt.Fatalf(\"StoreSandbox() error = %v\", err)\n\t}\n\n\t// Get initial activity score\n\tinitialScore, err := m.ZScore(s.lastActivityIndexKey, \"test-session\")\n\tif err != nil {\n\t\tt.Fatalf(\"ZScore() error = %v\", err)\n\t}\n\n\t// Wait to ensure different Unix timestamp (ZAdd uses Unix() which is in seconds)\n\ttime.Sleep(1100 * time.Millisecond)\n\n\t// Update activity with zero time (should use Now)\n\tif err := s.UpdateSessionLastActivity(ctx, \"test-session\", time.Time{}); err != nil {\n\t\tt.Fatalf(\"UpdateSessionLastActivity() error = %v\", err)\n\t}\n\n\t// Verify activity was updated\n\tnewScore, err := m.ZScore(s.lastActivityIndexKey, \"test-session\")\n\tif err != nil {\n\t\tt.Fatalf(\"ZScore() error = %v\", err)\n\t}\n\tif newScore <= initialScore {\n\t\tt.Error(\"Activity timestamp was not updated\")\n\t}\n\n\t// Update activity with specific time\n\tfuture := now.Add(time.Hour)\n\tif err := s.UpdateSessionLastActivity(ctx, \"test-session\", future); err != nil {\n\t\tt.Fatalf(\"UpdateSessionLastActivity() error = %v\", err)\n\t}\n\n\t// Verify specific time was used\n\tscore, err := m.ZScore(s.lastActivityIndexKey, \"test-session\")\n\tif err != nil {\n\t\tt.Fatalf(\"ZScore() error = %v\", err)\n\t}\n\tif score != float64(future.Unix()) {\n\t\tt.Errorf(\"Activity timestamp = %v, want %v\", score, float64(future.Unix()))\n\t}\n}\n\nfunc TestValkeyStore_Close(t *testing.T) {\n\tm := setupTestValkey(t)\n\tdefer m.Close()\n\n\ts := createTestValkeyStore(t, m)\n\n\terr := s.Close()\n\tif err != nil {\n\t\tt.Errorf(\"Close() error = %v\", err)\n\t}\n}\n\nfunc TestValkeyStore_LoadSandboxesBySessionIDs(t *testing.T) {\n\tm := setupTestValkey(t)\n\tdefer m.Close()\n\n\ts := createTestValkeyStore(t, m)\n\tdefer s.Close()\n\n\tctx := context.Background()\n\n\t// Test case: empty sessionIDs\n\tresult, err := s.loadSandboxesBySessionIDs(ctx, []string{})\n\tif err != nil {\n\t\tt.Fatalf(\"loadSandboxesBySessionIDs() error = %v\", err)\n\t}\n\tif len(result) != 0 {\n\t\tt.Errorf(\"loadSandboxesBySessionIDs() returned %d sandboxes, want 0\", len(result))\n\t}\n\n\t// Store multiple sandboxes\n\tsandbox1 := createTestSandboxForValkey(\"session-1\", time.Now().Add(time.Hour))\n\tsandbox2 := createTestSandboxForValkey(\"session-2\", time.Now().Add(time.Hour))\n\n\tif err := s.StoreSandbox(ctx, sandbox1); err != nil {\n\t\tt.Fatalf(\"StoreSandbox() error = %v\", err)\n\t}\n\tif err := s.StoreSandbox(ctx, sandbox2); err != nil {\n\t\tt.Fatalf(\"StoreSandbox() error = %v\", err)\n\t}\n\n\t// Load by session IDs\n\tsessionIDs := []string{\"session-1\", \"session-2\", \"non-existent\"}\n\tsandboxes, err := s.loadSandboxesBySessionIDs(ctx, sessionIDs)\n\tif err != nil {\n\t\tt.Fatalf(\"loadSandboxesBySessionIDs() error = %v\", err)\n\t}\n\tif len(sandboxes) != 2 {\n\t\tt.Errorf(\"loadSandboxesBySessionIDs() returned %d sandboxes, want 2\", len(sandboxes))\n\t}\n}\n\nfunc TestValkeyStore_LoadSandboxesWithOrphanedIndex(t *testing.T) {\n\tm := setupTestValkey(t)\n\tdefer m.Close()\n\n\ts := createTestValkeyStore(t, m)\n\tdefer s.Close()\n\n\tctx := context.Background()\n\n\t// Store a sandbox\n\tsandbox := createTestSandboxForValkey(\"test-session\", time.Now().Add(time.Hour))\n\tif err := s.StoreSandbox(ctx, sandbox); err != nil {\n\t\tt.Fatalf(\"StoreSandbox() error = %v\", err)\n\t}\n\n\t// Delete the session data but keep the index (simulate orphaned index)\n\tm.Del(s.sessionKey(\"test-session\"))\n\n\t// List expired sandboxes should handle orphaned entries gracefully\n\texpired, err := s.ListExpiredSandboxes(ctx, time.Now().Add(time.Hour*2), 10)\n\tif err != nil {\n\t\tt.Fatalf(\"ListExpiredSandboxes() error = %v\", err)\n\t}\n\tif len(expired) != 0 {\n\t\tt.Errorf(\"ListExpiredSandboxes() returned %d sandboxes, want 0 (orphaned entries should be skipped)\", len(expired))\n\t}\n}\n\nfunc TestValkeyStore_SessionKey(t *testing.T) {\n\ts := &valkeyStore{\n\t\tsessionPrefix: \"session:\",\n\t}\n\n\tkey := s.sessionKey(\"test-id\")\n\tif key != \"session:test-id\" {\n\t\tt.Errorf(\"sessionKey() = %v, want session:test-id\", key)\n\t}\n}\n\nfunc TestMakeValkeyOptions(t *testing.T) {\n\t// Clean up environment after test\n\toriginalAddr := os.Getenv(\"VALKEY_ADDR\")\n\toriginalPassword := os.Getenv(\"VALKEY_PASSWORD\")\n\toriginalRequired := os.Getenv(\"VALKEY_PASSWORD_REQUIRED\")\n\toriginalDisableCache := os.Getenv(\"VALKEY_DISABLE_CACHE\")\n\toriginalForceSingle := os.Getenv(\"VALKEY_FORCE_SINGLE\")\n\tdefer func() {\n\t\tos.Setenv(\"VALKEY_ADDR\", originalAddr)\n\t\tos.Setenv(\"VALKEY_PASSWORD\", originalPassword)\n\t\tos.Setenv(\"VALKEY_PASSWORD_REQUIRED\", originalRequired)\n\t\tos.Setenv(\"VALKEY_DISABLE_CACHE\", originalDisableCache)\n\t\tos.Setenv(\"VALKEY_FORCE_SINGLE\", originalForceSingle)\n\t}()\n\n\t// Test case: missing VALKEY_ADDR\n\tos.Unsetenv(\"VALKEY_ADDR\")\n\tos.Setenv(\"VALKEY_PASSWORD\", \"secret\")\n\t_, err := makeValkeyOptions()\n\tif err == nil {\n\t\tt.Error(\"makeValkeyOptions() without VALKEY_ADDR expected error\")\n\t}\n\n\t// Test case: missing VALKEY_PASSWORD when required\n\tos.Setenv(\"VALKEY_ADDR\", \"localhost:6379\")\n\tos.Setenv(\"VALKEY_PASSWORD\", \"\")\n\tos.Unsetenv(\"VALKEY_PASSWORD_REQUIRED\")\n\t_, err = makeValkeyOptions()\n\tif err == nil {\n\t\tt.Error(\"makeValkeyOptions() without password when required expected error\")\n\t}\n\n\t// Test case: password not required\n\tos.Setenv(\"VALKEY_ADDR\", \"localhost:6379\")\n\tos.Setenv(\"VALKEY_PASSWORD\", \"\")\n\tos.Setenv(\"VALKEY_PASSWORD_REQUIRED\", \"false\")\n\tos.Unsetenv(\"VALKEY_DISABLE_CACHE\")\n\tos.Unsetenv(\"VALKEY_FORCE_SINGLE\")\n\topts, err := makeValkeyOptions()\n\tif err != nil {\n\t\tt.Fatalf(\"makeValkeyOptions() error = %v\", err)\n\t}\n\tif len(opts.InitAddress) != 1 || opts.InitAddress[0] != \"localhost:6379\" {\n\t\tt.Errorf(\"InitAddress = %v, want [localhost:6379]\", opts.InitAddress)\n\t}\n\tif opts.Password != \"\" {\n\t\tt.Errorf(\"Password = %v, want empty\", opts.Password)\n\t}\n\tif opts.DisableCache != false {\n\t\tt.Errorf(\"DisableCache = %v, want false\", opts.DisableCache)\n\t}\n\tif opts.ForceSingleClient != false {\n\t\tt.Errorf(\"ForceSingleClient = %v, want false\", opts.ForceSingleClient)\n\t}\n\n\t// Test case: password required and provided\n\tos.Setenv(\"VALKEY_ADDR\", \"valkey:6379\")\n\tos.Setenv(\"VALKEY_PASSWORD\", \"mysecret\")\n\tos.Setenv(\"VALKEY_PASSWORD_REQUIRED\", \"true\")\n\topts, err = makeValkeyOptions()\n\tif err != nil {\n\t\tt.Fatalf(\"makeValkeyOptions() error = %v\", err)\n\t}\n\tif len(opts.InitAddress) != 1 || opts.InitAddress[0] != \"valkey:6379\" {\n\t\tt.Errorf(\"InitAddress = %v, want [valkey:6379]\", opts.InitAddress)\n\t}\n\tif opts.Password != \"mysecret\" {\n\t\tt.Errorf(\"Password = %v, want mysecret\", opts.Password)\n\t}\n\n\t// Test case: multiple addresses\n\tos.Setenv(\"VALKEY_ADDR\", \"valkey-1:6379, valkey-2:6379, valkey-3:6379\")\n\tos.Setenv(\"VALKEY_PASSWORD\", \"secret\")\n\topts, err = makeValkeyOptions()\n\tif err != nil {\n\t\tt.Fatalf(\"makeValkeyOptions() error = %v\", err)\n\t}\n\tif len(opts.InitAddress) != 3 {\n\t\tt.Errorf(\"InitAddress length = %v, want 3\", len(opts.InitAddress))\n\t}\n\n\t// Test case: optional flags\n\tos.Setenv(\"VALKEY_ADDR\", \"localhost:6379\")\n\tos.Setenv(\"VALKEY_PASSWORD\", \"secret\")\n\tos.Setenv(\"VALKEY_DISABLE_CACHE\", \"true\")\n\tos.Setenv(\"VALKEY_FORCE_SINGLE\", \"true\")\n\topts, err = makeValkeyOptions()\n\tif err != nil {\n\t\tt.Fatalf(\"makeValkeyOptions() error = %v\", err)\n\t}\n\tif opts.DisableCache != true {\n\t\tt.Errorf(\"DisableCache = %v, want true\", opts.DisableCache)\n\t}\n\tif opts.ForceSingleClient != true {\n\t\tt.Errorf(\"ForceSingleClient = %v, want true\", opts.ForceSingleClient)\n\t}\n\n\t// Test case: whitespace trimming\n\tos.Setenv(\"VALKEY_ADDR\", \"  localhost:6379  \")\n\tos.Setenv(\"VALKEY_PASSWORD\", \"  secret  \")\n\tos.Unsetenv(\"VALKEY_DISABLE_CACHE\")\n\tos.Unsetenv(\"VALKEY_FORCE_SINGLE\")\n\topts, err = makeValkeyOptions()\n\tif err != nil {\n\t\tt.Fatalf(\"makeValkeyOptions() error = %v\", err)\n\t}\n\tif len(opts.InitAddress) != 1 || opts.InitAddress[0] != \"localhost:6379\" {\n\t\tt.Errorf(\"InitAddress = %v, want [localhost:6379] (trimmed)\", opts.InitAddress)\n\t}\n\tif opts.Password != \"  secret  \" {\n\t\tt.Errorf(\"Password = %v, want \\\"  secret  \\\" (not trimmed)\", opts.Password)\n\t}\n}\n\nfunc TestMakeValkeyOptions_InvalidBool(t *testing.T) {\n\t// Clean up environment after test\n\toriginalAddr := os.Getenv(\"VALKEY_ADDR\")\n\toriginalPassword := os.Getenv(\"VALKEY_PASSWORD\")\n\toriginalRequired := os.Getenv(\"VALKEY_PASSWORD_REQUIRED\")\n\toriginalDisableCache := os.Getenv(\"VALKEY_DISABLE_CACHE\")\n\toriginalForceSingle := os.Getenv(\"VALKEY_FORCE_SINGLE\")\n\tdefer func() {\n\t\tos.Setenv(\"VALKEY_ADDR\", originalAddr)\n\t\tos.Setenv(\"VALKEY_PASSWORD\", originalPassword)\n\t\tos.Setenv(\"VALKEY_PASSWORD_REQUIRED\", originalRequired)\n\t\tos.Setenv(\"VALKEY_DISABLE_CACHE\", originalDisableCache)\n\t\tos.Setenv(\"VALKEY_FORCE_SINGLE\", originalForceSingle)\n\t}()\n\n\tos.Setenv(\"VALKEY_ADDR\", \"localhost:6379\")\n\tos.Setenv(\"VALKEY_PASSWORD\", \"secret\")\n\tos.Setenv(\"VALKEY_PASSWORD_REQUIRED\", \"invalid\")\n\tos.Setenv(\"VALKEY_DISABLE_CACHE\", \"invalid\")\n\tos.Setenv(\"VALKEY_FORCE_SINGLE\", \"invalid\")\n\n\t// Should use defaults when parsing fails\n\topts, err := makeValkeyOptions()\n\tif err != nil {\n\t\tt.Errorf(\"makeValkeyOptions() with invalid bools should use defaults, got error: %v\", err)\n\t}\n\tif opts.DisableCache != false {\n\t\tt.Errorf(\"DisableCache = %v, want false (default)\", opts.DisableCache)\n\t}\n\tif opts.ForceSingleClient != false {\n\t\tt.Errorf(\"ForceSingleClient = %v, want false (default)\", opts.ForceSingleClient)\n\t}\n}\n\nfunc TestNewValkeyStore(t *testing.T) {\n\tm := setupTestValkey(t)\n\tdefer m.Close()\n\n\t// Clean up environment after test\n\toriginalAddr := os.Getenv(\"VALKEY_ADDR\")\n\toriginalPassword := os.Getenv(\"VALKEY_PASSWORD\")\n\toriginalRequired := os.Getenv(\"VALKEY_PASSWORD_REQUIRED\")\n\toriginalDisableCache := os.Getenv(\"VALKEY_DISABLE_CACHE\")\n\tdefer func() {\n\t\tos.Setenv(\"VALKEY_ADDR\", originalAddr)\n\t\tos.Setenv(\"VALKEY_PASSWORD\", originalPassword)\n\t\tos.Setenv(\"VALKEY_PASSWORD_REQUIRED\", originalRequired)\n\t\tos.Setenv(\"VALKEY_DISABLE_CACHE\", originalDisableCache)\n\t}()\n\n\tos.Setenv(\"VALKEY_ADDR\", m.Addr())\n\tos.Setenv(\"VALKEY_PASSWORD\", \"\")\n\tos.Setenv(\"VALKEY_PASSWORD_REQUIRED\", \"false\")\n\tos.Setenv(\"VALKEY_DISABLE_CACHE\", \"true\")\n\n\tstore, err := newValkeyStore()\n\tif err != nil {\n\t\tt.Fatalf(\"newValkeyStore() error = %v\", err)\n\t}\n\tif store == nil {\n\t\tt.Fatal(\"newValkeyStore() returned nil\")\n\t}\n\tdefer store.Close()\n\n\t// Test that it implements Store interface\n\tvar _ Store = store\n}\n\nfunc TestNewValkeyStore_MissingAddr(t *testing.T) {\n\t// Clean up environment\n\toriginalAddr := os.Getenv(\"VALKEY_ADDR\")\n\tdefer func() {\n\t\tos.Setenv(\"VALKEY_ADDR\", originalAddr)\n\t}()\n\n\tos.Unsetenv(\"VALKEY_ADDR\")\n\n\t_, err := newValkeyStore()\n\tif err == nil {\n\t\tt.Error(\"newValkeyStore() without VALKEY_ADDR expected error\")\n\t}\n}\n\nfunc TestNewValkeyStore_InvalidAddress(t *testing.T) {\n\t// Clean up environment\n\toriginalAddr := os.Getenv(\"VALKEY_ADDR\")\n\toriginalPassword := os.Getenv(\"VALKEY_PASSWORD\")\n\toriginalRequired := os.Getenv(\"VALKEY_PASSWORD_REQUIRED\")\n\tdefer func() {\n\t\tos.Setenv(\"VALKEY_ADDR\", originalAddr)\n\t\tos.Setenv(\"VALKEY_PASSWORD\", originalPassword)\n\t\tos.Setenv(\"VALKEY_PASSWORD_REQUIRED\", originalRequired)\n\t}()\n\n\t// Use an invalid address format that will fail client creation\n\tos.Setenv(\"VALKEY_ADDR\", \"invalid-address-format\")\n\tos.Setenv(\"VALKEY_PASSWORD\", \"\")\n\tos.Setenv(\"VALKEY_PASSWORD_REQUIRED\", \"false\")\n\n\t// This may or may not fail depending on how valkey-go handles invalid addresses\n\t// The client might be created successfully but fail on actual operations\n\t_, err := newValkeyStore()\n\t// We don't assert on error here because valkey-go may allow client creation\n\t// with invalid addresses and only fail on actual operations\n\tif err == nil {\n\t\tt.Log(\"newValkeyStore() with invalid address did not error (client may be lazy)\")\n\t}\n}\n\nfunc TestValkeyStore_Ping_WrongResponse(t *testing.T) {\n\tm := setupTestValkey(t)\n\tdefer m.Close()\n\n\ts := createTestValkeyStore(t, m)\n\tdefer s.Close()\n\n\tctx := context.Background()\n\n\t// Normal ping should succeed\n\terr := s.Ping(ctx)\n\tif err != nil {\n\t\tt.Fatalf(\"Ping() error = %v\", err)\n\t}\n}\n\nfunc TestValkeyStore_StoreSandbox_MarshalError(t *testing.T) {\n\tm := setupTestValkey(t)\n\tdefer m.Close()\n\n\ts := createTestValkeyStore(t, m)\n\tdefer s.Close()\n\n\tctx := context.Background()\n\n\t// Create a sandbox that can be marshaled normally\n\tsandbox := createTestSandboxForValkey(\"test-session\", time.Now().Add(time.Hour))\n\n\t// This should succeed with valid sandbox\n\terr := s.StoreSandbox(ctx, sandbox)\n\tif err != nil {\n\t\tt.Fatalf(\"StoreSandbox() error = %v\", err)\n\t}\n}\n\nfunc TestValkeyStore_UpdateSandbox_MarshalError(t *testing.T) {\n\tm := setupTestValkey(t)\n\tdefer m.Close()\n\n\ts := createTestValkeyStore(t, m)\n\tdefer s.Close()\n\n\tctx := context.Background()\n\n\t// First store a valid sandbox\n\tsandbox := createTestSandboxForValkey(\"test-session\", time.Now().Add(time.Hour))\n\tif err := s.StoreSandbox(ctx, sandbox); err != nil {\n\t\tt.Fatalf(\"StoreSandbox() error = %v\", err)\n\t}\n\n\t// Now update with a normal sandbox - should work\n\tsandbox.Status = \"Updated\"\n\terr := s.UpdateSandbox(ctx, sandbox)\n\tif err != nil {\n\t\tt.Fatalf(\"UpdateSandbox() error = %v\", err)\n\t}\n}\n\nfunc TestValkeyStore_GetSandboxBySessionID_UnmarshalError(t *testing.T) {\n\tm := setupTestValkey(t)\n\tdefer m.Close()\n\n\ts := createTestValkeyStore(t, m)\n\tdefer s.Close()\n\n\tctx := context.Background()\n\n\t// Store invalid JSON data directly\n\tkey := s.sessionKey(\"bad-session\")\n\tm.Set(key, \"not-valid-json\")\n\n\t// Try to get the sandbox - should fail to unmarshal\n\t_, err := s.GetSandboxBySessionID(ctx, \"bad-session\")\n\tif err == nil {\n\t\tt.Error(\"GetSandboxBySessionID() with invalid JSON expected error\")\n\t}\n}\n\nfunc TestValkeyStore_ListExpiredSandboxes_EdgeCases(t *testing.T) {\n\tm := setupTestValkey(t)\n\tdefer m.Close()\n\n\ts := createTestValkeyStore(t, m)\n\tdefer s.Close()\n\n\tctx := context.Background()\n\tnow := time.Now()\n\n\t// Store sandbox with exact boundary time\n\tsandbox := createTestSandboxForValkey(\"boundary-session\", now)\n\tif err := s.StoreSandbox(ctx, sandbox); err != nil {\n\t\tt.Fatalf(\"StoreSandbox() error = %v\", err)\n\t}\n\n\t// List with before = now should include this session (ExpiresAt <= before)\n\texpired, err := s.ListExpiredSandboxes(ctx, now, 10)\n\tif err != nil {\n\t\tt.Fatalf(\"ListExpiredSandboxes() error = %v\", err)\n\t}\n\tif len(expired) != 1 {\n\t\tt.Errorf(\"ListExpiredSandboxes() returned %d sandboxes, want 1\", len(expired))\n\t}\n}\n\nfunc TestValkeyStore_ConcurrentOperations(t *testing.T) {\n\tm := setupTestValkey(t)\n\tdefer m.Close()\n\n\ts := createTestValkeyStore(t, m)\n\tdefer s.Close()\n\n\tctx := context.Background()\n\tnow := time.Now()\n\n\t// Store multiple sandboxes concurrently\n\tdone := make(chan bool, 5)\n\tfor i := 0; i < 5; i++ {\n\t\tgo func(idx int) {\n\t\t\tsessionID := fmt.Sprintf(\"concurrent-%d\", idx)\n\t\t\tsandbox := createTestSandboxForValkey(sessionID, now.Add(time.Hour))\n\t\t\terr := s.StoreSandbox(ctx, sandbox)\n\t\t\tif err != nil {\n\t\t\t\tt.Errorf(\"Concurrent Store