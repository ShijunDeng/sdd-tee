{"type":"tool_use","timestamp":1775877782189,"sessionID":"ses_285700e6cffe1o1w0ORJi5ZG82","part":{"id":"prt_d7a9066bd001Ypp9VnHYGkdWEn","messageID":"msg_d7a904be2001FSi606Tx1vhYJW","sessionID":"ses_285700e6cffe1o1w0ORJi5ZG82","type":"tool","tool":"read","callID":"toolu_functions.read:6","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/router/jwt.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/router/jwt.go</path>\n<type>file</type>\n<content>\n1: /*\n2: Copyright 2026 The Volcano Authors.\n3: \n4: Licensed under the Apache License, Version 2.0 (the \"License\");\n5: you may not use this file except in compliance with the License.\n6: You may obtain a copy of the License at\n7: \n8:     http://www.apache.org/licenses/LICENSE-2.0\n9: \n10: Unless required by applicable law or agreed to in writing, software\n11: distributed under the License is distributed on an \"AS IS\" BASIS,\n12: WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n13: See the License for the specific language governing permissions and\n14: limitations under the License.\n15: */\n16: \n17: package router\n18: \n19: import (\n20: \t\"context\"\n21: \t\"crypto/rand\"\n22: \t\"crypto/rsa\"\n23: \t\"crypto/x509\"\n24: \t\"encoding/pem\"\n25: \t\"errors\"\n26: \t\"fmt\"\n27: \t\"math/big\"\n28: \t\"os\"\n29: \t\"sync\"\n30: \t\"time\"\n31: \n32: \t\"github.com/golang-jwt/jwt/v5\"\n33: \tcorev1 \"k8s.io/api/core/v1\"\n34: \tapierrors \"k8s.io/apimachinery/pkg/api/errors\"\n35: \tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n36: \t\"k8s.io/client-go/kubernetes\"\n37: \t\"k8s.io/client-go/rest\"\n38: \t\"k8s.io/klog/v2\"\n39: )\n40: \n41: const (\n42: \trsaKeySize             = 2048\n43: \tjwtExpiration          = 5 * time.Minute\n44: \trefreshExpiration      = 24 * time.Hour\n45: \tidentitySecretName     = \"picod-router-identity\"\n46: \tprivateKeyDataKey      = \"private.pem\"\n47: \tpublicKeyDataKey       = \"public.pem\"\n48: \tkeyVersionAnnotation   = \"agentcube.volcano.sh/key-version\"\n49: \tkeyCreatedAtAnnotation = \"agentcube.volcano.sh/key-created-at\"\n50: )\n51: \n52: // IdentityNamespace is the namespace where the JWT identity secret is stored.\n53: // Initialized from AGENTCUBE_NAMESPACE env var or defaults to \"default\".\n54: var IdentityNamespace = \"default\"\n55: \n56: func init() {\n57: \tif ns := os.Getenv(\"AGENTCUBE_NAMESPACE\"); ns != \"\" {\n58: \t\tIdentityNamespace = ns\n59: \t}\n60: }\n61: \n62: // KeyPair represents an RSA key pair with version metadata.\n63: type KeyPair struct {\n64: \tPrivateKey *rsa.PrivateKey\n65: \tPublicKey  *rsa.PublicKey\n66: \tVersion    string\n67: \tCreatedAt  time.Time\n68: }\n69: \n70: // JWTManager handles JWT key generation and token signing.\n71: type JWTManager struct {\n72: \tprivateKey   *rsa.PrivateKey\n73: \tpublicKey    *rsa.PublicKey\n74: \tclientset    kubernetes.Interface\n75: \tconfig       *JWTConfig\n76: \tkeyVersion   string\n77: \tkeyCreatedAt time.Time\n78: \n79: \t// previousKeys holds old key versions for token validation during rotation\n80: \tpreviousKeys []*KeyPair\n81: \tkeyMutex     sync.RWMutex\n82: }\n83: \n84: // NewJWTManager creates a new JWTManager with a generated RSA key pair.\n85: func NewJWTManager() (*JWTManager, error) {\n86: \treturn NewJWTManagerWithConfig(nil)\n87: }\n88: \n89: // NewJWTManagerWithConfig creates a new JWTManager with the given configuration.\n90: func NewJWTManagerWithConfig(config *JWTConfig) (*JWTManager, error) {\n91: \tif config == nil {\n92: \t\tconfig = DefaultJWTConfig()\n93: \t}\n94: \n95: \tif err := config.Validate(); err != nil {\n96: \t\treturn nil, fmt.Errorf(\"invalid JWT config: %w\", err)\n97: \t}\n98: \n99: \tprivateKey, err := rsa.GenerateKey(rand.Reader, config.RSAKeySize)\n100: \tif err != nil {\n101: \t\treturn nil, NewJWTError(KeyGenerationFailed, \"failed to generate RSA key\", err)\n102: \t}\n103: \n104: \treturn &JWTManager{\n105: \t\tprivateKey:   privateKey,\n106: \t\tpublicKey:    &privateKey.PublicKey,\n107: \t\tconfig:       config,\n108: \t\tkeyVersion:   generateKeyVersion(),\n109: \t\tkeyCreatedAt: time.Now(),\n110: \t}, nil\n111: }\n112: \n113: // generateKeyVersion generates a unique key version identifier.\n114: func generateKeyVersion() string {\n115: \treturn fmt.Sprintf(\"v-%d\", time.Now().UnixNano())\n116: }\n117: \n118: // Initialize initializes the JWTManager with the given context.\n119: func (m *JWTManager) Initialize(ctx context.Context) error {\n120: \treturn m.TryStoreOrLoadJWTKeySecretWithContext(ctx)\n121: }\n122: \n123: // GenerateToken creates a JWT with the given claims.\n124: func (m *JWTManager) GenerateToken(claims map[string]interface{}) (string, error) {\n125: \treturn m.GenerateTokenWithExpiry(claims, m.config.AccessTokenExpiry)\n126: }\n127: \n128: // GenerateTokenWithExpiry creates a JWT with the given claims and custom expiry.\n129: func (m *JWTManager) GenerateTokenWithExpiry(claims map[string]interface{}, expiry time.Duration) (string, error) {\n130: \tm.keyMutex.RLock()\n131: \tprivateKey := m.privateKey\n132: \tm.keyMutex.RUnlock()\n133: \n134: \tif privateKey == nil {\n135: \t\treturn \"\", ErrKeyNotFound\n136: \t}\n137: \n138: \tnow := time.Now()\n139: \n140: \t// Build base claims\n141: \ttokenClaims := jwt.MapClaims{\n142: \t\t\"iat\": now.Unix(),\n143: \t\t\"iss\": m.config.Issuer,\n144: \t}\n145: \n146: \t// Set expiration - use custom if provided in claims, otherwise use default\n147: \tif expClaim, ok := claims[\"exp\"]; ok {\n148: \t\tif expFloat, ok := expClaim.(float64); ok {\n149: \t\t\ttokenClaims[\"exp\"] = int64(expFloat)\n150: \t\t} else if expInt, ok := expClaim.(int64); ok {\n151: \t\t\ttokenClaims[\"exp\"] = expInt\n152: \t\t}\n153: \t} else {\n154: \t\ttokenClaims[\"exp\"] = now.Add(expiry).Unix()\n155: \t}\n156: \n157: \t// Add key version for tracking\n158: \tif m.keyVersion != \"\" {\n159: \t\ttokenClaims[\"kid\"] = m.keyVersion\n160: \t}\n161: \n162: \t// Merge custom claims\n163: \tfor k, v := range claims {\n164: \t\tif k != \"exp\" { // exp is handled above\n165: \t\t\ttokenClaims[k] = v\n166: \t\t}\n167: \t}\n168: \n169: \t// Create and sign token\n170: \ttoken := jwt.NewWithClaims(jwt.SigningMethodRS256, tokenClaims)\n171: \ttokenString, err := token.SignedString(privateKey)\n172: \tif err != nil {\n173: \t\treturn \"\", NewJWTError(TokenInvalid, \"failed to sign token\", err)\n174: \t}\n175: \n176: \treturn tokenString, nil\n177: }\n178: \n179: // GenerateTokenPair creates both access and refresh tokens.\n180: func (m *JWTManager) GenerateTokenPair(claims map[string]interface{}) (*TokenPair, *TokenMetadata, error) {\n181: \tnow := time.Now()\n182: \n183: \t// Generate access token\n184: \taccessToken, err := m.GenerateToken(claims)\n185: \tif err != nil {\n186: \t\treturn nil, nil, fmt.Errorf(\"failed to generate access token: %w\", err)\n187: \t}\n188: \n189: \t// Generate refresh token with jti claim\n190: \trefreshClaims := make(map[string]interface{})\n191: \tfor k, v := range claims {\n192: \t\trefreshClaims[k] = v\n193: \t}\n194: \trefreshClaims[\"jti\"] = generateTokenID()\n195: \trefreshClaims[\"token_type\"] = \"refresh\"\n196: \n197: \trefreshToken, err := m.GenerateTokenWithExpiry(refreshClaims, m.config.RefreshTokenExpiry)\n198: \tif err != nil {\n199: \t\treturn nil, nil, fmt.Errorf(\"failed to generate refresh token: %w\", err)\n200: \t}\n201: \n202: \tmetadata := &TokenMetadata{\n203: \t\tIssuedAt:          now,\n204: \t\tExpiresAt:         now.Add(m.config.AccessTokenExpiry),\n205: \t\tRefreshExpiresAt:  now.Add(m.config.RefreshTokenExpiry),\n206: \t\tTokenType:         \"Bearer\",\n207: \t\tAccessTokenExpiry: int64(m.config.AccessTokenExpiry.Seconds()),\n208: \t}\n209: \n210: \treturn &TokenPair{\n211: \t\tAccessToken:  accessToken,\n212: \t\tRefreshToken: refreshToken,\n213: \t}, metadata, nil\n214: }\n215: \n216: // generateTokenID generates a unique token identifier.\n217: func generateTokenID() string {\n218: \tn, _ := rand.Int(rand.Reader, big.NewInt(1<<63-1))\n219: \treturn fmt.Sprintf(\"tid-%d-%d\", time.Now().UnixNano(), n.Int64())\n220: }\n221: \n222: // ValidateToken validates a JWT and returns the parsed claims.\n223: func (m *JWTManager) ValidateToken(tokenString string) (*TokenClaims, error) {\n224: \ttoken, err := jwt.Parse(tokenString, func(token *jwt.Token) (interface{}, error) {\n225: \t\t// Validate signing method\n226: \t\tif _, ok := token.Method.(*jwt.SigningMethodRSA); !ok {\n227: \t\t\treturn nil, NewJWTError(TokenSignatureInvalid,\n228: \t\t\t\tfmt.Sprintf(\"unexpected signing method: %v\", token.Header[\"alg\"]), nil)\n229: \t\t}\n230: \n231: \t\t// Get key ID from token header\n232: \t\tkid, ok := token.Header[\"kid\"].(string)\n233: \t\tif !ok || kid == \"\" {\n234: \t\t\t// No key ID, use current key\n235: \t\t\tm.keyMutex.RLock()\n236: \t\t\tpublicKey := m.publicKey\n237: \t\t\tm.keyMutex.RUnlock()\n238: \t\t\treturn publicKey, nil\n239: \t\t}\n240: \n241: \t\t// Find the key by version\n242: \t\treturn m.getKeyForVersion(kid)\n243: \t}, jwt.WithValidMethods([]string{\"RS256\"}))\n244: \n245: \tif err != nil {\n246: \t\t// Check for specific JWT errors using errors.Is\n247: \t\tif errors.Is(err, jwt.ErrTokenExpired) {\n248: \t\t\treturn nil, ErrTokenExpired\n249: \t\t}\n250: \t\tif errors.Is(err, jwt.ErrTokenSignatureInvalid) {\n251: \t\t\treturn nil, ErrTokenSignatureInvalid\n252: \t\t}\n253: \t\tif errors.Is(err, jwt.ErrTokenMalformed) {\n254: \t\t\treturn nil, ErrTokenMalformed\n255: \t\t}\n256: \t\treturn nil, NewJWTError(TokenInvalid, \"token validation failed\", err)\n257: \t}\n258: \n259: \tif !token.Valid {\n260: \t\treturn nil, ErrTokenInvalid\n261: \t}\n262: \n263: \t// Parse claims\n264: \tclaims, ok := token.Claims.(jwt.MapClaims)\n265: \tif !ok {\n266: \t\treturn nil, ErrTokenMalformed\n267: \t}\n268: \n269: \treturn m.parseTokenClaims(claims)\n270: }\n271: \n272: // getKeyForVersion returns the public key for the given version.\n273: func (m *JWTManager) getKeyForVersion(version string) (*rsa.PublicKey, error) {\n274: \tm.keyMutex.RLock()\n275: \tdefer m.keyMutex.RUnlock()\n276: \n277: \t// Check current key\n278: \tif m.keyVersion == version {\n279: \t\treturn m.publicKey, nil\n280: \t}\n281: \n282: \t// Check previous keys\n283: \tfor _, kp := range m.previousKeys {\n284: \t\tif kp.Version == version {\n285: \t\t\treturn kp.PublicKey, nil\n286: \t\t}\n287: \t}\n288: \n289: \treturn nil, NewJWTError(KeyNotFound, fmt.Sprintf(\"key version not found: %s\", version), nil)\n290: }\n291: \n292: // parseTokenClaims extracts TokenClaims from JWT MapClaims.\n293: func (m *JWTManager) parseTokenClaims(claims jwt.MapClaims) (*TokenClaims, error) {\n294: \ttokenClaims := &TokenClaims{\n295: \t\tIssuer: m.config.Issuer,\n296: \t}\n297: \n298: \t// Extract session_id (required)\n299: \tif sessionID, ok := claims[\"session_id\"].(string); ok {\n300: \t\ttokenClaims.SessionID = sessionID\n301: \t}\n302: \n303: \t// Extract user_id\n304: \tif userID, ok := claims[\"user_id\"].(string); ok {\n305: \t\ttokenClaims.UserID = userID\n306: \t}\n307: \n308: \t// Extract sandbox_id\n309: \tif sandboxID, ok := claims[\"sandbox_id\"].(string); ok {\n310: \t\ttokenClaims.SandboxID = sandboxID\n311: \t}\n312: \n313: \t// Extract namespace\n314: \tif namespace, ok := claims[\"namespace\"].(string); ok {\n315: \t\ttokenClaims.Namespace = namespace\n316: \t}\n317: \n318: \t// Extract runtime_kind\n319: \tif runtimeKind, ok := claims[\"runtime_kind\"].(string); ok {\n320: \t\ttokenClaims.RuntimeKind = runtimeKind\n321: \t}\n322: \n323: \t// Extract iss\n324: \tif iss, ok := claims[\"iss\"].(string); ok {\n325: \t\ttokenClaims.Issuer = iss\n326: \t}\n327: \n328: \t// Extract jti\n329: \tif jti, ok := claims[\"jti\"].(string); ok {\n330: \t\ttokenClaims.JWTID = jti\n331: \t}\n332: \n333: \t// Extract iat\n334: \tif iat, ok := claims[\"iat\"].(float64); ok {\n335: \t\ttokenClaims.IssuedAt = time.Unix(int64(iat), 0)\n336: \t}\n337: \n338: \t// Extract exp\n339: \tif exp, ok := claims[\"exp\"].(float64); ok {\n340: \t\ttokenClaims.ExpiresAt = time.Unix(int64(exp), 0)\n341: \t}\n342: \n343: \t// Validate required claims\n344: \tif tokenClaims.SessionID == \"\" {\n345: \t\treturn nil, NewJWTError(MissingClaims, \"session_id claim is required\", nil)\n346: \t}\n347: \n348: \treturn tokenClaims, nil\n349: }\n350: \n351: // ValidateTokenWithContext validates a JWT with context support.\n352: func (m *JWTManager) ValidateTokenWithContext(ctx context.Context, tokenString string) (*TokenClaims, error) {\n353: \t// Check for context cancellation\n354: \tselect {\n355: \tcase <-ctx.Done():\n356: \t\treturn nil, ctx.Err()\n357: \tdefault:\n358: \t}\n359: \n360: \treturn m.ValidateToken(tokenString)\n361: }\n362: \n363: // RefreshToken validates a refresh token and generates a new token pair.\n364: func (m *JWTManager) RefreshToken(refreshToken string) (*TokenPair, *TokenMetadata, error) {\n365: \t// Validate the refresh token\n366: \tclaims, err := m.ValidateToken(refreshToken)\n367: \tif err != nil {\n368: \t\treturn nil, nil, fmt.Errorf(\"invalid refresh token: %w\", err)\n369: \t}\n370: \n371: \t// Verify it's a refresh token\n372: \t// Note: We rely on the jti claim presence to identify refresh tokens\n373: \tif claims.JWTID == \"\" {\n374: \t\treturn nil, nil, NewJWTError(TokenInvalid, \"token is not a refresh token\", nil)\n375: \t}\n376: \n377: \t// Check if token is within refresh window\n378: \tif time.Now().After(claims.ExpiresAt) {\n379: \t\treturn nil, nil, ErrTokenExpired\n380: \t}\n381: \n382: \t// Create claims for new token pair\n383: \tnewClaims := map[string]interface{}{\n384: \t\t\"session_id\":   claims.SessionID,\n385: \t\t\"user_id\":      claims.UserID,\n386: \t\t\"sandbox_id\":   claims.SandboxID,\n387: \t\t\"namespace\":    claims.Namespace,\n388: \t\t\"runtime_kind\": claims.RuntimeKind,\n389: \t}\n390: \n391: \treturn m.GenerateTokenPair(newClaims)\n392: }\n393: \n394: // GetPublicKeyPEM returns the public key in PEM format.\n395: func (m *JWTManager) GetPublicKeyPEM() ([]byte, error) {\n396: \tm.keyMutex.RLock()\n397: \tpublicKey := m.publicKey\n398: \tm.keyMutex.RUnlock()\n399: \n400: \tif publicKey == nil {\n401: \t\treturn nil, ErrKeyNotFound\n402: \t}\n403: \n404: \tpublicKeyBytes, err := x509.MarshalPKIXPublicKey(publicKey)\n405: \tif err != nil {\n406: \t\treturn nil, fmt.Errorf(\"failed to marshal public key: %w\", err)\n407: \t}\n408: \n409: \tpemBlock := &pem.Block{\n410: \t\tType:  \"PUBLIC KEY\",\n411: \t\tBytes: publicKeyBytes,\n412: \t}\n413: \n414: \treturn pem.EncodeToMemory(pemBlock), nil\n415: }\n416: \n417: // GetPrivateKeyPEM returns the private key in PEM format.\n418: func (m *JWTManager) GetPrivateKeyPEM() ([]byte, error) {\n419: \tm.keyMutex.RLock()\n420: \tprivateKey := m.privateKey\n421: \tm.keyMutex.RUnlock()\n422: \n423: \tif privateKey == nil {\n424: \t\treturn nil, ErrKeyNotFound\n425: \t}\n426: \n427: \tprivateKeyBytes := x509.MarshalPKCS1PrivateKey(privateKey)\n428: \n429: \tpemBlock := &pem.Block{\n430: \t\tType:  \"RSA PRIVATE KEY\",\n431: \t\tBytes: privateKeyBytes,\n432: \t}\n433: \n434: \treturn pem.EncodeToMemory(pemBlock), nil\n435: }\n436: \n437: // GetKeyVersion returns the current key version.\n438: func (m *JWTManager) GetKeyVersion() string {\n439: \tm.keyMutex.RLock()\n440: \tdefer m.keyMutex.RUnlock()\n441: \treturn m.keyVersion\n442: }\n443: \n444: // GetKeyCreatedAt returns when the current key was created.\n445: func (m *JWTManager) GetKeyCreatedAt() time.Time {\n446: \tm.keyMutex.RLock()\n447: \tdefer m.keyMutex.RUnlock()\n448: \treturn m.keyCreatedAt\n449: }\n450: \n451: // TryStoreOrLoadJWTKeySecret attempts to store the JWT keys in a Kubernetes secret\n452: // or load them if the secret already exists. Returns nil if not running in-cluster.\n453: func (m *JWTManager) TryStoreOrLoadJWTKeySecret() error {\n454: \treturn m.TryStoreOrLoadJWTKeySecretWithContext(context.Background())\n455: }\n456: \n457: // TryStoreOrLoadJWTKeySecretWithContext attempts to store or load keys with context support.\n458: func (m *JWTManager) TryStoreOrLoadJWTKeySecretWithContext(ctx context.Context) error {\n459: \t// Try to get in-cluster config\n460: \tconfig, err := rest.InClusterConfig()\n461: \tif err != nil {\n462: \t\tklog.Warningf(\"Not running in Kubernetes cluster, using ephemeral JWT keys: %v\", err)\n463: \t\treturn nil\n464: \t}\n465: \n466: \t// Create clientset\n467: \tclientset, err := kubernetes.NewForConfig(config)\n468: \tif err != nil {\n469: \t\treturn NewJWTError(SecretAccessFailed, \"failed to create Kubernetes client\", err)\n470: \t}\n471: \n472: \tm.clientset = clientset\n473: \n474: \t// Get or create the secret\n475: \treturn m.createOrLoadSecret(ctx)\n476: }\n477: \n478: func (m *JWTManager) createOrLoadSecret(ctx context.Context) error {\n479: \t// Get key PEM data\n480: \tprivatePEM, err := m.GetPrivateKeyPEM()\n481: \tif err != nil {\n482: \t\treturn fmt.Errorf(\"failed to encode private key: %w\", err)\n483: \t}\n484: \n485: \tpublicPEM, err := m.GetPublicKeyPEM()\n486: \tif err != nil {\n487: \t\treturn fmt.Errorf(\"failed to encode public key: %w\", err)\n488: \t}\n489: \n490: \tsecret := &corev1.Secret{\n491: \t\tObjectMeta: metav1.ObjectMeta{\n492: \t\t\tName:      identitySecretName,\n493: \t\t\tNamespace: IdentityNamespace,\n494: \t\t\tLabels: map[string]string{\n495: \t\t\t\t\"app\":       \"agentcube\",\n496: \t\t\t\t\"component\": \"router\",\n497: \t\t\t},\n498: \t\t\tAnnotations: map[string]string{\n499: \t\t\t\tkeyVersionAnnotation:   m.keyVersion,\n500: \t\t\t\tkeyCreatedAtAnnotation: m.keyCreatedAt.Format(time.RFC3339),\n501: \t\t\t},\n502: \t\t},\n503: \t\tType: corev1.SecretTypeOpaque,\n504: \t\tData: map[string][]byte{\n505: \t\t\tprivateKeyDataKey: privatePEM,\n506: \t\t\tpublicKeyDataKey:  publicPEM,\n507: \t\t},\n508: \t}\n509: \n510: \t_, err = m.clientset.CoreV1().Secrets(IdentityNamespace).Create(ctx, secret, metav1.CreateOptions{})\n511: \tif err != nil {\n512: \t\tif apierrors.IsAlreadyExists(err) {\n513: \t\t\t// Secret exists, load the keys\n514: \t\t\treturn m.loadExistingSecret(ctx)\n515: \t\t}\n516: \t\treturn NewJWTError(SecretAccessFailed, \"failed to create JWT secret\", err)\n517: \t}\n518: \n519: \tklog.Infof(\"Created JWT identity secret '%s' in namespace '%s'\", identitySecretName, IdentityNamespace)\n520: \treturn nil\n521: }\n522: \n523: func (m *JWTManager) loadExistingSecret(ctx context.Context) error {\n524: \tsecret, err := m.clientset.CoreV1().Secrets(IdentityNamespace).Get(ctx, identitySecretName, metav1.GetOptions{})\n525: \tif err != nil {\n526: \t\treturn NewJWTError(SecretAccessFailed, \"failed to get existing JWT secret\", err)\n527: \t}\n528: \n529: \t// Load version info from annotations\n530: \tif version, ok := secret.Annotations[keyVersionAnnotation]; ok {\n531: \t\tm.keyVersion = version\n532: \t}\n533: \tif createdAt, ok := secret.Annotations[keyCreatedAtAnnotation]; ok {\n534: \t\tif t, err := time.Parse(time.RFC3339, createdAt); err == nil {\n535: \t\t\tm.keyCreatedAt = t\n536: \t\t}\n537: \t}\n538: \n539: \tprivatePEM, ok := secret.Data[privateKeyDataKey]\n540: \tif !ok {\n541: \t\treturn NewJWTError(SecretAccessFailed, \"existing JWT secret missing private key data\", nil)\n542: \t}\n543: \n544: \tif err := m.loadPrivateKeyPEM(privatePEM); err != nil {\n545: \t\treturn err\n546: \t}\n547: \n548: \tklog.Infof(\"Loaded existing JWT keys from secret '%s' (version: %s)\", identitySecretName, m.keyVersion)\n549: \treturn nil\n550: }\n551: \n552: func (m *JWTManager) loadPrivateKeyPEM(pemData []byte) error {\n553: \tblock, _ := pem.Decode(pemData)\n554: \tif block == nil {\n555: \t\treturn NewJWTError(KeyGenerationFailed, \"failed to decode PEM block\", nil)\n556: \t}\n557: \n558: \tprivateKey, err := x509.ParsePKCS1PrivateKey(block.Bytes)\n559: \tif err != nil {\n560: \t\treturn NewJWTError(KeyGenerationFailed, \"failed to parse private key\", err)\n561: \t}\n562: \n563: \tm.keyMutex.Lock()\n564: \tm.privateKey = privateKey\n565: \tm.publicKey = &privateKey.PublicKey\n566: \tm.keyMutex.Unlock()\n567: \n568: \treturn nil\n569: }\n570: \n571: // RotateKeys generates new RSA keys and updates the secret.\n572: func (m *JWTManager) RotateKeys(ctx context.Context) error {\n573: \t// Store current keys as previous\n574: \tm.keyMutex.Lock()\n575: \tif m.privateKey != nil {\n576: \t\tm.previousKeys = append(m.previousKeys, &KeyPair{\n577: \t\t\tPrivateKey: m.privateKey,\n578: \t\t\tPublicKey:  m.publicKey,\n579: \t\t\tVersion:    m.keyVersion,\n580: \t\t\tCreatedAt:  m.keyCreatedAt,\n581: \t\t})\n582: \t\t// Keep only last 2 previous keys\n583: \t\tif len(m.previousKeys) > 2 {\n584: \t\t\tm.previousKeys = m.previousKeys[len(m.previousKeys)-2:]\n585: \t\t}\n586: \t}\n587: \n588: \t// Generate new key pair\n589: \tprivateKey, err := rsa.GenerateKey(rand.Reader, m.config.RSAKeySize)\n590: \tif err != nil {\n591: \t\tm.keyMutex.Unlock()\n592: \t\treturn NewJWTError(KeyGenerationFailed, \"failed to generate new RSA key\", err)\n593: \t}\n594: \n595: \tm.privateKey = privateKey\n596: \tm.publicKey = &privateKey.PublicKey\n597: \tm.keyVersion = generateKeyVersion()\n598: \tm.keyCreatedAt = time.Now()\n599: \tm.keyMutex.Unlock()\n600: \n601: \t// Update secret if in cluster\n602: \tif m.clientset != nil {\n603: \t\tprivatePEM, err := m.GetPrivateKeyPEM()\n604: \t\tif err != nil {\n605: \t\t\treturn fmt.Errorf(\"failed to encode new private key: %w\", err)\n606: \t\t}\n607: \n608: \t\tpublicPEM, err := m.GetPublicKeyPEM()\n609: \t\tif err != nil {\n610: \t\t\treturn fmt.Errorf(\"failed to encode new public key: %w\", err)\n611: \t\t}\n612: \n613: \t\tsecret, err := m.clientset.CoreV1().Secrets(IdentityNamespace).Get(ctx, identitySecretName, metav1.GetOptions{})\n614: \t\tif err != nil {\n615: \t\t\treturn NewJWTError(SecretAccessFailed, \"failed to get secret for rotation\", err)\n616: \t\t}\n617: \n618: \t\tsecret.Data[privateKeyDataKey] = privatePEM\n619: \t\tsecret.Data[publicKeyDataKey] = publicPEM\n620: \t\tsecret.Annotations[keyVersionAnnotation] = m.keyVersion\n621: \t\tsecret.Annotations[keyCreatedAtAnnotation] = m.keyCreatedAt.Format(time.RFC3339)\n622: \n623: \t\t_, err = m.clientset.CoreV1().Secrets(IdentityNamespace).Update(ctx, secret, metav1.UpdateOptions{})\n624: \t\tif err != nil {\n625: \t\t\treturn NewJWTError(SecretAccessFailed, \"failed to update secret with new keys\", err)\n626: \t\t}\n627: \t}\n628: \n629: \tklog.Infof(\"Rotated JWT keys to version '%s'\", m.keyVersion)\n630: \treturn nil\n631: }\n632: \n633: // GetPreviousKeys returns the list of previous key versions.\n634: func (m *JWTManager) GetPreviousKeys() []*KeyPair {\n635: \tm.keyMutex.RLock()\n636: \tdefer m.keyMutex.RUnlock()\n637: \treturn append([]*KeyPair{}, m.previousKeys...)\n638: }\n\n(End of file - total 638 lines)\n</content>","metadata":{"preview":"/*\nCopyright 2026 The Volcano Authors.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\npackage router\n\nimport (\n\t\"context\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/router/jwt.go","time":{"start":1775877782164,"end":1775877782187}}}}
{"type":"tool_use","timestamp":1775877782192,"sessionID":"ses_285700e6cffe1o1w0ORJi5ZG82","part":{"id":"prt_d7a906bdd001rm3c9DsH0A1bjc","messageID":"msg_d7a904be2001FSi606Tx1vhYJW","sessionID":"ses_285700e6cffe1o1w0ORJi5ZG82","type":"tool","tool":"read","callID":"toolu_functions.read:7","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/router/jwt_types.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/router/jwt_types.go</path>\n<type>file</type>\n<content>\n1: /*\n2: Copyright 2026 The Volcano Authors.\n3: \n4: Licensed under the Apache License, Version 2.0 (the \"License\");\n5: you may not use this file except in compliance with the License.\n6: You may obtain a copy of the License at\n7: \n8:     http://www.apache.org/licenses/LICENSE-2.0\n9: \n10: Unless required by applicable law or agreed to in writing, software\n11: distributed under the License is distributed on an \"AS IS\" BASIS,\n12: WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n13: See the License for the specific language governing permissions and\n14: limitations under the License.\n15: */\n16: \n17: package router\n18: \n19: import (\n20: \t\"context\"\n21: \t\"time\"\n22: )\n23: \n24: // TokenIssuer is the default JWT token issuer identifier.\n25: const TokenIssuer = \"agentcube-router\"\n26: \n27: // DefaultTokenExpiry is the default access token expiration duration.\n28: const DefaultTokenExpiry = 5 * time.Minute\n29: \n30: // DefaultRefreshTokenExpiry is the default refresh token expiration duration.\n31: const DefaultRefreshTokenExpiry = 24 * time.Hour\n32: \n33: // DefaultRSAKeySize is the default RSA key size in bits.\n34: const DefaultRSAKeySize = 2048\n35: \n36: // TokenClaims represents the parsed JWT token claims.\n37: // These claims are extracted from validated JWT tokens and contain\n38: // session and user identification information.\n39: type TokenClaims struct {\n40: \t// SessionID is the unique session identifier.\n41: \tSessionID string `json:\"session_id\"`\n42: \n43: \t// UserID is the user identifier (optional).\n44: \tUserID string `json:\"user_id,omitempty\"`\n45: \n46: \t// SandboxID is the associated sandbox identifier.\n47: \tSandboxID string `json:\"sandbox_id,omitempty\"`\n48: \n49: \t// Namespace is the Kubernetes namespace.\n50: \tNamespace string `json:\"namespace,omitempty\"`\n51: \n52: \t// RuntimeKind is the runtime type (AgentRuntime or CodeInterpreter).\n53: \tRuntimeKind string `json:\"runtime_kind,omitempty\"`\n54: \n55: \t// Issuer is the token issuer.\n56: \tIssuer string `json:\"iss\"`\n57: \n58: \t// IssuedAt is when the token was issued.\n59: \tIssuedAt time.Time `json:\"iat\"`\n60: \n61: \t// ExpiresAt is when the token expires.\n62: \tExpiresAt time.Time `json:\"exp\"`\n63: \n64: \t// JWTID is the unique token identifier (for refresh tokens).\n65: \tJWTID string `json:\"jti,omitempty\"`\n66: }\n67: \n68: // TokenPair contains both access and refresh tokens.\n69: // This pair is returned when generating new tokens or refreshing\n70: // existing ones.\n71: type TokenPair struct {\n72: \t// AccessToken is the short-lived token for API access.\n73: \tAccessToken string `json:\"access_token\"`\n74: \n75: \t// RefreshToken is the long-lived token for obtaining new access tokens.\n76: \tRefreshToken string `json:\"refresh_token\"`\n77: }\n78: \n79: // TokenMetadata contains metadata about generated tokens.\n80: // This provides timing information for token lifecycle management.\n81: type TokenMetadata struct {\n82: \t// IssuedAt is when the tokens were issued.\n83: \tIssuedAt time.Time `json:\"issued_at\"`\n84: \n85: \t// ExpiresAt is when the access token expires.\n86: \tExpiresAt time.Time `json:\"expires_at\"`\n87: \n88: \t// RefreshExpiresAt is when the refresh token expires.\n89: \tRefreshExpiresAt time.Time `json:\"refresh_expires_at\"`\n90: \n91: \t// TokenType is the type of token (Bearer).\n92: \tTokenType string `json:\"token_type\"`\n93: \n94: \t// AccessTokenExpiry is the access token expiry duration in seconds.\n95: \tAccessTokenExpiry int64 `json:\"expires_in\"`\n96: }\n97: \n98: // TokenValidationResult represents the result of token validation.\n99: type TokenValidationResult struct {\n100: \t// Valid indicates if the token is valid.\n101: \tValid bool `json:\"valid\"`\n102: \n103: \t// Claims contains the parsed token claims if valid.\n104: \tClaims *TokenClaims `json:\"claims,omitempty\"`\n105: \n106: \t// Error contains the validation error if invalid.\n107: \tError string `json:\"error,omitempty\"`\n108: \n109: \t// ErrorCode contains a machine-readable error code.\n110: \tErrorCode string `json:\"error_code,omitempty\"`\n111: }\n112: \n113: // TokenRequest represents a request to generate new tokens.\n114: type TokenRequest struct {\n115: \t// SessionID is the session identifier (required).\n116: \tSessionID string `json:\"session_id\"`\n117: \n118: \t// UserID is the user identifier (optional).\n119: \tUserID string `json:\"user_id,omitempty\"`\n120: \n121: \t// SandboxID is the sandbox identifier (optional).\n122: \tSandboxID string `json:\"sandbox_id,omitempty\"`\n123: \n124: \t// Namespace is the Kubernetes namespace (optional).\n125: \tNamespace string `json:\"namespace,omitempty\"`\n126: \n127: \t// RuntimeKind is the runtime kind (optional).\n128: \tRuntimeKind string `json:\"runtime_kind,omitempty\"`\n129: \n130: \t// CustomClaims contains additional custom claims.\n131: \tCustomClaims map[string]interface{} `json:\"custom_claims,omitempty\"`\n132: }\n133: \n134: // TokenRefreshRequest represents a request to refresh tokens.\n135: type TokenRefreshRequest struct {\n136: \t// RefreshToken is the refresh token to use.\n137: \tRefreshToken string `json:\"refresh_token\"`\n138: }\n139: \n140: // TokenResponse represents the response containing tokens.\n141: type TokenResponse struct {\n142: \t// Tokens contains the access and refresh tokens.\n143: \tTokens TokenPair `json:\"tokens\"`\n144: \n145: \t// Metadata contains token metadata.\n146: \tMetadata TokenMetadata `json:\"metadata\"`\n147: }\n148: \n149: // PublicKeyResponse represents the response containing the public key.\n150: type PublicKeyResponse struct {\n151: \t// PublicKey is the PEM-encoded public key.\n152: \tPublicKey string `json:\"public_key\"`\n153: \n154: \t// Algorithm is the signing algorithm (RS256).\n155: \tAlgorithm string `json:\"algorithm\"`\n156: \n157: \t// KeyID is the key identifier (optional).\n158: \tKeyID string `json:\"key_id,omitempty\"`\n159: }\n160: \n161: // TokenValidateRequest represents a request to validate a token.\n162: type TokenValidateRequest struct {\n163: \t// Token is the token to validate.\n164: \tToken string `json:\"token\"`\n165: }\n166: \n167: // TokenValidateResponse represents the response from token validation.\n168: type TokenValidateResponse struct {\n169: \t// Valid indicates if the token is valid.\n170: \tValid bool `json:\"valid\"`\n171: \n172: \t// Claims contains the parsed claims if valid.\n173: \tClaims *TokenClaims `json:\"claims,omitempty\"`\n174: \n175: \t// Error contains the error message if invalid.\n176: \tError string `json:\"error,omitempty\"`\n177: \n178: \t// ErrorCode contains the error code if invalid.\n179: \tErrorCode string `json:\"error_code,omitempty\"`\n180: }\n181: \n182: // KeyVersionInfo contains information about a key version.\n183: type KeyVersionInfo struct {\n184: \t// Version is the key version identifier.\n185: \tVersion string `json:\"version\"`\n186: \n187: \t// CreatedAt is when the key was created.\n188: \tCreatedAt time.Time `json:\"created_at\"`\n189: \n190: \t// Active indicates if this key version is active.\n191: \tActive bool `json:\"active\"`\n192: }\n193: \n194: // JWTMetrics provides metrics collection for JWT operations.\n195: // This interface allows tracking token generation and validation metrics.\n196: type JWTMetrics struct {\n197: \t// tokenGenerationCount tracks the number of tokens generated\n198: \ttokenGenerationCount int\n199: \n200: \t// tokenValidationCount tracks the number of token validations\n201: \ttokenValidationCount int\n202: \n203: \t// tokenValidationFailures tracks the number of validation failures\n204: \ttokenValidationFailures int\n205: }\n206: \n207: // NewJWTMetrics creates a new JWTMetrics instance.\n208: func NewJWTMetrics() *JWTMetrics {\n209: \treturn &JWTMetrics{}\n210: }\n211: \n212: // RecordTokenGeneration records metrics for token generation.\n213: func (m *JWTMetrics) RecordTokenGeneration(operation string, err error) {\n214: \tm.tokenGenerationCount++\n215: }\n216: \n217: // RecordTokenValidation records metrics for token validation.\n218: func (m *JWTMetrics) RecordTokenValidation(operation string, err error) {\n219: \tm.tokenValidationCount++\n220: \tif err != nil {\n221: \t\tm.tokenValidationFailures++\n222: \t}\n223: }\n224: \n225: // GetTokenGenerationCount returns the total number of token generations.\n226: func (m *JWTMetrics) GetTokenGenerationCount() int {\n227: \treturn m.tokenGenerationCount\n228: }\n229: \n230: // GetTokenValidationCount returns the total number of token validations.\n231: func (m *JWTMetrics) GetTokenValidationCount() int {\n232: \treturn m.tokenValidationCount\n233: }\n234: \n235: // GetTokenValidationFailures returns the number of validation failures.\n236: func (m *JWTMetrics) GetTokenValidationFailures() int {\n237: \treturn m.tokenValidationFailures\n238: }\n239: \n240: // TokenManager defines the interface for JWT token operations.\n241: // Implementations provide token generation, validation, and refresh capabilities.\n242: type TokenManager interface {\n243: \t// GenerateToken creates a JWT with the given claims.\n244: \tGenerateToken(claims map[string]interface{}) (string, error)\n245: \n246: \t// GenerateTokenPair creates both access and refresh tokens.\n247: \tGenerateTokenPair(claims map[string]interface{}) (*TokenPair, *TokenMetadata, error)\n248: \n249: \t// ValidateToken validates a JWT and returns the claims.\n250: \tValidateToken(token string) (*TokenClaims, error)\n251: \n252: \t// RefreshToken generates a new token pair using a refresh token.\n253: \tRefreshToken(refreshToken string) (*TokenPair, *TokenMetadata, error)\n254: \n255: \t// GetPublicKeyPEM returns the public key in PEM format.\n256: \tGetPublicKeyPEM() ([]byte, error)\n257: \n258: \t// Initialize initializes the token manager with context.\n259: \tInitialize(ctx context.Context) error\n260: }\n261: \n262: // contextKey is a type for context keys to avoid collisions.\n263: type contextKey string\n264: \n265: // TokenClaimsContextKey is the key for storing TokenClaims in context.\n266: const TokenClaimsContextKey contextKey = \"token-claims\"\n\n(End of file - total 266 lines)\n</content>","metadata":{"preview":"/*\nCopyright 2026 The Volcano Authors.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\npackage router\n\nimport (\n\t\"context\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/router/jwt_types.go","time":{"start":1775877782167,"end":1775877782190}}}}
{"type":"tool_use","timestamp":1775877782194,"sessionID":"ses_285700e6cffe1o1w0ORJi5ZG82","part":{"id":"prt_d7a9070ec001pkci7RTWhmSpdy","messageID":"msg_d7a904be2001FSi606Tx1vhYJW","sessionID":"ses_285700e6cffe1o1w0ORJi5ZG82","type":"tool","tool":"read","callID":"toolu_functions.read:8","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/router/jwt_config.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/router/jwt_config.go</path>\n<type>file</type>\n<content>\n1: /*\n2: Copyright 2026 The Volcano Authors.\n3: \n4: Licensed under the Apache License, Version 2.0 (the \"License\");\n5: you may not use this file except in compliance with the License.\n6: You may obtain a copy of the License at\n7: \n8:     http://www.apache.org/licenses/LICENSE-2.0\n9: \n10: Unless required by applicable law or agreed to in writing, software\n11: distributed under the License is distributed on an \"AS IS\" BASIS,\n12: WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n13: See the License for the specific language governing permissions and\n14: limitations under the License.\n15: */\n16: \n17: package router\n18: \n19: import (\n20: \t\"fmt\"\n21: \t\"os\"\n22: \t\"strconv\"\n23: \t\"time\"\n24: )\n25: \n26: // JWTConfig holds JWT configuration options.\n27: type JWTConfig struct {\n28: \t// AccessTokenExpiry is the access token expiration duration.\n29: \tAccessTokenExpiry time.Duration\n30: \n31: \t// RefreshTokenExpiry is the refresh token expiration duration.\n32: \tRefreshTokenExpiry time.Duration\n33: \n34: \t// RSAKeySize is the RSA key size in bits (minimum 2048).\n35: \tRSAKeySize int\n36: \n37: \t// Issuer is the JWT token issuer identifier.\n38: \tIssuer string\n39: \n40: \t// SecretName is the Kubernetes secret name for key storage.\n41: \tSecretName string\n42: \n43: \t// SecretNamespace is the Kubernetes namespace for the secret.\n44: \tSecretNamespace string\n45: }\n46: \n47: // DefaultJWTConfig returns a JWTConfig with sensible defaults.\n48: func DefaultJWTConfig() *JWTConfig {\n49: \tconfig := &JWTConfig{\n50: \t\tAccessTokenExpiry:  DefaultTokenExpiry,\n51: \t\tRefreshTokenExpiry: DefaultRefreshTokenExpiry,\n52: \t\tRSAKeySize:         DefaultRSAKeySize,\n53: \t\tIssuer:             TokenIssuer,\n54: \t\tSecretName:         identitySecretName,\n55: \t\tSecretNamespace:    IdentityNamespace,\n56: \t}\n57: \n58: \t// Override with environment variables if set\n59: \tif expiry := os.Getenv(\"AGENTCUBE_JWT_ACCESS_EXPIRY\"); expiry != \"\" {\n60: \t\tif d, err := time.ParseDuration(expiry); err == nil && d > 0 {\n61: \t\t\tconfig.AccessTokenExpiry = d\n62: \t\t}\n63: \t}\n64: \n65: \tif expiry := os.Getenv(\"AGENTCUBE_JWT_REFRESH_EXPIRY\"); expiry != \"\" {\n66: \t\tif d, err := time.ParseDuration(expiry); err == nil && d > 0 {\n67: \t\t\tconfig.RefreshTokenExpiry = d\n68: \t\t}\n69: \t}\n70: \n71: \tif secretName := os.Getenv(\"AGENTCUBE_JWT_SECRET_NAME\"); secretName != \"\" {\n72: \t\tconfig.SecretName = secretName\n73: \t}\n74: \n75: \tif keySize := os.Getenv(\"AGENTCUBE_JWT_RSA_KEY_SIZE\"); keySize != \"\" {\n76: \t\tif size, err := strconv.Atoi(keySize); err == nil && size >= 2048 {\n77: \t\t\tconfig.RSAKeySize = size\n78: \t\t}\n79: \t}\n80: \n81: \treturn config\n82: }\n83: \n84: // NewJWTConfig creates a new JWTConfig with the given options.\n85: func NewJWTConfig(accessExpiry, refreshExpiry time.Duration, rsaKeySize int) *JWTConfig {\n86: \treturn &JWTConfig{\n87: \t\tAccessTokenExpiry:  accessExpiry,\n88: \t\tRefreshTokenExpiry: refreshExpiry,\n89: \t\tRSAKeySize:         rsaKeySize,\n90: \t\tIssuer:             TokenIssuer,\n91: \t\tSecretName:         identitySecretName,\n92: \t\tSecretNamespace:    IdentityNamespace,\n93: \t}\n94: }\n95: \n96: // Validate validates the JWT configuration.\n97: func (c *JWTConfig) Validate() error {\n98: \tif c.AccessTokenExpiry <= 0 {\n99: \t\treturn fmt.Errorf(\"access token expiry must be greater than 0\")\n100: \t}\n101: \n102: \tif c.RefreshTokenExpiry <= c.AccessTokenExpiry {\n103: \t\treturn fmt.Errorf(\"refresh token expiry must be greater than access token expiry\")\n104: \t}\n105: \n106: \tif c.RSAKeySize < 2048 {\n107: \t\treturn fmt.Errorf(\"RSA key size must be at least 2048 bits\")\n108: \t}\n109: \n110: \tif c.Issuer == \"\" {\n111: \t\treturn fmt.Errorf(\"issuer cannot be empty\")\n112: \t}\n113: \n114: \treturn nil\n115: }\n116: \n117: // WithAccessTokenExpiry returns a new config with the given access token expiry.\n118: func (c *JWTConfig) WithAccessTokenExpiry(expiry time.Duration) *JWTConfig {\n119: \tnewConfig := *c\n120: \tnewConfig.AccessTokenExpiry = expiry\n121: \treturn &newConfig\n122: }\n123: \n124: // WithRefreshTokenExpiry returns a new config with the given refresh token expiry.\n125: func (c *JWTConfig) WithRefreshTokenExpiry(expiry time.Duration) *JWTConfig {\n126: \tnewConfig := *c\n127: \tnewConfig.RefreshTokenExpiry = expiry\n128: \treturn &newConfig\n129: }\n130: \n131: // WithRSAKeySize returns a new config with the given RSA key size.\n132: func (c *JWTConfig) WithRSAKeySize(size int) *JWTConfig {\n133: \tnewConfig := *c\n134: \tnewConfig.RSAKeySize = size\n135: \treturn &newConfig\n136: }\n137: \n138: // WithIssuer returns a new config with the given issuer.\n139: func (c *JWTConfig) WithIssuer(issuer string) *JWTConfig {\n140: \tnewConfig := *c\n141: \tnewConfig.Issuer = issuer\n142: \treturn &newConfig\n143: }\n\n(End of file - total 143 lines)\n</content>","metadata":{"preview":"/*\nCopyright 2026 The Volcano Authors.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\npackage router\n\nimport (\n\t\"fmt\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/router/jwt_config.go","time":{"start":1775877782170,"end":1775877782192}}}}
