{"type":"tool_use","timestamp":1775892708117,"sessionID":"ses_2848c4100ffe5LtG4M55bByBGV","part":{"id":"prt_d7b743113001oOvnXCbUUNOw8s","messageID":"msg_d7b741afa001YiI6GNk90JjBHD","sessionID":"ses_2848c4100ffe5LtG4M55bByBGV","type":"tool","tool":"read","callID":"toolu_functions.read:7","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/agentcube/services/k8s_provider.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/agentcube/services/k8s_provider.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Kubernetes provider for deploying standard K8s resources.\n2: \n3: This module provides the KubernetesProvider class for deploying agents\n4: as standard Kubernetes Deployment and Service resources.\n5: \"\"\"\n6: \n7: import logging\n8: import time\n9: from typing import Any, Dict, Optional\n10: \n11: from agentcube.utils.log import get_logger\n12: \n13: \n14: class KubernetesProvider:\n15:     \"\"\"Provider for standard Kubernetes Deployment and Service deployment.\"\"\"\n16: \n17:     def __init__(self, namespace: str = \"default\", verbose: bool = False) -> None:\n18:         \"\"\"Initialize KubernetesProvider.\n19: \n20:         Args:\n21:             namespace: The Kubernetes namespace for deployment.\n22:             verbose: Whether to enable verbose logging.\n23:         \"\"\"\n24:         self.namespace = namespace\n25:         self.verbose = verbose\n26:         self.logger = get_logger(__name__, logging.DEBUG if verbose else logging.INFO)\n27:         self._k8s_client = None\n28:         self._apps_v1 = None\n29:         self._core_v1 = None\n30: \n31:     def _get_k8s_client(self) -> Any:\n32:         \"\"\"Get or create Kubernetes client.\n33: \n34:         Returns:\n35:             Kubernetes client instance.\n36: \n37:         Raises:\n38:             RuntimeError: If Kubernetes client cannot be initialized.\n39:         \"\"\"\n40:         if self._k8s_client is None:\n41:             try:\n42:                 from kubernetes import client, config\n43: \n44:                 # Try to load kubeconfig\n45:                 try:\n46:                     config.load_kube_config()\n47:                     self.logger.debug(\"Loaded kubeconfig\")\n48:                 except Exception:\n49:                     # Try in-cluster config\n50:                     try:\n51:                         config.load_incluster_config()\n52:                         self.logger.debug(\"Loaded in-cluster config\")\n53:                     except Exception as e:\n54:                         raise RuntimeError(\n55:                             \"Failed to load Kubernetes configuration. \"\n56:                             \"Ensure kubeconfig is available or running in-cluster.\"\n57:                         ) from e\n58: \n59:                 self._k8s_client = client\n60:                 self._apps_v1 = client.AppsV1Api()\n61:                 self._core_v1 = client.CoreV1Api()\n62: \n63:             except ImportError as e:\n64:                 raise RuntimeError(\n65:                     \"Kubernetes client library not installed. Install with: pip install kubernetes\"\n66:                 ) from e\n67:             except Exception as e:\n68:                 raise RuntimeError(f\"Failed to initialize Kubernetes client: {e}\") from e\n69: \n70:         return self._k8s_client\n71: \n72:     def _ensure_namespace(self) -> None:\n73:         \"\"\"Ensure the target namespace exists.\n74: \n75:         Creates the namespace if it doesn't exist.\n76:         \"\"\"\n77:         client = self._get_k8s_client()\n78: \n79:         try:\n80:             self._core_v1.read_namespace(self.namespace)\n81:             self.logger.debug(f\"Namespace {self.namespace} exists\")\n82:         except client.exceptions.NotFoundException:\n83:             self.logger.info(f\"Creating namespace: {self.namespace}\")\n84:             namespace_body = client.V1Namespace(metadata=client.V1ObjectMeta(name=self.namespace))\n85:             self._core_v1.create_namespace(namespace_body)\n86:             self.logger.info(f\"Created namespace: {self.namespace}\")\n87: \n88:     def deploy_agent(\n89:         self,\n90:         agent_name: str,\n91:         image_url: str,\n92:         port: int,\n93:         entrypoint: Optional[str] = None,\n94:         replicas: int = 1,\n95:         node_port: Optional[int] = None,\n96:         env_vars: Optional[Dict[str, str]] = None,\n97:     ) -> Dict[str, Any]:\n98:         \"\"\"Deploy an agent as Kubernetes Deployment and NodePort Service.\n99: \n100:         Args:\n101:             agent_name: Name of the agent.\n102:             image_url: Full URL of the container image.\n103:             port: Port exposed by the agent.\n104:             entrypoint: Optional entrypoint command.\n105:             replicas: Number of replicas (default: 1).\n106:             node_port: Optional NodePort (30000-32767). Auto-assigned if not specified.\n107:             env_vars: Optional environment variables.\n108: \n109:         Returns:\n110:             Dict containing deployment results with keys:\n111:             - deployment_name: Name of the created Deployment\n112:             - service_name: Name of the created Service\n113:             - namespace: Deployment namespace\n114:             - node_port: Assigned NodePort\n115:             - replicas: Number of replicas\n116:             - service_url: Service access URL\n117: \n118:         Raises:\n119:             RuntimeError: If deployment fails.\n120:             ValueError: If node_port is outside valid range.\n121:         \"\"\"\n122:         # Validate node_port if provided\n123:         if node_port is not None:\n124:             if not 30000 <= node_port <= 32767:\n125:                 raise ValueError(f\"NodePort must be in range 30000-32767, got {node_port}\")\n126: \n127:         client = self._get_k8s_client()\n128: \n129:         # Ensure namespace exists\n130:         self._ensure_namespace()\n131: \n132:         self.logger.info(f\"Deploying agent to Kubernetes: {agent_name}\")\n133: \n134:         # Create or update Deployment\n135:         deployment_result = self._create_or_update_deployment(\n136:             agent_name=agent_name,\n137:             image_url=image_url,\n138:             port=port,\n139:             entrypoint=entrypoint,\n140:             replicas=replicas,\n141:             env_vars=env_vars,\n142:         )\n143: \n144:         # Create or update Service\n145:         service_result = self._create_or_update_service(\n146:             agent_name=agent_name,\n147:             port=port,\n148:             node_port=node_port,\n149:         )\n150: \n151:         # Build service URL\n152:         node_port_assigned = service_result.get(\"node_port\")\n153:         service_url = f\"http://localhost:{node_port_assigned}\"\n154: \n155:         return {\n156:             \"deployment_name\": deployment_result[\"name\"],\n157:             \"service_name\": service_result[\"name\"],\n158:             \"namespace\": self.namespace,\n159:             \"node_port\": node_port_assigned,\n160:             \"replicas\": replicas,\n161:             \"service_url\": service_url,\n162:             \"status\": \"deployed\",\n163:         }\n164: \n165:     def _create_or_update_deployment(\n166:         self,\n167:         agent_name: str,\n168:         image_url: str,\n169:         port: int,\n170:         entrypoint: Optional[str] = None,\n171:         replicas: int = 1,\n172:         env_vars: Optional[Dict[str, str]] = None,\n173:     ) -> Dict[str, Any]:\n174:         \"\"\"Create or update a Kubernetes Deployment.\n175: \n176:         Args:\n177:             agent_name: Name of the agent.\n178:             image_url: Full URL of the container image.\n179:             port: Port exposed by the agent.\n180:             entrypoint: Optional entrypoint command.\n181:             replicas: Number of replicas.\n182:             env_vars: Optional environment variables.\n183: \n184:         Returns:\n185:             Dict containing deployment information.\n186:         \"\"\"\n187:         client = self._get_k8s_client()\n188: \n189:         # Build container spec\n190:         container = client.V1Container(\n191:             name=agent_name,\n192:             image=image_url,\n193:             ports=[client.V1ContainerPort(container_port=port)],\n194:             env=[client.V1EnvVar(name=k, value=v) for k, v in (env_vars or {}).items()]\n195:             if env_vars\n196:             else None,\n197:         )\n198: \n199:         # Add command/args if entrypoint provided\n200:         if entrypoint:\n201:             parts = entrypoint.split()\n202:             if parts:\n203:                 container.command = [parts[0]]\n204:                 if len(parts) > 1:\n205:                     container.args = parts[1:]\n206: \n207:         # Build pod template\n208:         template = client.V1PodTemplateSpec(\n209:             metadata=client.V1ObjectMeta(\n210:                 labels={\"app\": agent_name},\n211:             ),\n212:             spec=client.V1PodSpec(\n213:                 containers=[container],\n214:             ),\n215:         )\n216: \n217:         # Build deployment spec\n218:         deployment_spec = client.V1DeploymentSpec(\n219:             replicas=replicas,\n220:             selector={\"matchLabels\": {\"app\": agent_name}},\n221:             template=template,\n222:         )\n223: \n224:         # Build deployment\n225:         deployment = client.V1Deployment(\n226:             api_version=\"apps/v1\",\n227:             kind=\"Deployment\",\n228:             metadata=client.V1ObjectMeta(\n229:                 name=agent_name,\n230:                 namespace=self.namespace,\n231:                 labels={\"app\": agent_name},\n232:             ),\n233:             spec=deployment_spec,\n234:         )\n235: \n236:         try:\n237:             # Try to get existing deployment\n238:             existing = self._apps_v1.read_namespaced_deployment(\n239:                 name=agent_name,\n240:                 namespace=self.namespace,\n241:             )\n242: \n243:             if existing:\n244:                 # Update existing deployment\n245:                 self.logger.info(f\"Updating existing Deployment: {agent_name}\")\n246:                 result = self._apps_v1.replace_namespaced_deployment(\n247:                     name=agent_name,\n248:                     namespace=self.namespace,\n249:                     body=deployment,\n250:                 )\n251:                 self.logger.info(f\"Updated Deployment: {agent_name}\")\n252: \n253:         except client.exceptions.NotFoundException:\n254:             # Create new deployment\n255:             self.logger.info(f\"Creating new Deployment: {agent_name}\")\n256:             result = self._apps_v1.create_namespaced_deployment(\n257:                 namespace=self.namespace,\n258:                 body=deployment,\n259:             )\n260:             self.logger.info(f\"Created Deployment: {agent_name}\")\n261: \n262:         return {\"name\": agent_name, \"namespace\": self.namespace}\n263: \n264:     def _create_or_update_service(\n265:         self,\n266:         agent_name: str,\n267:         port: int,\n268:         node_port: Optional[int] = None,\n269:     ) -> Dict[str, Any]:\n270:         \"\"\"Create or update a Kubernetes NodePort Service.\n271: \n272:         Args:\n273:             agent_name: Name of the agent (used for service name).\n274:             port: Target port on the pod.\n275:             node_port: Optional NodePort (30000-32767).\n276: \n277:         Returns:\n278:             Dict containing service information including assigned node_port.\n279:         \"\"\"\n280:         client = self._get_k8s_client()\n281: \n282:         # Build service ports\n283:         service_port = client.V1ServicePort(\n284:             port=port,\n285:             target_port=port,\n286:             node_port=node_port,\n287:         )\n288: \n289:         # Build service spec\n290:         service_spec = client.V1ServiceSpec(\n291:             type=\"NodePort\",\n292:             selector={\"app\": agent_name},\n293:             ports=[service_port],\n294:         )\n295: \n296:         # Build service\n297:         service = client.V1Service(\n298:             api_version=\"v1\",\n299:             kind=\"Service\",\n300:             metadata=client.V1ObjectMeta(\n301:                 name=agent_name,\n302:                 namespace=self.namespace,\n303:                 labels={\"app\": agent_name},\n304:             ),\n305:             spec=service_spec,\n306:         )\n307: \n308:         try:\n309:             # Try to get existing service\n310:             existing = self._core_v1.read_namespaced_service(\n311:                 name=agent_name,\n312:                 namespace=self.namespace,\n313:             )\n314: \n315:             if existing:\n316:                 # Update existing service\n317:                 self.logger.info(f\"Updating existing Service: {agent_name}\")\n318:                 result = self._core_v1.replace_namespaced_service(\n319:                     name=agent_name,\n320:                     namespace=self.namespace,\n321:                     body=service,\n322:                 )\n323:                 self.logger.info(f\"Updated Service: {agent_name}\")\n324: \n325:         except client.exceptions.NotFoundException:\n326:             # Create new service\n327:             self.logger.info(f\"Creating new Service: {agent_name}\")\n328:             result = self._core_v1.create_namespaced_service(\n329:                 namespace=self.namespace,\n330:                 body=service,\n331:             )\n332:             self.logger.info(f\"Created Service: {agent_name}\")\n333: \n334:         # Get the assigned node port\n335:         assigned_node_port = None\n336:         if result and result.spec and result.spec.ports:\n337:             assigned_node_port = result.spec.ports[0].node_port\n338: \n339:         return {\n340:             \"name\": agent_name,\n341:             \"namespace\": self.namespace,\n342:             \"node_port\": assigned_node_port,\n343:         }\n344: \n345:     def wait_for_deployment_ready(\n346:         self,\n347:         name: str,\n348:         timeout: int = 120,\n349:         interval: int = 5,\n350:     ) -> Dict[str, Any]:\n351:         \"\"\"Wait for a Deployment to be ready.\n352: \n353:         Args:\n354:             name: Name of the deployment.\n355:             timeout: Maximum time to wait in seconds (default: 120).\n356:             interval: Check interval in seconds (default: 5).\n357: \n358:         Returns:\n359:             Dict containing deployment status.\n360: \n361:         Raises:\n362:             TimeoutError: If deployment is not ready within timeout.\n363:             RuntimeError: If deployment fails.\n364:         \"\"\"\n365:         client = self._get_k8s_client()\n366: \n367:         self.logger.info(f\"Waiting for Deployment {name} to be ready (timeout: {timeout}s)\")\n368: \n369:         start_time = time.time()\n370:         while time.time() - start_time < timeout:\n371:             try:\n372:                 deployment = self._apps_v1.read_namespaced_deployment(\n373:                     name=name,\n374:                     namespace=self.namespace,\n375:                 )\n376: \n377:                 if deployment.status:\n378:                     ready_replicas = deployment.status.ready_replicas or 0\n379:                     desired_replicas = deployment.spec.replicas or 1\n380: \n381:                     self.logger.debug(\n382:                         f\"Deployment {name}: {ready_replicas}/{desired_replicas} ready\"\n383:                     )\n384: \n385:                     if ready_replicas >= desired_replicas:\n386:                         self.logger.info(f\"Deployment {name} is ready\")\n387:                         return {\n388:                             \"name\": name,\n389:                             \"namespace\": self.namespace,\n390:                             \"ready_replicas\": ready_replicas,\n391:                             \"desired_replicas\": desired_replicas,\n392:                             \"status\": \"ready\",\n393:                         }\n394: \n395:                     # Check for failures\n396:                     if (\n397:                         deployment.status.unavailable_replicas\n398:                         and deployment.status.unavailable_replicas > 0\n399:                     ):\n400:                         # Check if there are any failed conditions\n401:                         conditions = deployment.status.conditions or []\n402:                         for condition in conditions:\n403:                             if condition.type == \"Progressing\" and condition.status == \"False\":\n404:                                 raise RuntimeError(f\"Deployment {name} failed: {condition.message}\")\n405: \n406:             except client.exceptions.NotFoundException:\n407:                 self.logger.debug(f\"Deployment {name} not yet created\")\n408: \n409:             except Exception as e:\n410:                 self.logger.warning(f\"Error checking deployment status: {e}\")\n411: \n412:             time.sleep(interval)\n413: \n414:         # Timeout reached\n415:         raise TimeoutError(f\"Deployment {name} did not become ready within {timeout} seconds\")\n416: \n417:     def get_agent_status(self, name: str) -> Dict[str, Any]:\n418:         \"\"\"Get the status of a deployed agent.\n419: \n420:         Args:\n421:             name: Name of the agent (deployment name).\n422: \n423:         Returns:\n424:             Dict containing the agent status.\n425: \n426:         Raises:\n427:             RuntimeError: If status retrieval fails.\n428:         \"\"\"\n429:         client = self._get_k8s_client()\n430: \n431:         try:\n432:             deployment = self._apps_v1.read_namespaced_deployment(\n433:                 name=name,\n434:                 namespace=self.namespace,\n435:             )\n436: \n437:             service = None\n438:             try:\n439:                 service = self._core_v1.read_namespaced_service(\n440:                     name=name,\n441:                     namespace=self.namespace,\n442:                 )\n443:             except client.exceptions.NotFoundException:\n444:                 pass\n445: \n446:             return {\n447:                 \"name\": name,\n448:                 \"namespace\": self.namespace,\n449:                 \"deployment\": {\n450:                     \"replicas\": deployment.spec.replicas if deployment.spec else 0,\n451:                     \"ready_replicas\": deployment.status.ready_replicas if deployment.status else 0,\n452:                     \"available_replicas\": deployment.status.available_replicas\n453:                     if deployment.status\n454:                     else 0,\n455:                 },\n456:                 \"service\": {\n457:                     \"cluster_ip\": service.spec.cluster_ip if service and service.spec else None,\n458:                     \"node_port\": service.spec.ports[0].node_port\n459:                     if service and service.spec and service.spec.ports\n460:                     else None,\n461:                 }\n462:                 if service\n463:                 else None,\n464:             }\n465: \n466:         except client.exceptions.NotFoundException:\n467:             return {\n468:                 \"name\": name,\n469:                 \"namespace\": self.namespace,\n470:                 \"status\": \"not_found\",\n471:             }\n472: \n473:         except Exception as e:\n474:             self.logger.error(f\"Failed to get agent status: {e}\")\n475:             raise RuntimeError(f\"Failed to get agent status: {e}\") from e\n476: \n477:     def delete_agent(self, name: str) -> Dict[str, Any]:\n478:         \"\"\"Delete a deployed agent (Deployment and Service).\n479: \n480:         Args:\n481:             name: Name of the agent to delete.\n482: \n483:         Returns:\n484:             Dict containing deletion result.\n485: \n486:         Raises:\n487:             RuntimeError: If deletion fails.\n488:         \"\"\"\n489:         client = self._get_k8s_client()\n490: \n491:         result = {\n492:             \"name\": name,\n493:             \"namespace\": self.namespace,\n494:             \"deployment_deleted\": False,\n495:             \"service_deleted\": False,\n496:         }\n497: \n498:         # Delete Deployment\n499:         try:\n500:             self._apps_v1.delete_namespaced_deployment(\n501:                 name=name,\n502:                 namespace=self.namespace,\n503:             )\n504:             self.logger.info(f\"Deleted Deployment: {name}\")\n505:             result[\"deployment_deleted\"] = True\n506:         except client.exceptions.NotFoundException:\n507:             self.logger.warning(f\"Deployment not found: {name}\")\n508:         except Exception as e:\n509:             self.logger.error(f\"Failed to delete Deployment: {e}\")\n510:             raise RuntimeError(f\"Failed to delete Deployment: {e}\") from e\n511: \n512:         # Delete Service\n513:         try:\n514:             self._core_v1.delete_namespaced_service(\n515:                 name=name,\n516:                 namespace=self.namespace,\n517:             )\n518:             self.logger.info(f\"Deleted Service: {name}\")\n519:             result[\"service_deleted\"] = True\n520:         except client.exceptions.NotFoundException:\n521:             self.logger.warning(f\"Service not found: {name}\")\n522:         except Exception as e:\n523:             self.logger.error(f\"Failed to delete Service: {e}\")\n524:             raise RuntimeError(f\"Failed to delete Service: {e}\") from e\n525: \n526:         return result\n\n(End of file - total 526 lines)\n</content>","metadata":{"preview":"\"\"\"Kubernetes provider for deploying standard K8s resources.\n\nThis module provides the KubernetesProvider class for deploying agents\nas standard Kubernetes Deployment and Service resources.\n\"\"\"\n\nimport logging\nimport time\nfrom typing import Any, Dict, Optional\n\nfrom agentcube.utils.log import get_logger\n\n\nclass KubernetesProvider:\n    \"\"\"Provider for standard Kubernetes Deployment and Service deployment.\"\"\"\n\n    def __init__(self, namespace: str = \"default\", verbose: bool = False) -> None:\n        \"\"\"Initialize KubernetesProvider.\n\n        Args:","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/agentcube/services/k8s_provider.py","time":{"start":1775892708083,"end":1775892708114}}}}
