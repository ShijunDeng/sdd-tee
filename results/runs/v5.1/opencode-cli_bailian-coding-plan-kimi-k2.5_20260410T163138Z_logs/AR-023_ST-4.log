{"type":"tool_use","timestamp":1775892699833,"sessionID":"ses_2848c4100ffe5LtG4M55bByBGV","part":{"id":"prt_d7b741608001crc0T2N4QDtOf7","messageID":"msg_d7b73f383001KPaIq402jDBh3x","sessionID":"ses_2848c4100ffe5LtG4M55bByBGV","type":"tool","tool":"read","callID":"toolu_functions.read:6","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/agentcube/services/agentcube_provider.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/agentcube/services/agentcube_provider.py</path>\n<type>file</type>\n<content>\n1: \"\"\"AgentCube provider for deploying AgentRuntime Custom Resources.\n2: \n3: This module provides the AgentCubeProvider class for deploying agents\n4: as AgentRuntime Custom Resources in Kubernetes.\n5: \"\"\"\n6: \n7: import logging\n8: import time\n9: from pathlib import Path\n10: from typing import Any, Dict, Optional\n11: \n12: from agentcube.utils.log import get_logger\n13: \n14: \n15: class AgentCubeProvider:\n16:     \"\"\"Provider for AgentCube-specific AgentRuntime CR deployment.\"\"\"\n17: \n18:     def __init__(self, namespace: str = \"default\", verbose: bool = False) -> None:\n19:         \"\"\"Initialize AgentCubeProvider.\n20: \n21:         Args:\n22:             namespace: The Kubernetes namespace for deployment.\n23:             verbose: Whether to enable verbose logging.\n24:         \"\"\"\n25:         self.namespace = namespace\n26:         self.verbose = verbose\n27:         self.logger = get_logger(__name__, logging.DEBUG if verbose else logging.INFO)\n28:         self._k8s_client = None\n29: \n30:     def _get_k8s_client(self) -> Any:\n31:         \"\"\"Get or create Kubernetes client.\n32: \n33:         Returns:\n34:             Kubernetes client instance.\n35: \n36:         Raises:\n37:             RuntimeError: If Kubernetes client cannot be initialized.\n38:         \"\"\"\n39:         if self._k8s_client is None:\n40:             try:\n41:                 from kubernetes import client, config\n42: \n43:                 # Try to load kubeconfig\n44:                 try:\n45:                     config.load_kube_config()\n46:                     self.logger.debug(\"Loaded kubeconfig\")\n47:                 except Exception:\n48:                     # Try in-cluster config\n49:                     try:\n50:                         config.load_incluster_config()\n51:                         self.logger.debug(\"Loaded in-cluster config\")\n52:                     except Exception as e:\n53:                         raise RuntimeError(\n54:                             \"Failed to load Kubernetes configuration. \"\n55:                             \"Ensure kubeconfig is available or running in-cluster.\"\n56:                         ) from e\n57: \n58:                 self._k8s_client = client\n59:             except ImportError as e:\n60:                 raise RuntimeError(\n61:                     \"Kubernetes client library not installed. Install with: pip install kubernetes\"\n62:                 ) from e\n63:             except Exception as e:\n64:                 raise RuntimeError(f\"Failed to initialize Kubernetes client: {e}\") from e\n65: \n66:         return self._k8s_client\n67: \n68:     def _ensure_namespace(self) -> None:\n69:         \"\"\"Ensure the target namespace exists.\n70: \n71:         Creates the namespace if it doesn't exist.\n72:         \"\"\"\n73:         client = self._get_k8s_client()\n74:         core_v1 = client.CoreV1Api()\n75: \n76:         try:\n77:             core_v1.read_namespace(self.namespace)\n78:             self.logger.debug(f\"Namespace {self.namespace} exists\")\n79:         except client.exceptions.NotFoundException:\n80:             self.logger.info(f\"Creating namespace: {self.namespace}\")\n81:             namespace_body = client.V1Namespace(metadata=client.V1ObjectMeta(name=self.namespace))\n82:             core_v1.create_namespace(namespace_body)\n83:             self.logger.info(f\"Created namespace: {self.namespace}\")\n84: \n85:     def deploy_agent_runtime(\n86:         self,\n87:         agent_name: str,\n88:         image_url: str,\n89:         port: int,\n90:         entrypoint: Optional[str] = None,\n91:         env_vars: Optional[Dict[str, str]] = None,\n92:         workload_manager_url: Optional[str] = None,\n93:         router_url: Optional[str] = None,\n94:         readiness_probe_path: Optional[str] = None,\n95:         readiness_probe_port: Optional[int] = None,\n96:         session_timeout: str = \"15m\",\n97:         max_session_duration: str = \"8h\",\n98:         image_pull_secrets: Optional[list] = None,\n99:     ) -> Dict[str, Any]:\n100:         \"\"\"Deploy an AgentRuntime Custom Resource to Kubernetes.\n101: \n102:         Args:\n103:             agent_name: Name of the agent.\n104:             image_url: Full URL of the container image.\n105:             port: Port exposed by the agent.\n106:             entrypoint: Optional entrypoint command.\n107:             env_vars: Optional environment variables.\n108:             workload_manager_url: URL for the Workload Manager.\n109:             router_url: URL for the Router.\n110:             readiness_probe_path: Path for readiness probe.\n111:             readiness_probe_port: Port for readiness probe.\n112:             session_timeout: Session timeout duration (default: \"15m\").\n113:             max_session_duration: Maximum session duration (default: \"8h\").\n114:             image_pull_secrets: List of image pull secrets.\n115: \n116:         Returns:\n117:             Dict containing deployment results with keys:\n118:             - agent_id: The deployed agent identifier\n119:             - agent_endpoint: The agent endpoint URL\n120:             - name: The AgentRuntime CR name\n121:             - namespace: The deployment namespace\n122:             - status: Deployment status\n123: \n124:         Raises:\n125:             RuntimeError: If deployment fails.\n126:             ValueError: If required parameters are missing.\n127:         \"\"\"\n128:         if not workload_manager_url or not router_url:\n129:             raise ValueError(\n130:                 \"AgentCube provider requires router_url and workload_manager_url. \"\n131:                 \"Please set these in agent_metadata.yaml or provide via options.\"\n132:             )\n133: \n134:         client = self._get_k8s_client()\n135: \n136:         # Ensure namespace exists\n137:         self._ensure_namespace()\n138: \n139:         self.logger.info(f\"Deploying AgentRuntime CR: {agent_name}\")\n140: \n141:         # Build the AgentRuntime CR spec\n142:         cr_spec = self._build_agent_runtime_spec(\n143:             agent_name=agent_name,\n144:             image_url=image_url,\n145:             port=port,\n146:             entrypoint=entrypoint,\n147:             env_vars=env_vars,\n148:             workload_manager_url=workload_manager_url,\n149:             router_url=router_url,\n150:             readiness_probe_path=readiness_probe_path,\n151:             readiness_probe_port=readiness_probe_port,\n152:             session_timeout=session_timeout,\n153:             max_session_duration=max_session_duration,\n154:             image_pull_secrets=image_pull_secrets,\n155:         )\n156: \n157:         # Apply the CR to the cluster\n158:         result = self._apply_agent_runtime_cr(agent_name, cr_spec)\n159: \n160:         # Build endpoint URL from router_url\n161:         agent_endpoint = f\"{router_url}/v1/agents/{agent_name}\"\n162: \n163:         return {\n164:             \"agent_id\": agent_name,\n165:             \"agent_endpoint\": agent_endpoint,\n166:             \"name\": agent_name,\n167:             \"namespace\": self.namespace,\n168:             \"status\": \"deployed\",\n169:             \"workload_manager_url\": workload_manager_url,\n170:             \"router_url\": router_url,\n171:         }\n172: \n173:     def _build_agent_runtime_spec(\n174:         self,\n175:         agent_name: str,\n176:         image_url: str,\n177:         port: int,\n178:         entrypoint: Optional[str] = None,\n179:         env_vars: Optional[Dict[str, str]] = None,\n180:         workload_manager_url: Optional[str] = None,\n181:         router_url: Optional[str] = None,\n182:         readiness_probe_path: Optional[str] = None,\n183:         readiness_probe_port: Optional[int] = None,\n184:         session_timeout: str = \"15m\",\n185:         max_session_duration: str = \"8h\",\n186:         image_pull_secrets: Optional[list] = None,\n187:     ) -> Dict[str, Any]:\n188:         \"\"\"Build the AgentRuntime Custom Resource specification.\n189: \n190:         Args:\n191:             agent_name: Name of the agent.\n192:             image_url: Full URL of the container image.\n193:             port: Port exposed by the agent.\n194:             entrypoint: Optional entrypoint command.\n195:             env_vars: Optional environment variables.\n196:             workload_manager_url: URL for the Workload Manager.\n197:             router_url: URL for the Router.\n198:             readiness_probe_path: Path for readiness probe.\n199:             readiness_probe_port: Port for readiness probe.\n200:             session_timeout: Session timeout duration.\n201:             max_session_duration: Maximum session duration.\n202:             image_pull_secrets: List of image pull secrets.\n203: \n204:         Returns:\n205:             Dict containing the AgentRuntime CR specification.\n206:         \"\"\"\n207:         # Merge env vars with AgentCube required vars\n208:         merged_env = env_vars.copy() if env_vars else {}\n209:         merged_env[\"WORKLOAD_MANAGER_URL\"] = workload_manager_url\n210:         merged_env[\"ROUTER_URL\"] = router_url\n211: \n212:         # Build container spec\n213:         container_spec = {\n214:             \"name\": agent_name,\n215:             \"image\": image_url,\n216:             \"ports\": [{\"containerPort\": port}],\n217:             \"env\": [{\"name\": k, \"value\": v} for k, v in merged_env.items()],\n218:         }\n219: \n220:         # Add entrypoint if provided\n221:         if entrypoint:\n222:             # Parse entrypoint into command and args\n223:             parts = entrypoint.split()\n224:             if parts:\n225:                 container_spec[\"command\"] = [parts[0]]\n226:                 if len(parts) > 1:\n227:                     container_spec[\"args\"] = parts[1:]\n228: \n229:         # Add readiness probe if configured\n230:         if readiness_probe_path:\n231:             probe_port = readiness_probe_port or port\n232:             container_spec[\"readinessProbe\"] = {\n233:                 \"httpGet\": {\n234:                     \"path\": readiness_probe_path,\n235:                     \"port\": probe_port,\n236:                 },\n237:                 \"initialDelaySeconds\": 10,\n238:                 \"periodSeconds\": 5,\n239:             }\n240: \n241:         # Build the CR spec\n242:         spec = {\n243:             \"apiVersion\": \"agentcube.io/v1\",\n244:             \"kind\": \"AgentRuntime\",\n245:             \"metadata\": {\n246:                 \"name\": agent_name,\n247:                 \"namespace\": self.namespace,\n248:             },\n249:             \"spec\": {\n250:                 \"image\": image_url,\n251:                 \"port\": port,\n252:                 \"sessionTimeout\": session_timeout,\n253:                 \"maxSessionDuration\": max_session_duration,\n254:                 \"podTemplate\": {\n255:                     \"spec\": {\n256:                         \"containers\": [container_spec],\n257:                     }\n258:                 },\n259:             },\n260:         }\n261: \n262:         # Add image pull secrets if provided\n263:         if image_pull_secrets:\n264:             spec[\"spec\"][\"podTemplate\"][\"spec\"][\"imagePullSecrets\"] = image_pull_secrets\n265:         else:\n266:             # Default image pull secret\n267:             spec[\"spec\"][\"podTemplate\"][\"spec\"][\"imagePullSecrets\"] = [{\"name\": \"default-secret\"}]\n268: \n269:         return spec\n270: \n271:     def _apply_agent_runtime_cr(self, agent_name: str, cr_spec: Dict[str, Any]) -> Dict[str, Any]:\n272:         \"\"\"Apply the AgentRuntime CR to the Kubernetes cluster.\n273: \n274:         Args:\n275:             agent_name: Name of the agent.\n276:             cr_spec: The AgentRuntime CR specification.\n277: \n278:         Returns:\n279:             Dict containing the applied CR information.\n280: \n281:         Raises:\n282:             RuntimeError: If CR application fails.\n283:         \"\"\"\n284:         client = self._get_k8s_client()\n285: \n286:         # Use the CustomObjectsApi for CR operations\n287:         api = client.CustomObjectsApi()\n288: \n289:         group = \"agentcube.io\"\n290:         version = \"v1\"\n291:         plural = \"agentruntimes\"\n292: \n293:         try:\n294:             # Check if CR already exists\n295:             existing = api.get_namespaced_custom_object(\n296:                 group=group,\n297:                 version=version,\n298:                 namespace=self.namespace,\n299:                 plural=plural,\n300:                 name=agent_name,\n301:             )\n302: \n303:             if existing:\n304:                 # Update (patch) existing CR\n305:                 self.logger.info(f\"Updating existing AgentRuntime: {agent_name}\")\n306:                 result = api.patch_namespaced_custom_object(\n307:                     group=group,\n308:                     version=version,\n309:                     namespace=self.namespace,\n310:                     plural=plural,\n311:                     name=agent_name,\n312:                     body=cr_spec,\n313:                 )\n314:                 self.logger.info(f\"Updated AgentRuntime: {agent_name}\")\n315:                 return result\n316: \n317:         except client.exceptions.NotFoundException:\n318:             # CR doesn't exist, create it\n319:             self.logger.info(f\"Creating new AgentRuntime: {agent_name}\")\n320:             result = api.create_namespaced_custom_object(\n321:                 group=group,\n322:                 version=version,\n323:                 namespace=self.namespace,\n324:                 plural=plural,\n325:                 body=cr_spec,\n326:             )\n327:             self.logger.info(f\"Created AgentRuntime: {agent_name}\")\n328:             return result\n329: \n330:         except Exception as e:\n331:             self.logger.error(f\"Failed to apply AgentRuntime CR: {e}\")\n332:             raise RuntimeError(f\"Failed to deploy AgentRuntime: {e}\") from e\n333: \n334:         return cr_spec\n335: \n336:     def get_agent_status(self, agent_name: str) -> Dict[str, Any]:\n337:         \"\"\"Get the status of a deployed AgentRuntime.\n338: \n339:         Args:\n340:             agent_name: Name of the agent.\n341: \n342:         Returns:\n343:             Dict containing the agent status.\n344: \n345:         Raises:\n346:             RuntimeError: If status retrieval fails.\n347:         \"\"\"\n348:         client = self._get_k8s_client()\n349:         api = client.CustomObjectsApi()\n350: \n351:         group = \"agentcube.io\"\n352:         version = \"v1\"\n353:         plural = \"agentruntimes\"\n354: \n355:         try:\n356:             result = api.get_namespaced_custom_object(\n357:                 group=group,\n358:                 version=version,\n359:                 namespace=self.namespace,\n360:                 plural=plural,\n361:                 name=agent_name,\n362:             )\n363: \n364:             return {\n365:                 \"agent_name\": agent_name,\n366:                 \"namespace\": self.namespace,\n367:                 \"status\": result.get(\"status\", {}),\n368:                 \"spec\": result.get(\"spec\", {}),\n369:             }\n370: \n371:         except client.exceptions.NotFoundException:\n372:             return {\n373:                 \"agent_name\": agent_name,\n374:                 \"namespace\": self.namespace,\n375:                 \"status\": \"not_found\",\n376:             }\n377: \n378:         except Exception as e:\n379:             self.logger.error(f\"Failed to get agent status: {e}\")\n380:             raise RuntimeError(f\"Failed to get agent status: {e}\") from e\n381: \n382:     def delete_agent(self, agent_name: str) -> Dict[str, Any]:\n383:         \"\"\"Delete an AgentRuntime Custom Resource.\n384: \n385:         Args:\n386:             agent_name: Name of the agent to delete.\n387: \n388:         Returns:\n389:             Dict containing deletion result.\n390: \n391:         Raises:\n392:             RuntimeError: If deletion fails.\n393:         \"\"\"\n394:         client = self._get_k8s_client()\n395:         api = client.CustomObjectsApi()\n396: \n397:         group = \"agentcube.io\"\n398:         version = \"v1\"\n399:         plural = \"agentruntimes\"\n400: \n401:         try:\n402:             api.delete_namespaced_custom_object(\n403:                 group=group,\n404:                 version=version,\n405:                 namespace=self.namespace,\n406:                 plural=plural,\n407:                 name=agent_name,\n408:             )\n409: \n410:             self.logger.info(f\"Deleted AgentRuntime: {agent_name}\")\n411:             return {\n412:                 \"agent_name\": agent_name,\n413:                 \"namespace\": self.namespace,\n414:                 \"deleted\": True,\n415:             }\n416: \n417:         except client.exceptions.NotFoundException:\n418:             self.logger.warning(f\"AgentRuntime not found: {agent_name}\")\n419:             return {\n420:                 \"agent_name\": agent_name,\n421:                 \"namespace\": self.namespace,\n422:                 \"deleted\": False,\n423:                 \"reason\": \"not_found\",\n424:             }\n425: \n426:         except Exception as e:\n427:             self.logger.error(f\"Failed to delete AgentRuntime: {e}\")\n428:             raise RuntimeError(f\"Failed to delete AgentRuntime: {e}\") from e\n\n(End of file - total 428 lines)\n</content>","metadata":{"preview":"\"\"\"AgentCube provider for deploying AgentRuntime Custom Resources.\n\nThis module provides the AgentCubeProvider class for deploying agents\nas AgentRuntime Custom Resources in Kubernetes.\n\"\"\"\n\nimport logging\nimport time\nfrom pathlib import Path\nfrom typing import Any, Dict, Optional\n\nfrom agentcube.utils.log import get_logger\n\n\nclass AgentCubeProvider:\n    \"\"\"Provider for AgentCube-specific AgentRuntime CR deployment.\"\"\"\n\n    def __init__(self, namespace: str = \"default\", verbose: bool = False) -> None:\n        \"\"\"Initialize AgentCubeProvider.\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/agentcube/services/agentcube_provider.py","time":{"start":1775892699804,"end":1775892699830}}}}
{"type":"step_finish","timestamp":1775892699872,"sessionID":"ses_2848c4100ffe5LtG4M55bByBGV","part":{"id":"prt_d7b741ab80010ksLdUksd4Uveb","reason":"tool-calls","snapshot":"f33c5114db06c230ebdbad281b75532a26b6f114","messageID":"msg_d7b73f383001KPaIq402jDBh3x","sessionID":"ses_2848c4100ffe5LtG4M55bByBGV","type":"step-finish","tokens":{"total":15544,"input":4,"output":250,"reasoning":0,"cache":{"write":1138,"read":14152}},"cost":0}}
