\t// SandboxConditionFailed indicates the Sandbox has failed.\n37: \tSandboxConditionFailed SandboxConditionType = \"Failed\"\n38: )\n39: \n40: // SandboxStatus defines the observed state of Sandbox.\n41: type SandboxStatus struct {\n42: \t// Phase represents the current phase of the Sandbox.\n43: \t// Possible values: Pending, Running, Succeeded, Failed, Unknown.\n44: \t// +kubebuilder:validation:Optional\n45: \tPhase string `json:\"phase,omitempty\"`\n46: \n47: \t// Conditions represents the latest available observations of the Sandbox's state.\n48: \t// +kubebuilder:validation:Optional\n49: \t// +listType=map\n50: \t// +listMapKey=type\n51: \tConditions []SandboxCondition `json:\"conditions,omitempty\"`\n52: \n53: \t// Ready indicates whether the Sandbox is ready to accept requests.\n54: \t// +kubebuilder:validation:Optional\n55: \tReady *bool `json:\"ready,omitempty\"`\n56: }\n57: \n58: // SandboxCondition represents a condition of a Sandbox.\n59: type SandboxCondition struct {\n60: \t// Type is the type of the condition.\n61: \t// +kubebuilder:validation:Required\n62: \tType SandboxConditionType `json:\"type\"`\n63: \n64: \t// Status is the status of the condition (True, False, Unknown).\n65: \t// +kubebuilder:validation:Required\n66: \t// +kubebuilder:validation:Enum=True;False;Unknown\n67: \tStatus string `json:\"status\"`\n68: \n69: \t// LastTransitionTime is the last time the condition transitioned.\n70: \t// +kubebuilder:validation:Optional\n71: \tLastTransitionTime metav1.Time `json:\"lastTransitionTime,omitempty\"`\n72: \n73: \t// Reason is a brief reason for the condition's last transition.\n74: \t// +kubebuilder:validation:Optional\n75: \tReason string `json:\"reason,omitempty\"`\n76: \n77: \t// Message is a human-readable message indicating details about the transition.\n78: \t// +kubebuilder:validation:Optional\n79: \tMessage string `json:\"message,omitempty\"`\n80: }\n81: \n82: // +genclient\n83: // +genclient:noStatus\n84: // +k8s:deepcopy-gen:interfaces=k8s.io/apimachinery/pkg/runtime.Object\n85: // +kubebuilder:object:root=true\n86: // +kubebuilder:resource:path=sandboxes,shortName=sb;sbs,singular=sandbox,categories={agentcube,all}\n87: // +kubebuilder:subresource:status\n88: // +kubebuilder:printcolumn:name=\"Phase\",type=string,JSONPath=`.status.phase`,description=\"Current phase of the sandbox\"\n89: // +kubebuilder:printcolumn:name=\"Age\",type=date,JSONPath=`.metadata.creationTimestamp`,description=\"Time since creation\"\n90: \n91: // Sandbox is the Schema for the sandboxes API.\n92: // A Sandbox represents a sandbox instance managed by the agentd controller.\n93: // The controller monitors the last-activity-time annotation and deletes\n94: // sandboxes that have been idle beyond the configured timeout.\n95: type Sandbox struct {\n96: \tmetav1.TypeMeta   `json:\",inline\"`\n97: \tmetav1.ObjectMeta `json:\"metadata,omitempty\"`\n98: \n99: \t// Status defines the observed state of the Sandbox.\n100: \t// +kubebuilder:validation:Optional\n101: \tStatus SandboxStatus `json:\"status,omitempty\"`\n102: }\n103: \n104: // +k8s:deepcopy-gen:interfaces=k8s.io/apimachinery/pkg/runtime.Object\n105: // +kubebuilder:object:root=true\n106: \n107: // SandboxList contains a list of Sandbox resources.\n108: type SandboxList struct {\n109: \tmetav1.TypeMeta `json:\",inline\"`\n110: \tmetav1.ListMeta `json:\"metadata,omitempty\"`\n111: \n112: \t// Items is the list of Sandbox resources.\n113: \t// +kubebuilder:validation:Required\n114: \tItems []Sandbox `json:\"items\"`\n115: }\n116: \n117: // DeepCopyInto copies all properties of this object into another object of the\n118: // same type.\n119: func (in *Sandbox) DeepCopyInto(out *Sandbox) {\n120: \t*out = *in\n121: \tout.TypeMeta = in.TypeMeta\n122: \tin.ObjectMeta.DeepCopyInto(&out.ObjectMeta)\n123: \tin.Status.DeepCopyInto(&out.Status)\n124: }\n125: \n126: // DeepCopy creates a new object of the same type with the same contents.\n127: func (in *Sandbox) DeepCopy() *Sandbox {\n128: \tif in == nil {\n129: \t\treturn nil\n130: \t}\n131: \tout := new(Sandbox)\n132: \tin.DeepCopyInto(out)\n133: \treturn out\n134: }\n135: \n136: // DeepCopyObject returns a generically typed copy of an object.\n137: func (in *Sandbox) DeepCopyObject() runtime.Object {\n138: \tif c := in.DeepCopy(); c != nil {\n139: \t\treturn c\n140: \t}\n141: \treturn nil\n142: }\n143: \n144: // DeepCopyInto copies all properties of this object into another object of the\n145: // same type.\n146: func (in *SandboxList) DeepCopyInto(out *SandboxList) {\n147: \t*out = *in\n148: \tout.TypeMeta = in.TypeMeta\n149: \tin.ListMeta.DeepCopyInto(&out.ListMeta)\n150: \tif in.Items != nil {\n151: \t\tin, out := &in.Items, &out.Items\n152: \t\t*out = make([]Sandbox, len(*in))\n153: \t\tfor i := range *in {\n154: \t\t\t(*in)[i].DeepCopyInto(&(*out)[i])\n155: \t\t}\n156: \t}\n157: }\n158: \n159: // DeepCopy creates a new object of the same type with the same contents.\n160: func (in *SandboxList) DeepCopy() *SandboxList {\n161: \tif in == nil {\n162: \t\treturn nil\n163: \t}\n164: \tout := new(SandboxList)\n165: \tin.DeepCopyInto(out)\n166: \treturn out\n167: }\n168: \n169: // DeepCopyObject returns a generically typed copy of an object.\n170: func (in *SandboxList) DeepCopyObject() runtime.Object {\n171: \tif c := in.DeepCopy(); c != nil {\n172: \t\treturn c\n173: \t}\n174: \treturn nil\n175: }\n176: \n177: // DeepCopyInto copies all properties of this object into another object of the\n178: // same type.\n179: func (in *SandboxStatus) DeepCopyInto(out *SandboxStatus) {\n180: \t*out = *in\n181: \tif in.Conditions != nil {\n182: \t\tin, out := &in.Conditions, &out.Conditions\n183: \t\t*out = make([]SandboxCondition, len(*in))\n184: \t\tfor i := range *in {\n185: \t\t\t(*in)[i].DeepCopyInto(&(*out)[i])\n186: \t\t}\n187: \t}\n188: \tif in.Ready != nil {\n189: \t\tin, out := &in.Ready, &out.Ready\n190: \t\t*out = new(bool)\n191: \t\t**out = **in\n192: \t}\n193: }\n194: \n195: // DeepCopyInto copies all properties of this object into another object of the\n196: // same type.\n197: func (in *SandboxCondition) DeepCopyInto(out *SandboxCondition) {\n198: \t*out = *in\n199: \tin.LastTransitionTime.DeepCopyInto(&out.LastTransitionTime)\n200: }\n\n(End of file - total 200 lines)\n</content>","metadata":{"preview":"/*\nCopyright 2026 The Volcano Authors.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\npackage v1alpha1\n\nimport (\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/apis/runtime/v1alpha1/sandbox_types.go","time":{"start":1775881429167,"end":1775881429195}}}}
