to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\npackage agentd\n\nimport (\n\t\"context\"\n\t\"errors\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/google/go-cmp/cmp\"\n\t\"k8s.io/apimachinery/pkg/api/meta\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/apimachinery/pkg/runtime\"\n\t\"k8s.io/apimachinery/pkg/runtime/schema\"\n\t\"k8s.io/apimachinery/pkg/types\"\n\tctrl \"sigs.k8s.io/controller-runtime\"\n\t\"sigs.k8s.io/controller-runtime/pkg/client\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1\"\n\t\"github.com/volcano-sh/agentcube/pkg/workloadmanager\"\n)\n\n// mockClient is a mock implementation of client.Client for testing.\ntype mockClient struct {\n\tclient.Client\n\tgetFunc    func(ctx context.Context, key client.ObjectKey, obj client.Object, opts ...client.GetOption) error\n\tdeleteFunc func(ctx context.Context, obj client.Object, opts ...client.DeleteOption) error\n}\n\nfunc (m *mockClient) Get(ctx context.Context, key client.ObjectKey, obj client.Object, opts ...client.GetOption) error {\n\tif m.getFunc != nil {\n\t\treturn m.getFunc(ctx, key, obj, opts...)\n\t}\n\treturn nil\n}\n\nfunc (m *mockClient) Delete(ctx context.Context, obj client.Object, opts ...client.DeleteOption) error {\n\tif m.deleteFunc != nil {\n\t\treturn m.deleteFunc(ctx, obj, opts...)\n\t}\n\treturn nil\n}\n\n// notFoundError implements the IsNotFound check\ntype notFoundError struct{}\n\nfunc (e notFoundError) Error() string { return \"not found\" }\nfunc (e notFoundError) Status() metav1.Status {\n\treturn metav1.Status{Code: 404, Reason: \"NotFound\"}\n}\n\n// testError implements a generic error\ntype testError struct{}\n\nfunc (e testError) Error() string { return \"test error\" }\n\n// createSandbox creates a test Sandbox with the given annotation.\nfunc createSandbox(name, namespace, lastActivity string) *v1alpha1.Sandbox {\n\tsandbox := &v1alpha1.Sandbox{\n\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\tName:        name,\n\t\t\tNamespace:   namespace,\n\t\t\tAnnotations: make(map[string]string),\n\t\t},\n\t}\n\tif lastActivity != \"\" {\n\t\tsandbox.Annotations[workloadmanager.LastActivityAnnotationKey] = lastActivity\n\t}\n\treturn sandbox\n}\n\n// TestReconcile_SandboxNotFound tests that NotFound errors on Get are handled gracefully.\nfunc TestReconcile_SandboxNotFound(t *testing.T) {\n\tmock := &mockClient{\n\t\tgetFunc: func(ctx context.Context, key client.ObjectKey, obj client.Object, opts ...client.GetOption) error {\n\t\t\treturn notFoundError{}\n\t\t},\n\t}\n\n\tr := &Reconciler{Client: mock}\n\tresult, err := r.Reconcile(context.Background(), ctrl.Request{\n\t\tNamespacedName: types.NamespacedName{Name: \"test-sandbox\", Namespace: \"default\"},\n\t})\n\n\tif err != nil {\n\t\tt.Errorf(\"Expected no error, got: %v\", err)\n\t}\n\tif result.Requeue || result.RequeueAfter != 0 {\n\t\tt.Errorf(\"Expected empty result, got: %+v\", result)\n\t}\n}\n\n// TestReconcile_GetError tests that other Get errors are returned.\nfunc TestReconcile_GetError(t *testing.T) {\n\tmock := &mockClient{\n\t\tgetFunc: func(ctx context.Context, key client.ObjectKey, obj client.Object, opts ...client.GetOption) error {\n\t\t\treturn testError{}\n\t\t},\n\t}\n\n\tr := &Reconciler{Client: mock}\n\tresult, err := r.Reconcile(context.Background(), ctrl.Request{\n\t\tNamespacedName: types.NamespacedName{Name: \"test-sandbox\", Namespace: \"default\"},\n\t})\n\n\tif err == nil {\n\t\tt.Error(\"Expected error, got nil\")\n\t}\n\tif result.RequeueAfter != 0 {\n\t\tt.Errorf(\"Expected no requeue, got: %v\", result.RequeueAfter)\n\t}\n}\n\n// TestReconcile_NoAnnotation tests that missing annotation returns empty result.\nfunc TestReconcile_NoAnnotation(t *testing.T) {\n\tsandbox := createSandbox(\"test-sandbox\", \"default\", \"\")\n\t// No annotation set\n\n\tmock := &mockClient{\n\t\tgetFunc: func(ctx context.Context, key client.ObjectKey, obj client.Object, opts ...client.GetOption) error {\n\t\t\tsandboxObj := obj.(*v1alpha1.Sandbox)\n\t\t\tsandboxObj.Name = sandbox.Name\n\t\t\tsandboxObj.Namespace = sandbox.Namespace\n\t\t\tsandboxObj.Annotations = sandbox.Annotations\n\t\t\treturn nil\n\t\t},\n\t}\n\n\tr := &Reconciler{Client: mock}\n\tresult, err := r.Reconcile(context.Background(), ctrl.Request{\n\t\tNamespacedName: types.NamespacedName{Name: \"test-sandbox\", Namespace: \"default\"},\n\t})\n\n\tif err != nil {\n\t\tt.Errorf(\"Expected no error, got: %v\", err)\n\t}\n\tif result.Requeue || result.RequeueAfter != 0 {\n\t\tt.Errorf(\"Expected empty result, got: %+v\", result)\n\t}\n}\n\n// TestReconcile_EmptyAnnotation tests that empty annotation value returns empty result.\nfunc TestReconcile_EmptyAnnotation(t *testing.T) {\n\tsandbox := createSandbox(\"test-sandbox\", \"default\", \"\")\n\tsandbox.Annotations[workloadmanager.LastActivityAnnotationKey] = \"\"\n\n\tmock := &mockClient{\n\t\tgetFunc: func(ctx context.Context, key client.ObjectKey, obj client.Object, opts ...client.GetOption) error {\n\t\t\tsandboxObj := obj.(*v1alpha1.Sandbox)\n\t\t\tsandboxObj.Name = sandbox.Name\n\t\t\tsandboxObj.Namespace = sandbox.Namespace\n\t\t\tsandboxObj.Annotations = sandbox.Annotations\n\t\t\treturn nil\n\t\t},\n\t}\n\n\tr := &Reconciler{Client: mock}\n\tresult, err := r.Reconcile(context.Background(), ctrl.Request{\n\t\tNamespacedName: types.NamespacedName{Name: \"test-sandbox\", Namespace: \"default\"},\n\t})\n\n\tif err != nil {\n\t\tt.Errorf(\"Expected no error, got: %v\", err)\n\t}\n\tif result.Requeue || result.RequeueAfter != 0 {\n\t\tt.Errorf(\"Expected empty result, got: %+v\", result)\n\t}\n}\n\n// TestReconcile_InvalidTimestamp tests that invalid timestamp requeues with 30s.\nfunc TestReconcile_InvalidTimestamp(t *testing.T) {\n\tsandbox := createSandbox(\"test-sandbox\", \"default\", \"invalid-timestamp\")\n\n\tmock := &mockClient{\n\t\tgetFunc: func(ctx context.Context, key client.ObjectKey, obj client.Object, opts ...client.GetOption) error {\n\t\t\tsandboxObj := obj.(*v1alpha1.Sandbox)\n\t\t\tsandboxObj.Name = sandbox.Name\n\t\t\tsandboxObj.Namespace = sandbox.Namespace\n\t\t\tsandboxObj.Annotations = sandbox.Annotations\n\t\t\treturn nil\n\t\t},\n\t}\n\n\tr := &Reconciler{Client: mock}\n\tresult, err := r.Reconcile(context.Background(), ctrl.Request{\n\t\tNamespacedName: types.NamespacedName{Name: \"test-sandbox\", Namespace: \"default\"},\n\t})\n\n\tif err == nil {\n\t\tt.Error(\"Expected error for invalid timestamp\")\n\t}\n\texpectedRequeue := RequeueAfterParseError\n\tif result.RequeueAfter != expectedRequeue {\n\t\tt.Errorf(\"Expected RequeueAfter %v, got %v\", expectedRequeue, result.RequeueAfter)\n\t}\n}\n\n// TestReconcile_NotExpired tests that non-expired sandbox requeues at expiration time.\nfunc TestReconcile_NotExpired(t *testing.T) {\n\t// Last activity 5 minutes ago\n\tlastActivity := time.Now().UTC().Add(-5 * time.Minute).Format(time.RFC3339)\n\tsandbox := createSandbox(\"test-sandbox\", \"default\", lastActivity)\n\n\tmock := &mockClient{\n\t\tgetFunc: func(ctx context.Context, key client.ObjectKey, obj client.Object, opts ...client.GetOption) error {\n\t\t\tsandboxObj := obj.(*v1alpha1.Sandbox)\n\t\t\tsandboxObj.Name = sandbox.Name\n\t\t\tsandboxObj.Namespace = sandbox.Namespace\n\t\t\tsandboxObj.Annotations = sandbox.Annotations\n\t\t\treturn nil\n\t\t},\n\t}\n\n\tr := &Reconciler{Client: mock}\n\tresult, err := r.Reconcile(context.Background(), ctrl.Request{\n\t\tNamespacedName: types.NamespacedName{Name: \"test-sandbox\", Namespace: \"default\"},\n\t})\n\n\tif err != nil {\n\t\tt.Errorf(\"Expected no error, got: %v\", err)\n\t}\n\n\t// Should requeue after approximately 10 minutes (15 min timeout - 5 min elapsed)\n\texpectedMin := 9 * time.Minute\n\texpectedMax := 11 * time.Minute\n\tif result.RequeueAfter < expectedMin || result.RequeueAfter > expectedMax {\n\t\tt.Errorf(\"Expected RequeueAfter between %v and %v, got %v\", expectedMin, expectedMax, result.RequeueAfter)\n\t}\n}\n\n// TestReconcile_JustExpired tests that sandbox exactly at expiration is deleted.\nfunc TestReconcile_JustExpired(t *testing.T) {\n\t// Last activity exactly 15 minutes ago\n\tlastActivity := time.Now().UTC().Add(-15 * time.Minute).Format(time.RFC3339)\n\tsandbox := createSandbox(\"test-sandbox\", \"default\", lastActivity)\n\n\tdeleteCalled := false\n\tmock := &mockClient{\n\t\tgetFunc: func(ctx context.Context, key client.ObjectKey, obj client.Object, opts ...client.GetOption) error {\n\t\t\tsandboxObj := obj.(*v1alpha1.Sandbox)\n\t\t\tsandboxObj.Name = sandbox.Name\n\t\t\tsandboxObj.Namespace = sandbox.Namespace\n\t\t\tsandboxObj.Annotations = sandbox.Annotations\n\t\t\treturn nil\n\t\t},\n\t\tdeleteFunc: func(ctx context.Context, obj client.Object, opts ...client.DeleteOption) error {\n\t\t\tdeleteCalled = true\n\t\t\treturn nil\n\t\t},\n\t}\n\n\tr := &Reconciler{Client: mock}\n\tresult, err := r.Reconcile(context.Background(), ctrl.Request{\n\t\tNamespacedName: types.NamespacedName{Name: \"test-sandbox\", Namespace: \"default\"},\n\t})\n\n\tif err != nil {\n\t\tt.Errorf(\"Expected no error, got: %v\", err)\n\t}\n\tif result.RequeueAfter != 0 {\n\t\tt.Errorf(\"Expected no requeue, got: %v\", result.RequeueAfter)\n\t}\n\tif !deleteCalled {\n\t\tt.Error(\"Expected Delete to be called\")\n\t}\n}\n\n// TestReconcile_Expired tests that expired sandbox is deleted.\nfunc TestReconcile_Expired(t *testing.T) {\n\t// Last activity 20 minutes ago\n\tlastActivity := time.Now().UTC().Add(-20 * time.Minute).Format(time.RFC3339)\n\tsandbox := createSandbox(\"test-sandbox\", \"default\", lastActivity)\n\n\tdeleteCalled := false\n\tmock := &mockClient{\n\t\tgetFunc: func(ctx context.Context, key client.ObjectKey, obj client.Object, opts ...client.GetOption) error {\n\t\t\tsandboxObj := obj.(*v1alpha1.Sandbox)\n\t\t\tsandboxObj.Name = sandbox.Name\n\t\t\tsandboxObj.Namespace = sandbox.Namespace\n\t\t\tsandboxObj.Annotations = sandbox.Annotations\n\t\t\treturn nil\n\t\t},\n\t\tdeleteFunc: func(ctx context.Context, obj client.Object, opts ...client.DeleteOption) error {\n\t\t\tdeleteCalled = true\n\t\t\treturn nil\n\t\t},\n\t}\n\n\tr := &Reconciler{Client: mock}\n\tresult, err := r.Reconcile(context.Background(), ctrl.Request{\n\t\tNamespacedName: types.NamespacedName{Name: \"test-sandbox\", Namespace: \"default\"},\n\t})\n\n\tif err != nil {\n\t\tt.Errorf(\"Expected no error, got: %v\", err)\n\t}\n\tif result.RequeueAfter != 0 {\n\t\tt.Errorf(\"Expected no requeue, got: %v\", result.RequeueAfter)\n\t}\n\tif !deleteCalled {\n\t\tt.Error(\"Expected Delete to be called\")\n\t}\n}\n\n// TestReconcile_DeleteNotFound tests that NotFound on delete is handled gracefully.\nfunc TestReconcile_DeleteNotFound(t *testing.T) {\n\t// Last activity 20 minutes ago\n\tlastActivity := time.Now().UTC().Add(-20 * time.Minute).Format(time.RFC3339)\n\tsandbox := createSandbox(\"test-sandbox\", \"default\", lastActivity)\n\n\tmock := &mockClient{\n\t\tgetFunc: func(ctx context.Context, key client.ObjectKey, obj client.Object, opts ...client.GetOption) error {\n\t\t\tsandboxObj := obj.(*v1alpha1.Sandbox)\n\t\t\tsandboxObj.Name = sandbox.Name\n\t\t\tsandboxObj.Namespace = sandbox.Namespace\n\t\t\tsandboxObj.Annotations = sandbox.Annotations\n\t\t\treturn nil\n\t\t},\n\t\tdeleteFunc: func(ctx context.Context, obj client.Object, opts ...client.DeleteOption) error {\n\t\t\treturn notFoundError{}\n\t\t},\n\t}\n\n\tr := &Reconciler{Client: mock}\n\tresult, err := r.Reconcile(context.Background(), ctrl.Request{\n\t\tNamespacedName: types.NamespacedName{Name: \"test-sandbox\", Namespace: \"default\"},\n\t})\n\n\tif err != nil {\n\t\tt.Errorf(\"Expected no error for NotFound, got: %v\", err)\n\t}\n\tif result.RequeueAfter != 0 {\n\t\tt.Errorf(\"Expected no requeue, got: %v\", result.RequeueAfter)\n\t}\n}\n\n// TestReconcile_DeleteError tests that other delete errors are returned.\nfunc TestReconcile_DeleteError(t *testing.T) {\n\t// Last activity 20 minutes ago\n\tlastActivity := time.Now().UTC().Add(-20 * time.Minute).Format(time.RFC3339)\n\tsandbox := createSandbox(\"test-sandbox\", \"default\", lastActivity)\n\n\tmock := &mockClient{\n\t\tgetFunc: func(ctx context.Context, key client.ObjectKey, obj client.Object, opts ...client.GetOption) error {\n\t\t\tsandboxObj := obj.(*v1alpha1.Sandbox)\n\t\t\tsandboxObj.Name = sandbox.Name\n\t\t\tsandboxObj.Namespace = sandbox.Namespace\n\t\t\tsandboxObj.Annotations = sandbox.Annotations\n\t\t\treturn nil\n\t\t},\n\t\tdeleteFunc: func(ctx context.Context, obj client.Object, opts ...client.DeleteOption) error {\n\t\t\treturn testError{}\n\t\t},\n\t}\n\n\tr := &Reconciler{Client: mock}\n\tresult, err := r.Reconcile(context.Background(), ctrl.Request{\n\t\tNamespacedName: types.NamespacedName{Name: \"test-sandbox\", Namespace: \"default\"},\n\t})\n\n\tif err == nil {\n\t\tt.Error(\"Expected error for delete failure\")\n\t}\n\tif result.RequeueAfter != 0 {\n\t\tt.Errorf(\"Expected no requeue, got: %v\", result.RequeueAfter)\n\t}\n}\n\n// TestReconcile_FutureExpirationRequeue tests that RequeueAfter is calculated correctly.\nfunc TestReconcile_FutureExpirationRequeue(t *testing.T) {\n\t// Test multiple scenarios\n\ttests := []struct {\n\t\tname        string\n\t\tminutesAgo  time.Duration\n\t\texpectedMin time.Duration\n\t\texpectedMax time.Duration\n\t}{\n\t\t{\n\t\t\tname:        \"Just created (0 min ago)\",\n\t\t\tminutesAgo:  0,\n\t\t\texpectedMin: 14 * time.Minute,\n\t\t\texpectedMax: 16 * time.Minute,\n\t\t},\n\t\t{\n\t\t\tname:        \"1 minute ago\",\n\t\t\tminutesAgo:  1 * time.Minute,\n\t\t\texpectedMin: 13 * time.Minute,\n\t\t\texpectedMax: 15 * time.Minute,\n\t\t},\n\t\t{\n\t\t\tname:        \"10 minutes ago\",\n\t\t\tminutesAgo:  10 * time.Minute,\n\t\t\texpectedMin: 4 * time.Minute,\n\t\t\texpectedMax: 6 * time.Minute,\n\t\t},\n\t\t{\n\t\t\tname:        \"14 minutes ago\",\n\t\t\tminutesAgo:  14 * time.Minute,\n\t\t\texpectedMin: 0 * time.Second,\n\t\t\texpectedMax: 2 * time.Minute,\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tlastActivity := time.Now().UTC().Add(-tt.minutesAgo).Format(time.RFC3339)\n\t\t\tsandbox := createSandbox(\"test-sandbox\", \"default\", lastActivity)\n\n\t\t\tmock := &mockClient{\n\t\t\t\tgetFunc: func(ctx context.Context, key client.ObjectKey, obj client.Object, opts ...client.GetOption) error {\n\t\t\t\t\tsandboxObj := obj.(*v1alpha1.Sandbox)\n\t\t\t\t\tsandboxObj.Name = sandbox.Name\n\t\t\t\t\tsandboxObj.Namespace = sandbox.Namespace\n\t\t\t\t\tsandboxObj.Annotations = sandbox.Annotations\n\t\t\t\t\treturn nil\n\t\t\t\t},\n\t\t\t}\n\n\t\t\tr := &Reconciler{Client: mock}\n\t\t\tresult, err := r.Reconcile(context.Background(), ctrl.Request{\n\t\t\t\tNamespacedName: types.NamespacedName{Name: \"test-sandbox\", Namespace: \"default\"},\n\t\t\t})\n\n\t\t\tif err != nil {\n\t\t\t\tt.Errorf(\"Expected no error, got: %v\", err)\n\t\t\t}\n\t\t\tif result.RequeueAfter < tt.expectedMin || result.RequeueAfter > tt.expectedMax {\n\t\t\t\tt.Errorf(\"Expected RequeueAfter between %v and %v, got %v\", tt.expectedMin, tt.expectedMax, result.RequeueAfter)\n\t\t\t}\n\t\t})\n\t}\n}\n\n// TestReconciler_Struct tests the Reconciler struct fields.\nfunc TestReconciler_Struct(t *testing.T) {\n\tscheme := runtime.NewScheme()\n\tr := &Reconciler{\n\t\tClient: nil,\n\t\tScheme: scheme,\n\t}\n\n\tif r.Client != nil {\n\t\tt.Error(\"Expected Client to be nil\")\n\t}\n\tif r.Scheme != scheme {\n\t\tt.Error(\"Expected Scheme to match\")\n\t}\n}\n\n// TestConstants tests that constants are properly defined.\nfunc TestConstants(t *testing.T) {\n\tif SessionExpirationTimeout != 15*time.Minute {\n\t\tt.Errorf(\"SessionExpirationTimeout expected 15m, got %v\", SessionExpirationTimeout)\n\t}\n\tif RequeueAfterParseError != 30*time.Second {\n\t\tt.Errorf(\"RequeueAfterParseError expected 30s, got %v\", RequeueAfterParseError)\n\t}\n}\n\n// TestCreateSandbox tests the test helper function.\nfunc TestCreateSandbox(t *testing.T) {\n\tsandbox := createSandbox(\"test\", \"default\", \"2024-01-01T00:00:00Z\")\n\n\tif sandbox.Name != \"test\" {\n\t\tt.Errorf(\"Expected name 'test', got '%s'\", sandbox.Name)\n\t}\n\tif sandbox.Namespace != \"default\" {\n\t\tt.Errorf(\"Expected namespace 'default', got '%s'\", sandbox.Namespace)\n\t}\n\tif sandbox.Annotations[workloadmanager.LastActivityAnnotationKey] != \"2024-01-01T00:00:00Z\" {\n\t\tt.Errorf(\"Expected annotation value, got '%s'\", sandbox.Annotations[workloadmanager.LastActivityAnnotationKey])\n\t}\n}\n\n// TestCreateSandbox_NoAnnotation tests creating sandbox without annotation.\nfunc TestCreateSandbox_NoAnnotation(t *testing.T) {\n\tsandbox := createSandbox(\"test\", \"default\", \"\")\n\n\tif _, exists := sandbox.Annotations[workloadmanager.LastActivityAnnotationKey]; exists {\n\t\tt.Error(\"Expected no annotation when empty value\")\n\t}\n}\n\n// TestMockClient implements a more realistic mock client test.\nfunc TestMockClient(t *testing.T) {\n\tctx := context.Background()\n\n\tt.Run(\"Get returns error\", func(t *testing.T) {\n\t\texpectedErr := errors.New(\"get error\")\n\t\tmock := &mockClient{\n\t\t\tgetFunc: func(ctx context.Context, key client.ObjectKey, obj client.Object, opts ...client.GetOption) error {\n\t\t\t\treturn expectedErr\n\t\t\t},\n\t\t}\n\n\t\tsandbox := &v1alpha1.Sandbox{}\n\t\terr := mock.Get(ctx, client.ObjectKey{Name: \"test\"}, sandbox)\n\t\tif !errors.Is(err, expectedErr) && err.Error() != expectedErr.Error() {\n\t\t\tt.Errorf(\"Expected error '%v', got '%v'\", expectedErr, err)\n\t\t}\n\t})\n\n\tt.Run(\"Delete returns error\", func(t *testing.T) {\n\t\texpectedErr := errors.New(\"delete error\")\n\t\tmock := &mockClient{\n\t\t\tdeleteFunc: func(ctx context.Context, obj client.Object, opts ...client.DeleteOption) error {\n\t\t\t\treturn expectedErr\n\t\t\t},\n\t\t}\n\n\t\tsandbox := &v1alpha1.Sandbox{}\n\t\terr := mock.Delete(ctx, sandbox)\n\t\tif !errors.Is(err, expectedErr) && err.Error() != expectedErr.Error() {\n\t\t\tt.Errorf(\"Expected error '%v', got '%v'\", expectedErr, err)\n\t\t}\n\t})\n}\n\n// TestReconcile_MalformedTimestamp tests various malformed timestamps.\nfunc TestReconcile_MalformedTimestamp(t *testing.T) {\n\tmalformedTimestamps := []string{\n\t\t\"2024-13-45T99:99:99Z\", // Invalid date/time\n\t\t\"not-a-timestamp\",\n\t\t\"\",\n\t\t\"2024\",\n\t\t\"01-15-2024\",\n\t\t\"T10:00:00Z\",\n\t}\n\n\tfor _, ts := range malformedTimestamps {\n\t\tt.Run(ts, func(t *testing.T) {\n\t\t\tsandbox := createSandbox(\"test-sandbox\", \"default\", ts)\n\n\t\t\tmock := &mockClient{\n\t\t\t\tgetFunc: func(ctx context.Context, key client.ObjectKey, obj client.Object, opts ...client.GetOption) error {\n\t\t\t\t\tsandboxObj := obj.(*v1alpha1.Sandbox)\n\t\t\t\t\tsandboxObj.Name = sandbox.Name\n\t\t\t\t\tsandboxObj.Namespace = sandbox.Namespace\n\t\t\t\t\tsandboxObj.Annotations = sandbox.Annotations\n\t\t\t\t\treturn nil\n\t\t\t\t},\n\t\t\t}\n\n\t\t\tr := &Reconciler{Client: mock}\n\t\t\tresult, err := r.Reconcile(context.Background(), ctrl.Request{\n\t\t\t\tNamespacedName: types.NamespacedName{Name: \"test-sandbox\", Namespace: \"default\"},\n\t\t\t})\n\n\t\t\t// Should return error and requeue after 30s\n\t\t\tif ts == \"\" {\n\t\t\t\t// Empty string is handled separately - no error\n\t\t\t\tif err != nil {\n\t\t\t\t\tt.Errorf(\"Expected no error for empty string, got: %v\", err)\n\t\t\t\t}\n\t\t\t} else {\n\t\t\t\tif err == nil {\n\t\t\t\t\tt.Error(\"Expected error for malformed timestamp\")\n\t\t\t\t}\n\t\t\t\tif result.RequeueAfter != RequeueAfterParseError {\n\t\t\t\t\tt.Errorf(\"Expected RequeueAfter %v, got %v\", RequeueAfterParseError, result.RequeueAfter)\n\t\t\t\t}\n\t\t\t}\n\t\t})\n\t}\n}\n\n// TestReconcile_ContextCancellation tests handling of cancelled context.\nfunc TestReconcile_ContextCancellation(t *testing.T) {\n\tctx, cancel := context.WithCancel(context.Background())\n\tcancel() // Cancel immediately\n\n\tsandbox := createSandbox(\"test-sandbox\", \"default\", time.Now().UTC().Format(time.RFC3339))\n\n\tmock := &mockClient{\n\t\tgetFunc: func(ctx context.Context, key client.ObjectKey, obj client.Object, opts ...client.GetOption) error {\n\t\t\treturn ctx.Err()\n\t\t},\n\t}\n\n\tr := &Reconciler{Client: mock}\n\t_, err := r.Reconcile(ctx, ctrl.Request{\n\t\tNamespacedName: types.NamespacedName{Name: \"test-sandbox\", Namespace: \"default\"},\n\t})\n\n\tif err == nil {\n\t\tt.Error(\"Expected error for cancelled context\")\n\t}\n}\n\n// TestReconcile_ValidRFC3339Variants tests various valid RFC3339 formats.\nfunc TestReconcile_ValidRFC3339Variants(t *testing.T) {\n\tvalidTimestamps := []string{\n\t\ttime.Now().UTC().Add(-20 * time.Minute).Format(time.RFC3339),\n\t\ttime.Now().UTC().Add(-20 * time.Minute).Format(time.RFC3339Nano),\n\t}\n\n\tfor _, ts := range validTimestamps {\n\t\tt.Run(ts, func(t *testing.T) {\n\t\t\tsandbox := createSandbox(\"test-sandbox\", \"default\", ts)\n\n\t\t\tdeleteCalled := false\n\t\t\tmock := &mockClient{\n\t\t\t\tgetFunc: func(ctx context.Context, key client.ObjectKey, obj client.Object, opts ...client.GetOption) error {\n\t\t\t\t\tsandboxObj := obj.(*v1alpha1.Sandbox)\n\t\t\t\t\tsandboxObj.Name = sandbox.Name\n\t\t\t\t\tsandboxObj.Namespace = sandbox.Namespace\n\t\t\t\t\tsandboxObj.Annotations = sandbox.Annotations\n\t\t\t\t\treturn nil\n\t\t\t\t},\n\t\t\t\tdeleteFunc: func(ctx context.Context, obj client.Object, opts ...client.DeleteOption) error {\n\t\t\t\t\tdeleteCalled = true\n\t\t\t\t\treturn nil\n\t\t\t\t},\n\t\t\t}\n\n\t\t\tr := &Reconciler{Client: mock}\n\t\t\tresult, err := r.Reconcile(context.Background(), ctrl.Request{\n\t\t\t\tNamespacedName: types.NamespacedName{Name: \"test-sandbox\", Namespace: \"default\"},\n\t\t\t})\n\n\t\t\tif err != nil {\n\t\t\t\tt.Errorf(\"Expected no error, got: %v\", err)\n\t\t\t}\n\t\t\tif result.RequeueAfter != 0 {\n\t\t\t\tt.Errorf(\"Expected no requeue for expired sandbox, got: %v\", result.RequeueAfter)\n\t\t\t}\n\t\t\tif !deleteCalled {\n\t\t\t\tt.Error(\"Expected Delete to be called for expired sandbox\")\n\t\t\t}\n\t\t})\n\t}\n}\n\n// TestReconcile_MultipleNamespaces tests reconciliation across namespaces.\nfunc TestReconcile_MultipleNamespaces(t *testing.T) {\n\tnamespaces := []string{\"default\", \"kube-system\", \"agentcube\", \"test-ns\"}\n\n\tfor _, ns := range namespaces {\n\t\tt.Run(ns, func(t *testing.T) {\n\t\t\tlastActivity := time.Now().UTC().Add(-20 * time.Minute).Format(time.RFC3339)\n\t\t\tsandbox := createSandbox(\"test-sandbox\", ns, lastActivity)\n\n\t\t\tdeleteCalled := false\n\t\t\tmock := &mockClient{\n\t\t\t\tgetFunc: func(ctx context.Context, key client.ObjectKey, obj client.Object, opts ...client.GetOption) error {\n\t\t\t\t\tsandboxObj := obj.(*v1alpha1.Sandbox)\n\t\t\t\t\tsandboxObj.Name = sandbox.Name\n\t\t\t\t\tsandboxObj.Namespace = sandbox.Namespace\n\t\t\t\t\tsandboxObj.Annotations = sandbox.Annotations\n\t\t\t\t\treturn nil\n\t\t\t\t},\n\t\t\t\tdeleteFunc: func(ctx context.Context, obj client.Object, opts ...client.DeleteOption) error {\n\t\t\t\t\tdeleteCalled = true\n\t\t\t\t\treturn nil\n\t\t\t\t},\n\t\t\t}\n\n\t\t\tr := &Reconciler{Client: mock}\n\t\t\tresult, err := r.Reconcile(context.Background(), ctrl.Request{\n\t\t\t\tNamespacedName: types.NamespacedName{Name: \"test-sandbox\", Namespace: ns},\n\t\t\t})\n\n\t\t\tif err != nil {\n\t\t\t\tt.Errorf(\"Expected no error, got: %v\", err)\n\t\t\t}\n\t\t\tif result.RequeueAfter != 0 {\n\t\t\t\tt.Errorf(\"Expected no requeue, got: %v\", result.RequeueAfter)\n\t\t\t}\n\t\t\tif !deleteCalled {\n\t\t\t\tt.Error(\"Expected Delete to be called\")\n\t\t\t}\n\t\t})\n\t}\n}\n\n// TestWorkloadManager_LastActivityAnnotationKey tests the constant value.\nfunc TestWorkloadManager_LastActivityAnnotationKey(t *testing.T) {\n\texpected := \"last-activity-time\"\n\tif workloadmanager.LastActivityAnnotationKey != expected {\n\t\tt.Errorf(\"Expected LastActivityAnnotationKey to be '%s', got '%s'\", expected, workloadmanager.LastActivityAnnotationKey)\n\t}\n}\n\n// TestReconcile_ZeroTime tests edge case with zero timestamp (far in the past).\nfunc TestReconcile_ZeroTime(t *testing.T) {\n\t// Zero time is far in the past, so it should be considered expired\n\tzeroTime := time.Time{}.UTC().Format(time.RFC3339)\n\tsandbox := createSandbox(\"test-sandbox\", \"default\", zeroTime)\n\n\tdeleteCalled := false\n\tmock := &mockClient{\n\t\tgetFunc: func(ctx context.Context, key client.ObjectKey, obj client.Object, opts ...client.GetOption) error {\n\t\t\tsandboxObj := obj.(*v1alpha1.Sandbox)\n\t\t\tsandboxObj.Name = sandbox.Name\n\t\t\tsandboxObj.Namespace = sandbox.Namespace\n\t\t\tsandboxObj.Annotations = sandbox.Annotations\n\t\t\treturn nil\n\t\t},\n\t\tdeleteFunc: func(ctx context.Context, obj client.Object, opts ...client.DeleteOption) error {\n\t\t\tdeleteCalled = true\n\t\t\treturn nil\n\t\t},\n\t}\n\n\tr := &Reconciler{Client: mock}\n\tresult, err := r.Reconcile(context.Background(), ctrl.Request{\n\t\tNamespacedName: types.NamespacedName{Name: \"test-sandbox\", Namespace: \"default\"},\n\t})\n\n\tif err != nil {\n\t\tt.Errorf(\"Expected no error, got: %v\", err)\n\t}\n\tif result.RequeueAfter != 0 {\n\t\tt.Errorf(\"Expected no requeue for expired sandbox, got: %v\", result.RequeueAfter)\n\t}\n\tif !deleteCalled {\n\t\tt.Error(\"Expected Delete to be called for zero time (far in past)\")\n\t}\n}\n\n// TestReconcile_JustBeforeExpiration tests sandbox that expires very soon.\nfunc TestReconcile_JustBeforeExpiration(t *testing.T) {\n\t// Last activity 14 minutes 59 seconds ago - just about to expire\n\tlastActivity := time.Now().UTC().Add(-(14*time.Minute + 59*time.Second)).Format(time.RFC3339)\n\tsandbox := createSandbox(\"test-sandbox\", \"default\", lastActivity)\n\n\tmock := &mockClient{\n\t\tgetFunc: func(ctx context.Context, key client.ObjectKey, obj client.Object, opts ...client.GetOption) error {\n\t\t\tsandboxObj := obj.(*v1alpha1.Sandbox)\n\t\t\tsandboxObj.Name = sandbox.Name\n\t\t\tsandboxObj.Namespace = sandbox.Namespace\n\t\t\tsandboxObj.Annotations = sandbox.Annotations\n\t\t\treturn nil\n\t\t},\n\t}\n\n\tr := &Reconciler{Client: mock}\n\tresult, err := r.Reconcile(context.Background(), ctrl.Request{\n\t\tNamespacedName: types.NamespacedName{Name: \"test-sandbox\", Namespace: \"default\"},\n\t})\n\n\tif err != nil {\n\t\tt.Errorf(\"Expected no error, got: %v\", err)\n\t}\n\t// Should requeue very soon (within 1 minute)\n\tif result.RequeueAfter > 2*time.Minute {\n\t\tt.Errorf(\"Expected RequeueAfter < 2m for near-expiration, got %v\", result.RequeueAfter)\n\t}\n}\n\n// MockStatusWriter implements client.StatusWriter for testing.\ntype MockStatusWriter struct{}\n\nfunc (m *MockStatusWriter) Create(ctx context.Context, obj client.Object, subResource client.Object, opts ...client.SubResourceCreateOption) error {\n\treturn nil\n}\n\nfunc (m *MockStatusWriter) Update(ctx context.Context, obj client.Object, opts ...client.SubResourceUpdateOption) error {\n\treturn nil\n}\n\nfunc (m *MockStatusWriter) Patch(ctx context.Context, obj client.Object, patch client.Patch, opts ...client.SubResourcePatchOption) error {\n\treturn nil\n}\n\n// MockClient is a more complete mock implementation\ntype MockClient struct {\n\tclient.Client\n\tGetFunc    func(ctx context.Context, key client.ObjectKey, obj client.Object, opts ...client.GetOption) error\n\tListFunc   func(ctx context.Context, list client.ObjectList, opts ...client.ListOption) error\n\tCreateFunc func(ctx context.Context, obj client.Object, opts ...client.CreateOption) error\n\tDeleteFunc func(ctx context.Context, obj client.Object, opts ...client.DeleteOption) error\n\tUpdateFunc func(ctx context.Context, obj client.Object, opts ...client.UpdateOption) error\n\tPatchFunc  func(ctx context.Context, obj client.Object, patch client.Patch, opts ...client.PatchOption) error\n\tSchemeFunc func() *runtime.Scheme\n}\n\nfunc (m *MockClient) Get(ctx context.Context, key client.ObjectKey, obj client.Object, opts ...client.GetOption) error {\n\tif m.GetFunc != nil {\n\t\treturn m.GetFunc(ctx, key, obj, opts...)\n\t}\n\treturn nil\n}\n\nfunc (m *MockClient) List(ctx context.Context, list client.ObjectList, opts ...client.ListOption) error {\n\tif m.ListFunc != nil {\n\t\treturn m.ListFunc(ctx, list, opts...)\n\t}\n\treturn nil\n}\n\nfunc (m *MockClient) Create(ctx context.Context, obj client.Object, opts ...client.CreateOption) error {\n\tif m.CreateFunc != nil {\n\t\treturn m.CreateFunc(ctx, obj, opts...)\n\t}\n\treturn nil\n}\n\nfunc (m *MockClient) Delete(ctx context.Context, obj client.Object, opts ...client.DeleteOption) error {\n\tif m.DeleteFunc != nil {\n\t\treturn m.DeleteFunc(ctx, obj, opts...)\n\t}\n\treturn nil\n}\n\nfunc (m *MockClient) Update(ctx context.Context, obj client.Object, opts ...client.UpdateOption) error {\n\tif m.UpdateFunc != nil {\n\t\treturn m.UpdateFunc(ctx, obj, opts...)\n\t}\n\treturn nil\n}\n\nfunc (m *MockClient) Patch(ctx context.Context, obj client.Object, patch client.Patch, opts ...client.PatchOption) error {\n\tif m.PatchFunc != nil {\n\t\treturn m.PatchFunc(ctx, obj, patch, opts...)\n\t}\n\treturn nil\n}\n\nfunc (m *MockClient) DeleteAllOf(ctx context.Context, obj client.Object, opts ...client.DeleteAllOfOption) error {\n\treturn nil\n}\n\nfunc (m *MockClient) Status() client.StatusWriter {\n\treturn &MockStatusWriter{}\n}\n\nfunc (m *MockClient) SubResource(subResource string) client.SubResourceClient {\n\treturn nil\n}\n\nfunc (m *MockClient) Scheme() *runtime.Scheme {\n\tif m.SchemeFunc != nil {\n\t\treturn m.SchemeFunc()\n\t}\n\treturn nil\n}\n\nfunc (m *MockClient) RESTMapper() ctrl.RESTMapper {\n\treturn nil\n}\n\nfunc (m *MockClient) GroupVersionKindFor(obj runtime.Object) (ctrl.GroupVersionKind, error) {\n\treturn ctrl.GroupVersionKind{}, nil\n}\n\nfunc (m *MockClient) IsObjectNamespaced(obj runtime.Object) (bool, error) {\n\treturn true, nil\n}\n\n// BenchmarkReconcile benchmarks the reconcile function.\nfunc BenchmarkReconcile(b *testing.B) {\n\tlastActivity := time.Now().UTC().Add(-20 * time.Minute).Format(time.RFC3339)\n\tsandbox := createSandbox(\"test-sandbox\", \"default\", lastActivity)\n\n\tmock := &MockClient{\n\t\tGetFunc: func(ctx context.Context, key client.ObjectKey, obj client.Object, opts ...client.GetOption) error {\n\t\t\tsandboxObj := obj.(*v1alpha1.Sandbox)\n\t\t\tsandboxObj.Name = sandbox.Name\n\t\t\tsandboxObj.Namespace = sandbox.Namespace\n\t\t\tsandboxObj.Annotations = sandbox.Annotations\n\t\t\treturn nil\n\t\t},\n\t\tDeleteFunc: func(ctx context.Context, obj client.Object, opts ...client.DeleteOption) error {\n\t\t\treturn nil\n\t\t},\n\t}\n\n\tr := &Reconciler{Client: mock}\n\tctx := context.Background()\n\treq := ctrl.Request{\n\t\tNamespacedName: types.NamespacedName{Name: \"test-sandbox\", Namespace: \"default\"},\n\t}\n\n\tb.ResetTimer()\n\tfor i := 0; i < b.N; i++ {\n\t\t_, err := r.Reconcile(ctx, req)\n\t\tif err != nil {\n\t\t\tb.Fatalf(\"Unexpected error: %v\", err)\n\t\t}\n\t}\n}\n\n// TestReconcile_EdgeCase_FarFuture tests timestamp far in the future.\nfunc TestReconcile_EdgeCase_FarFuture(t *testing.T) {\n\t// Far future timestamp (1 year from now) - should not be expired\n\tlastActivity := time.Now().UTC().Add(365 * 24 * time.Hour).Format(time.RFC3339)\n\tsandbox := createSandbox(\"test-sandbox\", \"default\", lastActivity)\n\n\tmock := &mockClient{\n\t\tgetFunc: func(ctx context.Context, key client.ObjectKey, obj client.Object, opts ...client.GetOption) error {\n\t\t\tsandboxObj := obj.(*v1alpha1.Sandbox)\n\t\t\tsandboxObj.Name = sandbox.Name\n\t\t\tsandboxObj.Namespace = sandbox.Namespace\n\t\t\tsandboxObj.Annotations = sandbox.Annotations\n\t\t\treturn nil\n\t\t},\n\t}\n\n\tr := &Reconciler{Client: mock}\n\tresult, err := r.Reconcile(context.Background(), ctrl.Request{\n\t\tNamespacedName: types.NamespacedName{Name: \"test-sandbox\", Namespace: \"default\"},\n\t})\n\n\tif err != nil {\n\t\tt.Errorf(\"Expected no error, got: %v\", err)\n\t}\n\t// Should requeue after a very long time (1 year + 15 minutes)\n\tminExpected := 364 * 24 * time.Hour // At least 364 days\n\tif result.RequeueAfter < minExpected {\n\t\tt.Errorf(\"Expected RequeueAfter > %v for far future, got %v\", minExpected, result.RequeueAfter)\n\t}\n}\n\n// cmpDiff is a helper for comparing using cmp.Diff\nfunc cmpDiff(x, y interface{}) string {\n\treturn cmp.Diff(x, y)\n}\n","after":"/*\nCopyright 2026 The Volcano Authors.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\npackage agentd\n\nimport (\n\t\"context\"\n\t\"errors\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/google/go-cmp/cmp\"\n\t\"k8s.io/apimachinery/pkg/api/meta\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/apimachinery/pkg/runtime\"\n\t\"k8s.io/apimachinery/pkg/runtime/schema\"\n\t\"k8s.io/apimachinery/pkg/types\"\n\tctrl \"sigs.k8s.io/controller-runtime\"\n\t\"sigs.k8s.io/controller-runtime/pkg/client\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1\"\n\t\"github.com/volcano-sh/agentcube/pkg/workloadmanager\"\n)\n\n// mockClient is a mock implementation of client.Client for testing.\ntype mockClient struct {\n\tclient.Client\n\tgetFunc    func(ctx context.Context, key client.ObjectKey, obj client.Object, opts ...client.GetOption) error\n\tdeleteFunc func(ctx context.Context, obj client.Object, opts ...client.DeleteOption) error\n}\n\nfunc (m *mockClient) Get(ctx context.Context, key client.ObjectKey, obj client.Object, opts ...client.GetOption) error {\n\tif m.getFunc != nil {\n\t\treturn m.getFunc(ctx, key, obj, opts...)\n\t}\n\treturn nil\n}\n\nfunc (m *mockClient) Delete(ctx context.Context, obj client.Object, opts ...client.DeleteOption) error {\n\tif m.deleteFunc != nil {\n\t\treturn m.deleteFunc(ctx, obj, opts...)\n\t}\n\treturn nil\n}\n\n// notFoundError implements the IsNotFound check\ntype notFoundError struct{}\n\nfunc (e notFoundError) Error() string { return \"not found\" }\nfunc (e notFoundError) Status() metav1.Status {\n\treturn metav1.Status{Code: 404, Reason: \"NotFound\"}\n}\n\n// testError implements a generic error\ntype testError struct{}\n\nfunc (e testError) Error() string { return \"test error\" }\n\n// createSandbox creates a test Sandbox with the given annotation.\nfunc createSandbox(name, namespace, lastActivity string) *v1alpha1.Sandbox {\n\tsandbox := &v1alpha1.Sandbox{\n\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\tName:        name,\n\t\t\tNamespace:   namespace,\n\t\t\tAnnotations: make(map[string]string),\n\t\t},\n\t}\n\tif lastActivity != \"\" {\n\t\tsandbox.Annotations[workloadmanager.LastActivityAnnotationKey] = lastActivity\n\t}\n\treturn sandbox\n}\n\n// TestReconcile_SandboxNotFound tests that NotFound errors on Get are handled gracefully.\nfunc TestReconcile_SandboxNotFound(t *testing.T) {\n\tmock := &mockClient{\n\t\tgetFunc: func(ctx context.Context, key client.ObjectKey, obj client.Object, opts ...client.GetOption) error {\n\t\t\treturn notFoundError{}\n\t\t},\n\t}\n\n\tr := &Reconciler{Client: mock}\n\tresult, err := r.Reconcile(context.Background(), ctrl.Request{\n\t\tNamespacedName: types.NamespacedName{Name: \"test-sandbox\", Namespace: \"default\"},\n\t})\n\n\tif err != nil {\n\t\tt.Errorf(\"Expected no error, got: %v\", err)\n\t}\n\tif result.Requeue || result.RequeueAfter != 0 {\n\t\tt.Errorf(\"Expected empty result, got: %+v\", result)\n\t}\n}\n\n// TestReconcile_GetError tests that other Get errors are returned.\nfunc TestReconcile_GetError(t *testing.T) {\n\tmock := &mockClient{\n\t\tgetFunc: func(ctx context.Context, key client.ObjectKey, obj client.Object, opts ...client.GetOption) error {\n\t\t\treturn testError{}\n\t\t},\n\t}\n\n\tr := &Reconciler{Client: mock}\n\tresult, err := r.Reconcile(context.Background(), ctrl.Request{\n\t\tNamespacedName: types.NamespacedName{Name: \"test-sandbox\", Namespace: \"default\"},\n\t})\n\n\tif err == nil {\n\t\tt.Error(\"Expected error, got nil\")\n\t}\n\tif result.RequeueAfter != 0 {\n\t\tt.Errorf(\"Expected no requeue, got: %v\", result.RequeueAfter)\n\t}\n}\n\n// TestReconcile_NoAnnotation tests that missing annotation returns empty result.\nfunc TestReconcile_NoAnnotation(t *testing.T) {\n\tsandbox := createSandbox(\"test-sandbox\", \"default\", \"\")\n\t// No annotation set\n\n\tmock := &mockClient{\n\t\tgetFunc: func(ctx context.Context, key client.ObjectKey, obj client.Object, opts ...client.GetOption) error {\n\t\t\tsandboxObj := obj.(*v1alpha1.Sandbox)\n\t\t\tsandboxObj.Name = sandbox.Name\n\t\t\tsandboxObj.Namespace = sandbox.Namespace\n\t\t\tsandboxObj.Annotations = sandbox.Annotations\n\t\t\treturn nil\n\t\t},\n\t}\n\n\tr := &Reconciler{Client: mock}\n\tresult, err := r.Reconcile(context.Background(), ctrl.Request{\n\t\tNamespacedName: types.NamespacedName{Name: \"test-sandbox\", Namespace: \"default\"},\n\t})\n\n\tif err != nil {\n\t\tt.Errorf(\"Expected no error, got: %v\", err)\n\t}\n\tif result.Requeue || result.RequeueAfter != 0 {\n\t\tt.Errorf(\"Expected empty result, got: %+v\", result)\n\t}\n}\n\n// TestReconcile_EmptyAnnotation tests that empty annotation value returns empty result.\nfunc TestReconcile_EmptyAnnotation(t *testing.T) {\n\tsandbox := createSandbox(\"test-sandbox\", \"default\", \"\")\n\tsandbox.Annotations[workloadmanager.LastActivityAnnotationKey] = \"\"\n\n\tmock := &mockClient{\n\t\tgetFunc: func(ctx context.Context, key client.ObjectKey, obj client.Object, opts ...client.GetOption) error {\n\t\t\tsandboxObj := obj.(*v1alpha1.Sandbox)\n\t\t\tsandboxObj.Name = sandbox.Name\n\t\t\tsandboxObj.Namespace = sandbox.Namespace\n\t\t\tsandboxObj.Annotations = sandbox.Annotations\n\t\t\treturn nil\n\t\t},\n\t}\n\n\tr := &Reconciler{Client: mock}\n\tresult, err := r.Reconcile(context.Background(), ctrl.Request{\n\t\tNamespacedName: types.NamespacedName{Name: \"test-sandbox\", Namespace: \"default\"},\n\t})\n\n\tif err != nil {\n\t\tt.Errorf(\"Expected no error, got: %v\", err)\n\t}\n\tif result.Requeue || result.RequeueAfter != 0 {\n\t\tt.Errorf(\"Expected empty result, got: %+v\", result)\n\t}\n}\n\n// TestReconcile_InvalidTimestamp tests that invalid timestamp requeues with 30s.\nfunc TestReconcile_InvalidTimestamp(t *testing.T) {\n\tsandbox := createSandbox(\"test-sandbox\", \"default\", \"invalid-timestamp\")\n\n\tmock := &mockClient{\n\t\tgetFunc: func(ctx context.Context, key client.ObjectKey, obj client.Object, opts ...client.GetOption) error {\n\t\t\tsandboxObj := obj.(*v1alpha1.Sandbox)\n\t\t\tsandboxObj.Name = sandbox.Name\n\t\t\tsandboxObj.Namespace = sandbox.Namespace\n\t\t\tsandboxObj.Annotations = sandbox.Annotations\n\t\t\treturn nil\n\t\t},\n\t}\n\n\tr := &Reconciler{Client: mock}\n\tresult, err := r.Reconcile(context.Background(), ctrl.Request{\n\t\tNamespacedName: types.NamespacedName{Name: \"test-sandbox\", Namespace: \"default\"},\n\t})\n\n\tif err == nil {\n\t\tt.Error(\"Expected error for invalid timestamp\")\n\t}\n\texpectedRequeue := RequeueAfterParseError\n\tif result.RequeueAfter != expectedRequeue {\n\t\tt.Errorf(\"Expected RequeueAfter %v, got %v\", expectedRequeue, result.RequeueAfter)\n\t}\n}\n\n// TestReconcile_NotExpired tests that non-expired sandbox requeues at expiration time.\nfunc TestReconcile_NotExpired(t *testing.T) {\n\t// Last activity 5 minutes ago\n\tlastActivity := time.Now().UTC().Add(-5 * time.Minute).Format(time.RFC3339)\n\tsandbox := createSandbox(\"test-sandbox\", \"default\", lastActivity)\n\n\tmock := &mockClient{\n\t\tgetFunc: func(ctx context.Context, key client.ObjectKey, obj client.Object, opts ...client.GetOption) error {\n\t\t\tsandboxObj := obj.(*v1alpha1.Sandbox)\n\t\t\tsandboxObj.Name = sandbox.Name\n\t\t\tsandboxObj.Namespace = sandbox.Namespace\n\t\t\tsandboxObj.Annotations = sandbox.Annotations\n\t\t\treturn nil\n\t\t},\n\t}\n\n\tr := &Reconciler{Client: mock}\n\tresult, err := r.Reconcile(context.Background(), ctrl.Request{\n\t\tNamespacedName: types.NamespacedName{Name: \"test-sandbox\", Namespace: \"default\"},\n\t})\n\n\tif err != nil {\n\t\tt.Errorf(\"Expected no error, got: %v\", err)\n\t}\n\n\t// Should requeue after approximately 10 minutes (15 min timeout - 5 min elapsed)\n\texpectedMin := 9 * time.Minute\n\texpectedMax := 11 * time.Minute\n\tif result.RequeueAfter < expectedMin || result.RequeueAfter > expectedMax {\n\t\tt.Errorf(\"Expected RequeueAfter between %v and %v, got %v\", expectedMin, expectedMax, result.RequeueAfter)\n\t}\n}\n\n// TestReconcile_JustExpired tests that sandbox exactly at expiration is deleted.\nfunc TestReconcile_JustExpired(t *testing.T) {\n\t// Last activity exactly 15 minutes ago\n\tlastActivity := time.Now().UTC().Add(-15 * time.Minute).Format(time.RFC3339)\n\tsandbox := createSandbox(\"test-sandbox\", \"default\", lastActivity)\n\n\tdeleteCalled := false\n\tmock := &mockClient{\n\t\tgetFunc: func(ctx context.Context, key client.ObjectKey, obj client.Object, opts ...client.GetOption) error {\n\t\t\tsandboxObj := obj.(*v1alpha1.Sandbox)\n\t\t\tsandboxObj.Name = sandbox.Name\n\t\t\tsandboxObj.Namespace = sandbox.Namespace\n\t\t\tsandboxObj.Annotations = sandbox.Annotations\n\t\t\treturn nil\n\t\t},\n\t\tdeleteFunc: func(ctx context.Context, obj client.Object, opts ...client.DeleteOption) error {\n\t\t\tdeleteCalled = true\n\t\t\treturn nil\n\t\t},\n\t}\n\n\tr := &Reconciler{Client: mock}\n\tresult, err := r.Reconcile(context.Background(), ctrl.Request{\n\t\tNamespacedName: types.NamespacedName{Name: \"test-sandbox\", Namespace: \"default\"},\n\t})\n\n\tif err != nil {\n\t\tt.Errorf(\"Expected no error, got: %v\", err)\n\t}\n\tif result.RequeueAfter != 0 {\n\t\tt.Errorf(\"Expected no requeue, got: %v\", result.RequeueAfter)\n\t}\n\tif !deleteCalled {\n\t\tt.Error(\"Expected Delete to be called\")\n\t}\n}\n\n// TestReconcile_Expired tests that expired sandbox is deleted.\nfunc TestReconcile_Expired(t *testing.T) {\n\t// Last activity 20 minutes ago\n\tlastActivity := time.Now().UTC().Add(-20 * time.Minute).Format(time.RFC3339)\n\tsandbox := createSandbox(\"test-sandbox\", \"default\", lastActivity)\n\n\tdeleteCalled := false\n\tmock := &mockClient{\n\t\tgetFunc: func(ctx context.Context, key client.ObjectKey, obj client.Object, opts ...client.GetOption) error {\n\t\t\tsandboxObj := obj.(*v1alpha1.Sandbox)\n\t\t\tsandboxObj.Name = sandbox.Name\n\t\t\tsandboxObj.Namespace = sandbox.Namespace\n\t\t\tsandboxObj.Annotations = sandbox.Annotations\n\t\t\treturn nil\n\t\t},\n\t\tdeleteFunc: func(ctx context.Context, obj client.Object, opts ...client.DeleteOption) error {\n\t\t\tdeleteCalled = true\n\t\t\treturn nil\n\t\t},\n\t}\n\n\tr := &Reconciler{Client: mock}\n\tresult, err := r.Reconcile(context.Background(), ctrl.Request{\n\t\tNamespacedName: types.NamespacedName{Name: \"test-sandbox\", Namespace: \"default\"},\n\t})\n\n\tif err != nil {\n\t\tt.Errorf(\"Expected no error, got: %v\", err)\n\t}\n\tif result.RequeueAfter != 0 {\n\t\tt.Errorf(\"Expected no requeue, got: %v\", result.RequeueAfter)\n\t}\n\tif !deleteCalled {\n\t\tt.Error(\"Expected Delete to be called\")\n\t}\n}\n\n// TestReconcile_DeleteNotFound tests that NotFound on delete is handled gracefully.\nfunc TestReconcile_DeleteNotFound(t *testing.T) {\n\t// Last activity 20 minutes ago\n\tlastActivity := time.Now().UTC().Add(-20 * time.Minute).Format(time.RFC3339)\n\tsandbox := createSandbox(\"test-sandbox\", \"default\", lastActivity)\n\n\tmock := &mockClient{\n\t\tgetFunc: func(ctx context.Context, key client.ObjectKey, obj client.Object, opts ...client.GetOption) error {\n\t\t\tsandboxObj := obj.(*v1alpha1.Sandbox)\n\t\t\tsandboxObj.Name = sandbox.Name\n\t\t\tsandboxObj.Namespace = sandbox.Namespace\n\t\t\tsandboxObj.Annotations = sandbox.Annotations\n\t\t\treturn nil\n\t\t},\n\t\tdeleteFunc: func(ctx context.Context, obj client.Object, opts ...client.DeleteOption) error {\n\t\t\treturn notFoundError{}\n\t\t},\n\t}\n\n\tr := &Reconciler{Client: mock}\n\tresult, err := r.Reconcile(context.Background(), ctrl.Request{\n\t\tNamespacedName: types.NamespacedName{Name: \"test-sandbox\", Namespace: \"default\"},\n\t})\n\n\tif err != nil {\n\t\tt.Errorf(\"Expected no error for NotFound, got: %v\", err)\n\t}\n\tif result.RequeueAfter != 0 {\n\t\tt.Errorf(\"Expected no requeue, got: %v\", result.RequeueAfter)\n\t}\n}\n\n// TestReconcile_DeleteError tests that other delete errors are returned.\nfunc TestReconcile_DeleteError(t *testing.T) {\n\t// Last activity 20 minutes ago\n\tlastActivity := time.Now().UTC().Add(-20 * time.Minute).Format(time.RFC3339)\n\tsandbox := createSandbox(\"test-sandbox\", \"default\", lastActivity)\n\n\tmock := &mockClient{\n\t\tgetFunc: func(ctx context.Context, key client.ObjectKey, obj client.Object, opts ...client.GetOption) error {\n\t\t\tsandboxObj := obj.(*v1alpha1.Sandbox)\n\t\t\tsandboxObj.Name = sandbox.Name\n\t\t\tsandboxObj.Namespace = sandbox.Namespace\n\t\t\tsandboxObj.Annotations = sandbox.Annotations\n\t\t\treturn nil\n\t\t},\n\t\tdeleteFunc: func(ctx context.Context, obj client.Object, opts ...client.DeleteOption) error {\n\t\t\treturn testError{}\n\t\t},\n\t}\n\n\tr := &Reconciler{Client: mock}\n\tresult, err := r.Reconcile(context.Background(), ctrl.Request{\n\t\tNamespacedName: types.NamespacedName{Name: \"test-sandbox\", Namespace: \"default\"},\n\t})\n\n\tif err == nil {\n\t\tt.Error(\"Expected error for delete failure\")\n\t}\n\tif result.RequeueAfter != 0 {\n\t\tt.Errorf(\"Expected no requeue, got: %v\", result.RequeueAfter)\n\t}\n}\n\n// TestReconcile_FutureExpirationRequeue tests that RequeueAfter is calculated correctly.\nfunc TestReconcile_FutureExpirationRequeue(t *testing.T) {\n\t// Test multiple scenarios\n\ttests := []struct {\n\t\tname        string\n\t\tminutesAgo  time.Duration\n\t\texpectedMin time.Duration\n\t\texpectedMax time.Duration\n\t}{\n\t\t{\n\t\t\tname:        \"Just created (0 min ago)\",\n\t\t\tminutesAgo:  0,\n\t\t\texpectedMin: 14 * time.Minute,\n\t\t\texpectedMax: 16 * time.Minute,\n\t\t},\n\t\t{\n\t\t\tname:        \"1 minute ago\",\n\t\t\tminutesAgo:  1 * time.Minute,\n\t\t\texpectedMin: 13 * time.Minute,\n\t\t\texpectedMax: 15 * time.Minute,\n\t\t},\n\t\t{\n\t\t\tname:        \"10 minutes ago\",\n\t\t\tminutesAgo:  10 * time.Minute,\n\t\t\texpectedMin: 4 * time.Minute,\n\t\t\texpectedMax: 6 * time.Minute,\n\t\t},\n\t\t{\n\t\t\tname:        \"14 minutes ago\",\n\t\t\tminutesAgo:  14 * time.Minute,\n\t\t\texpectedMin: 0 * time.Second,\n\t\t\texpectedMax: 2 * time.Minute,\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tlastActivity := time.Now().UTC().Add(-tt.minutesAgo).Format(time.RFC3339)\n\t\t\tsandbox := createSandbox(\"test-sandbox\", \"default\", lastActivity)\n\n\t\t\tmock := &mockClient{\n\t\t\t\tgetFunc: func(ctx context.Context, key client.ObjectKey, obj client.Object, opts ...client.GetOption) error {\n\t\t\t\t\tsandboxObj := obj.(*v1alpha1.Sandbox)\n\t\t\t\t\tsandboxObj.Name = sandbox.Name\n\t\t\t\t\tsandboxObj.Namespace = sandbox.Namespace\n\t\t\t\t\tsandboxObj.Annotations = sandbox.Annotations\n\t\t\t\t\treturn nil\n\t\t\t\t},\n\t\t\t}\n\n\t\t\tr := &Reconciler{Client: mock}\n\t\t\tresult, err := r.Reconcile(context.Background(), ctrl.Request{\n\t\t\t\tNamespacedName: types.NamespacedName{Name: \"test-sandbox\", Namespace: \"default\"},\n\t\t\t})\n\n\t\t\tif err != nil {\n\t\t\t\tt.Errorf(\"Expected no error, got: %v\", err)\n\t\t\t}\n\t\t\tif result.RequeueAfter < tt.expectedMin || result.RequeueAfter > tt.expectedMax {\n\t\t\t\tt.Errorf(\"Expected RequeueAfter between %v and %v, got %v\", tt.expectedMin, tt.expectedMax, result.RequeueAfter)\n\t\t\t}\n\t\t})\n\t}\n}\n\n// TestReconciler_Struct tests the Reconciler struct fields.\nfunc TestReconciler_Struct(t *testing.T) {\n\tscheme := runtime.NewScheme()\n\tr := &Reconciler{\n\t\tClient: nil,\n\t\tScheme: scheme,\n\t}\n\n\tif r.Client != nil {\n\t\tt.Error(\"Expected Client to be nil\")\n\t}\n\tif r.Scheme != scheme {\n\t\tt.Error(\"Expected Scheme to match\")\n\t}\n}\n\n// TestConstants tests that constants are properly defined.\nfunc TestConstants(t *testing.T) {\n\tif SessionExpirationTimeout != 15*time.Minute {\n\t\tt.Errorf(\"SessionExpirationTimeout expected 15m, got %v\", SessionExpirationTimeout)\n\t}\n\tif RequeueAfterParseError != 30*time.Second {\n\t\tt.Errorf(\"RequeueAfterParseError expected 30s, got %v\", RequeueAfterParseError)\n\t}\n}\n\n// TestCreateSandbox tests the test helper function.\nfunc TestCreateSandbox(t *testing.T) {\n\tsandbox := createSandbox(\"test\", \"default\", \"2024-01-01T00:00:00Z\")\n\n\tif sandbox.Name != \"test\" {\n\t\tt.Errorf(\"Expected name 'test', got '%s'\", sandbox.Name)\n\t}\n\tif sandbox.Namespace != \"default\" {\n\t\tt.Errorf(\"Expected namespace 'default', got '%s'\", sandbox.Namespace)\n\t}\n\tif sandbox.Annotations[workloadmanager.LastActivityAnnotationKey] != \"2024-01-01T00:00:00Z\" {\n\t\tt.Errorf(\"Expected annotation value, got '%s'\", sandbox.Annotations[workloadmanager.LastActivityAnnotationKey])\n\t}\n}\n\n// TestCreateSandbox_NoAnnotation tests creating sandbox without annotation.\nfunc TestCreateSandbox_NoAnnotation(t *testing.T) {\n\tsandbox := createSandbox(\"test\", \"default\", \"\")\n\n\tif _, exists := sandbox.Annotations[workloadmanager.LastActivityAnnotationKey]; exists {\n\t\tt.Error(\"Expected no annotation when empty value\")\n\t}\n}\n\n// TestMockClient implements a more realistic mock client test.\nfunc TestMockClient(t *testing.T) {\n\tctx := context.Background()\n\n\tt.Run(\"Get returns error\", func(t *testing.T) {\n\t\texpectedErr := errors.New(\"get error\")\n\t\tmock := &mockClient{\n\t\t\tgetFunc: func(ctx context.Context, key client.ObjectKey, obj client.Object, opts ...client.GetOption) error {\n\t\t\t\treturn expectedErr\n\t\t\t},\n\t\t}\n\n\t\tsandbox := &v1alpha1.Sandbox{}\n\t\terr := mock.Get(ctx, client.ObjectKey{Name: \"test\"}, sandbox)\n\t\tif !errors.Is(err, expectedErr) && err.Error() != expectedErr.Error() {\n\t\t\tt.Errorf(\"Expected error '%v', got '%v'\", expectedErr, err)\n\t\t}\n\t})\n\n\tt.Run(\"Delete returns error\", func(t *testing.T) {\n\t\texpectedErr := errors.New(\"delete error\")\n\t\tmock := &mockClient{\n\t\t\tdeleteFunc: func(ctx context.Context, obj client.Object, opts ...client.DeleteOption) error {\n\t\t\t\treturn expectedErr\n\t\t\t},\n\t\t}\n\n\t\tsandbox := &v1alpha1.Sandbox{}\n\t\terr := mock.Delete(ctx, sandbox)\n\t\tif !errors.Is(err, expectedErr) && err.Error() != expectedErr.Error() {\n\t\t\tt.Errorf(\"Expected error '%v', got '%v'\", expectedErr, err)\n\t\t}\n\t})\n}\n\n// TestReconcile_MalformedTimestamp tests various malformed timestamps.\nfunc TestReconcile_MalformedTimestamp(t *testing.T) {\n\tmalformedTimestamps := []string{\n\t\t\"2024-13-45T99:99:99Z\", // Invalid date/time\n\t\t\"not-a-timestamp\",\n\t\t\"\",\n\t\t\"2024\",\n\t\t\"01-15-2024\",\n\t\t\"T10:00:00Z\",\n\t}\n\n\tfor _, ts := range malformedTimestamps {\n\t\tt.Run(ts, func(t *testing.T) {\n\t\t\tsandbox := createSandbox(\"test-sandbox\", \"default\", ts)\n\n\t\t\tmock := &mockClient{\n\t\t\t\tgetFunc: func(ctx context.Context, key client.ObjectKey, obj client.Object, opts ...client.GetOption) error {\n\t\t\t\t\tsandboxObj := obj.(*v1alpha1.Sandbox)\n\t\t\t\t\tsandboxObj.Name = sandbox.Name\n\t\t\t\t\tsandboxObj.Namespace = sandbox.Namespace\n\t\t\t\t\tsandboxObj.Annotations = sandbox.Annotations\n\t\t\t\t\treturn nil\n\t\t\t\t},\n\t\t\t}\n\n\t\t\tr := &Reconciler{Client: mock}\n\t\t\tresult, err := r.Reconcile(context.Background(), ctrl.Request{\n\t\t\t\tNamespacedName: types.NamespacedName{Name: \"test-sandbox\", Namespace: \"default\"},\n\t\t\t})\n\n\t\t\t// Should return error and requeue after 30s\n\t\t\tif ts == \"\" {\n\t\t\t\t// Empty string is handled separately - no error\n\t\t\t\tif err != nil {\n\t\t\t\t\tt.Errorf(\"Expected no error for empty string, got: %v\", err)\n\t\t\t\t}\n\t\t\t} else {\n\t\t\t\tif err == nil {\n\t\t\t\t\tt.Error(\"Expected error for malformed timestamp\")\n\t\t\t\t}\n\t\t\t\tif result.RequeueAfter != RequeueAfterParseError {\n\t\t\t\t\tt.Errorf(\"Expected RequeueAfter %v, got %v\", RequeueAfterParseError, result.RequeueAfter)\n\t\t\t\t}\n\t\t\t}\n\t\t})\n\t}\n}\n\n// TestReconcile_ContextCancellation tests handling of cancelled context.\nfunc TestReconcile_ContextCancellation(t *testing.T) {\n\tctx, cancel := context.WithCancel(context.Background())\n\tcancel() // Cancel immediately\n\n\tmock := &mockClient{\n\t\tgetFunc: func(ctx context.Context, key client.ObjectKey, obj client.Object, opts ...client.GetOption) error {\n\t\t\treturn ctx.Err()\n\t\t},\n\t}\n\n\tr := &Reconciler{Client: mock}\n\t_, err := r.Reconcile(ctx, ctrl.Request{\n\t\tNamespacedName: types.NamespacedName{Name: \"test-sandbox\", Namespace: \"default\"},\n\t})\n\n\tif err == nil {\n\t\tt.Error(\"Expected error for cancelled context\")\n\t}\n}\n\n// TestReconcile_ValidRFC3339Variants tests various valid RFC3339 formats.\nfunc TestReconcile_ValidRFC3339Variants(t *testing.T) {\n\tvalidTimestamps := []string{\n\t\ttime.Now().UTC().Add(-20 * time.Minute).Format(time.RFC3339),\n\t\ttime.Now().UTC().Add(-20 * time.Minute).Format(time.RFC3339Nano),\n\t}\n\n\tfor _, ts := range validTimestamps {\n\t\tt.Run(ts, func(t *testing.T) {\n\t\t\tsandbox := createSandbox(\"test-sandbox\", \"default\", ts)\n\n\t\t\tdeleteCalled := false\n\t\t\tmock := &mockClient{\n\t\t\t\tgetFunc: func(ctx context.Context, key client.ObjectKey, obj client.Object, opts ...client.GetOption) error {\n\t\t\t\t\tsandboxObj := obj.(*v1alpha1.Sandbox)\n\t\t\t\t\tsandboxObj.Name = sandbox.Name\n\t\t\t\t\tsandboxObj.Namespace = sandbox.Namespace\n\t\t\t\t\tsandboxObj.Annotations = sandbox.Annotations\n\t\t\t\t\treturn nil\n\t\t\t\t},\n\t\t\t\tdeleteFunc: func(ctx context.Context, obj client.Object, opts ...client.DeleteOption) error {\n\t\t\t\t\tdeleteCalled = true\n\t\t\t\t\treturn nil\n\t\t\t\t},\n\t\t\t}\n\n\t\t\tr := &Reconciler{Client: mock}\n\t\t\tresult, err := r.Reconcile(context.Background(), ctrl.Request{\n\t\t\t\tNamespacedName: types.NamespacedName{Name: \"test-sandbox\", Namespace: \"default\"},\n\t\t\t})\n\n\t\t\tif err != nil {\n\t\t\t\tt.Errorf(\"Expected no error, got: %v\", err)\n\t\t\t}\n\t\t\tif result.RequeueAfter != 0 {\n\t\t\t\tt.Errorf(\"Expected no requeue for expired sandbox, got: %v\", result.RequeueAfter)\n\t\t\t}\n\t\t\tif !deleteCalled {\n\t\t\t\tt.Error(\"Expected Delete to be called for expired sandbox\")\n\t\t\t}\n\t\t})\n\t}\n}\n\n// TestReconcile_MultipleNamespaces tests reconciliation across namespaces.\nfunc TestReconcile_MultipleNamespaces(t *testing.T) {\n\tnamespaces := []string{\"default\", \"kube-system\", \"agentcube\", \"test-ns\"}\n\n\tfor _, ns := range namespaces {\n\t\tt.Run(ns, func(t *testing.T) {\n\t\t\tlastActivity := time.Now().UTC().Add(-20 * time.Minute).Format(time.RFC3339)\n\t\t\tsandbox := createSandbox(\"test-sandbox\", ns, lastActivity)\n\n\t\t\tdeleteCalled := false\n\t\t\tmock := &mockClient{\n\t\t\t\tgetFunc: func(ctx context.Context, key client.ObjectKey, obj client.Object, opts ...client.GetOption) error {\n\t\t\t\t\tsandboxObj := obj.(*v1alpha1.Sandbox)\n\t\t\t\t\tsandboxObj.Name = sandbox.Name\n\t\t\t\t\tsandboxObj.Namespace = sandbox.Namespace\n\t\t\t\t\tsandboxObj.Annotations = sandbox.Annotations\n\t\t\t\t\treturn nil\n\t\t\t\t},\n\t\t\t\tdeleteFunc: func(ctx context.Context, obj client.Object, opts ...client.DeleteOption) error {\n\t\t\t\t\tdeleteCalled = true\n\t\t\t\t\treturn nil\n\t\t\t\t},\n\t\t\t}\n\n\t\t\tr := &Reconciler{Client: mock}\n\t\t\tresult, err := r.Reconcile(context.Background(), ctrl.Request{\n\t\t\t\tNamespacedName: types.NamespacedName{Name: \"test-sandbox\", Namespace: ns},\n\t\t\t})\n\n\t\t\tif err != nil {\n\t\t\t\tt.Errorf(\"Expected no error, got: %v\", err)\n\t\t\t}\n\t\t\tif result.RequeueAfter != 0 {\n\t\t\t\tt.Errorf(\"Expected no requeue, got: %v\", result.RequeueAfter)\n\t\t\t}\n\t\t\tif !deleteCalled {\n\t\t\t\tt.Error(\"Expected Delete to be called\")\n\t\t\t}\n\t\t})\n\t}\n}\n\n// TestWorkloadManager_LastActivityAnnotationKey tests the constant value.\nfunc TestWorkloadManager_LastActivityAnnotationKey(t *testing.T) {\n\texpected := \"last-activity-time\"\n\tif workloadmanager.LastActivityAnnotationKey != expected {\n\t\tt.Errorf(\"Expected LastActivityAnnotationKey to be '%s', got '%s'\", expected, workloadmanager.LastActivityAnnotationKey)\n\t}\n}\n\n// TestReconcile_ZeroTime tests edge case with zero timestamp (far in the past).\nfunc TestReconcile_ZeroTime(t *testing.T) {\n\t// Zero time is far in the past, so it should be considered expired\n\tzeroTime := time.Time{}.UTC().Format(time.RFC3339)\n\tsandbox := createSandbox(\"test-sandbox\", \"default\", zeroTime)\n\n\tdeleteCalled := false\n\tmock := &mockClient{\n\t\tgetFunc: func(ctx context.Context, key client.ObjectKey, obj client.Object, opts ...client.GetOption) error {\n\t\t\tsandboxObj := obj.(*v1alpha1.Sandbox)\n\t\t\tsandboxObj.Name = sandbox.Name\n\t\t\tsandboxObj.Namespace = sandbox.Namespace\n\t\t\tsandboxObj.Annotations = sandbox.Annotations\n\t\t\treturn nil\n\t\t},\n\t\tdeleteFunc: func(ctx context.Context, obj client.Object, opts ...client.DeleteOption) error {\n\t\t\tdeleteCalled = true\n\t\t\treturn nil\n\t\t},\n\t}\n\n\tr := &Reconciler{Client: mock}\n\tresult, err := r.Reconcile(context.Background(), ctrl.Request{\n\t\tNamespacedName: types.NamespacedName{Name: \"test-sandbox\", Namespace: \"default\"},\n\t})\n\n\tif err != nil {\n\t\tt.Errorf(\"Expected no error, got: %v\", err)\n\t}\n\tif result.RequeueAfter != 0 {\n\t\tt.Errorf(\"Expected no requeue for expired sandbox, got: %v\", result.RequeueAfter)\n\t}\n\tif !deleteCalled {\n\t\tt.Error(\"Expected Delete to be called for zero time (far in past)\")\n\t}\n}\n\n// TestReconcile_JustBeforeExpiration tests sandbox that expires very soon.\nfunc TestReconcile_JustBeforeExpiration(t *testing.T) {\n\t// Last activity 14 minutes 59 seconds ago - just about to expire\n\tlastActivity := time.Now().UTC().Add(-(14*time.Minute + 59*time.Second)).Format(time.RFC3339)\n\tsandbox := createSandbox(\"test-sandbox\", \"default\", lastActivity)\n\n\tmock := &mockClient{\n\t\tgetFunc: func(ctx context.Context, key client.ObjectKey, obj client.Object, opts ...client.GetOption) error {\n\t\t\tsandboxObj := obj.(*v1alpha1.Sandbox)\n\t\t\tsandboxObj.Name = sandbox.Name\n\t\t\tsandboxObj.Namespace = sandbox.Namespace\n\t\t\tsandboxObj.Annotations = sandbox.Annotations\n\t\t\treturn nil\n\t\t},\n\t}\n\n\tr := &Reconciler{Client: mock}\n\tresult, err := r.Reconcile(context.Background(), ctrl.Request{\n\t\tNamespacedName: types.NamespacedName{Name: \"test-sandbox\", Namespace: \"default\"},\n\t})\n\n\tif err != nil {\n\t\tt.Errorf(\"Expected no error, got: %v\", err)\n\t}\n\t// Should requeue very soon (within 1 minute)\n\tif result.RequeueAfter > 2*time.Minute {\n\t\tt.Errorf(\"Expected RequeueAfter < 2m for near-expiration, got %v\", result.RequeueAfter)\n\t}\n}\n\n// MockStatusWriter implements client.StatusWriter for testing.\ntype MockStatusWriter struct{}\n\nfunc (m *MockStatusWriter) Create(ctx context.Context, obj client.Object, subResource client.Object, opts ...client.SubResourceCreateOption) error {\n\treturn nil\n}\n\nfunc (m *MockStatusWriter) Update(ctx context.Context, obj client.Object, opts ...client.SubResourceUpdateOption) error {\n\treturn nil\n}\n\nfunc (m *MockStatusWriter) Patch(ctx context.Context, obj client.Object, patch client.Patch, opts ...client.SubResourcePatchOption) error {\n\treturn nil\n}\n\n// MockClient is a more complete mock implementation\ntype MockClient struct {\n\tclient.Client\n\tGetFunc    func(ctx context.Context, key client.ObjectKey, obj client.Object, opts ...client.GetOption) error\n\tListFunc   func(ctx context.Context, list client.ObjectList, opts ...client.ListOption) error\n\tCreateFunc func(ctx context.Context, obj client.Object, opts ...client.CreateOption) error\n\tDeleteFunc func(ctx context.Context, obj client.Object, opts ...client.DeleteOption) error\n\tUpdateFunc func(ctx context.Context, obj client.Object, opts ...client.UpdateOption) error\n\tPatchFunc  func(ctx context.Context, obj client.Object, patch client.Patch, opts ...client.PatchOption) error\n\tSchemeFunc func() *runtime.Scheme\n}\n\nfunc (m *MockClient) Get(ctx context.Context, key client.ObjectKey, obj client.Object, opts ...client.GetOption) error {\n\tif m.GetFunc != nil {\n\t\treturn m.GetFunc(ctx, key, obj, opts...)\n\t}\n\treturn nil\n}\n\nfunc (m *MockClient) List(ctx context.Context, list client.ObjectList, opts ...client.ListOption) error {\n\tif m.ListFunc != nil {\n\t\treturn m.ListFunc(ctx, list, opts...)\n\t}\n\treturn nil\n}\n\nfunc (m *MockClient) Create(ctx context.Context, obj client.Object, opts ...client.CreateOption) error {\n\tif m.CreateFunc != nil {\n\t\treturn m.CreateFunc(ctx, obj, opts...)\n\t}\n\treturn nil\n}\n\nfunc (m *MockClient) Delete(ctx context.Context, obj client.Object, opts ...client.DeleteOption) error {\n\tif m.DeleteFunc != nil {\n\t\treturn m.DeleteFunc(ctx, obj, opts...)\n\t}\n\treturn nil\n}\n\nfunc (m *MockClient) Update(ctx context.Context, obj client.Object, opts ...client.UpdateOption) error {\n\tif m.UpdateFunc != nil {\n\t\treturn m.UpdateFunc(ctx, obj, opts...)\n\t}\n\treturn nil\n}\n\nfunc (m *MockClient) Patch(ctx context.Context, obj client.Object, patch client.Patch, opts ...client.PatchOption) error {\n\tif m.PatchFunc != nil {\n\t\treturn m.PatchFunc(ctx, obj, patch, opts...)\n\t}\n\treturn nil\n}\n\nfunc (m *MockClient) DeleteAllOf(ctx context.Context, obj client.Object, opts ...client.DeleteAllOfOption) error {\n\treturn nil\n}\n\nfunc (m *MockClient) Status() client.StatusWriter {\n\treturn &MockStatusWriter{}\n}\n\nfunc (m *MockClient) SubResource(subResource string) client.SubResourceClient {\n\treturn nil\n}\n\nfunc (m *MockClient) Scheme() *runtime.Scheme {\n\tif m.SchemeFunc != nil {\n\t\treturn m.SchemeFunc()\n\t}\n\treturn nil\n}\n\nfunc (m *MockClient) RESTMapper() ctrl.RESTMapper {\n\treturn nil\n}\n\nfunc (m *MockClient) GroupVersionKindFor(obj runtime.Object) (ctrl.GroupVersionKind, error) {\n\treturn ctrl.GroupVersionKind{}, nil\n}\n\nfunc (m *MockClient) IsObjectNamespaced(obj runtime.Object) (bool, error) {\n\treturn true, nil\n}\n\n// BenchmarkReconcile benchmarks the reconcile function.\nfunc BenchmarkReconcile(b *testing.B) {\n\tlastActivity := time.Now().UTC().Add(-20 * time.Minute).Format(time.RFC3339)\n\tsandbox := createSandbox(\"test-sandbox\", \"default\", lastActivity)\n\n\tmock := &MockClient{\n\t\tGetFunc: func(ctx context.Context, key client.ObjectKey, obj client.Object, opts ...client.GetOption) error {\n\t\t\tsandboxObj := obj.(*v1alpha1.Sandbox)\n\t\t\tsandboxObj.Name = sandbox.Name\n\t\t\tsandboxObj.Namespace = sandbox.Namespace\n\t\t\tsandboxObj.Annotations = sandbox.Annotations\n\t\t\treturn nil\n\t\t},\n\t\tDeleteFunc: func(ctx context.Context, obj client.Object, opts ...client.DeleteOption) error {\n\t\t\treturn nil\n\t\t},\n\t}\n\n\tr := &Reconciler{Client: mock}\n\tctx := context.Background()\n\treq := ctrl.Request{\n\t\tNamespacedName: types.NamespacedName{Name: \"test-sandbox\", Namespace: \"default\"},\n\t}\n\n\tb.ResetTimer()\n\tfor i := 0; i < b.N; i++ {\n\t\t_, err := r.Reconcile(ctx, req)\n\t\tif err != nil {\n\t\t\tb.Fatalf(\"Unexpected error: %v\", err)\n\t\t}\n\t}\n}\n\n// TestReconcile_EdgeCase_FarFuture tests timestamp far in the future.\nfunc TestReconcile_EdgeCase_FarFuture(t *testing.T) {\n\t// Far future timestamp (1 year from now) - should not be expired\n\tlastActivity := time.Now().UTC().Add(365 * 24 * time.Hour).Format(time.RFC3339)\n\tsandbox := createSandbox(\"test-sandbox\", \"default\", lastActivity)\n\n\tmock := &mockClient{\n\t\tgetFunc: func(ctx context.Context, key client.ObjectKey, obj client.Object, opts ...client.GetOption) error {\n\t\t\tsandboxObj := obj.(*v1alpha1.Sandbox)\n\t\t\tsandboxObj.Name = sandbox.Name\n\t\t\tsandboxObj.Namespace = sandbox.Namespace\n\t\t\tsandboxObj.Annotations = sandbox.Annotations\n\t\t\treturn nil\n\t\t},\n\t}\n\n\tr := &Reconciler{Client: mock}\n\tresult, err := r.Reconcile(context.Background(), ctrl.Request{\n\t\tNamespacedName: types.NamespacedName{Name: \"test-sandbox\", Namespace: \"default\"},\n\t})\n\n\tif err != nil {\n\t\tt.Errorf(\"Expected no error, got: %v\", err)\n\t}\n\t// Should requeue after a very long time (1 year + 15 minutes)\n\tminExpected := 364 * 24 * time.Hour // At least 364 days\n\tif result.RequeueAfter < minExpected {\n\t\tt.Errorf(\"Expected RequeueAfter > %v for far future, got %v\", minExpected, result.RequeueAfter)\n\t}\n}\n\n// cmpDiff is a helper for comparing using cmp.Diff\nfunc cmpDiff(x, y interface{}) string {\n\treturn cmp.Diff(x, y)\n}\n","additions":0,"deletions":2},"truncated":false},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/agentd/reconciler_test.go","time":{"start":1775881404284,"end":1775881404495}}}}
