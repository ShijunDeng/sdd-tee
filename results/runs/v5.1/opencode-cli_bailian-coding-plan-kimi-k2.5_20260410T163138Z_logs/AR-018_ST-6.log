{"type":"tool_use","timestamp":1775881307133,"sessionID":"ses_2853a130cffe7ZrnsNmL39pUlM","part":{"id":"prt_d7ac639a6001jFUUwHy35DWHWI","messageID":"msg_d7ac61e31001fiBNtP2RFwiKzJ","sessionID":"ses_2853a130cffe7ZrnsNmL39pUlM","type":"tool","tool":"read","callID":"toolu_functions.read:4","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/agentd/reconciler_test.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/agentd/reconciler_test.go</path>\n<type>file</type>\n<content>\n1: /*\n2: Copyright 2026 The Volcano Authors.\n3: \n4: Licensed under the Apache License, Version 2.0 (the \"License\");\n5: you may not use this file except in compliance with the License.\n6: You may obtain a copy of the License at\n7: \n8:     http://www.apache.org/licenses/LICENSE-2.0\n9: \n10: Unless required by applicable law or agreed to in writing, software\n11: distributed under the License is distributed on an \"AS IS\" BASIS,\n12: WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n13: See the License for the specific language governing permissions and\n14: limitations under the License.\n15: */\n16: \n17: package agentd\n18: \n19: import (\n20: \t\"context\"\n21: \t\"errors\"\n22: \t\"testing\"\n23: \t\"time\"\n24: \n25: \t\"github.com/google/go-cmp/cmp\"\n26: \tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n27: \t\"k8s.io/apimachinery/pkg/runtime\"\n28: \t\"k8s.io/apimachinery/pkg/types\"\n29: \tctrl \"sigs.k8s.io/controller-runtime\"\n30: \t\"sigs.k8s.io/controller-runtime/pkg/client\"\n31: \n32: \t\"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1\"\n33: \t\"github.com/volcano-sh/agentcube/pkg/workloadmanager\"\n34: )\n35: \n36: // mockClient is a mock implementation of client.Client for testing.\n37: type mockClient struct {\n38: \tclient.Client\n39: \tgetFunc    func(ctx context.Context, key client.ObjectKey, obj client.Object, opts ...client.GetOption) error\n40: \tdeleteFunc func(ctx context.Context, obj client.Object, opts ...client.DeleteOption) error\n41: }\n42: \n43: func (m *mockClient) Get(ctx context.Context, key client.ObjectKey, obj client.Object, opts ...client.GetOption) error {\n44: \tif m.getFunc != nil {\n45: \t\treturn m.getFunc(ctx, key, obj, opts...)\n46: \t}\n47: \treturn nil\n48: }\n49: \n50: func (m *mockClient) Delete(ctx context.Context, obj client.Object, opts ...client.DeleteOption) error {\n51: \tif m.deleteFunc != nil {\n52: \t\treturn m.deleteFunc(ctx, obj, opts...)\n53: \t}\n54: \treturn nil\n55: }\n56: \n57: // notFoundError implements the IsNotFound check\n58: type notFoundError struct{}\n59: \n60: func (e notFoundError) Error() string { return \"not found\" }\n61: func (e notFoundError) Status() metav1.Status {\n62: \treturn metav1.Status{Code: 404, Reason: \"NotFound\"}\n63: }\n64: \n65: // testError implements a generic error\n66: type testError struct{}\n67: \n68: func (e testError) Error() string { return \"test error\" }\n69: \n70: // createSandbox creates a test Sandbox with the given annotation.\n71: func createSandbox(name, namespace, lastActivity string) *v1alpha1.Sandbox {\n72: \tsandbox := &v1alpha1.Sandbox{\n73: \t\tObjectMeta: metav1.ObjectMeta{\n74: \t\t\tName:        name,\n75: \t\t\tNamespace:   namespace,\n76: \t\t\tAnnotations: make(map[string]string),\n77: \t\t},\n78: \t}\n79: \tif lastActivity != \"\" {\n80: \t\tsandbox.Annotations[workloadmanager.LastActivityAnnotationKey] = lastActivity\n81: \t}\n82: \treturn sandbox\n83: }\n84: \n85: // TestReconcile_SandboxNotFound tests that NotFound errors on Get are handled gracefully.\n86: func TestReconcile_SandboxNotFound(t *testing.T) {\n87: \tmock := &mockClient{\n88: \t\tgetFunc: func(ctx context.Context, key client.ObjectKey, obj client.Object, opts ...client.GetOption) error {\n89: \t\t\treturn notFoundError{}\n90: \t\t},\n91: \t}\n92: \n93: \tr := &Reconciler{Client: mock}\n94: \tresult, err := r.Reconcile(context.Background(), ctrl.Request{\n95: \t\tNamespacedName: types.NamespacedName{Name: \"test-sandbox\", Namespace: \"default\"},\n96: \t})\n97: \n98: \tif err != nil {\n99: \t\tt.Errorf(\"Expected no error, got: %v\", err)\n100: \t}\n101: \tif result.Requeue || result.RequeueAfter != 0 {\n102: \t\tt.Errorf(\"Expected empty result, got: %+v\", result)\n103: \t}\n104: }\n105: \n106: // TestReconcile_GetError tests that other Get errors are returned.\n107: func TestReconcile_GetError(t *testing.T) {\n108: \tmock := &mockClient{\n109: \t\tgetFunc: func(ctx context.Context, key client.ObjectKey, obj client.Object, opts ...client.GetOption) error {\n110: \t\t\treturn testError{}\n111: \t\t},\n112: \t}\n113: \n114: \tr := &Reconciler{Client: mock}\n115: \tresult, err := r.Reconcile(context.Background(), ctrl.Request{\n116: \t\tNamespacedName: types.NamespacedName{Name: \"test-sandbox\", Namespace: \"default\"},\n117: \t})\n118: \n119: \tif err == nil {\n120: \t\tt.Error(\"Expected error, got nil\")\n121: \t}\n122: \tif result.RequeueAfter != 0 {\n123: \t\tt.Errorf(\"Expected no requeue, got: %v\", result.RequeueAfter)\n124: \t}\n125: }\n126: \n127: // TestReconcile_NoAnnotation tests that missing annotation returns empty result.\n128: func TestReconcile_NoAnnotation(t *testing.T) {\n129: \tsandbox := createSandbox(\"test-sandbox\", \"default\", \"\")\n130: \t// No annotation set\n131: \n132: \tmock := &mockClient{\n133: \t\tgetFunc: func(ctx context.Context, key client.ObjectKey, obj client.Object, opts ...client.GetOption) error {\n134: \t\t\tsandboxObj := obj.(*v1alpha1.Sandbox)\n135: \t\t\tsandboxObj.Name = sandbox.Name\n136: \t\t\tsandboxObj.Namespace = sandbox.Namespace\n137: \t\t\tsandboxObj.Annotations = sandbox.Annotations\n138: \t\t\treturn nil\n139: \t\t},\n140: \t}\n141: \n142: \tr := &Reconciler{Client: mock}\n143: \tresult, err := r.Reconcile(context.Background(), ctrl.Request{\n144: \t\tNamespacedName: types.NamespacedName{Name: \"test-sandbox\", Namespace: \"default\"},\n145: \t})\n146: \n147: \tif err != nil {\n148: \t\tt.Errorf(\"Expected no error, got: %v\", err)\n149: \t}\n150: \tif result.Requeue || result.RequeueAfter != 0 {\n151: \t\tt.Errorf(\"Expected empty result, got: %+v\", result)\n152: \t}\n153: }\n154: \n155: // TestReconcile_EmptyAnnotation tests that empty annotation value returns empty result.\n156: func TestReconcile_EmptyAnnotation(t *testing.T) {\n157: \tsandbox := createSandbox(\"test-sandbox\", \"default\", \"\")\n158: \tsandbox.Annotations[workloadmanager.LastActivityAnnotationKey] = \"\"\n159: \n160: \tmock := &mockClient{\n161: \t\tgetFunc: func(ctx context.Context, key client.ObjectKey, obj client.Object, opts ...client.GetOption) error {\n162: \t\t\tsandboxObj := obj.(*v1alpha1.Sandbox)\n163: \t\t\tsandboxObj.Name = sandbox.Name\n164: \t\t\tsandboxObj.Namespace = sandbox.Namespace\n165: \t\t\tsandboxObj.Annotations = sandbox.Annotations\n166: \t\t\treturn nil\n167: \t\t},\n168: \t}\n169: \n170: \tr := &Reconciler{Client: mock}\n171: \tresult, err := r.Reconcile(context.Background(), ctrl.Request{\n172: \t\tNamespacedName: types.NamespacedName{Name: \"test-sandbox\", Namespace: \"default\"},\n173: \t})\n174: \n175: \tif err != nil {\n176: \t\tt.Errorf(\"Expected no error, got: %v\", err)\n177: \t}\n178: \tif result.Requeue || result.RequeueAfter != 0 {\n179: \t\tt.Errorf(\"Expected empty result, got: %+v\", result)\n180: \t}\n181: }\n182: \n183: // TestReconcile_InvalidTimestamp tests that invalid timestamp requeues with 30s.\n184: func TestReconcile_InvalidTimestamp(t *testing.T) {\n185: \tsandbox := createSandbox(\"test-sandbox\", \"default\", \"invalid-timestamp\")\n186: \n187: \tmock := &mockClient{\n188: \t\tgetFunc: func(ctx context.Context, key client.ObjectKey, obj client.Object, opts ...client.GetOption) error {\n189: \t\t\tsandboxObj := obj.(*v1alpha1.Sandbox)\n190: \t\t\tsandboxObj.Name = sandbox.Name\n191: \t\t\tsandboxObj.Namespace = sandbox.Namespace\n192: \t\t\tsandboxObj.Annotations = sandbox.Annotations\n193: \t\t\treturn nil\n194: \t\t},\n195: \t}\n196: \n197: \tr := &Reconciler{Client: mock}\n198: \tresult, err := r.Reconcile(context.Background(), ctrl.Request{\n199: \t\tNamespacedName: types.NamespacedName{Name: \"test-sandbox\", Namespace: \"default\"},\n200: \t})\n201: \n202: \tif err == nil {\n203: \t\tt.Error(\"Expected error for invalid timestamp\")\n204: \t}\n205: \texpectedRequeue := RequeueAfterParseError\n206: \tif result.RequeueAfter != expectedRequeue {\n207: \t\tt.Errorf(\"Expected RequeueAfter %v, got %v\", expectedRequeue, result.RequeueAfter)\n208: \t}\n209: }\n210: \n211: // TestReconcile_NotExpired tests that non-expired sandbox requeues at expiration time.\n212: func TestReconcile_NotExpired(t *testing.T) {\n213: \t// Last activity 5 minutes ago\n214: \tlastActivity := time.Now().UTC().Add(-5 * time.Minute).Format(time.RFC3339)\n215: \tsandbox := createSandbox(\"test-sandbox\", \"default\", lastActivity)\n216: \n217: \tmock := &mockClient{\n218: \t\tgetFunc: func(ctx context.Context, key client.ObjectKey, obj client.Object, opts ...client.GetOption) error {\n219: \t\t\tsandboxObj := obj.(*v1alpha1.Sandbox)\n220: \t\t\tsandboxObj.Name = sandbox.Name\n221: \t\t\tsandboxObj.Namespace = sandbox.Namespace\n222: \t\t\tsandboxObj.Annotations = sandbox.Annotations\n223: \t\t\treturn nil\n224: \t\t},\n225: \t}\n226: \n227: \tr := &Reconciler{Client: mock}\n228: \tresult, err := r.Reconcile(context.Background(), ctrl.Request{\n229: \t\tNamespacedName: types.NamespacedName{Name: \"test-sandbox\", Namespace: \"default\"},\n230: \t})\n231: \n232: \tif err != nil {\n233: \t\tt.Errorf(\"Expected no error, got: %v\", err)\n234: \t}\n235: \n236: \t// Should requeue after approximately 10 minutes (15 min timeout - 5 min elapsed)\n237: \texpectedMin := 9 * time.Minute\n238: \texpectedMax := 11 * time.Minute\n239: \tif result.RequeueAfter < expectedMin || result.RequeueAfter > expectedMax {\n240: \t\tt.Errorf(\"Expected RequeueAfter between %v and %v, got %v\", expectedMin, expectedMax, result.RequeueAfter)\n241: \t}\n242: }\n243: \n244: // TestReconcile_JustExpired tests that sandbox exactly at expiration is deleted.\n245: func TestReconcile_JustExpired(t *testing.T) {\n246: \t// Last activity exactly 15 minutes ago\n247: \tlastActivity := time.Now().UTC().Add(-15 * time.Minute).Format(time.RFC3339)\n248: \tsandbox := createSandbox(\"test-sandbox\", \"default\", lastActivity)\n249: \n250: \tdeleteCalled := false\n251: \tmock := &mockClient{\n252: \t\tgetFunc: func(ctx context.Context, key client.ObjectKey, obj client.Object, opts ...client.GetOption) error {\n253: \t\t\tsandboxObj := obj.(*v1alpha1.Sandbox)\n254: \t\t\tsandboxObj.Name = sandbox.Name\n255: \t\t\tsandboxObj.Namespace = sandbox.Namespace\n256: \t\t\tsandboxObj.Annotations = sandbox.Annotations\n257: \t\t\treturn nil\n258: \t\t},\n259: \t\tdeleteFunc: func(ctx context.Context, obj client.Object, opts ...client.DeleteOption) error {\n260: \t\t\tdeleteCalled = true\n261: \t\t\treturn nil\n262: \t\t},\n263: \t}\n264: \n265: \tr := &Reconciler{Client: mock}\n266: \tresult, err := r.Reconcile(context.Background(), ctrl.Request{\n267: \t\tNamespacedName: types.NamespacedName{Name: \"test-sandbox\", Namespace: \"default\"},\n268: \t})\n269: \n270: \tif err != nil {\n271: \t\tt.Errorf(\"Expected no error, got: %v\", err)\n272: \t}\n273: \tif result.RequeueAfter != 0 {\n274: \t\tt.Errorf(\"Expected no requeue, got: %v\", result.RequeueAfter)\n275: \t}\n276: \tif !deleteCalled {\n277: \t\tt.Error(\"Expected Delete to be called\")\n278: \t}\n279: }\n280: \n281: // TestReconcile_Expired tests that expired sandbox is deleted.\n282: func TestReconcile_Expired(t *testing.T) {\n283: \t// Last activity 20 minutes ago\n284: \tlastActivity := time.Now().UTC().Add(-20 * time.Minute).Format(time.RFC3339)\n285: \tsandbox := createSandbox(\"test-sandbox\", \"default\", lastActivity)\n286: \n287: \tdeleteCalled := false\n288: \tmock := &mockClient{\n289: \t\tgetFunc: func(ctx context.Context, key client.ObjectKey, obj client.Object, opts ...client.GetOption) error {\n290: \t\t\tsandboxObj := obj.(*v1alpha1.Sandbox)\n291: \t\t\tsandboxObj.Name = sandbox.Name\n292: \t\t\tsandboxObj.Namespace = sandbox.Namespace\n293: \t\t\tsandboxObj.Annotations = sandbox.Annotations\n294: \t\t\treturn nil\n295: \t\t},\n296: \t\tdeleteFunc: func(ctx context.Context, obj client.Object, opts ...client.DeleteOption) error {\n297: \t\t\tdeleteCalled = true\n298: \t\t\treturn nil\n299: \t\t},\n300: \t}\n301: \n302: \tr := &Reconciler{Client: mock}\n303: \tresult, err := r.Reconcile(context.Background(), ctrl.Request{\n304: \t\tNamespacedName: types.NamespacedName{Name: \"test-sandbox\", Namespace: \"default\"},\n305: \t})\n306: \n307: \tif err != nil {\n308: \t\tt.Errorf(\"Expected no error, got: %v\", err)\n309: \t}\n310: \tif result.RequeueAfter != 0 {\n311: \t\tt.Errorf(\"Expected no requeue, got: %v\", result.RequeueAfter)\n312: \t}\n313: \tif !deleteCalled {\n314: \t\tt.Error(\"Expected Delete to be called\")\n315: \t}\n316: }\n317: \n318: // TestReconcile_DeleteNotFound tests that NotFound on delete is handled gracefully.\n319: func TestReconcile_DeleteNotFound(t *testing.T) {\n320: \t// Last activity 20 minutes ago\n321: \tlastActivity := time.Now().UTC().Add(-20 * time.Minute).Format(time.RFC3339)\n322: \tsandbox := createSandbox(\"test-sandbox\", \"default\", lastActivity)\n323: \n324: \tmock := &mockClient{\n325: \t\tgetFunc: func(ctx context.Context, key client.ObjectKey, obj client.Object, opts ...client.GetOption) error {\n326: \t\t\tsandboxObj := obj.(*v1alpha1.Sandbox)\n327: \t\t\tsandboxObj.Name = sandbox.Name\n328: \t\t\tsandboxObj.Namespace = sandbox.Namespace\n329: \t\t\tsandboxObj.Annotations = sandbox.Annotations\n330: \t\t\treturn nil\n331: \t\t},\n332: \t\tdeleteFunc: func(ctx context.Context, obj client.Object, opts ...client.DeleteOption) error {\n333: \t\t\treturn notFoundError{}\n334: \t\t},\n335: \t}\n336: \n337: \tr := &Reconciler{Client: mock}\n338: \tresult, err := r.Reconcile(context.Background(), ctrl.Request{\n339: \t\tNamespacedName: types.NamespacedName{Name: \"test-sandbox\", Namespace: \"default\"},\n340: \t})\n341: \n342: \tif err != nil {\n343: \t\tt.Errorf(\"Expected no error for NotFound, got: %v\", err)\n344: \t}\n345: \tif result.RequeueAfter != 0 {\n346: \t\tt.Errorf(\"Expected no requeue, got: %v\", result.RequeueAfter)\n347: \t}\n348: }\n349: \n350: // TestReconcile_DeleteError tests that other delete errors are returned.\n351: func TestReconcile_DeleteError(t *testing.T) {\n352: \t// Last activity 20 minutes ago\n353: \tlastActivity := time.Now().UTC().Add(-20 * time.Minute).Format(time.RFC3339)\n354: \tsandbox := createSandbox(\"test-sandbox\", \"default\", lastActivity)\n355: \n356: \tmock := &mockClient{\n357: \t\tgetFunc: func(ctx context.Context, key client.ObjectKey, obj client.Object, opts ...client.GetOption) error {\n358: \t\t\tsandboxObj := obj.(*v1alpha1.Sandbox)\n359: \t\t\tsandboxObj.Name = sandbox.Name\n360: \t\t\tsandboxObj.Namespace = sandbox.Namespace\n361: \t\t\tsandboxObj.Annotations = sandbox.Annotations\n362: \t\t\treturn nil\n363: \t\t},\n364: \t\tdeleteFunc: func(ctx context.Context, obj client.Object, opts ...client.DeleteOption) error {\n365: \t\t\treturn testError{}\n366: \t\t},\n367: \t}\n368: \n369: \tr := &Reconciler{Client: mock}\n370: \tresult, err := r.Reconcile(context.Background(), ctrl.Request{\n371: \t\tNamespacedName: types.NamespacedName{Name: \"test-sandbox\", Namespace: \"default\"},\n372: \t})\n373: \n374: \tif err == nil {\n375: \t\tt.Error(\"Expected error for delete failure\")\n376: \t}\n377: \tif result.RequeueAfter != 0 {\n378: \t\tt.Errorf(\"Expected no requeue, got: %v\", result.RequeueAfter)\n379: \t}\n380: }\n381: \n382: // TestReconcile_FutureExpirationRequeue tests that RequeueAfter is calculated correctly.\n383: func TestReconcile_FutureExpirationRequeue(t *testing.T) {\n384: \t// Test multiple scenarios\n385: \ttests := []struct {\n386: \t\tname        string\n387: \t\tminutesAgo  time.Duration\n388: \t\texpectedMin time.Duration\n389: \t\texpectedMax time.Duration\n390: \t}{\n391: \t\t{\n392: \t\t\tname:        \"Just created (0 min ago)\",\n393: \t\t\tminutesAgo:  0,\n394: \t\t\texpectedMin: 14 * time.Minute,\n395: \t\t\texpectedMax: 16 * time.Minute,\n396: \t\t},\n397: \t\t{\n398: \t\t\tname:        \"1 minute ago\",\n399: \t\t\tminutesAgo:  1 * time.Minute,\n400: \t\t\texpectedMin: 13 * time.Minute,\n401: \t\t\texpectedMax: 15 * time.Minute,\n402: \t\t},\n403: \t\t{\n404: \t\t\tname:        \"10 minutes ago\",\n405: \t\t\tminutesAgo:  10 * time.Minute,\n406: \t\t\texpectedMin: 4 * time.Minute,\n407: \t\t\texpectedMax: 6 * time.Minute,\n408: \t\t},\n409: \t\t{\n410: \t\t\tname:        \"14 minutes ago\",\n411: \t\t\tminutesAgo:  14 * time.Minute,\n412: \t\t\texpectedMin: 0 * time.Second,\n413: \t\t\texpectedMax: 2 * time.Minute,\n414: \t\t},\n415: \t}\n416: \n417: \tfor _, tt := range tests {\n418: \t\tt.Run(tt.name, func(t *testing.T) {\n419: \t\t\tlastActivity := time.Now().UTC().Add(-tt.minutesAgo).Format(time.RFC3339)\n420: \t\t\tsandbox := createSandbox(\"test-sandbox\", \"default\", lastActivity)\n421: \n422: \t\t\tmock := &mockClient{\n423: \t\t\t\tgetFunc: func(ctx context.Context, key client.ObjectKey, obj client.Object, opts ...client.GetOption) error {\n424: \t\t\t\t\tsandboxObj := obj.(*v1alpha1.Sandbox)\n425: \t\t\t\t\tsandboxObj.Name = sandbox.Name\n426: \t\t\t\t\tsandboxObj.Namespace = sandbox.Namespace\n427: \t\t\t\t\tsandboxObj.Annotations = sandbox.Annotations\n428: \t\t\t\t\treturn nil\n429: \t\t\t\t},\n430: \t\t\t}\n431: \n432: \t\t\tr := &Reconciler{Client: mock}\n433: \t\t\tresult, err := r.Reconcile(context.Background(), ctrl.Request{\n434: \t\t\t\tNamespacedName: types.NamespacedName{Name: \"test-sandbox\", Namespace: \"default\"},\n435: \t\t\t})\n436: \n437: \t\t\tif err != nil {\n438: \t\t\t\tt.Errorf(\"Expected no error, got: %v\", err)\n439: \t\t\t}\n440: \t\t\tif result.RequeueAfter < tt.expectedMin || result.RequeueAfter > tt.expectedMax {\n441: \t\t\t\tt.Errorf(\"Expected RequeueAfter between %v and %v, got %v\", tt.expectedMin, tt.expectedMax, result.RequeueAfter)\n442: \t\t\t}\n443: \t\t})\n444: \t}\n445: }\n446: \n447: // TestReconciler_Struct tests the Reconciler struct fields.\n448: func TestReconciler_Struct(t *testing.T) {\n449: \tscheme := runtime.NewScheme()\n450: \tr := &Reconciler{\n451: \t\tClient: nil,\n452: \t\tScheme: scheme,\n453: \t}\n454: \n455: \tif r.Client != nil {\n456: \t\tt.Error(\"Expected Client to be nil\")\n457: \t}\n458: \tif r.Scheme != scheme {\n459: \t\tt.Error(\"Expected Scheme to match\")\n460: \t}\n461: }\n462: \n463: // TestConstants tests that constants are properly defined.\n464: func TestConstants(t *testing.T) {\n465: \tif SessionExpirationTimeout != 15*time.Minute {\n466: \t\tt.Errorf(\"SessionExpirationTimeout expected 15m, got %v\", SessionExpirationTimeout)\n467: \t}\n468: \tif RequeueAfterParseError != 30*time.Second {\n469: \t\tt.Errorf(\"RequeueAfterParseError expected 30s, got %v\", RequeueAfterParseError)\n470: \t}\n471: }\n472: \n473: // TestCreateSandbox tests the test helper function.\n474: func TestCreateSandbox(t *testing.T) {\n475: \tsandbox := createSandbox(\"test\", \"default\", \"2024-01-01T00:00:00Z\")\n476: \n477: \tif sandbox.Name != \"test\" {\n478: \t\tt.Errorf(\"Expected name 'test', got '%s'\", sandbox.Name)\n479: \t}\n480: \tif sandbox.Namespace != \"default\" {\n481: \t\tt.Errorf(\"Expected namespace 'default', got '%s'\", sandbox.Namespace)\n482: \t}\n483: \tif sandbox.Annotations[workloadmanager.LastActivityAnnotationKey] != \"2024-01-01T00:00:00Z\" {\n484: \t\tt.Errorf(\"Expected annotation value, got '%s'\", sandbox.Annotations[workloadmanager.LastActivityAnnotationKey])\n485: \t}\n486: }\n487: \n488: // TestCreateSandbox_NoAnnotation tests creating sandbox without annotation.\n489: func TestCreateSandbox_NoAnnotation(t *testing.T) {\n490: \tsandbox := createSandbox(\"test\", \"default\", \"\")\n491: \n492: \tif _, exists := sandbox.Annotations[workloadmanager.LastActivityAnnotationKey]; exists {\n493: \t\tt.Error(\"Expected no annotation when empty value\")\n494: \t}\n495: }\n496: \n497: // TestMockClient implements a more realistic mock client test.\n498: func TestMockClient(t *testing.T) {\n499: \tctx := context.Background()\n500: \n501: \tt.Run(\"Get returns error\", func(t *testing.T) {\n502: \t\texpectedErr := errors.New(\"get error\")\n503: \t\tmock := &mockClient{\n504: \t\t\tgetFunc: func(ctx context.Context, key client.ObjectKey, obj client.Object, opts ...client.GetOption) error {\n505: \t\t\t\treturn expectedErr\n506: \t\t\t},\n507: \t\t}\n508: \n509: \t\tsandbox := &v1alpha1.Sandbox{}\n510: \t\terr := mock.Get(ctx, client.ObjectKey{Name: \"test\"}, sandbox)\n511: \t\tif !errors.Is(err, expectedErr) && err.Error() != expectedErr.Error() {\n512: \t\t\tt.Errorf(\"Expected error '%v', got '%v'\", expectedErr, err)\n513: \t\t}\n514: \t})\n515: \n516: \tt.Run(\"Delete returns error\", func(t *testing.T) {\n517: \t\texpectedErr := errors.New(\"delete error\")\n518: \t\tmock := &mockClient{\n519: \t\t\tdeleteFunc: func(ctx context.Context, obj client.Object, opts ...client.DeleteOption) error {\n520: \t\t\t\treturn expectedErr\n521: \t\t\t},\n522: \t\t}\n523: \n524: \t\tsandbox := &v1alpha1.Sandbox{}\n525: \t\terr := mock.Delete(ctx, sandbox)\n526: \t\tif !errors.Is(err, expectedErr) && err.Error() != expectedErr.Error() {\n527: \t\t\tt.Errorf(\"Expected error '%v', got '%v'\", expectedErr, err)\n528: \t\t}\n529: \t})\n530: }\n531: \n532: // TestReconcile_MalformedTimestamp tests various malformed timestamps.\n533: func TestReconcile_MalformedTimestamp(t *testing.T) {\n534: \tmalformedTimestamps := []string{\n535: \t\t\"2024-13-45T99:99:99Z\", // Invalid date/time\n536: \t\t\"not-a-timestamp\",\n537: \t\t\"\",\n538: \t\t\"2024\",\n539: \t\t\"01-15-2024\",\n540: \t\t\"T10:00:00Z\",\n541: \t}\n542: \n543: \tfor _, ts := range malformedTimestamps {\n544: \t\tt.Run(ts, func(t *testing.T) {\n545: \t\t\tsandbox := createSandbox(\"test-sandbox\", \"default\", ts)\n546: \n547: \t\t\tmock := &mockClient{\n548: \t\t\t\tgetFunc: func(ctx context.Context, key client.ObjectKey, obj client.Object, opts ...client.GetOption) error {\n549: \t\t\t\t\tsandboxObj := obj.(*v1alpha1.Sandbox)\n550: \t\t\t\t\tsandboxObj.Name = sandbox.Name\n551: \t\t\t\t\tsandboxObj.Namespace = sandbox.Namespace\n552: \t\t\t\t\tsandboxObj.Annotations = sandbox.Annotations\n553: \t\t\t\t\treturn nil\n554: \t\t\t\t},\n555: \t\t\t}\n556: \n557: \t\t\tr := &Reconciler{Client: mock}\n558: \t\t\tresult, err := r.Reconcile(context.Background(), ctrl.Request{\n559: \t\t\t\tNamespacedName: types.NamespacedName{Name: \"test-sandbox\", Namespace: \"default\"},\n560: \t\t\t})\n561: \n562: \t\t\t// Should return error and requeue after 30s\n563: \t\t\tif ts == \"\" {\n564: \t\t\t\t// Empty string is handled separately - no error\n565: \t\t\t\tif err != nil {\n566: \t\t\t\t\tt.Errorf(\"Expected no error for empty string, got: %v\", err)\n567: \t\t\t\t}\n568: \t\t\t} else {\n569: \t\t\t\tif err == nil {\n570: \t\t\t\t\tt.Error(\"Expected error for malformed timestamp\")\n571: \t\t\t\t}\n572: \t\t\t\tif result.RequeueAfter != RequeueAfterParseError {\n573: \t\t\t\t\tt.Errorf(\"Expected RequeueAfter %v, got %v\", RequeueAfterParseError, result.RequeueAfter)\n574: \t\t\t\t}\n575: \t\t\t}\n576: \t\t})\n577: \t}\n578: }\n579: \n580: // TestReconcile_ContextCancellation tests handling of cancelled context.\n581: func TestReconcile_ContextCancellation(t *testing.T) {\n582: \tctx, cancel := context.WithCancel(context.Background())\n583: \tcancel() // Cancel immediately\n584: \n585: \tsandbox := createSandbox(\"test-sandbox\", \"default\", time.Now().UTC().Format(time.RFC3339))\n586: \n587: \tmock := &mockClient{\n588: \t\tgetFunc: func(ctx context.Context, key client.ObjectKey, obj client.Object, opts ...client.GetOption) error {\n589: \t\t\treturn ctx.Err()\n590: \t\t},\n591: \t}\n592: \n593: \tr := &Reconciler{Client: mock}\n594: \t_, err := r.Reconcile(ctx, ctrl.Request{\n595: \t\tNamespacedName: types.NamespacedName{Name: \"test-sandbox\", Namespace: \"default\"},\n596: \t})\n597: \n598: \tif err == nil {\n599: \t\tt.Error(\"Expected error for cancelled context\")\n600: \t}\n601: }\n602: \n603: // TestReconcile_ValidRFC3339Variants tests various valid RFC3339 formats.\n604: func TestReconcile_ValidRFC3339Variants(t *testing.T) {\n605: \tvalidTimestamps := []string{\n606: \t\ttime.Now().UTC().Add(-20 * time.Minute).Format(time.RFC3339),\n607: \t\ttime.Now().UTC().Add(-20 * time.Minute).Format(time.RFC3339Nano),\n608: \t}\n609: \n610: \tfor _, ts := range validTimestamps {\n611: \t\tt.Run(ts, func(t *testing.T) {\n612: \t\t\tsandbox := createSandbox(\"test-sandbox\", \"default\", ts)\n613: \n614: \t\t\tdeleteCalled := false\n615: \t\t\tmock := &mockClient{\n616: \t\t\t\tgetFunc: func(ctx context.Context, key client.ObjectKey, obj client.Object, opts ...client.GetOption) error {\n617: \t\t\t\t\tsandboxObj := obj.(*v1alpha1.Sandbox)\n618: \t\t\t\t\tsandboxObj.Name = sandbox.Name\n619: \t\t\t\t\tsandboxObj.Namespace = sandbox.Namespace\n620: \t\t\t\t\tsandboxObj.Annotations = sandbox.Annotations\n621: \t\t\t\t\treturn nil\n622: \t\t\t\t},\n623: \t\t\t\tdeleteFunc: func(ctx context.Context, obj client.Object, opts ...client.DeleteOption) error {\n624: \t\t\t\t\tdeleteCalled = true\n625: \t\t\t\t\treturn nil\n626: \t\t\t\t},\n627: \t\t\t}\n628: \n629: \t\t\tr := &Reconciler{Client: mock}\n630: \t\t\tresult, err := r.Reconcile(context.Background(), ctrl.Request{\n631: \t\t\t\tNamespacedName: types.NamespacedName{Name: \"test-sandbox\", Namespace: \"default\"},\n632: \t\t\t})\n633: \n634: \t\t\tif err != nil {\n635: \t\t\t\tt.Errorf(\"Expected no error, got: %v\", err)\n636: \t\t\t}\n637: \t\t\tif result.RequeueAfter != 0 {\n638: \t\t\t\tt.Errorf(\"Expected no requeue for expired sandbox, got: %v\", result.RequeueAfter)\n639: \t\t\t}\n640: \t\t\tif !deleteCalled {\n641: \t\t\t\tt.Error(\"Expected Delete to be called for expired sandbox\")\n642: \t\t\t}\n643: \t\t})\n644: \t}\n645: }\n646: \n647: // TestReconcile_MultipleNamespaces tests reconciliation across namespaces.\n648: func TestReconcile_MultipleNamespaces(t *testing.T) {\n649: \tnamespaces := []string{\"default\", \"kube-system\", \"agentcube\", \"test-ns\"}\n650: \n651: \tfor _, ns := range namespaces {\n652: \t\tt.Run(ns, func(t *testing.T) {\n653: \t\t\tlastActivity := time.Now().UTC().Add(-20 * time.Minute).Format(time.RFC3339)\n654: \t\t\tsandbox := createSandbox(\"test-sandbox\", ns, lastActivity)\n655: \n656: \t\t\tdeleteCalled := false\n657: \t\t\tmock := &mockClient{\n658: \t\t\t\tgetFunc: func(ctx context.Context, key client.ObjectKey, obj client.Object, opts ...client.GetOption) error {\n659: \t\t\t\t\tsandboxObj := obj.(*v1alpha1.Sandbox)\n660: \t\t\t\t\tsandboxObj.Name = sandbox.Name\n661: \t\t\t\t\tsandboxObj.Namespace = sandbox.Namespace\n662: \t\t\t\t\tsandboxObj.Annotations = sandbox.Annotations\n663: \t\t\t\t\treturn nil\n664: \t\t\t\t},\n665: \t\t\t\tdeleteFunc: func(ctx context.Context, obj client.Object, opts ...client.DeleteOption) error {\n666: \t\t\t\t\tdeleteCalled = true\n667: \t\t\t\t\treturn nil\n668: \t\t\t\t},\n669: \t\t\t}\n670: \n671: \t\t\tr := &Reconciler{Client: mock}\n672: \t\t\tresult, err := r.Reconcile(context.Background(), ctrl.Request{\n673: \t\t\t\tNamespacedName: types.NamespacedName{Name: \"test-sandbox\", Namespace: ns},\n674: \t\t\t})\n675: \n676: \t\t\tif err != nil {\n677: \t\t\t\tt.Errorf(\"Expected no error, got: %v\", err)\n678: \t\t\t}\n679: \t\t\tif result.RequeueAfter != 0 {\n680: \t\t\t\tt.Errorf(\"Expected no requeue, got: %v\", result.RequeueAfter)\n681: \t\t\t}\n682: \t\t\tif !deleteCalled {\n683: \t\t\t\tt.Error(\"Expected Delete to be called\")\n684: \t\t\t}\n685: \t\t})\n686: \t}\n687: }\n688: \n689: // TestWorkloadManager_LastActivityAnnotationKey tests the constant value.\n690: func TestWorkloadManager_LastActivityAnnotationKey(t *testing.T) {\n691: \texpected := \"last-activity-time\"\n692: \tif workloadmanager.LastActivityAnnotationKey != expected {\n693: \t\tt.Errorf(\"Expected LastActivityAnnotationKey to be '%s', got '%s'\", expected, workloadmanager.LastActivityAnnotationKey)\n694: \t}\n695: }\n696: \n697: // TestReconcile_ZeroTime tests edge case with zero timestamp (far in the past).\n698: func TestReconcile_ZeroTime(t *testing.T) {\n699: \t// Zero time is far in the past, so it should be considered expired\n700: \tzeroTime := time.Time{}.UTC().Format(time.RFC3339)\n701: \tsandbox := createSandbox(\"test-sandbox\", \"default\", zeroTime)\n702: \n703: \tdeleteCalled := false\n704: \tmock := &mockClient{\n705: \t\tgetFunc: func(ctx context.Context, key client.ObjectKey, obj client.Object, opts ...client.GetOption) error {\n706: \t\t\tsandboxObj := obj.(*v1alpha1.Sandbox)\n707: \t\t\tsandboxObj.Name = sandbox.Name\n708: \t\t\tsandboxObj.Namespace = sandbox.Namespace\n709: \t\t\tsandboxObj.Annotations = sandbox.Annotations\n710: \t\t\treturn nil\n711: \t\t},\n712: \t\tdeleteFunc: func(ctx context.Context, obj client.Object, opts ...client.DeleteOption) error {\n713: \t\t\tdeleteCalled = true\n714: \t\t\treturn nil\n715: \t\t},\n716: \t}\n717: \n718: \tr := &Reconciler{Client: mock}\n719: \tresult, err := r.Reconcile(context.Background(), ctrl.Request{\n720: \t\tNamespacedName: types.NamespacedName{Name: \"test-sandbox\", Namespace: \"default\"},\n721: \t})\n722: \n723: \tif err != nil {\n724: \t\tt.Errorf(\"Expected no error, got: %v\", err)\n725: \t}\n726: \tif result.RequeueAfter != 0 {\n727: \t\tt.Errorf(\"Expected no requeue for expired sandbox, got: %v\", result.RequeueAfter)\n728: \t}\n729: \tif !deleteCalled {\n730: \t\tt.Error(\"Expected Delete to be called for zero time (far in past)\")\n731: \t}\n732: }\n733: \n734: // TestReconcile_JustBeforeExpiration tests sandbox that expires very soon.\n735: func TestReconcile_JustBeforeExpiration(t *testing.T) {\n736: \t// Last activity 14 minutes 59 seconds ago - just about to expire\n737: \tlastActivity := time.Now().UTC().Add(-(14*time.Minute + 59*time.Second)).Format(time.RFC3339)\n738: \tsandbox := createSandbox(\"test-sandbox\", \"default\", lastActivity)\n739: \n740: \tmock := &mockClient{\n741: \t\tgetFunc: func(ctx context.Context, key client.ObjectKey, obj client.Object, opts ...client.GetOption) error {\n742: \t\t\tsandboxObj := obj.(*v1alpha1.Sandbox)\n743: \t\t\tsandboxObj.Name = sandbox.Name\n744: \t\t\tsandboxObj.Namespace = sandbox.Namespace\n745: \t\t\tsandboxObj.Annotations = sandbox.Annotations\n746: \t\t\treturn nil\n747: \t\t},\n748: \t}\n749: \n750: \tr := &Reconciler{Client: mock}\n751: \tresult, err := r.Reconcile(context.Background(), ctrl.Request{\n752: \t\tNamespacedName: types.NamespacedName{Name: \"test-sandbox\", Namespace: \"default\"},\n753: \t})\n754: \n755: \tif err != nil {\n756: \t\tt.Errorf(\"Expected no error, got: %v\", err)\n757: \t}\n758: \t// Should requeue very soon (within 1 minute)\n759: \tif result.RequeueAfter > 2*time.Minute {\n760: \t\tt.Errorf(\"Expected RequeueAfter < 2m for near-expiration, got %v\", result.RequeueAfter)\n761: \t}\n762: }\n763: \n764: // MockStatusWriter implements client.StatusWriter for testing.\n765: type MockStatusWriter struct{}\n766: \n767: func (m *MockStatusWriter) Create(ctx context.Context, obj client.Object, subResource client.Object, opts ...client.SubResourceCreateOption) error {\n768: \treturn nil\n769: }\n770: \n771: func (m *MockStatusWriter) Update(ctx context.Context, obj client.Object, opts ...client.SubResourceUpdateOption) error {\n772: \treturn nil\n773: }\n774: \n775: func (m *MockStatusWriter) Patch(ctx context.Context, obj client.Object, patch client.Patch, opts ...client.SubResourcePatchOption) error {\n776: \treturn nil\n777: }\n778: \n779: // MockClient is a more complete mock implementation\n780: type MockClient struct {\n781: \tclient.Client\n782: \tGetFunc    func(ctx context.Context, key client.ObjectKey, obj client.Object, opts ...client.GetOption) error\n783: \tListFunc   func(ctx context.Context, list client.ObjectList, opts ...client.ListOption) error\n784: \tCreateFunc func(ctx context.Context, obj client.Object, opts ...client.CreateOption) error\n785: \tDeleteFunc func(ctx context.Context, obj client.Object, opts ...client.DeleteOption) error\n786: \tUpdateFunc func(ctx context.Context, obj client.Object, opts ...client.UpdateOption) error\n787: \tPatchFunc  func(ctx context.Context, obj client.Object, patch client.Patch, opts ...client.PatchOption) error\n788: \tSchemeFunc func() *runtime.Scheme\n789: }\n790: \n791: func (m *MockClient) Get(ctx context.Context, key client.ObjectKey, obj client.Object, opts ...client.GetOption) error {\n792: \tif m.GetFunc != nil {\n793: \t\treturn m.GetFunc(ctx, key, obj, opts...)\n794: \t}\n795: \treturn nil\n796: }\n797: \n798: func (m *MockClient) List(ctx context.Context, list client.ObjectList, opts ...client.ListOption) error {\n799: \tif m.ListFunc != nil {\n800: \t\treturn m.ListFunc(ctx, list, opts...)\n801: \t}\n802: \treturn nil\n803: }\n804: \n805: func (m *MockClient) Create(ctx context.Context, obj client.Object, opts ...client.CreateOption) error {\n806: \tif m.CreateFunc != nil {\n807: \t\treturn m.CreateFunc(ctx, obj, opts...)\n808: \t}\n809: \treturn nil\n810: }\n811: \n812: func (m *MockClient) Delete(ctx context.Context, obj client.Object, opts ...client.DeleteOption) error {\n813: \tif m.DeleteFunc != nil {\n814: \t\treturn m.DeleteFunc(ctx, obj, opts...)\n815: \t}\n816: \treturn nil\n817: }\n818: \n819: func (m *MockClient) Update(ctx context.Context, obj client.Object, opts ...client.UpdateOption) error {\n820: \tif m.UpdateFunc != nil {\n821: \t\treturn m.UpdateFunc(ctx, obj, opts...)\n822: \t}\n823: \treturn nil\n824: }\n825: \n826: func (m *MockClient) Patch(ctx context.Context, obj client.Object, patch client.Patch, opts ...client.PatchOption) error {\n827: \tif m.PatchFunc != nil {\n828: \t\treturn m.PatchFunc(ctx, obj, patch, opts...)\n829: \t}\n830: \treturn nil\n831: }\n832: \n833: func (m *MockClient) DeleteAllOf(ctx context.Context, obj client.Object, opts ...client.DeleteAllOfOption) error {\n834: \treturn nil\n835: }\n836: \n837: func (m *MockClient) Status() client.StatusWriter {\n838: \treturn &MockStatusWriter{}\n839: }\n840: \n841: func (m *MockClient) SubResource(subResource string) client.SubResourceClient {\n842: \treturn nil\n843: }\n844: \n845: func (m *MockClient) Scheme() *runtime.Scheme {\n846: \tif m.SchemeFunc != nil {\n847: \t\treturn m.SchemeFunc()\n848: \t}\n849: \treturn nil\n850: }\n851: \n852: func (m *MockClient) RESTMapper() ctrl.RESTMapper {\n853: \treturn nil\n854: }\n855: \n856: func (m *MockClient) GroupVersionKindFor(obj runtime.Object) (ctrl.GroupVersionKind, error) {\n857: \treturn ctrl.GroupVersionKind{}, nil\n858: }\n859: \n860: func (m *MockClient) IsObjectNamespaced(obj runtime.Object) (bool, error) {\n861: \treturn true, nil\n862: }\n863: \n864: // BenchmarkReconcile benchmarks the reconcile function.\n865: func BenchmarkReconcile(b *testing.B) {\n866: \tlastActivity := time.Now().UTC().Add(-20 * time.Minute).Format(time.RFC3339)\n867: \tsandbox := createSandbox(\"test-sandbox\", \"default\", lastActivity)\n868: \n869: \tmock := &MockClient{\n870: \t\tGetFunc: func(ctx context.Context, key client.ObjectKey, obj client.Object, opts ...client.GetOption) error {\n871: \t\t\tsandboxObj := obj.(*v1alpha1.Sandbox)\n872: \t\t\tsandboxObj.Name = sandbox.Name\n873: \t\t\tsandboxObj.Namespace = sandbox.Namespace\n874: \t\t\tsandboxObj.Annotations = sandbox.Annotations\n875: \t\t\treturn nil\n876: \t\t},\n877: \t\tDeleteFunc: func(ctx context.Context, obj client.Object, opts ...client.DeleteOption) error {\n878: \t\t\treturn nil\n879: \t\t},\n880: \t}\n881: \n882: \tr := &Reconciler{Client: mock}\n883: \tctx := context.Background()\n884: \treq := ctrl.Request{\n885: \t\tNamespacedName: types.NamespacedName{Name: \"test-sandbox\", Namespace: \"default\"},\n886: \t}\n887: \n888: \tb.ResetTimer()\n889: \tfor i := 0; i < b.N; i++ {\n890: \t\t_, err := r.Reconcile(ctx, req)\n891: \t\tif err != nil {\n892: \t\t\tb.Fatalf(\"Unexpected error: %v\", err)\n893: \t\t}\n894: \t}\n895: }\n896: \n897: // TestReconcile_EdgeCase_FarFuture tests timestamp far in the future.\n898: func TestReconcile_EdgeCase_FarFuture(t *testing.T) {\n899: \t// Far future timestamp (1 year from now) - should not be expired\n900: \tlastActivity := time.Now().UTC().Add(365 * 24 * time.Hour).Format(time.RFC3339)\n901: \tsandbox := createSandbox(\"test-sandbox\", \"default\", lastActivity)\n902: \n903: \tmock := &mockClient{\n904: \t\tgetFunc: func(ctx context.Context, key client.ObjectKey, obj client.Object, opts ...client.GetOption) error {\n905: \t\t\tsandboxObj := obj.(*v1alpha1.Sandbox)\n906: \t\t\tsandboxObj.Name = sandbox.Name\n907: \t\t\tsandboxObj.Namespace = sandbox.Namespace\n908: \t\t\tsandboxObj.Annotations = sandbox.Annotations\n909: \t\t\treturn nil\n910: \t\t},\n911: \t}\n912: \n913: \tr := &Reconciler{Client: mock}\n914: \tresult, err := r.Reconcile(context.Background(), ctrl.Request{\n915: \t\tNamespacedName: types.NamespacedName{Name: \"test-sandbox\", Namespace: \"default\"},\n916: \t})\n917: \n918: \tif err != nil {\n919: \t\tt.Errorf(\"Expected no error, got: %v\", err)\n920: \t}\n921: \t// Should requeue after a very long time (1 year + 15 minutes)\n922: \tminExpected := 364 * 24 * time.Hour // At least 364 days\n923: \tif result.RequeueAfter < minExpected {\n924: \t\tt.Errorf(\"Expected RequeueAfter > %v for far future, got %v\", minExpected, result.RequeueAfter)\n925: \t}\n926: }\n927: \n928: // cmpDiff is a helper for comparing using cmp.Diff\n929: func cmpDiff(x, y interface{}) string {\n930: \treturn cmp.Diff(x, y)\n931: }\n\n(End of file - total 931 lines)\n</content>","metadata":{"preview":"/*\nCopyright 2026 The Volcano Authors.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\npackage agentd\n\nimport (\n\t\"context\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/agentd/reconciler_test.go","time":{"start":1775881307101,"end":1775881307130}}}}
{"type":"tool_use","timestamp":1775881307136,"sessionID":"ses_2853a130cffe7ZrnsNmL39pUlM","part":{"id":"prt_d7ac63543001SX4UdoUGwOBIli","messageID":"msg_d7ac61e31001fiBNtP2RFwiKzJ","sessionID":"ses_2853a130cffe7ZrnsNmL39pUlM","type":"tool","tool":"read","callID":"toolu_functions.read:3","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/agentd/reconciler.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/agentd/reconciler.go</path>\n<type>file</type>\n<content>\n1: /*\n2: Copyright 2026 The Volcano Authors.\n3: \n4: Licensed under the Apache License, Version 2.0 (the \"License\");\n5: you may not use this file except in compliance with the License.\n6: You may obtain a copy of the License at\n7: \n8:     http://www.apache.org/licenses/LICENSE-2.0\n9: \n10: Unless required by applicable law or agreed to in writing, software\n11: distributed under the License is distributed on an \"AS IS\" BASIS,\n12: WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n13: See the License for the specific language governing permissions and\n14: limitations under the License.\n15: */\n16: \n17: package agentd\n18: \n19: import (\n20: \t\"context\"\n21: \t\"time\"\n22: \n23: \t\"k8s.io/apimachinery/pkg/api/errors\"\n24: \t\"k8s.io/apimachinery/pkg/runtime\"\n25: \tctrl \"sigs.k8s.io/controller-runtime\"\n26: \t\"sigs.k8s.io/controller-runtime/pkg/client\"\n27: \t\"sigs.k8s.io/controller-runtime/pkg/log\"\n28: \n29: \t\"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1\"\n30: \t\"github.com/volcano-sh/agentcube/pkg/workloadmanager\"\n31: )\n32: \n33: // SessionExpirationTimeout defines the idle timeout before sandbox deletion.\n34: // A sandbox that has been inactive for longer than this duration will be\n35: // automatically deleted by the reconciler.\n36: var SessionExpirationTimeout = 15 * time.Minute\n37: \n38: // RequeueAfterParseError defines the requeue delay when timestamp parsing fails.\n39: // This gives time for the workload manager to potentially fix the annotation\n40: // before retrying.\n41: var RequeueAfterParseError = 30 * time.Second\n42: \n43: // Reconciler reconciles Sandbox objects for idle cleanup.\n44: // It watches Sandbox resources and deletes them when they have been inactive\n45: // beyond the configured SessionExpirationTimeout.\n46: type Reconciler struct {\n47: \tclient.Client\n48: \tScheme *runtime.Scheme\n49: }\n50: \n51: // Reconcile implements the idle cleanup logic.\n52: //\n53: // The reconciliation flow:\n54: //  1. Get the Sandbox resource by namespace/name from the request\n55: //  2. If not found, return empty result (idempotent success)\n56: //  3. Read the last-activity-time annotation from Sandbox metadata\n57: //  4. If missing/empty, return empty result (no action needed)\n58: //  5. Parse the timestamp as RFC3339\n59: //  6. If parse error, return error with RequeueAfter: 30s\n60: //  7. Compute expiration time: lastActivity + SessionExpirationTimeout\n61: //  8. If not yet expired, requeue at expiration time\n62: //  9. If expired, delete the Sandbox\n63: //\n64: // 10. If delete returns NotFound, return empty result (already deleted)\n65: // 11. If delete returns other error, return error for retry\n66: // 12. If delete succeeds, return empty result\n67: //\n68: // Parameters:\n69: //   - ctx: The context for the reconciliation operation\n70: //   - req: The reconcile request containing namespace and name\n71: //\n72: // Returns:\n73: //   - ctrl.Result: Indicates whether and when to requeue\n74: //   - error: Any error that occurred during reconciliation\n75: func (r *Reconciler) Reconcile(ctx context.Context, req ctrl.Request) (ctrl.Result, error) {\n76: \tlog := log.FromContext(ctx)\n77: \n78: \t// Fetch the Sandbox instance\n79: \tsandbox := &v1alpha1.Sandbox{}\n80: \tif err := r.Get(ctx, req.NamespacedName, sandbox); err != nil {\n81: \t\t// Sandbox not found - may have been deleted already\n82: \t\t// This is idempotent success\n83: \t\tif errors.IsNotFound(err) {\n84: \t\t\tlog.V(1).Info(\"Sandbox not found, ignoring\", \"namespacedName\", req.NamespacedName)\n85: \t\t\treturn ctrl.Result{}, nil\n86: \t\t}\n87: \t\t// Other get error - return for retry\n88: \t\tlog.Error(err, \"Failed to get Sandbox\", \"namespacedName\", req.NamespacedName)\n89: \t\treturn ctrl.Result{}, err\n90: \t}\n91: \n92: \tlog.V(1).Info(\"Reconciling Sandbox\", \"name\", sandbox.Name, \"namespace\", sandbox.Namespace)\n93: \n94: \t// Read the last-activity-time annotation\n95: \tlastActivityStr, exists := sandbox.Annotations[workloadmanager.LastActivityAnnotationKey]\n96: \tif !exists || lastActivityStr == \"\" {\n97: \t\t// No activity annotation - sandbox may not be tracking activity yet\n98: \t\t// or is managed by another mechanism. Take no action.\n99: \t\tlog.V(1).Info(\"No last-activity-time annotation, skipping\", \"sandbox\", sandbox.Name)\n100: \t\treturn ctrl.Result{}, nil\n101: \t}\n102: \n103: \t// Parse the timestamp as RFC3339\n104: \tlastActivity, err := time.Parse(time.RFC3339, lastActivityStr)\n105: \tif err != nil {\n106: \t\t// Invalid timestamp format - requeue with delay to retry\n107: \t\tlog.Error(err, \"Failed to parse last-activity-time, requeuing\",\n108: \t\t\t\"sandbox\", sandbox.Name,\n109: \t\t\t\"value\", lastActivityStr)\n110: \t\treturn ctrl.Result{RequeueAfter: RequeueAfterParseError}, err\n111: \t}\n112: \n113: \t// Compute expiration time\n114: \texpirationTime := lastActivity.Add(SessionExpirationTimeout)\n115: \n116: \t// Check if the sandbox has expired\n117: \tnow := time.Now()\n118: \tif now.After(expirationTime) || now.Equal(expirationTime) {\n119: \t\t// Sandbox has been idle beyond the timeout - delete it\n120: \t\tlog.Info(\"Sandbox expired, deleting\",\n121: \t\t\t\"sandbox\", sandbox.Name,\n122: \t\t\t\"namespace\", sandbox.Namespace,\n123: \t\t\t\"lastActivity\", lastActivity.Format(time.RFC3339),\n124: \t\t\t\"expirationTime\", expirationTime.Format(time.RFC3339))\n125: \n126: \t\tif err := r.Delete(ctx, sandbox); err != nil {\n127: \t\t\t// Delete returned NotFound - sandbox was already deleted\n128: \t\t\t// This is idempotent success\n129: \t\t\tif errors.IsNotFound(err) {\n130: \t\t\t\tlog.V(1).Info(\"Sandbox already deleted\", \"sandbox\", sandbox.Name)\n131: \t\t\t\treturn ctrl.Result{}, nil\n132: \t\t\t}\n133: \t\t\t// Other delete error - return for retry\n134: \t\t\tlog.Error(err, \"Failed to delete Sandbox\", \"sandbox\", sandbox.Name)\n135: \t\t\treturn ctrl.Result{}, err\n136: \t\t}\n137: \n138: \t\t// Delete succeeded\n139: \t\tlog.Info(\"Successfully deleted expired Sandbox\",\n140: \t\t\t\"sandbox\", sandbox.Name,\n141: \t\t\t\"namespace\", sandbox.Namespace)\n142: \t\treturn ctrl.Result{}, nil\n143: \t}\n144: \n145: \t// Sandbox not yet expired - requeue at expiration time\n146: \t// This ensures we check again exactly when it expires\n147: \trequeueAfter := time.Until(expirationTime)\n148: \tlog.V(1).Info(\"Sandbox not yet expired, requeuing\",\n149: \t\t\"sandbox\", sandbox.Name,\n150: \t\t\"lastActivity\", lastActivity.Format(time.RFC3339),\n151: \t\t\"expirationTime\", expirationTime.Format(time.RFC3339),\n152: \t\t\"requeueAfter\", requeueAfter)\n153: \n154: \treturn ctrl.Result{RequeueAfter: requeueAfter}, nil\n155: }\n156: \n157: // SetupWithManager sets up the controller with the Manager.\n158: // This registers the reconciler to watch Sandbox resources and be invoked\n159: // when they are created, updated, or deleted.\n160: //\n161: // Parameters:\n162: //   - mgr: The controller-runtime manager\n163: //\n164: // Returns:\n165: //   - error: Any error that occurred during setup\n166: func (r *Reconciler) SetupWithManager(mgr ctrl.Manager) error {\n167: \treturn ctrl.NewControllerManagedBy(mgr).\n168: \t\tFor(&v1alpha1.Sandbox{}).\n169: \t\tComplete(r)\n170: }\n\n(End of file - total 170 lines)\n</content>","metadata":{"preview":"/*\nCopyright 2026 The Volcano Authors.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\npackage agentd\n\nimport (\n\t\"context\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/agentd/reconciler.go","time":{"start":1775881307095,"end":1775881307134}}}}
{"type":"tool_use","timestamp":1775881307138,"sessionID":"ses_2853a130cffe7ZrnsNmL39pUlM","part":{"id":"prt_d7ac63e3f001B6AHjac40MfPL4","messageID":"msg_d7ac61e31001fiBNtP2RFwiKzJ","sessionID":"ses_2853a130cffe7ZrnsNmL39pUlM","type":"tool","tool":"read","callID":"toolu_functions.read:5","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/agentd/doc.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/agentd/doc.go</path>\n<type>file</type>\n<content>\n1: /*\n2: Copyright 2026 The Volcano Authors.\n3: \n4: Licensed under the Apache License, Version 2.0 (the \"License\");\n5: you may not use this file except in compliance with the License.\n6: You may obtain a copy of the License at\n7: \n8:     http://www.apache.org/licenses/LICENSE-2.0\n9: \n10: Unless required by applicable law or agreed to in writing, software\n11: distributed under the License is distributed on an \"AS IS\" BASIS,\n12: WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n13: See the License for the specific language governing permissions and\n14: limitations under the License.\n15: */\n16: \n17: // Package agentd provides the idle cleanup controller for Sandbox resources.\n18: //\n19: // The agentd package implements a controller-runtime reconciler that watches\n20: // Sandbox custom resources and automatically deletes them when they have been\n21: // inactive beyond a configured grace period (15 minutes by default).\n22: //\n23: // The controller reads the \"last-activity-time\" annotation from Sandbox\n24: // metadata to determine when the sandbox was last active. If the annotation\n25: // is missing or empty, no action is taken. If the timestamp is invalid, the\n26: // controller requeues with a 30-second delay to retry parsing.\n27: //\n28: // When a sandbox has been idle for more than the configured timeout, the\n29: // controller deletes the Sandbox resource. Kubernetes garbage collection\n30: // handles cleanup of owned resources (pods, secrets, etc.) via ownerReferences.\n31: //\n32: // Usage:\n33: //\n34: //\timport (\n35: //\t    \"sigs.k8s.io/controller-runtime/pkg/manager\"\n36: //\t    \"github.com/volcano-sh/agentcube/pkg/agentd\"\n37: //\t)\n38: //\n39: //\tfunc main() {\n40: //\t    mgr, err := manager.New(config, manager.Options{})\n41: //\t    if err != nil {\n42: //\t        panic(err)\n43: //\t    }\n44: //\n45: //\t    reconciler := &agentd.Reconciler{\n46: //\t        Client: mgr.GetClient(),\n47: //\t        Scheme: mgr.GetScheme(),\n48: //\t    }\n49: //\n50: //\t    if err := reconciler.SetupWithManager(mgr); err != nil {\n51: //\t        panic(err)\n52: //\t    }\n53: //\n54: //\t    mgr.Start(signals.SetupSignalHandler())\n55: //\t}\n56: //\n57: // Constants:\n58: //\n59: //\tSessionExpirationTimeout - The idle timeout before sandbox deletion (15 minutes)\n60: //\tRequeueAfterParseError   - The requeue delay when timestamp parsing fails (30 seconds)\n61: //\n62: // The controller handles the following scenarios:\n63: //   - Sandbox not found: Returns empty result (idempotent)\n64: //   - Missing/empty annotation: Returns empty result (no action)\n65: //   - Invalid timestamp: Returns error with 30s requeue\n66: //   - Not yet expired: Returns requeue at expiration time\n67: //   - Expired: Deletes sandbox\n68: //   - Delete not found: Returns empty result (idempotent)\n69: //   - Delete error: Returns error for retry\n70: package agentd\n\n(End of file - total 70 lines)\n</content>","metadata":{"preview":"/*\nCopyright 2026 The Volcano Authors.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\n// Package agentd provides the idle cleanup controller for Sandbox resources.\n//\n// The agentd package implements a controller-runtime reconciler that watches\n// Sandbox custom resources and automatically deletes them when they have been","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/agentd/doc.go","time":{"start":1775881307104,"end":1775881307136}}}}
