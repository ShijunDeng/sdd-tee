om dict, filtering None values.\n37: \n38:         Args:\n39:             options: Dictionary of option key-value pairs.\n40: \n41:         Returns:\n42:             A MetadataOptions instance with non-None values from the dict.\n43:         \"\"\"\n44:         filtered = {k: v for k, v in options.items() if v is not None}\n45:         return cls(**filtered)\n\n(End of file - total 45 lines)\n</content>","metadata":{"preview":"\"\"\"Data models for the pack command.\n\nThis module contains dataclasses used for packaging agent workspaces.\n\"\"\"\n\nfrom dataclasses import dataclass\nfrom typing import Any, Dict, Optional\n\n\n@dataclass\nclass MetadataOptions:\n    \"\"\"Options for metadata creation/overrides during pack.\n\n    This dataclass represents CLI options that can be used to override\n    or create agent metadata during the pack operation.\n    \"\"\"\n\n    agent_name: Optional[str] = None\n    language: Optional[str] = \"python\"\n    entrypoint: Optional[str] = None","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/agentcube/models/pack_models.py","time":{"start":1775888466413,"end":1775888466429}}}}
