{"type":"tool_use","timestamp":1775888466426,"sessionID":"ses_284ccea01ffepIvCJtkQ5bc36T","part":{"id":"prt_d7b3374d2001vqjUT04tO9hUED","messageID":"msg_d7b335e910011s8AlcAVbG8YlJ","sessionID":"ses_284ccea01ffepIvCJtkQ5bc36T","type":"tool","tool":"read","callID":"toolu_functions.read:7","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/agentcube/runtime/build_runtime.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/agentcube/runtime/build_runtime.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Build runtime for AgentCube CLI.\n2: \n3: This module provides the BuildRuntime class for building agent images\n4: from packaged workspaces, supporting both local Docker builds and\n5: cloud-based builds.\n6: \"\"\"\n7: \n8: import logging\n9: import re\n10: import time\n11: from datetime import datetime, timezone\n12: from pathlib import Path\n13: from typing import Any, Dict, Optional, Tuple\n14: \n15: from packaging.version import InvalidVersion, Version\n16: \n17: from agentcube.services.docker_service import DockerService\n18: from agentcube.services.metadata_service import AgentMetadata, MetadataService\n19: from agentcube.utils.log import get_logger\n20: \n21: \n22: class BuildRuntime:\n23:     \"\"\"Runtime class responsible for building agent images.\"\"\"\n24: \n25:     def __init__(self, verbose: bool = False) -> None:\n26:         \"\"\"Initialize BuildRuntime.\n27: \n28:         Args:\n29:             verbose: Whether to enable verbose logging.\n30:         \"\"\"\n31:         self.verbose = verbose\n32:         self.logger = get_logger(__name__, logging.DEBUG if verbose else logging.INFO)\n33:         self.metadata_service = MetadataService(verbose=verbose)\n34:         self.docker_service = DockerService(verbose=verbose)\n35:         self._original_version: Optional[str] = None\n36:         self._current_metadata: Optional[AgentMetadata] = None\n37: \n38:     def build(self, workspace_path: Path, **options: Any) -> Dict[str, Any]:\n39:         \"\"\"Build the agent image from the packaged workspace.\n40: \n41:         This is the main entry point for the build operation. It validates\n42:         prerequisites, increments version, builds the image (locally or\n43:         in the cloud), and updates metadata.\n44: \n45:         Args:\n46:             workspace_path: Path to the agent workspace directory.\n47:             **options: Build options including:\n48:                 - proxy: Custom proxy URL\n49:                 - cloud_provider: Cloud provider name (e.g., 'huawei')\n50:                 - output: Output path for build artifacts\n51: \n52:         Returns:\n53:             Dict containing build results with keys:\n54:             - status: 'success' or 'error'\n55:             - image_name: Name of the built image\n56:             - image_tag: Tag of the image\n57:             - image_id: Docker image ID\n58:             - image_size: Human-readable size\n59:             - build_time: Build duration\n60:             - build_mode: 'local' or 'cloud'\n61:             - metadata_path: Path to updated metadata file\n62: \n63:         Raises:\n64:             ValueError: If workspace is invalid.\n65:             RuntimeError: If build prerequisites are not met.\n66:             FileNotFoundError: If required files (e.g., Dockerfile) are missing.\n67:         \"\"\"\n68:         self.logger.info(f\"Starting build operation for workspace: {workspace_path}\")\n69: \n70:         # Validate workspace\n71:         self._validate_workspace(workspace_path)\n72: \n73:         # Load metadata\n74:         metadata = self.metadata_service.load_metadata(workspace_path)\n75:         self._current_metadata = metadata\n76: \n77:         # Validate build prerequisites\n78:         self._validate_build_prerequisites(workspace_path, metadata)\n79: \n80:         # Increment version\n81:         original_version = metadata.version or \"0.0.1\"\n82:         self._original_version = original_version\n83: \n84:         try:\n85:             new_version = self._increment_version(metadata)\n86:             metadata.version = new_version\n87:             self.logger.info(f\"Version incremented: {original_version} -> {new_version}\")\n88: \n89:             # Save metadata with new version\n90:             self.metadata_service.save_metadata(workspace_path, metadata)\n91: \n92:             # Determine build mode and execute\n93:             build_mode = metadata.build_mode or \"local\"\n94:             self.logger.info(f\"Build mode: {build_mode}\")\n95: \n96:             if build_mode == \"local\":\n97:                 build_result = self._build_local(workspace_path, metadata, options)\n98:             elif build_mode == \"cloud\":\n99:                 build_result = self._build_cloud(workspace_path, metadata, options)\n100:             else:\n101:                 raise ValueError(f\"Unsupported build mode: {build_mode}\")\n102: \n103:             # Update metadata with build results\n104:             self._update_build_metadata(workspace_path, metadata, build_result, tag=new_version)\n105: \n106:             self.logger.info(\n107:                 f\"Build completed successfully: {build_result.get('image_name', 'unknown')}\"\n108:             )\n109: \n110:             return {\n111:                 \"status\": \"success\",\n112:                 \"image_name\": build_result.get(\"image_name\", metadata.agent_name),\n113:                 \"image_tag\": build_result.get(\"image_tag\", new_version),\n114:                 \"image_id\": build_result.get(\"image_id\", \"\"),\n115:                 \"image_size\": build_result.get(\"image_size\", \"unknown\"),\n116:                 \"build_time\": build_result.get(\"build_time\", \"0\"),\n117:                 \"build_mode\": build_mode,\n118:                 \"metadata_path\": str(workspace_path / \"agent_metadata.yaml\"),\n119:             }\n120: \n121:         except Exception as e:\n122:             # Revert version on failure\n123:             if self._current_metadata and self._original_version:\n124:                 self.logger.warning(f\"Build failed, reverting version to {self._original_version}\")\n125:                 self._current_metadata.version = self._original_version\n126:                 self.metadata_service.save_metadata(workspace_path, self._current_metadata)\n127:             raise\n128: \n129:     def _validate_workspace(self, workspace_path: Path) -> None:\n130:         \"\"\"Validate that the workspace exists and is a directory.\n131: \n132:         Args:\n133:             workspace_path: Path to the workspace directory.\n134: \n135:         Raises:\n136:             ValueError: If workspace path is invalid.\n137:         \"\"\"\n138:         if not workspace_path.exists():\n139:             raise ValueError(f\"Invalid workspace path: {workspace_path} does not exist\")\n140:         if not workspace_path.is_dir():\n141:             raise ValueError(f\"Invalid workspace path: {workspace_path} is not a directory\")\n142: \n143:     def _validate_build_prerequisites(self, workspace_path: Path, metadata: AgentMetadata) -> None:\n144:         \"\"\"Validate prerequisites for the build operation.\n145: \n146:         For local builds, verifies Docker is available.\n147:         For cloud builds, verifies cloud provider is configured.\n148: \n149:         Args:\n150:             workspace_path: Path to the agent workspace.\n151:             metadata: The agent metadata.\n152: \n153:         Raises:\n154:             RuntimeError: If prerequisites are not met.\n155:             FileNotFoundError: If required files are missing.\n156:         \"\"\"\n157:         build_mode = metadata.build_mode or \"local\"\n158: \n159:         # Check for metadata file (indicating pack was run)\n160:         metadata_file = workspace_path / \"agent_metadata.yaml\"\n161:         if not metadata_file.exists():\n162:             raise FileNotFoundError(\n163:                 \"agent_metadata.yaml not found. Please run 'agentcube pack' first.\"\n164:             )\n165: \n166:         if build_mode == \"local\":\n167:             # Check for Dockerfile\n168:             dockerfile_path = workspace_path / \"Dockerfile\"\n169:             if not dockerfile_path.exists():\n170:                 raise FileNotFoundError(\"Dockerfile not found. Please run 'agentcube pack' first.\")\n171: \n172:             # Check Docker availability\n173:             if not self.docker_service.is_docker_available():\n174:                 raise RuntimeError(\"Docker is not available or not running\")\n175: \n176:             self.logger.debug(\"Local build prerequisites validated\")\n177: \n178:         elif build_mode == \"cloud\":\n179:             # For cloud builds, we need the cloud provider configuration\n180:             # Actual validation happens in _build_cloud\n181:             self.logger.debug(\"Cloud build prerequisites validated (cloud provider check pending)\")\n182: \n183:     def _increment_version(self, metadata: AgentMetadata) -> str:\n184:         \"\"\"Increment the version string.\n185: \n186:         Supports semantic versioning (e.g., 1.2.3 -> 1.2.4) and falls back\n187:         to appending -N for non-semver formats.\n188: \n189:         Args:\n190:             metadata: The agent metadata containing the version.\n191: \n192:         Returns:\n193:             The incremented version string.\n194:         \"\"\"\n195:         current_version = metadata.version or \"0.0.1\"\n196: \n197:         # Try semantic versioning first\n198:         try:\n199:             version = Version(current_version)\n200:             # For simple versions like 1.2.3, increment patch\n201:             if version.micro is not None:\n202:                 new_version = f\"{version.major}.{version.minor}.{version.micro + 1}\"\n203:             elif version.minor is not None:\n204:                 new_version = f\"{version.major}.{version.minor + 1}\"\n205:             else:\n206:                 new_version = f\"{version.major + 1}.0\"\n207:             return new_version\n208:         except InvalidVersion:\n209:             pass\n210: \n211:         # Try simple semver pattern matching (X.Y.Z)\n212:         semver_match = re.match(r\"^(\\d+)\\.(\\d+)(?:\\.(\\d+))?$\", current_version)\n213:         if semver_match:\n214:             major, minor, patch = semver_match.groups()\n215:             if patch is not None:\n216:                 return f\"{major}.{minor}.{int(patch) + 1}\"\n217:             else:\n218:                 return f\"{major}.{int(minor) + 1}\"\n219: \n220:         # Fallback: append -N or increment existing -N\n221:         if \"-\" in current_version:\n222:             parts = current_version.rsplit(\"-\", 1)\n223:             suffix = parts[1]\n224:             if suffix.isdigit():\n225:                 return f\"{parts[0]}-{int(suffix) + 1}\"\n226:             else:\n227:                 return f\"{current_version}-1\"\n228:         else:\n229:             return f\"{current_version}-1\"\n230: \n231:     def _build_local(\n232:         self, workspace_path: Path, metadata: AgentMetadata, options: Dict[str, Any]\n233:     ) -> Dict[str, Any]:\n234:         \"\"\"Build the Docker image locally.\n235: \n236:         Args:\n237:             workspace_path: Path to the agent workspace.\n238:             metadata: The agent metadata.\n239:             options: Build options including proxy settings.\n240: \n241:         Returns:\n242:             Dict containing build results.\n243: \n244:         Raises:\n245:             RuntimeError: If the Docker build fails.\n246:         \"\"\"\n247:         self.logger.info(\"Starting local Docker build\")\n248: \n249:         dockerfile_path = workspace_path / \"Dockerfile\"\n250:         context_path = workspace_path\n251:         image_name = metadata.agent_name\n252:         tag = metadata.version or \"latest\"\n253: \n254:         # Prepare build arguments\n255:         build_args: Dict[str, str] = {}\n256: \n257:         # Add proxy settings if provided\n258:         proxy = options.get(\"proxy\")\n259:         if proxy:\n260:             build_args[\"HTTP_PROXY\"] = proxy\n261:             build_args[\"HTTPS_PROXY\"] = proxy\n262:             build_args[\"NO_PROXY\"] = \"localhost,127.0.0.1\"\n263:             self.logger.debug(f\"Using proxy: {proxy}\")\n264: \n265:         # Build the image\n266:         build_result = self.docker_service.build_image(\n267:             context_path=context_path,\n268:             dockerfile_path=dockerfile_path,\n269:             image_name=image_name,\n270:             tag=tag,\n271:             build_args=build_args if build_args else None,\n272:         )\n273: \n274:         # Handle output directory if specified\n275:         output_path = options.get(\"output\")\n276:         if output_path:\n277:             output_dir = Path(output_path)\n278:             output_dir.mkdir(parents=True, exist_ok=True)\n279:             self.logger.debug(f\"Output directory prepared: {output_dir}\")\n280: \n281:         self.logger.info(f\"Local build completed: {build_result['full_tag']}\")\n282:         return build_result\n283: \n284:     def _build_cloud(\n285:         self, workspace_path: Path, metadata: AgentMetadata, options: Dict[str, Any]\n286:     ) -> Dict[str, Any]:\n287:         \"\"\"Build the image using a cloud provider.\n288: \n289:         This is a placeholder implementation for cloud builds. In a real\n290:         implementation, this would integrate with cloud provider SDKs\n291:         like Huawei Cloud, AWS, GCP, etc.\n292: \n293:         Args:\n294:             workspace_path: Path to the agent workspace.\n295:             metadata: The agent metadata.\n296:             options: Build options including cloud_provider.\n297: \n298:         Returns:\n299:             Dict containing build results from the cloud provider.\n300: \n301:         Raises:\n302:             RuntimeError: If cloud build fails or provider is not configured.\n303:             NotImplementedError: If the cloud provider is not yet supported.\n304:         \"\"\"\n305:         cloud_provider = options.get(\"cloud_provider\") or \"default\"\n306:         self.logger.info(f\"Starting cloud build with provider: {cloud_provider}\")\n307: \n308:         # For now, raise NotImplementedError for actual cloud builds\n309:         # In a real implementation, this would:\n310:         # 1. Upload workspace to cloud storage\n311:         # 2. Trigger cloud build job\n312:         # 3. Wait for build completion\n313:         # 4. Return build artifacts\n314: \n315:         # Simulate a successful cloud build for testing purposes\n316:         if cloud_provider == \"mock\" or self.verbose:\n317:             self.logger.warning(\"Cloud build is simulated for testing\")\n318:             return {\n319:                 \"image_name\": metadata.agent_name,\n320:                 \"image_tag\": metadata.version or \"latest\",\n321:                 \"image_id\": \"cloud-build-mock-id\",\n322:                 \"image_size\": \"0MB\",\n323:                 \"build_time\": \"0.00\",\n324:                 \"full_tag\": f\"{metadata.agent_name}:{metadata.version or 'latest'}\",\n325:                 \"image_url\": f\"registry.example.com/{metadata.agent_name}:{metadata.version}\",\n326:                 \"image_digest\": f\"sha256:{metadata.agent_name}-mock-digest\",\n327:                 \"build_id\": f\"build-{int(time.time())}\",\n328:             }\n329: \n330:         raise NotImplementedError(\n331:             f\"Cloud provider '{cloud_provider}' is not yet implemented. \"\n332:             \"Supported providers will be: huawei, aws, gcp, azure\"\n333:         )\n334: \n335:     def _update_build_metadata(\n336:         self,\n337:         workspace_path: Path,\n338:         metadata: AgentMetadata,\n339:         build_result: Dict[str, str],\n340:         tag: str = \"latest\",\n341:     ) -> None:\n342:         \"\"\"Update metadata with build results.\n343: \n344:         Args:\n345:             workspace_path: Path to the agent workspace.\n346:             metadata: The agent metadata to update.\n347:             build_result: Dict containing build results from Docker or cloud.\n348:             tag: Tag to record (defaults to version).\n349:         \"\"\"\n350:         # Update image information\n351:         metadata.image = {\n352:             \"name\": build_result.get(\"image_name\", metadata.agent_name),\n353:             \"tag\": tag,\n354:             \"id\": build_result.get(\"image_id\", \"\"),\n355:             \"size\": build_result.get(\"image_size\", \"\"),\n356:         }\n357: \n358:         # Update build information\n359:         metadata.pack_timestamp = datetime.now(timezone.utc).isoformat()\n360: \n361:         # Save updated metadata\n362:         self.metadata_service.save_metadata(workspace_path, metadata)\n363:         self.logger.debug(f\"Metadata updated with build results: {metadata.image}\")\n364: \n365:     def _revert_version(self, workspace_path: Path) -> None:\n366:         \"\"\"Revert the version to its original value.\n367: \n368:         This is called when a build fails to restore the original version.\n369: \n370:         Args:\n371:             workspace_path: Path to the agent workspace.\n372:         \"\"\"\n373:         if self._current_metadata and self._original_version:\n374:             self.logger.debug(f\"Reverting version to {self._original_version}\")\n375:             self._current_metadata.version = self._original_version\n376:             self.metadata_service.save_metadata(workspace_path, self._current_metadata)\n\n(End of file - total 376 lines)\n</content>","metadata":{"preview":"\"\"\"Build runtime for AgentCube CLI.\n\nThis module provides the BuildRuntime class for building agent images\nfrom packaged workspaces, supporting both local Docker builds and\ncloud-based builds.\n\"\"\"\n\nimport logging\nimport re\nimport time\nfrom datetime import datetime, timezone\nfrom pathlib import Path\nfrom typing import Any, Dict, Optional, Tuple\n\nfrom packaging.version import InvalidVersion, Version\n\nfrom agentcube.services.docker_service import DockerService\nfrom agentcube.services.metadata_service import AgentMetadata, MetadataService\nfrom agentcube.utils.log import get_logger\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/agentcube/runtime/build_runtime.py","time":{"start":1775888466407,"end":1775888466425}}}}
{"type":"tool_use","timestamp":1775888466428,"sessionID":"ses_284ccea01ffepIvCJtkQ5bc36T","part":{"id":"prt_d7b3379380013imEpw92cWgReW","messageID":"msg_d7b335e910011s8AlcAVbG8YlJ","sessionID":"ses_284ccea01ffepIvCJtkQ5bc36T","type":"tool","tool":"read","callID":"toolu_functions.read:8","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/agentcube/runtime/pack_runtime.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/agentcube/runtime/pack_runtime.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Pack runtime for AgentCube CLI.\n2: \n3: This module provides the PackRuntime class for packaging agent workspaces.\n4: \"\"\"\n5: \n6: import logging\n7: from datetime import datetime, timezone\n8: from pathlib import Path\n9: from typing import Any, Dict, Optional\n10: \n11: from agentcube.models.pack_models import MetadataOptions\n12: from agentcube.services.metadata_service import AgentMetadata, MetadataService\n13: from agentcube.utils.log import get_logger\n14: \n15: \n16: class PackRuntime:\n17:     \"\"\"Core class responsible for packaging agent workspaces.\"\"\"\n18: \n19:     def __init__(self, verbose: bool = False) -> None:\n20:         \"\"\"Initialize PackRuntime with optional verbose logging.\n21: \n22:         Args:\n23:             verbose: Whether to enable verbose logging.\n24:         \"\"\"\n25:         self.verbose = verbose\n26:         self.logger = get_logger(__name__, logging.DEBUG if verbose else logging.INFO)\n27:         self.metadata_service = MetadataService(verbose=verbose)\n28: \n29:     def pack(self, workspace_path: Path, **options: Any) -> Dict[str, Any]:\n30:         \"\"\"Main entry point for packaging an agent workspace.\n31: \n32:         Args:\n33:             workspace_path: Path to the agent workspace directory.\n34:             **options: CLI options and overrides.\n35: \n36:         Returns:\n37:             Dict containing packaging results including agent_name,\n38:             workspace_path, and metadata_path.\n39: \n40:         Raises:\n41:             ValueError: If workspace validation fails.\n42:         \"\"\"\n43:         self.logger.info(f\"Starting pack operation for workspace: {workspace_path}\")\n44: \n45:         # Step 1: Validate workspace structure\n46:         self._validate_workspace_structure(workspace_path)\n47:         self.logger.debug(\"Workspace structure validated\")\n48: \n49:         # Step 2: Load or create metadata\n50:         metadata = self._load_or_create_metadata(workspace_path, options)\n51:         self.logger.debug(f\"Metadata loaded: agent_name={metadata.agent_name}\")\n52: \n53:         # Step 3: Apply CLI option overrides\n54:         metadata = self._apply_option_overrides(metadata, options)\n55:         self.logger.debug(\"Option overrides applied\")\n56: \n57:         # Step 4: Validate language compatibility\n58:         self._validate_language_compatibility(workspace_path, metadata)\n59:         self.logger.debug(\"Language compatibility validated\")\n60: \n61:         # Step 5: Process dependencies\n62:         self._process_dependencies(workspace_path, metadata)\n63:         self.logger.debug(\"Dependencies processed\")\n64: \n65:         # Step 6: Generate Dockerfile\n66:         dockerfile_path = self._generate_dockerfile(workspace_path, metadata)\n67:         self.logger.debug(f\"Dockerfile generated: {dockerfile_path}\")\n68: \n69:         # Step 7: Update metadata with pack results\n70:         self._update_pack_metadata(workspace_path, metadata, dockerfile_path)\n71:         self.logger.debug(\"Pack metadata updated\")\n72: \n73:         # Step 8: Prepare output path\n74:         final_workspace = self._prepare_output_path(workspace_path, options.get(\"output\"))\n75: \n76:         self.logger.info(f\"Pack operation completed successfully for agent: {metadata.agent_name}\")\n77: \n78:         return {\n79:             \"agent_name\": metadata.agent_name,\n80:             \"workspace_path\": str(final_workspace),\n81:             \"metadata_path\": str(final_workspace / \"agent_metadata.yaml\"),\n82:         }\n83: \n84:     def _validate_workspace_structure(self, workspace_path: Path) -> None:\n85:         \"\"\"Validate that workspace exists and contains required files.\n86: \n87:         Args:\n88:             workspace_path: Path to the agent workspace directory.\n89: \n90:         Raises:\n91:             ValueError: If workspace doesn't exist or is not a directory.\n92:         \"\"\"\n93:         if not workspace_path.exists():\n94:             raise ValueError(f\"Workspace directory does not exist: {workspace_path}\")\n95:         if not workspace_path.is_dir():\n96:             raise ValueError(f\"Workspace path is not a directory: {workspace_path}\")\n97: \n98:     def _load_or_create_metadata(\n99:         self, workspace_path: Path, options: Dict[str, Any]\n100:     ) -> AgentMetadata:\n101:         \"\"\"Load existing metadata or create new from options.\n102: \n103:         Metadata loading precedence:\n104:         1. agent_metadata.yaml (primary)\n105:         2. agent.yaml (fallback)\n106:         3. metadata.yaml (fallback)\n107:         4. Create new from defaults + options\n108: \n109:         Args:\n110:             workspace_path: Path to the agent workspace directory.\n111:             options: CLI options and overrides.\n112: \n113:         Returns:\n114:             The loaded or created AgentMetadata instance.\n115:         \"\"\"\n116:         try:\n117:             return self.metadata_service.load_metadata(workspace_path)\n118:         except FileNotFoundError:\n119:             self.logger.info(\"No existing metadata found, creating new\")\n120: \n121:             # Derive agent name from directory if not provided\n122:             agent_name = options.get(\"agent_name\") or workspace_path.name\n123: \n124:             # Infer entrypoint from workspace\n125:             language = options.get(\"language\") or \"python\"\n126:             entrypoint = options.get(\"entrypoint\") or self._infer_entrypoint(\n127:                 workspace_path, language\n128:             )\n129: \n130:             # Create new metadata with defaults\n131:             metadata = AgentMetadata(\n132:                 agent_name=agent_name,\n133:                 entrypoint=entrypoint,\n134:                 language=language,\n135:                 port=options.get(\"port\") or 8080,\n136:                 build_mode=options.get(\"build_mode\") or \"local\",\n137:                 description=options.get(\"description\"),\n138:             )\n139: \n140:             return metadata\n141: \n142:     def _apply_option_overrides(\n143:         self, metadata: AgentMetadata, options: Dict[str, Any]\n144:     ) -> AgentMetadata:\n145:         \"\"\"Apply CLI option overrides to metadata.\n146: \n147:         Override precedence (highest first):\n148:         1. Explicit CLI options\n149:         2. Existing metadata values\n150:         3. Default values from AgentMetadata\n151: \n152:         Args:\n153:             metadata: The current AgentMetadata instance.\n154:             options: CLI options and overrides.\n155: \n156:         Returns:\n157:             The updated AgentMetadata instance.\n158:         \"\"\"\n159:         # Map CLI option names to metadata field names\n160:         field_mapping = {\n161:             \"agent_name\": \"agent_name\",\n162:             \"language\": \"language\",\n163:             \"entrypoint\": \"entrypoint\",\n164:             \"port\": \"port\",\n165:             \"build_mode\": \"build_mode\",\n166:             \"description\": \"description\",\n167:         }\n168: \n169:         for option_key, field_name in field_mapping.items():\n170:             if option_key in options and options[option_key] is not None:\n171:                 setattr(metadata, field_name, options[option_key])\n172:                 self.logger.debug(f\"Applied override: {field_name}={options[option_key]}\")\n173: \n174:         return metadata\n175: \n176:     def _validate_language_compatibility(\n177:         self, workspace_path: Path, metadata: AgentMetadata\n178:     ) -> None:\n179:         \"\"\"Validate workspace contents match declared language.\n180: \n181:         Args:\n182:             workspace_path: Path to the agent workspace directory.\n183:             metadata: The AgentMetadata instance with language configuration.\n184: \n185:         Raises:\n186:             ValueError: If language-specific files are missing.\n187:         \"\"\"\n188:         if metadata.language == \"python\":\n189:             self._validate_python_compatibility(workspace_path)\n190:         elif metadata.language == \"java\":\n191:             self._validate_java_compatibility(workspace_path)\n192: \n193:     def _validate_python_compatibility(self, workspace_path: Path) -> None:\n194:         \"\"\"Validate Python workspace has at least one .py file.\n195: \n196:         Args:\n197:             workspace_path: Path to the agent workspace directory.\n198: \n199:         Raises:\n200:             ValueError: If no Python files found.\n201:         \"\"\"\n202:         py_files = list(workspace_path.glob(\"*.py\"))\n203:         if not py_files:\n204:             raise ValueError(\"No Python files found in workspace\")\n205: \n206:     def _validate_java_compatibility(self, workspace_path: Path) -> None:\n207:         \"\"\"Validate Java workspace has pom.xml.\n208: \n209:         Args:\n210:             workspace_path: Path to the agent workspace directory.\n211: \n212:         Raises:\n213:             ValueError: If pom.xml not found.\n214:         \"\"\"\n215:         pom_path = workspace_path / \"pom.xml\"\n216:         if not pom_path.exists():\n217:             raise ValueError(\"No pom.xml found in workspace (required for Java agents)\")\n218: \n219:     def _process_dependencies(self, workspace_path: Path, metadata: AgentMetadata) -> None:\n220:         \"\"\"Process and validate language-specific dependencies.\n221: \n222:         Args:\n223:             workspace_path: Path to the agent workspace directory.\n224:             metadata: The AgentMetadata instance with language configuration.\n225:         \"\"\"\n226:         if metadata.language == \"python\":\n227:             self._process_python_dependencies(workspace_path)\n228:         elif metadata.language == \"java\":\n229:             self._process_java_dependencies(workspace_path)\n230: \n231:     def _process_python_dependencies(self, workspace_path: Path) -> None:\n232:         \"\"\"Process Python requirements.txt if present.\n233: \n234:         Validates file exists and logs dependency count.\n235: \n236:         Args:\n237:             workspace_path: Path to the agent workspace directory.\n238:         \"\"\"\n239:         req_file = workspace_path / \"requirements.txt\"\n240:         if req_file.exists():\n241:             deps = [\n242:                 line.strip()\n243:                 for line in req_file.read_text().splitlines()\n244:                 if line.strip() and not line.startswith(\"#\")\n245:             ]\n246:             self.logger.info(f\"Found {len(deps)} Python dependencies\")\n247:         else:\n248:             self.logger.debug(\"No requirements.txt found\")\n249: \n250:     def _process_java_dependencies(self, workspace_path: Path) -> None:\n251:         \"\"\"Process Java Maven dependencies from pom.xml.\n252: \n253:         Args:\n254:             workspace_path: Path to the agent workspace directory.\n255:         \"\"\"\n256:         import xml.etree.ElementTree as ET\n257: \n258:         pom_path = workspace_path / \"pom.xml\"\n259:         if pom_path.exists():\n260:             try:\n261:                 tree = ET.parse(pom_path)\n262:                 root = tree.getroot()\n263:                 # Count dependency elements\n264:                 deps = root.findall(\".//{http://maven.apache.org/POM/4.0.0}dependency\")\n265:                 self.logger.info(f\"Found {len(deps)} Maven dependencies\")\n266:             except ET.ParseError as e:\n267:                 self.logger.warning(f\"Could not parse pom.xml: {e}\")\n268:         else:\n269:             self.logger.debug(\"No pom.xml found\")\n270: \n271:     def _generate_dockerfile(self, workspace_path: Path, metadata: AgentMetadata) -> Optional[Path]:\n272:         \"\"\"Generate Dockerfile based on language and metadata.\n273: \n274:         Args:\n275:             workspace_path: Path to agent workspace.\n276:             metadata: Agent metadata with configuration.\n277: \n278:         Returns:\n279:             Path to generated Dockerfile, or None if generation skipped.\n280:         \"\"\"\n281:         dockerfile_path = workspace_path / \"Dockerfile\"\n282: \n283:         if metadata.language == \"python\":\n284:             content = self._generate_python_dockerfile(metadata)\n285:         elif metadata.language == \"java\":\n286:             content = self._generate_java_dockerfile(metadata)\n287:         else:\n288:             self.logger.warning(\n289:                 f\"Unsupported language for Dockerfile generation: {metadata.language}\"\n290:             )\n291:             return None\n292: \n293:         dockerfile_path.write_text(content)\n294:         self.logger.info(f\"Generated Dockerfile at {dockerfile_path}\")\n295:         return dockerfile_path\n296: \n297:     def _generate_python_dockerfile(self, metadata: AgentMetadata) -> str:\n298:         \"\"\"Generate Python-specific Dockerfile content.\n299: \n300:         Template includes:\n301:         - Python 3.11 slim base image\n302:         - Working directory setup\n303:         - Requirements installation\n304:         - Source code copying\n305:         - Entrypoint configuration\n306:         - Port exposure\n307: \n308:         Args:\n309:             metadata: Agent metadata with configuration.\n310: \n311:         Returns:\n312:             Dockerfile content as string.\n313:         \"\"\"\n314:         entrypoint = metadata.entrypoint or \"python main.py\"\n315:         port = metadata.port or 8080\n316: \n317:         return f\"\"\"FROM python:3.11-slim\n318: \n319: WORKDIR /app\n320: \n321: # Install dependencies\n322: COPY requirements.txt .\n323: RUN pip install --no-cache-dir -r requirements.txt\n324: \n325: # Copy source code\n326: COPY . .\n327: \n328: # Expose port\n329: EXPOSE {port}\n330: \n331: # Run the agent\n332: CMD [\"{entrypoint}\"]\n333: \"\"\"\n334: \n335:     def _generate_java_dockerfile(self, metadata: AgentMetadata) -> str:\n336:         \"\"\"Generate Java-specific Dockerfile content.\n337: \n338:         Template includes:\n339:         - Maven build stage\n340:         - JAR extraction\n341:         - Runtime stage with minimal base\n342:         - Port exposure\n343: \n344:         Args:\n345:             metadata: Agent metadata with configuration.\n346: \n347:         Returns:\n348:             Dockerfile content as string.\n349:         \"\"\"\n350:         port = metadata.port or 8080\n351: \n352:         return f\"\"\"# Build stage\n353: FROM maven:3.9-eclipse-temurin-17-alpine AS builder\n354: \n355: WORKDIR /app\n356: COPY pom.xml .\n357: COPY src ./src\n358: \n359: RUN mvn clean package -DskipTests\n360: \n361: # Runtime stage\n362: FROM eclipse-temurin:17-jre-alpine\n363: \n364: WORKDIR /app\n365: \n366: # Copy built JAR\n367: COPY --from=builder /app/target/*.jar app.jar\n368: \n369: # Expose port\n370: EXPOSE {port}\n371: \n372: # Run the agent\n373: ENTRYPOINT [\"java\", \"-jar\", \"app.jar\"]\n374: \"\"\"\n375: \n376:     def _update_pack_metadata(\n377:         self,\n378:         workspace_path: Path,\n379:         metadata: AgentMetadata,\n380:         dockerfile_path: Optional[Path],\n381:     ) -> None:\n382:         \"\"\"Update metadata with pack results.\n383: \n384:         Sets:\n385:         - pack_timestamp: Current UTC time\n386:         - dockerfile_generated: Whether Dockerfile was created\n387: \n388:         Args:\n389:             workspace_path: Path to the agent workspace directory.\n390:             metadata: The AgentMetadata instance to update.\n391:             dockerfile_path: Path to the generated Dockerfile, or None.\n392:         \"\"\"\n393:         metadata.pack_timestamp = datetime.now(timezone.utc).isoformat()\n394:         metadata.dockerfile_generated = dockerfile_path is not None\n395: \n396:         self.metadata_service.save_metadata(workspace_path, metadata)\n397: \n398:     def _prepare_output_path(self, workspace_path: Path, output_path: Optional[str]) -> Path:\n399:         \"\"\"Resolve output path for packaged workspace.\n400: \n401:         Args:\n402:             workspace_path: Source workspace path.\n403:             output_path: Optional explicit output path.\n404: \n405:         Returns:\n406:             Resolved output path.\n407:         \"\"\"\n408:         if output_path:\n409:             return Path(output_path)\n410:         return workspace_path\n411: \n412:     def _infer_entrypoint(self, workspace_path: Path, language: str) -> str:\n413:         \"\"\"Attempt to infer entrypoint from workspace contents.\n414: \n415:         Args:\n416:             workspace_path: Path to workspace.\n417:             language: Programming language.\n418: \n419:         Returns:\n420:             Inferred entrypoint command.\n421:         \"\"\"\n422:         if language == \"python\":\n423:             # Look for main.py, app.py, or any .py file\n424:             for candidate in [\"main.py\", \"app.py\", \"agent.py\"]:\n425:                 if (workspace_path / candidate).exists():\n426:                     return f\"python {candidate}\"\n427:             # Fallback to first .py file\n428:             py_files = list(workspace_path.glob(\"*.py\"))\n429:             if py_files:\n430:                 return f\"python {py_files[0].name}\"\n431:             return \"python main.py\"\n432: \n433:         elif language == \"java\":\n434:             # For Java, entrypoint is typically the JAR\n435:             return \"java -jar app.jar\"\n436: \n437:         return \"\"\n\n(End of file - total 437 lines)\n</content>","metadata":{"preview":"\"\"\"Pack runtime for AgentCube CLI.\n\nThis module provides the PackRuntime class for packaging agent workspaces.\n\"\"\"\n\nimport logging\nfrom datetime import datetime, timezone\nfrom pathlib import Path\nfrom typing import Any, Dict, Optional\n\nfrom agentcube.models.pack_models import MetadataOptions\nfrom agentcube.services.metadata_service import AgentMetadata, MetadataService\nfrom agentcube.utils.log import get_logger\n\n\nclass PackRuntime:\n    \"\"\"Core class responsible for packaging agent workspaces.\"\"\"\n\n    def __init__(self, verbose: bool = False) -> None:\n        \"\"\"Initialize PackRuntime with optional verbose logging.","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/agentcube/runtime/pack_runtime.py","time":{"start":1775888466411,"end":1775888466427}}}}
