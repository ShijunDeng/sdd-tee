\t// Check for unsupported algorithm\n263: \tcase contains(errStr, \"signing method\") && contains(errStr, \"is invalid\"):\n264: \t\treturn ErrUnsupportedAlgorithm\n265: \t}\n266: \n267: \treturn err\n268: }\n269: \n270: // contains checks if a string contains a substring\n271: func contains(s, substr string) bool {\n272: \treturn len(s) >= len(substr) && (s == substr ||\n273: \t\t(len(s) > len(substr) &&\n274: \t\t\t(findSubstring(s, substr) >= 0)))\n275: }\n276: \n277: // findSubstring finds the substring position\n\n(Showing lines 228-277 of 340. Use offset=278 to continue.)\n</content>","metadata":{"preview":"\n// mapError maps JWT library errors to our error types\nfunc (v *validator) mapError(err error) error {\n\tif err == nil {\n\t\treturn nil\n\t}\n\n\t// In jwt/v5, validation errors are returned as standard errors\n\t// We need to check error messages to determine the type\n\terrStr := err.Error()\n\n\tswitch {\n\t// Check for expired token\n\tcase contains(errStr, \"token is expired\") ||\n\t\tcontains(errStr, \"token has invalid claims: token is expired\"):\n\t\treturn ErrTokenExpired\n\n\t// Check for not yet valid token\n\tcase contains(errStr, \"token is not valid yet\") ||\n\t\tcontains(errStr, \"token has invalid claims: token is not valid yet\"):","truncated":true,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/picod/jwt/validator.go","time":{"start":1775879068568,"end":1775879068577}}}}
