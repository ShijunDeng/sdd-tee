t\"time\"\n\n\t\"github.com/golang-jwt/jwt/v5\"\n)\n\n// validator implements the JWTValidator interface\ntype validator struct {\n\topts ValidationOptions\n}\n\n// NewValidator creates a new JWTValidator with the given options\nfunc NewValidator(opts ValidationOptions) (JWTValidator, error) {\n\t// Set default clock skew if not specified\n\tif opts.ClockSkew == 0 {\n\t\topts.ClockSkew = defaultClockSkew\n\t}\n\n\t// Set default algorithm if not specified\n\tif opts.Algorithm == \"\" {\n\t\topts.Algorithm = \"RS256\"\n\t}\n\n\t// Validate algorithm\n\tif !isValidAlgorithm(opts.Algorithm) {\n\t\treturn nil, fmt.Errorf(\"%w: invalid algorithm %q\", ErrInvalidConfiguration, opts.Algorithm)\n\t}\n\n\t// Set allowed algorithms if not specified\n\tif len(opts.AllowedAlgs) == 0 {\n\t\topts.AllowedAlgs = []string{opts.Algorithm}\n\t}\n\n\t// Validate required configuration based on algorithm\n\tif err := validateAlgorithmConfig(opts); err != nil {\n\t\treturn nil, err\n\t}\n\n\treturn &validator{opts: opts}, nil\n}\n\n// ValidateToken validates a JWT token string and returns the parsed claims\nfunc (v *validator) ValidateToken(tokenString string) (*Claims, error) {\n\tif tokenString == \"\" {\n\t\treturn nil, ErrMissingToken\n\t}\n\n\t// Parse the token with clock skew as leeway for time-based validations\n\ttoken, err := jwt.Parse(tokenString, v.keyFunc,\n\t\tjwt.WithValidMethods(v.opts.AllowedAlgs),\n\t\tjwt.WithLeeway(v.opts.ClockSkew),\n\t)\n\tif err != nil {\n\t\treturn nil, v.mapError(err)\n\t}\n\n\tif !token.Valid {\n\t\treturn nil, ErrInvalidSignature\n\t}\n\n\t// Extract and validate claims\n\tclaims, err := v.extractClaims(token)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\t// Validate custom claims\n\tif err := v.validateCustomClaims(claims); err != nil {\n\t\treturn nil, err\n\t}\n\n\treturn claims, nil\n}\n\n// keyFunc returns the appropriate key for the given token\nfunc (v *validator) keyFunc(token *jwt.Token) (interface{}, error) {\n\talg, ok := token.Header[\"alg\"].(string)\n\tif !ok {\n\t\treturn nil, ErrUnsupportedAlgorithm\n\t}\n\n\t// Check if algorithm is allowed\n\tif !v.isAlgorithmAllowed(alg) {\n\t\treturn nil, ErrUnsupportedAlgorithm\n\t}\n\n\tswitch alg {\n\tcase \"HS256\":\n\t\tif len(v.opts.Secret) == 0 {\n\t\t\treturn nil, fmt.Errorf(\"%w: HMAC secret not configured\", ErrInvalidConfiguration)\n\t\t}\n\t\treturn v.opts.Secret, nil\n\tcase \"RS256\":\n\t\tif v.opts.PublicKey == nil {\n\t\t\treturn nil, fmt.Errorf(\"%w: RSA public key not configured\", ErrInvalidConfiguration)\n\t\t}\n\t\treturn v.opts.PublicKey, nil\n\tdefault:\n\t\treturn nil, ErrUnsupportedAlgorithm\n\t}\n}\n\n// isAlgorithmAllowed checks if the algorithm is in the allowed list\nfunc (v *validator) isAlgorithmAllowed(alg string) bool {\n\tfor _, allowed := range v.opts.AllowedAlgs {\n\t\tif allowed == alg {\n\t\t\treturn true\n\t\t}\n\t}\n\treturn false\n}\n\n// extractClaims extracts Claims from a parsed JWT token\nfunc (v *validator) extractClaims(token *jwt.Token) (*Claims, error) {\n\tmapClaims, ok := token.Claims.(jwt.MapClaims)\n\tif !ok {\n\t\treturn nil, ErrMissingClaims\n\t}\n\n\tclaims := &Claims{}\n\n\t// Extract subject\n\tif sub, ok := mapClaims[\"sub\"].(string); ok {\n\t\tclaims.Subject = sub\n\t}\n\n\t// Extract issuer\n\tif iss, ok := mapClaims[\"iss\"].(string); ok {\n\t\tclaims.Issuer = iss\n\t}\n\n\t// Extract audience (can be string or []string)\n\tif aud, ok := mapClaims[\"aud\"]; ok {\n\t\tswitch a := aud.(type) {\n\t\tcase string:\n\t\t\tclaims.Audience = []string{a}\n\t\tcase []string:\n\t\t\tclaims.Audience = a\n\t\tcase []interface{}:\n\t\t\tfor _, item := range a {\n\t\t\t\tif s, ok := item.(string); ok {\n\t\t\t\t\tclaims.Audience = append(claims.Audience, s)\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\t// Extract expiration time\n\tif exp, err := mapClaims.GetExpirationTime(); err == nil && exp != nil {\n\t\tclaims.ExpiresAt = exp.Time\n\t}\n\n\t// Extract not before time\n\tif nbf, err := mapClaims.GetNotBefore(); err == nil && nbf != nil {\n\t\tclaims.NotBefore = &nbf.Time\n\t}\n\n\t// Extract issued at time\n\tif iat, err := mapClaims.GetIssuedAt(); err == nil && iat != nil {\n\t\tclaims.IssuedAt = iat.Time\n\t}\n\n\t// Extract JWT ID\n\tif jti, ok := mapClaims[\"jti\"].(string); ok {\n\t\tclaims.JWTID = jti\n\t}\n\n\treturn claims, nil\n}\n\n// validateCustomClaims performs custom claim validations\nfunc (v *validator) validateCustomClaims(claims *Claims) error {\n\t// Validate expiration with clock skew\n\tif v.opts.RequireExpiration && claims.ExpiresAt.IsZero() {\n\t\treturn ErrMissingClaims\n\t}\n\n\tif !claims.ExpiresAt.IsZero() && claims.IsExpired(v.opts.ClockSkew) {\n\t\treturn ErrTokenExpired\n\t}\n\n\t// Validate not before with clock skew\n\tif claims.IsNotYetValid(v.opts.ClockSkew) {\n\t\treturn ErrTokenNotYetValid\n\t}\n\n\t// Validate issuer\n\tif v.opts.ExpectedIssuer != \"\" && claims.Issuer != v.opts.ExpectedIssuer {\n\t\treturn ErrInvalidIssuer\n\t}\n\n\t// Validate audience if specified\n\tif v.opts.ExpectedAudience != \"\" {\n\t\tfound := false\n\t\tfor _, aud := range claims.Audience {\n\t\t\tif aud == v.opts.ExpectedAudience {\n\t\t\t\tfound = true\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\t\tif !found {\n\t\t\treturn ErrInvalidIssuer\n\t\t}\n\t}\n\n\treturn nil\n}\n\n// mapError maps JWT library errors to our error types\nfunc (v *validator) mapError(err error) error {\n\tif err == nil {\n\t\treturn nil\n\t}\n\n\t// In jwt/v5, validation errors are returned as standard errors\n\t// We need to check error messages to determine the type\n\terrStr := err.Error()\n\n\tswitch {\n\t// Check for unsupported algorithm (must be before signature check\n\t// because jwt/v5 wraps algorithm errors as signature errors)\n\tcase contains(errStr, \"unsupported algorithm\"):\n\t\treturn ErrUnsupportedAlgorithm\n\n\t// Check for expired token\n\tcase contains(errStr, \"token is expired\") ||\n\t\tcontains(errStr, \"token has invalid claims: token is expired\"):\n\t\treturn ErrTokenExpired\n\n\t// Check for not yet valid token\n\tcase contains(errStr, \"token is not valid yet\") ||\n\t\tcontains(errStr, \"token has invalid claims: token is not valid yet\"):\n\t\treturn ErrTokenNotYetValid\n\n\t// Check for invalid signature\n\tcase contains(errStr, \"signature is invalid\") ||\n\t\tcontains(errStr, \"token signature invalid\"):\n\t\treturn ErrInvalidSignature\n\n\t// Check for malformed token\n\tcase contains(errStr, \"token is malformed\") ||\n\t\tcontains(errStr, \"token contains an invalid number of segments\") ||\n\t\tcontains(errStr, \"invalid character\") ||\n\t\tcontains(errStr, \"illegal base64\"):\n\t\treturn ErrInvalidTokenFormat\n\n\t// Check for unsupported algorithm via signing method message\n\tcase contains(errStr, \"signing method\") && contains(errStr, \"is invalid\"):\n\t\treturn ErrUnsupportedAlgorithm\n\t}\n\n\treturn err\n}\n\n// contains checks if a string contains a substring\nfunc contains(s, substr string) bool {\n\treturn len(s) >= len(substr) && (s == substr ||\n\t\t(len(s) > len(substr) &&\n\t\t\t(findSubstring(s, substr) >= 0)))\n}\n\n// findSubstring finds the substring position\nfunc findSubstring(s, substr string) int {\n\tfor i := 0; i <= len(s)-len(substr); i++ {\n\t\tif s[i:i+len(substr)] == substr {\n\t\t\treturn i\n\t\t}\n\t}\n\treturn -1\n}\n\n// isValidAlgorithm checks if the algorithm is supported\nfunc isValidAlgorithm(alg string) bool {\n\tswitch alg {\n\tcase \"HS256\", \"RS256\":\n\t\treturn true\n\tdefault:\n\t\treturn false\n\t}\n}\n\n// validateAlgorithmConfig validates configuration based on algorithm\nfunc validateAlgorithmConfig(opts ValidationOptions) error {\n\tswitch opts.Algorithm {\n\tcase \"HS256\":\n\t\tif len(opts.Secret) == 0 {\n\t\t\treturn fmt.Errorf(\"%w: HMAC secret required for HS256\", ErrInvalidConfiguration)\n\t\t}\n\tcase \"RS256\":\n\t\tif opts.PublicKey == nil {\n\t\t\treturn fmt.Errorf(\"%w: RSA public key required for RS256\", ErrInvalidConfiguration)\n\t\t}\n\t}\n\treturn nil\n}\n\n// ensureRSAPublicKey ensures the key is an RSA public key\nfunc ensureRSAPublicKey(key interface{}) (*rsa.PublicKey, error) {\n\tswitch k := key.(type) {\n\tcase *rsa.PublicKey:\n\t\treturn k, nil\n\tdefault:\n\t\treturn nil, fmt.Errorf(\"%w: expected RSA public key\", ErrInvalidConfiguration)\n\t}\n}\n\n// getSigningMethod returns the jwt.SigningMethod for the algorithm\nfunc getSigningMethod(alg string) jwt.SigningMethod {\n\tswitch alg {\n\tcase \"HS256\":\n\t\treturn jwt.SigningMethodHS256\n\tcase \"RS256\":\n\t\treturn jwt.SigningMethodRS256\n\tdefault:\n\t\treturn nil\n\t}\n}\n\n// now is a variable to allow mocking in tests\nvar now = time.Now\n\n// setNow sets the time function for testing\nfunc setNow(fn func() time.Time) {\n\tnow = fn\n}\n","after":"/*\nCopyright 2026 The Volcano Authors.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\npackage jwt\n\nimport (\n\t\"crypto/rsa\"\n\t\"fmt\"\n\t\"time\"\n\n\t\"github.com/golang-jwt/jwt/v5\"\n)\n\n// validator implements the JWTValidator interface\ntype validator struct {\n\topts ValidationOptions\n}\n\n// NewValidator creates a new JWTValidator with the given options\nfunc NewValidator(opts ValidationOptions) (JWTValidator, error) {\n\t// Set default clock skew if not specified\n\tif opts.ClockSkew == 0 {\n\t\topts.ClockSkew = defaultClockSkew\n\t}\n\n\t// Set default algorithm if not specified\n\tif opts.Algorithm == \"\" {\n\t\topts.Algorithm = \"RS256\"\n\t}\n\n\t// Validate algorithm\n\tif !isValidAlgorithm(opts.Algorithm) {\n\t\treturn nil, fmt.Errorf(\"%w: invalid algorithm %q\", ErrInvalidConfiguration, opts.Algorithm)\n\t}\n\n\t// Set allowed algorithms if not specified\n\tif len(opts.AllowedAlgs) == 0 {\n\t\topts.AllowedAlgs = []string{opts.Algorithm}\n\t}\n\n\t// Validate required configuration based on algorithm\n\tif err := validateAlgorithmConfig(opts); err != nil {\n\t\treturn nil, err\n\t}\n\n\treturn &validator{opts: opts}, nil\n}\n\n// ValidateToken validates a JWT token string and returns the parsed claims\nfunc (v *validator) ValidateToken(tokenString string) (*Claims, error) {\n\tif tokenString == \"\" {\n\t\treturn nil, ErrMissingToken\n\t}\n\n\t// Parse the token with clock skew as leeway for time-based validations\n\ttoken, err := jwt.Parse(tokenString, v.keyFunc,\n\t\tjwt.WithValidMethods(v.opts.AllowedAlgs),\n\t\tjwt.WithLeeway(v.opts.ClockSkew),\n\t)\n\tif err != nil {\n\t\treturn nil, v.mapError(err)\n\t}\n\n\tif !token.Valid {\n\t\treturn nil, ErrInvalidSignature\n\t}\n\n\t// Extract and validate claims\n\tclaims, err := v.extractClaims(token)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\t// Validate custom claims\n\tif err := v.validateCustomClaims(claims); err != nil {\n\t\treturn nil, err\n\t}\n\n\treturn claims, nil\n}\n\n// keyFunc returns the appropriate key for the given token\nfunc (v *validator) keyFunc(token *jwt.Token) (interface{}, error) {\n\talg, ok := token.Header[\"alg\"].(string)\n\tif !ok {\n\t\treturn nil, ErrUnsupportedAlgorithm\n\t}\n\n\t// Check if algorithm is allowed\n\tif !v.isAlgorithmAllowed(alg) {\n\t\treturn nil, ErrUnsupportedAlgorithm\n\t}\n\n\tswitch alg {\n\tcase \"HS256\":\n\t\tif len(v.opts.Secret) == 0 {\n\t\t\treturn nil, fmt.Errorf(\"%w: HMAC secret not configured\", ErrInvalidConfiguration)\n\t\t}\n\t\treturn v.opts.Secret, nil\n\tcase \"RS256\":\n\t\tif v.opts.PublicKey == nil {\n\t\t\treturn nil, fmt.Errorf(\"%w: RSA public key not configured\", ErrInvalidConfiguration)\n\t\t}\n\t\treturn v.opts.PublicKey, nil\n\tdefault:\n\t\treturn nil, ErrUnsupportedAlgorithm\n\t}\n}\n\n// isAlgorithmAllowed checks if the algorithm is in the allowed list\nfunc (v *validator) isAlgorithmAllowed(alg string) bool {\n\tfor _, allowed := range v.opts.AllowedAlgs {\n\t\tif allowed == alg {\n\t\t\treturn true\n\t\t}\n\t}\n\treturn false\n}\n\n// extractClaims extracts Claims from a parsed JWT token\nfunc (v *validator) extractClaims(token *jwt.Token) (*Claims, error) {\n\tmapClaims, ok := token.Claims.(jwt.MapClaims)\n\tif !ok {\n\t\treturn nil, ErrMissingClaims\n\t}\n\n\tclaims := &Claims{}\n\n\t// Extract subject\n\tif sub, ok := mapClaims[\"sub\"].(string); ok {\n\t\tclaims.Subject = sub\n\t}\n\n\t// Extract issuer\n\tif iss, ok := mapClaims[\"iss\"].(string); ok {\n\t\tclaims.Issuer = iss\n\t}\n\n\t// Extract audience (can be string or []string)\n\tif aud, ok := mapClaims[\"aud\"]; ok {\n\t\tswitch a := aud.(type) {\n\t\tcase string:\n\t\t\tclaims.Audience = []string{a}\n\t\tcase []string:\n\t\t\tclaims.Audience = a\n\t\tcase []interface{}:\n\t\t\tfor _, item := range a {\n\t\t\t\tif s, ok := item.(string); ok {\n\t\t\t\t\tclaims.Audience = append(claims.Audience, s)\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\t// Extract expiration time\n\tif exp, err := mapClaims.GetExpirationTime(); err == nil && exp != nil {\n\t\tclaims.ExpiresAt = exp.Time\n\t}\n\n\t// Extract not before time\n\tif nbf, err := mapClaims.GetNotBefore(); err == nil && nbf != nil {\n\t\tclaims.NotBefore = &nbf.Time\n\t}\n\n\t// Extract issued at time\n\tif iat, err := mapClaims.GetIssuedAt(); err == nil && iat != nil {\n\t\tclaims.IssuedAt = iat.Time\n\t}\n\n\t// Extract JWT ID\n\tif jti, ok := mapClaims[\"jti\"].(string); ok {\n\t\tclaims.JWTID = jti\n\t}\n\n\treturn claims, nil\n}\n\n// validateCustomClaims performs custom claim validations\nfunc (v *validator) validateCustomClaims(claims *Claims) error {\n\t// Validate expiration with clock skew\n\tif v.opts.RequireExpiration && claims.ExpiresAt.IsZero() {\n\t\treturn ErrMissingClaims\n\t}\n\n\tif !claims.ExpiresAt.IsZero() && claims.IsExpired(v.opts.ClockSkew) {\n\t\treturn ErrTokenExpired\n\t}\n\n\t// Validate not before with clock skew\n\tif claims.IsNotYetValid(v.opts.ClockSkew) {\n\t\treturn ErrTokenNotYetValid\n\t}\n\n\t// Validate issuer\n\tif v.opts.ExpectedIssuer != \"\" && claims.Issuer != v.opts.ExpectedIssuer {\n\t\treturn ErrInvalidIssuer\n\t}\n\n\t// Validate audience if specified\n\tif v.opts.ExpectedAudience != \"\" {\n\t\tfound := false\n\t\tfor _, aud := range claims.Audience {\n\t\t\tif aud == v.opts.ExpectedAudience {\n\t\t\t\tfound = true\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\t\tif !found {\n\t\t\treturn ErrInvalidIssuer\n\t\t}\n\t}\n\n\treturn nil\n}\n\n// mapError maps JWT library errors to our error types\nfunc (v *validator) mapError(err error) error {\n\tif err == nil {\n\t\treturn nil\n\t}\n\n\t// In jwt/v5, validation errors are returned as standard errors\n\t// We need to check error messages to determine the type\n\terrStr := err.Error()\n\n\tswitch {\n\t// Check for expired token\n\tcase contains(errStr, \"token is expired\") ||\n\t\tcontains(errStr, \"token has invalid claims: token is expired\"):\n\t\treturn ErrTokenExpired\n\n\t// Check for not yet valid token\n\tcase contains(errStr, \"token is not valid yet\") ||\n\t\tcontains(errStr, \"token has invalid claims: token is not valid yet\"):\n\t\treturn ErrTokenNotYetValid\n\n\t// Check for unsupported algorithm (must be before signature check\n\t// because jwt/v5 includes \"signature is invalid\" in the error message)\n\tcase contains(errStr, \"signing method\") && contains(errStr, \"is invalid\"):\n\t\treturn ErrUnsupportedAlgorithm\n\n\t// Check for invalid signature\n\tcase contains(errStr, \"signature is invalid\") ||\n\t\tcontains(errStr, \"token signature invalid\"):\n\t\treturn ErrInvalidSignature\n\n\t// Check for malformed token\n\tcase contains(errStr, \"token is malformed\") ||\n\t\tcontains(errStr, \"token contains an invalid number of segments\") ||\n\t\tcontains(errStr, \"invalid character\") ||\n\t\tcontains(errStr, \"illegal base64\"):\n\t\treturn ErrInvalidTokenFormat\n\t}\n\n\treturn err\n}\n\n// contains checks if a string contains a substring\nfunc contains(s, substr string) bool {\n\treturn len(s) >= len(substr) && (s == substr ||\n\t\t(len(s) > len(substr) &&\n\t\t\t(findSubstring(s, substr) >= 0)))\n}\n\n// findSubstring finds the substring position\nfunc findSubstring(s, substr string) int {\n\tfor i := 0; i <= len(s)-len(substr); i++ {\n\t\tif s[i:i+len(substr)] == substr {\n\t\t\treturn i\n\t\t}\n\t}\n\treturn -1\n}\n\n// isValidAlgorithm checks if the algorithm is supported\nfunc isValidAlgorithm(alg string) bool {\n\tswitch alg {\n\tcase \"HS256\", \"RS256\":\n\t\treturn true\n\tdefault:\n\t\treturn false\n\t}\n}\n\n// validateAlgorithmConfig validates configuration based on algorithm\nfunc validateAlgorithmConfig(opts ValidationOptions) error {\n\tswitch opts.Algorithm {\n\tcase \"HS256\":\n\t\tif len(opts.Secret) == 0 {\n\t\t\treturn fmt.Errorf(\"%w: HMAC secret required for HS256\", ErrInvalidConfiguration)\n\t\t}\n\tcase \"RS256\":\n\t\tif opts.PublicKey == nil {\n\t\t\treturn fmt.Errorf(\"%w: RSA public key required for RS256\", ErrInvalidConfiguration)\n\t\t}\n\t}\n\treturn nil\n}\n\n// ensureRSAPublicKey ensures the key is an RSA public key\nfunc ensureRSAPublicKey(key interface{}) (*rsa.PublicKey, error) {\n\tswitch k := key.(type) {\n\tcase *rsa.PublicKey:\n\t\treturn k, nil\n\tdefault:\n\t\treturn nil, fmt.Errorf(\"%w: expected RSA public key\", ErrInvalidConfiguration)\n\t}\n}\n\n// getSigningMethod returns the jwt.SigningMethod for the algorithm\nfunc getSigningMethod(alg string) jwt.SigningMethod {\n\tswitch alg {\n\tcase \"HS256\":\n\t\treturn jwt.SigningMethodHS256\n\tcase \"RS256\":\n\t\treturn jwt.SigningMethodRS256\n\tdefault:\n\t\treturn nil\n\t}\n}\n\n// now is a variable to allow mocking in tests\nvar now = time.Now\n\n// setNow sets the time function for testing\nfunc setNow(fn func() time.Time) {\n\tnow = fn\n}\n","additions":5,"deletions":9},"truncated":false},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/picod/jwt/validator.go","time":{"start":1775879242441,"end":1775879242633}}}}
