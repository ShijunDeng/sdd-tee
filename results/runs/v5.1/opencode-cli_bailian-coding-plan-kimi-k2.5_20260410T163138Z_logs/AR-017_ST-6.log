{"type":"tool_use","timestamp":1775878954443,"sessionID":"ses_2855e09b0ffeOwnQksGdceY7xM","part":{"id":"prt_d7aa2394b0010GWPHZVspgnl36","messageID":"msg_d7aa22668001gv27Cf4rbE5U1r","sessionID":"ses_2855e09b0ffeOwnQksGdceY7xM","type":"tool","tool":"read","callID":"toolu_functions.read:5","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/picod/jwt/middleware.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/picod/jwt/middleware.go</path>\n<type>file</type>\n<content>\n1: /*\n2: Copyright 2026 The Volcano Authors.\n3: \n4: Licensed under the Apache License, Version 2.0 (the \"License\");\n5: you may not use this file except in compliance with the License.\n6: You may obtain a copy of the License at\n7: \n8:     http://www.apache.org/licenses/LICENSE-2.0\n9: \n10: Unless required by applicable law or agreed to in writing, software\n11: distributed under the License is distributed on an \"AS IS\" BASIS,\n12: WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n13: See the License for the specific language governing permissions and\n14: limitations under the License.\n15: */\n16: \n17: package jwt\n18: \n19: import (\n20: \t\"encoding/json\"\n21: \t\"net/http\"\n22: \t\"strings\"\n23: )\n24: \n25: // JWTMiddleware creates an HTTP middleware for JWT validation\n26: // It wraps the provided handler with JWT token validation\n27: func JWTMiddleware(opts MiddlewareOptions) func(http.Handler) http.Handler {\n28: \treturn func(next http.Handler) http.Handler {\n29: \t\treturn http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n30: \t\t\t// Check if validation should be skipped\n31: \t\t\tif opts.SkipValidation != nil && opts.SkipValidation(r) {\n32: \t\t\t\tnext.ServeHTTP(w, r)\n33: \t\t\t\treturn\n34: \t\t\t}\n35: \n36: \t\t\t// Extract token from Authorization header\n37: \t\t\ttoken, err := extractBearerToken(r)\n38: \t\t\tif err != nil {\n39: \t\t\t\thandleError(w, r, err, opts.ErrorHandler)\n40: \t\t\t\treturn\n41: \t\t\t}\n42: \n43: \t\t\t// Validate the token\n44: \t\t\tclaims, err := opts.Validator.ValidateToken(token)\n45: \t\t\tif err != nil {\n46: \t\t\t\thandleError(w, r, err, opts.ErrorHandler)\n47: \t\t\t\treturn\n48: \t\t\t}\n49: \n50: \t\t\t// Add claims to request context\n51: \t\t\tctx := WithClaims(r.Context(), claims)\n52: \n53: \t\t\t// Call the next handler\n54: \t\t\tnext.ServeHTTP(w, r.WithContext(ctx))\n55: \t\t})\n56: \t}\n57: }\n58: \n59: // extractBearerToken extracts the bearer token from the Authorization header\n60: func extractBearerToken(r *http.Request) (string, error) {\n61: \tauthHeader := r.Header.Get(authorizationHeader)\n62: \tif authHeader == \"\" {\n63: \t\treturn \"\", ErrMissingToken\n64: \t}\n65: \n66: \t// Check for Bearer prefix\n67: \tif !strings.HasPrefix(authHeader, bearerPrefix) {\n68: \t\treturn \"\", ErrInvalidTokenFormat\n69: \t}\n70: \n71: \t// Extract the token\n72: \ttoken := strings.TrimPrefix(authHeader, bearerPrefix)\n73: \ttoken = strings.TrimSpace(token)\n74: \n75: \tif token == \"\" {\n76: \t\treturn \"\", ErrInvalidTokenFormat\n77: \t}\n78: \n79: \treturn token, nil\n80: }\n81: \n82: // handleError handles authentication errors\n83: func handleError(w http.ResponseWriter, r *http.Request, err error, customHandler func(http.ResponseWriter, error)) {\n84: \t// Use custom error handler if provided\n85: \tif customHandler != nil {\n86: \t\tcustomHandler(w, err)\n87: \t\treturn\n88: \t}\n89: \n90: \t// Default error handling\n91: \tstatus, response := buildErrorResponse(err)\n92: \n93: \tw.Header().Set(\"Content-Type\", \"application/json\")\n94: \tw.WriteHeader(status)\n95: \tjson.NewEncoder(w).Encode(response)\n96: }\n97: \n98: // buildErrorResponse builds an error response based on the error type\n99: func buildErrorResponse(err error) (int, ErrorResponse) {\n100: \tswitch err {\n101: \tcase ErrMissingToken:\n102: \t\treturn http.StatusUnauthorized, ErrorResponse{\n103: \t\t\tError:   \"unauthorized\",\n104: \t\t\tMessage: \"missing bearer token\",\n105: \t\t}\n106: \tcase ErrInvalidTokenFormat:\n107: \t\treturn http.StatusUnauthorized, ErrorResponse{\n108: \t\t\tError:   \"unauthorized\",\n109: \t\t\tMessage: \"invalid token format\",\n110: \t\t}\n111: \tcase ErrInvalidSignature:\n112: \t\treturn http.StatusUnauthorized, ErrorResponse{\n113: \t\t\tError:   \"unauthorized\",\n114: \t\t\tMessage: \"invalid token signature\",\n115: \t\t}\n116: \tcase ErrTokenExpired:\n117: \t\treturn http.StatusUnauthorized, ErrorResponse{\n118: \t\t\tError:   \"unauthorized\",\n119: \t\t\tMessage: \"token expired\",\n120: \t\t}\n121: \tcase ErrTokenNotYetValid:\n122: \t\treturn http.StatusUnauthorized, ErrorResponse{\n123: \t\t\tError:   \"unauthorized\",\n124: \t\t\tMessage: \"token not yet valid\",\n125: \t\t}\n126: \tcase ErrInvalidIssuer:\n127: \t\treturn http.StatusForbidden, ErrorResponse{\n128: \t\t\tError:   \"forbidden\",\n129: \t\t\tMessage: \"invalid issuer\",\n130: \t\t}\n131: \tcase ErrUnsupportedAlgorithm:\n132: \t\treturn http.StatusUnauthorized, ErrorResponse{\n133: \t\t\tError:   \"unauthorized\",\n134: \t\t\tMessage: \"unsupported signing algorithm\",\n135: \t\t}\n136: \tdefault:\n137: \t\treturn http.StatusUnauthorized, ErrorResponse{\n138: \t\t\tError:   \"unauthorized\",\n139: \t\t\tMessage: \"authentication failed\",\n140: \t\t}\n141: \t}\n142: }\n143: \n144: // ErrorResponse represents an authentication error response\n145: type ErrorResponse struct {\n146: \tError   string `json:\"error\"`\n147: \tMessage string `json:\"message\"`\n148: }\n149: \n150: // OptionalMiddleware creates a middleware that only validates when a token is present\n151: // If no token is provided, the request proceeds without authentication\n152: func OptionalMiddleware(opts MiddlewareOptions) func(http.Handler) http.Handler {\n153: \treturn func(next http.Handler) http.Handler {\n154: \t\treturn http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n155: \t\t\t// Check if validation should be skipped\n156: \t\t\tif opts.SkipValidation != nil && opts.SkipValidation(r) {\n157: \t\t\t\tnext.ServeHTTP(w, r)\n158: \t\t\t\treturn\n159: \t\t\t}\n160: \n161: \t\t\t// Extract token from Authorization header\n162: \t\t\ttoken, err := extractBearerToken(r)\n163: \t\t\tif err != nil {\n164: \t\t\t\t// No token - proceed without authentication\n165: \t\t\t\tif err == ErrMissingToken {\n166: \t\t\t\t\tnext.ServeHTTP(w, r)\n167: \t\t\t\t\treturn\n168: \t\t\t\t}\n169: \t\t\t\t// Invalid format - return error\n170: \t\t\t\thandleError(w, r, err, opts.ErrorHandler)\n171: \t\t\t\treturn\n172: \t\t\t}\n173: \n174: \t\t\t// Validate the token\n175: \t\t\tclaims, err := opts.Validator.ValidateToken(token)\n176: \t\t\tif err != nil {\n177: \t\t\t\thandleError(w, r, err, opts.ErrorHandler)\n178: \t\t\t\treturn\n179: \t\t\t}\n180: \n181: \t\t\t// Add claims to request context\n182: \t\t\tctx := WithClaims(r.Context(), claims)\n183: \n184: \t\t\t// Call the next handler\n185: \t\t\tnext.ServeHTTP(w, r.WithContext(ctx))\n186: \t\t})\n187: \t}\n188: }\n\n(End of file - total 188 lines)\n</content>","metadata":{"preview":"/*\nCopyright 2026 The Volcano Authors.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\npackage jwt\n\nimport (\n\t\"encoding/json\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/picod/jwt/middleware.go","time":{"start":1775878954385,"end":1775878954441}}}}
{"type":"tool_use","timestamp":1775878954445,"sessionID":"ses_2855e09b0ffeOwnQksGdceY7xM","part":{"id":"prt_d7aa24576001m9aB1CDWHqTtF3","messageID":"msg_d7aa22668001gv27Cf4rbE5U1r","sessionID":"ses_2855e09b0ffeOwnQksGdceY7xM","type":"tool","tool":"read","callID":"toolu_functions.read:7","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/picod/jwt/types.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/picod/jwt/types.go</path>\n<type>file</type>\n<content>\n1: /*\n2: Copyright 2026 The Volcano Authors.\n3: \n4: Licensed under the Apache License, Version 2.0 (the \"License\");\n5: you may not use this file except in compliance with the License.\n6: You may obtain a copy of the License at\n7: \n8:     http://www.apache.org/licenses/LICENSE-2.0\n9: \n10: Unless required by applicable law or agreed to in writing, software\n11: distributed under the License is distributed on an \"AS IS\" BASIS,\n12: WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n13: See the License for the specific language governing permissions and\n14: limitations under the License.\n15: */\n16: \n17: package jwt\n18: \n19: import (\n20: \t\"context\"\n21: \t\"crypto/rsa\"\n22: \t\"net/http\"\n23: \t\"time\"\n24: )\n25: \n26: // contextKey is a custom type for context keys to avoid collisions\n27: type contextKey string\n28: \n29: const (\n30: \t// claimsContextKey is the key used to store claims in the request context\n31: \tclaimsContextKey contextKey = \"jwt.claims\"\n32: \n33: \t// defaultClockSkew is the default clock skew tolerance\n34: \tdefaultClockSkew = 1 * time.Minute\n35: \n36: \t// authorizationHeader is the HTTP header name for authorization\n37: \tauthorizationHeader = \"Authorization\"\n38: \n39: \t// bearerPrefix is the prefix for bearer tokens\n40: \tbearerPrefix = \"Bearer \"\n41: )\n42: \n43: // JWTValidator validates JWT tokens\n44: type JWTValidator interface {\n45: \t// ValidateToken validates a JWT string and returns the parsed claims\n46: \tValidateToken(token string) (*Claims, error)\n47: }\n48: \n49: // Claims represents validated JWT claims\n50: type Claims struct {\n51: \t// Subject identifies the principal that is the subject of the JWT\n52: \tSubject string `json:\"sub\"`\n53: \n54: \t// Issuer identifies the principal that issued the JWT\n55: \tIssuer string `json:\"iss\"`\n56: \n57: \t// Audience identifies the recipients that the JWT is intended for\n58: \tAudience []string `json:\"aud,omitempty\"`\n59: \n60: \t// ExpiresAt identifies the expiration time on or after which the JWT must not be accepted\n61: \tExpiresAt time.Time `json:\"exp\"`\n62: \n63: \t// NotBefore identifies the time before which the JWT must not be accepted\n64: \tNotBefore *time.Time `json:\"nbf,omitempty\"`\n65: \n66: \t// IssuedAt identifies the time at which the JWT was issued\n67: \tIssuedAt time.Time `json:\"iat\"`\n68: \n69: \t// JWTID provides a unique identifier for the JWT\n70: \tJWTID string `json:\"jti,omitempty\"`\n71: }\n72: \n73: // IsExpired checks if the token is expired considering clock skew\n74: func (c *Claims) IsExpired(clockSkew time.Duration) bool {\n75: \tif c.ExpiresAt.IsZero() {\n76: \t\treturn false\n77: \t}\n78: \treturn time.Now().After(c.ExpiresAt.Add(clockSkew))\n79: }\n80: \n81: // IsNotYetValid checks if the token is not yet valid considering clock skew\n82: func (c *Claims) IsNotYetValid(clockSkew time.Duration) bool {\n83: \tif c.NotBefore == nil || c.NotBefore.IsZero() {\n84: \t\treturn false\n85: \t}\n86: \treturn time.Now().Before(c.NotBefore.Add(-clockSkew))\n87: }\n88: \n89: // ValidationOptions configures the validator\n90: type ValidationOptions struct {\n91: \t// Algorithm is the expected signing algorithm (e.g., \"HS256\", \"RS256\")\n92: \tAlgorithm string\n93: \n94: \t// Secret is the HMAC secret for HS256 algorithm\n95: \tSecret []byte\n96: \n97: \t// PublicKey is the RSA public key for RS256 algorithm\n98: \tPublicKey *rsa.PublicKey\n99: \n100: \t// ExpectedIssuer is the expected issuer claim value\n101: \tExpectedIssuer string\n102: \n103: \t// ExpectedAudience is the expected audience claim value (optional)\n104: \tExpectedAudience string\n105: \n106: \t// ClockSkew is the allowed clock skew for time-based validations\n107: \tClockSkew time.Duration\n108: \n109: \t// AllowedAlgs is the list of allowed signing algorithms\n110: \t// If empty, defaults to Algorithm\n111: \tAllowedAlgs []string\n112: \n113: \t// RequireExpiration requires the exp claim to be present\n114: \tRequireExpiration bool\n115: }\n116: \n117: // MiddlewareOptions configures the middleware behavior\n118: type MiddlewareOptions struct {\n119: \t// Validator is the JWT validator to use\n120: \tValidator JWTValidator\n121: \n122: \t// ErrorHandler is an optional custom error handler\n123: \t// If nil, a default error handler is used\n124: \tErrorHandler func(http.ResponseWriter, error)\n125: \n126: \t// SkipValidation is an optional function to skip validation for certain requests\n127: \t// If it returns true, validation is skipped\n128: \tSkipValidation func(*http.Request) bool\n129: }\n130: \n131: // GetClaims retrieves validated claims from the context\n132: // Returns the claims and true if found, nil and false otherwise\n133: func GetClaims(ctx context.Context) (*Claims, bool) {\n134: \tclaims, ok := ctx.Value(claimsContextKey).(*Claims)\n135: \treturn claims, ok\n136: }\n137: \n138: // WithClaims adds claims to the context\n139: func WithClaims(ctx context.Context, claims *Claims) context.Context {\n140: \treturn context.WithValue(ctx, claimsContextKey, claims)\n141: }\n\n(End of file - total 141 lines)\n</content>","metadata":{"preview":"/*\nCopyright 2026 The Volcano Authors.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\npackage jwt\n\nimport (\n\t\"context\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/picod/jwt/types.go","time":{"start":1775878954396,"end":1775878954443}}}}
{"type":"tool_use","timestamp":1775878954446,"sessionID":"ses_2855e09b0ffeOwnQksGdceY7xM","part":{"id":"prt_d7aa23f5f001RcxHwwFnt3H4Lt","messageID":"msg_d7aa22668001gv27Cf4rbE5U1r","sessionID":"ses_2855e09b0ffeOwnQksGdceY7xM","type":"tool","tool":"read","callID":"toolu_functions.read:6","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/picod/jwt/validator.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/picod/jwt/validator.go</path>\n<type>file</type>\n<content>\n1: /*\n2: Copyright 2026 The Volcano Authors.\n3: \n4: Licensed under the Apache License, Version 2.0 (the \"License\");\n5: you may not use this file except in compliance with the License.\n6: You may obtain a copy of the License at\n7: \n8:     http://www.apache.org/licenses/LICENSE-2.0\n9: \n10: Unless required by applicable law or agreed to in writing, software\n11: distributed under the License is distributed on an \"AS IS\" BASIS,\n12: WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n13: See the License for the specific language governing permissions and\n14: limitations under the License.\n15: */\n16: \n17: package jwt\n18: \n19: import (\n20: \t\"crypto/rsa\"\n21: \t\"fmt\"\n22: \t\"time\"\n23: \n24: \t\"github.com/golang-jwt/jwt/v5\"\n25: )\n26: \n27: // validator implements the JWTValidator interface\n28: type validator struct {\n29: \topts ValidationOptions\n30: }\n31: \n32: // NewValidator creates a new JWTValidator with the given options\n33: func NewValidator(opts ValidationOptions) (JWTValidator, error) {\n34: \t// Set default clock skew if not specified\n35: \tif opts.ClockSkew == 0 {\n36: \t\topts.ClockSkew = defaultClockSkew\n37: \t}\n38: \n39: \t// Set default algorithm if not specified\n40: \tif opts.Algorithm == \"\" {\n41: \t\topts.Algorithm = \"RS256\"\n42: \t}\n43: \n44: \t// Validate algorithm\n45: \tif !isValidAlgorithm(opts.Algorithm) {\n46: \t\treturn nil, fmt.Errorf(\"%w: invalid algorithm %q\", ErrInvalidConfiguration, opts.Algorithm)\n47: \t}\n48: \n49: \t// Set allowed algorithms if not specified\n50: \tif len(opts.AllowedAlgs) == 0 {\n51: \t\topts.AllowedAlgs = []string{opts.Algorithm}\n52: \t}\n53: \n54: \t// Validate required configuration based on algorithm\n55: \tif err := validateAlgorithmConfig(opts); err != nil {\n56: \t\treturn nil, err\n57: \t}\n58: \n59: \treturn &validator{opts: opts}, nil\n60: }\n61: \n62: // ValidateToken validates a JWT token string and returns the parsed claims\n63: func (v *validator) ValidateToken(tokenString string) (*Claims, error) {\n64: \tif tokenString == \"\" {\n65: \t\treturn nil, ErrMissingToken\n66: \t}\n67: \n68: \t// Parse the token\n69: \ttoken, err := jwt.Parse(tokenString, v.keyFunc,\n70: \t\tjwt.WithValidMethods(v.opts.AllowedAlgs),\n71: \t)\n72: \tif err != nil {\n73: \t\treturn nil, v.mapError(err)\n74: \t}\n75: \n76: \tif !token.Valid {\n77: \t\treturn nil, ErrInvalidSignature\n78: \t}\n79: \n80: \t// Extract and validate claims\n81: \tclaims, err := v.extractClaims(token)\n82: \tif err != nil {\n83: \t\treturn nil, err\n84: \t}\n85: \n86: \t// Validate custom claims\n87: \tif err := v.validateCustomClaims(claims); err != nil {\n88: \t\treturn nil, err\n89: \t}\n90: \n91: \treturn claims, nil\n92: }\n93: \n94: // keyFunc returns the appropriate key for the given token\n95: func (v *validator) keyFunc(token *jwt.Token) (interface{}, error) {\n96: \talg, ok := token.Header[\"alg\"].(string)\n97: \tif !ok {\n98: \t\treturn nil, ErrUnsupportedAlgorithm\n99: \t}\n100: \n101: \t// Check if algorithm is allowed\n102: \tif !v.isAlgorithmAllowed(alg) {\n103: \t\treturn nil, ErrUnsupportedAlgorithm\n104: \t}\n105: \n106: \tswitch alg {\n107: \tcase \"HS256\":\n108: \t\tif len(v.opts.Secret) == 0 {\n109: \t\t\treturn nil, fmt.Errorf(\"%w: HMAC secret not configured\", ErrInvalidConfiguration)\n110: \t\t}\n111: \t\treturn v.opts.Secret, nil\n112: \tcase \"RS256\":\n113: \t\tif v.opts.PublicKey == nil {\n114: \t\t\treturn nil, fmt.Errorf(\"%w: RSA public key not configured\", ErrInvalidConfiguration)\n115: \t\t}\n116: \t\treturn v.opts.PublicKey, nil\n117: \tdefault:\n118: \t\treturn nil, ErrUnsupportedAlgorithm\n119: \t}\n120: }\n121: \n122: // isAlgorithmAllowed checks if the algorithm is in the allowed list\n123: func (v *validator) isAlgorithmAllowed(alg string) bool {\n124: \tfor _, allowed := range v.opts.AllowedAlgs {\n125: \t\tif allowed == alg {\n126: \t\t\treturn true\n127: \t\t}\n128: \t}\n129: \treturn false\n130: }\n131: \n132: // extractClaims extracts Claims from a parsed JWT token\n133: func (v *validator) extractClaims(token *jwt.Token) (*Claims, error) {\n134: \tmapClaims, ok := token.Claims.(jwt.MapClaims)\n135: \tif !ok {\n136: \t\treturn nil, ErrMissingClaims\n137: \t}\n138: \n139: \tclaims := &Claims{}\n140: \n141: \t// Extract subject\n142: \tif sub, ok := mapClaims[\"sub\"].(string); ok {\n143: \t\tclaims.Subject = sub\n144: \t}\n145: \n146: \t// Extract issuer\n147: \tif iss, ok := mapClaims[\"iss\"].(string); ok {\n148: \t\tclaims.Issuer = iss\n149: \t}\n150: \n151: \t// Extract audience (can be string or []string)\n152: \tif aud, ok := mapClaims[\"aud\"]; ok {\n153: \t\tswitch a := aud.(type) {\n154: \t\tcase string:\n155: \t\t\tclaims.Audience = []string{a}\n156: \t\tcase []string:\n157: \t\t\tclaims.Audience = a\n158: \t\tcase []interface{}:\n159: \t\t\tfor _, item := range a {\n160: \t\t\t\tif s, ok := item.(string); ok {\n161: \t\t\t\t\tclaims.Audience = append(claims.Audience, s)\n162: \t\t\t\t}\n163: \t\t\t}\n164: \t\t}\n165: \t}\n166: \n167: \t// Extract expiration time\n168: \tif exp, err := mapClaims.GetExpirationTime(); err == nil && exp != nil {\n169: \t\tclaims.ExpiresAt = exp.Time\n170: \t}\n171: \n172: \t// Extract not before time\n173: \tif nbf, err := mapClaims.GetNotBefore(); err == nil && nbf != nil {\n174: \t\tclaims.NotBefore = &nbf.Time\n175: \t}\n176: \n177: \t// Extract issued at time\n178: \tif iat, err := mapClaims.GetIssuedAt(); err == nil && iat != nil {\n179: \t\tclaims.IssuedAt = iat.Time\n180: \t}\n181: \n182: \t// Extract JWT ID\n183: \tif jti, ok := mapClaims[\"jti\"].(string); ok {\n184: \t\tclaims.JWTID = jti\n185: \t}\n186: \n187: \treturn claims, nil\n188: }\n189: \n190: // validateCustomClaims performs custom claim validations\n191: func (v *validator) validateCustomClaims(claims *Claims) error {\n192: \t// Validate expiration with clock skew\n193: \tif v.opts.RequireExpiration && claims.ExpiresAt.IsZero() {\n194: \t\treturn ErrMissingClaims\n195: \t}\n196: \n197: \tif !claims.ExpiresAt.IsZero() && claims.IsExpired(v.opts.ClockSkew) {\n198: \t\treturn ErrTokenExpired\n199: \t}\n200: \n201: \t// Validate not before with clock skew\n202: \tif claims.IsNotYetValid(v.opts.ClockSkew) {\n203: \t\treturn ErrTokenNotYetValid\n204: \t}\n205: \n206: \t// Validate issuer\n207: \tif v.opts.ExpectedIssuer != \"\" && claims.Issuer != v.opts.ExpectedIssuer {\n208: \t\treturn ErrInvalidIssuer\n209: \t}\n210: \n211: \t// Validate audience if specified\n212: \tif v.opts.ExpectedAudience != \"\" {\n213: \t\tfound := false\n214: \t\tfor _, aud := range claims.Audience {\n215: \t\t\tif aud == v.opts.ExpectedAudience {\n216: \t\t\t\tfound = true\n217: \t\t\t\tbreak\n218: \t\t\t}\n219: \t\t}\n220: \t\tif !found {\n221: \t\t\treturn ErrInvalidIssuer\n222: \t\t}\n223: \t}\n224: \n225: \treturn nil\n226: }\n227: \n228: // mapError maps JWT library errors to our error types\n229: func (v *validator) mapError(err error) error {\n230: \tif err == nil {\n231: \t\treturn nil\n232: \t}\n233: \n234: \t// In jwt/v5, validation errors are returned as standard errors\n235: \t// We need to check error messages to determine the type\n236: \terrStr := err.Error()\n237: \n238: \tswitch {\n239: \t// Check for expired token\n240: \tcase contains(errStr, \"token is expired\") ||\n241: \t\tcontains(errStr, \"token has invalid claims: token is expired\"):\n242: \t\treturn ErrTokenExpired\n243: \n244: \t// Check for not yet valid token\n245: \tcase contains(errStr, \"token is not valid yet\") ||\n246: \t\tcontains(errStr, \"token has invalid claims: token is not valid yet\"):\n247: \t\treturn ErrTokenNotYetValid\n248: \n249: \t// Check for invalid signature\n250: \tcase contains(errStr, \"signature is invalid\") ||\n251: \t\tcontains(errStr, \"token signature invalid\"):\n252: \t\treturn ErrInvalidSignature\n253: \n254: \t// Check for malformed token\n255: \tcase contains(errStr, \"token is malformed\") ||\n256: \t\tcontains(errStr, \"token contains an invalid number of segments\") ||\n257: \t\tcontains(errStr, \"invalid character\") ||\n258: \t\tcontains(errStr, \"illegal base64\"):\n259: \t\treturn ErrInvalidTokenFormat\n260: \n261: \t// Check for unsupported algorithm\n262: \tcase contains(errStr, \"signing method\") && contains(errStr, \"is invalid\"):\n263: \t\treturn ErrUnsupportedAlgorithm\n264: \t}\n265: \n266: \treturn err\n267: }\n268: \n269: // contains checks if a string contains a substring\n270: func contains(s, substr string) bool {\n271: \treturn len(s) >= len(substr) && (s == substr ||\n272: \t\t(len(s) > len(substr) &&\n273: \t\t\t(findSubstring(s, substr) >= 0)))\n274: }\n275: \n276: // findSubstring finds the substring position\n277: func findSubstring(s, substr string) int {\n278: \tfor i := 0; i <= len(s)-len(substr); i++ {\n279: \t\tif s[i:i+len(substr)] == substr {\n280: \t\t\treturn i\n281: \t\t}\n282: \t}\n283: \treturn -1\n284: }\n285: \n286: // isValidAlgorithm checks if the algorithm is supported\n287: func isValidAlgorithm(alg string) bool {\n288: \tswitch alg {\n289: \tcase \"HS256\", \"RS256\":\n290: \t\treturn true\n291: \tdefault:\n292: \t\treturn false\n293: \t}\n294: }\n295: \n296: // validateAlgorithmConfig validates configuration based on algorithm\n297: func validateAlgorithmConfig(opts ValidationOptions) error {\n298: \tswitch opts.Algorithm {\n299: \tcase \"HS256\":\n300: \t\tif len(opts.Secret) == 0 {\n301: \t\t\treturn fmt.Errorf(\"%w: HMAC secret required for HS256\", ErrInvalidConfiguration)\n302: \t\t}\n303: \tcase \"RS256\":\n304: \t\tif opts.PublicKey == nil {\n305: \t\t\treturn fmt.Errorf(\"%w: RSA public key required for RS256\", ErrInvalidConfiguration)\n306: \t\t}\n307: \t}\n308: \treturn nil\n309: }\n310: \n311: // ensureRSAPublicKey ensures the key is an RSA public key\n312: func ensureRSAPublicKey(key interface{}) (*rsa.PublicKey, error) {\n313: \tswitch k := key.(type) {\n314: \tcase *rsa.PublicKey:\n315: \t\treturn k, nil\n316: \tdefault:\n317: \t\treturn nil, fmt.Errorf(\"%w: expected RSA public key\", ErrInvalidConfiguration)\n318: \t}\n319: }\n320: \n321: // getSigningMethod returns the jwt.SigningMethod for the algorithm\n322: func getSigningMethod(alg string) jwt.SigningMethod {\n323: \tswitch alg {\n324: \tcase \"HS256\":\n325: \t\treturn jwt.SigningMethodHS256\n326: \tcase \"RS256\":\n327: \t\treturn jwt.SigningMethodRS256\n328: \tdefault:\n329: \t\treturn nil\n330: \t}\n331: }\n332: \n333: // now is a variable to allow mocking in tests\n334: var now = time.Now\n335: \n336: // setNow sets the time function for testing\n337: func setNow(fn func() time.Time) {\n338: \tnow = fn\n339: }\n\n(End of file - total 339 lines)\n</content>","metadata":{"preview":"/*\nCopyright 2026 The Volcano Authors.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\npackage jwt\n\nimport (\n\t\"crypto/rsa\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/picod/jwt/validator.go","time":{"start":1775878954393,"end":1775878954445}}}}
{"type":"tool_use","timestamp":1775878954448,"sessionID":"ses_2855e09b0ffeOwnQksGdceY7xM","part":{"id":"prt_d7aa24b6e001X20h4eVHdhNbc4","messageID":"msg_d7aa22668001gv27Cf4rbE5U1r","sessionID":"ses_2855e09b0ffeOwnQksGdceY7xM","type":"tool","tool":"read","callID":"toolu_functions.read:8","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/picod/jwt/config.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/picod/jwt/config.go</path>\n<type>file</type>\n<content>\n1: /*\n2: Copyright 2026 The Volcano Authors.\n3: \n4: Licensed under the Apache License, Version 2.0 (the \"License\");\n5: you may not use this file except in compliance with the License.\n6: You may obtain a copy of the License at\n7: \n8:     http://www.apache.org/licenses/LICENSE-2.0\n9: \n10: Unless required by applicable law or agreed to in writing, software\n11: distributed under the License is distributed on an \"AS IS\" BASIS,\n12: WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n13: See the License for the specific language governing permissions and\n14: limitations under the License.\n15: */\n16: \n17: package jwt\n18: \n19: import (\n20: \t\"crypto/rsa\"\n21: \t\"crypto/x509\"\n22: \t\"encoding/pem\"\n23: \t\"fmt\"\n24: \t\"os\"\n25: \t\"strconv\"\n26: \t\"strings\"\n27: \t\"time\"\n28: )\n29: \n30: // Config holds JWT configuration loaded from environment variables\n31: type Config struct {\n32: \t// Algorithm is the signing algorithm (HS256 or RS256)\n33: \tAlgorithm string\n34: \n35: \t// Secret is the HMAC secret for HS256\n36: \tSecret []byte\n37: \n38: \t// PublicKeyPath is the path to the RSA public key file for RS256\n39: \tPublicKeyPath string\n40: \n41: \t// PublicKey is the loaded RSA public key\n42: \tPublicKey *rsa.PublicKey\n43: \n44: \t// Issuer is the expected issuer claim\n45: \tIssuer string\n46: \n47: \t// Audience is the expected audience claim (optional)\n48: \tAudience string\n49: \n50: \t// ClockSkew is the allowed clock skew for time-based validations\n51: \tClockSkew time.Duration\n52: \n53: \t// AllowedAlgorithms is the list of allowed signing algorithms\n54: \tAllowedAlgorithms []string\n55: }\n56: \n57: // Environment variable names\n58: const (\n59: \tEnvJWTSecret      = \"PICOD_JWT_SECRET\"\n60: \tEnvJWTPublicKey   = \"PICOD_JWT_PUBLIC_KEY\"\n61: \tEnvJWTIssuer      = \"PICOD_JWT_ISSUER\"\n62: \tEnvJWTAudience    = \"PICOD_JWT_AUDIENCE\"\n63: \tEnvJWTClockSkew   = \"PICOD_JWT_CLOCK_SKEW\"\n64: \tEnvJWTAlg         = \"PICOD_JWT_ALG\"\n65: \tEnvJWTAllowedAlgs = \"PICOD_JWT_ALLOWED_ALGS\"\n66: )\n67: \n68: // LoadConfigFromEnv loads JWT configuration from environment variables\n69: func LoadConfigFromEnv() (*Config, error) {\n70: \tconfig := &Config{\n71: \t\tAlgorithm: getEnvOrDefault(EnvJWTAlg, \"RS256\"),\n72: \t\tClockSkew: defaultClockSkew,\n73: \t}\n74: \n75: \t// Load issuer (required)\n76: \tconfig.Issuer = os.Getenv(EnvJWTIssuer)\n77: \tif config.Issuer == \"\" {\n78: \t\treturn nil, fmt.Errorf(\"%w: %s is required\", ErrInvalidConfiguration, EnvJWTIssuer)\n79: \t}\n80: \n81: \t// Load optional audience\n82: \tconfig.Audience = os.Getenv(EnvJWTAudience)\n83: \n84: \t// Load clock skew\n85: \tif skewStr := os.Getenv(EnvJWTClockSkew); skewStr != \"\" {\n86: \t\tskew, err := parseDuration(skewStr)\n87: \t\tif err != nil {\n88: \t\t\treturn nil, fmt.Errorf(\"%w: invalid %s: %v\", ErrInvalidConfiguration, EnvJWTClockSkew, err)\n89: \t\t}\n90: \t\tconfig.ClockSkew = skew\n91: \t}\n92: \n93: \t// Load allowed algorithms\n94: \tif algsStr := os.Getenv(EnvJWTAllowedAlgs); algsStr != \"\" {\n95: \t\tconfig.AllowedAlgorithms = strings.Split(algsStr, \",\")\n96: \t\tfor i := range config.AllowedAlgorithms {\n97: \t\t\tconfig.AllowedAlgorithms[i] = strings.TrimSpace(config.AllowedAlgorithms[i])\n98: \t\t}\n99: \t} else {\n100: \t\tconfig.AllowedAlgorithms = []string{config.Algorithm}\n101: \t}\n102: \n103: \t// Load algorithm-specific configuration\n104: \tswitch config.Algorithm {\n105: \tcase \"HS256\":\n106: \t\tconfig.Secret = []byte(os.Getenv(EnvJWTSecret))\n107: \t\tif len(config.Secret) == 0 {\n108: \t\t\treturn nil, fmt.Errorf(\"%w: %s is required for HS256\", ErrInvalidConfiguration, EnvJWTSecret)\n109: \t\t}\n110: \n111: \tcase \"RS256\":\n112: \t\tconfig.PublicKeyPath = os.Getenv(EnvJWTPublicKey)\n113: \t\tif config.PublicKeyPath == \"\" {\n114: \t\t\treturn nil, fmt.Errorf(\"%w: %s is required for RS256\", ErrInvalidConfiguration, EnvJWTPublicKey)\n115: \t\t}\n116: \n117: \t\tpublicKey, err := loadRSAPublicKeyFromFile(config.PublicKeyPath)\n118: \t\tif err != nil {\n119: \t\t\treturn nil, fmt.Errorf(\"%w: failed to load RSA public key: %v\", ErrFailedToLoadKey, err)\n120: \t\t}\n121: \t\tconfig.PublicKey = publicKey\n122: \n123: \tdefault:\n124: \t\treturn nil, fmt.Errorf(\"%w: unsupported algorithm %s\", ErrInvalidConfiguration, config.Algorithm)\n125: \t}\n126: \n127: \treturn config, nil\n128: }\n129: \n130: // ToValidationOptions converts Config to ValidationOptions\n131: func (c *Config) ToValidationOptions() ValidationOptions {\n132: \treturn ValidationOptions{\n133: \t\tAlgorithm:         c.Algorithm,\n134: \t\tSecret:            c.Secret,\n135: \t\tPublicKey:         c.PublicKey,\n136: \t\tExpectedIssuer:    c.Issuer,\n137: \t\tExpectedAudience:  c.Audience,\n138: \t\tClockSkew:         c.ClockSkew,\n139: \t\tAllowedAlgs:       c.AllowedAlgorithms,\n140: \t\tRequireExpiration: true,\n141: \t}\n142: }\n143: \n144: // loadRSAPublicKeyFromFile loads an RSA public key from a PEM file\n145: func loadRSAPublicKeyFromFile(path string) (*rsa.PublicKey, error) {\n146: \tdata, err := os.ReadFile(path)\n147: \tif err != nil {\n148: \t\treturn nil, fmt.Errorf(\"failed to read key file: %w\", err)\n149: \t}\n150: \n151: \treturn parseRSAPublicKey(data)\n152: }\n153: \n154: // parseRSAPublicKey parses an RSA public key from PEM-encoded data\n155: func parseRSAPublicKey(data []byte) (*rsa.PublicKey, error) {\n156: \t// Decode PEM block\n157: \tblock, _ := pem.Decode(data)\n158: \tif block == nil {\n159: \t\treturn nil, fmt.Errorf(\"failed to decode PEM block\")\n160: \t}\n161: \n162: \t// Parse the key\n163: \tswitch block.Type {\n164: \tcase \"RSA PUBLIC KEY\":\n165: \t\t// PKCS#1 format\n166: \t\tkey, err := x509.ParsePKCS1PublicKey(block.Bytes)\n167: \t\tif err != nil {\n168: \t\t\treturn nil, fmt.Errorf(\"failed to parse PKCS#1 public key: %w\", err)\n169: \t\t}\n170: \t\treturn key, nil\n171: \n172: \tcase \"PUBLIC KEY\":\n173: \t\t// PKIX/PKCS#8 format\n174: \t\tpub, err := x509.ParsePKIXPublicKey(block.Bytes)\n175: \t\tif err != nil {\n176: \t\t\treturn nil, fmt.Errorf(\"failed to parse PKIX public key: %w\", err)\n177: \t\t}\n178: \n179: \t\trsaKey, ok := pub.(*rsa.PublicKey)\n180: \t\tif !ok {\n181: \t\t\treturn nil, fmt.Errorf(\"key is not an RSA public key\")\n182: \t\t}\n183: \t\treturn rsaKey, nil\n184: \n185: \tdefault:\n186: \t\treturn nil, fmt.Errorf(\"unsupported key type: %s\", block.Type)\n187: \t}\n188: }\n189: \n190: // getEnvOrDefault returns the value of an environment variable or a default value\n191: func getEnvOrDefault(key, defaultValue string) string {\n192: \tvalue := os.Getenv(key)\n193: \tif value == \"\" {\n194: \t\treturn defaultValue\n195: \t}\n196: \treturn value\n197: }\n198: \n199: // parseDuration parses a duration string (e.g., \"1m\", \"30s\", \"2h\")\n200: func parseDuration(s string) (time.Duration, error) {\n201: \t// Try standard duration parsing first\n202: \td, err := time.ParseDuration(s)\n203: \tif err == nil {\n204: \t\treturn d, nil\n205: \t}\n206: \n207: \t// Try parsing as seconds (numeric string)\n208: \tif seconds, err := strconv.ParseInt(s, 10, 64); err == nil {\n209: \t\treturn time.Duration(seconds) * time.Second, nil\n210: \t}\n211: \n212: \treturn 0, fmt.Errorf(\"invalid duration: %s\", s)\n213: }\n214: \n215: // NewValidatorFromEnv creates a new JWTValidator from environment configuration\n216: func NewValidatorFromEnv() (JWTValidator, error) {\n217: \tconfig, err := LoadConfigFromEnv()\n218: \tif err != nil {\n219: \t\treturn nil, err\n220: \t}\n221: \n222: \treturn NewValidator(config.ToValidationOptions())\n223: }\n\n(End of file - total 223 lines)\n</content>","metadata":{"preview":"/*\nCopyright 2026 The Volcano Authors.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\npackage jwt\n\nimport (\n\t\"crypto/rsa\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/picod/jwt/config.go","time":{"start":1775878954398,"end":1775878954447}}}}
{"type":"tool_use","timestamp":1775878954449,"sessionID":"ses_2855e09b0ffeOwnQksGdceY7xM","part":{"id":"prt_d7aa2517a00169n0GbjRjvxiWz","messageID":"msg_d7aa22668001gv27Cf4rbE5U1r","sessionID":"ses_2855e09b0ffeOwnQksGdceY7xM","type":"tool","tool":"read","callID":"toolu_functions.read:9","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/picod/jwt/errors.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/picod/jwt/errors.go</path>\n<type>file</type>\n<content>\n1: /*\n2: Copyright 2026 The Volcano Authors.\n3: \n4: Licensed under the Apache License, Version 2.0 (the \"License\");\n5: you may not use this file except in compliance with the License.\n6: You may obtain a copy of the License at\n7: \n8:     http://www.apache.org/licenses/LICENSE-2.0\n9: \n10: Unless required by applicable law or agreed to in writing, software\n11: distributed under the License is distributed on an \"AS IS\" BASIS,\n12: WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n13: See the License for the specific language governing permissions and\n14: limitations under the License.\n15: */\n16: \n17: package jwt\n18: \n19: import \"errors\"\n20: \n21: // Authentication errors\n22: var (\n23: \t// ErrMissingToken is returned when no Authorization header is present\n24: \tErrMissingToken = errors.New(\"jwt: missing bearer token\")\n25: \n26: \t// ErrInvalidTokenFormat is returned when the Authorization header format is invalid\n27: \tErrInvalidTokenFormat = errors.New(\"jwt: invalid token format\")\n28: \n29: \t// ErrInvalidSignature is returned when token signature verification fails\n30: \tErrInvalidSignature = errors.New(\"jwt: invalid signature\")\n31: \n32: \t// ErrTokenExpired is returned when the token has expired\n33: \tErrTokenExpired = errors.New(\"jwt: token expired\")\n34: \n35: \t// ErrTokenNotYetValid is returned when the token is used before its issued at time\n36: \tErrTokenNotYetValid = errors.New(\"jwt: token not yet valid\")\n37: \n38: \t// ErrInvalidIssuer is returned when the issuer claim does not match\n39: \tErrInvalidIssuer = errors.New(\"jwt: invalid issuer\")\n40: \n41: \t// ErrUnsupportedAlgorithm is returned when the signing algorithm is not allowed\n42: \tErrUnsupportedAlgorithm = errors.New(\"jwt: unsupported algorithm\")\n43: \n44: \t// ErrMissingClaims is returned when required claims are missing\n45: \tErrMissingClaims = errors.New(\"jwt: missing required claims\")\n46: \n47: \t// ErrInvalidConfiguration is returned when the validator configuration is invalid\n48: \tErrInvalidConfiguration = errors.New(\"jwt: invalid configuration\")\n49: \n50: \t// ErrFailedToLoadKey is returned when a key cannot be loaded from file\n51: \tErrFailedToLoadKey = errors.New(\"jwt: failed to load key\")\n52: )\n\n(End of file - total 52 lines)\n</content>","metadata":{"preview":"/*\nCopyright 2026 The Volcano Authors.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\npackage jwt\n\nimport \"errors\"\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/picod/jwt/errors.go","time":{"start":1775878954400,"end":1775878954448}}}}
{"type":"tool_use","timestamp":1775878954452,"sessionID":"ses_2855e09b0ffeOwnQksGdceY7xM","part":{"id":"prt_d7aa2577d001IHepRauxoT6J6q","messageID":"msg_d7aa22668001gv27Cf4rbE5U1r","sessionID":"ses_2855e09b0ffeOwnQksGdceY7xM","type":"tool","tool":"read","callID":"toolu_functions.read:10","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/picod/jwt/validator_test.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/picod/jwt/validator_test.go</path>\n<type>file</type>\n<content>\n1: /*\n2: Copyright 2026 The Volcano Authors.\n3: \n4: Licensed under the Apache License, Version 2.0 (the \"License\");\n5: you may not use this file except in compliance with the License.\n6: You may obtain a copy of the License at\n7: \n8:     http://www.apache.org/licenses/LICENSE-2.0\n9: \n10: Unless required by applicable law or agreed to in writing, software\n11: distributed under the License is distributed on an \"AS IS\" BASIS,\n12: WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n13: See the License for the specific language governing permissions and\n14: limitations under the License.\n15: */\n16: \n17: package jwt\n18: \n19: import (\n20: \t\"crypto/rand\"\n21: \t\"crypto/rsa\"\n22: \t\"crypto/x509\"\n23: \t\"encoding/pem\"\n24: \t\"testing\"\n25: \t\"time\"\n26: \n27: \t\"github.com/golang-jwt/jwt/v5\"\n28: )\n29: \n30: // Test keys\n31: var (\n32: \ttestHMACSecret    = []byte(\"test-secret-12345\")\n33: \ttestRSAPrivateKey *rsa.PrivateKey\n34: \ttestRSAPublicKey  *rsa.PublicKey\n35: )\n36: \n37: func init() {\n38: \tvar err error\n39: \ttestRSAPrivateKey, err = rsa.GenerateKey(rand.Reader, 2048)\n40: \tif err != nil {\n41: \t\tpanic(err)\n42: \t}\n43: \ttestRSAPublicKey = &testRSAPrivateKey.PublicKey\n44: }\n45: \n46: // generateHS256Token generates a test token signed with HS256\n47: func generateHS256Token(claims jwt.MapClaims) string {\n48: \ttoken := jwt.NewWithClaims(jwt.SigningMethodHS256, claims)\n49: \ttokenString, _ := token.SignedString(testHMACSecret)\n50: \treturn tokenString\n51: }\n52: \n53: // generateRS256Token generates a test token signed with RS256\n54: func generateRS256Token(claims jwt.MapClaims) string {\n55: \ttoken := jwt.NewWithClaims(jwt.SigningMethodRS256, claims)\n56: \ttokenString, _ := token.SignedString(testRSAPrivateKey)\n57: \treturn tokenString\n58: }\n59: \n60: // generateRS256TokenWithInvalidKey generates a token signed with a different RSA key\n61: func generateRS256TokenWithInvalidKey(claims jwt.MapClaims) string {\n62: \tprivateKey, _ := rsa.GenerateKey(rand.Reader, 2048)\n63: \ttoken := jwt.NewWithClaims(jwt.SigningMethodRS256, claims)\n64: \ttokenString, _ := token.SignedString(privateKey)\n65: \treturn tokenString\n66: }\n67: \n68: func TestNewValidator(t *testing.T) {\n69: \ttests := []struct {\n70: \t\tname    string\n71: \t\topts    ValidationOptions\n72: \t\twantErr bool\n73: \t}{\n74: \t\t{\n75: \t\t\tname: \"valid HS256 config\",\n76: \t\t\topts: ValidationOptions{\n77: \t\t\t\tAlgorithm: \"HS256\",\n78: \t\t\t\tSecret:    testHMACSecret,\n79: \t\t\t},\n80: \t\t\twantErr: false,\n81: \t\t},\n82: \t\t{\n83: \t\t\tname: \"valid RS256 config\",\n84: \t\t\topts: ValidationOptions{\n85: \t\t\t\tAlgorithm: \"RS256\",\n86: \t\t\t\tPublicKey: testRSAPublicKey,\n87: \t\t\t},\n88: \t\t\twantErr: false,\n89: \t\t},\n90: \t\t{\n91: \t\t\tname: \"HS256 without secret\",\n92: \t\t\topts: ValidationOptions{\n93: \t\t\t\tAlgorithm: \"HS256\",\n94: \t\t\t},\n95: \t\t\twantErr: true,\n96: \t\t},\n97: \t\t{\n98: \t\t\tname: \"RS256 without public key\",\n99: \t\t\topts: ValidationOptions{\n100: \t\t\t\tAlgorithm: \"RS256\",\n101: \t\t\t},\n102: \t\t\twantErr: true,\n103: \t\t},\n104: \t\t{\n105: \t\t\tname: \"invalid algorithm\",\n106: \t\t\topts: ValidationOptions{\n107: \t\t\t\tAlgorithm: \"ES256\",\n108: \t\t\t},\n109: \t\t\twantErr: true,\n110: \t\t},\n111: \t\t{\n112: \t\t\tname: \"default algorithm is RS256\",\n113: \t\t\topts: ValidationOptions{\n114: \t\t\t\tPublicKey: testRSAPublicKey,\n115: \t\t\t},\n116: \t\t\twantErr: false,\n117: \t\t},\n118: \t}\n119: \n120: \tfor _, tt := range tests {\n121: \t\tt.Run(tt.name, func(t *testing.T) {\n122: \t\t\tvalidator, err := NewValidator(tt.opts)\n123: \t\t\tif (err != nil) != tt.wantErr {\n124: \t\t\t\tt.Errorf(\"NewValidator() error = %v, wantErr %v\", err, tt.wantErr)\n125: \t\t\t\treturn\n126: \t\t\t}\n127: \t\t\tif !tt.wantErr && validator == nil {\n128: \t\t\t\tt.Error(\"NewValidator() returned nil validator without error\")\n129: \t\t\t}\n130: \t\t})\n131: \t}\n132: }\n133: \n134: func TestValidateToken_HS256_Success(t *testing.T) {\n135: \topts := ValidationOptions{\n136: \t\tAlgorithm:      \"HS256\",\n137: \t\tSecret:         testHMACSecret,\n138: \t\tExpectedIssuer: \"auth-service\",\n139: \t\tClockSkew:      time.Minute,\n140: \t}\n141: \n142: \tvalidator, err := NewValidator(opts)\n143: \tif err != nil {\n144: \t\tt.Fatalf(\"Failed to create validator: %v\", err)\n145: \t}\n146: \n147: \tclaims := jwt.MapClaims{\n148: \t\t\"sub\": \"user123\",\n149: \t\t\"iss\": \"auth-service\",\n150: \t\t\"exp\": time.Now().Add(time.Hour).Unix(),\n151: \t\t\"iat\": time.Now().Unix(),\n152: \t}\n153: \ttoken := generateHS256Token(claims)\n154: \n155: \tparsedClaims, err := validator.ValidateToken(token)\n156: \tif err != nil {\n157: \t\tt.Errorf(\"ValidateToken() error = %v\", err)\n158: \t\treturn\n159: \t}\n160: \n161: \tif parsedClaims.Subject != \"user123\" {\n162: \t\tt.Errorf(\"Subject = %v, want %v\", parsedClaims.Subject, \"user123\")\n163: \t}\n164: \tif parsedClaims.Issuer != \"auth-service\" {\n165: \t\tt.Errorf(\"Issuer = %v, want %v\", parsedClaims.Issuer, \"auth-service\")\n166: \t}\n167: }\n168: \n169: func TestValidateToken_HS256_InvalidSignature(t *testing.T) {\n170: \topts := ValidationOptions{\n171: \t\tAlgorithm: \"HS256\",\n172: \t\tSecret:    testHMACSecret,\n173: \t}\n174: \n175: \tvalidator, err := NewValidator(opts)\n176: \tif err != nil {\n177: \t\tt.Fatalf(\"Failed to create validator: %v\", err)\n178: \t}\n179: \n180: \t// Generate token with wrong secret\n181: \tclaims := jwt.MapClaims{\n182: \t\t\"sub\": \"user123\",\n183: \t\t\"exp\": time.Now().Add(time.Hour).Unix(),\n184: \t}\n185: \ttoken := jwt.NewWithClaims(jwt.SigningMethodHS256, claims)\n186: \ttokenString, _ := token.SignedString([]byte(\"wrong-secret\"))\n187: \n188: \t_, err = validator.ValidateToken(tokenString)\n189: \tif err != ErrInvalidSignature {\n190: \t\tt.Errorf(\"ValidateToken() error = %v, want %v\", err, ErrInvalidSignature)\n191: \t}\n192: }\n193: \n194: func TestValidateToken_RS256_Success(t *testing.T) {\n195: \topts := ValidationOptions{\n196: \t\tAlgorithm:      \"RS256\",\n197: \t\tPublicKey:      testRSAPublicKey,\n198: \t\tExpectedIssuer: \"auth-service\",\n199: \t\tClockSkew:      time.Minute,\n200: \t}\n201: \n202: \tvalidator, err := NewValidator(opts)\n203: \tif err != nil {\n204: \t\tt.Fatalf(\"Failed to create validator: %v\", err)\n205: \t}\n206: \n207: \tclaims := jwt.MapClaims{\n208: \t\t\"sub\": \"user456\",\n209: \t\t\"iss\": \"auth-service\",\n210: \t\t\"exp\": time.Now().Add(time.Hour).Unix(),\n211: \t\t\"iat\": time.Now().Unix(),\n212: \t}\n213: \ttoken := generateRS256Token(claims)\n214: \n215: \tparsedClaims, err := validator.ValidateToken(token)\n216: \tif err != nil {\n217: \t\tt.Errorf(\"ValidateToken() error = %v\", err)\n218: \t\treturn\n219: \t}\n220: \n221: \tif parsedClaims.Subject != \"user456\" {\n222: \t\tt.Errorf(\"Subject = %v, want %v\", parsedClaims.Subject, \"user456\")\n223: \t}\n224: }\n225: \n226: func TestValidateToken_RS256_InvalidSignature(t *testing.T) {\n227: \topts := ValidationOptions{\n228: \t\tAlgorithm: \"RS256\",\n229: \t\tPublicKey: testRSAPublicKey,\n230: \t}\n231: \n232: \tvalidator, err := NewValidator(opts)\n233: \tif err != nil {\n234: \t\tt.Fatalf(\"Failed to create validator: %v\", err)\n235: \t}\n236: \n237: \tclaims := jwt.MapClaims{\n238: \t\t\"sub\": \"user456\",\n239: \t\t\"exp\": time.Now().Add(time.Hour).Unix(),\n240: \t}\n241: \ttoken := generateRS256TokenWithInvalidKey(claims)\n242: \n243: \t_, err = validator.ValidateToken(token)\n244: \tif err != ErrInvalidSignature {\n245: \t\tt.Errorf(\"ValidateToken() error = %v, want %v\", err, ErrInvalidSignature)\n246: \t}\n247: }\n248: \n249: func TestValidateToken_Expired(t *testing.T) {\n250: \topts := ValidationOptions{\n251: \t\tAlgorithm: \"HS256\",\n252: \t\tSecret:    testHMACSecret,\n253: \t\tClockSkew: 0,\n254: \t}\n255: \n256: \tvalidator, err := NewValidator(opts)\n257: \tif err != nil {\n258: \t\tt.Fatalf(\"Failed to create validator: %v\", err)\n259: \t}\n260: \n261: \tclaims := jwt.MapClaims{\n262: \t\t\"sub\": \"user789\",\n263: \t\t\"exp\": time.Now().Add(-time.Hour).Unix(),\n264: \t\t\"iat\": time.Now().Add(-2 * time.Hour).Unix(),\n265: \t}\n266: \ttoken := generateHS256Token(claims)\n267: \n268: \t_, err = validator.ValidateToken(token)\n269: \tif err != ErrTokenExpired {\n270: \t\tt.Errorf(\"ValidateToken() error = %v, want %v\", err, ErrTokenExpired)\n271: \t}\n272: }\n273: \n274: func TestValidateToken_ClockSkew(t *testing.T) {\n275: \topts := ValidationOptions{\n276: \t\tAlgorithm: \"HS256\",\n277: \t\tSecret:    testHMACSecret,\n278: \t\tClockSkew: 2 * time.Minute,\n279: \t}\n280: \n281: \tvalidator, err := NewValidator(opts)\n282: \tif err != nil {\n283: \t\tt.Fatalf(\"Failed to create validator: %v\", err)\n284: \t}\n285: \n286: \t// Token expired 30 seconds ago, but clock skew is 2 minutes\n287: \tclaims := jwt.MapClaims{\n288: \t\t\"sub\": \"user789\",\n289: \t\t\"exp\": time.Now().Add(-30 * time.Second).Unix(),\n290: \t\t\"iat\": time.Now().Add(-time.Hour).Unix(),\n291: \t}\n292: \ttoken := generateHS256Token(claims)\n293: \n294: \t_, err = validator.ValidateToken(token)\n295: \tif err != nil {\n296: \t\tt.Errorf(\"ValidateToken() with clock skew error = %v, want nil\", err)\n297: \t}\n298: }\n299: \n300: func TestValidateToken_NotYetValid(t *testing.T) {\n301: \topts := ValidationOptions{\n302: \t\tAlgorithm: \"HS256\",\n303: \t\tSecret:    testHMACSecret,\n304: \t\tClockSkew: 0,\n305: \t}\n306: \n307: \tvalidator, err := NewValidator(opts)\n308: \tif err != nil {\n309: \t\tt.Fatalf(\"Failed to create validator: %v\", err)\n310: \t}\n311: \n312: \tclaims := jwt.MapClaims{\n313: \t\t\"sub\": \"user000\",\n314: \t\t\"nbf\": time.Now().Add(time.Hour).Unix(),\n315: \t\t\"exp\": time.Now().Add(2 * time.Hour).Unix(),\n316: \t}\n317: \ttoken := generateHS256Token(claims)\n318: \n319: \t_, err = validator.ValidateToken(token)\n320: \tif err != ErrTokenNotYetValid {\n321: \t\tt.Errorf(\"ValidateToken() error = %v, want %v\", err, ErrTokenNotYetValid)\n322: \t}\n323: }\n324: \n325: func TestValidateToken_InvalidIssuer(t *testing.T) {\n326: \topts := ValidationOptions{\n327: \t\tAlgorithm:      \"HS256\",\n328: \t\tSecret:         testHMACSecret,\n329: \t\tExpectedIssuer: \"auth-service\",\n330: \t}\n331: \n332: \tvalidator, err := NewValidator(opts)\n333: \tif err != nil {\n334: \t\tt.Fatalf(\"Failed to create validator: %v\", err)\n335: \t}\n336: \n337: \tclaims := jwt.MapClaims{\n338: \t\t\"sub\": \"user123\",\n339: \t\t\"iss\": \"other-service\",\n340: \t\t\"exp\": time.Now().Add(time.Hour).Unix(),\n341: \t}\n342: \ttoken := generateHS256Token(claims)\n343: \n344: \t_, err = validator.ValidateToken(token)\n345: \tif err != ErrInvalidIssuer {\n346: \t\tt.Errorf(\"ValidateToken() error = %v, want %v\", err, ErrInvalidIssuer)\n347: \t}\n348: }\n349: \n350: func TestValidateToken_InvalidAudience(t *testing.T) {\n351: \topts := ValidationOptions{\n352: \t\tAlgorithm:        \"HS256\",\n353: \t\tSecret:           testHMACSecret,\n354: \t\tExpectedAudience: \"expected-audience\",\n355: \t}\n356: \n357: \tvalidator, err := NewValidator(opts)\n358: \tif err != nil {\n359: \t\tt.Fatalf(\"Failed to create validator: %v\", err)\n360: \t}\n361: \n362: \tclaims := jwt.MapClaims{\n363: \t\t\"sub\": \"user123\",\n364: \t\t\"aud\": \"wrong-audience\",\n365: \t\t\"exp\": time.Now().Add(time.Hour).Unix(),\n366: \t}\n367: \ttoken := generateHS256Token(claims)\n368: \n369: \t_, err = validator.ValidateToken(token)\n370: \tif err != ErrInvalidIssuer {\n371: \t\tt.Errorf(\"ValidateToken() error = %v, want %v\", err, ErrInvalidIssuer)\n372: \t}\n373: }\n374: \n375: func TestValidateToken_UnsupportedAlgorithm(t *testing.T) {\n376: \topts := ValidationOptions{\n377: \t\tAlgorithm:   \"HS256\",\n378: \t\tSecret:      testHMACSecret,\n379: \t\tAllowedAlgs: []string{\"HS256\"},\n380: \t}\n381: \n382: \tvalidator, err := NewValidator(opts)\n383: \tif err != nil {\n384: \t\tt.Fatalf(\"Failed to create validator: %v\", err)\n385: \t}\n386: \n387: \t// Generate ES256 token (we can't actually sign it, but we can test the header)\n388: \tclaims := jwt.MapClaims{\n389: \t\t\"sub\": \"user123\",\n390: \t\t\"exp\": time.Now().Add(time.Hour).Unix(),\n391: \t}\n392: \ttoken := jwt.NewWithClaims(jwt.SigningMethodES256, claims)\n393: \ttoken.Header[\"alg\"] = \"ES256\"\n394: \ttokenString, _ := token.SigningString()\n395: \n396: \t_, err = validator.ValidateToken(tokenString + \".invalid\")\n397: \t// Should fail with unsupported algorithm\n398: \tif err != ErrInvalidTokenFormat && err != ErrUnsupportedAlgorithm {\n399: \t\tt.Errorf(\"ValidateToken() error = %v, want ErrUnsupportedAlgorithm or ErrInvalidTokenFormat\", err)\n400: \t}\n401: }\n402: \n403: func TestValidateToken_Malformed(t *testing.T) {\n404: \topts := ValidationOptions{\n405: \t\tAlgorithm: \"HS256\",\n406: \t\tSecret:    testHMACSecret,\n407: \t}\n408: \n409: \tvalidator, err := NewValidator(opts)\n410: \tif err != nil {\n411: \t\tt.Fatalf(\"Failed to create validator: %v\", err)\n412: \t}\n413: \n414: \ttests := []string{\n415: \t\t\"not-a-token\",\n416: \t\t\"header.payload\",\n417: \t\t\"header.\",\n418: \t\t\"\",\n419: \t}\n420: \n421: \tfor _, token := range tests {\n422: \t\t_, err := validator.ValidateToken(token)\n423: \t\tif err != ErrInvalidTokenFormat && err != ErrMissingToken {\n424: \t\t\tt.Errorf(\"ValidateToken(%q) error = %v, want ErrInvalidTokenFormat or ErrMissingToken\", token, err)\n425: \t\t}\n426: \t}\n427: }\n428: \n429: func TestValidateToken_MissingClaims(t *testing.T) {\n430: \topts := ValidationOptions{\n431: \t\tAlgorithm:         \"HS256\",\n432: \t\tSecret:            testHMACSecret,\n433: \t\tRequireExpiration: true,\n434: \t}\n435: \n436: \tvalidator, err := NewValidator(opts)\n437: \tif err != nil {\n438: \t\tt.Fatalf(\"Failed to create validator: %v\", err)\n439: \t}\n440: \n441: \tclaims := jwt.MapClaims{\n442: \t\t\"sub\": \"user123\",\n443: \t\t\"iat\": time.Now().Unix(),\n444: \t\t// No exp claim\n445: \t}\n446: \ttoken := generateHS256Token(claims)\n447: \n448: \t_, err = validator.ValidateToken(token)\n449: \tif err != ErrMissingClaims {\n450: \t\tt.Errorf(\"ValidateToken() error = %v, want %v\", err, ErrMissingClaims)\n451: \t}\n452: }\n453: \n454: func TestClaims_IsExpired(t *testing.T) {\n455: \tclockSkew := time.Minute\n456: \n457: \ttests := []struct {\n458: \t\tname      string\n459: \t\texpiresAt time.Time\n460: \t\twant      bool\n461: \t}{\n462: \t\t{\n463: \t\t\tname:      \"not expired\",\n464: \t\t\texpiresAt: time.Now().Add(time.Hour),\n465: \t\t\twant:      false,\n466: \t\t},\n467: \t\t{\n468: \t\t\tname:      \"expired\",\n469: \t\t\texpiresAt: time.Now().Add(-time.Hour),\n470: \t\t\twant:      true,\n471: \t\t},\n472: \t\t{\n473: \t\t\tname:      \"expired within clock skew\",\n474: \t\t\texpiresAt: time.Now().Add(-30 * time.Second),\n475: \t\t\twant:      false,\n476: \t\t},\n477: \t\t{\n478: \t\t\tname:      \"zero time (no expiration)\",\n479: \t\t\texpiresAt: time.Time{},\n480: \t\t\twant:      false,\n481: \t\t},\n482: \t}\n483: \n484: \tfor _, tt := range tests {\n485: \t\tt.Run(tt.name, func(t *testing.T) {\n486: \t\t\tc := &Claims{ExpiresAt: tt.expiresAt}\n487: \t\t\tif got := c.IsExpired(clockSkew); got != tt.want {\n488: \t\t\t\tt.Errorf(\"Claims.IsExpired() = %v, want %v\", got, tt.want)\n489: \t\t\t}\n490: \t\t})\n491: \t}\n492: }\n493: \n494: func TestClaims_IsNotYetValid(t *testing.T) {\n495: \tclockSkew := time.Minute\n496: \n497: \ttests := []struct {\n498: \t\tname      string\n499: \t\tnotBefore *time.Time\n500: \t\twant      bool\n501: \t}{\n502: \t\t{\n503: \t\t\tname:      \"already valid\",\n504: \t\t\tnotBefore: timePtr(time.Now().Add(-time.Hour)),\n505: \t\t\twant:      false,\n506: \t\t},\n507: \t\t{\n508: \t\t\tname:      \"not yet valid\",\n509: \t\t\tnotBefore: timePtr(time.Now().Add(time.Hour)),\n510: \t\t\twant:      true,\n511: \t\t},\n512: \t\t{\n513: \t\t\tname:      \"valid within clock skew\",\n514: \t\t\tnotBefore: timePtr(time.Now().Add(30 * time.Second)),\n515: \t\t\twant:      false,\n516: \t\t},\n517: \t\t{\n518: \t\t\tname:      \"nil (no nbf)\",\n519: \t\t\tnotBefore: nil,\n520: \t\t\twant:      false,\n521: \t\t},\n522: \t\t{\n523: \t\t\tname:      \"zero time\",\n524: \t\t\tnotBefore: timePtr(time.Time{}),\n525: \t\t\twant:      false,\n526: \t\t},\n527: \t}\n528: \n529: \tfor _, tt := range tests {\n530: \t\tt.Run(tt.name, func(t *testing.T) {\n531: \t\t\tc := &Claims{NotBefore: tt.notBefore}\n532: \t\t\tif got := c.IsNotYetValid(clockSkew); got != tt.want {\n533: \t\t\t\tt.Errorf(\"Claims.IsNotYetValid() = %v, want %v\", got, tt.want)\n534: \t\t\t}\n535: \t\t})\n536: \t}\n537: }\n538: \n539: func TestValidateToken_AllowedAlgorithms(t *testing.T) {\n540: \topts := ValidationOptions{\n541: \t\tAlgorithm:   \"HS256\",\n542: \t\tSecret:      testHMACSecret,\n543: \t\tAllowedAlgs: []string{\"HS256\", \"RS256\"},\n544: \t}\n545: \n546: \tvalidator, err := NewValidator(opts)\n547: \tif err != nil {\n548: \t\tt.Fatalf(\"Failed to create validator: %v\", err)\n549: \t}\n550: \n551: \t// Valid HS256 token\n552: \tclaims := jwt.MapClaims{\n553: \t\t\"sub\": \"user123\",\n554: \t\t\"exp\": time.Now().Add(time.Hour).Unix(),\n555: \t}\n556: \ttoken := generateHS256Token(claims)\n557: \n558: \t_, err = validator.ValidateToken(token)\n559: \tif err != nil {\n560: \t\tt.Errorf(\"ValidateToken() with allowed HS256 error = %v\", err)\n561: \t}\n562: }\n563: \n564: func TestValidateToken_AudienceValidation(t *testing.T) {\n565: \topts := ValidationOptions{\n566: \t\tAlgorithm:        \"HS256\",\n567: \t\tSecret:           testHMACSecret,\n568: \t\tExpectedAudience: \"my-api\",\n569: \t}\n570: \n571: \tvalidator, err := NewValidator(opts)\n572: \tif err != nil {\n573: \t\tt.Fatalf(\"Failed to create validator: %v\", err)\n574: \t}\n575: \n576: \tclaims := jwt.MapClaims{\n577: \t\t\"sub\": \"user123\",\n578: \t\t\"aud\": []string{\"other-api\", \"my-api\"},\n579: \t\t\"exp\": time.Now().Add(time.Hour).Unix(),\n580: \t}\n581: \ttoken := generateHS256Token(claims)\n582: \n583: \t_, err = validator.ValidateToken(token)\n584: \tif err != nil {\n585: \t\tt.Errorf(\"ValidateToken() with valid audience error = %v\", err)\n586: \t}\n587: }\n588: \n589: func TestValidateToken_JTI(t *testing.T) {\n590: \topts := ValidationOptions{\n591: \t\tAlgorithm: \"HS256\",\n592: \t\tSecret:    testHMACSecret,\n593: \t}\n594: \n595: \tvalidator, err := NewValidator(opts)\n596: \tif err != nil {\n597: \t\tt.Fatalf(\"Failed to create validator: %v\", err)\n598: \t}\n599: \n600: \tclaims := jwt.MapClaims{\n601: \t\t\"sub\": \"user123\",\n602: \t\t\"jti\": \"unique-token-id\",\n603: \t\t\"exp\": time.Now().Add(time.Hour).Unix(),\n604: \t}\n605: \ttoken := generateHS256Token(claims)\n606: \n607: \tparsedClaims, err := validator.ValidateToken(token)\n608: \tif err != nil {\n609: \t\tt.Errorf(\"ValidateToken() error = %v\", err)\n610: \t\treturn\n611: \t}\n612: \n613: \tif parsedClaims.JWTID != \"unique-token-id\" {\n614: \t\tt.Errorf(\"JWTID = %v, want %v\", parsedClaims.JWTID, \"unique-token-id\")\n615: \t}\n616: }\n617: \n618: func TestValidateToken_EmptyToken(t *testing.T) {\n619: \topts := ValidationOptions{\n620: \t\tAlgorithm: \"HS256\",\n621: \t\tSecret:    testHMACSecret,\n622: \t}\n623: \n624: \tvalidator, err := NewValidator(opts)\n625: \tif err != nil {\n626: \t\tt.Fatalf(\"Failed to create validator: %v\", err)\n627: \t}\n628: \n629: \t_, err = validator.ValidateToken(\"\")\n630: \tif err != ErrMissingToken {\n631: \t\tt.Errorf(\"ValidateToken(\\\"\\\") error = %v, want %v\", err, ErrMissingToken)\n632: \t}\n633: }\n634: \n635: // timePtr returns a pointer to a time.Time\n636: func timePtr(t time.Time) *time.Time {\n637: \treturn &t\n638: }\n639: \n640: // Helper to generate RSA key PEM for tests\n641: func generateRSAPublicKeyPEM(key *rsa.PublicKey) []byte {\n642: \tpubKeyBytes, _ := x509.MarshalPKIXPublicKey(key)\n643: \tpemBlock := &pem.Block{\n644: \t\tType:  \"PUBLIC KEY\",\n645: \t\tBytes: pubKeyBytes,\n646: \t}\n647: \treturn pem.EncodeToMemory(pemBlock)\n648: }\n\n(End of file - total 648 lines)\n</content>","metadata":{"preview":"/*\nCopyright 2026 The Volcano Authors.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\npackage jwt\n\nimport (\n\t\"crypto/rand\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/picod/jwt/validator_test.go","time":{"start":1775878954403,"end":1775878954449}}}}
