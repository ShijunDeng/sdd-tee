{"type":"tool_use","timestamp":1775863953728,"sessionID":"ses_28644a1e1ffeXevK8ggqv8mK5C","part":{"id":"prt_d79bd6ecd0015pwe8p7jxFSKjx","messageID":"msg_d79bcd020001hkOxPRRXHfCpvp","sessionID":"ses_28644a1e1ffeXevK8ggqv8mK5C","type":"tool","tool":"read","callID":"toolu_functions.read:17","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/router/jwt_middleware.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/router/jwt_middleware.go</path>\n<type>file</type>\n<content>\n1: /*\n2: Copyright 2026 The Volcano Authors.\n3: \n4: Licensed under the Apache License, Version 2.0 (the \"License\");\n5: you may not use this file except in compliance with the License.\n6: You may obtain a copy of the License at\n7: \n8:     http://www.apache.org/licenses/LICENSE-2.0\n9: \n10: Unless required by applicable law or agreed to in writing, software\n11: distributed under the License is distributed on an \"AS IS\" BASIS,\n12: WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n13: See the License for the specific language governing permissions and\n14: limitations under the License.\n15: */\n16: \n17: package router\n18: \n19: import (\n20: \t\"context\"\n21: \t\"encoding/json\"\n22: \t\"net/http\"\n23: \t\"strings\"\n24: \n25: \t\"k8s.io/klog/v2\"\n26: )\n27: \n28: // JWTMiddleware provides HTTP middleware for JWT authentication.\n29: type JWTMiddleware struct {\n30: \tjwtManager     *JWTManager\n31: \tsessionManager SessionManager\n32: }\n33: \n34: // NewJWTMiddleware creates a new JWTMiddleware instance.\n35: func NewJWTMiddleware(jwtManager *JWTManager) *JWTMiddleware {\n36: \treturn &JWTMiddleware{\n37: \t\tjwtManager: jwtManager,\n38: \t}\n39: }\n40: \n41: // NewJWTMiddlewareWithSession creates a new JWTMiddleware with session support.\n42: func NewJWTMiddlewareWithSession(jwtManager *JWTManager, sessionManager SessionManager) *JWTMiddleware {\n43: \treturn &JWTMiddleware{\n44: \t\tjwtManager:     jwtManager,\n45: \t\tsessionManager: sessionManager,\n46: \t}\n47: }\n48: \n49: // SetSessionManager sets the session manager for the middleware.\n50: func (m *JWTMiddleware) SetSessionManager(sessionManager SessionManager) {\n51: \tm.sessionManager = sessionManager\n52: }\n53: \n54: // Authenticate returns an HTTP handler that authenticates requests using JWT.\n55: // It extracts the Bearer token from the Authorization header, validates it,\n56: // and stores the claims in the request context.\n57: func (m *JWTMiddleware) Authenticate(next http.Handler) http.Handler {\n58: \treturn http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n59: \t\ttokenString, err := extractBearerToken(r)\n60: \t\tif err != nil {\n61: \t\t\twriteAuthError(w, http.StatusUnauthorized, \"Unauthorized\", \"missing or invalid authorization header\")\n62: \t\t\treturn\n63: \t\t}\n64: \n65: \t\t// Validate the token\n66: \t\tclaims, err := m.jwtManager.ValidateToken(tokenString)\n67: \t\tif err != nil {\n68: \t\t\tklog.V(4).Infof(\"Token validation failed: %v\", err)\n69: \n70: \t\t\tstatus := http.StatusUnauthorized\n71: \t\t\tmessage := \"Unauthorized\"\n72: \t\t\terrorCode := string(GetJWTErrorCode(err))\n73: \n74: \t\t\tif errorCode == \"\" {\n75: \t\t\t\terrorCode = \"TOKEN_INVALID\"\n76: \t\t\t}\n77: \n78: \t\t\twriteAuthError(w, status, message, errorCode)\n79: \t\t\treturn\n80: \t\t}\n81: \n82: \t\t// Store claims in context\n83: \t\tctx := WithTokenClaims(r.Context(), claims)\n84: \t\tnext.ServeHTTP(w, r.WithContext(ctx))\n85: \t})\n86: }\n87: \n88: // OptionalAuthenticate returns an HTTP handler that authenticates requests if a token is present.\n89: // If no token is provided, the request proceeds without authentication.\n90: func (m *JWTMiddleware) OptionalAuthenticate(next http.Handler) http.Handler {\n91: \treturn http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n92: \t\ttokenString, err := extractBearerToken(r)\n93: \t\tif err != nil {\n94: \t\t\t// No token provided, proceed without authentication\n95: \t\t\tnext.ServeHTTP(w, r)\n96: \t\t\treturn\n97: \t\t}\n98: \n99: \t\t// Validate the token\n100: \t\tclaims, err := m.jwtManager.ValidateToken(tokenString)\n101: \t\tif err != nil {\n102: \t\t\tklog.V(4).Infof(\"Optional token validation failed: %v\", err)\n103: \t\t\t// Continue without setting claims\n104: \t\t\tnext.ServeHTTP(w, r)\n105: \t\t\treturn\n106: \t\t}\n107: \n108: \t\t// Store claims in context\n109: \t\tctx := WithTokenClaims(r.Context(), claims)\n110: \t\tnext.ServeHTTP(w, r.WithContext(ctx))\n111: \t})\n112: }\n113: \n114: // RequireSession returns an HTTP handler that verifies the session is valid.\n115: // It requires that authentication has already been performed and session_id is present.\n116: func (m *JWTMiddleware) RequireSession(next http.Handler) http.Handler {\n117: \treturn http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n118: \t\tclaims, ok := GetTokenClaims(r.Context())\n119: \t\tif !ok {\n120: \t\t\twriteAuthError(w, http.StatusUnauthorized, \"Unauthorized\", \"token claims not found in context\")\n121: \t\t\treturn\n122: \t\t}\n123: \n124: \t\tif claims.SessionID == \"\" {\n125: \t\t\twriteAuthError(w, http.StatusUnauthorized, \"Unauthorized\", \"session_id claim is required\")\n126: \t\t\treturn\n127: \t\t}\n128: \n129: \t\t// If session manager is available, validate the session\n130: \t\tif m.sessionManager != nil {\n131: \t\t\t// Session validation would be done here\n132: \t\t\t// For now, we just check that session_id is present\n133: \t\t\tklog.V(5).Infof(\"Session check for session_id: %s\", claims.SessionID)\n134: \t\t}\n135: \n136: \t\tnext.ServeHTTP(w, r)\n137: \t})\n138: }\n139: \n140: // RequireClaims returns an HTTP handler that verifies specific claims are present.\n141: func (m *JWTMiddleware) RequireClaims(claimNames []string, next http.Handler) http.Handler {\n142: \treturn http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n143: \t\tclaims, ok := GetTokenClaims(r.Context())\n144: \t\tif !ok {\n145: \t\t\twriteAuthError(w, http.StatusUnauthorized, \"Unauthorized\", \"token claims not found in context\")\n146: \t\t\treturn\n147: \t\t}\n148: \n149: \t\tfor _, name := range claimNames {\n150: \t\t\tif !hasClaim(claims, name) {\n151: \t\t\t\twriteAuthError(w, http.StatusForbidden, \"Forbidden\", \"missing required claim: \"+name)\n152: \t\t\t\treturn\n153: \t\t\t}\n154: \t\t}\n155: \n156: \t\tnext.ServeHTTP(w, r)\n157: \t})\n158: }\n159: \n160: // hasClaim checks if the token claims contain the specified claim.\n161: func hasClaim(claims *TokenClaims, name string) bool {\n162: \tswitch name {\n163: \tcase \"session_id\":\n164: \t\treturn claims.SessionID != \"\"\n165: \tcase \"user_id\":\n166: \t\treturn claims.UserID != \"\"\n167: \tcase \"sandbox_id\":\n168: \t\treturn claims.SandboxID != \"\"\n169: \tcase \"namespace\":\n170: \t\treturn claims.Namespace != \"\"\n171: \tcase \"runtime_kind\":\n172: \t\treturn claims.RuntimeKind != \"\"\n173: \tdefault:\n174: \t\treturn false\n175: \t}\n176: }\n177: \n178: // extractBearerToken extracts the Bearer token from the Authorization header.\n179: func extractBearerToken(r *http.Request) (string, error) {\n180: \tauthHeader := r.Header.Get(\"Authorization\")\n181: \tif authHeader == \"\" {\n182: \t\treturn \"\", ErrTokenInvalid\n183: \t}\n184: \n185: \tparts := strings.SplitN(authHeader, \" \", 2)\n186: \tif len(parts) != 2 || strings.ToLower(parts[0]) != \"bearer\" {\n187: \t\treturn \"\", ErrTokenInvalid\n188: \t}\n189: \n190: \treturn strings.TrimSpace(parts[1]), nil\n191: }\n192: \n193: // authErrorResponse represents an authentication error response.\n194: type authErrorResponse struct {\n195: \tError       string `json:\"error\"`\n196: \tDescription string `json:\"error_description,omitempty\"`\n197: \tCode        string `json:\"code,omitempty\"`\n198: }\n199: \n200: // writeAuthError writes an authentication error response.\n201: func writeAuthError(w http.ResponseWriter, status int, message, description string) {\n202: \tw.Header().Set(\"Content-Type\", \"application/json\")\n203: \tw.Header().Set(\"WWW-Authenticate\", `Bearer error=\"`+message+`\"`)\n204: \tw.WriteHeader(status)\n205: \n206: \tresp := authErrorResponse{\n207: \t\tError:       message,\n208: \t\tDescription: description,\n209: \t\tCode:        description,\n210: \t}\n211: \n212: \tif err := json.NewEncoder(w).Encode(resp); err != nil {\n213: \t\tklog.Errorf(\"Failed to encode auth error response: %v\", err)\n214: \t}\n215: }\n216: \n217: // WithTokenClaims stores TokenClaims in the context.\n218: func WithTokenClaims(ctx context.Context, claims *TokenClaims) context.Context {\n219: \treturn context.WithValue(ctx, TokenClaimsContextKey, claims)\n220: }\n221: \n222: // GetTokenClaims retrieves TokenClaims from the context.\n223: // Returns the claims and true if found, nil and false otherwise.\n224: func GetTokenClaims(ctx context.Context) (*TokenClaims, bool) {\n225: \tclaims, ok := ctx.Value(TokenClaimsContextKey).(*TokenClaims)\n226: \treturn claims, ok\n227: }\n228: \n229: // MustGetTokenClaims retrieves TokenClaims from the context or panics.\n230: // Use this when you know the claims should be present.\n231: func MustGetTokenClaims(ctx context.Context) *TokenClaims {\n232: \tclaims, ok := GetTokenClaims(ctx)\n233: \tif !ok {\n234: \t\tpanic(\"token claims not found in context\")\n235: \t}\n236: \treturn claims\n237: }\n\n(End of file - total 237 lines)\n</content>","metadata":{"preview":"/*\nCopyright 2026 The Volcano Authors.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\npackage router\n\nimport (\n\t\"context\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/router/jwt_middleware.go","time":{"start":1775863953713,"end":1775863953726}}}}
{"type":"tool_use","timestamp":1775863953731,"sessionID":"ses_28644a1e1ffeXevK8ggqv8mK5C","part":{"id":"prt_d79bd74d0001SRWnrNBJ9RTMvH","messageID":"msg_d79bcd020001hkOxPRRXHfCpvp","sessionID":"ses_28644a1e1ffeXevK8ggqv8mK5C","type":"tool","tool":"read","callID":"toolu_functions.read:18","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/router/jwt_handlers.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/router/jwt_handlers.go</path>\n<type>file</type>\n<content>\n1: /*\n2: Copyright 2026 The Volcano Authors.\n3: \n4: Licensed under the Apache License, Version 2.0 (the \"License\");\n5: you may not use this file except in compliance with the License.\n6: You may obtain a copy of the License at\n7: \n8:     http://www.apache.org/licenses/LICENSE-2.0\n9: \n10: Unless required by applicable law or agreed to in writing, software\n11: distributed under the License is distributed on an \"AS IS\" BASIS,\n12: WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n13: See the License for the specific language governing permissions and\n14: limitations under the License.\n15: */\n16: \n17: package router\n18: \n19: import (\n20: \t\"encoding/json\"\n21: \t\"net/http\"\n22: \n23: \t\"k8s.io/klog/v2\"\n24: )\n25: \n26: // JWTHandlers provides HTTP handlers for JWT operations.\n27: type JWTHandlers struct {\n28: \tjwtManager *JWTManager\n29: \tmetrics    *JWTMetrics\n30: }\n31: \n32: // NewJWTHandlers creates a new JWTHandlers instance.\n33: func NewJWTHandlers(jwtManager *JWTManager) *JWTHandlers {\n34: \treturn &JWTHandlers{\n35: \t\tjwtManager: jwtManager,\n36: \t}\n37: }\n38: \n39: // NewJWTHandlersWithMetrics creates a new JWTHandlers instance with metrics.\n40: func NewJWTHandlersWithMetrics(jwtManager *JWTManager, metrics *JWTMetrics) *JWTHandlers {\n41: \treturn &JWTHandlers{\n42: \t\tjwtManager: jwtManager,\n43: \t\tmetrics:    metrics,\n44: \t}\n45: }\n46: \n47: // HandleTokenGenerate handles requests to generate new tokens.\n48: // POST /v1/tokens\n49: func (h *JWTHandlers) HandleTokenGenerate(w http.ResponseWriter, r *http.Request) {\n50: \tif r.Method != http.MethodPost {\n51: \t\twriteErrorResponse(w, http.StatusMethodNotAllowed, \"Method not allowed\", \"\")\n52: \t\treturn\n53: \t}\n54: \n55: \tif h.metrics != nil {\n56: \t\th.metrics.RecordTokenGeneration(\"generate\", r.Context().Err())\n57: \t}\n58: \n59: \tvar req TokenRequest\n60: \tif err := json.NewDecoder(r.Body).Decode(&req); err != nil {\n61: \t\twriteErrorResponse(w, http.StatusBadRequest, \"Invalid request body\", err.Error())\n62: \t\treturn\n63: \t}\n64: \n65: \t// Validate required fields\n66: \tif req.SessionID == \"\" {\n67: \t\twriteErrorResponse(w, http.StatusBadRequest, \"Missing required field\", \"session_id is required\")\n68: \t\treturn\n69: \t}\n70: \n71: \t// Build claims\n72: \tclaims := map[string]interface{}{\n73: \t\t\"session_id\": req.SessionID,\n74: \t}\n75: \tif req.UserID != \"\" {\n76: \t\tclaims[\"user_id\"] = req.UserID\n77: \t}\n78: \tif req.SandboxID != \"\" {\n79: \t\tclaims[\"sandbox_id\"] = req.SandboxID\n80: \t}\n81: \tif req.Namespace != \"\" {\n82: \t\tclaims[\"namespace\"] = req.Namespace\n83: \t}\n84: \tif req.RuntimeKind != \"\" {\n85: \t\tclaims[\"runtime_kind\"] = req.RuntimeKind\n86: \t}\n87: \n88: \t// Add custom claims\n89: \tfor k, v := range req.CustomClaims {\n90: \t\tclaims[k] = v\n91: \t}\n92: \n93: \t// Generate token pair\n94: \ttokens, metadata, err := h.jwtManager.GenerateTokenPair(claims)\n95: \tif err != nil {\n96: \t\tklog.Errorf(\"Failed to generate token pair: %v\", err)\n97: \t\twriteErrorResponse(w, http.StatusInternalServerError, \"Failed to generate tokens\", err.Error())\n98: \t\treturn\n99: \t}\n100: \n101: \tresp := TokenResponse{\n102: \t\tTokens:   *tokens,\n103: \t\tMetadata: *metadata,\n104: \t}\n105: \n106: \tw.Header().Set(\"Content-Type\", \"application/json\")\n107: \tw.WriteHeader(http.StatusOK)\n108: \tif err := json.NewEncoder(w).Encode(resp); err != nil {\n109: \t\tklog.Errorf(\"Failed to encode token response: %v\", err)\n110: \t}\n111: }\n112: \n113: // HandleTokenRefresh handles requests to refresh tokens.\n114: // POST /v1/tokens/refresh\n115: func (h *JWTHandlers) HandleTokenRefresh(w http.ResponseWriter, r *http.Request) {\n116: \tif r.Method != http.MethodPost {\n117: \t\twriteErrorResponse(w, http.StatusMethodNotAllowed, \"Method not allowed\", \"\")\n118: \t\treturn\n119: \t}\n120: \n121: \tif h.metrics != nil {\n122: \t\th.metrics.RecordTokenValidation(\"refresh\", r.Context().Err())\n123: \t}\n124: \n125: \tvar req TokenRefreshRequest\n126: \tif err := json.NewDecoder(r.Body).Decode(&req); err != nil {\n127: \t\twriteErrorResponse(w, http.StatusBadRequest, \"Invalid request body\", err.Error())\n128: \t\treturn\n129: \t}\n130: \n131: \tif req.RefreshToken == \"\" {\n132: \t\twriteErrorResponse(w, http.StatusBadRequest, \"Missing required field\", \"refresh_token is required\")\n133: \t\treturn\n134: \t}\n135: \n136: \t// Refresh the token\n137: \ttokens, metadata, err := h.jwtManager.RefreshToken(req.RefreshToken)\n138: \tif err != nil {\n139: \t\tklog.V(4).Infof(\"Token refresh failed: %v\", err)\n140: \n141: \t\tstatus := http.StatusUnauthorized\n142: \t\tmessage := \"Failed to refresh token\"\n143: \n144: \t\tif IsTokenExpiredError(err) {\n145: \t\t\tmessage = \"Refresh token has expired\"\n146: \t\t} else if IsTokenInvalidError(err) {\n147: \t\t\tmessage = \"Invalid refresh token\"\n148: \t\t}\n149: \n150: \t\twriteErrorResponse(w, status, message, err.Error())\n151: \t\treturn\n152: \t}\n153: \n154: \tresp := TokenResponse{\n155: \t\tTokens:   *tokens,\n156: \t\tMetadata: *metadata,\n157: \t}\n158: \n159: \tw.Header().Set(\"Content-Type\", \"application/json\")\n160: \tw.WriteHeader(http.StatusOK)\n161: \tif err := json.NewEncoder(w).Encode(resp); err != nil {\n162: \t\tklog.Errorf(\"Failed to encode refresh response: %v\", err)\n163: \t}\n164: }\n165: \n166: // HandlePublicKey handles requests to get the public key.\n167: // GET /v1/keys/public\n168: func (h *JWTHandlers) HandlePublicKey(w http.ResponseWriter, r *http.Request) {\n169: \tif r.Method != http.MethodGet {\n170: \t\twriteErrorResponse(w, http.StatusMethodNotAllowed, \"Method not allowed\", \"\")\n171: \t\treturn\n172: \t}\n173: \n174: \tpublicKeyPEM, err := h.jwtManager.GetPublicKeyPEM()\n175: \tif err != nil {\n176: \t\tklog.Errorf(\"Failed to get public key: %v\", err)\n177: \t\twriteErrorResponse(w, http.StatusInternalServerError, \"Failed to get public key\", err.Error())\n178: \t\treturn\n179: \t}\n180: \n181: \tresp := PublicKeyResponse{\n182: \t\tPublicKey: string(publicKeyPEM),\n183: \t\tAlgorithm: \"RS256\",\n184: \t\tKeyID:     h.jwtManager.GetKeyVersion(),\n185: \t}\n186: \n187: \tw.Header().Set(\"Content-Type\", \"application/json\")\n188: \tw.WriteHeader(http.StatusOK)\n189: \tif err := json.NewEncoder(w).Encode(resp); err != nil {\n190: \t\tklog.Errorf(\"Failed to encode public key response: %v\", err)\n191: \t}\n192: }\n193: \n194: // HandleTokenValidate handles requests to validate tokens.\n195: // POST /v1/tokens/validate\n196: func (h *JWTHandlers) HandleTokenValidate(w http.ResponseWriter, r *http.Request) {\n197: \tif r.Method != http.MethodPost {\n198: \t\twriteErrorResponse(w, http.StatusMethodNotAllowed, \"Method not allowed\", \"\")\n199: \t\treturn\n200: \t}\n201: \n202: \tvar req TokenValidateRequest\n203: \tif err := json.NewDecoder(r.Body).Decode(&req); err != nil {\n204: \t\twriteErrorResponse(w, http.StatusBadRequest, \"Invalid request body\", err.Error())\n205: \t\treturn\n206: \t}\n207: \n208: \tif req.Token == \"\" {\n209: \t\twriteErrorResponse(w, http.StatusBadRequest, \"Missing required field\", \"token is required\")\n210: \t\treturn\n211: \t}\n212: \n213: \t// Validate the token\n214: \tclaims, err := h.jwtManager.ValidateToken(req.Token)\n215: \n216: \tif h.metrics != nil {\n217: \t\th.metrics.RecordTokenValidation(\"validate\", err)\n218: \t}\n219: \n220: \tif err != nil {\n221: \t\tklog.V(4).Infof(\"Token validation failed: %v\", err)\n222: \n223: \t\terrorCode := string(GetJWTErrorCode(err))\n224: \t\tif errorCode == \"\" {\n225: \t\t\terrorCode = \"TOKEN_INVALID\"\n226: \t\t}\n227: \n228: \t\tresp := TokenValidateResponse{\n229: \t\t\tValid:     false,\n230: \t\t\tError:     err.Error(),\n231: \t\t\tErrorCode: errorCode,\n232: \t\t}\n233: \n234: \t\tw.Header().Set(\"Content-Type\", \"application/json\")\n235: \t\tw.WriteHeader(http.StatusOK)\n236: \t\tjson.NewEncoder(w).Encode(resp)\n237: \t\treturn\n238: \t}\n239: \n240: \tresp := TokenValidateResponse{\n241: \t\tValid:  true,\n242: \t\tClaims: claims,\n243: \t}\n244: \n245: \tw.Header().Set(\"Content-Type\", \"application/json\")\n246: \tw.WriteHeader(http.StatusOK)\n247: \tif err := json.NewEncoder(w).Encode(resp); err != nil {\n248: \t\tklog.Errorf(\"Failed to encode validate response: %v\", err)\n249: \t}\n250: }\n251: \n252: // errorResponse represents an error response.\n253: type errorResponse struct {\n254: \tError       string `json:\"error\"`\n255: \tDescription string `json:\"description,omitempty\"`\n256: }\n257: \n258: // writeErrorResponse writes an error response.\n259: func writeErrorResponse(w http.ResponseWriter, status int, message, description string) {\n260: \tw.Header().Set(\"Content-Type\", \"application/json\")\n261: \tw.WriteHeader(status)\n262: \n263: \tresp := errorResponse{\n264: \t\tError:       message,\n265: \t\tDescription: description,\n266: \t}\n267: \n268: \tif err := json.NewEncoder(w).Encode(resp); err != nil {\n269: \t\tklog.Errorf(\"Failed to encode error response: %v\", err)\n270: \t}\n271: }\n\n(End of file - total 271 lines)\n</content>","metadata":{"preview":"/*\nCopyright 2026 The Volcano Authors.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\npackage router\n\nimport (\n\t\"encoding/json\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/router/jwt_handlers.go","time":{"start":1775863953717,"end":1775863953729}}}}
