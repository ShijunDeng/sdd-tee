e default CPU limit.\n275: \tDefaultCPULimit = \"1000m\"\n276: \n277: \t// DefaultMemoryRequest is the default memory request.\n278: \tDefaultMemoryRequest = \"128Mi\"\n279: \n280: \t// DefaultMemoryLimit is the default memory limit.\n281: \tDefaultMemoryLimit = \"1Gi\"\n282: )\n283: \n284: // Status condition constants.\n285: const (\n286: \t// StatusTrue represents a true condition status.\n287: \tStatusTrue = \"True\"\n288: \n289: \t// StatusFalse represents a false condition status.\n290: \tStatusFalse = \"False\"\n291: \n292: \t// StatusUnknown represents an unknown condition status.\n293: \tStatusUnknown = \"Unknown\"\n294: )\n295: \n296: // Finalizer constants for resource cleanup.\n297: const (\n298: \t// FinalizerSandbox is the finalizer for sandbox cleanup.\n299: \tFinalizerSandbox = \"runtime.agentcube.volcano.sh/sandbox-cleanup\"\n300: \n301: \t// FinalizerResource is the finalizer for general resource cleanup.\n302: \tFinalizerResource = \"runtime.agentcube.volcano.sh/resource-cleanup\"\n303: )\n304: \n305: // Event reason constants for Kubernetes events.\n306: const (\n307: \t// EventReasonCreated indicates a resource was created.\n308: \tEventReasonCreated = \"Created\"\n309: \n310: \t// EventReasonUpdated indicates a resource was updated.\n311: \tEventReasonUpdated = \"Updated\"\n312: \n313: \t// EventReasonDeleted indicates a resource was deleted.\n314: \tEventReasonDeleted = \"Deleted\"\n315: \n316: \t// EventReasonFailed indicates a resource operation failed.\n317: \tEventReasonFailed = \"Failed\"\n318: \n319: \t// EventReasonSucceeded indicates a resource operation succeeded.\n320: \tEventReasonSucceeded = \"Succeeded\"\n321: \n322: \t// EventReasonSandboxCreated indicates a sandbox was created.\n323: \tEventReasonSandboxCreated = \"SandboxCreated\"\n324: \n325: \t// EventReasonSandboxDeleted indicates a sandbox was deleted.\n326: \tEventReasonSandboxDeleted = \"SandboxDeleted\"\n327: \n328: \t// EventReasonSandboxFailed indicates a sandbox operation failed.\n329: \tEventReasonSandboxFailed = \"SandboxFailed\"\n330: \n331: \t// EventReasonTimeout indicates a timeout occurred.\n332: \tEventReasonTimeout = \"Timeout\"\n333: \n334: \t// EventReasonIdle indicates an idle timeout occurred.\n335: \tEventReasonIdle = \"Idle\"\n336: )\n337: \n338: // Error message constants for consistent error reporting.\n339: const (\n340: \t// ErrMsgResourceNotFound is the error message for resource not found.\n341: \tErrMsgResourceNotFound = \"resource not found\"\n342: \n343: \t// ErrMsgResourceAlreadyExists is the error message for resource already exists.\n344: \tErrMsgResourceAlreadyExists = \"resource already exists\"\n345: \n346: \t// ErrMsgInvalidSpec is the error message for invalid spec.\n347: \tErrMsgInvalidSpec = \"invalid spec\"\n348: \n349: \t// ErrMsgSandboxCreationFailed is the error message for sandbox creation failure.\n350: \tErrMsgSandboxCreationFailed = \"sandbox creation failed\"\n351: \n352: \t// ErrMsgSandboxNotReady is the error message for sandbox not ready.\n353: \tErrMsgSandboxNotReady = \"sandbox not ready\"\n354: \n355: \t// ErrMsgTimeout is the error message for timeout.\n356: \tErrMsgTimeout = \"operation timed out\"\n357: \n358: \t// ErrMsgUnauthorized is the error message for unauthorized access.\n359: \tErrMsgUnauthorized = \"unauthorized\"\n360: \n361: \t// ErrMsgForbidden is the error message for forbidden access.\n362: \tErrMsgForbidden = \"forbidden\"\n363: )\n\n(End of file - total 363 lines)\n</content>","metadata":{"preview":"/*\nCopyright 2026 The Volcano Authors.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or