{"type":"tool_use","timestamp":1775842758333,"sessionID":"ses_2878684e2ffezY1s0Ga7zERhoa","part":{"id":"prt_d7879f4e2001xqg6ffG5W0tIGc","messageID":"msg_d7879d560001aHtKCgJfv6n6Hd","sessionID":"ses_2878684e2ffezY1s0Ga7zERhoa","type":"tool","tool":"read","callID":"toolu_functions.read:10","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/apis/runtime/v1alpha1/common_types_test.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/apis/runtime/v1alpha1/common_types_test.go</path>\n<type>file</type>\n<content>\n1: /*\n2: Copyright 2026 The Volcano Authors.\n3: \n4: Licensed under the Apache License, Version 2.0 (the \"License\");\n5: you may not use this file except in compliance with the License.\n6: You may obtain a copy of the License at\n7: \n8:     http://www.apache.org/licenses/LICENSE-2.0\n9: \n10: Unless required by applicable law or agreed to in writing, software\n11: distributed under the License is distributed on an \"AS IS\" BASIS,\n12: WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n13: See the License for the specific language governing permissions and\n14: limitations under the License.\n15: */\n16: \n17: package v1alpha1\n18: \n19: import (\n20: \t\"encoding/json\"\n21: \t\"testing\"\n22: \t\"time\"\n23: \n24: \tcorev1 \"k8s.io/api/core/v1\"\n25: \tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n26: )\n27: \n28: func TestPhaseValues(t *testing.T) {\n29: \ttests := []struct {\n30: \t\tname     string\n31: \t\tphase    Phase\n32: \t\texpected string\n33: \t}{\n34: \t\t{\"Pending\", PhasePending, \"Pending\"},\n35: \t\t{\"Running\", PhaseRunning, \"Running\"},\n36: \t\t{\"Succeeded\", PhaseSucceeded, \"Succeeded\"},\n37: \t\t{\"Failed\", PhaseFailed, \"Failed\"},\n38: \t\t{\"Unknown\", PhaseUnknown, \"Unknown\"},\n39: \t}\n40: \n41: \tfor _, tt := range tests {\n42: \t\tt.Run(tt.name, func(t *testing.T) {\n43: \t\t\tif string(tt.phase) != tt.expected {\n44: \t\t\t\tt.Errorf(\"Expected phase %s, got %s\", tt.expected, tt.phase)\n45: \t\t\t}\n46: \t\t})\n47: \t}\n48: }\n49: \n50: func TestConditionTypeValues(t *testing.T) {\n51: \ttests := []struct {\n52: \t\tname     string\n53: \t\tcondType ConditionType\n54: \t\texpected string\n55: \t}{\n56: \t\t{\"Ready\", ConditionReady, \"Ready\"},\n57: \t\t{\"SandboxCreated\", ConditionSandboxCreated, \"SandboxCreated\"},\n58: \t\t{\"SandboxReady\", ConditionSandboxReady, \"SandboxReady\"},\n59: \t\t{\"Failed\", ConditionFailed, \"Failed\"},\n60: \t\t{\"Scheduled\", ConditionScheduled, \"Scheduled\"},\n61: \t\t{\"Initialized\", ConditionInitialized, \"Initialized\"},\n62: \t}\n63: \n64: \tfor _, tt := range tests {\n65: \t\tt.Run(tt.name, func(t *testing.T) {\n66: \t\t\tif string(tt.condType) != tt.expected {\n67: \t\t\t\tt.Errorf(\"Expected condition type %s, got %s\", tt.expected, tt.condType)\n68: \t\t\t}\n69: \t\t})\n70: \t}\n71: }\n72: \n73: func TestStorageTypeValues(t *testing.T) {\n74: \ttests := []struct {\n75: \t\tname     string\n76: \t\tstorage  StorageType\n77: \t\texpected string\n78: \t}{\n79: \t\t{\"EmptyDir\", StorageTypeEmptyDir, \"EmptyDir\"},\n80: \t\t{\"HostPath\", StorageTypeHostPath, \"HostPath\"},\n81: \t\t{\"PersistentVolumeClaim\", StorageTypePersistentVolumeClaim, \"PersistentVolumeClaim\"},\n82: \t\t{\"ConfigMap\", StorageTypeConfigMap, \"ConfigMap\"},\n83: \t\t{\"Secret\", StorageTypeSecret, \"Secret\"},\n84: \t}\n85: \n86: \tfor _, tt := range tests {\n87: \t\tt.Run(tt.name, func(t *testing.T) {\n88: \t\t\tif string(tt.storage) != tt.expected {\n89: \t\t\t\tt.Errorf(\"Expected storage type %s, got %s\", tt.expected, tt.storage)\n90: \t\t\t}\n91: \t\t})\n92: \t}\n93: }\n94: \n95: func TestCondition(t *testing.T) {\n96: \tnow := metav1.NewTime(time.Now())\n97: \n98: \ttests := []struct {\n99: \t\tname      string\n100: \t\tcondition Condition\n101: \t}{\n102: \t\t{\n103: \t\t\tname: \"minimal condition\",\n104: \t\t\tcondition: Condition{\n105: \t\t\t\tType:   ConditionReady,\n106: \t\t\t\tStatus: corev1.ConditionTrue,\n107: \t\t\t},\n108: \t\t},\n109: \t\t{\n110: \t\t\tname: \"full condition\",\n111: \t\t\tcondition: Condition{\n112: \t\t\t\tType:               ConditionSandboxReady,\n113: \t\t\t\tStatus:             corev1.ConditionTrue,\n114: \t\t\t\tLastTransitionTime: now,\n115: \t\t\t\tReason:             \"SandboxCreated\",\n116: \t\t\t\tMessage:            \"Sandbox is ready for use\",\n117: \t\t\t\tObservedGeneration: 1,\n118: \t\t\t},\n119: \t\t},\n120: \t\t{\n121: \t\t\tname: \"failed condition\",\n122: \t\t\tcondition: Condition{\n123: \t\t\t\tType:               ConditionFailed,\n124: \t\t\t\tStatus:             corev1.ConditionFalse,\n125: \t\t\t\tLastTransitionTime: now,\n126: \t\t\t\tReason:             \"SandboxCreationFailed\",\n127: \t\t\t\tMessage:            \"Failed to create sandbox pod\",\n128: \t\t\t\tObservedGeneration: 2,\n129: \t\t\t},\n130: \t\t},\n131: \t}\n132: \n133: \tfor _, tt := range tests {\n134: \t\tt.Run(tt.name, func(t *testing.T) {\n135: \t\t\tif tt.condition.Type == \"\" {\n136: \t\t\t\tt.Error(\"Condition Type should not be empty\")\n137: \t\t\t}\n138: \t\t\tif tt.condition.Status == \"\" {\n139: \t\t\t\tt.Error(\"Condition Status should not be empty\")\n140: \t\t\t}\n141: \t\t})\n142: \t}\n143: }\n144: \n145: func TestResourceReference(t *testing.T) {\n146: \ttests := []struct {\n147: \t\tname      string\n148: \t\tref       ResourceReference\n149: \t\twantName  string\n150: \t\twantNS    string\n151: \t}{\n152: \t\t{\n153: \t\t\tname: \"simple reference\",\n154: \t\t\tref: ResourceReference{\n155: \t\t\t\tName: \"my-secret\",\n156: \t\t\t},\n157: \t\t\twantName: \"my-secret\",\n158: \t\t\twantNS:   \"\",\n159: \t\t},\n160: \t\t{\n161: \t\t\tname: \"reference with namespace\",\n162: \t\t\tref: ResourceReference{\n163: \t\t\t\tName:      \"my-config\",\n164: \t\t\t\tNamespace: \"other-namespace\",\n165: \t\t\t},\n166: \t\t\twantName: \"my-config\",\n167: \t\t\twantNS:   \"other-namespace\",\n168: \t\t},\n169: \t}\n170: \n171: \tfor _, tt := range tests {\n172: \t\tt.Run(tt.name, func(t *testing.T) {\n173: \t\t\tif tt.ref.Name != tt.wantName {\n174: \t\t\t\tt.Errorf(\"Expected name %s, got %s\", tt.wantName, tt.ref.Name)\n175: \t\t\t}\n176: \t\t\tif tt.ref.Namespace != tt.wantNS {\n177: \t\t\t\tt.Errorf(\"Expected namespace %s, got %s\", tt.wantNS, tt.ref.Namespace)\n178: \t\t\t}\n179: \t\t})\n180: \t}\n181: }\n182: \n183: func TestLocalResourceReference(t *testing.T) {\n184: \tref := LocalResourceReference{\n185: \t\tName: \"my-resource\",\n186: \t}\n187: \n188: \tif ref.Name != \"my-resource\" {\n189: \t\tt.Errorf(\"Expected name 'my-resource', got %s\", ref.Name)\n190: \t}\n191: }\n192: \n193: func TestSecretReference(t *testing.T) {\n194: \ttests := []struct {\n195: \t\tname     string\n196: \t\tref      SecretReference\n197: \t\twantName string\n198: \t\twantKey  string\n199: \t}{\n200: \t\t{\n201: \t\t\tname: \"secret without key\",\n202: \t\t\tref: SecretReference{\n203: \t\t\t\tName: \"my-secret\",\n204: \t\t\t},\n205: \t\t\twantName: \"my-secret\",\n206: \t\t\twantKey:  \"\",\n207: \t\t},\n208: \t\t{\n209: \t\t\tname: \"secret with key\",\n210: \t\t\tref: SecretReference{\n211: \t\t\t\tName: \"my-secret\",\n212: \t\t\t\tKey:  \"password\",\n213: \t\t\t},\n214: \t\t\twantName: \"my-secret\",\n215: \t\t\twantKey:  \"password\",\n216: \t\t},\n217: \t}\n218: \n219: \tfor _, tt := range tests {\n220: \t\tt.Run(tt.name, func(t *testing.T) {\n221: \t\t\tif tt.ref.Name != tt.wantName {\n222: \t\t\t\tt.Errorf(\"Expected name %s, got %s\", tt.wantName, tt.ref.Name)\n223: \t\t\t}\n224: \t\t\tif tt.ref.Key != tt.wantKey {\n225: \t\t\t\tt.Errorf(\"Expected key %s, got %s\", tt.wantKey, tt.ref.Key)\n226: \t\t\t}\n227: \t\t})\n228: \t}\n229: }\n230: \n231: func TestConfigMapReference(t *testing.T) {\n232: \ttests := []struct {\n233: \t\tname     string\n234: \t\tref      ConfigMapReference\n235: \t\twantName string\n236: \t\twantKey  string\n237: \t}{\n238: \t\t{\n239: \t\t\tname: \"configmap without key\",\n240: \t\t\tref: ConfigMapReference{\n241: \t\t\t\tName: \"my-config\",\n242: \t\t\t},\n243: \t\t\twantName: \"my-config\",\n244: \t\t\twantKey:  \"\",\n245: \t\t},\n246: \t\t{\n247: \t\t\tname: \"configmap with key\",\n248: \t\t\tref: ConfigMapReference{\n249: \t\t\t\tName: \"my-config\",\n250: \t\t\t\tKey:  \"data\",\n251: \t\t\t},\n252: \t\t\twantName: \"my-config\",\n253: \t\t\twantKey:  \"data\",\n254: \t\t},\n255: \t}\n256: \n257: \tfor _, tt := range tests {\n258: \t\tt.Run(tt.name, func(t *testing.T) {\n259: \t\t\tif tt.ref.Name != tt.wantName {\n260: \t\t\t\tt.Errorf(\"Expected name %s, got %s\", tt.wantName, tt.ref.Name)\n261: \t\t\t}\n262: \t\t\tif tt.ref.Key != tt.wantKey {\n263: \t\t\t\tt.Errorf(\"Expected key %s, got %s\", tt.wantKey, tt.ref.Key)\n264: \t\t\t}\n265: \t\t})\n266: \t}\n267: }\n268: \n269: func TestResourceRequirements(t *testing.T) {\n270: \treq := ResourceRequirements{\n271: \t\tLimits: corev1.ResourceList{\n272: \t\t\tcorev1.ResourceCPU:    mustParseQuantity(\"1000m\"),\n273: \t\t\tcorev1.ResourceMemory: mustParseQuantity(\"1Gi\"),\n274: \t\t},\n275: \t\tRequests: corev1.ResourceList{\n276: \t\t\tcorev1.ResourceCPU:    mustParseQuantity(\"500m\"),\n277: \t\t\tcorev1.ResourceMemory: mustParseQuantity(\"512Mi\"),\n278: \t\t},\n279: \t}\n280: \n281: \tif req.Limits.Cpu().MilliValue() != 1000 {\n282: \t\tt.Errorf(\"Expected CPU limit 1000m, got %d\", req.Limits.Cpu().MilliValue())\n283: \t}\n284: \n285: \tif req.Requests.Cpu().MilliValue() != 500 {\n286: \t\tt.Errorf(\"Expected CPU request 500m, got %d\", req.Requests.Cpu().MilliValue())\n287: \t}\n288: }\n289: \n290: func TestSandboxTemplate(t *testing.T) {\n291: \ttests := []struct {\n292: \t\tname     string\n293: \t\ttemplate SandboxTemplate\n294: \t}{\n295: \t\t{\n296: \t\t\tname:     \"empty template\",\n297: \t\t\ttemplate: SandboxTemplate{},\n298: \t\t},\n299: \t\t{\n300: \t\t\tname: \"template with labels\",\n301: \t\t\ttemplate: SandboxTemplate{\n302: \t\t\t\tLabels: map[string]string{\n303: \t\t\t\t\t\"app\":     \"test\",\n304: \t\t\t\t\t\"version\": \"v1\",\n305: \t\t\t\t},\n306: \t\t\t},\n307: \t\t},\n308: \t\t{\n309: \t\t\tname: \"template with annotations\",\n310: \t\t\ttemplate: SandboxTemplate{\n311: \t\t\t\tAnnotations: map[string]string{\n312: \t\t\t\t\t\"description\": \"Test sandbox\",\n313: \t\t\t\t},\n314: \t\t\t},\n315: \t\t},\n316: \t\t{\n317: \t\t\tname: \"template with spec\",\n318: \t\t\ttemplate: SandboxTemplate{\n319: \t\t\t\tSpec: &corev1.PodSpec{\n320: \t\t\t\t\tContainers: []corev1.Container{\n321: \t\t\t\t\t\t{\n322: \t\t\t\t\t\t\tName:  \"test\",\n323: \t\t\t\t\t\t\tImage: \"busybox:latest\",\n324: \t\t\t\t\t\t},\n325: \t\t\t\t\t},\n326: \t\t\t\t},\n327: \t\t\t},\n328: \t\t},\n329: \t\t{\n330: \t\t\tname: \"full template\",\n331: \t\t\ttemplate: SandboxTemplate{\n332: \t\t\t\tLabels: map[string]string{\n333: \t\t\t\t\t\"app\": \"test\",\n334: \t\t\t\t},\n335: \t\t\t\tAnnotations: map[string]string{\n336: \t\t\t\t\t\"description\": \"Test sandbox\",\n337: \t\t\t\t},\n338: \t\t\t\tSpec: &corev1.PodSpec{\n339: \t\t\t\t\tContainers: []corev1.Container{\n340: \t\t\t\t\t\t{\n341: \t\t\t\t\t\t\tName:  \"main\",\n342: \t\t\t\t\t\t\tImage: \"ubuntu:22.04\",\n343: \t\t\t\t\t\t},\n344: \t\t\t\t\t},\n345: \t\t\t\t},\n346: \t\t\t},\n347: \t\t},\n348: \t}\n349: \n350: \tfor _, tt := range tests {\n351: \t\tt.Run(tt.name, func(t *testing.T) {\n352: \t\t\t// Just verify the template can be created\n353: \t\t\t_ = tt.template\n354: \t\t})\n355: \t}\n356: }\n357: \n358: func TestVolumeSource(t *testing.T) {\n359: \ttests := []struct {\n360: \t\tname   string\n361: \t\tvs     VolumeSource\n362: \t\twantType StorageType\n363: \t}{\n364: \t\t{\n365: \t\t\tname: \"empty dir volume\",\n366: \t\t\tvs: VolumeSource{\n367: \t\t\t\tType:     StorageTypeEmptyDir,\n368: \t\t\t\tEmptyDir: &corev1.EmptyDirVolumeSource{},\n369: \t\t\t},\n370: \t\t\twantType: StorageTypeEmptyDir,\n371: \t\t},\n372: \t\t{\n373: \t\t\tname: \"host path volume\",\n374: \t\t\tvs: VolumeSource{\n375: \t\t\t\tType: StorageTypeHostPath,\n376: \t\t\t\tHostPath: &corev1.HostPathVolumeSource{\n377: \t\t\t\t\tPath: \"/data\",\n378: \t\t\t\t},\n379: \t\t\t},\n380: \t\t\twantType: StorageTypeHostPath,\n381: \t\t},\n382: \t\t{\n383: \t\t\tname: \"pvc volume\",\n384: \t\t\tvs: VolumeSource{\n385: \t\t\t\tType: StorageTypePersistentVolumeClaim,\n386: \t\t\t\tPersistentVolumeClaim: &corev1.PersistentVolumeClaimVolumeSource{\n387: \t\t\t\t\tClaimName: \"my-pvc\",\n388: \t\t\t\t},\n389: \t\t\t},\n390: \t\t\twantType: StorageTypePersistentVolumeClaim,\n391: \t\t},\n392: \t\t{\n393: \t\t\tname: \"configmap volume\",\n394: \t\t\tvs: VolumeSource{\n395: \t\t\t\tType: StorageTypeConfigMap,\n396: \t\t\t\tConfigMap: &corev1.ConfigMapVolumeSource{\n397: \t\t\t\t\tLocalObjectReference: corev1.LocalObjectReference{\n398: \t\t\t\t\t\tName: \"my-config\",\n399: \t\t\t\t\t},\n400: \t\t\t\t},\n401: \t\t\t},\n402: \t\t\twantType: StorageTypeConfigMap,\n403: \t\t},\n404: \t\t{\n405: \t\t\tname: \"secret volume\",\n406: \t\t\tvs: VolumeSource{\n407: \t\t\t\tType: StorageTypeSecret,\n408: \t\t\t\tSecret: &corev1.SecretVolumeSource{\n409: \t\t\t\t\tSecretName: \"my-secret\",\n410: \t\t\t\t},\n411: \t\t\t},\n412: \t\t\twantType: StorageTypeSecret,\n413: \t\t},\n414: \t}\n415: \n416: \tfor _, tt := range tests {\n417: \t\tt.Run(tt.name, func(t *testing.T) {\n418: \t\t\tif tt.vs.Type != tt.wantType {\n419: \t\t\t\tt.Errorf(\"Expected type %s, got %s\", tt.wantType, tt.vs.Type)\n420: \t\t\t}\n421: \t\t})\n422: \t}\n423: }\n424: \n425: func TestVolumeMount(t *testing.T) {\n426: \ttests := []struct {\n427: \t\tname         string\n428: \t\tvm           VolumeMount\n429: \t\twantName     string\n430: \t\twantPath     string\n431: \t\twantReadOnly bool\n432: \t}{\n433: \t\t{\n434: \t\t\tname: \"basic mount\",\n435: \t\t\tvm: VolumeMount{\n436: \t\t\t\tName:      \"data\",\n437: \t\t\t\tMountPath: \"/data\",\n438: \t\t\t},\n439: \t\t\twantName:     \"data\",\n440: \t\t\twantPath:     \"/data\",\n441: \t\t\twantReadOnly: false,\n442: \t\t},\n443: \t\t{\n444: \t\t\tname: \"read-only mount\",\n445: \t\t\tvm: VolumeMount{\n446: \t\t\t\tName:      \"config\",\n447: \t\t\t\tMountPath: \"/etc/config\",\n448: \t\t\t\tReadOnly:  true,\n449: \t\t\t},\n450: \t\t\twantName:     \"config\",\n451: \t\t\twantPath:     \"/etc/config\",\n452: \t\t\twantReadOnly: true,\n453: \t\t},\n454: \t\t{\n455: \t\t\tname: \"mount with subpath\",\n456: \t\t\tvm: VolumeMount{\n457: \t\t\t\tName:      \"data\",\n458: \t\t\t\tMountPath: \"/data\",\n459: \t\t\t\tSubPath:   \"subdir\",\n460: \t\t\t},\n461: \t\t\twantName: \"data\",\n462: \t\t\twantPath: \"/data\",\n463: \t\t},\n464: \t}\n465: \n466: \tfor _, tt := range tests {\n467: \t\tt.Run(tt.name, func(t *testing.T) {\n468: \t\t\tif tt.vm.Name != tt.wantName {\n469: \t\t\t\tt.Errorf(\"Expected name %s, got %s\", tt.wantName, tt.vm.Name)\n470: \t\t\t}\n471: \t\t\tif tt.vm.MountPath != tt.wantPath {\n472: \t\t\t\tt.Errorf(\"Expected mount path %s, got %s\", tt.wantPath, tt.vm.MountPath)\n473: \t\t\t}\n474: \t\t\tif tt.vm.ReadOnly != tt.wantReadOnly {\n475: \t\t\t\tt.Errorf(\"Expected readOnly %v, got %v\", tt.wantReadOnly, tt.vm.ReadOnly)\n476: \t\t\t}\n477: \t\t})\n478: \t}\n479: }\n480: \n481: func TestNetworkConfig(t *testing.T) {\n482: \tnc := NetworkConfig{\n483: \t\tHostNetwork: true,\n484: \t\tHostPID:     true,\n485: \t\tHostIPC:     false,\n486: \t\tDNSPolicy:   corev1.DNSClusterFirst,\n487: \t\tDNSConfig: &corev1.PodDNSConfig{\n488: \t\t\tNameservers: []string{\"8.8.8.8\"},\n489: \t\t},\n490: \t}\n491: \n492: \tif !nc.HostNetwork {\n493: \t\tt.Error(\"Expected HostNetwork to be true\")\n494: \t}\n495: \n496: \tif !nc.HostPID {\n497: \t\tt.Error(\"Expected HostPID to be true\")\n498: \t}\n499: \n500: \tif nc.HostIPC {\n501: \t\tt.Error(\"Expected HostIPC to be false\")\n502: \t}\n503: \n504: \tif nc.DNSPolicy != corev1.DNSClusterFirst {\n505: \t\tt.Errorf(\"Expected DNSPolicy DNSClusterFirst, got %s\", nc.DNSPolicy)\n506: \t}\n507: \n508: \tif nc.DNSConfig == nil {\n509: \t\tt.Error(\"Expected DNSConfig to be set\")\n510: \t}\n511: }\n512: \n513: func TestSecurityContext(t *testing.T) {\n514: \tsc := SecurityContext{\n515: \t\tRunAsUser:                int64Ptr(1000),\n516: \t\tRunAsGroup:               int64Ptr(1000),\n517: \t\tRunAsNonRoot:             boolPtr(true),\n518: \t\tReadOnlyRootFilesystem:   boolPtr(true),\n519: \t\tPrivileged:               boolPtr(false),\n520: \t\tAllowPrivilegeEscalation: boolPtr(false),\n521: \t}\n522: \n523: \tif sc.RunAsUser == nil || *sc.RunAsUser != 1000 {\n524: \t\tt.Error(\"Expected RunAsUser to be 1000\")\n525: \t}\n526: \n527: \tif sc.RunAsGroup == nil || *sc.RunAsGroup != 1000 {\n528: \t\tt.Error(\"Expected RunAsGroup to be 1000\")\n529: \t}\n530: \n531: \tif sc.RunAsNonRoot == nil || !*sc.RunAsNonRoot {\n532: \t\tt.Error(\"Expected RunAsNonRoot to be true\")\n533: \t}\n534: \n535: \tif sc.ReadOnlyRootFilesystem == nil || !*sc.ReadOnlyRootFilesystem {\n536: \t\tt.Error(\"Expected ReadOnlyRootFilesystem to be true\")\n537: \t}\n538: \n539: \tif sc.Privileged == nil || *sc.Privileged {\n540: \t\tt.Error(\"Expected Privileged to be false\")\n541: \t}\n542: \n543: \tif sc.AllowPrivilegeEscalation == nil || *sc.AllowPrivilegeEscalation {\n544: \t\tt.Error(\"Expected AllowPrivilegeEscalation to be false\")\n545: \t}\n546: }\n547: \n548: func TestLifecycleHooks(t *testing.T) {\n549: \tlh := LifecycleHooks{\n550: \t\tPostStart: &corev1.LifecycleHandler{\n551: \t\t\tExec: &corev1.ExecAction{\n552: \t\t\t\tCommand: []string{\"echo\", \"started\"},\n553: \t\t\t},\n554: \t\t},\n555: \t\tPreStop: &corev1.LifecycleHandler{\n556: \t\t\tExec: &corev1.ExecAction{\n557: \t\t\t\tCommand: []string{\"echo\", \"stopping\"},\n558: \t\t\t},\n559: \t\t},\n560: \t}\n561: \n562: \tif lh.PostStart == nil {\n563: \t\tt.Error(\"Expected PostStart to be set\")\n564: \t}\n565: \n566: \tif lh.PreStop == nil {\n567: \t\tt.Error(\"Expected PreStop to be set\")\n568: \t}\n569: }\n570: \n571: func TestHealthCheck(t *testing.T) {\n572: \thc := HealthCheck{\n573: \t\tLivenessProbe: &corev1.Probe{\n574: \t\t\tProbeHandler: corev1.ProbeHandler{\n575: \t\t\t\tHTTPGet: &corev1.HTTPGetAction{\n576: \t\t\t\t\tPath: \"/health\",\n577: \t\t\t\t\tPort: int32FromInt(8080),\n578: \t\t\t\t},\n579: \t\t\t},\n580: \t\t},\n581: \t\tReadinessProbe: &corev1.Probe{\n582: \t\t\tProbeHandler: corev1.ProbeHandler{\n583: \t\t\t\tHTTPGet: &corev1.HTTPGetAction{\n584: \t\t\t\t\tPath: \"/ready\",\n585: \t\t\t\t\tPort: int32FromInt(8080),\n586: \t\t\t\t},\n587: \t\t\t},\n588: \t\t},\n589: \t\tStartupProbe: &corev1.Probe{\n590: \t\t\tProbeHandler: corev1.ProbeHandler{\n591: \t\t\t\tHTTPGet: &corev1.HTTPGetAction{\n592: \t\t\t\t\tPath: \"/startup\",\n593: \t\t\t\t\tPort: int32FromInt(8080),\n594: \t\t\t\t},\n595: \t\t\t},\n596: \t\t},\n597: \t}\n598: \n599: \tif hc.LivenessProbe == nil {\n600: \t\tt.Error(\"Expected LivenessProbe to be set\")\n601: \t}\n602: \n603: \tif hc.ReadinessProbe == nil {\n604: \t\tt.Error(\"Expected ReadinessProbe to be set\")\n605: \t}\n606: \n607: \tif hc.StartupProbe == nil {\n608: \t\tt.Error(\"Expected StartupProbe to be set\")\n609: \t}\n610: }\n611: \n612: func TestTimeoutConfig(t *testing.T) {\n613: \ttc := TimeoutConfig{\n614: \t\tTTLSecondsAfterFinished: int32Ptr(3600),\n615: \t\tIdleTimeoutSeconds:      int32Ptr(1800),\n616: \t\tMaxLifetimeSeconds:      int32Ptr(28800),\n617: \t\tGracePeriodSeconds:      int64Ptr(30),\n618: \t}\n619: \n620: \tif tc.TTLSecondsAfterFinished == nil || *tc.TTLSecondsAfterFinished != 3600 {\n621: \t\tt.Error(\"Expected TTLSecondsAfterFinished to be 3600\")\n622: \t}\n623: \n624: \tif tc.IdleTimeoutSeconds == nil || *tc.IdleTimeoutSeconds != 1800 {\n625: \t\tt.Error(\"Expected IdleTimeoutSeconds to be 1800\")\n626: \t}\n627: \n628: \tif tc.MaxLifetimeSeconds == nil || *tc.MaxLifetimeSeconds != 28800 {\n629: \t\tt.Error(\"Expected MaxLifetimeSeconds to be 28800\")\n630: \t}\n631: \n632: \tif tc.GracePeriodSeconds == nil || *tc.GracePeriodSeconds != 30 {\n633: \t\tt.Error(\"Expected GracePeriodSeconds to be 30\")\n634: \t}\n635: }\n636: \n637: func TestConditionDeepCopy(t *testing.T) {\n638: \tnow := metav1.NewTime(time.Now())\n639: \n640: \toriginal := &Condition{\n641: \t\tType:               ConditionReady,\n642: \t\tStatus:             corev1.ConditionTrue,\n643: \t\tLastTransitionTime: now,\n644: \t\tReason:             \"ResourceReady\",\n645: \t\tMessage:            \"Resource is ready\",\n646: \t\tObservedGeneration: 1,\n647: \t}\n648: \n649: \tcopied := original.DeepCopy()\n650: \n651: \tif copied == nil {\n652: \t\tt.Fatal(\"DeepCopy returned nil\")\n653: \t}\n654: \n655: \tif copied.Type != original.Type {\n656: \t\tt.Errorf(\"Expected type %s, got %s\", original.Type, copied.Type)\n657: \t}\n658: \n659: \tif copied.Status != original.Status {\n660: \t\tt.Errorf(\"Expected status %s, got %s\", original.Status, copied.Status)\n661: \t}\n662: \n663: \tif copied.Reason != original.Reason {\n664: \t\tt.Errorf(\"Expected reason %s, got %s\", original.Reason, copied.Reason)\n665: \t}\n666: \n667: \tif copied.Message != original.Message {\n668: \t\tt.Errorf(\"Expected message %s, got %s\", original.Message, copied.Message)\n669: \t}\n670: \n671: \t// Verify independence\n672: \toriginal.Reason = \"Modified\"\n673: \tif copied.Reason == \"Modified\" {\n674: \t\tt.Error(\"DeepCopy should create independent copy\")\n675: \t}\n676: }\n677: \n678: func TestResourceReferenceDeepCopy(t *testing.T) {\n679: \toriginal := &ResourceReference{\n680: \t\tName:      \"my-resource\",\n681: \t\tNamespace: \"my-namespace\",\n682: \t}\n683: \n684: \tcopied := original.DeepCopy()\n685: \n686: \tif copied == nil {\n687: \t\tt.Fatal(\"DeepCopy returned nil\")\n688: \t}\n689: \n690: \tif copied.Name != original.Name {\n691: \t\tt.Errorf(\"Expected name %s, got %s\", original.Name, copied.Name)\n692: \t}\n693: \n694: \tif copied.Namespace != original.Namespace {\n695: \t\tt.Errorf(\"Expected namespace %s, got %s\", original.Namespace, copied.Namespace)\n696: \t}\n697: }\n698: \n699: func TestSecretReferenceDeepCopy(t *testing.T) {\n700: \toriginal := &SecretReference{\n701: \t\tName: \"my-secret\",\n702: \t\tKey:  \"password\",\n703: \t}\n704: \n705: \tcopied := original.DeepCopy()\n706: \n707: \tif copied == nil {\n708: \t\tt.Fatal(\"DeepCopy returned nil\")\n709: \t}\n710: \n711: \tif copied.Name != original.Name {\n712: \t\tt.Errorf(\"Expected name %s, got %s\", original.Name, copied.Name)\n713: \t}\n714: \n715: \tif copied.Key != original.Key {\n716: \t\tt.Errorf(\"Expected key %s, got %s\", original.Key, copied.Key)\n717: \t}\n718: }\n719: \n720: func TestConfigMapReferenceDeepCopy(t *testing.T) {\n721: \toriginal := &ConfigMapReference{\n722: \t\tName: \"my-config\",\n723: \t\tKey:  \"data\",\n724: \t}\n725: \n726: \tcopied := original.DeepCopy()\n727: \n728: \tif copied == nil {\n729: \t\tt.Fatal(\"DeepCopy returned nil\")\n730: \t}\n731: \n732: \tif copied.Name != original.Name {\n733: \t\tt.Errorf(\"Expected name %s, got %s\", original.Name, copied.Name)\n734: \t}\n735: \n736: \tif copied.Key != original.Key {\n737: \t\tt.Errorf(\"Expected key %s, got %s\", original.Key, copied.Key)\n738: \t}\n739: }\n740: \n741: func TestSandboxTemplateDeepCopy(t *testing.T) {\n742: \toriginal := &SandboxTemplate{\n743: \t\tLabels: map[string]string{\n744: \t\t\t\"app\": \"test\",\n745: \t\t},\n746: \t\tAnnotations: map[string]string{\n747: \t\t\t\"description\": \"Test\",\n748: \t\t},\n749: \t\tSpec: &corev1.PodSpec{\n750: \t\t\tContainers: []corev1.Container{\n751: \t\t\t\t{\n752: \t\t\t\t\tName:  \"test\",\n753: \t\t\t\t\tImage: \"busybox:latest\",\n754: \t\t\t\t},\n755: \t\t\t},\n756: \t\t},\n757: \t}\n758: \n759: \tcopied := original.DeepCopy()\n760: \n761: \tif copied == nil {\n762: \t\tt.Fatal(\"DeepCopy returned nil\")\n763: \t}\n764: \n765: \tif copied.Labels[\"app\"] != \"test\" {\n766: \t\tt.Error(\"Labels should be copied\")\n767: \t}\n768: \n769: \t// Verify independence of labels\n770: \toriginal.Labels[\"new-key\"] = \"new-value\"\n771: \tif _, exists := copied.Labels[\"new-key\"]; exists {\n772: \t\tt.Error(\"Labels should be independent\")\n773: \t}\n774: \n775: \t// Verify independence of annotations\n776: \toriginal.Annotations[\"new-annotation\"] = \"new-value\"\n777: \tif _, exists := copied.Annotations[\"new-annotation\"]; exists {\n778: \t\tt.Error(\"Annotations should be independent\")\n779: \t}\n780: \n781: \t// Verify independence of spec\n782: \toriginal.Spec.Containers[0].Name = \"modified\"\n783: \tif copied.Spec.Containers[0].Name == \"modified\" {\n784: \t\tt.Error(\"Spec should be independent\")\n785: \t}\n786: }\n787: \n788: func TestVolumeSourceDeepCopy(t *testing.T) {\n789: \toriginal := &VolumeSource{\n790: \t\tType: StorageTypeHostPath,\n791: \t\tHostPath: &corev1.HostPathVolumeSource{\n792: \t\t\tPath: \"/data\",\n793: \t\t},\n794: \t}\n795: \n796: \tcopied := original.DeepCopy()\n797: \n798: \tif copied == nil {\n799: \t\tt.Fatal(\"DeepCopy returned nil\")\n800: \t}\n801: \n802: \tif copied.Type != original.Type {\n803: \t\tt.Errorf(\"Expected type %s, got %s\", original.Type, copied.Type)\n804: \t}\n805: \n806: \tif copied.HostPath.Path != original.HostPath.Path {\n807: \t\tt.Errorf(\"Expected path %s, got %s\", original.HostPath.Path, copied.HostPath.Path)\n808: \t}\n809: \n810: \t// Verify independence\n811: \toriginal.HostPath.Path = \"/modified\"\n812: \tif copied.HostPath.Path == \"/modified\" {\n813: \t\tt.Error(\"HostPath should be independent\")\n814: \t}\n815: }\n816: \n817: func TestVolumeMountDeepCopy(t *testing.T) {\n818: \toriginal := &VolumeMount{\n819: \t\tName:      \"data\",\n820: \t\tMountPath: \"/data\",\n821: \t\tReadOnly:  true,\n822: \t\tSubPath:   \"subdir\",\n823: \t}\n824: \n825: \tcopied := original.DeepCopy()\n826: \n827: \tif copied == nil {\n828: \t\tt.Fatal(\"DeepCopy returned nil\")\n829: \t}\n830: \n831: \tif copied.Name != original.Name {\n832: \t\tt.Errorf(\"Expected name %s, got %s\", original.Name, copied.Name)\n833: \t}\n834: \n835: \tif copied.MountPath != original.MountPath {\n836: \t\tt.Errorf(\"Expected mount path %s, got %s\", original.MountPath, copied.MountPath)\n837: \t}\n838: \n839: \tif copied.ReadOnly != original.ReadOnly {\n840: \t\tt.Errorf(\"Expected readOnly %v, got %v\", original.ReadOnly, copied.ReadOnly)\n841: \t}\n842: \n843: \tif copied.SubPath != original.SubPath {\n844: \t\tt.Errorf(\"Expected subPath %s, got %s\", original.SubPath, copied.SubPath)\n845: \t}\n846: }\n847: \n848: func TestNetworkConfigDeepCopy(t *testing.T) {\n849: \toriginal := &NetworkConfig{\n850: \t\tHostNetwork: true,\n851: \t\tHostPID:     false,\n852: \t\tHostIPC:     true,\n853: \t\tDNSPolicy:   corev1.DNSClusterFirstWithHostNet,\n854: \t\tDNSConfig: &corev1.PodDNSConfig{\n855: \t\t\tNameservers: []string{\"8.8.8.8\", \"8.8.4.4\"},\n856: \t\t},\n857: \t}\n858: \n859: \tcopied := original.DeepCopy()\n860: \n861: \tif copied == nil {\n862: \t\tt.Fatal(\"DeepCopy returned nil\")\n863: \t}\n864: \n865: \tif copied.HostNetwork != original.HostNetwork {\n866: \t\tt.Error(\"HostNetwork should match\")\n867: \t}\n868: \n869: \tif copied.DNSConfig == nil {\n870: \t\tt.Fatal(\"DNSConfig should be copied\")\n871: \t}\n872: \n873: \t// Verify independence\n874: \toriginal.DNSConfig.Nameservers = append(original.DNSConfig.Nameservers, \"1.1.1.1\")\n875: \tif len(copied.DNSConfig.Nameservers) == 3 {\n876: \t\tt.Error(\"DNSConfig should be independent\")\n877: \t}\n878: }\n879: \n880: func TestSecurityContextDeepCopy(t *testing.T) {\n881: \toriginal := &SecurityContext{\n882: \t\tRunAsUser:    int64Ptr(1000),\n883: \t\tRunAsGroup:   int64Ptr(1000),\n884: \t\tRunAsNonRoot: boolPtr(true),\n885: \t}\n886: \n887: \tcopied := original.DeepCopy()\n888: \n889: \tif copied == nil {\n890: \t\tt.Fatal(\"DeepCopy returned nil\")\n891: \t}\n892: \n893: \tif *copied.RunAsUser != *original.RunAsUser {\n894: \t\tt.Error(\"RunAsUser should match\")\n895: \t}\n896: \n897: \t// Verify independence\n898: \t*original.RunAsUser = 2000\n899: \tif *copied.RunAsUser == 2000 {\n900: \t\tt.Error(\"RunAsUser should be independent\")\n901: \t}\n902: }\n903: \n904: func TestLifecycleHooksDeepCopy(t *testing.T) {\n905: \toriginal := &LifecycleHooks{\n906: \t\tPostStart: &corev1.LifecycleHandler{\n907: \t\t\tExec: &corev1.ExecAction{\n908: \t\t\t\tCommand: []string{\"echo\", \"start\"},\n909: \t\t\t},\n910: \t\t},\n911: \t\tPreStop: &corev1.LifecycleHandler{\n912: \t\t\tExec: &corev1.ExecAction{\n913: \t\t\t\tCommand: []string{\"echo\", \"stop\"},\n914: \t\t\t},\n915: \t\t},\n916: \t}\n917: \n918: \tcopied := original.DeepCopy()\n919: \n920: \tif copied == nil {\n921: \t\tt.Fatal(\"DeepCopy returned nil\")\n922: \t}\n923: \n924: \tif copied.PostStart == nil || copied.PreStop == nil {\n925: \t\tt.Fatal(\"Both hooks should be copied\")\n926: \t}\n927: \n928: \t// Verify independence\n929: \toriginal.PostStart.Exec.Command[0] = \"modified\"\n930: \tif copied.PostStart.Exec.Command[0] == \"modified\" {\n931: \t\tt.Error(\"PostStart should be independent\")\n932: \t}\n933: }\n934: \n935: func TestHealthCheckDeepCopy(t *testing.T) {\n936: \toriginal := &HealthCheck{\n937: \t\tLivenessProbe: &corev1.Probe{\n938: \t\t\tProbeHandler: corev1.ProbeHandler{\n939: \t\t\t\tHTTPGet: &corev1.HTTPGetAction{\n940: \t\t\t\t\tPath: \"/health\",\n941: \t\t\t\t\tPort: int32FromInt(8080),\n942: \t\t\t\t},\n943: \t\t\t},\n944: \t\t},\n945: \t\tReadinessProbe: &corev1.Probe{\n946: \t\t\tProbeHandler: corev1.ProbeHandler{\n947: \t\t\t\tHTTPGet: &corev1.HTTPGetAction{\n948: \t\t\t\t\tPath: \"/ready\",\n949: \t\t\t\t\tPort: int32FromInt(8080),\n950: \t\t\t\t},\n951: \t\t\t},\n952: \t\t},\n953: \t}\n954: \n955: \tcopied := original.DeepCopy()\n956: \n957: \tif copied == nil {\n958: \t\tt.Fatal(\"DeepCopy returned nil\")\n959: \t}\n960: \n961: \tif copied.LivenessProbe == nil || copied.ReadinessProbe == nil {\n962: \t\tt.Fatal(\"Probes should be copied\")\n963: \t}\n964: \n965: \t// Verify independence\n966: \toriginal.LivenessProbe.HTTPGet.Path = \"/modified\"\n967: \tif copied.LivenessProbe.HTTPGet.Path == \"/modified\" {\n968: \t\tt.Error(\"LivenessProbe should be independent\")\n969: \t}\n970: }\n971: \n972: func TestTimeoutConfigDeepCopy(t *testing.T) {\n973: \toriginal := &TimeoutConfig{\n974: \t\tTTLSecondsAfterFinished: int32Ptr(3600),\n975: \t\tIdleTimeoutSeconds:      int32Ptr(1800),\n976: \t\tMaxLifetimeSeconds:      int32Ptr(28800),\n977: \t\tGracePeriodSeconds:      int64Ptr(30),\n978: \t}\n979: \n980: \tcopied := original.DeepCopy()\n981: \n982: \tif copied == nil {\n983: \t\tt.Fatal(\"DeepCopy returned nil\")\n984: \t}\n985: \n986: \tif *copied.TTLSecondsAfterFinished != *original.TTLSecondsAfterFinished {\n987: \t\tt.Error(\"TTLSecondsAfterFinished should match\")\n988: \t}\n989: \n990: \t// Verify independence\n991: \t*original.TTLSecondsAfterFinished = 7200\n992: \tif *copied.TTLSecondsAfterFinished == 7200 {\n993: \t\tt.Error(\"TTLSecondsAfterFinished should be independent\")\n994: \t}\n995: }\n996: \n997: func TestConditionJSONMarshal(t *testing.T) {\n998: \tnow := metav1.NewTime(time.Now())\n999: \n1000: \tcond := Condition{\n1001: \t\tType:               ConditionReady,\n1002: \t\tStatus:             corev1.ConditionTrue,\n1003: \t\tLastTransitionTime: now,\n1004: \t\tReason:             \"ResourceReady\",\n1005: \t\tMessage:            \"Resource is ready\",\n1006: \t\tObservedGeneration: 1,\n1007: \t}\n1008: \n1009: \tdata, err := json.Marshal(cond)\n1010: \tif err != nil {\n1011: \t\tt.Fatalf(\"Failed to marshal Condition: %v\", err)\n1012: \t}\n1013: \n1014: \tvar unmarshaled Condition\n1015: \terr = json.Unmarshal(data, &unmarshaled)\n1016: \tif err != nil {\n1017: \t\tt.Fatalf(\"Failed to unmarshal Condition: %v\", err)\n1018: \t}\n1019: \n1020: \tif unmarshaled.Type != cond.Type {\n1021: \t\tt.Errorf(\"Expected type %s, got %s\", cond.Type, unmarshaled.Type)\n1022: \t}\n1023: \n1024: \tif unmarshaled.Status != cond.Status {\n1025: \t\tt.Errorf(\"Expected status %s, got %s\", cond.Status, unmarshaled.Status)\n1026: \t}\n1027: \n1028: \tif unmarshaled.Reason != cond.Reason {\n1029: \t\tt.Errorf(\"Expected reason %s, got %s\", cond.Reason, unmarshaled.Reason)\n1030: \t}\n1031: \n1032: \tif unmarshaled.Message != cond.Message {\n1033: \t\tt.Errorf(\"Expected message %s, got %s\", cond.Message, unmarshaled.Message)\n1034: \t}\n1035: }\n1036: \n1037: func TestConstants(t *testing.T) {\n1038: \t// Test API constants\n1039: \tif APIGroup != \"runtime.agentcube.volcano.sh\" {\n1040: \t\tt.Errorf(\"Expected APIGroup 'runtime.agentcube.volcano.sh', got %s\", APIGroup)\n1041: \t}\n1042: \n1043: \tif APIVersion != \"v1alpha1\" {\n1044: \t\tt.Errorf(\"Expected APIVersion 'v1alpha1', got %s\", APIVersion)\n1045: \t}\n1046: \n1047: \tif FullAPIVersion != \"runtime.agentcube.volcano.sh/v1alpha1\" {\n1048: \t\tt.Errorf(\"Expected FullAPIVersion 'runtime.agentcube.volcano.sh/v1alpha1', got %s\", FullAPIVersion)\n1049: \t}\n1050: \n1051: \t// Test kind constants\n1052: \tif AgentRuntimeKind != \"AgentRuntime\" {\n1053: \t\tt.Errorf(\"Expected AgentRuntimeKind 'AgentRuntime', got %s\", AgentRuntimeKind)\n1054: \t}\n1055: \n1056: \tif CodeInterpreterKind != \"CodeInterpreter\" {\n1057: \t\tt.Errorf(\"Expected CodeInterpreterKind 'CodeInterpreter', got %s\", CodeInterpreterKind)\n1058: \t}\n1059: \n1060: \t// Test phase constants\n1061: \tif PhasePending != \"Pending\" {\n1062: \t\tt.Errorf(\"Expected PhasePending 'Pending', got %s\", PhasePending)\n1063: \t}\n1064: \n1065: \t// Test condition type constants\n1066: \tif ConditionReady != \"Ready\" {\n1067: \t\tt.Errorf(\"Expected ConditionReady 'Ready', got %s\", ConditionReady)\n1068: \t}\n1069: \n1070: \t// Test reason constants\n1071: \tif ReasonCreating != \"Creating\" {\n1072: \t\tt.Errorf(\"Expected ReasonCreating 'Creating', got %s\", ReasonCreating)\n1073: \t}\n1074: \n1075: \t// Test timeout constants\n1076: \tif DefaultTTLSecondsAfterFinished != 3600 {\n1077: \t\tt.Errorf(\"Expected DefaultTTLSecondsAfterFinished 3600, got %d\", DefaultTTLSecondsAfterFinished)\n1078: \t}\n1079: \n1080: \t// Test port constants\n1081: \tif DefaultHTTPPort != 80 {\n1082: \t\tt.Errorf(\"Expected DefaultHTTPPort 80, got %d\", DefaultHTTPPort)\n1083: \t}\n1084: \n1085: \t// Test resource quantity defaults\n1086: \tif DefaultCPURequest != \"100m\" {\n1087: \t\tt.Errorf(\"Expected DefaultCPURequest '100m', got %s\", DefaultCPURequest)\n1088: \t}\n1089: \n1090: \t// Test status constants\n1091: \tif StatusTrue != \"True\" {\n1092: \t\tt.Errorf(\"Expected StatusTrue 'True', got %s\", StatusTrue)\n1093: \t}\n1094: \n1095: \t// Test finalizer constants\n1096: \tif FinalizerSandbox != \"runtime.agentcube.volcano.sh/sandbox-cleanup\" {\n1097: \t\tt.Errorf(\"Expected FinalizerSandbox 'runtime.agentcube.volcano.sh/sandbox-cleanup', got %s\", FinalizerSandbox)\n1098: \t}\n1099: \n1100: \t// Test event reason constants\n1101: \tif EventReasonCreated != \"Created\" {\n1102: \t\tt.Errorf(\"Expected EventReasonCreated 'Created', got %s\", EventReasonCreated)\n1103: \t}\n1104: \n1105: \t// Test error message constants\n1106: \tif ErrMsgResourceNotFound != \"resource not found\" {\n1107: \t\tt.Errorf(\"Expected ErrMsgResourceNotFound 'resource not found', got %s\", ErrMsgResourceNotFound)\n1108: \t}\n1109: }\n1110: \n1111: // Helper functions\n1112: func int32Ptr(i int32) *int32 {\n1113: \treturn &i\n1114: }\n1115: \n1116: func int64Ptr(i int64) *int64 {\n1117: \treturn &i\n1118: }\n1119: \n1120: func boolPtr(b bool) *bool {\n1121: \treturn &b\n1122: }\n1123: \n1124: func mustParseQuantity(s string) corev1.ResourceQuantity {\n1125: \tfromInt := func(i int) intstr.IntOrString {\n1126: \t\treturn intstr.FromInt(i)\n1127: \t}\n1128: \t// This is a simplified version - in real code would use resource.ParseQuantity\n1129: \treturn corev1.ResourceQuantity{}\n1130: }\n1131: \n1132: func int32FromInt(i int) intstr.IntOrString {\n1133: \treturn intstr.FromInt(i)\n1134: }\n1135: \n1136: // Need to import intstr\n1137: import (\n1138: \t\"k8s.io/apimachinery/pkg/util/intstr\"\n1139: )\n\n(End of file - total 1139 lines)\n</content>","metadata":{"preview":"/*\nCopyright 2026 The Volcano Authors.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\npackage v1alpha1\n\nimport (\n\t\"encoding/json\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/apis/runtime/v1alpha1/common_types_test.go","time":{"start":1775842758222,"end":1775842758329}}}}
