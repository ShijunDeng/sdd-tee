{\n\t\tt.Errorf(\"Expected name %s, got %s\", original.Name, copied.Name)\n\t}\n\n\tif copied.Namespace != original.Namespace {\n\t\tt.Errorf(\"Expected namespace %s, got %s\", original.Namespace, copied.Namespace)\n\t}\n}\n\nfunc TestSecretReferenceDeepCopy(t *testing.T) {\n\toriginal := &SecretReference{\n\t\tName: \"my-secret\",\n\t\tKey:  \"password\",\n\t}\n\n\tcopied := original.DeepCopy()\n\n\tif copied == nil {\n\t\tt.Fatal(\"DeepCopy returned nil\")\n\t}\n\n\tif copied.Name != original.Name {\n\t\tt.Errorf(\"Expected name %s, got %s\", original.Name, copied.Name)\n\t}\n\n\tif copied.Key != original.Key {\n\t\tt.Errorf(\"Expected key %s, got %s\", original.Key, copied.Key)\n\t}\n}\n\nfunc TestConfigMapReferenceDeepCopy(t *testing.T) {\n\toriginal := &ConfigMapReference{\n\t\tName: \"my-config\",\n\t\tKey:  \"data\",\n\t}\n\n\tcopied := original.DeepCopy()\n\n\tif copied == nil {\n\t\tt.Fatal(\"DeepCopy returned nil\")\n\t}\n\n\tif copied.Name != original.Name {\n\t\tt.Errorf(\"Expected name %s, got %s\", original.Name, copied.Name)\n\t}\n\n\tif copied.Key != original.Key {\n\t\tt.Errorf(\"Expected key %s, got %s\", original.Key, copied.Key)\n\t}\n}\n\nfunc TestSandboxTemplateDeepCopy(t *testing.T) {\n\toriginal := &SandboxTemplate{\n\t\tLabels: map[string]string{\n\t\t\t\"app\": \"test\",\n\t\t},\n\t\tAnnotations: map[string]string{\n\t\t\t\"description\": \"Test\",\n\t\t},\n\t\tSpec: &corev1.PodSpec{\n\t\t\tContainers: []corev1.Container{\n\t\t\t\t{\n\t\t\t\t\tName:  \"test\",\n\t\t\t\t\tImage: \"busybox:latest\",\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\n\tcopied := original.DeepCopy()\n\n\tif copied == nil {\n\t\tt.Fatal(\"DeepCopy returned nil\")\n\t}\n\n\tif copied.Labels[\"app\"] != \"test\" {\n\t\tt.Error(\"Labels should be copied\")\n\t}\n\n\t// Verify independence of labels\n\toriginal.Labels[\"new-key\"] = \"new-value\"\n\tif _, exists := copied.Labels[\"new-key\"]; exists {\n\t\tt.Error(\"Labels should be independent\")\n\t}\n\n\t// Verify independence of annotations\n\toriginal.Annotations[\"new-annotation\"] = \"new-value\"\n\tif _, exists := copied.Annotations[\"new-annotation\"]; exists {\n\t\tt.Error(\"Annotations should be independent\")\n\t}\n\n\t// Verify independence of spec\n\toriginal.Spec.Containers[0].Name = \"modified\"\n\tif copied.Spec.Containers[0].Name == \"modified\" {\n\t\tt.Error(\"Spec should be independent\")\n\t}\n}\n\nfunc TestVolumeSourceDeepCopy(t *testing.T) {\n\toriginal := &VolumeSource{\n\t\tType: StorageTypeHostPath,\n\t\tHostPath: &corev1.HostPathVolumeSource{\n\t\t\tPath: \"/data\",\n\t\t},\n\t}\n\n\tcopied := original.DeepCopy()\n\n\tif copied == nil {\n\t\tt.Fatal(\"DeepCopy returned nil\")\n\t}\n\n\tif copied.Type != original.Type {\n\t\tt.Errorf(\"Expected type %s, got %s\", original.Type, copied.Type)\n\t}\n\n\tif copied.HostPath.Path != original.HostPath.Path {\n\t\tt.Errorf(\"Expected path %s, got %s\", original.HostPath.Path, copied.HostPath.Path)\n\t}\n\n\t// Verify independence\n\toriginal.HostPath.Path = \"/modified\"\n\tif copied.HostPath.Path == \"/modified\" {\n\t\tt.Error(\"HostPath should be independent\")\n\t}\n}\n\nfunc TestVolumeMountDeepCopy(t *testing.T) {\n\toriginal := &VolumeMount{\n\t\tName:      \"data\",\n\t\tMountPath: \"/data\",\n\t\tReadOnly:  true,\n\t\tSubPath:   \"subdir\",\n\t}\n\n\tcopied := original.DeepCopy()\n\n\tif copied == nil {\n\t\tt.Fatal(\"DeepCopy returned nil\")\n\t}\n\n\tif copied.Name != original.Name {\n\t\tt.Errorf(\"Expected name %s, got %s\", original.Name, copied.Name)\n\t}\n\n\tif copied.MountPath != original.MountPath {\n\t\tt.Errorf(\"Expected mount path %s, got %s\", original.MountPath, copied.MountPath)\n\t}\n\n\tif copied.ReadOnly != original.ReadOnly {\n\t\tt.Errorf(\"Expected readOnly %v, got %v\", original.ReadOnly, copied.ReadOnly)\n\t}\n\n\tif copied.SubPath != original.SubPath {\n\t\tt.Errorf(\"Expected subPath %s, got %s\", original.SubPath, copied.SubPath)\n\t}\n}\n\nfunc TestNetworkConfigDeepCopy(t *testing.T) {\n\toriginal := &NetworkConfig{\n\t\tHostNetwork: true,\n\t\tHostPID:     false,\n\t\tHostIPC:     true,\n\t\tDNSPolicy:   corev1.DNSClusterFirstWithHostNet,\n\t\tDNSConfig: &corev1.PodDNSConfig{\n\t\t\tNameservers: []string{\"8.8.8.8\", \"8.8.4.4\"},\n\t\t},\n\t}\n\n\tcopied := original.DeepCopy()\n\n\tif copied == nil {\n\t\tt.Fatal(\"DeepCopy returned nil\")\n\t}\n\n\tif copied.HostNetwork != original.HostNetwork {\n\t\tt.Error(\"HostNetwork should match\")\n\t}\n\n\tif copied.DNSConfig == nil {\n\t\tt.Fatal(\"DNSConfig should be copied\")\n\t}\n\n\t// Verify independence\n\toriginal.DNSConfig.Nameservers = append(original.DNSConfig.Nameservers, \"1.1.1.1\")\n\tif len(copied.DNSConfig.Nameservers) == 3 {\n\t\tt.Error(\"DNSConfig should be independent\")\n\t}\n}\n\nfunc TestSecurityContextDeepCopy(t *testing.T) {\n\toriginal := &SecurityContext{\n\t\tRunAsUser:    int64Ptr(1000),\n\t\tRunAsGroup:   int64Ptr(1000),\n\t\tRunAsNonRoot: boolPtr(true),\n\t}\n\n\tcopied := original.DeepCopy()\n\n\tif copied == nil {\n\t\tt.Fatal(\"DeepCopy returned nil\")\n\t}\n\n\tif *copied.RunAsUser != *original.RunAsUser {\n\t\tt.Error(\"RunAsUser should match\")\n\t}\n\n\t// Verify independence\n\t*original.RunAsUser = 2000\n\tif *copied.RunAsUser == 2000 {\n\t\tt.Error(\"RunAsUser should be independent\")\n\t}\n}\n\nfunc TestLifecycleHooksDeepCopy(t *testing.T) {\n\toriginal := &LifecycleHooks{\n\t\tPostStart: &corev1.LifecycleHandler{\n\t\t\tExec: &corev1.ExecAction{\n\t\t\t\tCommand: []string{\"echo\", \"start\"},\n\t\t\t},\n\t\t},\n\t\tPreStop: &corev1.LifecycleHandler{\n\t\t\tExec: &corev1.ExecAction{\n\t\t\t\tCommand: []string{\"echo\", \"stop\"},\n\t\t\t},\n\t\t},\n\t}\n\n\tcopied := original.DeepCopy()\n\n\tif copied == nil {\n\t\tt.Fatal(\"DeepCopy returned nil\")\n\t}\n\n\tif copied.PostStart == nil || copied.PreStop == nil {\n\t\tt.Fatal(\"Both hooks should be copied\")\n\t}\n\n\t// Verify independence\n\toriginal.PostStart.Exec.Command[0] = \"modified\"\n\tif copied.Po