lues(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\tcondType ConditionType\n\t\texpected string\n\t}{\n\t\t{\"Ready\", ConditionReady, \"Ready\"},\n\t\t{\"SandboxCreated\", ConditionSandboxCreated, \"SandboxCreated\"},\n\t\t{\"SandboxReady\", ConditionSandboxReady, \"SandboxReady\"},\n\t\t{\"Failed\", ConditionFailed, \"Failed\"},\n\t\t{\"Scheduled\", ConditionScheduled, \"Scheduled\"},\n\t\t{\"Initialized\", ConditionInitialized, \"Initialized\"},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tif string(tt.condType) != tt.expected {\n\t\t\t\tt.Errorf(\"Expected condition type %s, got %s\", tt.expected, tt.condType)\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestStorageTypeValues(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\tstorage  StorageType\n\t\texpected string\n\t}{\n\t\t{\"EmptyDir\", StorageTypeEmptyDir, \"EmptyDir\"},\n\t\t{\"HostPath\", StorageTypeHostPath, \"HostPath\"},\n\t\t{\"PersistentVolumeClaim\", StorageTypePersistentVolumeClaim, \"PersistentVolumeClaim\"},\n\t\t{\"ConfigMap\", StorageTypeConfigMap, \"ConfigMap\"},\n\t\t{\"Secret\", StorageTypeSecret, \"Secret\"},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tif string(tt.storage) != tt.expected {\n\t\t\t\tt.Errorf(\"Expected storage type %s, got %s\", tt.expected, tt.storage)\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestCondition(t *testing.T) {\n\tnow := metav1.NewTime(time.Now())\n\n\ttests := []struct {\n\t\tname      string\n\t\tcondition Condition\n\t}{\n\t\t{\n\t\t\tname: \"minimal condition\",\n\t\t\tcondition: Condition{\n\t\t\t\tType:   ConditionReady,\n\t\t\t\tStatus: corev1.ConditionTrue,\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"full condition\",\n\t\t\tcondition: Condition{\n\t\t\t\tType:               ConditionSandboxReady,\n\t\t\t\tStatus:             corev1.ConditionTrue,\n\t\t\t\tLastTransitionTime: now,\n\t\t\t\tReason:             \"SandboxCreated\",\n\t\t\t\tMessage:            \"Sandbox is ready for use\",\n\t\t\t\tObservedGeneration: 1,\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"failed condition\",\n\t\t\tcondition: Condition{\n\t\t\t\tType:               ConditionFailed,\n\t\t\t\tStatus:             corev1.ConditionFalse,\n\t\t\t\tLastTransitionTime: now,\n\t\t\t\tReason:             \"SandboxCreationFailed\",\n\t\t\t\tMessage:            \"Failed to create sandbox pod\",\n\t\t\t\tObservedGeneration: 2,\n\t\t\t},\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tif tt.condition.Type == \"\" {\n\t\t\t\tt.Error(\"Condition Type should not be empty\")\n\t\t\t}\n\t\t\tif tt.condition.Status == \"\" {\n\t\t\t\tt.Error(\"Condition Status should not be empty\")\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestResourceReference(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\tref      ResourceReference\n\t\twantName string\n\t\twantNS   string\n\t}{\n\t\t{\n\t\t\tname: \"simple reference\",\n\t\t\tref: ResourceReference{\n\t\t\t\tName: \"my-secret\",\n\t\t\t},\n\t\t\twantName: \"my-secret\",\n\t\t\twantNS:   \"\",\n\t\t},\n\t\t{\n\t\t\tname: \"reference with namespace\",\n\t\t\tref: ResourceReference{\n\t\t\t\tName:      \"my-config\",\n\t\t\t\tNamespace: \"other-namespace\",\n\t\t\t},\n\t\t\twantName: \"my-config\",\n\t\t\twantNS:   \"other-namespace\",\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tif tt.ref.Name != tt.wantName {\n\t\t\t\tt.Errorf(\"Expected name %s, got %s\", tt.wantName, tt.ref.Name)\n\t\t\t}\n\t\t\tif tt.ref.Namespace != tt.wantNS {\n\t\t\t\tt.Errorf(\"Expected namespace %s, got %s\", tt.wantNS, tt.ref.Namespace)\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestLocalResourceReference(t *testing.T) {\n\tref := LocalResourceReference{\n\t\tName: \"my-resource\",\n\t}\n\n\tif ref.Name != \"my-resource\" {\n\t\tt.Errorf(\"Expected name 'my-resource', got %s\", ref.Name)\n\t}\n}\n\nfunc TestSecretReference(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\tref      SecretReference\n\t\twantName string\n\t\twantKey  string\n\t}{\n\t\t{\n\t\t\tname: \"secret without key\",\n\t\t\tref: SecretReference{\n\t\t\t\tName: \"my-secret\",\n\t\t\t},\n\t\t\twantName: \"my-secret\",\n\t\t\twantKey:  \"\",\n\t\t},\n\t\t{\n\t\t\tname: \"secret with key\",\n\t\t\tref: SecretReference{\n\t\t\t\tName: \"my-secret\",\n\t\t\t\tKey:  \"password\",\n\t\t\t},\n\t\t\twantName: \"my-secret\",\n\t\t\twantKey:  \"password\",\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tif tt.ref.Name != tt.wantName {\n\t\t\t\tt.Errorf(\"Expected name %s, got %s\", tt.wantName, tt.ref.Name)\n\t\t\t}\n\t\t\tif tt.ref.Key != tt.wantKey {\n\t\t\t\tt.Errorf(\"Expected key %s, got %s\", tt.wantKey, tt.ref.Key)\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestConfigMapReference(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\tref      ConfigMapReference\n\t\twantName string\n\t\twantKey  string\n\t}{\n\t\t{\n\t\t\tname: \"configmap without key\",\n\t\t\tref: ConfigMapReference{\n\t\t\t\tName: \"my-config\",\n\t\t\t},\n\t\t\twantName: \"my-config\",\n\t\t\twantKey:  \"\",\n\t\t},\n\t\t{\n\t\t\tname: \"configmap with key\",\n\t\t\tref: ConfigMapReference{\n\t\t\t\tName: \"my-config\",\n\t\t\t\tKey:  \"data\",\n\t\t\t},\n\t\t\twantName: \"my-config\",\n\t\t\twantKey:  \"data\",\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tif tt.ref.Name != tt.wantName {\n\t\t\t\tt.Errorf(\"Expected name %s, got %s\", tt.wantName, tt.ref.Name)\n\t\t\t}\n\t\t\tif tt.ref.Key != tt.wantKey {\n\t\t\t\tt.Errorf(\"Expected key %s, got %s\", tt.wantKey, tt.ref.Key)\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestResourceRequirements(t *testing.T) {\n\treq := ResourceRequirements{\n\t\tLimits: corev1.ResourceList{\n\t\t\tcorev1.ResourceCPU:    mustParseQuantity(\"1000m\"),\n\t\t\tcorev1.ResourceMemory: mustParseQuantity(\"1Gi\"),\n\t\t},\n\t\tRequests: corev1.ResourceList{\n\t\t\tcorev1.ResourceCPU:    mustParseQuantity(\"500m\"),\n\t\t\tcorev1.ResourceMemory: mustParseQuantity(\"512Mi\"),\n\t\t},\n\t}\n\n\tif req.Limits.Cpu().MilliValue() != 1000 {\n\t\tt.Errorf(\"Expected CPU limit 1000m, got %d\", req.Limits.Cpu().MilliValue())\n\t}\n\n\tif req.Requests.Cpu().MilliValue() != 500 {\n\t\tt.Errorf(\"Expected CPU request 500m, got %d\", req.Requests.Cpu().MilliValue())\n\t}\n}\n\nfunc TestSandboxTemplate(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\ttemplate SandboxTemplate\n\t}{\n\t\t{\n\t\t\tname:     \"empty template\",\n\t\t\ttemplate: SandboxTemplate{},\n\t\t},\n\t\t{\n\t\t\tname: \"template with labels\",\n\t\t\ttemplate: SandboxTemplate{\n\t\t\t\tLabels: map[string]string{\n\t\t\t\t\t\"app\":     \"test\",\n\t\t\t\t\t\"version\": \"v1\",\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"template with annotations\",\n\t\t\ttemplate: SandboxTemplate{\n\t\t\t\tAnnotations: map[string]string{\n\t\t\t\t\t\"description\": \"Test sandbox\",\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"template with spec\",\n\t\t\ttemplate: SandboxTemplate{\n\t\t\t\tSpec: &corev1.PodSpec{\n\t\t\t\t\tContainers: []corev1.Container{\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\tName:  \"test\",\n\t\t\t\t\t\t\tImage: \"busybox:latest\",\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"full template\",\n\t\t\ttemplate: SandboxTemplate{\n\t\t\t\tLabels: map[string]string{\n\t\t\t\t\t\"app\": \"test\",\n\t\t\t\t},\n\t\t\t\tAnnotations: map[string]string{\n\t\t\t\t\t\"description\": \"Test sandbox\",\n\t\t\t\t},\n\t\t\t\tSpec: &corev1.PodSpec{\n\t\t\t\t\tContainers: []corev1.Container{\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\tName:  \"main\",\n\t\t\t\t\t\t\tImage: \"ubuntu:22.04\",\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\t// Just verify the template can be created\n\t\t\t_ = tt.template\n\t\t})\n\t}\n}\n\nfunc TestVolumeSource(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\tvs       VolumeSource\n\t\twantType StorageType\n\t}{\n\t\t{\n\t\t\tname: \"empty dir volume\",\n\t\t\tvs: VolumeSource{\n\t\t\t\tType:     StorageTypeEmptyDir,\n\t\t\t\tEmptyDir: &corev1.EmptyDirVolumeSource{},\n\t\t\t},\n\t\t\twantType: StorageTypeEmptyDir,\n\t\t},\n\t\t{\n\t\t\tname: \"host path volume\",\n\t\t\tvs: VolumeSource{\n\t\t\t\tType: StorageTypeHostPath,\n\t\t\t\tHostPath: &corev1.HostPathVolumeSource{\n\t\t\t\t\tPath: \"/data\",\n\t\t\t\t},\n\t\t\t},\n\t\t\twantType: StorageTypeHostPath,\n\t\t},\n\t\t{\n\t\t\tname: \"pvc volume\",\n\t\t\tvs: VolumeSource{\n\t\t\t\tType: StorageTypePersistentVolumeClaim,\n\t\t\t\tPersistentVolumeClaim: &corev1.PersistentVolumeClaimVolumeSource{\n\t\t\t\t\tClaimName: \"my-pvc\",\n\t\t\t\t},\n\t\t\t},\n\t\t\twantType: StorageTypePersistentVolumeClaim,\n\t\t},\n\t\t{\n\t\t\tname: \"configmap volume\",\n\t\t\tvs: VolumeSource{\n\t\t\t\tType: StorageTypeConfigMap,\n\t\t\t\tConfigMap: &corev1.ConfigMapVolumeSource{\n\t\t\t\t\tLocalObjectReference: corev1.LocalObjectReference{\n\t\t\t\t\t\tName: \"my-config\",\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t\twantType: StorageTypeConfigMap,\n\t\t},\n\t\t{\n\t\t\tname: \"secret volume\",\n\t\t\tvs: VolumeSource{\n\t\t\t\tType: StorageTypeSecret,\n\t\t\t\tSecret: &corev1.SecretVolumeSource{\n\t\t\t\t\tSecretName: \"my-secret\",\n\t\t\t\t},\n\t\t\t},\n\t\t\twantType: StorageTypeSecret,\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tif tt.vs.Type != tt.wantType {\n\t\t\t\tt.Errorf(\"Expected type %s, got %s\", tt.wantType, tt.vs.Type)\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestVolumeMount(t *testing.T) {\n\ttests := []struct {\n\t\tname         string\n\t\tvm           VolumeMount\n\t\twantName     string\n\t\twantPath     string\n\t\twantReadOnly bool\n\t}{\n\t\t{\n\t\t\tname: \"basic mount\",\n\t\t\tvm: VolumeMount{\n\t\t\t\tName:      \"data\",\n\t\t\t\tMountPath: \"/data\",\n\t\t\t},\n\t\t\twantName:     \"data\",\n\t\t\twantPath:     \"/data\",\n\t\t\twantReadOnly: false,\n\t\t},\n\t\t{\n\t\t\tname: \"read-only mount\",\n\t\t\tvm: VolumeMount{\n\t\t\t\tName:      \"config\",\n\t\t\t\tMountPath: \"/etc/config\",\n\t\t\t\tReadOnly:  true,\n\t\t\t},\n\t\t\twantName:     \"config\",\n\t\t\twantPath:     \"/etc/config\",\n\t\t\twantReadOnly: true,\n\t\t},\n\t\t{\n\t\t\tname: \"mount with subpath\",\n\t\t\tvm: VolumeMount{\n\t\t\t\tName:      \"data\",\n\t\t\t\tMountPath: \"/data\",\n\t\t\t\tSubPath:   \"subdir\",\n\t\t\t},\n\t\t\twantName: \"data\",\n\t\t\twantPath: \"/data\",\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tif tt.vm.Name != tt.wantName {\n\t\t\t\tt.Errorf(\"Expected name %s, got %s\", tt.wantName, tt.vm.Name)\n\t\t\t}\n\t\t\tif tt.vm.MountPath != tt.wantPath {\n\t\t\t\tt.Errorf(\"Expected mount path %s, got %s\", tt.wantPath, tt.vm.MountPath)\n\t\t\t}\n\t\t\tif tt.vm.ReadOnly != tt.wantReadOnly {\n\t\t\t\tt.Errorf(\"Expected readOnly %v, got %v\", tt.wantReadOnly, tt.vm.ReadOnly)\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestNetworkConfig(t *testing.T) {\n\tnc := NetworkConfig{\n\t\tHostNetwork: true,\n\t\tHostPID:     true,\n\t\tHostIPC:     false,\n\t\tDNSPolicy:   corev1.DNSClusterFirst,\n\t\tDNSConfig: &corev1.PodDNSConfig{\n\t\t\tNameservers: []string{\"8.8.8.8\"},\n\t\t},\n\t}\n\n\tif !nc.HostNetwork {\n\t\tt.Error(\"Expected HostNetwork to be true\")\n\t}\n\n\tif !nc.HostPID {\n\t\tt.Error(\"Expected HostPID to be true\")\n\t}\n\n\tif nc.HostIPC {\n\t\tt.Error(\"Expected HostIPC to be false\")\n\t}\n\n\tif nc.DNSPolicy != corev1.DNSClusterFirst {\n\t\tt.Errorf(\"Expected DNSPolicy DNSClusterFirst, got %s\", nc.DNSPolicy)\n\t}\n\n\tif nc.DNSConfig == nil {\n\t\tt.Error(\"Expected DNSConfig to be set\")\n\t}\n}\n\nfunc TestSecurityContext(t *testing.T) {\n\tsc := SecurityContext{\n\t\tRunAsUser:                int64Ptr(1000),\n\t\tRunAsGroup:               int64Ptr(1000),\n\t\tRunAsNonRoot:             boolPtr(true),\n\t\tReadOnlyRootFilesystem:   boolPtr(true),\n\t\tPrivileged:               boolPtr(false),\n\t\tAllowPrivilegeEscalation: boolPtr(false),\n\t}\n\n\tif sc.RunAsUser == nil || *sc.RunAsUser != 1000 {\n\t\tt.Error(\"Expected RunAsUser to be 1000\")\n\t}\n\n\tif sc.RunAsGroup == nil || *sc.RunAsGroup != 1000 {\n\t\tt.Error(\"Expected RunAsGroup to be 1000\")\n\t}\n\n\tif sc.RunAsNonRoot == nil || !*sc.RunAsNonRoot {\n\t\tt.Error(\"Expected RunAsNonRoot to be true\")\n\t}\n\n\tif sc.ReadOnlyRootFilesystem == nil || !*sc.ReadOnlyRootFilesystem {\n\t\tt.Error(\"Expected ReadOnlyRootFilesystem to be true\")\n\t}\n\n\tif sc.Privileged == nil || *sc.Privileged {\n\t\tt.Error(\"Expected Privileged to be false\")\n\t}\n\n\tif sc.AllowPrivilegeEscalation == nil || *sc.AllowPrivilegeEscalation {\n\t\tt.Error(\"Expected AllowPrivilegeEscalation to be false\")\n\t}\n}\n\nfunc TestLifecycleHooks(t *testing.T) {\n\tlh := LifecycleHooks{\n\t\tPostStart: &corev1.LifecycleHandler{\n\t\t\tExec: &corev1.ExecAction{\n\t\t\t\tCommand: []string{\"echo\", \"started\"},\n\t\t\t},\n\t\t},\n\t\tPreStop: &corev1.LifecycleHandler{\n\t\t\tExec: &corev1.ExecAction{\n\t\t\t\tCommand: []string{\"echo\", \"stopping\"},\n\t\t\t},\n\t\t},\n\t}\n\n\tif lh.PostStart == nil {\n\t\tt.Error(\"Expected PostStart to be set\")\n\t}\n\n\tif lh.PreStop == nil {\n\t\tt.Error(\"Expected PreStop to be set\")\n\t}\n}\n\nfunc TestHealthCheck(t *testing.T) {\n\thc := HealthCheck{\n\t\tLivenessProbe: &corev1.Probe{\n\t\t\tProbeHandler: corev1.ProbeHandler{\n\t\t\t\tHTTPGet: &corev1.HTTPGetAction{\n\t\t\t\t\tPath: \"/health\",\n\t\t\t\t\tPort: int32FromInt(8080),\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t\tReadinessProbe: &corev1.Probe{\n\t\t\tProbeHandler: corev1.ProbeHandler{\n\t\t\t\tHTTPGet: &corev1.HTTPGetAction{\n\t\t\t\t\tPath: \"/ready\",\n\t\t\t\t\tPort: int32FromInt(8080),\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t\tStartupProbe: &corev1.Probe{\n\t\t\tProbeHandler: corev1.ProbeHandler{\n\t\t\t\tHTTPGet: &corev1.HTTPGetAction{\n\t\t\t\t\tPath: \"/startup\",\n\t\t\t\t\tPort: int32FromInt(8080),\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\n\tif hc.LivenessProbe == nil {\n\t\tt.Error(\"Expected LivenessProbe to be set\")\n\t}\n\n\tif hc.ReadinessProbe == nil {\n\t\tt.Error(\"Expected ReadinessProbe to be set\")\n\t}\n\n\tif hc.StartupProbe == nil {\n\t\tt.Error(\"Expected StartupProbe to be set\")\n\t}\n}\n\nfunc TestTimeoutConfig(t *testing.T) {\n\ttc := TimeoutConfig{\n\t\tTTLSecondsAfterFinished: int32Ptr(3600),\n\t\tIdleTimeoutSeconds:      int32Ptr(1800),\n\t\tMaxLifetimeSeconds:      int32Ptr(28800),\n\t\tGracePeriodSeconds:      int64Ptr(30),\n\t}\n\n\tif tc.TTLSecondsAfterFinished == nil || *tc.TTLSecondsAfterFinished != 3600 {\n\t\tt.Error(\"Expected TTLSecondsAfterFinished to be 3600\")\n\t}\n\n\tif tc.IdleTimeoutSeconds == nil || *tc.IdleTimeoutSeconds != 1800 {\n\t\tt.Error(\"Expected IdleTimeoutSeconds to be 1800\")\n\t}\n\n\tif tc.MaxLifetimeSeconds == nil || *tc.MaxLifetimeSeconds != 28800 {\n\t\tt.Error(\"Expected MaxLifetimeSeconds to be 28800\")\n\t}\n\n\tif tc.GracePeriodSeconds == nil || *tc.GracePeriodSeconds != 30 {\n\t\tt.Error(\"Expected GracePeriodSeconds to be 30\")\n\t}\n}\n\nfunc TestConditionDeepCopy(t *testing.T) {\n\tnow := metav1.NewTime(time.Now())\n\n\toriginal := &Condition{\n\t\tType:               ConditionReady,\n\t\tStatus:             corev1.ConditionTrue,\n\t\tLastTransitionTime: now,\n\t\tReason:             \"ResourceReady\",\n\t\tMessage:            \"Resource is ready\",\n\t\tObservedGeneration: 1,\n\t}\n\n\tcopied := original.DeepCopy()\n\n\tif copied == nil {\n\t\tt.Fatal(\"DeepCopy returned nil\")\n\t}\n\n\tif copied.Type != original.Type {\n\t\tt.Errorf(\"Expected type %s, got %s\", original.Type, copied.Type)\n\t}\n\n\tif copied.Status != original.Status {\n\t\tt.Errorf(\"Expected status %s, got %s\", original.Status, copied.Status)\n\t}\n\n\tif copied.Reason != original.Reason {\n\t\tt.Errorf(\"Expected reason %s, got %s\", original.Reason, copied.Reason)\n\t}\n\n\tif copied.Message != original.Message {\n\t\tt.Errorf(\"Expected message %s, got %s\", original.Message, copied.Message)\n\t}\n\n\t// Verify independence\n\toriginal.Reason = \"Modified\"\n\tif copied.Reason == \"Modified\" {\n\t\tt.Error(\"DeepCopy should create independent copy\")\n\t}\n}\n\nfunc TestResourceReferenceDeepCopy(t *testing.T) {\n\toriginal := &ResourceReference{\n\t\tName:      \"my-resource\",\n\t\tNamespace: \"my-namespace\",\n\t}\n\n\tcopied := original.DeepCopy()\n\n\tif copied == nil {\n\t\tt.Fatal(\"DeepCopy returned nil\")\n\t}\n\n\tif copied.Name != original.Name {\n\t\tt.Errorf(\"Expected name %s, got %s\", original.Name, copied.Name)\n\t}\n\n\tif copied.Namespace != original.Namespace {\n\t\tt.Errorf(\"Expected namespace %s, got %s\", original.Namespace, copied.Namespace)\n\t}\n}\n\nfunc TestSecretReferenceDeepCopy(t *testing.T) {\n\toriginal := &SecretReference{\n\t\tName: \"my-secret\",\n\t\tKey:  \"password\",\n\t}\n\n\tcopied := original.DeepCopy()\n\n\tif copied == nil {\n\t\tt.Fatal(\"DeepCopy returned nil\")\n\t}\n\n\tif copied.Name != original.Name {\n\t\tt.Errorf(\"Expected name %s, got %s\", original.Name, copied.Name)\n\t}\n\n\tif copied.Key != original.Key {\n\t\tt.Errorf(\"Expected key %s, got %s\", original.Key, copied.Key)\n\t}\n}\n\nfunc TestConfigMapReferenceDeepCopy(t *testing.T) {\n\toriginal := &ConfigMapReference{\n\t\tName: \"my-config\",\n\t\tKey:  \"data\",\n\t}\n\n\tcopied := original.DeepCopy()\n\n\tif copied == nil {\n\t\tt.Fatal(\"DeepCopy returned nil\")\n\t}\n\n\tif copied.Name != original.Name {\n\t\tt.Errorf(\"Expected name %s, got %s\", original.Name, copied.Name)\n\t}\n\n\tif copied.Key != original.Key {\n\t\tt.Errorf(\"Expected key %s, got %s\", original.Key, copied.Key)\n\t}\n}\n\nfunc TestSandboxTemplateDeepCopy(t *testing.T) {\n\toriginal := &SandboxTemplate{\n\t\tLabels: map[string]string{\n\t\t\t\"app\": \"test\",\n\t\t},\n\t\tAnnotations: map[string]string{\n\t\t\t\"description\": \"Test\",\n\t\t},\n\t\tSpec: &corev1.PodSpec{\n\t\t\tContainers: []corev1.Container{\n\t\t\t\t{\n\t\t\t\t\tName:  \"test\",\n\t\t\t\t\tImage: \"busybox:latest\",\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\n\tcopied := original.DeepCopy()\n\n\tif copied == nil {\n\t\tt.Fatal(\"DeepCopy returned nil\")\n\t}\n\n\tif copied.Labels[\"app\"] != \"test\" {\n\t\tt.Error(\"Labels should be copied\")\n\t}\n\n\t// Verify independence of labels\n\toriginal.Labels[\"new-key\"] = \"new-value\"\n\tif _, exists := copied.Labels[\"new-key\"]; exists {\n\t\tt.Error(\"Labels should be independent\")\n\t}\n\n\t// Verify independence of annotations\n\toriginal.Annotations[\"new-annotation\"] = \"new-value\"\n\tif _, exists := copied.Annotations[\"new-annotation\"]; exists {\n\t\tt.Error(\"Annotations should be independent\")\n\t}\n\n\t// Verify independence of spec\n\toriginal.Spec.Containers[0].Name = \"modified\"\n\tif copied.Spec.Containers[0].Name == \"modified\" {\n\t\tt.Error(\"Spec should be independent\")\n\t}\n}\n\nfunc TestVolumeSourceDeepCopy(t *testing.T) {\n\toriginal := &VolumeSource{\n\t\tType: StorageTypeHostPath,\n\t\tHostPath: &corev1.HostPathVolumeSource{\n\t\t\tPath: \"/data\",\n\t\t},\n\t}\n\n\tcopied := original.DeepCopy()\n\n\tif copied == nil {\n\t\tt.Fatal(\"DeepCopy returned nil\")\n\t}\n\n\tif copied.Type != original.Type {\n\t\tt.Errorf(\"Expected type %s, got %s\", original.Type, copied.Type)\n\t}\n\n\tif copied.HostPath.Path != original.HostPath.Path {\n\t\tt.Errorf(\"Expected path %s, got %s\", original.HostPath.Path, copied.HostPath.Path)\n\t}\n\n\t// Verify independence\n\toriginal.HostPath.Path = \"/modified\"\n\tif copied.HostPath.Path == \"/modified\" {\n\t\tt.Error(\"HostPath should be independent\")\n\t}\n}\n\nfunc TestVolumeMountDeepCopy(t *testing.T) {\n\toriginal := &VolumeMount{\n\t\tName:      \"data\",\n\t\tMountPath: \"/data\",\n\t\tReadOnly:  true,\n\t\tSubPath:   \"subdir\",\n\t}\n\n\tcopied := original.DeepCopy()\n\n\tif copied == nil {\n\t\tt.Fatal(\"DeepCopy returned nil\")\n\t}\n\n\tif copied.Name != original.Name {\n\t\tt.Errorf(\"Expected name %s, got %s\", original.Name, copied.Name)\n\t}\n\n\tif copied.MountPath != original.MountPath {\n\t\tt.Errorf(\"Expected mount path %s, got %s\", original.MountPath, copied.MountPath)\n\t}\n\n\tif copied.ReadOnly != original.ReadOnly {\n\t\tt.Errorf(\"Expected readOnly %v, got %v\", original.ReadOnly, copied.ReadOnly)\n\t}\n\n\tif copied.SubPath != original.SubPath {\n\t\tt.Errorf(\"Expected subPath %s, got %s\", original.SubPath, copied.SubPath)\n\t}\n}\n\nfunc TestNetworkConfigDeepCopy(t *testing.T) {\n\toriginal := &NetworkConfig{\n\t\tHostNetwork: true,\n\t\tHostPID:     false,\n\t\tHostIPC:     true,\n\t\tDNSPolicy:   corev1.DNSClusterFirstWithHostNet,\n\t\tDNSConfig: &corev1.PodDNSConfig{\n\t\t\tNameservers: []string{\"8.8.8.8\", \"8.8.4.4\"},\n\t\t},\n\t}\n\n\tcopied := original.DeepCopy()\n\n\tif copied == nil {\n\t\tt.Fatal(\"DeepCopy returned nil\")\n\t}\n\n\tif copied.HostNetwork != original.HostNetwork {\n\t\tt.Error(\"HostNetwork should match\")\n\t}\n\n\tif copied.DNSConfig == nil {\n\t\tt.Fatal(\"DNSConfig should be copied\")\n\t}\n\n\t// Verify independence\n\toriginal.DNSConfig.Nameservers = append(original.DNSConfig.Nameservers, \"1.1.1.1\")\n\tif len(copied.DNSConfig.Nameservers) == 3 {\n\t\tt.Error(\"DNSConfig should be independent\")\n\t}\n}\n\nfunc TestSecurityContextDeepCopy(t *testing.T) {\n\toriginal := &SecurityContext{\n\t\tRunAsUser:    int64Ptr(1000),\n\t\tRunAsGroup:   int64Ptr(1000),\n\t\tRunAsNonRoot: boolPtr(true),\n\t}\n\n\tcopied := original.DeepCopy()\n\n\tif copied == nil {\n\t\tt.Fatal(\"DeepCopy returned nil\")\n\t}\n\n\tif *copied.RunAsUser != *original.RunAsUser {\n\t\tt.Error(\"RunAsUser should match\")\n\t}\n\n\t// Verify independence\n\t*original.RunAsUser = 2000\n\tif *copied.RunAsUser == 2000 {\n\t\tt.Error(\"RunAsUser should be independent\")\n\t}\n}\n\nfunc TestLifecycleHooksDeepCopy(t *testing.T) {\n\toriginal := &LifecycleHooks{\n\t\tPostStart: &corev1.LifecycleHandler{\n\t\t\tExec: &corev1.ExecAction{\n\t\t\t\tCommand: []string{\"echo\", \"start\"},\n\t\t\t},\n\t\t},\n\t\tPreStop: &corev1.LifecycleHandler{\n\t\t\tExec: &corev1.ExecAction{\n\t\t\t\tCommand: []string{\"echo\", \"stop\"},\n\t\t\t},\n\t\t},\n\t}\n\n\tcopied := original.DeepCopy()\n\n\tif copied == nil {\n\t\tt.Fatal(\"DeepCopy returned nil\")\n\t}\n\n\tif copied.PostStart == nil || copied.PreStop == nil {\n\t\tt.Fatal(\"Both hooks should be copied\")\n\t}\n\n\t// Verify independence\n\toriginal.PostStart.Exec.Command[0] = \"modified\"\n\tif copied.PostStart.Exec.Command[0] == \"modified\" {\n\t\tt.Error(\"PostStart should be independent\")\n\t}\n}\n\nfunc TestHealthCheckDeepCopy(t *testing.T) {\n\toriginal := &HealthCheck{\n\t\tLivenessProbe: &corev1.Probe{\n\t\t\tProbeHandler: corev1.ProbeHandler{\n\t\t\t\tHTTPGet: &corev1.HTTPGetAction{\n\t\t\t\t\tPath: \"/health\",\n\t\t\t\t\tPort: int32FromInt(8080),\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t\tReadinessProbe: &corev1.Probe{\n\t\t\tProbeHandler: corev1.ProbeHandler{\n\t\t\t\tHTTPGet: &corev1.HTTPGetAction{\n\t\t\t\t\tPath: \"/ready\",\n\t\t\t\t\tPort: int32FromInt(8080),\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\n\tcopied := original.DeepCopy()\n\n\tif copied == nil {\n\t\tt.Fatal(\"DeepCopy returned nil\")\n\t}\n\n\tif copied.LivenessProbe == nil || copied.ReadinessProbe == nil {\n\t\tt.Fatal(\"Probes should be copied\")\n\t}\n\n\t// Verify independence\n\toriginal.LivenessProbe.HTTPGet.Path = \"/modified\"\n\tif copied.LivenessProbe.HTTPGet.Path == \"/modified\" {\n\t\tt.Error(\"LivenessProbe should be independent\")\n\t}\n}\n\nfunc TestTimeoutConfigDeepCopy(t *testing.T) {\n\toriginal := &TimeoutConfig{\n\t\tTTLSecondsAfterFinished: int32Ptr(3600),\n\t\tIdleTimeoutSeconds:      int32Ptr(1800),\n\t\tMaxLifetimeSeconds:      int32Ptr(28800),\n\t\tGracePeriodSeconds:      int64Ptr(30),\n\t}\n\n\tcopied := original.DeepCopy()\n\n\tif copied == nil {\n\t\tt.Fatal(\"DeepCopy returned nil\")\n\t}\n\n\tif *copied.TTLSecondsAfterFinished != *original.TTLSecondsAfterFinished {\n\t\tt.Error(\"TTLSecondsAfterFinished should match\")\n\t}\n\n\t// Verify independence\n\t*original.TTLSecondsAfterFinished = 7200\n\tif *copied.TTLSecondsAfterFinished == 7200 {\n\t\tt.Error(\"TTLSecondsAfterFinished should be independent\")\n\t}\n}\n\nfunc TestConditionJSONMarshal(t *testing.T) {\n\tnow := metav1.NewTime(time.Now())\n\n\tcond := Condition{\n\t\tType:               ConditionReady,\n\t\tStatus:             corev1.ConditionTrue,\n\t\tLastTransitionTime: now,\n\t\tReason:             \"ResourceReady\",\n\t\tMessage:            \"Resource is ready\",\n\t\tObservedGeneration: 1,\n\t}\n\n\tdata, err := json.Marshal(cond)\n\tif err != nil {\n\t\tt.Fatalf(\"Failed to marshal Condition: %v\", err)\n\t}\n\n\tvar unmarshaled Condition\n\terr = json.Unmarshal(data, &unmarshaled)\n\tif err != nil {\n\t\tt.Fatalf(\"Failed to unmarshal Condition: %v\", err)\n\t}\n\n\tif unmarshaled.Type != cond.Type {\n\t\tt.Errorf(\"Expected type %s, got %s\", cond.Type, unmarshaled.Type)\n\t}\n\n\tif unmarshaled.Status != cond.Status {\n\t\tt.Errorf(\"Expected status %s, got %s\", cond.Status, unmarshaled.Status)\n\t}\n\n\tif unmarshaled.Reason != cond.Reason {\n\t\tt.Errorf(\"Expected reason %s, got %s\", cond.Reason, unmarshaled.Reason)\n\t}\n\n\tif unmarshaled.Message != cond.Message {\n\t\tt.Errorf(\"Expected message %s, got %s\", cond.Message, unmarshaled.Message)\n\t}\n}\n\nfunc TestConstants(t *testing.T) {\n\t// Test API constants\n\tif APIGroup != \"runtime.agentcube.volcano.sh\" {\n\t\tt.Errorf(\"Expected APIGroup 'runtime.agentcube.volcano.sh', got %s\", APIGroup)\n\t}\n\n\tif APIVersion != \"v1alpha1\" {\n\t\tt.Errorf(\"Expected APIVersion 'v1alpha1', got %s\", APIVersion)\n\t}\n\n\tif FullAPIVersion != \"runtime.agentcube.volcano.sh/v1alpha1\" {\n\t\tt.Errorf(\"Expected FullAPIVersion 'runtime.agentcube.volcano.sh/v1alpha1', got %s\", FullAPIVersion)\n\t}\n\n\t// Test kind constants\n\tif AgentRuntimeKind != \"AgentRuntime\" {\n\t\tt.Errorf(\"Expected AgentRuntimeKind 'AgentRuntime', got %s\", AgentRuntimeKind)\n\t}\n\n\tif CodeInterpreterKind != \"CodeInterpreter\" {\n\t\tt.Errorf(\"Expected CodeInterpreterKind 'CodeInterpreter', got %s\", CodeInterpreterKind)\n\t}\n\n\t// Test phase constants\n\tif PhasePending != \"Pending\" {\n\t\tt.Errorf(\"Expected PhasePending 'Pending', got %s\", PhasePending)\n\t}\n\n\t// Test condition type constants\n\tif ConditionReady != \"Ready\" {\n\t\tt.Errorf(\"Expected ConditionReady 'Ready', got %s\", ConditionReady)\n\t}\n\n\t// Test reason constants\n\tif ReasonCreating != \"Creating\" {\n\t\tt.Errorf(\"Expected ReasonCreating 'Creating', got %s\", ReasonCreating)\n\t}\n\n\t// Test timeout constants\n\tif DefaultTTLSecondsAfterFinished != 3600 {\n\t\tt.Errorf(\"Expected DefaultTTLSecondsAfterFinished 3600, got %d\", DefaultTTLSecondsAfterFinished)\n\t}\n\n\t// Test port constants\n\tif DefaultHTTPPort != 80 {\n\t\tt.Errorf(\"Expected DefaultHTTPPort 80, got %d\", DefaultHTTPPort)\n\t}\n\n\t// Test resource quantity defaults\n\tif DefaultCPURequest != \"100m\" {\n\t\tt.Errorf(\"Expected DefaultCPURequest '100m', got %s\", DefaultCPURequest)\n\t}\n\n\t// Test status constants\n\tif StatusTrue != \"True\" {\n\t\tt.Errorf(\"Expected StatusTrue 'True', got %s\", StatusTrue)\n\t}\n\n\t// Test finalizer constants\n\tif FinalizerSandbox != \"runtime.agentcube.volcano.sh/sandbox-cleanup\" {\n\t\tt.Errorf(\"Expected FinalizerSandbox 'runtime.agentcube.volcano.sh/sandbox-cleanup', got %s\", FinalizerSandbox)\n\t}\n\n\t// Test event reason constants\n\tif EventReasonCreated != \"Created\" {\n\t\tt.Errorf(\"Expected EventReasonCreated 'Created', got %s\", EventReasonCreated)\n\t}\n\n\t// Test error message constants\n\tif ErrMsgResourceNotFound != \"resource not found\" {\n\t\tt.Errorf(\"Expected ErrMsgResourceNotFound 'resource not found', got %s\", ErrMsgResourceNotFound)\n\t}\n}\n\n// Helper functions\nfunc int32Ptr(i int32) *int32 {\n\treturn &i\n}\n\nfunc int64Ptr(i int64) *int64 {\n\treturn &i\n}\n\nfunc boolPtr(b bool) *bool {\n\treturn &b\n}\n\nfunc mustParseQuantity(s string) resource.Quantity {\n\treturn resource.MustParse(s)\n}\n\nfunc int32FromInt(i int) intstr.IntOrString {\n\treturn intstr.FromInt(i)\n}\n","after":"/*\nCopyright 2026 The Volcano Authors.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\npackage v1alpha1\n\nimport (\n\t\"encoding/json\"\n\t\"testing\"\n\t\"time\"\n\n\tcorev1 \"k8s.io/api/core/v1\"\n\t\"k8s.io/apimachinery/pkg/api/resource\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/apimachinery/pkg/util/intstr\"\n)\n\nfunc TestPhaseValues(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\tphase    Phase\n\t\texpected string\n\t}{\n\t\t{\"Pending\", PhasePending, \"Pending\"},\n\t\t{\"Running\", PhaseRunning, \"Running\"},\n\t\t{\"Succeeded\", PhaseSucceeded, \"Succeeded\"},\n\t\t{\"Failed\", PhaseFailed, \"Failed\"},\n\t\t{\"Unknown\", PhaseUnknown, \"Unknown\"},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tif string(tt.phase) != tt.expected {\n\t\t\t\tt.Errorf(\"Expected phase %s, got %s\", tt.expected, tt.phase)\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestConditionTypeValues(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\tcondType ConditionType\n\t\texpected string\n\t}{\n\t\t{\"Ready\", ConditionReady, \"Ready\"},\n\t\t{\"SandboxCreated\", ConditionSandboxCreated, \"SandboxCreated\"},\n\t\t{\"SandboxReady\", ConditionSandboxReady, \"SandboxReady\"},\n\t\t{\"Failed\", ConditionFailed, \"Failed\"},\n\t\t{\"Scheduled\", ConditionScheduled, \"Scheduled\"},\n\t\t{\"Initialized\", ConditionInitialized, \"Initialized\"},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tif string(tt.condType) != tt.expected {\n\t\t\t\tt.Errorf(\"Expected condition type %s, got %s\", tt.expected, tt.condType)\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestStorageTypeValues(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\tstorage  StorageType\n\t\texpected string\n\t}{\n\t\t{\"EmptyDir\", StorageTypeEmptyDir, \"EmptyDir\"},\n\t\t{\"HostPath\", StorageTypeHostPath, \"HostPath\"},\n\t\t{\"PersistentVolumeClaim\", StorageTypePersistentVolumeClaim, \"PersistentVolumeClaim\"},\n\t\t{\"ConfigMap\", StorageTypeConfigMap, \"ConfigMap\"},\n\t\t{\"Secret\", StorageTypeSecret, \"Secret\"},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tif string(tt.storage) != tt.expected {\n\t\t\t\tt.Errorf(\"Expected storage type %s, got %s\", tt.expected, tt.storage)\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestCondition(t *testing.T) {\n\tnow := metav1.NewTime(time.Now())\n\n\ttests := []struct {\n\t\tname      string\n\t\tcondition Condition\n\t}{\n\t\t{\n\t\t\tname: \"minimal condition\",\n\t\t\tcondition: Condition{\n\t\t\t\tType:   ConditionReady,\n\t\t\t\tStatus: corev1.ConditionTrue,\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"full condition\",\n\t\t\tcondition: Condition{\n\t\t\t\tType:               ConditionSandboxReady,\n\t\t\t\tStatus:             corev1.ConditionTrue,\n\t\t\t\tLastTransitionTime: now,\n\t\t\t\tReason:             \"SandboxCreated\",\n\t\t\t\tMessage:            \"Sandbox is ready for use\",\n\t\t\t\tObservedGeneration: 1,\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"failed condition\",\n\t\t\tcondition: Condition{\n\t\t\t\tType:               ConditionFailed,\n\t\t\t\tStatus:             corev1.ConditionFalse,\n\t\t\t\tLastTransitionTime: now,\n\t\t\t\tReason:             \"SandboxCreationFailed\",\n\t\t\t\tMessage:            \"Failed to create sandbox pod\",\n\t\t\t\tObservedGeneration: 2,\n\t\t\t},\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tif tt.condition.Type == \"\" {\n\t\t\t\tt.Error(\"Condition Type should not be empty\")\n\t\t\t}\n\t\t\tif tt.condition.Status == \"\" {\n\t\t\t\tt.Error(\"Condition Status should not be empty\")\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestResourceReference(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\tref      ResourceReference\n\t\twantName string\n\t\twantNS   string\n\t}{\n\t\t{\n\t\t\tname: \"simple reference\",\n\t\t\tref: ResourceReference{\n\t\t\t\tName: \"my-secret\",\n\t\t\t},\n\t\t\twantName: \"my-secret\",\n\t\t\twantNS:   \"\",\n\t\t},\n\t\t{\n\t\t\tname: \"reference with namespace\",\n\t\t\tref: ResourceReference{\n\t\t\t\tName:      \"my-config\",\n\t\t\t\tNamespace: \"other-namespace\",\n\t\t\t},\n\t\t\twantName: \"my-config\",\n\t\t\twantNS:   \"other-namespace\",\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tif tt.ref.Name != tt.wantName {\n\t\t\t\tt.Errorf(\"Expected name %s, got %s\", tt.wantName, tt.ref.Name)\n\t\t\t}\n\t\t\tif tt.ref.Namespace != tt.wantNS {\n\t\t\t\tt.Errorf(\"Expected namespace %s, got %s\", tt.wantNS, tt.ref.Namespace)\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestLocalResourceReference(t *testing.T) {\n\tref := LocalResourceReference{\n\t\tName: \"my-resource\",\n\t}\n\n\tif ref.Name != \"my-resource\" {\n\t\tt.Errorf(\"Expected name 'my-resource', got %s\", ref.Name)\n\t}\n}\n\nfunc TestSecretReference(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\tref      SecretReference\n\t\twantName string\n\t\twantKey  string\n\t}{\n\t\t{\n\t\t\tname: \"secret without key\",\n\t\t\tref: SecretReference{\n\t\t\t\tName: \"my-secret\",\n\t\t\t},\n\t\t\twantName: \"my-secret\",\n\t\t\twantKey:  \"\",\n\t\t},\n\t\t{\n\t\t\tname: \"secret with key\",\n\t\t\tref: SecretReference{\n\t\t\t\tName: \"my-secret\",\n\t\t\t\tKey:  \"password\",\n\t\t\t},\n\t\t\twantName: \"my-secret\",\n\t\t\twantKey:  \"password\",\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tif tt.ref.Name != tt.wantName {\n\t\t\t\tt.Errorf(\"Expected name %s, got %s\", tt.wantName, tt.ref.Name)\n\t\t\t}\n\t\t\tif tt.ref.Key != tt.wantKey {\n\t\t\t\tt.Errorf(\"Expected key %s, got %s\", tt.wantKey, tt.ref.Key)\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestConfigMapReference(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\tref      ConfigMapReference\n\t\twantName string\n\t\twantKey  string\n\t}{\n\t\t{\n\t\t\tname: \"configmap without key\",\n\t\t\tref: ConfigMapReference{\n\t\t\t\tName: \"my-config\",\n\t\t\t},\n\t\t\twantName: \"my-config\",\n\t\t\twantKey:  \"\",\n\t\t},\n\t\t{\n\t\t\tname: \"configmap with key\",\n\t\t\tref: ConfigMapReference{\n\t\t\t\tName: \"my-config\",\n\t\t\t\tKey:  \"data\",\n\t\t\t},\n\t\t\twantName: \"my-config\",\n\t\t\twantKey:  \"data\",\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tif tt.ref.Name != tt.wantName {\n\t\t\t\tt.Errorf(\"Expected name %s, got %s\", tt.wantName, tt.ref.Name)\n\t\t\t}\n\t\t\tif tt.ref.Key != tt.wantKey {\n\t\t\t\tt.Errorf(\"Expected key %s, got %s\", tt.wantKey, tt.ref.Key)\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestResourceRequirements(t *testing.T) {\n\treq := ResourceRequirements{\n\t\tLimits: corev1.ResourceList{\n\t\t\tcorev1.ResourceCPU:    mustParseQuantity(\"1000m\"),\n\t\t\tcorev1.ResourceMemory: mustParseQuantity(\"1Gi\"),\n\t\t},\n\t\tRequests: corev1.ResourceList{\n\t\t\tcorev1.ResourceCPU:    mustParseQuantity(\"500m\"),\n\t\t\tcorev1.ResourceMemory: mustParseQuantity(\"512Mi\"),\n\t\t},\n\t}\n\n\tif req.Limits.Cpu().MilliValue() != 1000 {\n\t\tt.Errorf(\"Expected CPU limit 1000m, got %d\", req.Limits.Cpu().MilliValue())\n\t}\n\n\tif req.Requests.Cpu().MilliValue() != 500 {\n\t\tt.Errorf(\"Expected CPU request 500m, got %d\", req.Requests.Cpu().MilliValue())\n\t}\n}\n\nfunc TestSandboxTemplate(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\ttemplate SandboxTemplate\n\t}{\n\t\t{\n\t\t\tname:     \"empty template\",\n\t\t\ttemplate: SandboxTemplate{},\n\t\t},\n\t\t{\n\t\t\tname: \"template with labels\",\n\t\t\ttemplate: SandboxTemplate{\n\t\t\t\tLabels: map[string]string{\n\t\t\t\t\t\"app\":     \"test\",\n\t\t\t\t\t\"version\": \"v1\",\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"template with annotations\",\n\t\t\ttemplate: SandboxTemplate{\n\t\t\t\tAnnotations: map[string]string{\n\t\t\t\t\t\"description\": \"Test sandbox\",\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"template with spec\",\n\t\t\ttemplate: SandboxTemplate{\n\t\t\t\tSpec: &corev1.PodSpec{\n\t\t\t\t\tContainers: []corev1.Container{\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\tName:  \"test\",\n\t\t\t\t\t\t\tImage: \"busybox:latest\",\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"full template\",\n\t\t\ttemplate: SandboxTemplate{\n\t\t\t\tLabels: map[string]string{\n\t\t\t\t\t\"app\": \"test\",\n\t\t\t\t},\n\t\t\t\tAnnotations: map[string]string{\n\t\t\t\t\t\"description\": \"Test sandbox\",\n\t\t\t\t},\n\t\t\t\tSpec: &corev1.PodSpec{\n\t\t\t\t\tContainers: []corev1.Container{\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\tName:  \"main\",\n\t\t\t\t\t\t\tImage: \"ubuntu:22.04\",\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\t// Just verify the template can be created\n\t\t\t_ = tt.template\n\t\t})\n\t}\n}\n\nfunc TestVolumeSource(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\tvs       VolumeSource\n\t\twantType StorageType\n\t}{\n\t\t{\n\t\t\tname: \"empty dir volume\",\n\t\t\tvs: VolumeSource{\n\t\t\t\tType:     StorageTypeEmptyDir,\n\t\t\t\tEmptyDir: &corev1.EmptyDirVolumeSource{},\n\t\t\t},\n\t\t\twantType: StorageTypeEmptyDir,\n\t\t},\n\t\t{\n\t\t\tname: \"host path volume\",\n\t\t\tvs: VolumeSource{\n\t\t\t\tType: StorageTypeHostPath,\n\t\t\t\tHostPath: &corev1.HostPathVolumeSource{\n\t\t\t\t\tPath: \"/data\",\n\t\t\t\t},\n\t\t\t},\n\t\t\twantType: StorageTypeHostPath,\n\t\t},\n\t\t{\n\t\t\tname: \"pvc volume\",\n\t\t\tvs: VolumeSource{\n\t\t\t\tType: StorageTypePersistentVolumeClaim,\n\t\t\t\tPersistentVolumeClaim: &corev1.PersistentVolumeClaimVolumeSource{\n\t\t\t\t\tClaimName: \"my-pvc\",\n\t\t\t\t},\n\t\t\t},\n\t\t\twantType: StorageTypePersistentVolumeClaim,\n\t\t},\n\t\t{\n\t\t\tname: \"configmap volume\",\n\t\t\tvs: VolumeSource{\n\t\t\t\tType: StorageTypeConfigMap,\n\t\t\t\tConfigMap: &corev1.ConfigMapVolumeSource{\n\t\t\t\t\tLocalObjectReference: corev1.LocalObjectReference{\n\t\t\t\t\t\tName: \"my-config\",\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t\twantType: StorageTypeConfigMap,\n\t\t},\n\t\t{\n\t\t\tname: \"secret volume\",\n\t\t\tvs: VolumeSource{\n\t\t\t\tType: StorageTypeSecret,\n\t\t\t\tSecret: &corev1.SecretVolumeSource{\n\t\t\t\t\tSecretName: \"my-secret\",\n\t\t\t\t},\n\t\t\t},\n\t\t\twantType: StorageTypeSecret,\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tif tt.vs.Type != tt.wantType {\n\t\t\t\tt.Errorf(\"Expected type %s, got %s\", tt.wantType, tt.vs.Type)\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestVolumeMount(t *testing.T) {\n\ttests := []struct {\n\t\tname         string\n\t\tvm           VolumeMount\n\t\twantName     string\n\t\twantPath     string\n\t\twantReadOnly bool\n\t}{\n\t\t{\n\t\t\tname: \"basic mount\",\n\t\t\tvm: VolumeMount{\n\t\t\t\tName:      \"data\",\n\t\t\t\tMountPath: \"/data\",\n\t\t\t},\n\t\t\twantName:     \"data\",\n\t\t\twantPath:     \"/data\",\n\t\t\twantReadOnly: false,\n\t\t},\n\t\t{\n\t\t\tname: \"read-only mount\",\n\t\t\tvm: VolumeMount{\n\t\t\t\tName:      \"config\",\n\t\t\t\tMountPath: \"/etc/config\",\n\t\t\t\tReadOnly:  true,\n\t\t\t},\n\t\t\twantName:     \"config\",\n\t\t\twantPath:     \"/etc/config\",\n\t\t\twantReadOnly: true,\n\t\t},\n\t\t{\n\t\t\tname: \"mount with subpath\",\n\t\t\tvm: VolumeMount{\n\t\t\t\tName:      \"data\",\n\t\t\t\tMountPath: \"/data\",\n\t\t\t\tSubPath:   \"subdir\",\n\t\t\t},\n\t\t\twantName: \"data\",\n\t\t\twantPath: \"/data\",\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tif tt.vm.Name != tt.wantName {\n\t\t\t\tt.Errorf(\"Expected name %s, got %s\", tt.wantName, tt.vm.Name)\n\t\t\t}\n\t\t\tif tt.vm.MountPath != tt.wantPath {\n\t\t\t\tt.Errorf(\"Expected mount path %s, got %s\", tt.wantPath, tt.vm.MountPath)\n\t\t\t}\n\t\t\tif tt.vm.ReadOnly != tt.wantReadOnly {\n\t\t\t\tt.Errorf(\"Expected readOnly %v, got %v\", tt.wantReadOnly, tt.vm.ReadOnly)\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestNetworkConfig(t *testing.T) {\n\tnc := NetworkConfig{\n\t\tHostNetwork: true,\n\t\tHostPID:     true,\n\t\tHostIPC:     false,\n\t\tDNSPolicy:   corev1.DNSClusterFirst,\n\t\tDNSConfig: &corev1.PodDNSConfig{\n\t\t\tNameservers: []string{\"8.8.8.8\"},\n\t\t},\n\t}\n\n\tif !nc.HostNetwork {\n\t\tt.Error(\"Expected HostNetwork to be true\")\n\t}\n\n\tif !nc.HostPID {\n\t\tt.Error(\"Expected HostPID to be true\")\n\t}\n\n\tif nc.HostIPC {\n\t\tt.Error(\"Expected HostIPC to be false\")\n\t}\n\n\tif nc.DNSPolicy != corev1.DNSClusterFirst {\n\t\tt.Errorf(\"Expected DNSPolicy DNSClusterFirst, got %s\", nc.DNSPolicy)\n\t}\n\n\tif nc.DNSConfig == nil {\n\t\tt.Error(\"Expected DNSConfig to be set\")\n\t}\n}\n\nfunc TestSecurityContext(t *testing.T) {\n\tsc := SecurityContext{\n\t\tRunAsUser:                int64Ptr(1000),\n\t\tRunAsGroup:               int64Ptr(1000),\n\t\tRunAsNonRoot:             boolPtr(true),\n\t\tReadOnlyRootFilesystem:   boolPtr(true),\n\t\tPrivileged:               boolPtr(false),\n\t\tAllowPrivilegeEscalation: boolPtr(false),\n\t}\n\n\tif sc.RunAsUser == nil || *sc.RunAsUser != 1000 {\n\t\tt.Error(\"Expected RunAsUser to be 1000\")\n\t}\n\n\tif sc.RunAsGroup == nil || *sc.RunAsGroup != 1000 {\n\t\tt.Error(\"Expected RunAsGroup to be 1000\")\n\t}\n\n\tif sc.RunAsNonRoot == nil || !*sc.RunAsNonRoot {\n\t\tt.Error(\"Expected RunAsNonRoot to be true\")\n\t}\n\n\tif sc.ReadOnlyRootFilesystem == nil || !*sc.ReadOnlyRootFilesystem {\n\t\tt.Error(\"Expected ReadOnlyRootFilesystem to be true\")\n\t}\n\n\tif sc.Privileged == nil || *sc.Privileged {\n\t\tt.Error(\"Expected Privileged to be false\")\n\t}\n\n\tif sc.AllowPrivilegeEscalation == nil || *sc.AllowPrivilegeEscalation {\n\t\tt.Error(\"Expected AllowPrivilegeEscalation to be false\")\n\t}\n}\n\nfunc TestLifecycleHooks(t *testing.T) {\n\tlh := LifecycleHooks{\n\t\tPostStart: &corev1.LifecycleHandler{\n\t\t\tExec: &corev1.ExecAction{\n\t\t\t\tCommand: []string{\"echo\", \"started\"},\n\t\t\t},\n\t\t},\n\t\tPreStop: &corev1.LifecycleHandler{\n\t\t\tExec: &corev1.ExecAction{\n\t\t\t\tCommand: []string{\"echo\", \"stopping\"},\n\t\t\t},\n\t\t},\n\t}\n\n\tif lh.PostStart == nil {\n\t\tt.Error(\"Expected PostStart to be set\")\n\t}\n\n\tif lh.PreStop == nil {\n\t\tt.Error(\"Expected PreStop to be set\")\n\t}\n}\n\nfunc TestHealthCheck(t *testing.T) {\n\thc := HealthCheck{\n\t\tLivenessProbe: &corev1.Probe{\n\t\t\tProbeHandler: corev1.ProbeHandler{\n\t\t\t\tHTTPGet: &corev1.HTTPGetAction{\n\t\t\t\t\tPath: \"/health\",\n\t\t\t\t\tPort: int32FromInt(8080),\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t\tReadinessProbe: &corev1.Probe{\n\t\t\tProbeHandler: corev1.ProbeHandler{\n\t\t\t\tHTTPGet: &corev1.HTTPGetAction{\n\t\t\t\t\tPath: \"/ready\",\n\t\t\t\t\tPort: int32FromInt(8080),\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t\tStartupProbe: &corev1.Probe{\n\t\t\tProbeHandler: corev1.ProbeHandler{\n\t\t\t\tHTTPGet: &corev1.HTTPGetAction{\n\t\t\t\t\tPath: \"/startup\",\n\t\t\t\t\tPort: int32FromInt(8080),\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\n\tif hc.LivenessProbe == nil {\n\t\tt.Error(\"Expected LivenessProbe to be set\")\n\t}\n\n\tif hc.ReadinessProbe == nil {\n\t\tt.Error(\"Expected ReadinessProbe to be set\")\n\t}\n\n\tif hc.StartupProbe == nil {\n\t\tt.Error(\"Expected StartupProbe to be set\")\n\t}\n}\n\nfunc TestTimeoutConfig(t *testing.T) {\n\ttc := TimeoutConfig{\n\t\tTTLSecondsAfterFinished: int32Ptr(3600),\n\t\tIdleTimeoutSeconds:      int32Ptr(1800),\n\t\tMaxLifetimeSeconds:      int32Ptr(28800),\n\t\tGracePeriodSeconds:      int64Ptr(30),\n\t}\n\n\tif tc.TTLSecondsAfterFinished == nil || *tc.TTLSecondsAfterFinished != 3600 {\n\t\tt.Error(\"Expected TTLSecondsAfterFinished to be 3600\")\n\t}\n\n\tif tc.IdleTimeoutSeconds == nil || *tc.IdleTimeoutSeconds != 1800 {\n\t\tt.Error(\"Expected IdleTimeoutSeconds to be 1800\")\n\t}\n\n\tif tc.MaxLifetimeSeconds == nil || *tc.MaxLifetimeSeconds != 28800 {\n\t\tt.Error(\"Expected MaxLifetimeSeconds to be 28800\")\n\t}\n\n\tif tc.GracePeriodSeconds == nil || *tc.GracePeriodSeconds != 30 {\n\t\tt.Error(\"Expected GracePeriodSeconds to be 30\")\n\t}\n}\n\nfunc TestConditionJSONMarshal(t *testing.T) {\n\tnow := metav1.NewTime(time.Now())\n\n\tcond := Condition{\n\t\tType:               ConditionReady,\n\t\tStatus:             corev1.ConditionTrue,\n\t\tLastTransitionTime: now,\n\t\tReason:             \"ResourceReady\",\n\t\tMessage:            \"Resource is ready\",\n\t\tObservedGeneration: 1,\n\t}\n\n\tdata, err := json.Marshal(cond)\n\tif err != nil {\n\t\tt.Fatalf(\"Failed to marshal Condition: %v\", err)\n\t}\n\n\tvar unmarshaled Condition\n\terr = json.Unmarshal(data, &unmarshaled)\n\tif err != nil {\n\t\tt.Fatalf(\"Failed to unmarshal Condition: %v\", err)\n\t}\n\n\tif unmarshaled.Type != cond.Type {\n\t\tt.Errorf(\"Expected type %s, got %s\", cond.Type, unmarshaled.Type)\n\t}\n\n\tif unmarshaled.Status != cond.Status {\n\t\tt.Errorf(\"Expected status %s, got %s\", cond.Status, unmarshaled.Status)\n\t}\n\n\tif unmarshaled.Reason != cond.Reason {\n\t\tt.Errorf(\"Expected reason %s, got %s\", cond.Reason, unmarshaled.Reason)\n\t}\n\n\tif unmarshaled.Message != cond.Message {\n\t\tt.Errorf(\"Expected message %s, got %s\", cond.Message, unmarshaled.Message)\n\t}\n}\n\nfunc TestConstants(t *testing.T) {\n\t// Test API constants\n\tif APIGroup != \"runtime.agentcube.volcano.sh\" {\n\t\tt.Errorf(\"Expected APIGroup 'runtime.agentcube.volcano.sh', got %s\", APIGroup)\n\t}\n\n\tif APIVersion != \"v1alpha1\" {\n\t\tt.Errorf(\"Expected APIVersion 'v1alpha1', got %s\", APIVersion)\n\t}\n\n\tif FullAPIVersion != \"runtime.agentcube.volcano.sh/v1alpha1\" {\n\t\tt.Errorf(\"Expected FullAPIVersion 'runtime.agentcube.volcano.sh/v1alpha1', got %s\", FullAPIVersion)\n\t}\n\n\t// Test kind constants\n\tif AgentRuntimeKind != \"AgentRuntime\" {\n\t\tt.Errorf(\"Expected AgentRuntimeKind 'AgentRuntime', got %s\", AgentRuntimeKind)\n\t}\n\n\tif CodeInterpreterKind != \"CodeInterpreter\" {\n\t\tt.Errorf(\"Expected CodeInterpreterKind 'CodeInterpreter', got %s\", CodeInterpreterKind)\n\t}\n\n\t// Test phase constants\n\tif PhasePending != \"Pending\" {\n\t\tt.Errorf(\"Expected PhasePending 'Pending', got %s\", PhasePending)\n\t}\n\n\t// Test condition type constants\n\tif ConditionReady != \"Ready\" {\n\t\tt.Errorf(\"Expected ConditionReady 'Ready', got %s\", ConditionReady)\n\t}\n\n\t// Test reason constants\n\tif ReasonCreating != \"Creating\" {\n\t\tt.Errorf(\"Expected ReasonCreating 'Creating', got %s\", ReasonCreating)\n\t}\n\n\t// Test timeout constants\n\tif DefaultTTLSecondsAfterFinished != 3600 {\n\t\tt.Errorf(\"Expected DefaultTTLSecondsAfterFinished 3600, got %d\", DefaultTTLSecondsAfterFinished)\n\t}\n\n\t// Test port constants\n\tif DefaultHTTPPort != 80 {\n\t\tt.Errorf(\"Expected DefaultHTTPPort 80, got %d\", DefaultHTTPPort)\n\t}\n\n\t// Test resource quantity defaults\n\tif DefaultCPURequest != \"100m\" {\n\t\tt.Errorf(\"Expected DefaultCPURequest '100m', got %s\", DefaultCPURequest)\n\t}\n\n\t// Test status constants\n\tif StatusTrue != \"True\" {\n\t\tt.Errorf(\"Expected StatusTrue 'True', got %s\", StatusTrue)\n\t}\n\n\t// Test finalizer constants\n\tif FinalizerSandbox != \"runtime.agentcube.volcano.sh/sandbox-cleanup\" {\n\t\tt.Errorf(\"Expected FinalizerSandbox 'runtime.agentcube.volcano.sh/sandbox-cleanup', got %s\", FinalizerSandbox)\n\t}\n\n\t// Test event reason constants\n\tif EventReasonCreated != \"Created\" {\n\t\tt.Errorf(\"Expected EventReasonCreated 'Created', got %s\", EventReasonCreated)\n\t}\n\n\t// Test error message constants\n\tif ErrMsgResourceNotFound != \"resource not found\" {\n\t\tt.Errorf(\"Expected ErrMsgResourceNotFound 'resource not found', got %s\", ErrMsgResourceNotFound)\n\t}\n}\n\n// Helper functions\nfunc int32Ptr(i int32) *int32 {\n\treturn &i\n}\n\nfunc int64Ptr(i int64) *int64 {\n\treturn &i\n}\n\nfunc boolPtr(b bool) *bool {\n\treturn &b\n}\n\nfunc mustParseQuantity(s string) resource.Quantity {\n\treturn resource.MustParse(s)\n}\n\nfunc int32FromInt(i int) intstr.IntOrString {\n\treturn intstr.FromInt(i)\n}\n","additions":0,"deletions":360},"truncated":false},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/apis/runtime/v1alpha1/common_types_test.go","time":{"start":1775843051764,"end":1775843052000}}}}
