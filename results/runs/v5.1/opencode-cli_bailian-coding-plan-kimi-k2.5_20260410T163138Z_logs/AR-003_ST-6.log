all resources.\n80: \tCategoryAll = \"all\"\n81: )\n82: \n83: // Common label and annotation keys used across AgentCube resources.\n84: const (\n85: \t// LabelManagedBy is the label key indicating the controller managing the resource.\n86: \tLabelManagedBy = \"app.kubernetes.io/managed-by\"\n87: \n88: \t// LabelCreatedBy is the label key indicating the creator of the resource.\n89: \tLabelCreatedBy = \"app.kubernetes.io/created-by\"\n90: \n91: \t// LabelComponent is the label key indicating the component type.\n92: \tLabelComponent = \"app.kubernetes.io/component\"\n93: \n94: \t// LabelInstance is the label key indicating the instance name.\n95: \tLabelInstance = \"app.kubernetes.io/instance\"\n96: \n97: \t// LabelPartOf is the label key indicating the application this resource is part of.\n98: \tLabelPartOf = \"app.kubernetes.io/part-of\"\n99: \n100: \t// LabelSandboxID is the label key for the sandbox ID.\n101: \tLabelSandboxID = \"runtime.agentcube.volcano.sh/sandbox-id\"\n102: \n103: \t// LabelSessionID is the label key for the session ID.\n104: \tLabelSessionID = \"runtime.agentcube.volcano.sh/session-id\"\n105: \n106: \t// LabelResourceType is the label key for the resource type.\n107: \tLabelResourceType = \"runtime.agentcube.volcano.sh/resource-type\"\n108: )\n109: \n110: // Common annotation keys used across AgentCube resources.\n111: const (\n112: \t// AnnotationDescription is the annotation key for resource description.\n113: \tAnnotationDescription = \"runtime.agentcube.volcano.sh/description\"\n114: \n115: \t// AnnotationCreatedAt is the annotation key for creation timestamp.\n116: \tAnnotationCreatedAt = \"runtime.agentcube.volcano.sh/created-at\"\n117: \n118: \t// AnnotationUpdatedAt is the annotation key for update timestamp.\n119: \tAnnotationUpdatedAt = \"runtime.agentcube.volcano.sh/updated-at\"\n120: \n121: \t// AnnotationLastAppliedConfiguration is the annotation key for the last applied configuration.\n122: \tAnnotationLastAppliedConfiguration 