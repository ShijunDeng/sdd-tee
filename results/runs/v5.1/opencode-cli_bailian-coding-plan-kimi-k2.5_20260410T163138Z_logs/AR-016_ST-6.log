{"type":"tool_use","timestamp":1775877060278,"sessionID":"ses_2857fbf8fffeHhKEiyGQze1uRE","part":{"id":"prt_d7a856cff001XulwGU8wA1tz5Y","messageID":"msg_d7a854cb9001ogbA2K7QN9yGuf","sessionID":"ses_2857fbf8fffeHhKEiyGQze1uRE","type":"tool","tool":"read","callID":"toolu_functions.read:25","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/picod/errors.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/picod/errors.go</path>\n<type>file</type>\n<content>\n1: /*\n2: Copyright 2026 The Volcano Authors.\n3: \n4: Licensed under the Apache License, Version 2.0 (the \"License\");\n5: you may not use this file except in compliance with the License.\n6: You may obtain a copy of the License at\n7: \n8:     http://www.apache.org/licenses/LICENSE-2.0\n9: \n10: Unless required by applicable law or agreed to in writing, software\n11: distributed under the License is distributed on an \"AS IS\" BASIS,\n12: WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n13: See the License for the specific language governing permissions and\n14: limitations under the License.\n15: */\n16: \n17: package picod\n18: \n19: import \"errors\"\n20: \n21: // PicoD execution errors\n22: var (\n23: \t// ErrInvalidRequest indicates a malformed execution request\n24: \tErrInvalidRequest = errors.New(\"picod: invalid request\")\n25: \n26: \t// ErrInvalidCommand indicates an empty or invalid command\n27: \tErrInvalidCommand = errors.New(\"picod: command is required\")\n28: \n29: \t// ErrInvalidSessionID indicates a missing or invalid session ID\n30: \tErrInvalidSessionID = errors.New(\"picod: session ID is required\")\n31: \n32: \t// ErrInvalidWorkingDir indicates an invalid working directory\n33: \tErrInvalidWorkingDir = errors.New(\"picod: invalid working directory\")\n34: \n35: \t// ErrResourceExceeded indicates resource limits exceeded\n36: \tErrResourceExceeded = errors.New(\"picod: resource limits exceeded\")\n37: \n38: \t// ErrTimeout indicates execution timeout\n39: \tErrTimeout = errors.New(\"picod: execution timeout\")\n40: \n41: \t// ErrSandboxUnavailable indicates sandbox not accessible\n42: \tErrSandboxUnavailable = errors.New(\"picod: sandbox unavailable\")\n43: \n44: \t// ErrExecutionFailed indicates command returned non-zero exit\n45: \tErrExecutionFailed = errors.New(\"picod: execution failed\")\n46: \n47: \t// ErrExecutionNotFound indicates execution ID not found\n48: \tErrExecutionNotFound = errors.New(\"picod: execution not found\")\n49: \n50: \t// ErrExecutionAlreadyComplete indicates cannot cancel completed execution\n51: \tErrExecutionAlreadyComplete = errors.New(\"picod: execution already complete\")\n52: \n53: \t// ErrTooManyConcurrentExecutions indicates concurrent limit exceeded\n54: \tErrTooManyConcurrentExecutions = errors.New(\"picod: too many concurrent executions\")\n55: \n56: \t// ErrCancelled indicates execution was cancelled\n57: \tErrCancelled = errors.New(\"picod: execution cancelled\")\n58: )\n59: \n60: // Error codes for machine-readable error identification\n61: const (\n62: \t// ErrorCodeInvalidRequest indicates malformed request\n63: \tErrorCodeInvalidRequest = \"INVALID_REQUEST\"\n64: \n65: \t// ErrorCodeInvalidCommand indicates empty or invalid command\n66: \tErrorCodeInvalidCommand = \"INVALID_COMMAND\"\n67: \n68: \t// ErrorCodeInvalidSessionID indicates missing or invalid session ID\n69: \tErrorCodeInvalidSessionID = \"INVALID_SESSION_ID\"\n70: \n71: \t// ErrorCodeInvalidWorkingDir indicates invalid working directory\n72: \tErrorCodeInvalidWorkingDir = \"INVALID_WORKING_DIR\"\n73: \n74: \t// ErrorCodeResourceExceeded indicates resource limits exceeded\n75: \tErrorCodeResourceExceeded = \"RESOURCE_EXCEEDED\"\n76: \n77: \t// ErrorCodeTimeout indicates execution timeout\n78: \tErrorCodeTimeout = \"TIMEOUT\"\n79: \n80: \t// ErrorCodeSandboxUnavailable indicates sandbox not accessible\n81: \tErrorCodeSandboxUnavailable = \"SANDBOX_UNAVAILABLE\"\n82: \n83: \t// ErrorCodeExecutionFailed indicates command returned non-zero exit\n84: \tErrorCodeExecutionFailed = \"EXECUTION_FAILED\"\n85: \n86: \t// ErrorCodeExecutionNotFound indicates execution ID not found\n87: \tErrorCodeExecutionNotFound = \"EXECUTION_NOT_FOUND\"\n88: \n89: \t// ErrorCodeExecutionAlreadyComplete indicates cannot cancel completed execution\n90: \tErrorCodeExecutionAlreadyComplete = \"EXECUTION_ALREADY_COMPLETE\"\n91: \n92: \t// ErrorCodeTooManyConcurrent indicates concurrent limit exceeded\n93: \tErrorCodeTooManyConcurrent = \"TOO_MANY_CONCURRENT\"\n94: \n95: \t// ErrorCodeCancelled indicates execution was cancelled\n96: \tErrorCodeCancelled = \"CANCELLED\"\n97: )\n98: \n99: // IsRetryableError returns true if the error is potentially retryable.\n100: func IsRetryableError(err error) bool {\n101: \tif err == nil {\n102: \t\treturn false\n103: \t}\n104: \treturn errors.Is(err, ErrResourceExceeded) ||\n105: \t\terrors.Is(err, ErrTimeout) ||\n106: \t\terrors.Is(err, ErrSandboxUnavailable) ||\n107: \t\terrors.Is(err, ErrTooManyConcurrentExecutions)\n108: }\n109: \n110: // ErrorCode returns the machine-readable error code for an error.\n111: func ErrorCode(err error) string {\n112: \tif err == nil {\n113: \t\treturn \"\"\n114: \t}\n115: \tswitch {\n116: \tcase errors.Is(err, ErrInvalidRequest):\n117: \t\treturn ErrorCodeInvalidRequest\n118: \tcase errors.Is(err, ErrInvalidCommand):\n119: \t\treturn ErrorCodeInvalidCommand\n120: \tcase errors.Is(err, ErrInvalidSessionID):\n121: \t\treturn ErrorCodeInvalidSessionID\n122: \tcase errors.Is(err, ErrInvalidWorkingDir):\n123: \t\treturn ErrorCodeInvalidWorkingDir\n124: \tcase errors.Is(err, ErrResourceExceeded):\n125: \t\treturn ErrorCodeResourceExceeded\n126: \tcase errors.Is(err, ErrTimeout):\n127: \t\treturn ErrorCodeTimeout\n128: \tcase errors.Is(err, ErrSandboxUnavailable):\n129: \t\treturn ErrorCodeSandboxUnavailable\n130: \tcase errors.Is(err, ErrExecutionFailed):\n131: \t\treturn ErrorCodeExecutionFailed\n132: \tcase errors.Is(err, ErrExecutionNotFound):\n133: \t\treturn ErrorCodeExecutionNotFound\n134: \tcase errors.Is(err, ErrExecutionAlreadyComplete):\n135: \t\treturn ErrorCodeExecutionAlreadyComplete\n136: \tcase errors.Is(err, ErrTooManyConcurrentExecutions):\n137: \t\treturn ErrorCodeTooManyConcurrent\n138: \tcase errors.Is(err, ErrCancelled):\n139: \t\treturn ErrorCodeCancelled\n140: \tdefault:\n141: \t\treturn \"UNKNOWN\"\n142: \t}\n143: }\n\n(End of file - total 143 lines)\n</content>","metadata":{"preview":"/*\nCopyright 2026 The Volcano Authors.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\npackage picod\n\nimport \"errors\"\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/picod/errors.go","time":{"start":1775877060258,"end":1775877060276}}}}
{"type":"tool_use","timestamp":1775877060280,"sessionID":"ses_2857fbf8fffeHhKEiyGQze1uRE","part":{"id":"prt_d7a8571f4001gbLS6x32XrZzLq","messageID":"msg_d7a854cb9001ogbA2K7QN9yGuf","sessionID":"ses_2857fbf8fffeHhKEiyGQze1uRE","type":"tool","tool":"read","callID":"toolu_functions.read:26","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/picod/types.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/picod/types.go</path>\n<type>file</type>\n<content>\n1: /*\n2: Copyright 2026 The Volcano Authors.\n3: \n4: Licensed under the Apache License, Version 2.0 (the \"License\");\n5: you may not use this file except in compliance with the License.\n6: You may obtain a copy of the License at\n7: \n8:     http://www.apache.org/licenses/LICENSE-2.0\n9: \n10: Unless required by applicable law or agreed to in writing, software\n11: distributed under the License is distributed on an \"AS IS\" BASIS,\n12: WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n13: See the License for the specific language governing permissions and\n14: limitations under the License.\n15: */\n16: \n17: package picod\n18: \n19: import (\n20: \t\"context\"\n21: \t\"fmt\"\n22: \t\"strings\"\n23: \t\"time\"\n24: \n25: \t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n26: )\n27: \n28: // ExecutionID uniquely identifies a command execution.\n29: type ExecutionID string\n30: \n31: // ExecutionState represents the state of command execution.\n32: type ExecutionState string\n33: \n34: const (\n35: \t// StatePending indicates the execution is queued\n36: \tStatePending ExecutionState = \"pending\"\n37: \n38: \t// StateRunning indicates the execution is in progress\n39: \tStateRunning ExecutionState = \"running\"\n40: \n41: \t// StateCompleted indicates the execution completed successfully\n42: \tStateCompleted ExecutionState = \"completed\"\n43: \n44: \t// StateFailed indicates the execution failed\n45: \tStateFailed ExecutionState = \"failed\"\n46: \n47: \t// StateCancelled indicates the execution was cancelled\n48: \tStateCancelled ExecutionState = \"cancelled\"\n49: )\n50: \n51: // IsTerminal returns true if the state is terminal (completed, failed, or cancelled).\n52: func (s ExecutionState) IsTerminal() bool {\n53: \treturn s == StateCompleted || s == StateFailed || s == StateCancelled\n54: }\n55: \n56: // String returns the string representation of the state.\n57: func (s ExecutionState) String() string {\n58: \treturn string(s)\n59: }\n60: \n61: // ExecutionRequest contains parameters for command execution.\n62: type ExecutionRequest struct {\n63: \t// Command is the command to execute (required)\n64: \tCommand string `json:\"command\"`\n65: \n66: \t// Args are the command arguments\n67: \tArgs []string `json:\"args,omitempty\"`\n68: \n69: \t// WorkingDir is the working directory for execution (default: sandbox default)\n70: \tWorkingDir string `json:\"workingDir,omitempty\"`\n71: \n72: \t// Environment defines environment variables (merged with sandbox defaults)\n73: \tEnvironment map[string]string `json:\"environment,omitempty\"`\n74: \n75: \t// Timeout is the maximum execution time (default: 30s)\n76: \tTimeout time.Duration `json:\"timeout,omitempty\"`\n77: \n78: \t// ResourceLimits defines resource constraints for execution\n79: \tResourceLimits ResourceConstraints `json:\"resourceLimits,omitempty\"`\n80: \n81: \t// SessionID identifies the target sandbox (required)\n82: \tSessionID string `json:\"sessionId\"`\n83: }\n84: \n85: // Validate validates the execution request.\n86: func (r *ExecutionRequest) Validate() error {\n87: \tif strings.TrimSpace(r.Command) == \"\" {\n88: \t\treturn ErrInvalidCommand\n89: \t}\n90: \tif strings.Contains(r.Command, \"..\") || strings.Contains(r.Command, \"//\") {\n91: \t\treturn fmt.Errorf(\"%w: command contains invalid characters\", ErrInvalidCommand)\n92: \t}\n93: \tif r.SessionID == \"\" {\n94: \t\treturn ErrInvalidSessionID\n95: \t}\n96: \tif r.WorkingDir != \"\" && !isAllowedWorkingDir(r.WorkingDir) {\n97: \t\treturn ErrInvalidWorkingDir\n98: \t}\n99: \tfor name := range r.Environment {\n100: \t\tif !isValidEnvVarName(name) {\n101: \t\t\treturn fmt.Errorf(\"%w: invalid environment variable name: %s\", ErrInvalidRequest, name)\n102: \t\t}\n103: \t}\n104: \treturn nil\n105: }\n106: \n107: // ExecutionResult contains the result of a command execution.\n108: type ExecutionResult struct {\n109: \t// ID is the unique execution identifier\n110: \tID ExecutionID `json:\"id\"`\n111: \n112: \t// Status contains the execution status details\n113: \tStatus ExecutionStatus `json:\"status\"`\n114: \n115: \t// ExitCode is the command exit code (0 for success)\n116: \tExitCode int `json:\"exitCode\"`\n117: \n118: \t// Stdout contains the captured standard output\n119: \tStdout []byte `json:\"stdout,omitempty\"`\n120: \n121: \t// Stderr contains the captured standard error\n122: \tStderr []byte `json:\"stderr,omitempty\"`\n123: \n124: \t// StartedAt is when execution started\n125: \tStartedAt time.Time `json:\"startedAt\"`\n126: \n127: \t// FinishedAt is when execution completed\n128: \tFinishedAt time.Time `json:\"finishedAt\"`\n129: \n130: \t// Error contains error details if execution failed\n131: \tError *ExecutionError `json:\"error,omitempty\"`\n132: \n133: \t// Truncated indicates if output was truncated due to size limits\n134: \tTruncated bool `json:\"truncated,omitempty\"`\n135: }\n136: \n137: // ExecutionError contains detailed error information.\n138: type ExecutionError struct {\n139: \t// Code is the machine-readable error code\n140: \tCode string `json:\"code\"`\n141: \n142: \t// Message is the human-readable error message\n143: \tMessage string `json:\"message\"`\n144: \n145: \t// Details contains additional error context\n146: \tDetails map[string]interface{} `json:\"details,omitempty\"`\n147: }\n148: \n149: // ExecutionStatus represents the current state of an execution.\n150: type ExecutionStatus struct {\n151: \t// ID is the unique execution identifier\n152: \tID ExecutionID `json:\"id\"`\n153: \n154: \t// State is the current execution state\n155: \tState ExecutionState `json:\"state\"`\n156: \n157: \t// StartedAt is when execution started (nil if not started)\n158: \tStartedAt *time.Time `json:\"startedAt,omitempty\"`\n159: \n160: \t// FinishedAt is when execution completed (nil if not finished)\n161: \tFinishedAt *time.Time `json:\"finishedAt,omitempty\"`\n162: \n163: \t// ExitCode is the command exit code (nil if not finished)\n164: \tExitCode *int `json:\"exitCode,omitempty\"`\n165: \n166: \t// OutputRef references stored output (for large outputs)\n167: \tOutputRef string `json:\"outputRef,omitempty\"`\n168: \n169: \t// SessionID is the target sandbox session ID\n170: \tSessionID string `json:\"sessionId\"`\n171: }\n172: \n173: // ResourceConstraints defines resource limits for execution.\n174: type ResourceConstraints struct {\n175: \t// MaxMemory is the maximum memory in bytes (0 = unlimited)\n176: \tMaxMemory int64 `json:\"maxMemory,omitempty\"`\n177: \n178: \t// MaxCPU is the maximum CPU percentage (0-100, 0 = unlimited)\n179: \tMaxCPU float64 `json:\"maxCpu,omitempty\"`\n180: \n181: \t// MaxIOBytes is the maximum IO bandwidth in bytes per second (0 = unlimited)\n182: \tMaxIOBytes int64 `json:\"maxIoBytes,omitempty\"`\n183: \n184: \t// MaxFiles is the maximum number of open file descriptors (0 = unlimited)\n185: \tMaxFiles int `json:\"maxFiles,omitempty\"`\n186: }\n187: \n188: // IsEmpty returns true if no constraints are set.\n189: func (r ResourceConstraints) IsEmpty() bool {\n190: \treturn r.MaxMemory == 0 && r.MaxCPU == 0 && r.MaxIOBytes == 0 && r.MaxFiles == 0\n191: }\n192: \n193: // Validate validates resource constraints.\n194: func (r ResourceConstraints) Validate() error {\n195: \tif r.MaxMemory < 0 {\n196: \t\treturn fmt.Errorf(\"%w: maxMemory cannot be negative\", ErrInvalidRequest)\n197: \t}\n198: \tif r.MaxCPU < 0 || r.MaxCPU > 100 {\n199: \t\treturn fmt.Errorf(\"%w: maxCpu must be between 0 and 100\", ErrInvalidRequest)\n200: \t}\n201: \tif r.MaxIOBytes < 0 {\n202: \t\treturn fmt.Errorf(\"%w: maxIoBytes cannot be negative\", ErrInvalidRequest)\n203: \t}\n204: \tif r.MaxFiles < 0 {\n205: \t\treturn fmt.Errorf(\"%w: maxFiles cannot be negative\", ErrInvalidRequest)\n206: \t}\n207: \treturn nil\n208: }\n209: \n210: // OutputChunk represents a piece of output from a command.\n211: type OutputChunk struct {\n212: \t// Data is the output data\n213: \tData []byte `json:\"data\"`\n214: \n215: \t// Type indicates the output source\n216: \tType OutputType `json:\"type\"`\n217: \n218: \t// Timestamp is when the output was captured\n219: \tTimestamp time.Time `json:\"timestamp\"`\n220: }\n221: \n222: // OutputType indicates the source of output.\n223: type OutputType string\n224: \n225: const (\n226: \t// Stdout indicates standard output\n227: \tStdout OutputType = \"stdout\"\n228: \n229: \t// Stderr indicates standard error\n230: \tStderr OutputType = \"stderr\"\n231: )\n232: \n233: // String returns the string representation of the output type.\n234: func (o OutputType) String() string {\n235: \treturn string(o)\n236: }\n237: \n238: // CommandExecutor defines the interface for executing commands in sandboxes.\n239: type CommandExecutor interface {\n240: \t// Execute runs a command synchronously and returns the result.\n241: \t// Blocks until execution completes, times out, or is cancelled.\n242: \tExecute(ctx context.Context, req ExecutionRequest) (*ExecutionResult, error)\n243: \n244: \t// ExecuteAsync runs a command asynchronously and returns an execution ID.\n245: \t// Returns immediately; use GetStatus to poll for completion.\n246: \tExecuteAsync(ctx context.Context, req ExecutionRequest) (ExecutionID, error)\n247: \n248: \t// GetStatus retrieves the current status of an execution.\n249: \t// Returns ErrExecutionNotFound if the execution does not exist.\n250: \tGetStatus(ctx context.Context, id ExecutionID) (*ExecutionStatus, error)\n251: \n252: \t// Cancel stops a running execution.\n253: \t// Returns ErrExecutionAlreadyComplete if execution is in terminal state.\n254: \tCancel(ctx context.Context, id ExecutionID) error\n255: \n256: \t// StreamOutput returns a channel for streaming output from an execution.\n257: \t// Channel is closed when execution completes or context is cancelled.\n258: \tStreamOutput(ctx context.Context, id ExecutionID) (<-chan OutputChunk, error)\n259: }\n260: \n261: // ExecutionStore defines the interface for execution status persistence.\n262: type ExecutionStore interface {\n263: \t// CreateStatus creates a new execution status record.\n264: \tCreateStatus(ctx context.Context, status *ExecutionStatus) error\n265: \n266: \t// GetStatus retrieves execution status by ID.\n267: \t// Returns ErrExecutionNotFound if not found.\n268: \tGetStatus(ctx context.Context, id ExecutionID) (*ExecutionStatus, error)\n269: \n270: \t// UpdateStatus updates execution status.\n271: \tUpdateStatus(ctx context.Context, status *ExecutionStatus) error\n272: \n273: \t// UpdateStatusWithTransition updates status with state transition validation.\n274: \t// Only allows valid state transitions.\n275: \tUpdateStatusWithTransition(ctx context.Context, id ExecutionID, from, to ExecutionState, updateFn func(*ExecutionStatus)) error\n276: \n277: \t// DeleteStatus removes an execution status record.\n278: \tDeleteStatus(ctx context.Context, id ExecutionID) error\n279: \n280: \t// ListExecutions lists executions filtered by state and session.\n281: \tListExecutions(ctx context.Context, filter ExecutionFilter) ([]*ExecutionStatus, error)\n282: \n283: \t// StoreOutput stores execution output for later retrieval.\n284: \tStoreOutput(ctx context.Context, id ExecutionID, stdout, stderr []byte) error\n285: \n286: \t// GetOutput retrieves stored execution output.\n287: \tGetOutput(ctx context.Context, id ExecutionID) (stdout, stderr []byte, err error)\n288: }\n289: \n290: // ExecutionFilter defines filters for listing executions.\n291: type ExecutionFilter struct {\n292: \t// SessionID filters by session\n293: \tSessionID string\n294: \n295: \t// State filters by execution state\n296: \tState ExecutionState\n297: \n298: \t// Limit limits the number of results\n299: \tLimit int\n300: }\n301: \n302: // SandboxResolver resolves session IDs to sandbox information.\n303: type SandboxResolver interface {\n304: \t// Resolve returns sandbox info for a session ID.\n305: \t// Returns ErrSandboxUnavailable if session doesn't exist.\n306: \tResolve(ctx context.Context, sessionID string) (*types.SandboxInfo, error)\n307: }\n308: \n309: // SandboxRunner executes commands in a sandbox.\n310: type SandboxRunner interface {\n311: \t// Run executes a command synchronously.\n312: \tRun(ctx context.Context, sandbox *types.SandboxInfo, req ExecutionRequest) (*ExecutionResult, error)\n313: \n314: \t// Start begins async command execution.\n315: \tStart(ctx context.Context, sandbox *types.SandboxInfo, req ExecutionRequest, id ExecutionID) error\n316: \n317: \t// Cancel stops a running command.\n318: \tCancel(ctx context.Context, sandbox *types.SandboxInfo, id ExecutionID) error\n319: }\n320: \n321: // QueuedExecution represents an execution in the queue.\n322: type QueuedExecution struct {\n323: \tID         ExecutionID\n324: \tRequest    ExecutionRequest\n325: \tEnqueuedAt time.Time\n326: }\n327: \n328: // ExecutionQueue manages the async execution queue.\n329: type ExecutionQueue interface {\n330: \t// Enqueue adds an execution request to the queue.\n331: \t// Returns the assigned execution ID.\n332: \tEnqueue(req ExecutionRequest) (ExecutionID, error)\n333: \n334: \t// Dequeue retrieves the next pending execution.\n335: \t// Blocks until an execution is available or context is cancelled.\n336: \tDequeue(ctx context.Context) (*QueuedExecution, error)\n337: \n338: \t// GetPosition returns the queue position for an execution.\n339: \tGetPosition(id ExecutionID) (int, error)\n340: \n341: \t// Remove removes an execution from the queue.\n342: \tRemove(id ExecutionID) error\n343: \n344: \t// Size returns the current queue size.\n345: \tSize() int\n346: }\n\n(End of file - total 346 lines)\n</content>","metadata":{"preview":"/*\nCopyright 2026 The Volcano Authors.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\npackage picod\n\nimport (\n\t\"context\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/picod/types.go","time":{"start":1775877060260,"end":1775877060278}}}}
{"type":"tool_use","timestamp":1775877060301,"sessionID":"ses_2857fbf8fffeHhKEiyGQze1uRE","part":{"id":"prt_d7a85675c001OyxoLSx2G2NLsM","messageID":"msg_d7a854cb9001ogbA2K7QN9yGuf","sessionID":"ses_2857fbf8fffeHhKEiyGQze1uRE","type":"tool","tool":"read","callID":"toolu_functions.read:24","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/apis/runtime/v1alpha1/codeinterpreter_types_test.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/apis/runtime/v1alpha1/codeinterpreter_types_test.go</path>\n<type>file</type>\n<content>\n1: /*\n2: Copyright 2026 The Volcano Authors.\n3: \n4: Licensed under the Apache License, Version 2.0 (the \"License\");\n5: you may not use this file except in compliance with the License.\n6: You may obtain a copy of the License at\n7: \n8:     http://www.apache.org/licenses/LICENSE-2.0\n9: \n10: Unless required by applicable law or agreed to in writing, software\n11: distributed under the License is distributed on an \"AS IS\" BASIS,\n12: WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n13: See the License for the specific language governing permissions and\n14: limitations under the License.\n15: */\n16: \n17: package v1alpha1\n18: \n19: import (\n20: \t\"encoding/json\"\n21: \t\"testing\"\n22: \t\"time\"\n23: \n24: \tcorev1 \"k8s.io/api/core/v1\"\n25: \t\"k8s.io/apimachinery/pkg/api/resource\"\n26: \tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n27: )\n28: \n29: func TestProtocolTypeValues(t *testing.T) {\n30: \ttests := []struct {\n31: \t\tname     string\n32: \t\tprotocol ProtocolType\n33: \t\texpected string\n34: \t}{\n35: \t\t{\"HTTP\", ProtocolHTTP, \"HTTP\"},\n36: \t\t{\"HTTPS\", ProtocolHTTPS, \"HTTPS\"},\n37: \t}\n38: \n39: \tfor _, tt := range tests {\n40: \t\tt.Run(tt.name, func(t *testing.T) {\n41: \t\t\tif string(tt.protocol) != tt.expected {\n42: \t\t\t\tt.Errorf(\"Expected protocol %s, got %s\", tt.expected, tt.protocol)\n43: \t\t\t}\n44: \t\t})\n45: \t}\n46: }\n47: \n48: func TestAuthModeTypeValues(t *testing.T) {\n49: \ttests := []struct {\n50: \t\tname     string\n51: \t\tauthMode AuthModeType\n52: \t\texpected string\n53: \t}{\n54: \t\t{\"PicoD\", AuthModePicoD, \"picod\"},\n55: \t\t{\"None\", AuthModeNone, \"none\"},\n56: \t}\n57: \n58: \tfor _, tt := range tests {\n59: \t\tt.Run(tt.name, func(t *testing.T) {\n60: \t\t\tif string(tt.authMode) != tt.expected {\n61: \t\t\t\tt.Errorf(\"Expected auth mode %s, got %s\", tt.expected, tt.authMode)\n62: \t\t\t}\n63: \t\t})\n64: \t}\n65: }\n66: \n67: func TestTargetPort(t *testing.T) {\n68: \ttests := []struct {\n69: \t\tname       string\n70: \t\ttargetPort TargetPort\n71: \t}{\n72: \t\t{\n73: \t\t\tname: \"minimal target port\",\n74: \t\t\ttargetPort: TargetPort{\n75: \t\t\t\tPort:     8080,\n76: \t\t\t\tProtocol: ProtocolHTTP,\n77: \t\t\t},\n78: \t\t},\n79: \t\t{\n80: \t\t\tname: \"target port with all fields\",\n81: \t\t\ttargetPort: TargetPort{\n82: \t\t\t\tPathPrefix: \"/api\",\n83: \t\t\t\tName:       \"http-port\",\n84: \t\t\t\tPort:       443,\n85: \t\t\t\tProtocol:   ProtocolHTTPS,\n86: \t\t\t},\n87: \t\t},\n88: \t\t{\n89: \t\t\tname: \"target port without protocol (uses default)\",\n90: \t\t\ttargetPort: TargetPort{\n91: \t\t\t\tPort: 3000,\n92: \t\t\t},\n93: \t\t},\n94: \t}\n95: \n96: \tfor _, tt := range tests {\n97: \t\tt.Run(tt.name, func(t *testing.T) {\n98: \t\t\tif tt.targetPort.Port == 0 {\n99: \t\t\t\tt.Error(\"Port should not be 0\")\n100: \t\t\t}\n101: \t\t})\n102: \t}\n103: }\n104: \n105: func TestCodeInterpreterSandboxTemplate(t *testing.T) {\n106: \ttests := []struct {\n107: \t\tname     string\n108: \t\ttemplate CodeInterpreterSandboxTemplate\n109: \t}{\n110: \t\t{\n111: \t\t\tname: \"template with pod spec\",\n112: \t\t\ttemplate: CodeInterpreterSandboxTemplate{\n113: \t\t\t\tSpec: corev1.PodSpec{\n114: \t\t\t\t\tContainers: []corev1.Container{\n115: \t\t\t\t\t\t{\n116: \t\t\t\t\t\t\tName:  \"code-interpreter\",\n117: \t\t\t\t\t\t\tImage: \"python:3.11\",\n118: \t\t\t\t\t\t},\n119: \t\t\t\t\t},\n120: \t\t\t\t},\n121: \t\t\t},\n122: \t\t},\n123: \t\t{\n124: \t\t\tname: \"template with labels and annotations\",\n125: \t\t\ttemplate: CodeInterpreterSandboxTemplate{\n126: \t\t\t\tLabels: map[string]string{\n127: \t\t\t\t\t\"app\": \"code-interpreter\",\n128: \t\t\t\t},\n129: \t\t\t\tAnnotations: map[string]string{\n130: \t\t\t\t\t\"description\": \"Code interpreter sandbox\",\n131: \t\t\t\t},\n132: \t\t\t\tSpec: corev1.PodSpec{\n133: \t\t\t\t\tContainers: []corev1.Container{\n134: \t\t\t\t\t\t{\n135: \t\t\t\t\t\t\tName:  \"code-interpreter\",\n136: \t\t\t\t\t\t\tImage: \"node:18\",\n137: \t\t\t\t\t\t},\n138: \t\t\t\t\t},\n139: \t\t\t\t},\n140: \t\t\t},\n141: \t\t},\n142: \t\t{\n143: \t\t\tname: \"template with full pod spec\",\n144: \t\t\ttemplate: CodeInterpreterSandboxTemplate{\n145: \t\t\t\tLabels: map[string]string{\n146: \t\t\t\t\t\"app\":     \"code-interpreter\",\n147: \t\t\t\t\t\"version\": \"v1\",\n148: \t\t\t\t},\n149: \t\t\t\tAnnotations: map[string]string{\n150: \t\t\t\t\t\"prometheus.io/scrape\": \"true\",\n151: \t\t\t\t},\n152: \t\t\t\tSpec: corev1.PodSpec{\n153: \t\t\t\t\tContainers: []corev1.Container{\n154: \t\t\t\t\t\t{\n155: \t\t\t\t\t\t\tName:    \"code-interpreter\",\n156: \t\t\t\t\t\t\tImage:   \"jupyter/scipy-notebook:latest\",\n157: \t\t\t\t\t\t\tCommand: []string{\"jupyter\", \"notebook\"},\n158: \t\t\t\t\t\t\tArgs:    []string{\"--ip=0.0.0.0\"},\n159: \t\t\t\t\t\t\tPorts: []corev1.ContainerPort{\n160: \t\t\t\t\t\t\t\t{\n161: \t\t\t\t\t\t\t\t\tName:          \"notebook\",\n162: \t\t\t\t\t\t\t\t\tContainerPort: 8888,\n163: \t\t\t\t\t\t\t\t\tProtocol:      corev1.ProtocolTCP,\n164: \t\t\t\t\t\t\t\t},\n165: \t\t\t\t\t\t\t},\n166: \t\t\t\t\t\t\tResources: corev1.ResourceRequirements{\n167: \t\t\t\t\t\t\t\tRequests: corev1.ResourceList{\n168: \t\t\t\t\t\t\t\t\tcorev1.ResourceCPU:    resource.MustParse(\"500m\"),\n169: \t\t\t\t\t\t\t\t\tcorev1.ResourceMemory: resource.MustParse(\"512Mi\"),\n170: \t\t\t\t\t\t\t\t},\n171: \t\t\t\t\t\t\t\tLimits: corev1.ResourceList{\n172: \t\t\t\t\t\t\t\t\tcorev1.ResourceCPU:    resource.MustParse(\"1000m\"),\n173: \t\t\t\t\t\t\t\t\tcorev1.ResourceMemory: resource.MustParse(\"1Gi\"),\n174: \t\t\t\t\t\t\t\t},\n175: \t\t\t\t\t\t\t},\n176: \t\t\t\t\t\t},\n177: \t\t\t\t\t},\n178: \t\t\t\t\tServiceAccountName: \"code-interpreter-sa\",\n179: \t\t\t\t},\n180: \t\t\t},\n181: \t\t},\n182: \t}\n183: \n184: \tfor _, tt := range tests {\n185: \t\tt.Run(tt.name, func(t *testing.T) {\n186: \t\t\tif len(tt.template.Spec.Containers) == 0 {\n187: \t\t\t\tt.Error(\"Template should have at least one container\")\n188: \t\t\t}\n189: \t\t})\n190: \t}\n191: }\n192: \n193: func TestCodeInterpreterSpec(t *testing.T) {\n194: \tduration15m := metav1.Duration{Duration: 15 * time.Minute}\n195: \tduration8h := metav1.Duration{Duration: 8 * time.Hour}\n196: \n197: \ttests := []struct {\n198: \t\tname string\n199: \t\tspec CodeInterpreterSpec\n200: \t}{\n201: \t\t{\n202: \t\t\tname: \"minimal spec with template\",\n203: \t\t\tspec: CodeInterpreterSpec{\n204: \t\t\t\tTemplate: &CodeInterpreterSandboxTemplate{\n205: \t\t\t\t\tSpec: corev1.PodSpec{\n206: \t\t\t\t\t\tContainers: []corev1.Container{\n207: \t\t\t\t\t\t\t{\n208: \t\t\t\t\t\t\t\tName:  \"code-interpreter\",\n209: \t\t\t\t\t\t\t\tImage: \"python:3.11\",\n210: \t\t\t\t\t\t\t},\n211: \t\t\t\t\t\t},\n212: \t\t\t\t\t},\n213: \t\t\t\t},\n214: \t\t\t},\n215: \t\t},\n216: \t\t{\n217: \t\t\tname: \"spec with ports\",\n218: \t\t\tspec: CodeInterpreterSpec{\n219: \t\t\t\tPorts: []TargetPort{\n220: \t\t\t\t\t{\n221: \t\t\t\t\t\tName:       \"http\",\n222: \t\t\t\t\t\tPort:       8080,\n223: \t\t\t\t\t\tProtocol:   ProtocolHTTP,\n224: \t\t\t\t\t\tPathPrefix: \"/api\",\n225: \t\t\t\t\t},\n226: \t\t\t\t\t{\n227: \t\t\t\t\t\tName:     \"https\",\n228: \t\t\t\t\t\tPort:     8443,\n229: \t\t\t\t\t\tProtocol: ProtocolHTTPS,\n230: \t\t\t\t\t},\n231: \t\t\t\t},\n232: \t\t\t\tTemplate: &CodeInterpreterSandboxTemplate{\n233: \t\t\t\t\tSpec: corev1.PodSpec{\n234: \t\t\t\t\t\tContainers: []corev1.Container{\n235: \t\t\t\t\t\t\t{\n236: \t\t\t\t\t\t\t\tName:  \"code-interpreter\",\n237: \t\t\t\t\t\t\t\tImage: \"nginx:latest\",\n238: \t\t\t\t\t\t\t},\n239: \t\t\t\t\t\t},\n240: \t\t\t\t\t},\n241: \t\t\t\t},\n242: \t\t\t},\n243: \t\t},\n244: \t\t{\n245: \t\t\tname: \"spec with timeouts\",\n246: \t\t\tspec: CodeInterpreterSpec{\n247: \t\t\t\tTemplate: &CodeInterpreterSandboxTemplate{\n248: \t\t\t\t\tSpec: corev1.PodSpec{\n249: \t\t\t\t\t\tContainers: []corev1.Container{\n250: \t\t\t\t\t\t\t{\n251: \t\t\t\t\t\t\t\tName:  \"code-interpreter\",\n252: \t\t\t\t\t\t\t\tImage: \"busybox:latest\",\n253: \t\t\t\t\t\t\t},\n254: \t\t\t\t\t\t},\n255: \t\t\t\t\t},\n256: \t\t\t\t},\n257: \t\t\t\tSessionTimeout:     &duration15m,\n258: \t\t\t\tMaxSessionDuration: &duration8h,\n259: \t\t\t},\n260: \t\t},\n261: \t\t{\n262: \t\t\tname: \"spec with warm pool\",\n263: \t\t\tspec: CodeInterpreterSpec{\n264: \t\t\t\tTemplate: &CodeInterpreterSandboxTemplate{\n265: \t\t\t\t\tSpec: corev1.PodSpec{\n266: \t\t\t\t\t\tContainers: []corev1.Container{\n267: \t\t\t\t\t\t\t{\n268: \t\t\t\t\t\t\t\tName:  \"code-interpreter\",\n269: \t\t\t\t\t\t\t\tImage: \"busybox:latest\",\n270: \t\t\t\t\t\t\t},\n271: \t\t\t\t\t\t},\n272: \t\t\t\t\t},\n273: \t\t\t\t},\n274: \t\t\t\tWarmPoolSize: int32Ptr(5),\n275: \t\t\t},\n276: \t\t},\n277: \t\t{\n278: \t\t\tname: \"spec with auth mode\",\n279: \t\t\tspec: CodeInterpreterSpec{\n280: \t\t\t\tTemplate: &CodeInterpreterSandboxTemplate{\n281: \t\t\t\t\tSpec: corev1.PodSpec{\n282: \t\t\t\t\t\tContainers: []corev1.Container{\n283: \t\t\t\t\t\t\t{\n284: \t\t\t\t\t\t\t\tName:  \"code-interpreter\",\n285: \t\t\t\t\t\t\t\tImage: \"busybox:latest\",\n286: \t\t\t\t\t\t\t},\n287: \t\t\t\t\t\t},\n288: \t\t\t\t\t},\n289: \t\t\t\t},\n290: \t\t\t\tAuthMode: AuthModePicoD,\n291: \t\t\t},\n292: \t\t},\n293: \t\t{\n294: \t\t\tname: \"spec with auth mode none\",\n295: \t\t\tspec: CodeInterpreterSpec{\n296: \t\t\t\tTemplate: &CodeInterpreterSandboxTemplate{\n297: \t\t\t\t\tSpec: corev1.PodSpec{\n298: \t\t\t\t\t\tContainers: []corev1.Container{\n299: \t\t\t\t\t\t\t{\n300: \t\t\t\t\t\t\t\tName:  \"code-interpreter\",\n301: \t\t\t\t\t\t\t\tImage: \"busybox:latest\",\n302: \t\t\t\t\t\t\t},\n303: \t\t\t\t\t\t},\n304: \t\t\t\t\t},\n305: \t\t\t\t},\n306: \t\t\t\tAuthMode: AuthModeNone,\n307: \t\t\t},\n308: \t\t},\n309: \t\t{\n310: \t\t\tname: \"full spec\",\n311: \t\t\tspec: CodeInterpreterSpec{\n312: \t\t\t\tPorts: []TargetPort{\n313: \t\t\t\t\t{\n314: \t\t\t\t\t\tName:     \"jupyter\",\n315: \t\t\t\t\t\tPort:     8888,\n316: \t\t\t\t\t\tProtocol: ProtocolHTTP,\n317: \t\t\t\t\t},\n318: \t\t\t\t},\n319: \t\t\t\tTemplate: &CodeInterpreterSandboxTemplate{\n320: \t\t\t\t\tLabels: map[string]string{\n321: \t\t\t\t\t\t\"app\": \"code-interpreter\",\n322: \t\t\t\t\t},\n323: \t\t\t\t\tSpec: corev1.PodSpec{\n324: \t\t\t\t\t\tContainers: []corev1.Container{\n325: \t\t\t\t\t\t\t{\n326: \t\t\t\t\t\t\t\tName:  \"code-interpreter\",\n327: \t\t\t\t\t\t\t\tImage: \"jupyter/scipy-notebook:latest\",\n328: \t\t\t\t\t\t\t},\n329: \t\t\t\t\t\t},\n330: \t\t\t\t\t},\n331: \t\t\t\t},\n332: \t\t\t\tSessionTimeout:     &duration15m,\n333: \t\t\t\tMaxSessionDuration: &duration8h,\n334: \t\t\t\tWarmPoolSize:       int32Ptr(3),\n335: \t\t\t\tAuthMode:           AuthModePicoD,\n336: \t\t\t},\n337: \t\t},\n338: \t}\n339: \n340: \tfor _, tt := range tests {\n341: \t\tt.Run(tt.name, func(t *testing.T) {\n342: \t\t\tif tt.spec.Template == nil {\n343: \t\t\t\tt.Error(\"Template should not be nil\")\n344: \t\t\t}\n345: \t\t})\n346: \t}\n347: }\n348: \n349: func TestCodeInterpreterConditionTypeValues(t *testing.T) {\n350: \ttests := []struct {\n351: \t\tname     string\n352: \t\tcondType CodeInterpreterConditionType\n353: \t\texpected string\n354: \t}{\n355: \t\t{\"Ready\", CodeInterpreterConditionReady, \"Ready\"},\n356: \t\t{\"SandboxCreated\", CodeInterpreterConditionSandboxCreated, \"SandboxCreated\"},\n357: \t\t{\"SandboxReady\", CodeInterpreterConditionSandboxReady, \"SandboxReady\"},\n358: \t\t{\"Failed\", CodeInterpreterConditionFailed, \"Failed\"},\n359: \t}\n360: \n361: \tfor _, tt := range tests {\n362: \t\tt.Run(tt.name, func(t *testing.T) {\n363: \t\t\tif string(tt.condType) != tt.expected {\n364: \t\t\t\tt.Errorf(\"Expected condition type %s, got %s\", tt.expected, tt.condType)\n365: \t\t\t}\n366: \t\t})\n367: \t}\n368: }\n369: \n370: func TestCodeInterpreterCondition(t *testing.T) {\n371: \tcond := CodeInterpreterCondition{\n372: \t\tType:   CodeInterpreterConditionReady,\n373: \t\tStatus: corev1.ConditionTrue,\n374: \t\tLastTransitionTime: metav1.Time{\n375: \t\t\tTime: time.Now(),\n376: \t\t},\n377: \t\tReason:  \"CodeInterpreterReady\",\n378: \t\tMessage: \"CodeInterpreter is ready\",\n379: \t}\n380: \n381: \tif cond.Type != CodeInterpreterConditionReady {\n382: \t\tt.Errorf(\"Expected condition type %s, got %s\", CodeInterpreterConditionReady, cond.Type)\n383: \t}\n384: \n385: \tif cond.Status != corev1.ConditionTrue {\n386: \t\tt.Errorf(\"Expected status %s, got %s\", corev1.ConditionTrue, cond.Status)\n387: \t}\n388: \n389: \tif cond.Reason != \"CodeInterpreterReady\" {\n390: \t\tt.Errorf(\"Expected reason 'CodeInterpreterReady', got %s\", cond.Reason)\n391: \t}\n392: \n393: \tif cond.Message != \"CodeInterpreter is ready\" {\n394: \t\tt.Errorf(\"Expected message 'CodeInterpreter is ready', got %s\", cond.Message)\n395: \t}\n396: }\n397: \n398: func TestCodeInterpreterStatus(t *testing.T) {\n399: \ttests := []struct {\n400: \t\tname   string\n401: \t\tstatus CodeInterpreterStatus\n402: \t}{\n403: \t\t{\n404: \t\t\tname:   \"empty status\",\n405: \t\t\tstatus: CodeInterpreterStatus{},\n406: \t\t},\n407: \t\t{\n408: \t\t\tname: \"status with ready\",\n409: \t\t\tstatus: CodeInterpreterStatus{\n410: \t\t\t\tReady: boolPtr(true),\n411: \t\t\t},\n412: \t\t},\n413: \t\t{\n414: \t\t\tname: \"status with conditions\",\n415: \t\t\tstatus: CodeInterpreterStatus{\n416: \t\t\t\tConditions: []CodeInterpreterCondition{\n417: \t\t\t\t\t{\n418: \t\t\t\t\t\tType:   CodeInterpreterConditionReady,\n419: \t\t\t\t\t\tStatus: corev1.ConditionTrue,\n420: \t\t\t\t\t\tLastTransitionTime: metav1.Time{\n421: \t\t\t\t\t\t\tTime: time.Now(),\n422: \t\t\t\t\t\t},\n423: \t\t\t\t\t\tReason:  \"CodeInterpreterReady\",\n424: \t\t\t\t\t\tMessage: \"CodeInterpreter is ready\",\n425: \t\t\t\t\t},\n426: \t\t\t\t},\n427: \t\t\t},\n428: \t\t},\n429: \t\t{\n430: \t\t\tname: \"full status\",\n431: \t\t\tstatus: CodeInterpreterStatus{\n432: \t\t\t\tReady: boolPtr(true),\n433: \t\t\t\tConditions: []CodeInterpreterCondition{\n434: \t\t\t\t\t{\n435: \t\t\t\t\t\tType:   CodeInterpreterConditionReady,\n436: \t\t\t\t\t\tStatus: corev1.ConditionTrue,\n437: \t\t\t\t\t\tLastTransitionTime: metav1.Time{\n438: \t\t\t\t\t\t\tTime: time.Now(),\n439: \t\t\t\t\t\t},\n440: \t\t\t\t\t\tReason:  \"CodeInterpreterReady\",\n441: \t\t\t\t\t\tMessage: \"CodeInterpreter is ready to accept requests\",\n442: \t\t\t\t\t},\n443: \t\t\t\t\t{\n444: \t\t\t\t\t\tType:   CodeInterpreterConditionSandboxReady,\n445: \t\t\t\t\t\tStatus: corev1.ConditionTrue,\n446: \t\t\t\t\t\tLastTransitionTime: metav1.Time{\n447: \t\t\t\t\t\t\tTime: time.Now(),\n448: \t\t\t\t\t\t},\n449: \t\t\t\t\t\tReason:  \"SandboxCreated\",\n450: \t\t\t\t\t\tMessage: \"Sandbox pod is running\",\n451: \t\t\t\t\t},\n452: \t\t\t\t},\n453: \t\t\t},\n454: \t\t},\n455: \t}\n456: \n457: \tfor _, tt := range tests {\n458: \t\tt.Run(tt.name, func(t *testing.T) {\n459: \t\t\t// Validate conditions if present\n460: \t\t\tfor _, cond := range tt.status.Conditions {\n461: \t\t\t\tif cond.Type == \"\" {\n462: \t\t\t\t\tt.Error(\"Condition type should not be empty\")\n463: \t\t\t\t}\n464: \t\t\t\tif cond.Status == \"\" {\n465: \t\t\t\t\tt.Error(\"Condition status should not be empty\")\n466: \t\t\t\t}\n467: \t\t\t}\n468: \t\t})\n469: \t}\n470: }\n471: \n472: func TestCodeInterpreter(t *testing.T) {\n473: \tnow := metav1.NewTime(time.Now())\n474: \tduration15m := metav1.Duration{Duration: 15 * time.Minute}\n475: \n476: \tci := CodeInterpreter{\n477: \t\tTypeMeta: metav1.TypeMeta{\n478: \t\t\tAPIVersion: \"runtime.agentcube.volcano.sh/v1alpha1\",\n479: \t\t\tKind:       \"CodeInterpreter\",\n480: \t\t},\n481: \t\tObjectMeta: metav1.ObjectMeta{\n482: \t\t\tName:      \"test-code-interpreter\",\n483: \t\t\tNamespace: \"default\",\n484: \t\t\tLabels: map[string]string{\n485: \t\t\t\t\"app\": \"code-interpreter\",\n486: \t\t\t},\n487: \t\t\tAnnotations: map[string]string{\n488: \t\t\t\t\"description\": \"Test code interpreter\",\n489: \t\t\t},\n490: \t\t},\n491: \t\tSpec: CodeInterpreterSpec{\n492: \t\t\tPorts: []TargetPort{\n493: \t\t\t\t{\n494: \t\t\t\t\tName:     \"jupyter\",\n495: \t\t\t\t\tPort:     8888,\n496: \t\t\t\t\tProtocol: ProtocolHTTP,\n497: \t\t\t\t},\n498: \t\t\t},\n499: \t\t\tTemplate: &CodeInterpreterSandboxTemplate{\n500: \t\t\t\tSpec: corev1.PodSpec{\n501: \t\t\t\t\tContainers: []corev1.Container{\n502: \t\t\t\t\t\t{\n503: \t\t\t\t\t\t\tName:  \"code-interpreter\",\n504: \t\t\t\t\t\t\tImage: \"jupyter/scipy-notebook:latest\",\n505: \t\t\t\t\t\t},\n506: \t\t\t\t\t},\n507: \t\t\t\t},\n508: \t\t\t},\n509: \t\t\tSessionTimeout: &duration15m,\n510: \t\t\tAuthMode:       AuthModePicoD,\n511: \t\t},\n512: \t\tStatus: CodeInterpreterStatus{\n513: \t\t\tReady: boolPtr(true),\n514: \t\t\tConditions: []CodeInterpreterCondition{\n515: \t\t\t\t{\n516: \t\t\t\t\tType:   CodeInterpreterConditionReady,\n517: \t\t\t\t\tStatus: corev1.ConditionTrue,\n518: \t\t\t\t\tLastTransitionTime: metav1.Time{\n519: \t\t\t\t\t\tTime: now.Time,\n520: \t\t\t\t\t},\n521: \t\t\t\t\tReason:  \"CodeInterpreterReady\",\n522: \t\t\t\t\tMessage: \"CodeInterpreter is ready\",\n523: \t\t\t\t},\n524: \t\t\t},\n525: \t\t},\n526: \t}\n527: \n528: \t// Validate TypeMeta\n529: \tif ci.APIVersio