{"type":"tool_use","timestamp":1775877021058,"sessionID":"ses_2857fbf8fffeHhKEiyGQze1uRE","part":{"id":"prt_d7a838b410016rEEdcmMy6N0DZ","messageID":"msg_d7a826d01001OmM4AkE0RXOqql","sessionID":"ses_2857fbf8fffeHhKEiyGQze1uRE","type":"tool","tool":"read","callID":"toolu_functions.read:19","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/picod/file_errors.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/picod/file_errors.go</path>\n<type>file</type>\n<content>\n1: /*\n2: Copyright 2026 The Volcano Authors.\n3: \n4: Licensed under the Apache License, Version 2.0 (the \"License\");\n5: you may not use this file except in compliance with the License.\n6: You may obtain a copy of the License at\n7: \n8:     http://www.apache.org/licenses/LICENSE-2.0\n9: \n10: Unless required by applicable law or agreed to in writing, software\n11: distributed under the License is distributed on an \"AS IS\" BASIS,\n12: WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n13: See the License for the specific language governing permissions and\n14: limitations under the License.\n15: */\n16: \n17: package picod\n18: \n19: import \"errors\"\n20: \n21: // File operation errors (file-specific)\n22: // Note: ErrSandboxUnavailable is defined in errors.go\n23: var (\n24: \t// ErrInvalidPath indicates a malformed or invalid file path\n25: \tErrInvalidPath = errors.New(\"picod: invalid path\")\n26: \n27: \t// ErrFileNotFound indicates the file does not exist\n28: \tErrFileNotFound = errors.New(\"picod: file not found\")\n29: \n30: \t// ErrDirectoryNotFound indicates the directory does not exist\n31: \tErrDirectoryNotFound = errors.New(\"picod: directory not found\")\n32: \n33: \t// ErrFileExists indicates the file already exists\n34: \tErrFileExists = errors.New(\"picod: file already exists\")\n35: \n36: \t// ErrDirectoryExists indicates the directory already exists\n37: \tErrDirectoryExists = errors.New(\"picod: directory already exists\")\n38: \n39: \t// ErrFileTooLarge indicates the file exceeds size limits\n40: \tErrFileTooLarge = errors.New(\"picod: file too large\")\n41: \n42: \t// ErrDirectorySizeExceeded indicates directory size limit reached\n43: \tErrDirectorySizeExceeded = errors.New(\"picod: directory size exceeded\")\n44: \n45: \t// ErrPathNotAllowed indicates path is outside allowed directories\n46: \tErrPathNotAllowed = errors.New(\"picod: path not allowed\")\n47: \n48: \t// ErrFileTypeNotAllowed indicates the file type is blocked\n49: \tErrFileTypeNotAllowed = errors.New(\"picod: file type not allowed\")\n50: \n51: \t// ErrPermissionDenied indicates insufficient permissions\n52: \tErrPermissionDenied = errors.New(\"picod: permission denied\")\n53: \n54: \t// ErrInvalidFileRequest indicates a malformed request\n55: \tErrInvalidFileRequest = errors.New(\"picod: invalid file request\")\n56: \n57: \t// ErrWatcherClosed indicates the watcher has been stopped\n58: \tErrWatcherClosed = errors.New(\"picod: watcher closed\")\n59: )\n60: \n61: // Error codes for machine-readable error identification\n62: // Note: ErrorCodeSandboxUnavailable is defined in errors.go\n63: const (\n64: \t// ErrorCodeInvalidPath indicates malformed path\n65: \tErrorCodeInvalidPath = \"INVALID_PATH\"\n66: \n67: \t// ErrorCodeFileNotFound indicates file does not exist\n68: \tErrorCodeFileNotFound = \"FILE_NOT_FOUND\"\n69: \n70: \t// ErrorCodeDirectoryNotFound indicates directory does not exist\n71: \tErrorCodeDirectoryNotFound = \"DIRECTORY_NOT_FOUND\"\n72: \n73: \t// ErrorCodeFileExists indicates file already exists\n74: \tErrorCodeFileExists = \"FILE_EXISTS\"\n75: \n76: \t// ErrorCodeDirectoryExists indicates directory already exists\n77: \tErrorCodeDirectoryExists = \"DIRECTORY_EXISTS\"\n78: \n79: \t// ErrorCodeFileTooLarge indicates file exceeds size limits\n80: \tErrorCodeFileTooLarge = \"FILE_TOO_LARGE\"\n81: \n82: \t// ErrorCodeDirectorySizeExceeded indicates directory size limit\n83: \tErrorCodeDirectorySizeExceeded = \"DIRECTORY_SIZE_EXCEEDED\"\n84: \n85: \t// ErrorCodePathNotAllowed indicates path outside allowed directories\n86: \tErrorCodePathNotAllowed = \"PATH_NOT_ALLOWED\"\n87: \n88: \t// ErrorCodeFileTypeNotAllowed indicates blocked file type\n89: \tErrorCodeFileTypeNotAllowed = \"FILE_TYPE_NOT_ALLOWED\"\n90: \n91: \t// ErrorCodePermissionDenied indicates insufficient permissions\n92: \tErrorCodePermissionDenied = \"PERMISSION_DENIED\"\n93: \n94: \t// ErrorCodeInvalidFileRequest indicates malformed request\n95: \tErrorCodeInvalidFileRequest = \"INVALID_FILE_REQUEST\"\n96: \n97: \t// ErrorCodeWatcherClosed indicates watcher has been stopped\n98: \tErrorCodeWatcherClosed = \"WATCHER_CLOSED\"\n99: )\n100: \n101: // FileErrorCode returns the machine-readable error code for a file-related error.\n102: func FileErrorCode(err error) string {\n103: \tif err == nil {\n104: \t\treturn \"\"\n105: \t}\n106: \tswitch {\n107: \tcase errors.Is(err, ErrInvalidPath):\n108: \t\treturn ErrorCodeInvalidPath\n109: \tcase errors.Is(err, ErrFileNotFound):\n110: \t\treturn ErrorCodeFileNotFound\n111: \tcase errors.Is(err, ErrDirectoryNotFound):\n112: \t\treturn ErrorCodeDirectoryNotFound\n113: \tcase errors.Is(err, ErrFileExists):\n114: \t\treturn ErrorCodeFileExists\n115: \tcase errors.Is(err, ErrDirectoryExists):\n116: \t\treturn ErrorCodeDirectoryExists\n117: \tcase errors.Is(err, ErrFileTooLarge):\n118: \t\treturn ErrorCodeFileTooLarge\n119: \tcase errors.Is(err, ErrDirectorySizeExceeded):\n120: \t\treturn ErrorCodeDirectorySizeExceeded\n121: \tcase errors.Is(err, ErrPathNotAllowed):\n122: \t\treturn ErrorCodePathNotAllowed\n123: \tcase errors.Is(err, ErrFileTypeNotAllowed):\n124: \t\treturn ErrorCodeFileTypeNotAllowed\n125: \tcase errors.Is(err, ErrPermissionDenied):\n126: \t\treturn ErrorCodePermissionDenied\n127: \tcase errors.Is(err, ErrSandboxUnavailable):\n128: \t\treturn ErrorCodeSandboxUnavailable\n129: \tcase errors.Is(err, ErrInvalidFileRequest):\n130: \t\treturn ErrorCodeInvalidFileRequest\n131: \tcase errors.Is(err, ErrWatcherClosed):\n132: \t\treturn ErrorCodeWatcherClosed\n133: \tdefault:\n134: \t\treturn \"UNKNOWN\"\n135: \t}\n136: }\n137: \n138: // IsFileRetryableError returns true if the file error is potentially retryable.\n139: func IsFileRetryableError(err error) bool {\n140: \tif err == nil {\n141: \t\treturn false\n142: \t}\n143: \treturn errors.Is(err, ErrSandboxUnavailable)\n144: }\n\n(End of file - total 144 lines)\n</content>","metadata":{"preview":"/*\nCopyright 2026 The Volcano Authors.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\npackage picod\n\nimport \"errors\"\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/picod/file_errors.go","time":{"start":1775877021024,"end":1775877021057}}}}
{"type":"tool_use","timestamp":1775877021060,"sessionID":"ses_2857fbf8fffeHhKEiyGQze1uRE","part":{"id":"prt_d7a8415cf001sSd3vcgMobWDNl","messageID":"msg_d7a826d01001OmM4AkE0RXOqql","sessionID":"ses_2857fbf8fffeHhKEiyGQze1uRE","type":"tool","tool":"read","callID":"toolu_functions.read:20","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/picod/file_validation.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/picod/file_validation.go</path>\n<type>file</type>\n<content>\n1: /*\n2: Copyright 2026 The Volcano Authors.\n3: \n4: Licensed under the Apache License, Version 2.0 (the \"License\");\n5: you may not use this file except in compliance with the License.\n6: You may obtain a copy of the License at\n7: \n8:     http://www.apache.org/licenses/LICENSE-2.0\n9: \n10: Unless required by applicable law or agreed to in writing, software\n11: distributed under the License is distributed on an \"AS IS\" BASIS,\n12: WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n13: See the License for the specific language governing permissions and\n14: limitations under the License.\n15: */\n16: \n17: package picod\n18: \n19: import (\n20: \t\"fmt\"\n21: \t\"path/filepath\"\n22: \t\"strings\"\n23: )\n24: \n25: // ValidatePath validates a file path for security.\n26: // Returns nil if the path is valid, otherwise returns an error.\n27: func ValidatePath(path string, config *FileManagerConfig) error {\n28: \t// Check empty path\n29: \tif path == \"\" {\n30: \t\treturn fmt.Errorf(\"%w: path is required\", ErrInvalidPath)\n31: \t}\n32: \n33: \t// Check path length\n34: \tif len(path) > maxPathLength {\n35: \t\treturn fmt.Errorf(\"%w: path exceeds maximum length of %d characters\", ErrInvalidPath, maxPathLength)\n36: \t}\n37: \n38: \t// Check null bytes\n39: \tif strings.Contains(path, \"\\x00\") {\n40: \t\treturn fmt.Errorf(\"%w: path contains null bytes\", ErrInvalidPath)\n41: \t}\n42: \n43: \t// Check absolute path requirement\n44: \tif !strings.HasPrefix(path, \"/\") {\n45: \t\treturn fmt.Errorf(\"%w: absolute path required\", ErrInvalidPath)\n46: \t}\n47: \n48: \t// Clean the path\n49: \tcleanPath := filepath.Clean(path)\n50: \n51: \t// Check for path traversal patterns\n52: \tif containsPathTraversal(cleanPath) {\n53: \t\treturn fmt.Errorf(\"%w: path traversal not allowed\", ErrInvalidPath)\n54: \t}\n55: \n56: \t// Check filename length for the last component\n57: \tbase := filepath.Base(cleanPath)\n58: \tif base != \".\" && base != \"/\" && len(base) > maxFilenameLength {\n59: \t\treturn fmt.Errorf(\"%w: filename exceeds maximum length of %d characters\", ErrInvalidPath, maxFilenameLength)\n60: \t}\n61: \n62: \t// Check allowed paths\n63: \tif config != nil && !config.IsPathAllowed(cleanPath) {\n64: \t\treturn ErrPathNotAllowed\n65: \t}\n66: \n67: \treturn nil\n68: }\n69: \n70: // ValidatePathPair validates source and destination paths for move/copy operations.\n71: func ValidatePathPair(sourcePath, destPath string, config *FileManagerConfig) error {\n72: \tif err := ValidatePath(sourcePath, config); err != nil {\n73: \t\treturn fmt.Errorf(\"%w: invalid source path: %v\", ErrInvalidPath, err)\n74: \t}\n75: \tif err := ValidatePath(destPath, config); err != nil {\n76: \t\treturn fmt.Errorf(\"%w: invalid destination path: %v\", ErrInvalidPath, err)\n77: \t}\n78: \treturn nil\n79: }\n80: \n81: // containsPathTraversal checks if the path contains traversal patterns.\n82: func containsPathTraversal(path string) bool {\n83: \t// Split path into components\n84: \tparts := strings.Split(path, string(filepath.Separator))\n85: \tdepth := 0\n86: \n87: \tfor _, part := range parts {\n88: \t\tif part == \"\" || part == \".\" {\n89: \t\t\tcontinue\n90: \t\t}\n91: \t\tif part == \"..\" {\n92: \t\t\tdepth--\n93: \t\t\tif depth < 0 {\n94: \t\t\t\treturn true\n95: \t\t\t}\n96: \t\t} else {\n97: \t\t\tdepth++\n98: \t\t}\n99: \t}\n100: \n101: \treturn false\n102: }\n103: \n104: // ValidateFileType validates if a file extension is allowed.\n105: func ValidateFileType(path string, config *FileManagerConfig) error {\n106: \tif config == nil {\n107: \t\treturn nil\n108: \t}\n109: \n110: \text := strings.ToLower(filepath.Ext(path))\n111: \n112: \tif !config.IsExtensionAllowed(ext) {\n113: \t\treturn fmt.Errorf(\"%w: extension '%s' is not allowed\", ErrFileTypeNotAllowed, ext)\n114: \t}\n115: \n116: \treturn nil\n117: }\n118: \n119: // ValidateFileSize validates if a file size is within limits.\n120: func ValidateFileSize(size int64, config *FileManagerConfig) error {\n121: \tif config == nil {\n122: \t\treturn nil\n123: \t}\n124: \n125: \tif size > config.MaxFileSize {\n126: \t\treturn fmt.Errorf(\"%w: file size %d exceeds maximum %d\", ErrFileTooLarge, size, config.MaxFileSize)\n127: \t}\n128: \n129: \treturn nil\n130: }\n131: \n132: // ValidateWriteRequest validates a write file request.\n133: func ValidateWriteRequest(req WriteFileRequest, config *FileManagerConfig) error {\n134: \t// Validate path\n135: \tif err := ValidatePath(req.Path, config); err != nil {\n136: \t\treturn err\n137: \t}\n138: \n139: \t// Validate file type\n140: \tif err := ValidateFileType(req.Path, config); err != nil {\n141: \t\treturn err\n142: \t}\n143: \n144: \t// Validate file size\n145: \tif err := ValidateFileSize(int64(len(req.Data)), config); err != nil {\n146: \t\treturn err\n147: \t}\n148: \n149: \treturn nil\n150: }\n151: \n152: // ValidateWriteStreamRequest validates a write stream request.\n153: func ValidateWriteStreamRequest(req WriteStreamRequest, config *FileManagerConfig) error {\n154: \t// Validate path\n155: \tif err := ValidatePath(req.Path, config); err != nil {\n156: \t\treturn err\n157: \t}\n158: \n159: \t// Validate file type\n160: \tif err := ValidateFileType(req.Path, config); err != nil {\n161: \t\treturn err\n162: \t}\n163: \n164: \t// Validate expected size if provided\n165: \tif req.ExpectedSize > 0 {\n166: \t\tif err := ValidateFileSize(req.ExpectedSize, config); err != nil {\n167: \t\t\treturn err\n168: \t\t}\n169: \t}\n170: \n171: \treturn nil\n172: }\n173: \n174: // NormalizePath normalizes and cleans a path.\n175: func NormalizePath(path string) string {\n176: \tif path == \"\" {\n177: \t\treturn \"\"\n178: \t}\n179: \n180: \t// Clean the path\n181: \tpath = filepath.Clean(path)\n182: \n183: \t// Ensure absolute paths stay absolute\n184: \tif !strings.HasPrefix(path, \"/\") && strings.HasPrefix(filepath.Clean(\"/\"+path), \"/\") {\n185: \t\tpath = \"/\" + path\n186: \t}\n187: \n188: \treturn path\n189: }\n190: \n191: // GetFileExtension extracts the file extension from a path.\n192: func GetFileExtension(path string) string {\n193: \text := filepath.Ext(path)\n194: \tif ext != \"\" && ext[0] == '.' {\n195: \t\treturn ext[1:]\n196: \t}\n197: \treturn ext\n198: }\n199: \n200: // IsSymlink checks if a path is or contains a symlink component.\n201: // This is a helper that would need actual filesystem access for real implementation.\n202: func IsSymlink(path string) bool {\n203: \t// This is a placeholder - real implementation would use os.Lstat\n204: \t// For now, just check if the path string contains common symlink indicators\n205: \treturn strings.Contains(path, \"@\") || strings.HasSuffix(path, \".link\")\n206: }\n\n(End of file - total 206 lines)\n</content>","metadata":{"preview":"/*\nCopyright 2026 The Volcano Authors.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\npackage picod\n\nimport (\n\t\"fmt\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/picod/file_validation.go","time":{"start":1775877021030,"end":1775877021059}}}}
{"type":"tool_use","timestamp":1775877021062,"sessionID":"ses_2857fbf8fffeHhKEiyGQze1uRE","part":{"id":"prt_d7a8457aa001mYNBpej0g5VM54","messageID":"msg_d7a826d01001OmM4AkE0RXOqql","sessionID":"ses_2857fbf8fffeHhKEiyGQze1uRE","type":"tool","tool":"read","callID":"toolu_functions.read:21","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/picod/file_config.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/picod/file_config.go</path>\n<type>file</type>\n<content>\n1: /*\n2: Copyright 2026 The Volcano Authors.\n3: \n4: Licensed under the Apache License, Version 2.0 (the \"License\");\n5: you may not use this file except in compliance with the License.\n6: You may obtain a copy of the License at\n7: \n8:     http://www.apache.org/licenses/LICENSE-2.0\n9: \n10: Unless required by applicable law or agreed to in writing, software\n11: distributed under the License is distributed on an \"AS IS\" BASIS,\n12: WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n13: See the License for the specific language governing permissions and\n14: limitations under the License.\n15: */\n16: \n17: package picod\n18: \n19: import (\n20: \t\"fmt\"\n21: \t\"os\"\n22: \t\"strconv\"\n23: \t\"strings\"\n24: \t\"time\"\n25: )\n26: \n27: // Constants for file operations\n28: const (\n29: \t// defaultMaxFileSize is the default maximum file size (100MB)\n30: \tdefaultMaxFileSize = 100 * 1024 * 1024\n31: \n32: \t// defaultMaxDirectorySize is the default maximum directory size (1GB)\n33: \tdefaultMaxDirectorySize = 1024 * 1024 * 1024\n34: \n35: \t// defaultFileOpTimeout is the default file operation timeout (30 seconds)\n36: \tdefaultFileOpTimeout = 30 * time.Second\n37: \n38: \t// defaultMaxWatchers is the default maximum concurrent watchers\n39: \tdefaultMaxWatchers = 100\n40: \n41: \t// maxPathLength is the maximum allowed path length\n42: \tmaxPathLength = 4096\n43: \n44: \t// maxFilenameLength is the maximum filename length\n45: \tmaxFilenameLength = 255\n46: )\n47: \n48: // FileManagerConfig contains configuration for FileManager.\n49: type FileManagerConfig struct {\n50: \t// MaxFileSize is the maximum file size allowed (bytes)\n51: \tMaxFileSize int64\n52: \n53: \t// MaxDirectorySize is the maximum total size for a directory\n54: \tMaxDirectorySize int64\n55: \n56: \t// AllowedPaths are the allowed base directories\n57: \tAllowedPaths []string\n58: \n59: \t// BlockedExtensions are file extensions that cannot be written\n60: \tBlockedExtensions []string\n61: \n62: \t// AllowedExtensions are the only file extensions that can be written (empty = allow all)\n63: \tAllowedExtensions []string\n64: \n65: \t// FileOpTimeout is the timeout for file operations\n66: \tFileOpTimeout time.Duration\n67: \n68: \t// EnableFileWatching enables directory watching functionality\n69: \tEnableFileWatching bool\n70: \n71: \t// MaxWatchers is the maximum number of concurrent watchers\n72: \tMaxWatchers int\n73: }\n74: \n75: // DefaultFileManagerConfig returns the default file manager configuration.\n76: func DefaultFileManagerConfig() FileManagerConfig {\n77: \treturn FileManagerConfig{\n78: \t\tMaxFileSize:        defaultMaxFileSize,\n79: \t\tMaxDirectorySize:   defaultMaxDirectorySize,\n80: \t\tAllowedPaths:       []string{\"/workspace\", \"/tmp\"},\n81: \t\tFileOpTimeout:      defaultFileOpTimeout,\n82: \t\tEnableFileWatching: true,\n83: \t\tMaxWatchers:        defaultMaxWatchers,\n84: \t}\n85: }\n86: \n87: // LoadConfigFromEnv loads file manager configuration from environment variables.\n88: func LoadConfigFromEnv() FileManagerConfig {\n89: \tcfg := DefaultFileManagerConfig()\n90: \n91: \tif v := os.Getenv(\"PICOD_MAX_FILE_SIZE\"); v != \"\" {\n92: \t\tif size, err := parseByteSize(v); err == nil {\n93: \t\t\tcfg.MaxFileSize = size\n94: \t\t}\n95: \t}\n96: \n97: \tif v := os.Getenv(\"PICOD_MAX_DIRECTORY_SIZE\"); v != \"\" {\n98: \t\tif size, err := parseByteSize(v); err == nil {\n99: \t\t\tcfg.MaxDirectorySize = size\n100: \t\t}\n101: \t}\n102: \n103: \tif v := os.Getenv(\"PICOD_ALLOWED_PATHS\"); v != \"\" {\n104: \t\tcfg.AllowedPaths = parseCommaSeparatedList(v)\n105: \t}\n106: \n107: \tif v := os.Getenv(\"PICOD_BLOCKED_EXTENSIONS\"); v != \"\" {\n108: \t\tcfg.BlockedExtensions = parseCommaSeparatedList(v)\n109: \t}\n110: \n111: \tif v := os.Getenv(\"PICOD_ALLOWED_EXTENSIONS\"); v != \"\" {\n112: \t\tcfg.AllowedExtensions = parseCommaSeparatedList(v)\n113: \t}\n114: \n115: \tif v := os.Getenv(\"PICOD_FILE_OP_TIMEOUT\"); v != \"\" {\n116: \t\tif d, err := time.ParseDuration(v); err == nil {\n117: \t\t\tcfg.FileOpTimeout = d\n118: \t\t}\n119: \t}\n120: \n121: \tif v := os.Getenv(\"PICOD_ENABLE_FILE_WATCHING\"); v != \"\" {\n122: \t\tcfg.EnableFileWatching = parseBool(v)\n123: \t}\n124: \n125: \tif v := os.Getenv(\"PICOD_MAX_WATCHERS\"); v != \"\" {\n126: \t\tif n, err := strconv.Atoi(v); err == nil {\n127: \t\t\tcfg.MaxWatchers = n\n128: \t\t}\n129: \t}\n130: \n131: \treturn cfg\n132: }\n133: \n134: // Validate validates the file manager configuration.\n135: func (c FileManagerConfig) Validate() error {\n136: \tif c.MaxFileSize <= 0 {\n137: \t\treturn fmt.Errorf(\"%w: MaxFileSize must be positive\", ErrInvalidFileRequest)\n138: \t}\n139: \tif c.MaxDirectorySize <= 0 {\n140: \t\treturn fmt.Errorf(\"%w: MaxDirectorySize must be positive\", ErrInvalidFileRequest)\n141: \t}\n142: \tif len(c.AllowedPaths) == 0 {\n143: \t\treturn fmt.Errorf(\"%w: AllowedPaths must not be empty\", ErrInvalidFileRequest)\n144: \t}\n145: \tif c.FileOpTimeout <= 0 {\n146: \t\treturn fmt.Errorf(\"%w: FileOpTimeout must be positive\", ErrInvalidFileRequest)\n147: \t}\n148: \tif c.MaxWatchers <= 0 {\n149: \t\treturn fmt.Errorf(\"%w: MaxWatchers must be positive\", ErrInvalidFileRequest)\n150: \t}\n151: \treturn nil\n152: }\n153: \n154: // IsExtensionAllowed checks if a file extension is allowed based on configuration.\n155: func (c FileManagerConfig) IsExtensionAllowed(ext string) bool {\n156: \text = strings.ToLower(strings.TrimPrefix(ext, \".\"))\n157: \n158: \t// Check blocked extensions first\n159: \tfor _, blocked := range c.BlockedExtensions {\n160: \t\tif strings.ToLower(strings.TrimPrefix(blocked, \".\")) == ext {\n161: \t\t\treturn false\n162: \t\t}\n163: \t}\n164: \n165: \t// If allowed extensions list is not empty, extension must be in it\n166: \tif len(c.AllowedExtensions) > 0 {\n167: \t\tfor _, allowed := range c.AllowedExtensions {\n168: \t\t\tif strings.ToLower(strings.TrimPrefix(allowed, \".\")) == ext {\n169: \t\t\t\treturn true\n170: \t\t\t}\n171: \t\t}\n172: \t\treturn false\n173: \t}\n174: \n175: \treturn true\n176: }\n177: \n178: // IsPathAllowed checks if a path is within the allowed directories.\n179: func (c FileManagerConfig) IsPathAllowed(path string) bool {\n180: \t// Normalize path - must be absolute\n181: \tif !strings.HasPrefix(path, \"/\") {\n182: \t\treturn false\n183: \t}\n184: \n185: \t// Clean the path\n186: \tpath = strings.TrimSuffix(path, \"/\")\n187: \n188: \tfor _, allowed := range c.AllowedPaths {\n189: \t\tallowed = strings.TrimSuffix(allowed, \"/\")\n190: \t\tif path == allowed || strings.HasPrefix(path, allowed+\"/\") {\n191: \t\t\treturn true\n192: \t\t}\n193: \t}\n194: \n195: \treturn false\n196: }\n197: \n198: // parseByteSize parses a byte size string with optional suffix (e.g., \"100MB\", \"1GB\").\n199: func parseByteSize(s string) (int64, error) {\n200: \ts = strings.TrimSpace(strings.ToUpper(s))\n201: \n202: \tmultipliers := map[string]int64{\n203: \t\t\"B\":   1,\n204: \t\t\"KB\":  1024,\n205: \t\t\"MB\":  1024 * 1024,\n206: \t\t\"GB\":  1024 * 1024 * 1024,\n207: \t\t\"TB\":  1024 * 1024 * 1024 * 1024,\n208: \t\t\"KIB\": 1024,\n209: \t\t\"MIB\": 1024 * 1024,\n210: \t\t\"GIB\": 1024 * 1024 * 1024,\n211: \t\t\"TIB\": 1024 * 1024 * 1024 * 1024,\n212: \t}\n213: \n214: \tfor suffix, multiplier := range multipliers {\n215: \t\tif strings.HasSuffix(s, suffix) {\n216: \t\t\tval, err := strconv.ParseInt(strings.TrimSuffix(s, suffix), 10, 64)\n217: \t\t\tif err != nil {\n218: \t\t\t\treturn 0, err\n219: \t\t\t}\n220: \t\t\treturn val * multiplier, nil\n221: \t\t}\n222: \t}\n223: \n224: \t// No suffix, parse as bytes\n225: \treturn strconv.ParseInt(s, 10, 64)\n226: }\n227: \n228: // parseCommaSeparatedList parses a comma-separated list string.\n229: func parseCommaSeparatedList(s string) []string {\n230: \tparts := strings.Split(s, \",\")\n231: \tresult := make([]string, 0, len(parts))\n232: \tfor _, part := range parts {\n233: \t\tpart = strings.TrimSpace(part)\n234: \t\tif part != \"\" {\n235: \t\t\tresult = append(result, part)\n236: \t\t}\n237: \t}\n238: \treturn result\n239: }\n240: \n241: // parseBool parses a boolean string.\n242: func parseBool(s string) bool {\n243: \ts = strings.TrimSpace(strings.ToLower(s))\n244: \treturn s == \"true\" || s == \"1\" || s == \"yes\" || s == \"on\"\n245: }\n\n(End of file - total 245 lines)\n</content>","metadata":{"preview":"/*\nCopyright 2026 The Volcano Authors.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\npackage picod\n\nimport (\n\t\"fmt\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/picod/file_config.go","time":{"start":1775877021033,"end":1775877021061}}}}
