a file in the sandbox.\n35: \tWriteFile(ctx context.Context, sandbox *types.SandboxInfo, req WriteFileRequest) (*FileInfo, error)\n36: \n37: \t// WriteFileStream writes data from a reader to a file in the sandbox.\n38: \tWriteFileStream(ctx context.Context, sandbox *types.SandboxInfo, req WriteStreamRequest, reader io.Reader) error\n39: \n40: \t// DeleteFile deletes a file from the sandbox.\n41: \tDeleteFile(ctx context.Context, sandbox *types.SandboxInfo, path string) error\n42: \n43: \t// ListDirectory lists entries in a directory in the sandbox.\n44: \tListDirectory(ctx context.Context, sandbox *types.SandboxInfo, path string, opts ListOptions) (*DirectoryListing, error)\n45: \n46: \t// Stat returns metadata for a file or directory in the sandbox.\n47: \tStat(ctx context.Context, sandbox *types.SandboxInfo, path string) (*FileInfo, error)\n48: \n49: \t// CreateDirectory creates a new directory in the sandbox.\n50: \tCreateDirectory(ctx context.Context, sandbox *types.SandboxInfo, path string) (*FileInfo, error)\n51: \n52: \t// RemoveDirectory removes a directory and all its contents from the sandbox.\n53: \tRemoveDirectory(ctx context.Context, sandbox *types.SandboxInfo, path string) error\n54: \n55: \t// Move moves/renames a file or directory in the sandbox.\n56: \tMove(ctx context.Context, sandbox *types.SandboxInfo, sourcePath string, destPath string) (*FileInfo, error)\n57: \n58: \t// Copy copies a file in the sandbox.\n59: \tCopy(ctx context.Context, sandbox *types.SandboxInfo, sourcePath string, destPath string) error\n60: }\n61: \n62: // SessionStore defines the interface for resolving session IDs to sandbox information.\n63: type SessionStore interface {\n64: \t// GetSandboxBySessionID retrieves sandbox information by session ID.\n65: \t// Returns an error if the session does not exist.\n66: \tGetSandboxBySessionID(ctx context.Context, sessionID string) (*types.SandboxInfo, error)\n67: }\n68: \n69: // SandboxFileClientFactory creates SandboxFileClient instances.\n70: type SandboxFileClientFactory func() SandboxFileClient\n\n(End of file - total 70 lines)\n</content>","metadata":{"preview":"/*\nCopyright 2026 The Volcano Authors.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\npackage picod\n\nimport (\n\t\"context\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/picod/sandbox_file_client.go","time":{"start":1775876860894,"end":1775876860915}}}}
