false\n45: }\n46: \n47: // StatusManager manages execution status transitions.\n48: type StatusManager struct {\n49: \tstore ExecutionStore\n50: }\n51: \n52: // NewStatusManager creates a new status manager.\n53: func NewStatusManager(store ExecutionStore) *StatusManager {\n54: \treturn &StatusManager{\n55: \t\tstore: store,\n56: \t}\n57: }\n58: \n59: // Create creates a new execution status.\n60: func (m *StatusManager) Create(id ExecutionID, sessionID string) (*ExecutionStatus, error) {\n61: \tstatus := &ExecutionStatus{\n62: \t\tID:        id,\n63: \t\tState:     StatePending,\n64: \t\tSessionID: sessionID,\n65: \t}\n66: \treturn status, m.store.CreateStatus(nil, status)\n67: }\n68: \n69: // Transition transitions an execution from one state to another.\n70: func (m *StatusManager) Transition(id ExecutionID, from, to ExecutionState, updateFn func(*ExecutionStatus)) error {\n71: \tif !IsValidTransition(from, to) {\n72: \t\treturn fmt.Errorf(\"invalid state transition from %s to %s\", from, to)\n73: \t}\n74: \n75: \treturn m.store.UpdateStatusWithTransition(nil, id, from, to, updateFn)\n76: }\n77: \n78: // Start transitions an execution to running state.\n79: func (m *StatusManager) Start(id ExecutionID) error {\n80: \tnow := time.Now()\n81: \treturn m.Transition(id, StatePending, StateRunning, func(s *ExecutionStatus) {\n82: \t\ts.StartedAt = &now\n83: \t})\n84: }\n85: \n86: // Complete transitions an execution to completed state.\n87: func (m *StatusManager) Complete(id ExecutionID, exitCode int) error {\n88: \tnow := time.Now()\n89: \treturn m.Transition(id, StateRunning, StateCompleted, func(s *ExecutionStatus) {\n90: \t\ts.FinishedAt = &now\n91: \t\ts.ExitCode = &exitCode\n92: \t})\n93: }\n94: \n95: // Fail transitions an execution to failed state.\n96: func (m *StatusManager) Fail(id ExecutionID, exitCode int) error {\n97: \tnow := time.Now()\n98: \treturn m.Transition(id, StateRunning, StateFailed, func(s *ExecutionStatus) {\n99: \t\ts.FinishedAt = &now\n100: \t\ts.ExitCode = &exitCode\n101: \t})\n102: }\n103: \n104: // Cancel transitions an execution to cancelled state.\n105: func (m *StatusManager) Cancel(id ExecutionID) error {\n106: \tnow := time.Now()\n107: \n108: \t// Try to cancel from pending\n109: \tif err := m.Transition(id, StatePending, StateCancelled, func(s *ExecutionStatus) {\n110: \t\ts.FinishedAt = &now\n111: \t}); err == nil {\n112: \t\treturn nil\n113: \t}\n114: \n115: \t// Try to cancel from running\n116: \treturn m.Transition(id, StateRunning, StateCancelled, func(s *ExecutionStatus) {\n117: \t\ts.FinishedAt = &now\n118: \t})\n119: }\n120: \n121: // Get retrieves the current status of an execution.\n122: func (m *StatusManager) Get(id ExecutionID) (*ExecutionStatus, error) {\n123: \treturn m.store.GetStatus(nil, id)\n124: }\n125: \n126: // CanCancel returns true if the execution can be cancelled.\n127: func CanCancel(state ExecutionState) bool {\n128: \treturn state == StatePending || state == StateRunning\n129: }\n130: \n131: // IsTerminal returns true if the execution is in a terminal state.\n132: func IsTerminal(state ExecutionState) bool {\n133: \treturn state.IsTerminal()\n134: }\n135: \n136: // StateFromString parses a state string.\n137: func StateFromString(s string) (ExecutionState, error) {\n138: \tswitch s {\n139: \tcase \"pending\":\n140: \t\treturn StatePending, nil\n141: \tcase \"running\":\n142: \t\treturn StateRunning, nil\n143: \tcase \"completed\":\n144: \t\treturn StateCompleted, nil\n145: \tcase \"failed\":\n146: \t\treturn StateFailed, nil\n147: \tcase \"cancelled\":\n148: \t\treturn StateCancelled, nil\n149: \tdefault:\n150: \t\treturn \"\", fmt.Errorf(\"invalid execution state: %s\", s)\n151: \t}\n152: }\n\n(End of file - total 152 lines)\n</content>","metadata":{"preview":"/*\nCopyright 2026 The Volcano Authors.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\npackage picod\n\nimport (\n\t\"fmt\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/picod/status.go","time":{"start":1775877138913,"end":1775877138938}}}}
{"type":"tool_use","timestamp":1775877138943,"sessionID":"ses_2857fbf8fffeHhKEiyGQze1uRE","part":{"id":"prt_d7a869f3a001W2p12ltZhpiV4W","messageID":"msg_d7a857712001H6hJ93qjKXmUah","sessionID":"ses_2857fbf8fffeHhKEiyGQze1uRE","type":"tool","tool":"read","callID":"toolu_functions.read:29","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/picod/output.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/picod/output.go</path>\n<type>file</type>\n<content>\n1: /*\n2: Copyright 2026 The Volcano Authors.\n3: \n4: Licensed under the Apache License, Version 2.0 (the \"License\");\n5: you may not use this file except in compliance with the License.\n6: You may obtain a copy of the License at\n7: \n8:     http://www.apache.org/licenses/LICENSE-2.0\n9: \n10: Unless required by applicable law or agreed to in writing, software\n11: distributed under the License is distributed on an \"AS IS\" BASIS,\n12: WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n13: See the License for the specific language governing permissions and\n14: limitations under the License.\n15: */\n16: \n17: package picod\n18: \n19: import (\n20: \t\"container/ring\"\n21: \t\"sync\"\n22: \t\"time\"\n23: )\n24: \n25: // OutputBuffer provides circular buffer for command output.\n26: type OutputBuffer struct {\n27: \t// id is the execution ID\n28: \tid ExecutionID\n29: \n30: \t// buffer is the circular buffer for output\n31: \tbuffer *ring.Ring\n32: \n33: \t// mu protects buffer\n34: \tmu sync.RWMutex\n35: \n36: \t// subscribers are channels to broadcast output to\n37: \tsubscribers []chan OutputChunk\n38: \n39: \t// subMu protects subscribers\n40: \tsubMu sync.RWMutex\n41: \n42: \t// closed indicates if the buffer is closed\n43: \tclosed bool\n44: \n45: \t// maxSize is the maximum buffer size\n46: \tmaxSize int\n47: }\n48: \n49: // NewOutputBuffer creates a new output buffer.\n50: func NewOutputBuffer(id ExecutionID, maxSize int) *OutputBuffer {\n51: \tif maxSize <= 0 {\n52: \t\tmaxSize = DefaultOutputBufferSize\n53: \t}\n54: \treturn &OutputBuffer{\n55: \t\tid:      id,\n56: \t\tbuffer:  ring.New(maxSize),\n57: \t\tmaxSize: maxSize,\n58: \t}\n59: }\n60: \n61: // Write writes output to the buffer.\n62: func (b *OutputBuffer) Write(data []byte, typ OutputType) {\n63: \tb.mu.Lock()\n64: \tdefer b.mu.Unlock()\n65: \n66: \tif b.closed {\n67: \t\treturn\n68: \t}\n69: \n70: \tchunk := OutputChunk{\n71: \t\tData:      data,\n72: \t\tType:      typ,\n73: \t\tTimestamp: time.Now(),\n74: \t}\n75: \n76: \tb.buffer.Value = chunk\n77: \tb.buffer = b.buffer.Next()\n78: \n79: \t// Broadcast to subscribers\n80: \tb.broadcast(chunk)\n81: }\n82: \n83: // broadcast sends a chunk to all subscribers.\n84: func (b *OutputBuffer) broadcast(chunk OutputChunk) {\n85: \tb.subMu.RLock()\n86: \tsubscribers := make([]chan OutputChunk, len(b.subscribers))\n87: \tcopy(subscribers, b.subscribers)\n88: \tb.subMu.RUnlock()\n89: \n90: \tfor _, ch := range subscribers {\n91: \t\tselect {\n92: \t\tcase ch <- chunk:\n93: \t\tdefault:\n94: \t\t\t// Channel is full, skip this subscriber\n95: \t\t}\n96: \t}\n97: }\n98: \n99: // Subscribe returns a channel for receiving output chunks.\n100: func (b *OutputBuffer) Subscribe() <-chan OutputChunk {\n101: \tb.subMu.Lock()\n102: \tdefer b.subMu.Unlock()\n103: \n104: \tch := make(chan OutputChunk, 100)\n105: \tb.subscribers = append(b.subscribers, ch)\n106: \n107: \t// Send buffered output to new subscriber\n108: \tb.mu.RLock()\n109: \tb.buffer.Do(func(v interface{}) {\n110: \t\tif v != nil {\n111: \t\t\tselect {\n112: \t\t\tcase ch <- v.(OutputChunk):\n113: \t\t\tdefault:\n114: \t\t\t}\n115: \t\t}\n116: \t})\n117: \tb.mu.RUnlock()\n118: \n119: \treturn ch\n120: }\n121: \n122: // Unsubscribe removes a subscriber channel.\n123: func (b *OutputBuffer) Unsubscribe(ch <-chan OutputChunk) {\n124: \tb.subMu.Lock()\n125: \tdefer b.subMu.Unlock()\n126: \n127: \tfor i, subscriber := range b.subscribers {\n128: \t\tif subscriber == ch {\n129: \t\t\tclose(subscriber)\n130: \t\t\tb.subscribers = append(b.subscribers[:i], b.subscribers[i+1:]...)\n131: \t\t\treturn\n132: \t\t}\n133: \t}\n134: }\n135: \n136: // Close closes the buffer and all subscriber channels.\n137: func (b *OutputBuffer) Close() {\n138: \tb.mu.Lock()\n139: \tb.closed = true\n140: \tb.mu.Unlock()\n141: \n142: \tb.subMu.Lock()\n143: \tfor _, ch := range b.subscribers {\n144: \t\tclose(ch)\n145: \t}\n146: \tb.subscribers = nil\n147: \tb.subMu.Unlock()\n148: }\n149: \n150: // IsClosed returns true if the buffer is closed.\n151: func (b *OutputBuffer) IsClosed() bool {\n152: \tb.mu.RLock()\n153: \tdefer b.mu.RUnlock()\n154: \treturn b.closed\n155: }\n156: \n157: // ID returns the execution ID for this buffer.\n158: func (b *OutputBuffer) ID() ExecutionID {\n159: \treturn b.id\n160: }\n161: \n162: // Size returns the current number of chunks in the buffer.\n163: func (b *OutputBuffer) Size() int {\n164: \tb.mu.RLock()\n165: \tdefer b.mu.RUnlock()\n166: \n167: \tcount := 0\n168: \tb.buffer.Do(func(v interface{}) {\n169: \t\tif v != nil {\n170: \t\t\tcount++\n171: \t\t}\n172: \t})\n173: \treturn count\n174: }\n175: \n176: // GetAll returns all chunks in the buffer as a slice.\n177: func (b *OutputBuffer) GetAll() []OutputChunk {\n178: \tb.mu.RLock()\n179: \tdefer b.mu.RUnlock()\n180: \n181: \tchunks := make([]OutputChunk, 0, b.maxSize)\n182: \tb.buffer.Do(func(v interface{}) {\n183: \t\tif v != nil {\n184: \t\t\tchunks = append(chunks, v.(OutputChunk))\n185: \t\t}\n186: \t})\n187: \treturn chunks\n188: }\n\n(End of file - total 188 lines)\n</content>","metadata":{"preview":"/*\nCopyright 2026 The Volcano Authors.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\npackage picod\n\nimport (\n\t\"container/ring\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/picod/output.go","time":{"start":1775877138915,"end":1775877138939}}}}
