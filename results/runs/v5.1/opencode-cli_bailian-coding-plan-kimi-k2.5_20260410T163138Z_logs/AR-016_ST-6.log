{"type":"tool_use","timestamp":1775876860914,"sessionID":"ses_2857fbf8fffeHhKEiyGQze1uRE","part":{"id":"prt_d7a82510b001XDKqouZEohEsJb","messageID":"msg_d7a8229a1001hS3CVbJAxIsgsY","sessionID":"ses_2857fbf8fffeHhKEiyGQze1uRE","type":"tool","tool":"read","callID":"toolu_functions.read:16","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/picod/file_types.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/picod/file_types.go</path>\n<type>file</type>\n<content>\n1: /*\n2: Copyright 2026 The Volcano Authors.\n3: \n4: Licensed under the Apache License, Version 2.0 (the \"License\");\n5: you may not use this file except in compliance with the License.\n6: You may obtain a copy of the License at\n7: \n8:     http://www.apache.org/licenses/LICENSE-2.0\n9: \n10: Unless required by applicable law or agreed to in writing, software\n11: distributed under the License is distributed on an \"AS IS\" BASIS,\n12: WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n13: See the License for the specific language governing permissions and\n14: limitations under the License.\n15: */\n16: \n17: package picod\n18: \n19: import (\n20: \t\"context\"\n21: \t\"io\"\n22: \t\"os\"\n23: \t\"time\"\n24: )\n25: \n26: // FileType represents the type of a file system entry.\n27: type FileType string\n28: \n29: const (\n30: \t// File represents a regular file\n31: \tFile FileType = \"file\"\n32: \n33: \t// Directory represents a directory\n34: \tDirectory FileType = \"directory\"\n35: \n36: \t// Symlink represents a symbolic link\n37: \tSymlink FileType = \"symlink\"\n38: )\n39: \n40: // String returns the string representation of the file type.\n41: func (ft FileType) String() string {\n42: \treturn string(ft)\n43: }\n44: \n45: // FileContent represents the contents of a file.\n46: type FileContent struct {\n47: \t// Data is the file content\n48: \tData []byte `json:\"data\"`\n49: \n50: \t// Size is the total file size (may differ from len(Data) for partial reads)\n51: \tSize int64 `json:\"size\"`\n52: \n53: \t// Truncated indicates if the content was truncated due to size limits\n54: \tTruncated bool `json:\"truncated\"`\n55: \n56: \t// MIMEType is the detected MIME type of the content\n57: \tMIMEType string `json:\"mimeType,omitempty\"`\n58: }\n59: \n60: // FileInfo contains metadata about a file or directory.\n61: type FileInfo struct {\n62: \t// Name is the base name of the file/directory\n63: \tName string `json:\"name\"`\n64: \n65: \t// Path is the full path to the file/directory\n66: \tPath string `json:\"path\"`\n67: \n68: \t// Type indicates whether this is a file or directory\n69: \tType FileType `json:\"type\"`\n70: \n71: \t// Size is the file size in bytes (0 for directories)\n72: \tSize int64 `json:\"size\"`\n73: \n74: \t// CreatedAt is when the file was created\n75: \tCreatedAt time.Time `json:\"createdAt\"`\n76: \n77: \t// ModifiedAt is when the file was last modified\n78: \tModifiedAt time.Time `json:\"modifiedAt\"`\n79: \n80: \t// AccessedAt is when the file was last accessed\n81: \tAccessedAt time.Time `json:\"accessedAt,omitempty\"`\n82: \n83: \t// Permissions are the file permissions (Unix-style)\n84: \tPermissions os.FileMode `json:\"permissions\"`\n85: \n86: \t// IsSymlink indicates if this is a symbolic link\n87: \tIsSymlink bool `json:\"isSymlink,omitempty\"`\n88: \n89: \t// LinkTarget is the symlink target (if IsSymlink is true)\n90: \tLinkTarget string `json:\"linkTarget,omitempty\"`\n91: }\n92: \n93: // DirectoryListing contains entries in a directory.\n94: type DirectoryListing struct {\n95: \t// Path is the directory path\n96: \tPath string `json:\"path\"`\n97: \n98: \t// Entries are the directory entries\n99: \tEntries []FileInfo `json:\"entries\"`\n100: \n101: \t// TotalCount is the total number of entries (for pagination)\n102: \tTotalCount int `json:\"totalCount\"`\n103: }\n104: \n105: // WriteFileRequest contains parameters for writing a file.\n106: type WriteFileRequest struct {\n107: \t// Path is the target file path\n108: \tPath string `json:\"path\"`\n109: \n110: \t// Data is the file content to write\n111: \tData []byte `json:\"data\"`\n112: \n113: \t// Overwrite allows overwriting existing files (default: true)\n114: \tOverwrite bool `json:\"overwrite\"`\n115: \n116: \t// CreateDirs creates parent directories if they don't exist (default: true)\n117: \tCreateDirs bool `json:\"createDirs\"`\n118: \n119: \t// Permissions sets the file permissions (default: 0644)\n120: \tPermissions os.FileMode `json:\"permissions\"`\n121: }\n122: \n123: // WriteStreamRequest contains parameters for streaming file writes.\n124: type WriteStreamRequest struct {\n125: \t// Path is the target file path\n126: \tPath string `json:\"path\"`\n127: \n128: \t// ExpectedSize is the expected total size (optional, for validation)\n129: \tExpectedSize int64 `json:\"expectedSize,omitempty\"`\n130: \n131: \t// Overwrite allows overwriting existing files (default: true)\n132: \tOverwrite bool `json:\"overwrite\"`\n133: \n134: \t// CreateDirs creates parent directories if they don't exist (default: true)\n135: \tCreateDirs bool `json:\"createDirs\"`\n136: \n137: \t// Permissions sets the file permissions (default: 0644)\n138: \tPermissions os.FileMode `json:\"permissions\"`\n139: }\n140: \n141: // ReadOptions contains options for read operations.\n142: type ReadOptions struct {\n143: \t// Offset is the byte offset to start reading from (default: 0)\n144: \tOffset int64 `json:\"offset,omitempty\"`\n145: \n146: \t// Limit is the maximum number of bytes to read (0 = unlimited)\n147: \tLimit int64 `json:\"limit,omitempty\"`\n148: }\n149: \n150: // ListOptions contains options for directory listing.\n151: type ListOptions struct {\n152: \t// Recursive lists contents recursively (default: false)\n153: \tRecursive bool `json:\"recursive,omitempty\"`\n154: \n155: \t// Pattern filters entries by glob pattern (e.g., \"*.go\")\n156: \tPattern string `json:\"pattern,omitempty\"`\n157: \n158: \t// Offset is the pagination offset\n159: \tOffset int `json:\"offset,omitempty\"`\n160: \n161: \t// Limit limits the number of entries returned (0 = unlimited)\n162: \tLimit int `json:\"limit,omitempty\"`\n163: }\n164: \n165: // CopyPair represents a source-destination pair for copy operations.\n166: type CopyPair struct {\n167: \t// SourcePath is the source file path\n168: \tSourcePath string `json:\"sourcePath\"`\n169: \n170: \t// DestPath is the destination file path\n171: \tDestPath string `json:\"destPath\"`\n172: \n173: \t// Overwrite allows overwriting destination (default: true)\n174: \tOverwrite bool `json:\"overwrite\"`\n175: }\n176: \n177: // BatchResult contains the result of a batch operation.\n178: type BatchResult struct {\n179: \t// SuccessCount is the number of successful operations\n180: \tSuccessCount int `json:\"successCount\"`\n181: \n182: \t// FailureCount is the number of failed operations\n183: \tFailureCount int `json:\"failureCount\"`\n184: \n185: \t// Failures maps paths to their errors\n186: \tFailures map[string]error `json:\"failures,omitempty\"`\n187: }\n188: \n189: // FileEventType represents the type of file system event.\n190: type FileEventType string\n191: \n192: const (\n193: \t// FileCreated indicates a file was created\n194: \tFileCreated FileEventType = \"created\"\n195: \n196: \t// FileModified indicates a file was modified\n197: \tFileModified FileEventType = \"modified\"\n198: \n199: \t// FileDeleted indicates a file was deleted\n200: \tFileDeleted FileEventType = \"deleted\"\n201: \n202: \t// FileRenamed indicates a file was renamed\n203: \tFileRenamed FileEventType = \"renamed\"\n204: )\n205: \n206: // String returns the string representation of the file event type.\n207: func (fet FileEventType) String() string {\n208: \treturn string(fet)\n209: }\n210: \n211: // FileEvent represents a file system event.\n212: type FileEvent struct {\n213: \t// Type is the event type\n214: \tType FileEventType `json:\"type\"`\n215: \n216: \t// Path is the file/directory path that triggered the event\n217: \tPath string `json:\"path\"`\n218: \n219: \t// Info contains file metadata (may be nil for some events)\n220: \tInfo *FileInfo `json:\"info,omitempty\"`\n221: \n222: \t// Timestamp is when the event occurred\n223: \tTimestamp time.Time `json:\"timestamp\"`\n224: }\n225: \n226: // WatchOptions contains options for directory watching.\n227: type WatchOptions struct {\n228: \t// Recursive watches subdirectories recursively (default: false)\n229: \tRecursive bool `json:\"recursive,omitempty\"`\n230: \n231: \t// Pattern filters events by glob pattern\n232: \tPattern string `json:\"pattern,omitempty\"`\n233: \n234: \t// EventTypes filters by event types (empty = all events)\n235: \tEventTypes []FileEventType `json:\"eventTypes,omitempty\"`\n236: }\n237: \n238: // Watcher provides control over an active watch.\n239: type Watcher struct {\n240: \t// id is the watcher identifier\n241: \tid string\n242: \n243: \t// sessionID is the target sandbox session\n244: \tsessionID string\n245: \n246: \t// path is the watched path\n247: \tpath string\n248: \n249: \t// stop stops the watcher\n250: \tstop func()\n251: }\n252: \n253: // Stop stops the watcher and releases resources.\n254: func (w *Watcher) Stop() error {\n255: \tif w.stop != nil {\n256: \t\tw.stop()\n257: \t}\n258: \treturn nil\n259: }\n260: \n261: // FileManager defines the interface for file operations in sandboxes.\n262: type FileManager interface {\n263: \t// ReadFile reads the entire contents of a file.\n264: \t// Returns ErrFileNotFound if the file does not exist.\n265: \tReadFile(ctx context.Context, sessionID string, path string) (*FileContent, error)\n266: \n267: \t// ReadFileStream returns a stream for reading file contents.\n268: \t// Supports partial reads via ReadOptions.\n269: \tReadFileStream(ctx context.Context, sessionID string, path string, opts ReadOptions) (io.ReadCloser, error)\n270: \n271: \t// WriteFile writes data to a file.\n272: \t// Creates the file if it doesn't exist, overwrites if it does.\n273: \tWriteFile(ctx context.Context, sessionID string, req WriteFileRequest) (*FileInfo, error)\n274: \n275: \t// WriteFileStream writes data from a reader to a file.\n276: \t// Efficient for large files.\n277: \tWriteFileStream(ctx context.Context, sessionID string, req WriteStreamRequest, reader io.Reader) error\n278: \n279: \t// DeleteFile deletes a file.\n280: \t// Returns ErrFileNotFound if the file does not exist.\n281: \tDeleteFile(ctx context.Context, sessionID string, path string) error\n282: \n283: \t// ListDirectory lists entries in a directory.\n284: \t// Returns ErrDirectoryNotFound if the directory does not exist.\n285: \tListDirectory(ctx context.Context, sessionID string, path string, opts ListOptions) (*DirectoryListing, error)\n286: \n287: \t// Stat returns metadata for a file or directory.\n288: \t// Returns ErrFileNotFound or ErrDirectoryNotFound if the path does not exist.\n289: \tStat(ctx context.Context, sessionID string, path string) (*FileInfo, error)\n290: \n291: \t// CreateDirectory creates a new directory.\n292: \t// Returns ErrDirectoryExists if the directory already exists.\n293: \tCreateDirectory(ctx context.Context, sessionID string, path string) (*FileInfo, error)\n294: \n295: \t// RemoveDirectory removes a directory and all its contents.\n296: \t// Returns ErrDirectoryNotFound if the directory does not exist.\n297: \tRemoveDirectory(ctx context.Context, sessionID string, path string) error\n298: \n299: \t// Move moves/renames a file or directory.\n300: \tMove(ctx context.Context, sessionID string, sourcePath string, destPath string) (*FileInfo, error)\n301: \n302: \t// Copy copies a file.\n303: \tCopy(ctx context.Context, sessionID string, sourcePath string, destPath string) error\n304: \n305: \t// BatchStat returns metadata for multiple files.\n306: \tBatchStat(ctx context.Context, sessionID string, paths []string) (map[string]*FileInfo, error)\n307: \n308: \t// BatchDelete deletes multiple files.\n309: \tBatchDelete(ctx context.Context, sessionID string, paths []string) (*BatchResult, error)\n310: \n311: \t// BatchCopy copies multiple files.\n312: \tBatchCopy(ctx context.Context, sessionID string, pairs []CopyPair) (*BatchResult, error)\n313: \n314: \t// WatchDirectory watches for file system events in a directory.\n315: \t// Returns a Watcher handle and event channel.\n316: \tWatchDirectory(ctx context.Context, sessionID string, path string, opts WatchOptions) (*Watcher, <-chan FileEvent, error)\n317: }\n\n(End of file - total 317 lines)\n</content>","metadata":{"preview":"/*\nCopyright 2026 The Volcano Authors.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\npackage picod\n\nimport (\n\t\"context\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/picod/file_types.go","time":{"start":1775876860891,"end":1775876860912}}}}
