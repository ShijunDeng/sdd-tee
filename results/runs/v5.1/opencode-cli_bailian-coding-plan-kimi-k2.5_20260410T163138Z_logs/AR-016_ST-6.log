imePhaseFailed, \"Failed\"},\n39: \t\t{\"Unknown\", AgentRuntimePhaseUnknown, \"Unknown\"},\n40: \t}\n41: \n42: \tfor _, tt := range tests {\n43: \t\tt.Run(tt.name, func(t *testing.T) {\n44: \t\t\tif string(tt.phase) != tt.expected {\n45: \t\t\t\tt.Errorf(\"Expected phase %s, got %s\", tt.expected, tt.phase)\n46: \t\t\t}\n47: \t\t})\n48: \t}\n49: }\n50: \n51: func TestAgentRuntimeConditionTypeValues(t *testing.T) {\n52: \ttests := []struct {\n53: \t\tname     string\n54: \t\tcondType AgentRuntimeConditionType\n55: \t\texpected string\n56: \t}{\n57: \t\t{\"Ready\", AgentRuntimeConditionReady, \"Ready\"},\n58: \t\t{\"SandboxCreated\", AgentRuntimeConditionSandboxCreated, \"SandboxCreated\"},\n59: \t\t{\"SandboxReady\", AgentRuntimeConditionSandboxReady, \"SandboxReady\"},\n60: \t\t{\"Failed\", AgentRuntimeConditionFailed, \"Failed\"},\n61: \t}\n62: \n63: \tfor _, tt := range tests {\n64: \t\tt.Run(tt.name, func(t *testing.T) {\n65: \t\t\tif string(tt.condType) != tt.expected {\n66: \t\t\t\tt.Errorf(\"Expected condition type %s, got %s\", tt.expected, tt.condType)\n67: \t\t\t}\n68: \t\t})\n69: \t}\n70: }\n71: \n72: func TestAgentRuntimeSpec(t *testing.T) {\n73: \ttests := []struct {\n74: \t\tname string\n75: \t\tspec AgentRuntimeSpec\n76: \t}{\n77: \t\t{\n78: \t\t\tname: \"minimal spec with only image\",\n79: \t\t\tspec: AgentRuntimeSpec{\n80: \t\t\t\tImage: \"busybox:latest\",\n81: \t\t\t},\n82: \t\t},\n83: \t\t{\n84: \t\t\tname: \"spec with resources\",\n85: \t\t\tspec: AgentRuntimeSpec{\n86: \t\t\t\tImage: \"ubuntu:22.04\",\n87: \t\t\t\tResources: &corev1.ResourceRequirements{\n88: \t\t\t\t\tLimits: corev1.ResourceList{\n89: \t\t\t\t\t\tcorev1.ResourceCPU:    resource.MustParse(\"1000m\"),\n90: \t\t\t\t\t\tcorev1.ResourceMemory: resource.MustParse(\"1Gi\"),\n91: \t\t\t\t\t},\n92: \t\t\t\t\tRequests: corev1.ResourceList{\n93: \t\t\t\t\t\tcorev1.ResourceCPU:    resource.MustParse(\"500m\"),\n94: \t\t\t\t\t\tcorev1.ResourceMemory: resource.MustParse(\"512Mi\"),\n95: \t\t\t\t\t},\n96: \t\t\t\t},\n97: \t\t\t},\n98: \t\t},\n99: \t\t{\n100: \t\t\tname: \"spec with environment variables\",\n101: \t\t\tspec: AgentRuntimeSpec{\n102: \t\t\t\tImage: \"python:3.11\",\n103: \t\t\t\tEnv: []corev1.EnvVar{\n104: \t\t\t\t\t{\n105: \t\t\t\t\t\tName:  \"FOO\",\n106: \t\t\t\t\t\tValue: \"bar\",\n107: \t\t\t\t\t},\n108: \t\t\t\t\t{\n109: \t\t\t\t\t\tName: \"SECRET\",\n110: \t\t\t\t\t\tValueFrom: &corev1.EnvVarSource{\n111: \t\t\t\t\t\t\tSecretKeyRef: &corev1.SecretKeySelector{\n112: \t\t\t\t\t\t\t\tLocalObjectReference: corev1.LocalObjectReference{\n113: \t\t\t\t\t\t\t\t\tName: \"my-secret\",\n114: \t\t\t\t\t\t\t\t},\n115: \t\t\t\t\t\t\t\tKey: \"password\",\n116: \t\t\t\t\t\t\t},\n117: \t\t\t\t\t\t},\n118: \t\t\t\t\t},\n119: \t\t\t\t},\n120: \t\t\t},\n121: \t\t},\n122: \t\t{\n123: \t\t\tname: \"spec with command and args\",\n124: \t\t\tspec: AgentRuntimeSpec{\n125: \t\t\t\tImage:   \"python:3.11\",\n126: \t\t\t\tCommand: []string{\"python\", \"-m\", \"http.server\"},\n127: \t\t\t\tArgs:    []string{\"8080\"},\n128: \t\t\t},\n129: \t\t},\n130: \t\t{\n131: \t\t\tname: \"spec with working directory\",\n132: \t\t\tspec: AgentRuntimeSpec{\n133: \t\t\t\tImage:      \"node:18\",\n134: \t\t\t\tWorkingDir: \"/app\",\n135: \t\t\t},\n136: \t\t},\n137: \t\t{\n138: \t\t\tname: \"spec with ports\",\n139: \t\t\tspec: AgentRuntimeSpec{\n140: \t\t\t\tImage: \"nginx:latest\",\n141: \t\t\t\tPorts: []corev1.ContainerPort{\n142: \t\t\t\t\t{\n143: \t\t\t\t\t\tName:          \"http\",\n144: \t\t\t\t\t\tContainerPort: 80,\n145: \t\t\t\t\t\tProtocol:      corev1.ProtocolTCP,\n146: \t\t\t\t\t},\n147: \t\t\t\t\t{\n148: \t\t\t\t\t\tName:          \"https\",\n149: \t\t\t\t\t\tContainerPort: 443,\n150: \t\t\t\t\t\tProtocol:      corev1.ProtocolTCP,\n151: \t\t\t\t\t},\n152: \t\t\t\t},\n153: \t\t\t},\n154: \t\t},\n155: \t\t{\n156: \t\t\tname: \"spec with volume mounts and volumes\",\n157: \t\t\tspec: AgentRuntimeSpec{\n158: \t\t\t\tImage: \"busybox:latest\",\n159: \t\t\t\tVolumeMounts: []corev1.VolumeMount{\n160: \t\t\t\t\t{\n161: \t\t\t\t\t\tName:      \"data\",\n162: \t\t\t\t\t\tMountPath: \"/data\",\n163: \t\t\t\t\t},\n164: \t\t\t\t},\n165: \t\t\t\tVolumes: []corev1.Volume{\n166: \t\t\t\t\t{\n167: \t\t\t\t\t\tName: \"data\",\n168: \t\t\t\t\t\tVolumeSource: corev1.VolumeSource{\n169: \t\t\t\t\t\t\tEmptyDir: &corev1.EmptyDirVolumeSource{},\n170: \t\t\t\t\t\t},\n171: \t\t\t\t\t},\n172: \t\t\t\t},\n173: \t\t\t},\n174: \t\t},\n175: \t\t{\n176: \t\t\tname: \"spec with service account\",\n177: \t\t\tspec: AgentRuntimeSpec{\n178: \t\t\t\tImage:              \"busybox:latest\",\n179: \t\t\t\tServiceAccountName: \"sandbox-sa\",\n180: \t\t\t},\n181: \t\t},\n182: \t\t{\n183: \t\t\tname: \"spec with node selector\",\n184: \t\t\tspec: AgentRuntimeSpec{\n185: \t\t\t\tImage: \"busybox:latest\",\n186: \t\t\t\tNodeSelector: map[string]string{\n187: \t\t\t\t\t\"node-type\": \"sandbox\",\n188: \t\t\t\t\t\"gpu\":       \"nvidia\",\n189: \t\t\t\t},\n190: \t\t\t},\n191: \t\t},\n192: \t\t{\n193: \t\t\tname: \"spec with tolerations\",\n194: \t\t\tspec: AgentRuntimeSpec{\n195: \t\t\t\tImage: \"busybox:latest\",\n196: \t\t\t\tTolerations: []corev1.Toleration{\n197: \t\t\t\t\t{\n198: \t\t\t\t\t\tKey:      \"special\",\n199: \t\t\t\t\t\tOperator: corev1.TolerationOpEqual,\n200: \t\t\t\t\t\tValue:    \"true\",\n201: \t\t\t\t\t\tEffect:   corev1.TaintEffectNoSchedule,\n202: \t\t\t\t\t},\n203: \t\t\t\t},\n204: \t\t\t},\n205: \t\t},\n206: \t\t{\n207: \t\t\tname: \"spec with affinity\",\n208: \t\t\tspec: AgentRuntimeSpec{\n209: \t\t\t\tImage: \"busybox:latest\",\n210: \t\t\t\tAffinity: &corev1.Affinity{\n211: \t\t\t\t\tNodeAffinity: &corev1.NodeAffinity{\n212: \t\t\t\t\t\tRequiredDuringSchedulingIgnoredDuringExecution: &corev1.NodeSelector{\n213: \t\t\t\t\t\t\tNodeSelectorTerms: []corev1.NodeSelectorTerm{\n214: \t\t\t\t\t\t\t\t{\n215: \t\t\t\t\t\t\t\t\tMatchExpressions: []corev1.NodeSelectorRequirement{\n216: \t\t\t\t\t\t\t\t\t\t{\n217: \t\t\t\t\t\t\t\t\t\t\tKey:      \"kubernetes.io/os\",\n218: \t\t\t\t\t\t\t\t\t\t\tOperator: corev1.NodeSelectorOpIn,\n219: \t\t\t\t\t\t\t\t\t\t\tValues:   []string{\"linux\"},\n220: \t\t\t\t\t\t\t\t\t\t},\n221: \t\t\t\t\t\t\t\t\t},\n222: \t\t\t\t\t\t\t\t},\n223: \t\t\t\t\t\t\t},\n224: \t\t\t\t\t\t},\n225: \t\t\t\t\t},\n226: \t\t\t\t},\n227: \t\t\t},\n228: \t\t},\n229: \t\t{\n230: \t\t\tname: \"spec with timeouts\",\n231: \t\t\tspec: AgentRuntimeSpec{\n232: \t\t\t\tImage:                   \"busybox:latest\",\n233: \t\t\t\tTTLSecondsAfterFinished: int32Ptr(3600),\n234: \t\t\t\tIdleTimeoutSeconds:      int32Ptr(300),\n235: \t\t\t\tMaxLifetimeSeconds:      int32Ptr(7200),\n236: \t\t\t},\n237: \t\t},\n238: \t\t{\n239: \t\t\tname: \"full spec\",\n240: \t\t\tspec: AgentRuntimeSpec{\n241: \t\t\t\tImage:              \"ubuntu:22.04\",\n242: \t\t\t\tCommand:            []string{\"/bin/bash\", \"-c\"},\n243: \t\t\t\tArgs:               []string{\"sleep infinity\"},\n244: \t\t\t\tWorkingDir:         \"/workspace\",\n245: \t\t\t\tServiceAccountName: \"sandbox-sa\",\n246: \t\t\t\tResources: &corev1.ResourceRequirements{\n247: \t\t\t\t\tLimits: corev1.ResourceList{\n248: \t\t\t\t\t\tcorev1.ResourceCPU:    resource.MustParse(\"2000m\"),\n249: \t\t\t\t\t\tcorev1.ResourceMemory: resource.MustParse(\"4Gi\"),\n250: \t\t\t\t\t},\n251: \t\t\t\t},\n252: \t\t\t\tEnv: []corev1.EnvVar{\n253: \t\t\t\t\t{Name: \"ENV\", Value: \"production\"},\n254: \t\t\t\t},\n255: \t\t\t\tTTLSecondsAfterFinished: int32Ptr(600),\n256: \t\t\t\tIdleTimeoutSeconds:      int32Ptr(60),\n257: \t\t\t\tMaxLifetimeSeconds:      int32Ptr(3600),\n258: \t\t\t},\n259: \t\t},\n260: \t}\n261: \n262: \tfor _, tt := range tests {\n263: \t\tt.Run(tt.name, func(t *testing.T) {\n264: \t\t\tif tt.spec.Image == \"\" {\n265: \t\t\t\tt.Error(\"Image should not be empty\")\n266: \t\t\t}\n267: \t\t})\n268: \t}\n269: }\n270: \n271: func TestAgentRuntimeStatus(t *testing.T) {\n272: \tnow := metav1.NewTime(time.Now())\n273: \n274: \ttests := []struct {\n275: \t\tname   string\n276: \t\tstatus AgentRuntimeStatus\n277: \t}{\n278: \t\t{\n279: \t\t\tname:   \"empty status\",\n280: \t\t\tstatus: AgentRuntimeStatus{},\n281: \t\t},\n282: \t\t{\n283: \t\t\tname: \"status with phase\",\n284: \t\t\tstatus: AgentRuntimeStatus{\n285: \t\t\t\tPhase: AgentRuntimePhaseRunning,\n286: \t\t\t},\n287: \t\t},\n288: \t\t{\n289: \t\t\tname: \"status with sandbox info\",\n290: \t\t\tstatus: AgentRuntimeStatus{\n291: \t\t\t\tPhase:     AgentRuntimePhaseRunning,\n292: \t\t\t\tSandboxID: \"sandbox-abc123\",\n293: \t\t\t\tPodName:   \"agent-runtime-abc123\",\n294: \t\t\t\tPodIP:     \"10.244.0.5\",\n295: \t\t\t},\n296: \t\t},\n297: \t\t{\n298: \t\t\tname: \"status with timestamps\",\n299: \t\t\tstatus: AgentRuntimeStatus{\n300: \t\t\t\tPhase:            AgentRuntimePhaseSucceeded,\n301: \t\t\t\tStartTime:        &now,\n302: \t\t\t\tCompletionTime:   &now,\n303: \t\t\t\tLastActivityTime: &now,\n304: \t\t\t},\n305: \t\t},\n306: \t\t{\n307: \t\t\tname: \"status with conditions\",\n308: \t\t\tstatus: AgentRuntimeStatus{\n309: \t\t\t\tPhase: AgentRuntimePhaseRunning,\n310: \t\t\t\tConditions: []AgentRuntimeCondition{\n311: \t\t\t\t\t{\n312: \t\t\t\t\t\tType:   AgentRuntimeConditionReady,\n313: \t\t\t\t\t\tStatus: corev1.ConditionTrue,\n314: \t\t\t\t\t\tLastTransitionTime: metav1.Time{\n315: \t\t\t\t\t\t\tTime: time.Now(),\n316: \t\t\t\t\t\t},\n317: \t\t\t\t\t\tReason:  \"AgentRuntimeReady\",\n318: \t\t\t\t\t\tMessage: \"AgentRuntime is ready\",\n319: \t\t\t\t\t},\n320: \t\t\t\t\t{\n321: \t\t\t\t\t\tType:   AgentRuntimeConditionSandboxReady,\n322: \t\t\t\t\t\tStatus: corev1.ConditionTrue,\n323: \t\t\t\t\t\tLastTransitionTime: metav1.Time{\n324: \t\t\t\t\t\t\tTime: time.Now(),\n325: \t\t\t\t\t\t},\n326: \t\t\t\t\t\tReason:  \"SandboxCreated\",\n327: \t\t\t\t\t\tMessage: \"Sandbox pod is running\",\n328: \t\t\t\t\t},\n329: \t\t\t\t},\n330: \t\t\t},\n331: \t\t},\n332: \t\t{\n333: \t\t\tname: \"full status\",\n334: \t\t\tstatus: AgentRuntimeStatus{\n335: \t\t\t\tPhase:              AgentRuntimePhaseRunning,\n336: \t\t\t\tSandboxID:          \"sandbox-abc123\",\n337: \t\t\t\tPodName:            \"agent-runtime-abc123\",\n338: \t\t\t\tPodIP:              \"10.244.0.5\",\n339: \t\t\t\tStartTime:          &now,\n340: \t\t\t\tLastActivityTime:   &now,\n341: \t\t\t\tMessage:            \"Sandbox is running and ready\",\n342: \t\t\t\tReason:             \"SandboxRunning\",\n343: \t\t\t\tObservedGeneration: 1,\n344: \t\t\t\tConditions: []AgentRuntimeCondition{\n345: \t\t\t\t\t{\n346: \t\t\t\t\t\tType:   AgentRuntimeConditionReady,\n347: \t\t\t\t\t\tStatus: corev1.ConditionTrue,\n348: \t\t\t\t\t\tLastTransitionTime: metav1.Time{\n349: \t\t\t\t\t\t\tTime: time.Now(),\n350: \t\t\t\t\t\t},\n351: \t\t\t\t\t\tReason:  \"AgentRuntimeReady\",\n352: \t\t\t\t\t\tMessage: \"AgentRuntime is ready to accept requests\",\n353: \t\t\t\t\t},\n354: \t\t\t\t},\n355: \t\t\t},\n356: \t\t},\n357: \t}\n358: \n359: \tfor _, tt := range tests {\n360: \t\tt.Run(tt.name, func(t *testing.T) {\n361: \t\t\t// Validate phase if set\n362: \t\t\tif tt.status.Phase != \"\" {\n363: \t\t\t\tvalidPhases := []AgentRuntimePhase{\n364: \t\t\t\t\tAgentRuntimePhasePending,\n365: \t\t\t\t\tAgentRuntimePhaseRunning,\n366: \t\t\t\t\tAgentRuntimePhaseSucceeded,\n367: \t\t\t\t\tAgentRuntimePhaseFailed,\n368: \t\t\t\t\tAgentRuntimePhaseUnknown,\n369: \t\t\t\t}\n370: \t\t\t\tvalid := false\n371: \t\t\t\tfor _, p := range validPhases {\n372: \t\t\t\t\tif tt.status.Phase == p {\n373: \t\t\t\t\t\tvalid = true\n374: \t\t\t\t\t\tbreak\n375: \t\t\t\t\t}\n376: \t\t\t\t}\n377: \t\t\t\tif !valid {\n378: \t\t\t\t\tt.Errorf(\"Invalid phase: %s\", tt.status.Phase)\n379: \t\t\t\t}\n380: \t\t\t}\n381: \n382: \t\t\t// Validate conditions if present\n383: \t\t\tfor _, cond := range tt.status.Conditions {\n384: \t\t\t\tif cond.Type == \"\" {\n385: \t\t\t\t\tt.Error(\"Condition type should not be empty\")\n386: \t\t\t\t}\n387: \t\t\t\tif cond.Status == \"\" {\n388: \t\t\t\t\tt.Error(\"Condition status should not be empty\")\n389: \t\t\t\t}\n390: \t\t\t}\n391: \t\t})\n392: \t}\n393: }\n394: \n395: func TestAgentRuntimeCondition(t *testing.T) {\n396: \tcond := AgentRuntimeCondition{\n397: \t\tType:   AgentRuntimeConditionReady,\n398: \t\tStatus: corev1.ConditionTrue,\n399: \t\tLastTransitionTime: metav1.Time{\n400: \t\t\tTime: time.Now(),\n401: \t\t},\n402: \t\tReason:  \"AgentRuntimeReady\",\n403: \t\tMessage: \"AgentRuntime is ready\",\n404: \t}\n405: \n406: \tif cond.Type != AgentRuntimeConditionReady {\n407: \t\tt.Errorf(\"Expected condition type %s, got %s\", AgentRuntimeConditionReady, cond.Type)\n408: \t}\n409: \n410: \tif cond.Status != corev1.ConditionTrue {\n411: \t\tt.Errorf(\"Expected status %s, got %s\", corev1.ConditionTrue, cond.Status)\n412: \t}\n413: \n414: \tif cond.Reason != \"AgentRuntimeReady\" {\n415: \t\tt.Errorf(\"Expected reason 'AgentRuntimeReady', got %s\", cond.Reason)\n416: \t}\n417: \n418: \tif cond.Message != \"AgentRuntime is ready\" {\n419: \t\tt.Errorf(\"Expected message 'AgentRuntime is ready', got %s\", cond.Message)\n420: \t}\n421: }\n422: \n423: func TestAgentRuntime(t *testing.T) {\n424: \tnow := metav1.NewTime(time.Now())\n425: \n426: \truntime := AgentRuntime{\n427: \t\tTypeMeta: metav1.TypeMeta{\n428: \t\t\tAPIVersion: \"runtime.agentcube.volcano.sh/v1alpha1\",\n429: \t\t\tKind:       \"AgentRuntime\",\n430: \t\t},\n431: \t\tObjectMeta: metav1.ObjectMeta{\n432: \t\t\tName:      \"test-runtime\",\n433: \t\t\tNamespace: \"default\",\n434: \t\t\tLabels: map[string]string{\n435: \t\t\t\t\"app\": \"agent-runtime\",\n436: \t\t\t},\n437: \t\t\tAnnotations: map[string]string{\n438: \t\t\t\t\"description\": \"Test agent runtime\",\n439: \t\t\t},\n440: \t\t},\n441: \t\tSpec: AgentRuntimeSpec{\n442: \t\t\tImage: \"ubuntu:22.04\",\n443: \t\t\tResources: &corev1.ResourceRequirements{\n444: \t\t\t\tLimits: corev1.ResourceList{\n445: \t\t\t\t\tcorev1.ResourceCPU:    resource.MustParse(\"1000m\"),\n446: \t\t\t\t\tcorev1.ResourceMemory: resource.MustParse(\"1Gi\"),\n447: \t\t\t\t},\n448: \t\t\t},\n449: \t\t\tEnv: []corev1.EnvVar{\n450: \t\t\t\t{Name: \"FOO\", Value: \"bar\"},\n451: \t\t\t},\n452: \t\t\tTTLSecondsAfterFinished: int32Ptr(3600),\n453: \t\t},\n454: \t\tStatus: AgentRuntimeStatus{\n455: \t\t\tPhase:     AgentRuntimePhaseRunning,\n456: \t\t\tSandboxID: \"sandbox-abc123\",\n457: \t\t\tPodName:   \"test-runtime-abc123\",\n458: \t\t\tPodIP:     \"10.244.0.5\",\n459: \t\t\tStartTime: &now,\n460: \t\t\tConditions: []AgentRuntimeCondition{\n461: \t\t\t\t{\n462: \t\t\t\t\tType:   AgentRuntimeConditionReady,\n463: \t\t\t\t\tStatus: corev1.ConditionTrue,\n464: \t\t\t\t\tLastTransitionTime: metav1.Time{\n465: \t\t\t\t\t\tTime: time.Now(),\n466: \t\t\t\t\t},\n467: \t\t\t\t\tReason:  \"AgentRuntimeReady\",\n468: \t\t\t\t\tMessage: \"AgentRuntime is ready\",\n469: \t\t\t\t},\n470: \t\t\t},\n471: \t\t},\n472: \t}\n473: \n474: \t// Validate TypeMeta\n475: \tif runtime.APIVersion != \"runtime.agentcube.volcano.sh/v1alpha1\" {\n476: \t\tt.Errorf(\"Expected APIVersion 'runtime.agentcube.volcano.sh/v1alpha1', got %s\", runtime.APIVersion)\n477: \t}\n478: \n479: \tif runtime.Kind != \"AgentRuntime\" {\n480: \t\tt.Errorf(\"Expected Kind 'AgentRuntime', got %s\", runtime.Kind)\n481: \t}\n482: \n483: \t// Validate ObjectMeta\n484: \tif runtime.Name != \"test-runtime\" {\n485: \t\tt.Errorf(\"Expected name 'test-runtime', got %s\", runtime.Name)\n486: \t}\n487: \n488: \tif runtime.Namespace != \"default\" {\n489: \t\tt.Errorf(\"Expected namespace 'default', got %s\", runtime.Namespace)\n490: \t}\n491: \n492: \t// Validate Spec\n493: \tif runtime.Spec.Image != \"ubuntu:22.04\" {\n494: \t\tt.Errorf(\"Expected image 'ubuntu:22.04', got %s\", runtime.Spec.Image)\n495: \t}\n496: \n497: \tif runtime.Spec.Resources == nil {\n498: \t\tt.Error(\"Expected Resources to be set\")\n499: \t}\n500: \n501: \tif len(runtime.Spec.Env) != 1 {\n502: \t\tt.Errorf(\"Expected 1 env var, got %d\", len(runtime.Spec.Env))\n503: \t}\n504: \n505: \tif *runtime.Spec.TTLSecondsAfterFinished != 3600 {\n506: \t\tt.Errorf(\"Expected TTLSecondsAfterFinished 3600, got %d\", *runtime.Spec.TTLSecondsAfterFinished)\n507: \t}\n508: \n509: \t// Validate Status\n510: \tif runtime.Status.Phase != AgentRuntimePhaseRunning {\n511: \t\tt.Errorf(\"Expected phase %s, got %s\", AgentRuntimePhaseRunning, runtime.Status.Phase)\n512: \t}\n513: \n514: \tif runtime.Status.SandboxID != \"sandbox-abc123\" {\n515: \t\tt.Errorf(\"Expected sandboxId 'sandbox-abc123', got %s\", runtime.Status.SandboxID)\n516: \t}\n517: \n518: \tif len(runtime.Status.Conditions) != 1 {\n519: \t\tt.Errorf(\"Expected 1 condition, got %d\", len(runtime.Status.Conditions))\n520: \t}\n521: }\n522: \n523: func TestAgentRuntimeList(t *testing.T) {\n524: \tlist := AgentRuntimeList{\n525: \t\tTypeMeta: metav1.TypeMeta{\n526: \t\t\tAPIVersion: \"runtime.agentcube.volcano.sh/v1alpha1\",\n527: \t\t\tKind:       \"AgentRuntimeList\",\n528: \t\t},\n529: \t\tListMeta: metav1.ListMeta{\n530: \t\t\tResourceVersion: \"12345\",\n531: \t\t\tContinue:        \"\",\n532: \t\t},\n533: \t\tItems: []AgentRuntime{\n534: \t\t\t{\n535: \t\t\t\tObjectMeta: metav1.ObjectMeta{\n536: \t\t\t\t\tName:      \"runtime-1\",\n537: \t\t\t\t\tNamespace: \"default\",\n538: \t\t\t\t},\n539: \t\t\t\tSpec: AgentRuntimeSpec{\n540: \t\t\t\t\tImage: \"busybox:latest\",\n541: \t\t\t\t},\n542: \t\t\t},\n543: \t\t\t{\n544: \t\t\t\tObjectMeta: metav1.ObjectMeta{\n545: \t\t\t\t\tName:      \"runtime-2\",\n546: \t\t\t\t\tNamespace: \"default\",\n547: \t\t\t\t},\n548: \t\t\t\tSpec: AgentRuntimeSpec{\n549: \t\t\t\t\tImage: \"ubuntu:22.04\",\n550: \t\t\t\t},\n551: \t\t\t},\n552: \t\t},\n553: \t}\n554: \n555: \tif len(list.Items) != 2 {\n556: \t\tt.Errorf(\"Expected 2 items, got %d\", len(list.Items))\n557: \t}\n558: \n559: \tif list.Items[0].Name != \"runtime-1\" {\n560: \t\tt.Errorf(\"Expected first item name 'runtime-1', got %s\", list.Items[0].Name)\n561: \t}\n562: \n563: \tif list.Items[1].Name != \"runtime-2\" {\n564: \t\tt.Errorf(\"Expected second item name 'runtime-2', got %s\", list.Items[1].Name)\n565: \t}\n566: \n567: \tif list.Items[0].Spec.Image != \"busybox:latest\" {\n568: \t\tt.Errorf(\"Expected first item image 'busybox:latest', got %s\", list.Items[0].Spec.Image)\n569: \t}\n570: \n571: \tif list.Items[1].Spec.Image != \"ubuntu:22.04\" {\n572: \t\tt.Errorf(\"Expected second item image 'ubuntu:22.04', got %s\", list.Items[1].Spec.Image)\n573: \t}\n574: }\n575: \n576: func TestAgentRuntimeDeepCopy(t *testing.T) {\n577: \tnow := metav1.NewTime(time.Now())\n578: \n579: \toriginal := &AgentRuntime{\n580: \t\tTypeMeta: metav1.TypeMeta{\n581: \t\t\tAPIVersion: \"runtime.agentcube.volcano.sh/v1alpha1\",\n582: \t\t\tKind:       \"AgentRuntime\",\n583: \t\t},\n584: \t\tObjectMeta: metav1.ObjectMeta{\n585: \t\t\tName:      \"original\",\n586: \t\t\tNamespace: \"default\",\n587: \t\t\tLabels: map[string]string{\n588: \t\t\t\t\"key\": \"value\",\n589: \t\t\t},\n590: \t\t},\n591: \t\tSpec: AgentRuntimeSpec{\n592: \t\t\tImage: \"ubuntu:22.04\",\n593: \t\t\tResources: &corev1.ResourceRequirements{\n594: \t\t\t\tLimits: corev1.ResourceList{\n595: \t\t\t\t\tcorev1.ResourceCPU: resource.MustParse(\"1000m\"),\n596: \t\t\t\t},\n597: \t\t\t},\n598: \t\t\tEnv: []corev1.EnvVar{\n599: \t\t\t\t{Name: \"FOO\", Value: \"bar\"},\n600: \t\t\t},\n601: \t\t\tNodeSelector: map[string]string{\n602: \t\t\t\t\"node-type\": \"sandbox\",\n603: \t\t\t},\n604: \t\t},\n605: \t\tStatus: AgentRuntimeStatus{\n606: \t\t\tPhase:     AgentRuntimePhaseRunning,\n607: \t\t\tSandboxID: \"sandbox-abc123\",\n608: \t\t\tStartTime: &now,\n609: \t\t\tConditions: []AgentRuntimeCondition{\n610: \t\t\t\t{\n611: \t\t\t\t\tType:   AgentRuntimeConditionReady,\n612: \t\t\t\t\tStatus: corev1.ConditionTrue,\n613: \t\t\t\t},\n614: \t\t\t},\n615: \t\t},\n616: \t}\n617: \n618: \t// Test DeepCopy\n619: \tcopied := original.DeepCopy()\n620: \n621: \t// Ensure copied is not nil\n622: \tif copied == nil {\n623: \t\tt.Fatal(\"DeepCopy returned nil\")\n624: \t}\n625: \n626: \t// Verify basic fields are equal\n627: \tif copied.Name != original.Name {\n628: \t\tt.Errorf(\"Expected name '%s', got '%s'\", original.Name, copied.Name)\n629: \t}\n630: \n631: \tif copied.Spec.Image != original.Spec.Image {\n632: \t\tt.Errorf(\"Expected image '%s', got '%s'\", original.Spec.Image, copied.Spec.Image)\n633: \t}\n634: \n635: \t// Verify that slices are independent (modifying original doesn't affect copy)\n636: \toriginal.Labels[\"new-key\"] = \"new-value\"\n637: \tif _, exists := copied.Labels[\"new-key\"]; exists {\n638: \t\tt.Error(\"Labels should be independent between original and copy\")\n639: \t}\n640: \n641: \t// Modify original env\n642: \toriginal.Spec.Env[0].Value = \"modified\"\n643: \tif copied.Spec.Env[0].Value == \"modified\" {\n644: \t\tt.Error(\"Env should be independent between original and copy\")\n645: \t}\n646: \n647: \t// Modify original node selector\n648: \toriginal.Spec.NodeSelector[\"new-node\"] = \"true\"\n649: \tif _, exists := copied.Spec.NodeSelector[\"new-node\"]; exists {\n650: \t\tt.Error(\"NodeSelector should be independent between original and copy\")\n651: \t}\n652: \n653: \t// Modify original resources\n654: \toriginal.Spec.Resources.Limits[corev1.ResourceCPU] = resource.MustParse(\"2000m\")\n655: \tif copied.Spec.Resources.Limits.Cpu().MilliValue() == 2000 {\n656: \t\tt.Error(\"Resources should be independent between original and copy\")\n657: \t}\n658: \n659: \t// Test DeepCopyInto\n660: \tvar into AgentRuntime\n661: \toriginal.DeepCopyInto(&into)\n662: \n663: \tif into.Name != original.Name {\n664: \t\tt.Errorf(\"Expected name '%s', got '%s'\", original.Name, into.Name)\n665: \t}\n666: }\n667: \n668: func TestAgentRuntimeListDeepCopy(t *testing.T) {\n669: \toriginal := &AgentRuntimeList{\n670: \t\tTypeMeta: metav1.TypeMeta{\n671: \t\t\tAPIVersion: \"runtime.agentcube.volcano.sh/v1alpha1\",\n672: \t\t\tKind:       \"AgentRuntimeList\",\n673: \t\t},\n674: \t\tListMeta: metav1.ListMeta{\n675: \t\t\tResourceVersion: \"12345\",\n676: \t\t},\n677: \t\tItems: []AgentRuntime{\n678: \t\t\t{\n679: \t\t\t\tObjectMeta: metav1.ObjectMeta{\n680: \t\t\t\t\tName: \"runtime-1\",\n681: \t\t\t\t},\n682: \t\t\t\tSpec: AgentRuntimeSpec{\n683: \t\t\t\t\tImage: \"busybox:latest\",\n684: \t\t\t\t},\n685: \t\t\t},\n686: \t\t},\n687: \t}\n688: \n689: \tcopied := original.DeepCopy()\n690: \n691: \tif copied == nil {\n692: \t\tt.Fatal(\"DeepCopy returned nil\")\n693: \t}\n694: \n695: \tif len(copied.Items) != 1 {\n696: \t\tt.Fatalf(\"Expected 1 item, got %d\", len(copied.Items))\n697: \t}\n698: \n699: \t// Modify original\n700: \toriginal.Items[0].Name = \"modified\"\n701: \tif copied.Items[0].Name == \"modified\" {\n702: \t\tt.Error(\"Items should be independent between original and copy\")\n703: \t}\n704: \n705: \t// Test DeepCopyInto\n706: \tvar into AgentRuntimeList\n707: \toriginal.DeepCopyInto(&into)\n708: \n709: \tif into.ResourceVersion != original.ResourceVersion {\n710: \t\tt.Errorf(\"Expected resource version '%s', got '%s'\", original.ResourceVersion, into.ResourceVersion)\n711: \t}\n712: }\n713: \n714: func TestAgentRuntimeSpecDeepCopy(t *testing.T) {\n715: \toriginal := &AgentRuntimeSpec{\n716: \t\tImage: \"ubuntu:22.04\",\n717: \t\tResources: &corev1.ResourceRequirements{\n718: \t\t\tLimits: corev1.ResourceList{\n719: \t\t\t\tcorev1.ResourceCPU: resource.MustParse(\"1000m\"),\n720: \t\t\t},\n721: \t\t},\n722: \t\tEnv: []corev1.EnvVar{\n723: \t\t\t{Name: \"FOO\", Value: \"bar\"},\n724: \t\t},\n725: \t\tCommand: []string{\"/bin/bash\"},\n726: \t\tArgs:    []string{\"-c\", \"echo hello\"},\n727: \t\tNodeSelector: map[string]string{\n728: \t\t\t\"key\": \"value\",\n729: \t\t},\n730: \t}\n731: \n732: \tcopied := original.DeepCopy()\n733: \n734: \tif copied == nil {\n735: \t\tt.Fatal(\"DeepCopy returned nil\")\n736: \t}\n737: \n738: \tif copied.Image != original.Image {\n739: \t\tt.Errorf(\"Expected image '%s', got '%s'\", original.Image, copied.Image)\n740: \t}\n741: \n742: \t// Verify independence\n743: \toriginal.Resources.Limits[corev1.ResourceCPU] = resource.MustParse(\"2000m\")\n744: \tif copied.Resources.Limits.Cpu().MilliValue() == 2000 {\n745: \t\tt.Error(\"Resources should be independent\")\n746: \t}\n747: }\n748: \n749: func TestAgentRuntimeStatusDeepCopy(t *testing.T) {\n750: \tnow := metav1.NewTime(time.Now())\n751: \n752: \toriginal := &AgentRuntimeStatus{\n753: \t\tPhase:     AgentRuntimePhaseRunning,\n754: \t\tSandboxID: \"sandbox-abc123\",\n755: \t\tStartTime: &now,\n756: \t\tConditions: []AgentRuntimeCondition{\n757: \t\t\t{\n758: \t\t\t\tType:   AgentRuntimeConditionReady,\n759: \t\t\t\tStatus: corev1.ConditionTrue,\n760: \t\t\t},\n761: \t\t},\n762: \t}\n763: \n764: \tcopied := original.DeepCopy()\n765: \n766: \tif copied == nil {\n767: \t\tt.Fatal(\"DeepCopy returned nil\")\n768: \t}\n769: \n770: \tif copied.Phase != original.Phase {\n771: \t\tt.Errorf(\"Expected phase '%s', got '%s'\", original.Phase, copied.Phase)\n772: \t}\n773: \n774: \tif copied.SandboxID != original.SandboxID {\n775: \t\tt.Errorf(\"Expected sandboxId '%s', got '%s'\", original.SandboxID, copied.SandboxID)\n776: \t}\n777: \n778: \t// Verify independence\n779: \toriginal.Conditions[0].Type = AgentRuntimeConditionFailed\n780: \tif copied.Conditions[0].Type == AgentRuntimeConditionFailed {\n781: \t\tt.Error(\"Conditions should be independent\")\n782: \t}\n783: }\n784: \n785: func TestAgentRuntimeConditionDeepCopy(t *testing.T) {\n786: \toriginal := &AgentRuntimeCondition{\n787: \t\tType:   AgentRuntimeConditionReady,\n788: \t\tStatus: corev1.ConditionTrue,\n789: \t\tReason: \"AgentRuntimeReady\",\n790: \t}\n791: \n792: \tcopied := original.DeepCopy()\n793: \n794: \tif copied == nil {\n795: \t\tt.Fatal(\"DeepCopy returned nil\")\n796: \t}\n797: \n798: \tif copied.Type != original.Type {\n799: \t\tt.Errorf(\"Expected type '%s', got '%s'\", original.Type, copied.Type)\n800: \t}\n801: \n802: \tif copied.Status != original.Status {\n803: \t\tt.Errorf(\"Expected status '%s', got '%s'\", original.Status, copied.Status)\n804: \t}\n805: \n806: \tif copied.Reason != original.Reason {\n807: \t\tt.Errorf(\"Expected reason '%s', got '%s'\", original.Reason, copied.Reason)\n808: \t}\n809: }\n810: \n811: func TestAgentRuntimeJSONMarshal(t *testing.T) {\n812: \truntime := AgentRuntime{\n813: \t\tTypeMeta: metav1.TypeMeta{\n814: \t\t\tAPIVersion: \"runtime.agentcube.volcano.sh/v1alpha1\",\n815: \t\t\tKind:       \"AgentRuntime\",\n816: \t\t},\n817: \t\tObjectMeta: metav1.ObjectMeta{\n818: \t\t\tName:      \"test-runtime\",\n819: \t\t\tNamespace: \"default\",\n820: \t\t},\n821: \t\tSpec: AgentRuntimeSpec{\n822: \t\t\tImage: \"ubuntu:22.04\",\n823: \t\t},\n824: \t}\n825: \n826: \t// Marshal to JSON\n827: \tdata, err := json.Marshal(runtime)\n828: \tif err != nil {\n829: \t\tt.Fatalf(\"Failed to marshal AgentRuntime: %v\", err)\n830: \t}\n831: \n832: \t// Unmarshal back\n833: \tvar unmarshaled AgentRuntime\n834: \terr = json.Unmarshal(data, &unmarshaled)\n835: \tif err != nil {\n836: \t\tt.Fatalf(\"Failed to unmarshal AgentRuntime: %v\", err)\n837: \t}\n838: \n839: \t// Verify fields\n840: \tif unmarshaled.Name != runtime.Name {\n841: \t\tt.Errorf(\"Expected name '%s', got '%s'\", runtime.Name, unmarshaled.Name)\n842: \t}\n843: \n844: \tif unmarshaled.Spec.Image != runtime.Spec.Image {\n845: \t\tt.Errorf(\"Expected image '%s', got '%s'\", runtime.Spec.Image, unmarshaled.Spec.Image)\n846: \t}\n847: \n848: \t// Verify JSON uses camelCase\n849: \tjsonStr := string(data)\n850: \tif !contains(jsonStr, `\"image\"`) {\n851: \t\tt.Error(\"JSON should use camelCase 'image'\")\n852: \t}\n853: \tif !contains(jsonStr, `\"apiVersion\"`) {\n854: \t\tt.Error(\"JSON should use camelCase 'apiVersion'\")\n855: \t}\n856: }\n857: \n858: func TestAgentRuntimeListJSONMarshal(t *testing.T) {\n859: \tlist := AgentRuntimeList{\n860: \t\tTypeMeta: metav1.TypeMeta{\n861: \t\t\tAPIVersion: \"runtime.agentcube.volcano.sh/v1alpha1\",\n862: \t\t\tKind:       \"AgentRuntimeList\",\n863: \t\t},\n864: \t\tItems: []AgentRuntime{\n865: \t\t\t{\n866: \t\t\t\tObjectMeta: metav1.ObjectMeta{\n867: \t\t\t\t\tName: \"runtime-1\",\n868: \t\t\t\t},\n869: \t\t\t\tSpec: AgentRuntimeSpec{\n870: \t\t\t\t\tImage: \"busybox:latest\",\n871: \t\t\t\t},\n872: \t\t\t},\n873: \t\t},\n874: \t}\n875: \n876: \tdata, err := json.Marshal(list)\n877: \tif err != nil {\n878: \t\tt.Fatalf(\"Failed to marshal AgentRuntimeList: %v\", err)\n879: \t}\n880: \n881: \tvar unmarshaled AgentRuntimeList\n882: \terr = json.Unmarshal(data, &unmarshaled)\n883: \tif err != nil {\n884: \t\tt.Fatalf(\"Failed to unmarshal AgentRuntimeList: %v\", err)\n885: \t}\n886: \n887: \tif len(unmarshaled.Items) != 1 {\n888: \t\tt.Errorf(\"Expected 1 item, got %d\", len(unmarshaled.Items))\n889: \t}\n890: \n891: \tif unmarshaled.Items[0].Spec.Image != \"busybox:latest\" {\n892: \t\tt.Errorf(\"Expected image 'busybox:latest', got '%s'\", unmarshaled.Items[0].Spec.Image)\n893: \t}\n894: }\n895: \n896: func TestDeepCopyObject(t *testing.T) {\n897: \truntime := &AgentRuntime{\n898: \t\tTypeMeta: metav1.TypeMeta{\n899: \t\t\tAPIVersion: \"runtime.agentcube.volcano.sh/v1alpha1\",\n900: \t\t\tKind:       \"AgentRuntime\",\n901: \t\t},\n902: \t\tObjectMeta: metav1.ObjectMeta{\n903: \t\t\tName: \"test\",\n904: \t\t},\n905: \t\tSpec: AgentRuntimeSpec{\n906: \t\t\tImage: \"busybox:latest\",\n907: \t\t},\n908: \t}\n909: \n910: \tobj := runtime.DeepCopyObject()\n911: \tif obj == nil {\n912: \t\tt.Fatal(\"DeepCopyObject returned nil\")\n913: \t}\n914: \n915: \t// Verify it's the correct type\n916: \tcopiedRuntime, ok := obj.(*AgentRuntime)\n917: \tif !ok {\n918: \t\tt.Fatalf(\"DeepCopyObject returned wrong type: %T\", obj)\n919: \t}\n920: \n921: \tif copiedRuntime.Name != runtime.Name {\n922: \t\tt.Errorf(\"Expected name '%s', got '%s'\", runtime.Name, copiedRuntime.Name)\n923: \t}\n924: \n925: \t// Test with nil\n926: \tvar nilRuntime *AgentRuntime\n927: \tnilObj := nilRuntime.DeepCopyObject()\n928: \tif nilObj != nil {\n929: \t\tt.Error(\"DeepCopyObject of nil should return nil\")\n930: \t}\n931: \n932: \t// Test AgentRuntimeList\n933: \tlist := &AgentRuntimeList{\n934: \t\tItems: []AgentRuntime{\n935: \t\t\t{ObjectMeta: metav1.ObjectMeta{Name: \"test\"}},\n936: \t\t},\n937: \t}\n938: \tlistObj := list.DeepCopyObject()\n939: \tif listObj == nil {\n940: \t\tt.Fatal(\"DeepCopyObject returned nil for list\")\n941: \t}\n942: \n943: \tcopiedList, ok := listObj.(*AgentRuntimeList)\n944: \tif !ok {\n945: \t\tt.Fatalf(\"DeepCopyObject returned wrong type for list: %T\", listObj)\n946: \t}\n947: \n948: \tif len(copiedList.Items) != 1 {\n949: \t\tt.Errorf(\"Expected 1 item, got %d\", len(copiedList.Items))\n950: \t}\n951: \n952: \t// Test with nil list\n953: \tvar nilList *AgentRuntimeList\n954: \tnilListObj := nilList.DeepCopyObject()\n955: \tif nilListObj != nil {\n956: \t\tt.Error(\"DeepCopyObject of nil list should return nil\")\n957: \t}\n958: }\n959: \n960: func TestSchemeBuilder(t *testing.T) {\n961: \t// Verify SchemeBuilder is not nil\n962: \tif SchemeBuilder == nil {\n963: \t\tt.Error(\"SchemeBuilder should not be nil\")\n964: \t}\n965: \n966: \t// Verify AddToScheme is not nil\n967: \tif AddToScheme == nil {\n968: \t\tt.Error(\"AddToScheme should not be nil\")\n969: \t}\n970: \n971: \t// Verify SchemeGroupVersion\n972: \tif SchemeGroupVersion.Group != \"runtime.agentcube.volcano.sh\" {\n973: \t\tt.Errorf(\"Expected group 'runtime.agentcube.volcano.sh', got '%s'\", SchemeGroupVersion.Group)\n974: \t}\n975: \n976: \tif SchemeGroupVersion.Version != \"v1alpha1\" {\n977: \t\tt.Errorf(\"Expected version 'v1alpha1', got '%s'\", SchemeGroupVersion.Version)\n978: \t}\n979: }\n980: \n981: func TestResource(t *testing.T) {\n982: \tresource := Resource(\"agentruntimes\")\n983: \tif resource.Resource != \"agentruntimes\" {\n984: \t\tt.Errorf(\"Expected resource 'agentruntimes', got '%s'\", resource.Resource)\n985: \t}\n986: \tif resource.Group != \"runtime.agentcube.volcano.sh\" {\n987: \t\tt.Errorf(\"Expected group 'runtime.agentcube.volcano.sh', got '%s'\", resource.Group)\n988: \t}\n989: }\n990: \n991: // Helper function\n992: func int32Ptr(i int32) *int32 {\n993: \treturn &i\n994: }\n995: \n996: func contains(s, substr string) bool {\n997: \treturn len(s) >= len(substr) && (s == substr || len(s) > len(substr) && containsAt(s, substr))\n998: }\n999: \n1000: func containsAt(s, substr string) bool {\n1001: \tfor i := 0; i <= len(s)-len(substr); i++ {\n1002: \t\tif s[i:i+len(substr)] == substr {\n1003: \t\t\treturn true\n1004: \t\t}\n1005: \t}\n1006: \treturn false\n1007: }\n\n(End of file - total 1007 lines)\n</content>","metadata":{"preview":"/*\nCopyright 2026 The Volcano Authors.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\npackage v1alpha1\n\nimport (\n\t\"encoding/json\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/apis/runtime/v1alpha1/agentruntime_types_test.go","time":{"start":1775877060250,"end":1775877060302}}}}
