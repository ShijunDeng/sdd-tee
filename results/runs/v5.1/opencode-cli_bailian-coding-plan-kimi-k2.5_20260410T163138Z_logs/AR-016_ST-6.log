tring]string{\n649: \t\t\t\t\"key\": \"value\",\n650: \t\t\t},\n651: \t\t},\n652: \t\tSpec: CodeInterpreterSpec{\n653: \t\t\tPorts: []TargetPort{\n654: \t\t\t\t{\n655: \t\t\t\t\tName:     \"http\",\n656: \t\t\t\t\tPort:     8080,\n657: \t\t\t\t\tProtocol: ProtocolHTTP,\n658: \t\t\t\t},\n659: \t\t\t},\n660: \t\t\tTemplate: &CodeInterpreterSandboxTemplate{\n661: \t\t\t\tLabels: map[string]string{\n662: \t\t\t\t\t\"app\": \"code-interpreter\",\n663: \t\t\t\t},\n664: \t\t\t\tSpec: corev1.PodSpec{\n665: \t\t\t\t\tContainers: []corev1.Container{\n666: \t\t\t\t\t\t{\n667: \t\t\t\t\t\t\tName:  \"code-interpreter\",\n668: \t\t\t\t\t\t\tImage: \"python:3.11\",\n669: \t\t\t\t\t\t},\n670: \t\t\t\t\t},\n671: \t\t\t\t},\n672: \t\t\t},\n673: \t\t\tSessionTimeout: &duration15m,\n674: \t\t\tWarmPoolSize:   int32Ptr(5),\n675: \t\t\tAuthMode:       AuthModePicoD,\n676: \t\t},\n677: \t\tStatus: CodeInterpreterStatus{\n678: \t\t\tReady: boolPtr(true),\n679: \t\t\tConditions: []CodeInterpreterCondition{\n680: \t\t\t\t{\n681: \t\t\t\t\tType:   CodeInterpreterConditionReady,\n682: \t\t\t\t\tStatus: corev1.ConditionTrue,\n683: \t\t\t\t\tLastTransitionTime: metav1.Time{\n684: \t\t\t\t\t\tTime: now.Time,\n685: \t\t\t\t\t},\n686: \t\t\t\t},\n687: \t\t\t},\n688: \t\t},\n689: \t}\n690: \n691: \t// Test DeepCopy\n692: \tcopied := original.DeepCopy()\n693: \n694: \t// Ensure copied is not nil\n695: \tif copied == nil {\n696: \t\tt.Fatal(\"DeepCopy returned nil\")\n697: \t}\n698: \n699: \t// Verify basic fields are equal\n700: \tif copied.Name != original.Name {\n701: \t\tt.Errorf(\"Expected name '%s', got '%s'\", original.Name, copied.Name)\n702: \t}\n703: \n704: \tif copied.Spec.AuthMode != original.Spec.AuthMode {\n705: \t\tt.Errorf(\"Expected auth mode '%s', got '%s'\", original.Spec.AuthMode, copied.Spec.AuthMode)\n706: \t}\n707: \n708: \t// Verify that slices are independent (modifying original doesn't affect copy)\n709: \toriginal.Labels[\"new-key\"] = \"new-value\"\n710: \tif _, exists := copied.Labels[\"new-key\"]; exists {\n711: \t\tt.Error(\"Labels should be independent between original and copy\")\n712: \t}\n713: \n714: \t// Modify original ports\n715: \toriginal.Spec.Ports[0].Port = 9090\n716: \tif copied.Spec.Ports[0].Port == 9090 {\n717: \t\tt.Error(\"Ports should be independent between original and copy\")\n718: \t}\n719: \n720: \t// Modify original template labels\n721: \toriginal.Spec.Template.Labels[\"new-label\"] = \"value\"\n722: \tif _, exists := copied.Spec.Template.Labels[\"new-label\"]; exists {\n723: \t\tt.Error(\"Template labels should be independent between original and copy\")\n724: \t}\n725: \n726: \t// Modify original session timeout\n727: \toriginal.Spec.SessionTimeout.Duration = 30 * time.Minute\n728: \tif copied.Spec.SessionTimeout.Duration == 30*time.Minute {\n729: \t\tt.Error(\"SessionTimeout should be independent between original and copy\")\n730: \t}\n731: \n732: \t// Modify original warm pool size\n733: \t*original.Spec.WarmPoolSize = 10\n734: \tif *copied.Spec.WarmPoolSize == 10 {\n735: \t\tt.Error(\"WarmPoolSize should be independent between original and copy\")\n736: \t}\n737: \n738: \t// Modify original conditions\n739: \toriginal.Status.Conditions[0].Type = CodeInterpreterConditionFailed\n740: \tif copied.Status.Conditions[0].Type == CodeInterpreterConditionFailed {\n741: \t\tt.Error(\"Conditions should be independent between original and copy\")\n742: \t}\n743: \n744: \t// Modify original ready\n745: \t*original.Status.Ready = false\n746: \tif *copied.Status.Ready == false {\n747: \t\tt.Error(\"Ready should be independent between original and copy\")\n748: \t}\n749: \n750: \t// Test DeepCopyInto\n751: \tvar into CodeInterpreter\n752: \toriginal.DeepCopyInto(&into)\n753: \n754: \tif into.Name != original.Name {\n755: \t\tt.Errorf(\"Expected name '%s', got '%s'\", original.Name, into.Name)\n756: \t}\n757: }\n758: \n759: func TestCodeInterpreterListDeepCopy(t *testing.T) {\n760: \toriginal := &CodeInterpreterList{\n761: \t\tTypeMeta: metav1.TypeMeta{\n762: \t\t\tAPIVersion: \"runtime.agentcube.volcano.sh/v1alpha1\",\n763: \t\t\tKind:       \"CodeInterpreterList\",\n764: \t\t},\n765: \t\tListMeta: metav1.ListMeta{\n766: \t\t\tResourceVersion: \"12345\",\n767: \t\t},\n768: \t\tItems: []CodeInterpreter{\n769: \t\t\t{\n770: \t\t\t\tObjectMeta: metav1.ObjectMeta{\n771: \t\t\t\t\tName: \"ci-1\",\n772: \t\t\t\t},\n773: \t\t\t\tSpec: CodeInterpreterSpec{\n774: \t\t\t\t\tTemplate: &CodeInterpreterSandboxTemplate{\n775: \t\t\t\t\t\tSpec: corev1.PodSpec{\n776: \t\t\t\t\t\t\tContainers: []corev1.Container{\n777: \t\t\t\t\t\t\t\t{\n778: \t\t\t\t\t\t\t\t\tName:  \"code-interpreter\",\n779: \t\t\t\t\t\t\t\t\tImage: \"python:3.11\",\n780: \t\t\t\t\t\t\t\t},\n781: \t\t\t\t\t\t\t},\n782: \t\t\t\t\t\t},\n783: \t\t\t\t\t},\n784: \t\t\t\t},\n785: \t\t\t},\n786: \t\t},\n787: \t}\n788: \n789: \tcopied := original.DeepCopy()\n790: \n791: \tif copied == nil {\n792: \t\tt.Fatal(\"DeepCopy returned nil\")\n793: \t}\n794: \n795: \tif len(copied.Items) != 1 {\n796: \t\tt.Fatalf(\"Expected 1 item, got %d\", len(copied.Items))\n797: \t}\n798: \n799: \t// Modify original\n800: \toriginal.Items[0].Name = \"modified\"\n801: \tif copied.Items[0].Name == \"modified\" {\n802: \t\tt.Error(\"Items should be independent between original and copy\")\n803: \t}\n804: \n805: \t// Test DeepCopyInto\n806: \tvar into CodeInterpreterList\n807: \toriginal.DeepCopyInto(&into)\n808: \n809: \tif into.ResourceVersion != original.ResourceVersion {\n810: \t\tt.Errorf(\"Expected resource version '%s', got '%s'\", original.ResourceVersion, into.ResourceVersion)\n811: \t}\n812: }\n813: \n814: func TestCodeInterpreterSpecDeepCopy(t *testing.T) {\n815: \tduration15m := metav1.Duration{Duration: 15 * time.Minute}\n816: \tduration8h := metav1.Duration{Duration: 8 * time.Hour}\n817: \n818: \toriginal := &CodeInterpreterSpec{\n819: \t\tPorts: []TargetPort{\n820: \t\t\t{\n821: \t\t\t\tName:     \"http\",\n822: \t\t\t\tPort:     8080,\n823: \t