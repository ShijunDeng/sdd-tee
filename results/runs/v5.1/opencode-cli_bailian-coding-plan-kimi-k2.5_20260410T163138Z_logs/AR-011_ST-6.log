t\treturn err\n47: \t}\n48: \tns := meta.GetNamespace()\n49: \tname := meta.GetName()\n50: \tif s.objects[ns] == nil {\n51: \t\ts.objects[ns] = make(map[string]runtime.Object)\n52: \t}\n53: \tif _, exists := s.objects[ns][name]; exists {\n54: \t\treturn apierrors.NewAlreadyExists(s.gvr.GroupResource(), name)\n55: \t}\n56: \ts.objects[ns][name] = obj\n57: \treturn nil\n58: }\n59: \n60: func (s *ObjectStore) Update(obj runtime.Object) error {\n61: \ts.mu.Lock()\n62: \tdefer s.mu.Unlock()\n63: \tmeta, err := metaAccessor(obj)\n64: \tif err != nil {\n65: \t\treturn err\n66: \t}\n67: \tns := meta.GetNamespace()\n68: \tname := meta.GetName()\n69: \tif s.objects[ns] == nil {\n70: \t\treturn apierrors.NewNotFound(s.gvr.GroupResource(), name)\n71: \t}\n72: \tif _, exists := s.objects[ns][name]; !exists {\n73: \t\treturn apierrors.NewNotFound(s.gvr.GroupResource(), name)\n74: \t}\n75: \ts.objects[ns][name] = obj\n76: \treturn nil\n77: }\n78: \n79: func (s *ObjectStore) Delete(namespace, name string) error {\n80: \ts.mu.Lock()\n81: \tdefer s.mu.Unlock()\n82: \tns, ok := s.objects[namespace]\n83: \tif !ok {\n84: \t\treturn apierrors.NewNotFound(s.gvr.GroupResource(), name)\n85: \t}\n86: \tif _, exists := ns[name]; !exists {\n87: \t\treturn apierrors.NewNotFound(s.gvr.GroupResource(), name)\n88: \t}\n89: \tdelete(ns, name)\n90: \tif len(ns) == 0 {\n91: \t\tdelete(s.objects, namespace)\n92: \t}\n93: \treturn nil\n94: }\n95: \n96: func (s *ObjectStore) List(namespace string) []runtime.Object {\n97: \ts.mu.RLock()\n98: \tdefer s.mu.RUnlock()\n99: \tns, ok := s.objects[namespace]\n100: \tif !ok {\n101: \t\treturn nil\n102: \t}\n103: \tresult := make([]runtime.Object, 0, len(ns))\n104: \tfor _, obj := range ns {\n105: \t\tresult = append(result, obj.DeepCopyObject())\n106: \t}\n107: \treturn result\n108: }\n109: \n110: func metaAccessor(obj runtime.Object) (metav1.Object, error) {\n111: \tmeta, ok := obj.(metav1.Object)\n112: \tif !ok {\n113: \t\treturn nil, fmt.Errorf(\"object does not implement metav1.Object\")\n114: \t}\n115: \treturn meta, nil\n116: }\n117: \n118: type AgentRuntimeClient struct {\n119: \tstore *ObjectStore\n120: \tns    string\n121: }\n122: \n123: func NewAgentRuntimeClient(store *ObjectStore, namespace string) *AgentRuntimeClient {\n124: \treturn &AgentRuntimeClient{store: store, ns: namespace}\n125: }\n126: \n127: func (c *AgentRuntimeClient) Create(ctx context.Context, ar *v1alpha1.AgentRuntime, opts metav1.CreateOptions) (*v1alpha1.AgentRuntime, error) {\n128: \tobj := ar.DeepCopy()\n129: \tif err := c.store.Create(obj); err != nil {\n130: \t\treturn nil, err\n131: \t}\n132: \treturn obj, nil\n133: }\n134: \n135: func (c *AgentRuntimeClient) Update(ctx context.Context, ar *v1alpha1.AgentRuntime, opts metav1.UpdateOptions) (*v1alpha1.AgentRuntime, error) {\n136: \tobj := ar.DeepCopy()\n137: \tif err := c.store.Update(obj); err != nil {\n138: \t\treturn nil, err\n139: \t}\n140: \treturn obj, nil\n141: }\n142: \n143: func (c *AgentRuntimeClient) UpdateStatus(ctx context.Context, ar *v1alpha1.AgentRuntime, opts metav1.UpdateOptions) (*v1alpha1.AgentRuntime, error) {\n144: \treturn c.Update(ctx, ar, opts)\n145: }\n146: \n147: func (c *AgentRuntimeClient) Delete(ctx context.Context, name string, opts metav1.DeleteOptions) error {\n148: \treturn c.store.Delete(c.ns, name)\n149: }\n150: \n151: func (c *AgentRuntimeClient) Get(ctx context.Context, name string, opts metav1.GetOptions) (*v1alpha1.AgentRuntime, error) {\n152: \tobj, ok := c.store.Get(c.ns, name)\n153: \tif !ok {\n154: \t\treturn nil, apierrors.NewNotFound(v1alpha1.SchemeGroupVersion.WithResource(\"agentruntimes\").GroupResource(), name)\n155: \t}\n156: \treturn obj.(*v1alpha1.AgentRuntime).DeepCopy(), nil\n157: }\n158: \n159: func (c *AgentRuntimeClient) List(ctx context.Context, opts metav1.ListOptions) (*v1alpha1.AgentRuntimeList, error) {\n160: \titems := c.store.List(c.ns)\n161: \tresult := &v1alpha1.AgentRuntimeList{\n162: \t\tItems: make([]v1alpha1.AgentRunti