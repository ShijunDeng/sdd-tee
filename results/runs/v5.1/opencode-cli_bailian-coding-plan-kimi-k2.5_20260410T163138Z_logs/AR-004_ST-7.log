!= nil {\n41: \t\t// Fallback to timestamp-based ID if crypto/rand fails\n42: \t\treturn fmt.Sprintf(\"req-%d\", time.Now().UnixNano())\n43: \t}\n44: \treturn hex.EncodeToString(b)\n45: }\n46: \n47: // RequestIDMiddleware generates or propagates request IDs.\n48: func RequestIDMiddleware() Middleware {\n49: \treturn func(next http.Handler) http.Handler {\n50: \t\treturn http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n51: \t\t\trequestID := r.Header.Get(RequestIDHeader)\n52: \t\t\tif requestID == \"\" {\n53: \t\t\t\trequestID = generateRequestID()\n54: \t\t\t}\n55: \n56: \t\t\t// Store in context\n57: \t\t\tctx := context.WithValue(r.Context(), requestIDKey, requestID)\n58: \n59: \t\t\t// Set response header\n60: \t\t\tw.Header().Set(RequestIDHeader, requestID)\n61: \n62: \t\t\tnext.ServeHTTP(w, r.WithContext(ctx))\n63: \t\t})\n64: \t}\n65: }\n66: \n67: // GetRequestID retrieves the request ID from the request context.\n68: func GetRequestID(r *http.Request) string {\n69: \tif requestID, ok := r.Context().Value(requestIDKey).(string); ok {\n70: \t\treturn requestID\n71: \t}\n72: \treturn \"\"\n73: }\n\n(End of file - total 73 lines)\n</content>","metadata":{"preview":"/*\nCopyright 2026 The Volcano Authors.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\npackage middleware\n\nimport (\n\t\"context\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/workloadmanager/server/middleware/requesti