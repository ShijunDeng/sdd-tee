n {\n41: \t\trw.statusCode = code\n42: \t\trw.written = true\n43: \t\trw.ResponseWriter.WriteHeader(code)\n44: \t}\n45: }\n46: \n47: // Write captures the status code if not already written.\n48: func (rw *responseWriter) Write(b []byte) (int, error) {\n49: \tif !rw.written {\n50: \t\trw.statusCode = http.StatusOK\n51: \t\trw.written = true\n52: \t}\n53: \treturn rw.ResponseWriter.Write(b)\n54: }\n55: \n56: // LoggingMiddleware logs HTTP requests.\n57: func LoggingMiddleware(logger Logger) Middleware {\n58: \treturn func(next http.Handler) http.Handler {\n59: \t\treturn http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n60: \t\t\tstart := time.Now()\n61: \t\t\trequestID := GetRequestID(r)\n62: \n63: \t\t\t// Log request start\n64: \t\t\tlogger.Info(\"request started\",\n65: \t\t\t\t\"request_id\", requestID,\n66: \t\t\t\t\"method\", r.Method,\n67: \t\t\t\t\"path\", r.URL.Path,\n68: \t\t\t\t\"remote_addr\", r.RemoteAddr,\n69: \t\t\t)\n70: \n71: \t\t\t// Wrap response writer to capture status code\n72: \t\t\twrapped := &responseWriter{ResponseWriter: w, statusCode: http.StatusOK}\n73: \n74: \t\t\t// Call next handler\n75: \t\t\tnext.ServeHTTP(wrapped, r)\n76: \n77: \t\t\t// Log request completion\n78: \t\t\tduration := time.Since(start)\n79: \t\t\tlogger.Info(\"request completed\",\n80: \t\t\t\t\"request_id\", requestID,\n81: \t\t\t\t\"method\", r.Method,\n82: \t\t\t\t\"path\", r.URL.Path,\n83: \t\t\t\t\"status\", wrapped.statusCode,\n84: \t\t\t\t\"duration_ms\", duration.Milliseconds(),\n85: \t\t\t)\n86: \t\t})\n87: \t}\n88: }\n\n(End of file - total 88 lines)\n</content>","metadata":{"preview":"/*\nCopyright 2026 The Volcano Authors.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\npackage middleware\n\nimport (\n\t\"net/http\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/workloadmanager/server/middleware/logging.go","time":{"start":1775845590674,"end":1775845590699}}}}
