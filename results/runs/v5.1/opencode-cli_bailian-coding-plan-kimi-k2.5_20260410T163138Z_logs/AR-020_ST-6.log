{"type":"tool_use","timestamp":1775886106674,"sessionID":"ses_284f0e7efffeoJNYQHs4CBnkUX","part":{"id":"prt_d7b0f752f001ASHK7s6276dDK3","messageID":"msg_d7b0f5c75001pvzT8TbTKYqF9w","sessionID":"ses_284f0e7efffeoJNYQHs4CBnkUX","type":"tool","tool":"read","callID":"toolu_functions.read:8","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/agentcube/services/metadata_service.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/agentcube/services/metadata_service.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Metadata service for AgentCube CLI.\n2: \n3: This module provides the AgentMetadata Pydantic model and MetadataService\n4: for loading, saving, and validating agent metadata.\n5: \"\"\"\n6: \n7: import logging\n8: from pathlib import Path\n9: from typing import Any, Dict, Optional\n10: \n11: import yaml\n12: from pydantic import BaseModel, Field, field_validator\n13: \n14: from agentcube.utils.log import get_logger\n15: \n16: \n17: class AgentMetadata(BaseModel):\n18:     \"\"\"Core metadata model for agent configuration.\n19: \n20:     This model represents the configuration and metadata for an AgentCube agent,\n21:     including language settings, entrypoint, port, build mode, and various\n22:     optional configuration fields.\n23:     \"\"\"\n24: \n25:     agent_name: str = Field(..., description=\"Unique name identifying the agent\")\n26:     description: Optional[str] = Field(None, description=\"Human-readable summary\")\n27:     language: str = Field(default=\"python\", description=\"Programming language used\")\n28:     entrypoint: str = Field(..., description=\"Command to launch the agent\")\n29:     port: int = Field(default=8080, description=\"Port exposed by the agent runtime\")\n30:     build_mode: str = Field(default=\"local\", description=\"Build strategy: local or cloud\")\n31:     region: Optional[str] = Field(None, description=\"Deployment region\")\n32:     version: Optional[str] = Field(None, description=\"Semantic version string for publishing\")\n33:     image: Optional[Dict[str, Any]] = Field(None, description=\"Container image information\")\n34:     auth: Optional[Dict[str, Any]] = Field(None, description=\"Authentication configuration\")\n35:     requirements_file: Optional[str] = Field(\n36:         default=\"requirements.txt\", description=\"Python dependency file\"\n37:     )\n38:     registry_url: Optional[str] = Field(default=\"\", description=\"Registry URL for image publishing\")\n39:     registry_username: Optional[str] = Field(default=\"\", description=\"Registry username\")\n40:     registry_password: Optional[str] = Field(default=\"\", description=\"Registry password\")\n41:     agent_endpoint: Optional[str] = Field(None, description=\"Agent endpoint URL\")\n42:     workload_manager_url: Optional[str] = Field(None, description=\"URL for the Workload Manager\")\n43:     router_url: Optional[str] = Field(None, description=\"URL for the Router\")\n44:     readiness_probe_path: Optional[str] = Field(None, description=\"Path for the readiness probe\")\n45:     readiness_probe_port: Optional[int] = Field(None, description=\"Port for the readiness probe\")\n46:     agent_id: Optional[str] = Field(None, description=\"Agent ID assigned by AgentCube\")\n47:     session_id: Optional[str] = Field(None, description=\"The session ID for the agent\")\n48:     k8s_deployment: Optional[Dict[str, Any]] = Field(\n49:         None, description=\"Kubernetes deployment information\"\n50:     )\n51:     pack_timestamp: Optional[str] = Field(None, description=\"ISO timestamp of pack operation\")\n52:     dockerfile_generated: Optional[bool] = Field(\n53:         None, description=\"Whether Dockerfile was generated\"\n54:     )\n55: \n56:     @field_validator(\"language\")\n57:     @classmethod\n58:     def validate_language(cls, v: str) -> str:\n59:         \"\"\"Validate and normalize language.\n60: \n61:         Args:\n62:             v: The language string to validate.\n63: \n64:         Returns:\n65:             The normalized (lowercase) language string.\n66: \n67:         Raises:\n68:             ValueError: If the language is not 'python' or 'java'.\n69:         \"\"\"\n70:         v = v.lower()\n71:         if v not in (\"python\", \"java\"):\n72:             raise ValueError(f\"Unsupported language: {v}. Must be 'python' or 'java'\")\n73:         return v\n74: \n75:     @field_validator(\"build_mode\")\n76:     @classmethod\n77:     def validate_build_mode(cls, v: str) -> str:\n78:         \"\"\"Validate and normalize build_mode.\n79: \n80:         Args:\n81:             v: The build_mode string to validate.\n82: \n83:         Returns:\n84:             The normalized (lowercase) build_mode string.\n85: \n86:         Raises:\n87:             ValueError: If the build_mode is not 'local' or 'cloud'.\n88:         \"\"\"\n89:         v = v.lower()\n90:         if v not in (\"local\", \"cloud\"):\n91:             raise ValueError(f\"Unsupported build_mode: {v}. Must be 'local' or 'cloud'\")\n92:         return v\n93: \n94:     @field_validator(\"port\")\n95:     @classmethod\n96:     def validate_port(cls, v: int) -> int:\n97:         \"\"\"Validate port number.\n98: \n99:         Args:\n100:             v: The port number to validate.\n101: \n102:         Returns:\n103:             The validated port number.\n104: \n105:         Raises:\n106:             ValueError: If the port is not between 1 and 65535.\n107:         \"\"\"\n108:         if not 1 <= v <= 65535:\n109:             raise ValueError(f\"Invalid port: {v}. Must be between 1 and 65535\")\n110:         return v\n111: \n112: \n113: class MetadataService:\n114:     \"\"\"Service for loading, saving, and validating agent metadata.\"\"\"\n115: \n116:     def __init__(self, verbose: bool = False) -> None:\n117:         \"\"\"Initialize MetadataService.\n118: \n119:         Args:\n120:             verbose: Whether to enable verbose logging.\n121:         \"\"\"\n122:         self.verbose = verbose\n123:         self.logger = get_logger(__name__)\n124: \n125:     def load_metadata(self, workspace_path: Path) -> AgentMetadata:\n126:         \"\"\"Load metadata from workspace.\n127: \n128:         Loading precedence:\n129:         1. agent_metadata.yaml\n130:         2. agent.yaml\n131:         3. metadata.yaml\n132: \n133:         Args:\n134:             workspace_path: Path to the agent workspace directory.\n135: \n136:         Returns:\n137:             The loaded AgentMetadata instance.\n138: \n139:         Raises:\n140:             FileNotFoundError: If no metadata file exists.\n141:         \"\"\"\n142:         for filename in [\"agent_metadata.yaml\", \"agent.yaml\", \"metadata.yaml\"]:\n143:             filepath = workspace_path / filename\n144:             if filepath.exists():\n145:                 self.logger.debug(f\"Loading metadata from {filepath}\")\n146:                 data = yaml.safe_load(filepath.read_text())\n147:                 return AgentMetadata.model_validate(data)\n148: \n149:         raise FileNotFoundError(f\"No metadata file found in {workspace_path}\")\n150: \n151:     def save_metadata(self, workspace_path: Path, metadata: AgentMetadata) -> None:\n152:         \"\"\"Save metadata to workspace.\n153: \n154:         Always writes to agent_metadata.yaml with:\n155:         - default_flow_style=False\n156:         - indent=2\n157:         - sort_keys=False\n158:         - exclude_none=True\n159: \n160:         Args:\n161:             workspace_path: Path to the agent workspace directory.\n162:             metadata: The AgentMetadata instance to save.\n163:         \"\"\"\n164:         filepath = workspace_path / \"agent_metadata.yaml\"\n165:         data = metadata.model_dump(exclude_none=True)\n166:         with filepath.open(\"w\") as f:\n167:             yaml.dump(\n168:                 data,\n169:                 f,\n170:                 default_flow_style=False,\n171:                 indent=2,\n172:                 sort_keys=False,\n173:             )\n174:         self.logger.debug(f\"Saved metadata to {filepath}\")\n175: \n176:     def update_metadata(self, workspace_path: Path, updates: Dict[str, Any]) -> AgentMetadata:\n177:         \"\"\"Load, update, and save metadata.\n178: \n179:         Args:\n180:             workspace_path: Path to the agent workspace directory.\n181:             updates: Dictionary of field updates to apply.\n182: \n183:         Returns:\n184:             The updated AgentMetadata instance.\n185:         \"\"\"\n186:         metadata = self.load_metadata(workspace_path)\n187:         for key, value in updates.items():\n188:             setattr(metadata, key, value)\n189:         self.save_metadata(workspace_path, metadata)\n190:         return metadata\n191: \n192:     def validate_workspace(self, workspace_path: Path, metadata: AgentMetadata) -> bool:\n193:         \"\"\"Validate workspace contents match metadata.\n194: \n195:         Args:\n196:             workspace_path: Path to the agent workspace directory.\n197:             metadata: The AgentMetadata instance to validate against.\n198: \n199:         Returns:\n200:             True if validation passes.\n201: \n202:         Raises:\n203:             ValueError: If validation fails.\n204:         \"\"\"\n205:         if metadata.language == \"python\":\n206:             self._validate_python_workspace(workspace_path, metadata)\n207:         elif metadata.language == \"java\":\n208:             self._validate_java_workspace(workspace_path, metadata)\n209:         return True\n210: \n211:     def _validate_python_workspace(self, workspace_path: Path, metadata: AgentMetadata) -> None:\n212:         \"\"\"Python-specific validation.\n213: \n214:         Args:\n215:             workspace_path: Path to the agent workspace directory.\n216:             metadata: The AgentMetadata instance.\n217: \n218:         Raises:\n219:             ValueError: If no Python files found in workspace.\n220:         \"\"\"\n221:         if not list(workspace_path.glob(\"*.py\")):\n222:             raise ValueError(\"No Python files found in workspace\")\n223: \n224:     def _validate_java_workspace(self, workspace_path: Path, metadata: AgentMetadata) -> None:\n225:         \"\"\"Java-specific validation.\n226: \n227:         Args:\n228:             workspace_path: Path to the agent workspace directory.\n229:             metadata: The AgentMetadata instance.\n230: \n231:         Raises:\n232:             ValueError: If pom.xml not found in workspace.\n233:         \"\"\"\n234:         if not (workspace_path / \"pom.xml\").exists():\n235:             raise ValueError(\"No pom.xml found in workspace\")\n\n(End of file - total 235 lines)\n</content>","metadata":{"preview":"\"\"\"Metadata service for AgentCube CLI.\n\nThis module provides the AgentMetadata Pydantic model and MetadataService\nfor loading, saving, and validating agent metadata.\n\"\"\"\n\nimport logging\nfrom pathlib import Path\nfrom typing import Any, Dict, Optional\n\nimport yaml\nfrom pydantic import BaseModel, Field, field_validator\n\nfrom agentcube.utils.log import get_logger\n\n\nclass AgentMetadata(BaseModel):\n    \"\"\"Core metadata model for agent configuration.\n\n    This model represents the configuration and metadata for an AgentCube agent,","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/agentcube/services/metadata_service.py","time":{"start":1775886106654,"end":1775886106673}}}}
