 the data plane client.\n43: \n44:         Args:\n45:             session_id: The session ID for header injection.\n46:             base_url: The data plane base URL.\n47:             timeout: Read timeout in seconds (default: 120).\n48:             connect_timeout: Connect timeout in seconds (default: 5.0).\n49:         \"\"\"\n50:         self.session_id = session_id\n51:         self.base_url = base_url\n52:         self.timeout = timeout\n53:         self.connect_timeout = connect_timeout\n54: \n55:         # Create HTTP session with session header\n56:         self.session = create_session()\n57:         self.session.headers[\"x-agentcube-session-id\"] = session_id\n58: \n59:     def _request(\n60:         self,\n61:         method: str,\n62:         path: str,\n63:         **kwargs,\n64:     ) -> requests.Response:\n65:         \"\"\"Make an HTTP request to the data plane.\n66: \n67:         Args:\n68:             method: HTTP method.\n69:             path: URL path (will be joined with base_url).\n70:             **kwargs: Additional arguments for requests.\n71: \n72:         Returns:\n73:             The HTTP response.\n74:         \"\"\"\n75:         url = urljoin(self.base_url, path)\n76:         timeout = kwargs.pop(\"timeout\", (self.connect_timeout, self.timeout))\n77:         return self.session.request(method, url, timeout=timeout, **kwargs)\n78: \n79:     def execute_command(\n80:         self,\n81:         command: List[str],\n82:         timeout: Optional[int] = None,\n83:     ) -> Dict[str, Any]:\n84:         \"\"\"Execute a command in the Code Interpreter.\n85: \n86:         Args:\n87:             command: Command as a list of strings.\n88:             timeout: Command timeout in seconds (default: self.timeout).\n89: \n90:         Returns:\n91:             Dictionary with stdout, stderr, and exit_code.\n92: \n93:         Raises:\n94:             CommandExecutionError: If the command returns non-zero exit code.\n95:             requests.RequestException: If the HTTP request fails.\n96:         \"\"\"\n97:         effective_timeout = timeout if timeout is not None else self.timeout\n98: \n99:         # Build timeout string for PicoD (e.g., \"60s\")\n100:         timeout_str = f\"{effective_timeout}s\"\n101: \n102:         # Read timeout should be command timeout + 2.0 seconds buffer\n103:         # to avoid ReadTimeout before PicoD returns exit 124\n104:         read_timeout = effective_timeout + 2.0\n105: \n106:         payload = {\n107:             \"command\": command,\n108:             \"timeout\": timeout_str,\n109:         }\n110: \n111:         response = self._request(\n112:             \"POST\",\n113:             \"api/execute\",\n114:             json=payload,\n115:             timeout=(self.connect_timeout, read_timeout),\n116:         )\n117:         response.raise_for_status()\n118: \n119:         data = response.json()\n120:         exit_code = data.get(\"exit_code\", 0)\n121: \n122:         if exit_code != 0:\n123:             raise CommandExecutionError(\n124:                 exit_code=exit_code,\n125:                 stderr=data.get(\"stderr\", \"\"),\n126:                 command=\" \".join(command),\n127:             )\n128: \n129:         return data\n130: \n131:     def write_file(\n132:         self,\n133:         path: str,\n134:         content: Union[str, bytes],\n135:         mode: str = \"0644\",\n136:     ) -> None:\n137:         \"\"\"Write a file to the Code Interpreter.\n138: \n139:         Args:\n140:             path: Remote file path.\n141:             content: File content as string or bytes.\n142:             mode: File permissions as octal string (default: \"0644\").\n143: \n144:         Raises:\n145:             requests.RequestException: If the HTTP request fails.\n146:         \"\"\"\n147:         # Encode content as base64\n148:         if isinstance(content, str):\n149:             content_bytes = content.encode(\"utf-8\")\n150:         else:\n151:             content_bytes = content\n152: \n153:         encoded_content = base64.b64encode(content_bytes).decode(\"ascii\")\n154: \n155:         payload = {\n156:             \"path\": path,\n157:             \"content\": encoded_content,\n158:             \"mode\": mode,\n159:         }\n160: \n161:         response = self._request(\"POST\", \"api/files\", json=payload)\n162:         response.raise_for_status()\n163: \n164:     def upload_file(\n165:         self,\n166:         path: str,\n167:         content: Union[str, bytes, os.PathLike],\n168:         mode: str = \"0644\",\n169:     ) -> None:\n170:         \"\"\"Upload a file to the Code Interpreter via multipart.\n171: \n172:         Args:\n173:             path: Remote file path.\n174:             content: File content as string, bytes, or path to local file.\n175:             mode: File permissions as octal string (default: \"0644\").\n176: \n177:         Raises:\n178:             requests.RequestException: If the HTTP request fails.\n179:             IOError: If reading from a file path fails.\n180:         \"\"\"\n181:         # Read content if it's a path\n182:         if isinstance(content, (str, os.PathLike)) and os.path.isfile(content):\n183:             with open(content, \"rb\") as f:\n184:                 file_content = f.read()\n185:             filename = os.path.basename(content)\n186:         elif isinstance(content, str):\n187:             file_content = content.encode(\"utf-8\")\n188:             filename = os.path.basename(path)\n189:         else:\n190:             file_content = content\n191:             filename = os.path.basename(path)\n192: \n193:         files = {\n194:             \"file\": (filename, file_content),\n195:         }\n196:         data = {\n197:             \"path\": path,\n198:             \"mode\": mode,\n199:         }\n200: \n201:         # Explicitly set session header for multipart uploads\n202:         headers = {\n203:             \"x-agentcube-session-id\": self.session_id,\n204:         }\n205: \n206:         response = self._request(\n207:             \"POST\",\n208:             \"api/files\",\n209:             files=files,\n210:             data=data,\n211:             headers=headers,\n212:         )\n213:         response.raise_for_status()\n214: \n215:     def download_file(self, remote_path: str) -> bytes:\n216:         \"\"\"Download a file from the Code Interpreter.\n217: \n218:         Args:\n219:             remote_path: Remote file path.\n220: \n221:         Returns:\n222:             File content as bytes.\n223: \n224:         Raises:\n225:             requests.RequestException: If the HTTP request fails.\n226:         \"\"\"\n227:         # Clean path by removing leading slash\n228:         clean_path = remote_path.lstrip(\"/\")\n229:         url = f\"api/files/{clean_path}\"\n230: \n231:         response = self._request(\"GET\", url, stream=True)\n232:         response.raise_for_status()\n233: \n234:         return response.content\n235: \n236:     def list_files(self, path: str = \"/\") -> List[Dict[str, Any]]:\n237:         \"\"\"List files in the Code Interpreter workspace.\n238: \n239:         Args:\n240:             path: Directory path to list (default: \"/\").\n241: \n242:         Returns:\n243:             List of file information dictionaries.\n244: \n245:         Raises:\n246:             requests.RequestException: If the HTTP request fails.\n247:         \"\"\"\n248:         response = self._request(\"GET\", \"api/files\", params={\"path\": path})\n249:         response.raise_for_status()\n250: \n251:         return response.json()\n252: \n253:     def close(self) -> None:\n254:         \"\"\"Close the HTTP session and release resources.\"\"\"\n255:         self.session.close()\n256: \n257:     def __enter__(self) -> \"CodeInterpreterDataPlaneClient\":\n258:         \"\"\"Context manager entry.\"\"\"\n259:         return self\n260: \n261:     def __exit__(self, exc_type, exc_val, exc_tb) -> None:\n262:         \"