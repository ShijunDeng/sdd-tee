{"type":"tool_use","timestamp":1775895910176,"sessionID":"ses_2845ce194ffe5CxYu8JhfafWPt","part":{"id":"prt_d7ba5128a001WOTRgf1BEi4zu2","messageID":"msg_d7ba50020001l50pAdcOjXoCBM","sessionID":"ses_2845ce194ffe5CxYu8JhfafWPt","type":"tool","tool":"read","callID":"toolu_functions.read:25","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/agentcube/runtime/publish_runtime.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/agentcube/runtime/publish_runtime.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Publish runtime for AgentCube CLI.\n2: \n3: This module provides the PublishRuntime class for publishing agents\n4: to Kubernetes environments using either AgentCube AgentRuntime CRs\n5: or standard Kubernetes Deployment and Service resources.\n6: \"\"\"\n7: \n8: import logging\n9: from datetime import datetime, timezone\n10: from pathlib import Path\n11: from typing import Any, Dict, Optional\n12: \n13: from agentcube.services.docker_service import DockerService\n14: from agentcube.services.metadata_service import AgentMetadata, MetadataService\n15: from agentcube.utils.log import get_logger\n16: \n17: \n18: class PublishRuntime:\n19:     \"\"\"Runtime class responsible for publishing agents to Kubernetes.\"\"\"\n20: \n21:     def __init__(self, verbose: bool = False, provider: str = \"agentcube\") -> None:\n22:         \"\"\"Initialize PublishRuntime.\n23: \n24:         Args:\n25:             verbose: Whether to enable verbose logging.\n26:             provider: The default target provider ('agentcube' or 'k8s').\n27:         \"\"\"\n28:         self.verbose = verbose\n29:         self.provider = provider\n30:         self.logger = get_logger(__name__, logging.DEBUG if verbose else logging.INFO)\n31:         self.metadata_service = MetadataService(verbose=verbose)\n32:         self.docker_service = DockerService(verbose=verbose)\n33: \n34:     def publish(self, workspace_path: Path, **options: Any) -> Dict[str, Any]:\n35:         \"\"\"Publish the agent to the target platform.\n36: \n37:         This is the main entry point for the publish operation. It validates\n38:         prerequisites, prepares the image, and deploys to either AgentCube\n39:         (as AgentRuntime CR) or Kubernetes (as Deployment/Service).\n40: \n41:         Args:\n42:             workspace_path: Path to the agent workspace directory.\n43:             **options: Publish options including:\n44:                 - version: Semantic version string\n45:                 - image_url: Image repository URL\n46:                 - image_username: Username for registry\n47:                 - image_password: Password for registry\n48:                 - description: Agent description\n49:                 - region: Deployment region\n50:                 - cloud_provider: Cloud provider name\n51:                 - provider: Target provider ('agentcube' or 'k8s')\n52:                 - node_port: Specific NodePort (30000-32767)\n53:                 - replicas: Number of replicas\n54:                 - namespace: Deployment namespace\n55: \n56:         Returns:\n57:             Dict containing publish results with keys:\n58:             - status: 'success' or 'error'\n59:             - agent_id: Assigned agent identifier\n60:             - agent_endpoint: Invocation URL\n61:             - k8s_deployment: Deployment details\n62:             - provider: Target provider used\n63: \n64:         Raises:\n65:             ValueError: If workspace is invalid or missing required metadata.\n66:             RuntimeError: If publish prerequisites are not met.\n67:             FileNotFoundError: If required files are missing.\n68:             TimeoutError: If deployment times out.\n69:         \"\"\"\n70:         self.logger.info(f\"Starting publish operation for workspace: {workspace_path}\")\n71: \n72:         # Step 1: Validate workspace\n73:         self._validate_workspace(workspace_path)\n74:         self.logger.debug(\"Workspace validated\")\n75: \n76:         # Step 2: Load metadata\n77:         metadata = self.metadata_service.load_metadata(workspace_path)\n78:         self.logger.debug(f\"Metadata loaded: agent_name={metadata.agent_name}\")\n79: \n80:         # Step 3: Apply version override if provided\n81:         version = options.get(\"version\")\n82:         if version:\n83:             metadata.version = version\n84:             self.logger.info(f\"Version overridden: {version}\")\n85: \n86:         # Step 4: Apply description override if provided\n87:         description = options.get(\"description\")\n88:         if description:\n89:             metadata.description = description\n90:             self.logger.info(f\"Description overridden: {description}\")\n91: \n92:         # Step 5: Apply region override if provided\n93:         region = options.get(\"region\")\n94:         if region:\n95:             metadata.region = region\n96:             self.logger.info(f\"Region set: {region}\")\n97: \n98:         # Step 6: Prepare image for publishing\n99:         image_url = self._prepare_image_for_publishing(workspace_path, metadata, options)\n100:         self.logger.info(f\"Image prepared: {image_url}\")\n101: \n102:         # Step 7: Determine provider and deploy\n103:         provider_type = options.get(\"provider\", self.provider)\n104:         self.logger.info(f\"Using provider: {provider_type}\")\n105: \n106:         if provider_type == \"agentcube\":\n107:             result = self._publish_cr_to_k8s(\n108:                 workspace_path, metadata, image_url=image_url, **options\n109:             )\n110:         elif provider_type == \"k8s\":\n111:             result = self._publish_k8s(workspace_path, metadata, image_url=image_url, **options)\n112:         else:\n113:             raise ValueError(f\"Unknown provider: {provider_type}\")\n114: \n115:         # Step 8: Update metadata with deployment info\n116:         self._update_publish_metadata(workspace_path, result)\n117:         self.logger.info(f\"Publish completed successfully: {result.get('agent_id')}\")\n118: \n119:         return result\n120: \n121:     def _validate_workspace(self, workspace_path: Path) -> None:\n122:         \"\"\"Validate that workspace exists and is a directory.\n123: \n124:         Args:\n125:             workspace_path: Path to the agent workspace directory.\n126: \n127:         Raises:\n128:             ValueError: If workspace doesn't exist or is not a directory.\n129:         \"\"\"\n130:         if not workspace_path.exists():\n131:             raise ValueError(f\"Workspace directory does not exist: {workspace_path}\")\n132:         if not workspace_path.is_dir():\n133:             raise ValueError(f\"Workspace path is not a directory: {workspace_path}\")\n134: \n135:     def _prepare_image_for_publishing(\n136:         self,\n137:         workspace_path: Path,\n138:         metadata: AgentMetadata,\n139:         options: Dict[str, Any],\n140:     ) -> str:\n141:         \"\"\"Prepare the image URL for publishing.\n142: \n143:         Args:\n144:             workspace_path: Path to the agent workspace.\n145:             metadata: The agent metadata.\n146:             options: CLI options.\n147: \n148:         Returns:\n149:             The full image URL for deployment.\n150: \n151:         Raises:\n152:             ValueError: If image_url is required but not provided.\n153:             RuntimeError: If image preparation fails.\n154:         \"\"\"\n155:         # If image_url is provided in options, use it directly\n156:         if options.get(\"image_url\"):\n157:             return options[\"image_url\"]\n158: \n159:         # If image_url is in metadata, use it\n160:         if metadata.image and metadata.image.get(\"url\"):\n161:             return metadata.image[\"url\"]\n162: \n163:         # Otherwise, prepare based on build_mode\n164:         build_mode = metadata.build_mode or \"local\"\n165: \n166:         if build_mode == \"local\":\n167:             return self._prepare_local_image(workspace_path, metadata, options)\n168:         else:\n169:             return self._prepare_cloud_image(workspace_path, metadata, options)\n170: \n171:     def _prepare_local_image(\n172:         self,\n173:         workspace_path: Path,\n174:         metadata: AgentMetadata,\n175:         options: Dict[str, Any],\n176:     ) -> str:\n177:         \"\"\"Prepare a locally built image for publishing.\n178: \n179:         Tags the local image with the provided registry URL and pushes it.\n180: \n181:         Args:\n182:             workspace_path: Path to the agent workspace.\n183:             metadata: The agent metadata.\n184:             options: CLI options.\n185: \n186:         Returns:\n187:             The full image URL.\n188: \n189:         Raises:\n190:             ValueError: If image_url is not provided.\n191:             RuntimeError: If Docker is not available or push fails.\n192:         \"\"\"\n193:         # Check if image_url is provided in options or metadata\n194:         image_url = options.get(\"image_url\") or metadata.registry_url\n195: \n196:         if not image_url:\n197:             raise ValueError(\n198:                 \"image_url is required for local build mode. \"\n199:                 \"Please provide --image-url or set registry_url in metadata.\"\n200:             )\n201: \n202:         # Check Docker availability\n203:         if not self.docker_service.is_docker_available():\n204:             raise RuntimeError(\"Docker is not available or not running\")\n205: \n206:         # Get image name and tag\n207:         image_name = metadata.agent_name\n208:         tag = metadata.version or \"latest\"\n209: \n210:         # Construct full image name\n211:         if \"/\" in image_url:\n212:             # image_url contains registry URL\n213:             full_image_name = f\"{image_url}/{image_name}:{tag}\"\n214:         else:\n215:             full_image_name = f\"{image_name}:{tag}\"\n216: \n217:         self.logger.info(f\"Preparing local image: {full_image_name}\")\n218: \n219:         # Get registry credentials\n220:         username = options.get(\"image_username\") or metadata.registry_username\n221:         password = options.get(\"image_password\") or metadata.registry_password\n222: \n223:         # Extract credentials from URL if present\n224:         if image_url and (\":\" in image_url.split(\"@\")[0] if \"@\" in image_url else False):\n225:             clean_url, extracted_user, extracted_pass = (\n226:                 self.docker_service.extract_credentials_from_url(image_url)\n227:             )\n228:             if extracted_user:\n229:                 username = username or extracted_user\n230:             if extracted_pass:\n231:                 password = password or extracted_pass\n232:             if clean_url != image_url:\n233:                 full_image_name = f\"{clean_url}/{image_name}:{tag}\"\n234: \n235:         # Push the image\n236:         self.docker_service.push_image(\n237:             image_name=image_name,\n238:             tag=tag,\n239:             registry_url=image_url if \"/\" in image_url else None,\n240:             username=username,\n241:             password=password,\n242:         )\n243: \n244:         return full_image_name\n245: \n246:     def _prepare_cloud_image(\n247:         self,\n248:         workspace_path: Path,\n249:         metadata: AgentMetadata,\n250:         options: Dict[str, Any],\n251:     ) -> str:\n252:         \"\"\"Prepare a cloud-built image for publishing.\n253: \n254:         For cloud builds, the image should already be available in the registry.\n255:         This method returns the image URL from metadata.\n256: \n257:         Args:\n258:             workspace_path: Path to the agent workspace.\n259:             metadata: The agent metadata.\n260:             options: CLI options.\n261: \n262:         Returns:\n263:             The full image URL.\n264: \n265:         Raises:\n266:             ValueError: If image URL is not available.\n267:         \"\"\"\n268:         # For cloud builds, the image URL should be in metadata\n269:         if metadata.image and metadata.image.get(\"url\"):\n270:             return metadata.image[\"url\"]\n271: \n272:         # Try to construct from registry_url and agent_name\n273:         if metadata.registry_url:\n274:             tag = metadata.version or \"latest\"\n275:             return f\"{metadata.registry_url}/{metadata.agent_name}:{tag}\"\n276: \n277:         raise ValueError(\n278:             \"No image URL available for cloud build. \"\n279:             \"Please provide image_url in metadata or via --image-url.\"\n280:         )\n281: \n282:     def _publish_cr_to_k8s(\n283:         self,\n284:         workspace_path: Path,\n285:         metadata: AgentMetadata,\n286:         image_url: str,\n287:         **options: Any,\n288:     ) -> Dict[str, Any]:\n289:         \"\"\"Deploy AgentRuntime Custom Resource to Kubernetes.\n290: \n291:         Args:\n292:             workspace_path: Path to the agent workspace.\n293:             metadata: The agent metadata.\n294:             image_url: The full image URL.\n295:             **options: Additional options.\n296: \n297:         Returns:\n298:             Dict containing deployment results.\n299: \n300:         Raises:\n301:             ValueError: If required AgentCube URLs are missing.\n302:             RuntimeError: If deployment fails.\n303:         \"\"\"\n304:         from agentcube.services.agentcube_provider import AgentCubeProvider\n305: \n306:         # Validate required AgentCube URLs\n307:         workload_manager_url = metadata.workload_manager_url\n308:         router_url = metadata.router_url\n309: \n310:         if not workload_manager_url or not router_url:\n311:             raise ValueError(\n312:                 \"AgentCube provider requires router_url and workload_manager_url \"\n313:                 \"in agent_metadata.yaml. Please set these values before publishing.\"\n314:             )\n315: \n316:         namespace = options.get(\"namespace\", \"default\")\n317: \n318:         # Create provider\n319:         provider = AgentCubeProvider(\n320:             namespace=namespace,\n321:             verbose=self.verbose,\n322:         )\n323: \n324:         # Build env vars\n325:         env_vars: Dict[str, str] = {}\n326: \n327:         # Deploy the AgentRuntime CR\n328:         result = provider.deploy_agent_runtime(\n329:             agent_name=metadata.agent_name,\n330:             image_url=image_url,\n331:             port=metadata.port,\n332:             entrypoint=metadata.entrypoint,\n333:             env_vars=env_vars,\n334:             workload_manager_url=workload_manager_url,\n335:             router_url=router_url,\n336:             readiness_probe_path=metadata.readiness_probe_path,\n337:             readiness_probe_port=metadata.readiness_probe_port,\n338:         )\n339: \n340:         # Build result with deployment info\n341:         return {\n342:             \"status\": \"success\",\n343:             \"agent_id\": result[\"agent_id\"],\n344:             \"agent_endpoint\": result[\"agent_endpoint\"],\n345:             \"provider\": \"agentcube\",\n346:             \"k8s_deployment\": {\n347:                 \"type\": \"AgentRuntime\",\n348:                 \"name\": result[\"name\"],\n349:                 \"namespace\": result[\"namespace\"],\n350:             },\n351:         }\n352: \n353:     def _publish_k8s(\n354:         self,\n355:         workspace_path: Path,\n356:         metadata: AgentMetadata,\n357:         image_url: str,\n358:         **options: Any,\n359:     ) -> Dict[str, Any]:\n360:         \"\"\"Deploy standard Kubernetes Deployment and Service.\n361: \n362:         Args:\n363:             workspace_path: Path to the agent workspace.\n364:             metadata: The agent metadata.\n365:             image_url: The full image URL.\n366:             **options: Additional options.\n367: \n368:         Returns:\n369:             Dict containing deployment results.\n370: \n371:         Raises:\n372:             ValueError: If node_port is outside valid range.\n373:             RuntimeError: If deployment fails.\n374:             TimeoutError: If deployment times out.\n375:         \"\"\"\n376:         from agentcube.services.k8s_provider import KubernetesProvider\n377: \n378:         namespace = options.get(\"namespace\", \"default\")\n379:         replicas = options.get(\"replicas\", 1)\n380:         node_port = options.get(\"node_port\")\n381: \n382:         # Validate node_port if provided\n383:         if node_port is not None:\n384:             if not 30000 <= node_port <= 32767:\n385:                 raise ValueError(f\"NodePort must be in range 30000-32767, got {node_port}\")\n386: \n387:         # Create provider\n388:         provider = KubernetesProvider(\n389:             namespace=namespace,\n390:             verbose=self.verbose,\n391:         )\n392: \n393:         # Deploy the agent\n394:         result = provider.deploy_agent(\n395:             agent_name=metadata.agent_name,\n396:             image_url=image_url,\n397:             port=metadata.port,\n398:             entrypoint=metadata.entrypoint,\n399:             replicas=replicas,\n400:             node_port=node_port,\n401:         )\n402: \n403:         # Wait for deployment to be ready\n404:         try:\n405:             provider.wait_for_deployment_ready(\n406:                 name=result[\"deployment_name\"],\n407:                 timeout=120,\n408:             )\n409:             deployment_status = \"ready\"\n410:         except TimeoutError:\n411:             deployment_status = \"timeout\"\n412:             self.logger.warning(f\"Deployment timed out after 120 seconds\")\n413: \n414:         # Build result with deployment info\n415:         return {\n416:             \"status\": \"success\" if deployment_status == \"ready\" else \"timeout\",\n417:             \"agent_id\": metadata.agent_name,\n418:             \"agent_endpoint\": result[\"service_url\"],\n419:             \"provider\": \"k8s\",\n420:             \"k8s_deployment\": {\n421:                 \"type\": \"Deployment\",\n422:                 \"name\": result[\"deployment_name\"],\n423:                 \"namespace\": result[\"namespace\"],\n424:                 \"node_port\": result[\"node_port\"],\n425:                 \"replicas\": result[\"replicas\"],\n426:             },\n427:         }\n428: \n429:     def _update_publish_metadata(\n430:         self,\n431:         workspace_path: Path,\n432:         agent_info: Dict[str, Any],\n433:     ) -> None:\n434:         \"\"\"Update metadata with deployment information.\n435: \n436:         Args:\n437:             workspace_path: Path to the agent workspace.\n438:             agent_info: Dict containing deployment results.\n439:         \"\"\"\n440:         # Load current metadata\n441:         metadata = self.metadata_service.load_metadata(workspace_path)\n442: \n443:         # Update fields\n444:         metadata.agent_id = agent_info.get(\"agent_id\")\n445:         metadata.agent_endpoint = agent_info.get(\"agent_endpoint\")\n446: \n447:         if agent_info.get(\"k8s_deployment\"):\n448:             metadata.k8s_deployment = agent_info[\"k8s_deployment\"]\n449: \n450:         # Update timestamp\n451:         metadata.pack_timestamp = datetime.now(timezone.utc).isoformat()\n452: \n453:         # Save updated metadata\n454:         self.metadata_service.save_metadata(workspace_path, metadata)\n455:         self.logger.debug(f\"Updated metadata with deployment info: {agent_info.get('agent_id')}\")\n\n(End of file - total 455 lines)\n</content>","metadata":{"preview":"\"\"\"Publish runtime for AgentCube CLI.\n\nThis module provides the PublishRuntime class for publishing agents\nto Kubernetes environments using either AgentCube AgentRuntime CRs\nor standard Kubernetes Deployment and Service resources.\n\"\"\"\n\nimport logging\nfrom datetime import datetime, timezone\nfrom pathlib import Path\nfrom typing import Any, Dict, Optional\n\nfrom agentcube.services.docker_service import DockerService\nfrom agentcube.services.metadata_service import AgentMetadata, MetadataService\nfrom agentcube.utils.log import get_logger\n\n\nclass PublishRuntime:\n    \"\"\"Runtime class responsible for publishing agents to Kubernetes.\"\"\"\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/agentcube/runtime/publish_runtime.py","time":{"start":1775895910152,"end":1775895910174}}}}
{"type":"tool_use","timestamp":1775895910180,"sessionID":"ses_2845ce194ffe5CxYu8JhfafWPt","part":{"id":"prt_d7ba50dfb001LvEWLRdTP8YPQ8","messageID":"msg_d7ba50020001l50pAdcOjXoCBM","sessionID":"ses_2845ce194ffe5CxYu8JhfafWPt","type":"tool","tool":"read","callID":"toolu_functions.read:24","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/agentcube/runtime/pack_runtime.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/agentcube/runtime/pack_runtime.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Pack runtime for AgentCube CLI.\n2: \n3: This module provides the PackRuntime class for packaging agent workspaces.\n4: \"\"\"\n5: \n6: import logging\n7: from datetime import datetime, timezone\n8: from pathlib import Path\n9: from typing import Any, Dict, Optional\n10: \n11: from agentcube.models.pack_models import MetadataOptions\n12: from agentcube.services.metadata_service import AgentMetadata, MetadataService\n13: from agentcube.utils.log import get_logger\n14: \n15: \n16: class PackRuntime:\n17:     \"\"\"Core class responsible for packaging agent workspaces.\"\"\"\n18: \n19:     def __init__(self, verbose: bool = False) -> None:\n20:         \"\"\"Initialize PackRuntime with optional verbose logging.\n21: \n22:         Args:\n23:             verbose: Whether to enable verbose logging.\n24:         \"\"\"\n25:         self.verbose = verbose\n26:         self.logger = get_logger(__name__, logging.DEBUG if verbose else logging.INFO)\n27:         self.metadata_service = MetadataService(verbose=verbose)\n28: \n29:     def pack(self, workspace_path: Path, **options: Any) -> Dict[str, Any]:\n30:         \"\"\"Main entry point for packaging an agent workspace.\n31: \n32:         Args:\n33:             workspace_path: Path to the agent workspace directory.\n34:             **options: CLI options and overrides.\n35: \n36:         Returns:\n37:             Dict containing packaging results including agent_name,\n38:             workspace_path, and metadata_path.\n39: \n40:         Raises:\n41:             ValueError: If workspace validation fails.\n42:         \"\"\"\n43:         self.logger.info(f\"Starting pack operation for workspace: {workspace_path}\")\n44: \n45:         # Step 1: Validate workspace structure\n46:         self._validate_workspace_structure(workspace_path)\n47:         self.logger.debug(\"Workspace structure validated\")\n48: \n49:         # Step 2: Load or create metadata\n50:         metadata = self._load_or_create_metadata(workspace_path, options)\n51:         self.logger.debug(f\"Metadata loaded: agent_name={metadata.agent_name}\")\n52: \n53:         # Step 3: Apply CLI option overrides\n54:         metadata = self._apply_option_overrides(metadata, options)\n55:         self.logger.debug(\"Option overrides applied\")\n56: \n57:         # Step 4: Validate language compatibility\n58:         self._validate_language_compatibility(workspace_path, metadata)\n59:         self.logger.debug(\"Language compatibility validated\")\n60: \n61:         # Step 5: Process dependencies\n62:         self._process_dependencies(workspace_path, metadata)\n63:         self.logger.debug(\"Dependencies processed\")\n64: \n65:         # Step 6: Generate Dockerfile\n66:         dockerfile_path = self._generate_dockerfile(workspace_path, metadata)\n67:         self.logger.debug(f\"Dockerfile generated: {dockerfile_path}\")\n68: \n69:         # Step 7: Update metadata with pack results\n70:         self._update_pack_metadata(workspace_path, metadata, dockerfile_path)\n71:         self.logger.debug(\"Pack metadata updated\")\n72: \n73:         # Step 8: Prepare output path\n74:         final_workspace = self._prepare_output_path(workspace_path, options.get(\"output\"))\n75: \n76:         self.logger.info(f\"Pack operation completed successfully for agent: {metadata.agent_name}\")\n77: \n78:         return {\n79:             \"agent_name\": metadata.agent_name,\n80:             \"workspace_path\": str(final_workspace),\n81:             \"metadata_path\": str(final_workspace / \"agent_metadata.yaml\"),\n82:         }\n83: \n84:     def _validate_workspace_structure(self, workspace_path: Path) -> None:\n85:         \"\"\"Validate that workspace exists and contains required files.\n86: \n87:         Args:\n88:             workspace_path: Path to the agent workspace directory.\n89: \n90:         Raises:\n91:             ValueError: If workspace doesn't exist or is not a directory.\n92:         \"\"\"\n93:         if not workspace_path.exists():\n94:             raise ValueError(f\"Workspace directory does not exist: {workspace_path}\")\n95:         if not workspace_path.is_dir():\n96:             raise ValueError(f\"Workspace path is not a directory: {workspace_path}\")\n97: \n98:     def _load_or_create_metadata(\n99:         self, workspace_path: Path, options: Dict[str, Any]\n100:     ) -> AgentMetadata:\n101:         \"\"\"Load existing metadata or create new from options.\n102: \n103:         Metadata loading precedence:\n104:         1. agent_metadata.yaml (primary)\n105:         2. agent.yaml (fallback)\n106:         3. metadata.yaml (fallback)\n107:         4. Create new from defaults + options\n108: \n109:         Args:\n110:             workspace_path: Path to the agent workspace directory.\n111:             options: CLI options and overrides.\n112: \n113:         Returns:\n114:             The loaded or created AgentMetadata instance.\n115:         \"\"\"\n116:         try:\n117:             return self.metadata_service.load_metadata(workspace_path)\n118:         except FileNotFoundError:\n119:             self.logger.info(\"No existing metadata found, creating new\")\n120: \n121:             # Derive agent name from directory if not provided\n122:             agent_name = options.get(\"agent_name\") or workspace_path.name\n123: \n124:             # Infer entrypoint from workspace\n125:             language = options.get(\"language\") or \"python\"\n126:             entrypoint = options.get(\"entrypoint\") or self._infer_entrypoint(\n127:                 workspace_path, language\n128:             )\n129: \n130:             # Create new metadata with defaults\n131:             metadata = AgentMetadata(\n132:                 agent_name=agent_name,\n133:                 entrypoint=entrypoint,\n134:                 language=language,\n135:                 port=options.get(\"port\") or 8080,\n136:                 build_mode=options.get(\"build_mode\") or \"local\",\n137:                 description=options.get(\"description\"),\n138:             )\n139: \n140:             return metadata\n141: \n142:     def _apply_option_overrides(\n143:         self, metadata: AgentMetadata, options: Dict[str, Any]\n144:     ) -> AgentMetadata:\n145:         \"\"\"Apply CLI option overrides to metadata.\n146: \n147:         Override precedence (highest first):\n148:         1. Explicit CLI options\n149:         2. Existing metadata values\n150:         3. Default values from AgentMetadata\n151: \n152:         Args:\n153:             metadata: The current AgentMetadata instance.\n154:             options: CLI options and overrides.\n155: \n156:         Returns:\n157:             The updated AgentMetadata instance.\n158:         \"\"\"\n159:         # Map CLI option names to metadata field names\n160:         field_mapping = {\n161:             \"agent_name\": \"agent_name\",\n162:             \"language\": \"language\",\n163:             \"entrypoint\": \"entrypoint\",\n164:             \"port\": \"port\",\n165:             \"build_mode\": \"build_mode\",\n166:             \"description\": \"description\",\n167:         }\n168: \n169:         for option_key, field_name in field_mapping.items():\n170:             if option_key in options and options[option_key] is not None:\n171:                 setattr(metadata, field_name, options[option_key])\n172:                 self.logger.debug(f\"Applied override: {field_name}={options[option_key]}\")\n173: \n174:         return metadata\n175: \n176:     def _validate_language_compatibility(\n177:         self, workspace_path: Path, metadata: AgentMetadata\n178:     ) -> None:\n179:         \"\"\"Validate workspace contents match declared language.\n180: \n181:         Args:\n182:             workspace_path: Path to the agent workspace directory.\n183:             metadata: The AgentMetadata instance with language configuration.\n184: \n185:         Raises:\n186:             ValueError: If language-specific files are missing.\n187:         \"\"\"\n188:         if metadata.language == \"python\":\n189:             self._validate_python_compatibility(workspace_path)\n190:         elif metadata.language == \"java\":\n191:             self._validate_java_compatibility(workspace_path)\n192: \n193:     def _validate_python_compatibility(self, workspace_path: Path) -> None:\n194:         \"\"\"Validate Python workspace has at least one .py file.\n195: \n196:         Args:\n197:             workspace_path: Path to the agent workspace directory.\n198: \n199:         Raises:\n200:             ValueError: If no Python files found.\n201:         \"\"\"\n202:         py_files = list(workspace_path.glob(\"*.py\"))\n203:         if not py_files:\n204:             raise ValueError(\"No Python files found in workspace\")\n205: \n206:     def _validate_java_compatibility(self, workspace_path: Path) -> None:\n207:         \"\"\"Validate Java workspace has pom.xml.\n208: \n209:         Args:\n210:             workspace_path: Path to the agent workspace directory.\n211: \n212:         Raises:\n213:             ValueError: If pom.xml not found.\n214:         \"\"\"\n215:         pom_path = workspace_path / \"pom.xml\"\n216:         if not pom_path.exists():\n217:             raise ValueError(\"No pom.xml found in workspace (required for Java agents)\")\n218: \n219:     def _process_dependencies(self, workspace_path: Path, metadata: AgentMetadata) -> None:\n220:         \"\"\"Process and validate language-specific dependencies.\n221: \n222:         Args:\n223:             workspace_path: Path to the agent workspace directory.\n224:             metadata: The AgentMetadata instance with language configuration.\n225:         \"\"\"\n226:         if metadata.language == \"python\":\n227:             self._process_python_dependencies(workspace_path)\n228:         elif metadata.language == \"java\":\n229:             self._process_java_dependencies(workspace_path)\n230: \n231:     def _process_python_dependencies(self, workspace_path: Path) -> None:\n232:         \"\"\"Process Python requirements.txt if present.\n233: \n234:         Validates file exists and logs dependency count.\n235: \n236:         Args:\n237:             workspace_path: Path to the agent workspace directory.\n238:         \"\"\"\n239:         req_file = workspace_path / \"requirements.txt\"\n240:         if req_file.exists():\n241:             deps = [\n242:                 line.strip()\n243:                 for line in req_file.read_text().splitlines()\n244:                 if line.strip() and not line.startswith(\"#\")\n245:             ]\n246:             self.logger.info(f\"Found {len(deps)} Python dependencies\")\n247:         else:\n248:             self.logger.debug(\"No requirements.txt found\")\n249: \n250:     def _process_java_dependencies(self, workspace_path: Path) -> None:\n251:         \"\"\"Process Java Maven dependencies from pom.xml.\n252: \n253:         Args:\n254:             workspace_path: Path to the agent workspace directory.\n255:         \"\"\"\n256:         import xml.etree.ElementTree as ET\n257: \n258:         pom_path = workspace_path / \"pom.xml\"\n259:         if pom_path.exists():\n260:             try:\n261:                 tree = ET.parse(pom_path)\n262:                 root = tree.getroot()\n263:                 # Count dependency elements\n264:                 deps = root.findall(\".//{http://maven.apache.org/POM/4.0.0}dependency\")\n265:                 self.logger.info(f\"Found {len(deps)} Maven dependencies\")\n266:             except ET.ParseError as e:\n267:                 self.logger.warning(f\"Could not parse pom.xml: {e}\")\n268:         else:\n269:             self.logger.debug(\"No pom.xml found\")\n270: \n271:     def _generate_dockerfile(self, workspace_path: Path, metadata: AgentMetadata) -> Optional[Path]:\n272:         \"\"\"Generate Dockerfile based on language and metadata.\n273: \n274:         Args:\n275:             workspace_path: Path to agent workspace.\n276:             metadata: Agent metadata with configuration.\n277: \n278:         Returns:\n279:             Path to generated Dockerfile, or None if generation skipped.\n280:         \"\"\"\n281:         dockerfile_path = workspace_path / \"Dockerfile\"\n282: \n283:         if metadata.language == \"python\":\n284:             content = self._generate_python_dockerfile(metadata)\n285:         elif metadata.language == \"java\":\n286:             content = self._generate_java_dockerfile(metadata)\n287:         else:\n288:             self.logger.warning(\n289:                 f\"Unsupported language for Dockerfile generation: {metadata.language}\"\n290:             )\n291:             return None\n292: \n293:         dockerfile_path.write_text(content)\n294:         self.logger.info(f\"Generated Dockerfile at {dockerfile_path}\")\n295:         return dockerfile_path\n296: \n297:     def _generate_python_dockerfile(self, metadata: AgentMetadata) -> str:\n298:         \"\"\"Generate Python-specific Dockerfile content.\n299: \n300:         Template includes:\n301:         - Python 3.11 slim base image\n302:         - Working directory setup\n303:         - Requirements installation\n304:         - Source code copying\n305:         - Entrypoint configuration\n306:         - Port exposure\n307: \n308:         Args:\n309:             metadata: Agent metadata with configuration.\n310: \n311:         Returns:\n312:             Dockerfile content as string.\n313:         \"\"\"\n314:         entrypoint = metadata.entrypoint or \"python main.py\"\n315:         port = metadata.port or 8080\n316: \n317:         return f\"\"\"FROM python:3.11-slim\n318: \n319: WORKDIR /app\n320: \n321: # Install dependencies\n322: COPY requirements.txt .\n323: RUN pip install --no-cache-dir -r requirements.txt\n324: \n325: # Copy source code\n326: COPY . .\n327: \n328: # Expose port\n329: EXPOSE {port}\n330: \n331: # Run the agent\n332: CMD [\"{entrypoint}\"]\n333: \"\"\"\n334: \n335:     def _generate_java_dockerfile(self, metadata: AgentMetadata) -> str:\n336:         \"\"\"Generate Java-specific Dockerfile content.\n337: \n338:         Template includes:\n339:         - Maven build stage\n340:         - JAR extraction\n341:         - Runtime stage with minimal base\n342:         - Port exposure\n343: \n344:         Args:\n345:             metadata: Agent metadata with configuration.\n346: \n347:         Returns:\n348:             Dockerfile content as string.\n349:         \"\"\"\n350:         port = metadata.port or 8080\n351: \n352:         return f\"\"\"# Build stage\n353: FROM maven:3.9-eclipse-temurin-17-alpine AS builder\n354: \n355: WORKDIR /app\n356: COPY pom.xml .\n357: COPY src ./src\n358: \n359: RUN mvn clean package -DskipTests\n360: \n361: # Runtime stage\n362: FROM eclipse-temurin:17-jre-alpine\n363: \n364: WORKDIR /app\n365: \n366: # Copy built JAR\n367: COPY --from=builder /app/target/*.jar app.jar\n368: \n369: # Expose port\n370: EXPOSE {port}\n371: \n372: # Run the agent\n373: ENTRYPOINT [\"java\", \"-jar\", \"app.jar\"]\n374: \"\"\"\n375: \n376:     def _update_pack_metadata(\n377:         self,\n378:         workspace_path: Path,\n379:         metadata: AgentMetadata,\n380:         dockerfile_path: Optional[Path],\n381:     ) -> None:\n382:         \"\"\"Update metadata with pack results.\n383: \n384:         Sets:\n385:         - pack_timestamp: Current UTC time\n386:         - dockerfile_generated: Whether Dockerfile was created\n387: \n388:         Args:\n389:             workspace_path: Path to the agent workspace directory.\n390:             metadata: The AgentMetadata instance to update.\n391:             dockerfile_path: Path to the generated Dockerfile, or None.\n392:         \"\"\"\n393:         metadata.pack_timestamp = datetime.now(timezone.utc).isoformat()\n394:         metadata.dockerfile_generated = dockerfile_path is not None\n395: \n396:         self.metadata_service.save_metadata(workspace_path, metadata)\n397: \n398:     def _prepare_output_path(self, workspace_path: Path, output_path: Optional[str]) -> Path:\n399:         \"\"\"Resolve output path for packaged workspace.\n400: \n401:         Args:\n402:             workspace_path: Source workspace path.\n403:             output_path: Optional explicit output path.\n404: \n405:         Returns:\n406:             Resolved output path.\n407:         \"\"\"\n408:         if output_path:\n409:             return Path(output_path)\n410:         return workspace_path\n411: \n412:     def _infer_entrypoint(self, workspace_path: Path, language: str) -> str:\n413:         \"\"\"Attempt to infer entrypoint from workspace contents.\n414: \n415:         Args:\n416:             workspace_path: Path to workspace.\n417:             language: Programming language.\n418: \n419:         Returns:\n420:             Inferred entrypoint command.\n421:         \"\"\"\n422:         if language == \"python\":\n423:             # Look for main.py, app.py, or any .py file\n424:             for candidate in [\"main.py\", \"app.py\", \"agent.py\"]:\n425:                 if (workspace_path / candidate).exists():\n426:                     return f\"python {candidate}\"\n427:             # Fallback to first .py file\n428:             py_files = list(workspace_path.glob(\"*.py\"))\n429:             if py_files:\n430:                 return f\"python {py_files[0].name}\"\n431:             return \"python main.py\"\n432: \n433:         elif language == \"java\":\n434:             # For Java, entrypoint is typically the JAR\n435:             return \"java -jar app.jar\"\n436: \n437:         return \"\"\n\n(End of file - total 437 lines)\n</content>","metadata":{"preview":"\"\"\"Pack runtime for AgentCube CLI.\n\nThis module provides the PackRuntime class for packaging agent workspaces.\n\"\"\"\n\nimport logging\nfrom datetime import datetime, timezone\nfrom pathlib import Path\nfrom typing import Any, Dict, Optional\n\nfrom agentcube.models.pack_models import MetadataOptions\nfrom agentcube.services.metadata_service import AgentMetadata, MetadataService\nfrom agentcube.utils.log import get_logger\n\n\nclass PackRuntime:\n    \"\"\"Core class responsible for packaging agent workspaces.\"\"\"\n\n    def __init__(self, verbose: bool = False) -> None:\n        \"\"\"Initialize PackRuntime with optional verbose logging.","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/agentcube/runtime/pack_runtime.py","time":{"start":1775895910149,"end":1775895910177}}}}
