{"type":"tool_use","timestamp":1775895796835,"sessionID":"ses_2845ce194ffe5CxYu8JhfafWPt","part":{"id":"prt_d7ba3502c001Pop2WjcPILkPY6","messageID":"msg_d7ba33da8001VNeoQ0jZJg3ZIZ","sessionID":"ses_2845ce194ffe5CxYu8JhfafWPt","type":"tool","tool":"read","callID":"toolu_functions.read:4","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/agentcube/services/docker_service.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/agentcube/services/docker_service.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Docker service for AgentCube CLI.\n2: \n3: This module provides the DockerService class for building and managing\n4: Docker images using the Docker SDK.\n5: \"\"\"\n6: \n7: import logging\n8: import time\n9: from pathlib import Path\n10: from typing import Any, Dict, List, Optional\n11: \n12: import docker\n13: from docker.errors import BuildError, DockerException\n14: \n15: from agentcube.utils.log import get_logger\n16: \n17: \n18: def _format_image_id(image_id: Optional[str]) -> str:\n19:     \"\"\"Format Docker image ID for display.\n20: \n21:     Args:\n22:         image_id: Raw Docker image ID (may include 'sha256:' prefix).\n23: \n24:     Returns:\n25:         Formatted 12-character image ID.\n26:     \"\"\"\n27:     if not image_id:\n28:         return \"unknown\"\n29:     if \":\" in image_id:\n30:         return image_id.split(\":\")[-1][:12]\n31:     return image_id[:12]\n32: \n33: \n34: class DockerService:\n35:     \"\"\"Service for Docker image building and management.\"\"\"\n36: \n37:     def __init__(self, verbose: bool = False) -> None:\n38:         \"\"\"Initialize DockerService.\n39: \n40:         Args:\n41:             verbose: Whether to enable verbose logging.\n42:         \"\"\"\n43:         self.verbose = verbose\n44:         self.logger = get_logger(__name__, logging.DEBUG if verbose else logging.INFO)\n45:         self._client: Optional[docker.DockerClient] = None\n46: \n47:     def _get_client(self) -> docker.DockerClient:\n48:         \"\"\"Get or create Docker client.\n49: \n50:         Returns:\n51:             Docker client instance.\n52: \n53:         Raises:\n54:             RuntimeError: If Docker is not available or not running.\n55:         \"\"\"\n56:         if self._client is None:\n57:             try:\n58:                 self._client = docker.from_env()\n59:                 self._client.ping()  # Verify Docker is running\n60:             except DockerException as e:\n61:                 self.logger.error(f\"Docker connection failed: {e}\")\n62:                 raise RuntimeError(\"Docker is not available or not running\") from e\n63:         return self._client\n64: \n65:     def is_docker_available(self) -> bool:\n66:         \"\"\"Check if Docker daemon is available and running.\n67: \n68:         Returns:\n69:             True if Docker is available, False otherwise.\n70:         \"\"\"\n71:         try:\n72:             client = docker.from_env()\n73:             client.ping()\n74:             return True\n75:         except DockerException:\n76:             return False\n77: \n78:     def build_image(\n79:         self,\n80:         context_path: Path,\n81:         dockerfile_path: Path,\n82:         image_name: str,\n83:         tag: str,\n84:         build_args: Optional[Dict[str, str]] = None,\n85:     ) -> Dict[str, Any]:\n86:         \"\"\"Build a Docker image from a Dockerfile.\n87: \n88:         Args:\n89:             context_path: Path to the build context directory.\n90:             dockerfile_path: Path to the Dockerfile.\n91:             image_name: Name of the image to build.\n92:             tag: Tag for the image.\n93:             build_args: Optional build arguments to pass to Docker.\n94: \n95:         Returns:\n96:             Dict containing build results with keys:\n97:             - image_name: Name of the built image\n98:             - image_id: Docker image ID\n99:             - image_size: Human-readable image size\n100:             - build_time: Build duration in seconds\n101:             - image_tag: Full image tag (name:tag)\n102: \n103:         Raises:\n104:             RuntimeError: If the build fails or Docker is not available.\n105:             FileNotFoundError: If the Dockerfile does not exist.\n106:         \"\"\"\n107:         if not dockerfile_path.exists():\n108:             raise FileNotFoundError(f\"Dockerfile not found: {dockerfile_path}\")\n109: \n110:         if not context_path.exists():\n111:             raise FileNotFoundError(f\"Build context not found: {context_path}\")\n112: \n113:         client = self._get_client()\n114: \n115:         full_tag = f\"{image_name}:{tag}\"\n116:         self.logger.info(f\"Building Docker image: {full_tag}\")\n117:         self.logger.debug(f\"Context: {context_path}\")\n118:         self.logger.debug(f\"Dockerfile: {dockerfile_path}\")\n119: \n120:         # Prepare build arguments\n121:         dockerfile_rel = dockerfile_path.relative_to(context_path)\n122:         build_kwargs: Dict[str, Any] = {\n123:             \"path\": str(context_path),\n124:             \"dockerfile\": str(dockerfile_rel),\n125:             \"tag\": full_tag,\n126:             \"rm\": True,  # Remove intermediate containers\n127:             \"forcerm\": True,  # Force remove intermediate containers\n128:         }\n129: \n130:         if build_args:\n131:             build_kwargs[\"buildargs\"] = build_args\n132:             self.logger.debug(f\"Build args: {build_args}\")\n133: \n134:         # Build the image\n135:         start_time = time.time()\n136:         try:\n137:             image, build_logs = client.images.build(**build_kwargs)\n138:         except BuildError as e:\n139:             # Collect all error messages from build logs\n140:             error_msgs = []\n141:             for log in e.build_log:\n142:                 if \"error\" in log:\n143:                     error_msgs.append(log[\"error\"])\n144:             error_msg = \"; \".join(error_msgs) if error_msgs else str(e)\n145:             self.logger.error(f\"Docker build failed: {error_msg}\")\n146:             raise RuntimeError(f\"Docker build failed: {error_msg}\") from e\n147: \n148:         build_time = time.time() - start_time\n149: \n150:         # Get image details\n151:         image_id = _format_image_id(getattr(image, \"id\", None))\n152:         size_bytes = image.attrs.get(\"Size\", 0)\n153:         size_mb = size_bytes / (1024 * 1024)\n154: \n155:         self.logger.info(f\"Successfully built image {full_tag} ({image_id}) in {build_time:.2f}s\")\n156: \n157:         return {\n158:             \"image_name\": image_name,\n159:             \"image_tag\": tag,\n160:             \"image_id\": image_id,\n161:             \"image_size\": f\"{size_mb:.2f}MB\",\n162:             \"build_time\": f\"{build_time:.2f}\",\n163:             \"full_tag\": full_tag,\n164:         }\n165: \n166:     def tag_image(self, image_name: str, source_tag: str, target_tag: str) -> Dict[str, str]:\n167:         \"\"\"Tag an existing Docker image.\n168: \n169:         Args:\n170:             image_name: Name of the image.\n171:             source_tag: Source tag.\n172:             target_tag: Target tag to apply.\n173: \n174:         Returns:\n175:             Dict with tagging results.\n176:         \"\"\"\n177:         client = self._get_client()\n178: \n179:         full_source = f\"{image_name}:{source_tag}\"\n180:         full_target = f\"{image_name}:{target_tag}\"\n181: \n182:         try:\n183:             image = client.images.get(full_source)\n184:             image.tag(image_name, target_tag)\n185:             self.logger.info(f\"Tagged {full_source} as {full_target}\")\n186:             image_id = _format_image_id(getattr(image, \"id\", None))\n187:             return {\n188:                 \"source\": full_source,\n189:                 \"target\": full_target,\n190:                 \"image_id\": image_id,\n191:             }\n192:         except DockerException as e:\n193:             self.logger.error(f\"Failed to tag image: {e}\")\n194:             raise RuntimeError(f\"Failed to tag image: {e}\") from e\n195: \n196:     def get_image_info(self, image_name: str, tag: str = \"latest\") -> Dict[str, Any]:\n197:         \"\"\"Get information about a Docker image.\n198: \n199:         Args:\n200:             image_name: Name of the image.\n201:             tag: Tag of the image.\n202: \n203:         Returns:\n204:             Dict containing image information.\n205: \n206:         Raises:\n207:             RuntimeError: If the image does not exist.\n208:         \"\"\"\n209:         client = self._get_client()\n210:         full_tag = f\"{image_name}:{tag}\"\n211: \n212:         try:\n213:             image = client.images.get(full_tag)\n214:             size_bytes = image.attrs.get(\"Size\", 0)\n215:             size_mb = size_bytes / (1024 * 1024)\n216: \n217:             return {\n218:                 \"name\": image_name,\n219:                 \"tag\": tag,\n220:                 \"id\": _format_image_id(getattr(image, \"id\", None)),\n221:                 \"size\": f\"{size_mb:.2f}MB\",\n222:                 \"created\": image.attrs.get(\"Created\", \"\"),\n223:                 \"labels\": image.labels or {},\n224:             }\n225:         except DockerException as e:\n226:             self.logger.error(f\"Image not found: {full_tag}\")\n227:             raise RuntimeError(f\"Image not found: {full_tag}\") from e\n228: \n229:     def list_images(self, name: Optional[str] = None) -> List[Dict[str, Any]]:\n230:         \"\"\"List Docker images.\n231: \n232:         Args:\n233:             name: Optional filter by image name.\n234: \n235:         Returns:\n236:             List of image information dicts.\n237:         \"\"\"\n238:         client = self._get_client()\n239: \n240:         try:\n241:             images = client.images.list(name=name)\n242:             result = []\n243:             for image in images:\n244:                 size_bytes = image.attrs.get(\"Size\", 0)\n245:                 size_mb = size_bytes / (1024 * 1024)\n246:                 tags = image.tags if image.tags else [\"<none>:<none>\"]\n247: \n248:                 for tag in tags:\n249:                     if \":\" in tag:\n250:                         name_part, tag_part = tag.rsplit(\":\", 1)\n251:                     else:\n252:                         name_part, tag_part = tag, \"latest\"\n253: \n254:                     result.append(\n255:                         {\n256:                             \"name\": name_part,\n257:                             \"tag\": tag_part,\n258:                             \"id\": _format_image_id(getattr(image, \"id\", None)),\n259:                             \"size\": f\"{size_mb:.2f}MB\",\n260:                             \"created\": image.attrs.get(\"Created\", \"\"),\n261:                         }\n262:                     )\n263: \n264:             return result\n265:         except DockerException as e:\n266:             self.logger.error(f\"Failed to list images: {e}\")\n267:             raise RuntimeError(f\"Failed to list images: {e}\") from e\n268: \n269:     def push_image(\n270:         self,\n271:         image_name: str,\n272:         tag: str = \"latest\",\n273:         registry_url: Optional[str] = None,\n274:         username: Optional[str] = None,\n275:         password: Optional[str] = None,\n276:     ) -> Dict[str, Any]:\n277:         \"\"\"Push a Docker image to a registry.\n278: \n279:         Args:\n280:             image_name: Name of the image to push.\n281:             tag: Tag of the image (default: \"latest\").\n282:             registry_url: Optional registry URL (e.g., \"registry.example.com\").\n283:             username: Optional username for registry authentication.\n284:             password: Optional password for registry authentication.\n285: \n286:         Returns:\n287:             Dict containing push results with keys:\n288:             - image_name: Full image name including registry\n289:             - tag: Image tag\n290:             - registry: Registry URL (if any)\n291:             - pushed: Whether push was successful\n292: \n293:         Raises:\n294:             RuntimeError: If the push fails or image doesn't exist.\n295:         \"\"\"\n296:         client = self._get_client()\n297: \n298:         # Construct full image name\n299:         local_tag = f\"{image_name}:{tag}\"\n300:         if registry_url:\n301:             full_image_name = f\"{registry_url}/{image_name}:{tag}\"\n302:         else:\n303:             full_image_name = local_tag\n304: \n305:         self.logger.info(f\"Pushing image: {full_image_name}\")\n306: \n307:         try:\n308:             # Get the local image\n309:             image = client.images.get(local_tag)\n310: \n311:             # Tag with registry URL if different from local name\n312:             if registry_url and not local_tag.startswith(registry_url):\n313:                 image.tag(f\"{registry_url}/{image_name}\", tag=tag)\n314:                 self.logger.debug(f\"Tagged image as {full_image_name}\")\n315: \n316:             # Login to registry if credentials provided\n317:             if username and password and registry_url:\n318:                 self.logger.debug(f\"Logging in to registry: {registry_url}\")\n319:                 client.login(\n320:                     username=username,\n321:                     password=password,\n322:                     registry=registry_url,\n323:                 )\n324:                 self.logger.debug(\"Registry login successful\")\n325: \n326:             # Push the image\n327:             push_logs = client.images.push(full_image_name, stream=True, decode=True)\n328: \n329:             # Process push logs\n330:             for log in push_logs:\n331:                 if isinstance(log, dict):\n332:                     if \"status\" in log:\n333:                         self.logger.debug(f\"Push status: {log['status']}\")\n334:                     if \"error\" in log:\n335:                         error_msg = log[\"error\"]\n336:                         self.logger.error(f\"Push failed: {error_msg}\")\n337:                         raise RuntimeError(f\"Failed to push image: {error_msg}\")\n338: \n339:             self.logger.info(f\"Successfully pushed image: {full_image_name}\")\n340: \n341:             return {\n342:                 \"image_name\": full_image_name,\n343:                 \"tag\": tag,\n344:                 \"registry\": registry_url,\n345:                 \"pushed\": True,\n346:             }\n347: \n348:         except DockerException as e:\n349:             self.logger.error(f\"Push failed: {e}\")\n350:             raise RuntimeError(f\"Failed to push image: {e}\") from e\n351: \n352:     def extract_credentials_from_url(\n353:         self, image_url: str\n354:     ) -> tuple[str, Optional[str], Optional[str]]:\n355:         \"\"\"Extract credentials from image URL with embedded auth.\n356: \n357:         Args:\n358:             image_url: Image URL potentially containing credentials\n359:                       (e.g., \"user:pass@registry.com/image:tag\").\n360: \n361:         Returns:\n362:             Tuple of (clean_url, username, password) where username and password\n363:             may be None if not present in the URL.\n364:         \"\"\"\n365:         import urllib.parse\n366: \n367:         # Parse the URL\n368:         parsed = urllib.parse.urlparse(f\"//{image_url}\")\n369: \n370:         username = None\n371:         password = None\n372:         clean_url = image_url\n373: \n374:         # Extract credentials from netloc\n375:         if parsed.username:\n376:             username = urllib.parse.unquote(parsed.username)\n377:         if parsed.password:\n378:             password = urllib.parse.unquote(parsed.password)\n379: \n380:         # Remove credentials from URL\n381:         if parsed.username or parsed.password:\n382:             netloc = parsed.hostname or \"\"\n383:             if parsed.port:\n384:                 netloc += f\":{parsed.port}\"\n385:             clean_path = parsed.path.lstrip(\"/\")\n386:             if parsed.query:\n387:                 clean_path += f\"?{parsed.query}\"\n388:             clean_url = f\"{netloc}/{clean_path}\"\n389: \n390:         return clean_url, username, password\n\n(End of file - total 390 lines)\n</content>","metadata":{"preview":"\"\"\"Docker service for AgentCube CLI.\n\nThis module provides the DockerService class for building and managing\nDocker images using the Docker SDK.\n\"\"\"\n\nimport logging\nimport time\nfrom pathlib import Path\nfrom typing import Any, Dict, List, Optional\n\nimport docker\nfrom docker.errors import BuildError, DockerException\n\nfrom agentcube.utils.log import get_logger\n\n\ndef _format_image_id(image_id: Optional[str]) -> str:\n    \"\"\"Format Docker image ID for display.\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/agentcube/services/docker_service.py","time":{"start":1775895796805,"end":1775895796833}}}}
{"type":"tool_use","timestamp":1775895796838,"sessionID":"ses_2845ce194ffe5CxYu8JhfafWPt","part":{"id":"prt_d7ba35455001Xs4Nab3B9wqn8G","messageID":"msg_d7ba33da8001VNeoQ0jZJg3ZIZ","sessionID":"ses_2845ce194ffe5CxYu8JhfafWPt","type":"tool","tool":"read","callID":"toolu_functions.read:5","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/agentcube/cli/main.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/agentcube/cli/main.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Main CLI module for AgentCube.\n2: \n3: This module provides the Typer-based CLI application with all commands\n4: for agent lifecycle management including pack, build, publish, invoke, and status.\n5: \"\"\"\n6: \n7: import json\n8: import logging\n9: from pathlib import Path\n10: from typing import Any, Optional\n11: \n12: import typer\n13: from rich.console import Console\n14: from rich.progress import Progress, SpinnerColumn, TextColumn\n15: from rich.table import Table\n16: \n17: from agentcube import __version__\n18: from agentcube.runtime.build_runtime import BuildRuntime\n19: from agentcube.runtime.invoke_runtime import InvokeRuntime\n20: from agentcube.runtime.pack_runtime import PackRuntime\n21: from agentcube.runtime.publish_runtime import PublishRuntime\n22: from agentcube.runtime.status_runtime import StatusRuntime\n23: \n24: # Create Typer app\n25: app = typer.Typer(\n26:     name=\"agentcube\",\n27:     help=\"AgentCube CLI - A developer tool for AI agent lifecycle management\",\n28:     no_args_is_help=True,\n29:     rich_markup_mode=\"rich\",\n30:     add_completion=False,\n31: )\n32: \n33: # Create console for output\n34: console = Console()\n35: \n36: \n37: def version_callback(value: bool) -> None:\n38:     \"\"\"Display version and exit.\n39: \n40:     Args:\n41:         value: Whether the --version flag was passed.\n42:     \"\"\"\n43:     if value:\n44:         console.print(f\"AgentCube CLI (kubectl agentcube) version: {__version__}\")\n45:         raise typer.Exit()\n46: \n47: \n48: def _handle_error(e: Exception, command_name: str, verbose: bool) -> None:\n49:     \"\"\"Handle command errors with optional traceback.\n50: \n51:     Args:\n52:         e: The exception that was raised.\n53:         command_name: Name of the command being executed.\n54:         verbose: Whether verbose mode is enabled.\n55:     \"\"\"\n56:     console.print(f\"Error {command_name}: {e}\", style=\"red\")\n57:     if verbose:\n58:         console.print_exception()\n59:     raise typer.Exit(1)\n60: \n61: \n62: def _parse_payload(payload_str: str) -> dict[str, Any]:\n63:     \"\"\"Parse and validate JSON payload.\n64: \n65:     Args:\n66:         payload_str: JSON string to parse.\n67: \n68:     Returns:\n69:         Parsed JSON dictionary.\n70: \n71:     Raises:\n72:         typer.Exit: If JSON is invalid (exit code 1).\n73:     \"\"\"\n74:     try:\n75:         return json.loads(payload_str)\n76:     except json.JSONDecodeError as e:\n77:         console.print(f\"Invalid JSON payload: {e}\", style=\"red\")\n78:         raise typer.Exit(1)\n79: \n80: \n81: def _parse_headers(header_list: Optional[list[str]]) -> dict[str, str]:\n82:     \"\"\"Parse header strings into dictionary.\n83: \n84:     Args:\n85:         header_list: List of header strings in 'key:value' format.\n86: \n87:     Returns:\n88:         Dictionary of headers.\n89: \n90:     Raises:\n91:         typer.Exit: If header format is invalid (exit code 1).\n92:     \"\"\"\n93:     headers: dict[str, str] = {}\n94:     if header_list:\n95:         for header in header_list:\n96:             if \":\" not in header:\n97:                 console.print(\n98:                     f\"Invalid header format: '{header}'. Expected 'key:value'\",\n99:                     style=\"red\",\n100:                 )\n101:                 raise typer.Exit(1)\n102:             key, value = header.split(\":\", 1)\n103:             headers[key.strip()] = value.strip()\n104:     return headers\n105: \n106: \n107: def _display_status_table(status: dict[str, Any]) -> None:\n108:     \"\"\"Display status in a Rich Table format.\n109: \n110:     Args:\n111:         status: Status dictionary from get_status().\n112:     \"\"\"\n113:     table = Table(title=\"Agent Status\")\n114:     table.add_column(\"Property\", style=\"cyan\")\n115:     table.add_column(\"Value\", style=\"green\")\n116: \n117:     # Map status values to colors\n118:     status_value = status.get(\"status\", \"unknown\")\n119:     if status_value == \"ready\":\n120:         status_display = \"[green]ready[/green]\"\n121:     elif status_value == \"error\":\n122:         status_display = \"[red]error[/red]\"\n123:     elif status_value == \"not_published\":\n124:         status_display = \"[yellow]not_published[/yellow]\"\n125:     elif status_value == \"not_found\":\n126:         status_display = \"[red]not_found[/red]\"\n127:     elif status_value == \"not_found_in_k8s\":\n128:         status_display = \"[red]not_found_in_k8s[/red]\"\n129:     elif status_value == \"not_ready\":\n130:         status_display = \"[yellow]not_ready[/yellow]\"\n131:     elif status_value == \"partial\":\n132:         status_display = \"[yellow]partial[/yellow]\"\n133:     elif status_value == \"pending\":\n134:         status_display = \"[yellow]pending[/yellow]\"\n135:     else:\n136:         status_display = f\"[yellow]{status_value}[/yellow]\"\n137: \n138:     table.add_row(\"Status\", status_display)\n139:     table.add_row(\"Agent Name\", status.get(\"agent_name\", \"N/A\"))\n140:     table.add_row(\"Agent ID\", status.get(\"agent_id\", \"N/A\"))\n141:     table.add_row(\"Provider\", status.get(\"provider\", \"N/A\"))\n142:     table.add_row(\"Namespace\", status.get(\"namespace\", \"N/A\"))\n143: \n144:     if status.get(\"agent_endpoint\"):\n145:         table.add_row(\"Endpoint\", status[\"agent_endpoint\"])\n146: \n147:     if status.get(\"deployment\"):\n148:         dep = status[\"deployment\"]\n149:         table.add_row(\n150:             \"Replicas\",\n151:             f\"{dep.get('ready_replicas', 0)}/{dep.get('replicas', 0)}\",\n152:         )\n153: \n154:     if status.get(\"service\"):\n155:         svc = status[\"service\"]\n156:         if svc.get(\"node_port\"):\n157:             table.add_row(\"NodePort\", str(svc[\"node_port\"]))\n158:         if svc.get(\"cluster_ip\"):\n159:             table.add_row(\"Cluster IP\", svc[\"cluster_ip\"])\n160: \n161:     if status.get(\"message\"):\n162:         table.add_row(\"Message\", status[\"message\"])\n163: \n164:     if status.get(\"error\"):\n165:         table.add_row(\"Error\", f\"[red]{status['error']}[/red]\")\n166: \n167:     console.print(table)\n168: \n169: \n170: @app.callback()\n171: def main(\n172:     version: Optional[bool] = typer.Option(\n173:         None,\n174:         \"--version\",\n175:         help=\"Show version and exit\",\n176:         callback=version_callback,\n177:         is_eager=True,\n178:     ),\n179:     verbose: bool = typer.Option(False, \"--verbose\", \"-v\", help=\"Enable verbose output\"),\n180: ) -> None:\n181:     \"\"\"AgentCube CLI - A developer tool for AI agent lifecycle management.\"\"\"\n182:     if verbose:\n183:         logging.basicConfig(level=logging.DEBUG)\n184: \n185: \n186: @app.command()\n187: def pack(\n188:     workspace: str = typer.Option(\n189:         \".\",\n190:         \"-f\",\n191:         \"--workspace\",\n192:         help=\"Path to the agent workspace directory\",\n193:         show_default=True,\n194:     ),\n195:     agent_name: Optional[str] = typer.Option(None, \"--agent-name\", help=\"Override the agent name\"),\n196:     language: Optional[str] = typer.Option(\n197:         None, \"--language\", help=\"Programming language (python, java)\"\n198:     ),\n199:     entrypoint: Optional[str] = typer.Option(\n200:         None, \"--entrypoint\", help=\"Override the entrypoint command\"\n201:     ),\n202:     port: Optional[int] = typer.Option(None, \"--port\", help=\"Port to expose in the Dockerfile\"),\n203:     build_mode: Optional[str] = typer.Option(\n204:         None, \"--build-mode\", help=\"Build strategy: local or cloud\"\n205:     ),\n206:     description: Optional[str] = typer.Option(None, \"--description\", help=\"Agent description\"),\n207:     output: Optional[str] = typer.Option(\n208:         None, \"--output\", help=\"Output path for packaged workspace\"\n209:     ),\n210:     verbose: bool = typer.Option(False, \"--verbose\", help=\"Enable detailed logging\"),\n211: ) -> None:\n212:     \"\"\"Pack an agent workspace for building and publishing.\n213: \n214:     This command validates the workspace structure, processes metadata,\n215:     handles dependencies, and optionally generates a Dockerfile.\n216:     \"\"\"\n217:     workspace_path = Path(workspace)\n218: \n219:     # Create PackRuntime with verbose flag\n220:     runtime = PackRuntime(verbose=verbose)\n221: \n222:     try:\n223:         with Progress(\n224:             SpinnerColumn(),\n225:             TextColumn(\"[progress.description]{task.description}\"),\n226:             console=console,\n227:             transient=True,\n228:         ) as progress:\n229:             task = progress.add_task(\"Packing agent workspace...\", total=None)\n230: \n231:             result = runtime.pack(\n232:                 workspace_path,\n233:                 agent_name=agent_name,\n234:                 language=language,\n235:                 entrypoint=entrypoint,\n236:                 port=port,\n237:                 build_mode=build_mode,\n238:                 description=description,\n239:                 output=output,\n240:                 verbose=verbose,\n241:             )\n242: \n243:             progress.update(task, completed=True)\n244: \n245:         # Print success message\n246:         console.print(\"[green]✓[/green] Successfully packed agent workspace\")\n247:         console.print(f\"  Agent name: [cyan]{result['agent_name']}[/cyan]\")\n248:         console.print(f\"  Workspace: [cyan]{result['workspace_path']}[/cyan]\")\n249:         console.print(f\"  Metadata: [cyan]{result['metadata_path']}[/cyan]\")\n250: \n251:     except Exception as e:\n252:         _handle_error(e, \"packing agent\", verbose)\n253: \n254: \n255: @app.command()\n256: def build(\n257:     workspace: str = typer.Option(\n258:         \".\",\n259:         \"-f\",\n260:         \"--workspace\",\n261:         help=\"Path to the agent workspace directory\",\n262:         show_default=True,\n263:     ),\n264:     proxy: Optional[str] = typer.Option(\n265:         None, \"-p\", \"--proxy\", help=\"Custom proxy URL for dependency resolution\"\n266:     ),\n267:     cloud_provider: Optional[str] = typer.Option(\n268:         None, \"--cloud-provider\", help=\"Cloud provider name (e.g., huawei)\"\n269:     ),\n270:     output: Optional[str] = typer.Option(None, \"--output\", help=\"Output path for build artifacts\"),\n271:     verbose: bool = typer.Option(False, \"--verbose\", help=\"Enable detailed logging\"),\n272: ) -> None:\n273:     \"\"\"Build an agent image from the packaged workspace.\n274: \n275:     This command builds a container image from the agent workspace,\n276:     either locally or using a cloud build service.\n277:     \"\"\"\n278:     workspace_path = Path(workspace).resolve()\n279: \n280:     # Create BuildRuntime with verbose flag\n281:     runtime = BuildRuntime(verbose=verbose)\n282: \n283:     try:\n284:         # Show build header\n285:         console.print(f\"Building agent from [cyan]{workspace_path}[/cyan]...\")\n286:         if verbose:\n287:             console.print(f\"  Proxy: {proxy or 'None'}\")\n288:             console.print(f\"  Cloud provider: {cloud_provider or 'None'}\")\n289:             console.print(f\"  Output: {output or 'Default'}\")\n290: \n291:         with Progress(\n292:             SpinnerColumn(),\n293:             TextColumn(\"[progress.description]{task.description}\"),\n294:             console=console,\n295:             transient=True,\n296:         ) as progress:\n297:             task = progress.add_task(\"Building agent image...\", total=None)\n298: \n299:             # Prepare build options\n300:             build_options: dict[str, Optional[str]] = {}\n301:             if proxy:\n302:                 build_options[\"proxy\"] = proxy\n303:             if cloud_provider:\n304:                 build_options[\"cloud_provider\"] = cloud_provider\n305:             if output:\n306:                 build_options[\"output\"] = output\n307: \n308:             result = runtime.build(workspace_path, **build_options)\n309: \n310:             progress.update(task, completed=True)\n311: \n312:         # Print success message with build details\n313:         console.print()\n314:         console.print(\"[green]✓[/green] Build completed successfully!\")\n315:         console.print()\n316:         console.print(f\"  Image: [cyan]{result['image_name']}:{result['image_tag']}[/cyan]\")\n317:         console.print(f\"  Image ID: [cyan]{result['image_id']}[/cyan]\")\n318:         console.print(f\"  Image Size: [cyan]{result['image_size']}[/cyan]\")\n319:         console.print(f\"  Build Time: [cyan]{result['build_time']}s[/cyan]\")\n320:         console.print(f\"  Build Mode: [cyan]{result['build_mode']}[/cyan]\")\n321:         console.print()\n322:         console.print(f\"  Metadata updated: [cyan]{result['metadata_path']}[/cyan]\")\n323: \n324:     except FileNotFoundError as e:\n325:         console.print(f\"Error building agent: {e}\", style=\"red\")\n326:         if verbose:\n327:             console.print_exception()\n328:         raise typer.Exit(1)\n329:     except ValueError as e:\n330:         console.print(f\"Error building agent: {e}\", style=\"red\")\n331:         if verbose:\n332:             console.print_exception()\n333:         raise typer.Exit(1)\n334:     except RuntimeError as e:\n335:         console.print(f\"Error building agent: {e}\", style=\"red\")\n336:         if verbose:\n337:             console.print_exception()\n338:         raise typer.Exit(1)\n339:     except Exception as e:\n340:         _handle_error(e, \"building agent\", verbose)\n341: \n342: \n343: @app.command()\n344: def publish(\n345:     workspace: str = typer.Option(\n346:         \".\",\n347:         \"-f\",\n348:         \"--workspace\",\n349:         help=\"Path to the agent workspace directory\",\n350:         show_default=True,\n351:     ),\n352:     version: Optional[str] = typer.Option(\n353:         None, \"--version\", help=\"Semantic version string (e.g., v1.0.0)\"\n354:     ),\n355:     image_url: Optional[str] = typer.Option(\n356:         None, \"--image-url\", help=\"Image repository URL (required in local build mode)\"\n357:     ),\n358:     image_username: Optional[str] = typer.Option(\n359:         None, \"--image-username\", help=\"Username for image repository\"\n360:     ),\n361:     image_password: Optional[str] = typer.Option(\n362:         None, \"--image-password\", help=\"Password for image repository\"\n363:     ),\n364:     description: Optional[str] = typer.Option(None, \"--description\", help=\"Agent description\"),\n365:     region: Optional[str] = typer.Option(None, \"--region\", help=\"Deployment region\"),\n366:     cloud_provider: Optional[str] = typer.Option(\n367:         None, \"--cloud-provider\", help=\"Cloud provider name (e.g., huawei)\"\n368:     ),\n369:     provider: str = typer.Option(\n370:         \"agentcube\",\n371:         \"--provider\",\n372:         help=\"Target provider: 'agentcube' (AgentRuntime CR) or 'k8s' (Deployment/Service)\",\n373:     ),\n374:     node_port: Optional[int] = typer.Option(\n375:         None, \"--node-port\", help=\"Specific NodePort to use (30000-32767) for K8s deployment\"\n376:     ),\n377:     replicas: Optional[int] = typer.Option(\n378:         None, \"--replicas\", help=\"Number of replicas for K8s deployment (default: 1)\"\n379:     ),\n380:     namespace: Optional[str] = typer.Option(\n381:         None, \"--namespace\", help=\"The namespace for the deployment\"\n382:     ),\n383:     verbose: bool = typer.Option(False, \"--verbose\", help=\"Enable detailed logging\"),\n384: ) -> None:\n385:     \"\"\"Publish an agent to the AgentCube platform or Kubernetes.\n386: \n387:     This command publishes the agent image to a registry and deploys\n388:     it to the target platform.\n389:     \"\"\"\n390:     workspace_path = Path(workspace).resolve()\n391: \n392:     # Create PublishRuntime with verbose flag\n393:     runtime = PublishRuntime(verbose=verbose, provider=provider)\n394: \n395:     try:\n396:         # Show publish header\n397:         console.print(f\"Publishing agent from [cyan]{workspace_path}[/cyan]...\")\n398:         if verbose:\n399:             console.print(f\"  Provider: {provider}\")\n400:             console.print(f\"  Namespace: {namespace or 'default'}\")\n401:             console.print(f\"  Image URL: {image_url or 'from metadata'}\")\n402:             if node_port:\n403:                 console.print(f\"  NodePort: {node_port}\")\n404:             if replicas:\n405:                 console.print(f\"  Replicas: {replicas}\")\n406: \n407:         with Progress(\n408:             SpinnerColumn(),\n409:             TextColumn(\"[progress.description]{task.description}\"),\n410:             console=console,\n411:             transient=True,\n412:         ) as progress:\n413:             task = progress.add_task(\"Publishing agent...\", total=None)\n414: \n415:             # Prepare publish options\n416:             publish_options: dict[str, Any] = {\n417:                 \"provider\": provider,\n418:             }\n419:             if version:\n420:                 publish_options[\"version\"] = version\n421:             if image_url:\n422:                 publish_options[\"image_url\"] = image_url\n423:             if image_username:\n424:                 publish_options[\"image_username\"] = image_username\n425:             if image_password:\n426:                 publish_options[\"image_password\"] = image_password\n427:             if description:\n428:                 publish_options[\"description\"] = description\n429:             if region:\n430:                 publish_options[\"region\"] = region\n431:             if cloud_provider:\n432:                 publish_options[\"cloud_provider\"] = cloud_provider\n433:             if node_port:\n434:                 publish_options[\"node_port\"] = node_port\n435:             if replicas:\n436:                 publish_options[\"replicas\"] = replicas\n437:             if namespace:\n438:                 publish_options[\"namespace\"] = namespace\n439:             if verbose:\n440:                 publish_options[\"verbose\"] = verbose\n441: \n442:             result = runtime.publish(workspace_path, **publish_options)\n443: \n444:             progress.update(task, completed=True)\n445: \n446:         # Print success message with deployment details\n447:         console.print()\n448:         console.print(\"[green]✓[/green] Publish completed successfully!\")\n449:         console.print()\n450:         console.print(f\"  Agent ID: [cyan]{result['agent_id']}[/cyan]\")\n451:         console.print(f\"  Provider: [cyan]{result['provider']}[/cyan]\")\n452:         console.print(f\"  Status: [cyan]{result['status']}[/cyan]\")\n453:         if result.get(\"agent_endpoint\"):\n454:             console.print(f\"  Endpoint: [cyan]{result['agent_endpoint']}[/cyan]\")\n455:         if result.get(\"k8s_deployment\"):\n456:             k8s_dep = result[\"k8s_deployment\"]\n457:             console.print(f\"  Deployment: [cyan]{k8s_dep.get('type')}[/cyan]\")\n458:             console.print(f\"    Name: [cyan]{k8s_dep.get('name')}[/cyan]\")\n459:             console.print(f\"    Namespace: [cyan]{k8s_dep.get('namespace')}[/cyan]\")\n460:             if k8s_dep.get(\"node_port\"):\n461:                 console.print(f\"    NodePort: [cyan]{k8s_dep.get('node_port')}[/cyan]\")\n462:             if k8s_dep.get(\"replicas\"):\n463:                 console.print(f\"    Replicas: [cyan]{k8s_dep.get('replicas')}[/cyan]\")\n464:         console.print()\n465:         console.print(f\"  Metadata updated: [cyan]{workspace_path / 'agent_metadata.yaml'}[/cyan]\")\n466: \n467:     except ValueError as e:\n468:         console.print(f\"Error publishing agent: {e}\", style=\"red\")\n469:         if verbose:\n470:             console.print_exception()\n471:         raise typer.Exit(1)\n472:     except FileNotFoundError as e:\n473:         console.print(f\"Error publishing agent: {e}\", style=\"red\")\n474:         if verbose:\n475:             console.print_exception()\n476:         raise typer.Exit(1)\n477:     except RuntimeError as e:\n478:         console.print(f\"Error publishing agent: {e}\", style=\"red\")\n479:         if verbose:\n480:             console.print_exception()\n481:         raise typer.Exit(1)\n482:     except TimeoutError as e:\n483:         console.print(f\"Error publishing agent: {e}\", style=\"red\")\n484:         if verbose:\n485:             console.print_exception()\n486:         raise typer.Exit(1)\n487:     except Exception as e:\n488:         _handle_error(e, \"publishing agent\", verbose)\n489: \n490: \n491: @app.command()\n492: def invoke(\n493:     workspace: str = typer.Option(\n494:         \".\",\n495:         \"-f\",\n496:         \"--workspace\",\n497:         help=\"Path to the agent workspace directory\",\n498:         show_default=True,\n499:     ),\n500:     payload: str = typer.Option(\"{}\", \"--payload\", help=\"JSON-formatted input passed to the agent\"),\n501:     header_list: Optional[list[str]] = typer.Option(\n502:         None,\n503:         \"--header\",\n504:         help=\"Custom HTTP headers (e.g., 'Authorization: Bearer token'). Can be specified multiple times.\",\n505:     ),\n506:     provider: str = typer.Option(\n507:         \"agentcube\",\n508:         \"--provider\",\n509:         help=\"Target provider: 'agentcube' (AgentRuntime CR) or 'k8s' (Deployment/Service)\",\n510:     ),\n511:     verbose: bool = typer.Option(False, \"--verbose\", help=\"Enable detailed logging\"),\n512: ) -> None:\n513:     \"\"\"Invoke an agent with a payload.\n514: \n515:     This command sends a request to the deployed agent with the\n516:     specified payload and displays the response.\n517:     \"\"\"\n518:     workspace_path = Path(workspace).resolve()\n519: \n520:     # Parse payload\n521:     parsed_payload = _parse_payload(payload)\n522: \n523:     # Parse headers\n524:     headers = _parse_headers(header_list)\n525: \n526:     # Create InvokeRuntime with verbose flag\n527:     runtime = InvokeRuntime(verbose=verbose, provider=provider)\n528: \n529:     try:\n530:         # Show invoke header\n531:         console.print(f\"Invoking agent from [cyan]{workspace_path}[/cyan]...\")\n532:         if verbose:\n533:             console.print(f\"  Provider: {provider}\")\n534:             console.print(f\"  Payload: {json.dumps(parsed_payload, indent=2)}\")\n535:             if headers:\n536:                 console.print(f\"  Headers: {headers}\")\n537: \n538:         with Progress(\n539:             SpinnerColumn(),\n540:             TextColumn(\"[progress.description]{task.description}\"),\n541:             console=console,\n542:             transient=True,\n543:         ) as progress:\n544:             task = progress.add_task(\"Invoking agent...\", total=None)\n545: \n546:             result = runtime.invoke(\n547:                 workspace_path=workspace_path,\n548:                 payload=parsed_payload,\n549:                 headers=headers if headers else None,\n550:             )\n551: \n552:             progress.update(task, completed=True)\n553: \n554:         # Print success message with response\n555:         console.print()\n556:         console.print(\"[green]✓[/green] Agent invocation completed!\")\n557:         console.print()\n558:         console.print(\"[cyan]Response:[/cyan]\")\n559:         console.print_json(data=result)\n560: \n561:     except FileNotFoundError as e:\n562:         console.print(f\"Error invoking agent: {e}\", style=\"red\")\n563:         if verbose:\n564:             console.print_exception()\n565:         raise typer.Exit(1)\n566:     except ValueError as e:\n567:         console.print(f\"Error invoking agent: {e}\", style=\"red\")\n568:         if verbose:\n569:             console.print_exception()\n570:         raise typer.Exit(1)\n571:     except TimeoutError as e:\n572:         console.print(f\"Error invoking agent: {e}\", style=\"red\")\n573:         if verbose:\n574:             console.print_exception()\n575:         raise typer.Exit(1)\n576:     except Exception as e:\n577:         _handle_error(e, \"invoking agent\", verbose)\n578: \n579: \n580: @app.command()\n581: def status(\n582:     workspace: str = typer.Option(\n583:         \".\",\n584:         \"-f\",\n585:         \"--workspace\",\n586:         help=\"Path to the agent workspace directory\",\n587:         show_default=True,\n588:     ),\n589:     provider: str = typer.Option(\n590:         \"agentcube\",\n591:         \"--provider\",\n592:         help=\"Target provider: 'agentcube' (AgentRuntime CR) or 'k8s' (Deployment/Service)\",\n593:     ),\n594:     verbose: bool = typer.Option(False, \"--verbose\", help=\"Enable detailed logging\"),\n595: ) -> None:\n596:     \"\"\"Check the status of a deployed agent.\n597: \n598:     This command retrieves the current status of the agent deployment\n599:     from the target platform.\n600:     \"\"\"\n601:     workspace_path = Path(workspace).resolve()\n602: \n603:     # Create StatusRuntime with verbose flag\n604:     runtime = StatusRuntime(verbose=verbose, provider=provider)\n605: \n606:     try:\n607:         # Show status header\n608:         console.print(f\"Checking status for [cyan]{workspace_path}[/cyan]...\")\n609:         if verbose:\n610:             console.print(f\"  Provider: {provider}\")\n611: \n612:         with Progress(\n613:             SpinnerColumn(),\n614:             TextColumn(\"[progress.description]{task.description}\"),\n615:             console=console,\n616:             transient=True,\n617:         ) as progress:\n618:             task = progress.add_task(\"Retrieving status...\", total=None)\n619: \n620:             status_result = runtime.get_status(workspace_path=workspace_path)\n621: \n622:             progress.update(task, completed=True)\n623: \n624:         # Display status table\n625:         console.print()\n626:         _display_status_table(status_result)\n627: \n628:         # Exit with appropriate code based on status\n629:         status_value = status_result.get(\"status\", \"unknown\")\n630:         if status_value in (\"not_published\", \"error\", \"not_found\", \"not_found_in_k8s\", \"not_ready\"):\n631:             raise typer.Exit(1)\n632: \n633:     except FileNotFoundError as e:\n634:         console.print(f\"Error checking status: {e}\", style=\"red\")\n635:         if verbose:\n636:             console.print_exception()\n637:         raise typer.Exit(1)\n638:     except ValueError as e:\n639:         console.print(f\"Error checking status: {e}\", style=\"red\")\n640:         if verbose:\n641:             console.print_exception()\n642:         raise typer.Exit(1)\n643:     except Exception as e:\n644:         _handle_error(e, \"checking status\", verbose)\n645: \n646: \n647: if __name__ == \"__main__\":\n648:     app()\n\n(End of file - total 648 lines)\n</content>","metadata":{"preview":"\"\"\"Main CLI module for AgentCube.\n\nThis module provides the Typer-based CLI application with all commands\nfor agent lifecycle management including pack, build, publish, i