{"type":"tool_use","timestamp":1775850394195,"sessionID":"ses_28711a618ffe3Venx6ULlhg9No","part":{"id":"prt_d78ee892c001OdZyvItV7nCG0l","messageID":"msg_d78ee7cfa001CIzDpCq2rGYzQL","sessionID":"ses_28711a618ffe3Venx6ULlhg9No","type":"tool","tool":"read","callID":"toolu_functions.read:3","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/workloadmanager/lifecycle/types.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/workloadmanager/lifecycle/types.go</path>\n<type>file</type>\n<content>\n1: /*\n2: Copyright 2026 The Volcano Authors.\n3: \n4: Licensed under the Apache License, Version 2.0 (the \"License\");\n5: you may not use this file except in compliance with the License.\n6: You may obtain a copy of the License at\n7: \n8:     http://www.apache.org/licenses/LICENSE-2.0\n9: \n10: Unless required by applicable law or agreed to in writing, software\n11: distributed under the License is distributed on an \"AS IS\" BASIS,\n12: WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n13: See the License for the specific language governing permissions and\n14: limitations under the License.\n15: */\n16: \n17: // Package lifecycle provides sandbox lifecycle management functionality.\n18: package lifecycle\n19: \n20: import (\n21: \t\"context\"\n22: \t\"time\"\n23: \n24: \tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n25: \n26: \t\"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1\"\n27: \t\"github.com/volcano-sh/agentcube/pkg/workloadmanager/types\"\n28: )\n29: \n30: // DeletionMode represents the mode of deletion for a sandbox.\n31: type DeletionMode string\n32: \n33: const (\n34: \t// DeletionModeGraceful performs a graceful shutdown with cleanup.\n35: \tDeletionModeGraceful DeletionMode = \"graceful\"\n36: \n37: \t// DeletionModeForce performs an immediate force deletion.\n38: \tDeletionModeForce DeletionMode = \"force\"\n39: \n40: \t// DeletionModeOrphan removes the resource without cleaning up the sandbox.\n41: \tDeletionModeOrphan DeletionMode = \"orphan\"\n42: )\n43: \n44: // LifecyclePhase represents the lifecycle phase of a sandbox.\n45: type LifecyclePhase string\n46: \n47: const (\n48: \t// LifecyclePhasePending indicates the sandbox is pending creation.\n49: \tLifecyclePhasePending LifecyclePhase = \"Pending\"\n50: \n51: \t// LifecyclePhaseCreating indicates the sandbox is being created.\n52: \tLifecyclePhaseCreating LifecyclePhase = \"Creating\"\n53: \n54: \t// LifecyclePhaseRunning indicates the sandbox is running.\n55: \tLifecyclePhaseRunning LifecyclePhase = \"Running\"\n56: \n57: \t// LifecyclePhaseTerminating indicates the sandbox is being terminated.\n58: \tLifecyclePhaseTerminating LifecyclePhase = \"Terminating\"\n59: \n60: \t// LifecyclePhaseTerminated indicates the sandbox has been terminated.\n61: \tLifecyclePhaseTerminated LifecyclePhase = \"Terminated\"\n62: \n63: \t// LifecyclePhaseFailed indicates the sandbox has failed.\n64: \tLifecyclePhaseFailed LifecyclePhase = \"Failed\"\n65: )\n66: \n67: // DeletionReason represents the reason for sandbox deletion.\n68: type DeletionReason string\n69: \n70: const (\n71: \t// DeletionReasonUserRequested indicates user-requested deletion.\n72: \tDeletionReasonUserRequested DeletionReason = \"UserRequested\"\n73: \n74: \t// DeletionReasonTTLExpired indicates TTL has expired.\n75: \tDeletionReasonTTLExpired DeletionReason = \"TTLExpired\"\n76: \n77: \t// DeletionReasonIdleTimeout indicates idle timeout has been reached.\n78: \tDeletionReasonIdleTimeout DeletionReason = \"IdleTimeout\"\n79: \n80: \t// DeletionReasonMaxLifetime indicates maximum lifetime has been reached.\n81: \tDeletionReasonMaxLifetime DeletionReason = \"MaxLifetimeExceeded\"\n82: \n83: \t// DeletionReasonFailed indicates deletion due to failure.\n84: \tDeletionReasonFailed DeletionReason = \"Failed\"\n85: \n86: \t// DeletionReasonCleanup indicates deletion for cleanup purposes.\n87: \tDeletionReasonCleanup DeletionReason = \"Cleanup\"\n88: )\n89: \n90: // SandboxResource represents a sandbox resource with its metadata and spec.\n91: type SandboxResource struct {\n92: \t// Type is the workload type.\n93: \tType types.WorkloadType\n94: \n95: \t// Namespace is the Kubernetes namespace.\n96: \tNamespace string\n97: \n98: \t// Name is the resource name.\n99: \tName string\n100: \n101: \t// UID is the unique identifier.\n102: \tUID string\n103: \n104: \t// CreationTime is when the resource was created.\n105: \tCreationTime *metav1.Time\n106: \n107: \t// DeletionTime is when the resource is scheduled for deletion.\n108: \tDeletionTime *metav1.Time\n109: \n110: \t// Spec contains the resource spec.\n111: \tSpec interface{}\n112: \n113: \t// Status contains the resource status.\n114: \tStatus interface{}\n115: \n116: \t// Finalizers are the resource finalizers.\n117: \tFinalizers []string\n118: }\n119: \n120: // SandboxState represents the current state of a sandbox.\n121: type SandboxState struct {\n122: \t// Phase is the current lifecycle phase.\n123: \tPhase LifecyclePhase\n124: \n125: \t// DeletionMode is the current deletion mode.\n126: \tDeletionMode DeletionMode\n127: \n128: \t// DeletionReason is the reason for deletion.\n129: \tDeletionReason DeletionReason\n130: \n131: \t// StartTime is when the sandbox started.\n132: \tStartTime *time.Time\n133: \n134: \t// CompletionTime is when the sandbox completed.\n135: \tCompletionTime *time.Time\n136: \n137: \t// LastActivityTime is the time of last activity.\n138: \tLastActivityTime *time.Time\n139: \n140: \t// DeletionTimestamp is when deletion was requested.\n141: \tDeletionTimestamp *time.Time\n142: \n143: \t// GracePeriodEnd is when the grace period ends.\n144: \tGracePeriodEnd *time.Time\n145: \n146: \t// TTLExpired indicates if TTL has expired.\n147: \tTTLExpired bool\n148: \n149: \t// IdleTimedOut indicates if idle timeout has been reached.\n150: \tIdleTimedOut bool\n151: \n152: \t// MaxLifetimeReached indicates if max lifetime has been reached.\n153: \tMaxLifetimeReached bool\n154: }\n155: \n156: // DeletionRequest represents a request to delete a sandbox.\n157: type DeletionRequest struct {\n158: \t// Namespace is the resource namespace.\n159: \tNamespace string\n160: \n161: \t// Name is the resource name.\n162: \tName string\n163: \n164: \t// Type is the workload type.\n165: \tType types.WorkloadType\n166: \n167: \t// Mode is the deletion mode.\n168: \tMode DeletionMode\n169: \n170: \t// GracePeriodSeconds is the grace period for graceful deletion.\n171: \tGracePeriodSeconds *int64\n172: \n173: \t// Reason is the reason for deletion.\n174: \tReason DeletionReason\n175: \n176: \t// ForceDeletePods forces deletion of pods even if not owned.\n177: \tForceDeletePods bool\n178: \n179: \t// PropagationPolicy controls how dependent resources are deleted.\n180: \tPropagationPolicy string\n181: }\n182: \n183: // DeletionResult represents the result of a deletion operation.\n184: type DeletionResult struct {\n185: \t// Success indicates if deletion was successful.\n186: \tSuccess bool\n187: \n188: \t// Deleted indicates if the resource was actually deleted.\n189: \tDeleted bool\n190: \n191: \t// FinalizersRemoved indicates if finalizers were removed.\n192: \tFinalizersRemoved bool\n193: \n194: \t// PodsDeleted indicates how many pods were deleted.\n195: \tPodsDeleted int\n196: \n197: \t// Message provides additional information.\n198: \tMessage string\n199: \n200: \t// Error contains any error that occurred.\n201: \tError error\n202: \n203: \t// CompletedAt is when the deletion completed.\n204: \tCompletedAt time.Time\n205: }\n206: \n207: // TTLConfig represents TTL (time-to-live) configuration.\n208: type TTLConfig struct {\n209: \t// TTLSecondsAfterFinished is the TTL after the resource finishes.\n210: \tTTLSecondsAfterFinished *int32\n211: \n212: \t// IdleTimeoutSeconds is the maximum idle time.\n213: \tIdleTimeoutSeconds *int32\n214: \n215: \t// MaxLifetimeSeconds is the maximum total lifetime.\n216: \tMaxLifetimeSeconds *int32\n217: \n218: \t// GracePeriodSeconds is the grace period for termination.\n219: \tGracePeriodSeconds *int64\n220: }\n221: \n222: // TTLStatus represents the current TTL status.\n223: type TTLStatus struct {\n224: \t// ExpirationTime is when the resource will expire.\n225: \tExpirationTime *time.Time\n226: \n227: \t// RemainingTTL is the remaining TTL duration.\n228: \tRemainingTTL time.Duration\n229: \n230: \t// IsExpired indicates if the resource has expired.\n231: \tIsExpired bool\n232: \n233: \t// ExpirationReason is the reason for expiration.\n234: \tExpirationReason DeletionReason\n235: }\n236: \n237: // LifecycleEvent represents a lifecycle event.\n238: type LifecycleEvent struct {\n239: \t// Type is the event type.\n240: \tType string\n241: \n242: \t// Resource is the affected resource.\n243: \tResource *SandboxResource\n244: \n245: \t// State is the current state.\n246: \tState *SandboxState\n247: \n248: \t// Timestamp is when the event occurred.\n249: \tTimestamp time.Time\n250: \n251: \t// Message is the event message.\n252: \tMessage string\n253: }\n254: \n255: // EventHandler is called when lifecycle events occur.\n256: type EventHandler func(ctx context.Context, event *LifecycleEvent) error\n257: \n258: // LifecycleManager defines the interface for lifecycle management.\n259: type LifecycleManager interface {\n260: \t// Initialize initializes the lifecycle manager.\n261: \tInitialize(ctx context.Context) error\n262: \n263: \t// Shutdown shuts down the lifecycle manager.\n264: \tShutdown(ctx context.Context) error\n265: \n266: \t// RegisterSandbox registers a sandbox for lifecycle management.\n267: \tRegisterSandbox(ctx context.Context, resource *SandboxResource, config *TTLConfig) error\n268: \n269: \t// UnregisterSandbox unregisters a sandbox from lifecycle management.\n270: \tUnregisterSandbox(ctx context.Context, namespace, name string, workloadType types.WorkloadType) error\n271: \n272: \t// GetSandboxState returns the current lifecycle state of a sandbox.\n273: \tGetSandboxState(ctx context.Context, namespace, name string, workloadType types.WorkloadType) (*SandboxState, error)\n274: \n275: \t// UpdateActivity updates the last activity time for a sandbox.\n276: \tUpdateActivity(ctx context.Context, namespace, name string, workloadType types.WorkloadType) error\n277: \n278: \t// MarkCompleted marks a sandbox as completed.\n279: \tMarkCompleted(ctx context.Context, namespace, name string, workloadType types.WorkloadType, success bool) error\n280: \n281: \t// DeleteSandbox initiates deletion of a sandbox.\n282: \tDeleteSandbox(ctx context.Context, req *DeletionRequest) (*DeletionResult, error)\n283: \n284: \t// RegisterEventHandler registers an event handler.\n285: \tRegisterEventHandler(handler EventHandler)\n286: \n287: \t// UnregisterEventHandler unregisters an event handler.\n288: \tUnregisterEventHandler(handler EventHandler)\n289: }\n290: \n291: // ResourceDeleter defines the interface for deleting resources.\n292: type ResourceDeleter interface {\n293: \t// Delete deletes a resource.\n294: \tDelete(ctx context.Context, namespace, name string, workloadType types.WorkloadType, gracePeriodSeconds *int64) error\n295: \n296: \t// DeleteWithOptions deletes a resource with options.\n297: \tDeleteWithOptions(ctx context.Context, namespace, name string, workloadType types.WorkloadType, opts *DeleteOptions) error\n298: \n299: \t// RemoveFinalizers removes finalizers from a resource.\n300: \tRemoveFinalizers(ctx context.Context, namespace, name string, workloadType types.WorkloadType, finalizers []string) error\n301: \n302: \t// ListPods lists pods owned by a resource.\n303: \tListPods(ctx context.Context, namespace, name string, workloadType types.WorkloadType) ([]PodInfo, error)\n304: \n305: \t// DeletePod deletes a pod.\n306: \tDeletePod(ctx context.Context, namespace, name string, gracePeriodSeconds *int64, force bool) error\n307: }\n308: \n309: // DeleteOptions contains options for deletion.\n310: type DeleteOptions struct {\n311: \t// GracePeriodSeconds is the grace period.\n312: \tGracePeriodSeconds *int64\n313: \n314: \t// PropagationPolicy controls propagation.\n315: \tPropagationPolicy string\n316: \n317: \t// Preconditions must be true for deletion.\n318: \tPreconditions *Preconditions\n319: \n320: \t// OrphanDependents orphans dependents.\n321: \tOrphanDependents *bool\n322: }\n323: \n324: // Preconditions contains deletion preconditions.\n325: type Preconditions struct {\n326: \t// UID is the expected UID.\n327: \tUID string\n328: \n329: \t// ResourceVersion is the expected resource version.\n330: \tResourceVersion string\n331: }\n332: \n333: // PodInfo contains information about a pod.\n334: type PodInfo struct {\n335: \t// Name is the pod name.\n336: \tName string\n337: \n338: \t// Namespace is the pod namespace.\n339: \tNamespace string\n340: \n341: \t// UID is the pod UID.\n342: \tUID string\n343: \n344: \t// Phase is the pod phase.\n345: \tPhase string\n346: \n347: \t// DeletionTimestamp is when deletion was requested.\n348: \tDeletionTimestamp *time.Time\n349: }\n350: \n351: // Config contains lifecycle manager configuration.\n352: type Config struct {\n353: \t// SyncInterval is the interval for syncing sandbox states.\n354: \tSyncInterval time.Duration\n355: \n356: \t// DefaultGracePeriod is the default grace period.\n357: \tDefaultGracePeriod time.Duration\n358: \n359: \t// MaxGracePeriod is the maximum grace period.\n360: \tMaxGracePeriod time.Duration\n361: \n362: \t// EnableTTLCleanup enables TTL-based cleanup.\n363: \tEnableTTLCleanup bool\n364: \n365: \t// EnableIdleTimeout enables idle timeout cleanup.\n366: \tEnableIdleTimeout bool\n367: \n368: \t// CleanupInterval is the interval for cleanup checks.\n369: \tCleanupInterval time.Duration\n370: \n371: \t// EventBufferSize is the buffer size for event channels.\n372: \tEventBufferSize int\n373: \n374: \t// MaxConcurrentDeletions is the maximum concurrent deletions.\n375: \tMaxConcurrentDeletions int\n376: }\n377: \n378: // DefaultConfig returns a default configuration.\n379: func DefaultConfig() *Config {\n380: \treturn &Config{\n381: \t\tSyncInterval:           30 * time.Second,\n382: \t\tDefaultGracePeriod:     30 * time.Second,\n383: \t\tMaxGracePeriod:         5 * time.Minute,\n384: \t\tEnableTTLCleanup:       true,\n385: \t\tEnableIdleTimeout:      true,\n386: \t\tCleanupInterval:        10 * time.Second,\n387: \t\tEventBufferSize:        100,\n388: \t\tMaxConcurrentDeletions: 10,\n389: \t}\n390: }\n391: \n392: // Validate validates the configuration.\n393: func (c *Config) Validate() error {\n394: \tif c.SyncInterval <= 0 {\n395: \t\tc.SyncInterval = 30 * time.Second\n396: \t}\n397: \tif c.DefaultGracePeriod <= 0 {\n398: \t\tc.DefaultGracePeriod = 30 * time.Second\n399: \t}\n400: \tif c.MaxGracePeriod <= 0 {\n401: \t\tc.MaxGracePeriod = 5 * time.Minute\n402: \t}\n403: \tif c.CleanupInterval <= 0 {\n404: \t\tc.CleanupInterval = 10 * time.Second\n405: \t}\n406: \tif c.EventBufferSize <= 0 {\n407: \t\tc.EventBufferSize = 100\n408: \t}\n409: \tif c.MaxConcurrentDeletions <= 0 {\n410: \t\tc.MaxConcurrentDeletions = 10\n411: \t}\n412: \treturn nil\n413: }\n414: \n415: // GetDeletionGracePeriod returns the grace period for deletion.\n416: func GetDeletionGracePeriod(specGracePeriod, defaultGracePeriod, maxGracePeriod *int64) *int64 {\n417: \tvar gracePeriod int64\n418: \n419: \tif specGracePeriod != nil && *specGracePeriod >= 0 {\n420: \t\tgracePeriod = *specGracePeriod\n421: \t} else if defaultGracePeriod != nil && *defaultGracePeriod >= 0 {\n422: \t\tgracePeriod = *defaultGracePeriod\n423: \t} else {\n424: \t\tgracePeriod = 30\n425: \t}\n426: \n427: \tif maxGracePeriod != nil && gracePeriod > *maxGracePeriod {\n428: \t\tgracePeriod = *maxGracePeriod\n429: \t}\n430: \n431: \treturn &gracePeriod\n432: }\n433: \n434: // CalculateTTLStatus calculates the TTL status for a resource.\n435: func CalculateTTLStatus(\n436: \tcreationTime *metav1.Time,\n437: \tcompletionTime *metav1.Time,\n438: \tlastActivityTime *metav1.Time,\n439: \tconfig *TTLConfig,\n440: \tnow time.Time,\n441: ) *TTLStatus {\n442: \tstatus := &TTLStatus{\n443: \t\tIsExpired:    false,\n444: \t\tRemainingTTL: -1,\n445: \t}\n446: \n447: \tif config == nil {\n448: \t\treturn status\n449: \t}\n450: \n451: \t// Check TTL after finished\n452: \tif completionTime != nil && config.TTLSecondsAfterFinished != nil {\n453: \t\texpirationTime := completionTime.Time.Add(time.Duration(*config.TTLSecondsAfterFinished) * time.Second)\n454: \t\tstatus.ExpirationTime = &expirationTime\n455: \t\tstatus.RemainingTTL = expirationTime.Sub(now)\n456: \n457: \t\tif now.After(expirationTime) || now.Equal(expirationTime) {\n458: \t\t\tstatus.IsExpired = true\n459: \t\t\tstatus.ExpirationReason = DeletionReasonTTLExpired\n460: \t\t}\n461: \t\treturn status\n462: \t}\n463: \n464: \t// Check max lifetime\n465: \tif creationTime != nil && config.MaxLifetimeSeconds != nil {\n466: \t\texpirationTime := creationTime.Time.Add(time.Duration(*config.MaxLifetimeSeconds) * time.Second)\n467: \n468: \t\tif status.ExpirationTime == nil || expirationTime.Before(*status.ExpirationTime) {\n469: \t\t\tstatus.ExpirationTime = &expirationTime\n470: \t\t\tstatus.RemainingTTL = expirationTime.Sub(now)\n471: \n472: \t\t\tif now.After(expirationTime) || now.Equal(expirationTime) {\n473: \t\t\t\tstatus.IsExpired = true\n474: \t\t\t\tstatus.ExpirationReason = DeletionReasonMaxLifetime\n475: \t\t\t}\n476: \t\t}\n477: \t}\n478: \n479: \t// Check idle timeout\n480: \tif lastActivityTime != nil && config.IdleTimeoutSeconds != nil {\n481: \t\texpirationTime := lastActivityTime.Time.Add(time.Duration(*config.IdleTimeoutSeconds) * time.Second)\n482: \n483: \t\tif status.ExpirationTime == nil || expirationTime.Before(*status.ExpirationTime) {\n484: \t\t\tstatus.ExpirationTime = &expirationTime\n485: \t\t\tstatus.RemainingTTL = expirationTime.Sub(now)\n486: \n487: \t\t\tif now.After(expirationTime) || now.Equal(expirationTime) {\n488: \t\t\t\tstatus.IsExpired = true\n489: \t\t\t\tstatus.ExpirationReason = DeletionReasonIdleTimeout\n490: \t\t\t}\n491: \t\t}\n492: \t}\n493: \n494: \treturn status\n495: }\n496: \n497: // ExtractTTLConfig extracts TTL configuration from AgentRuntimeSpec.\n498: func ExtractTTLConfigFromAgentRuntime(spec *v1alpha1.AgentRuntimeSpec) *TTLConfig {\n499: \tif spec == nil {\n500: \t\treturn &TTLConfig{}\n501: \t}\n502: \n503: \treturn &TTLConfig{\n504: \t\tTTLSecondsAfterFinished: spec.TTLSecondsAfterFinished,\n505: \t\tIdleTimeoutSeconds:      spec.IdleTimeoutSeconds,\n506: \t\tMaxLifetimeSeconds:      spec.MaxLifetimeSeconds,\n507: \t\tGracePeriodSeconds:      nil, // Will use default\n508: \t}\n509: }\n510: \n511: // ExtractTTLConfigFromCodeInterpreter extracts TTL configuration from CodeInterpreterSpec.\n512: func ExtractTTLConfigFromCodeInterpreter(spec *v1alpha1.CodeInterpreterSpec) *TTLConfig {\n513: \tif spec == nil {\n514: \t\treturn &TTLConfig{}\n515: \t}\n516: \n517: \tconfig := &TTLConfig{\n518: \t\tGracePeriodSeconds: nil,\n519: \t}\n520: \n521: \t// Convert SessionTimeout to IdleTimeoutSeconds\n522: \tif spec.SessionTimeout != nil {\n523: \t\tidleTimeout := int32(spec.SessionTimeout.Duration.Seconds())\n524: \t\tconfig.IdleTimeoutSeconds = &idleTimeout\n525: \t}\n526: \n527: \t// Convert MaxSessionDuration to MaxLifetimeSeconds\n528: \tif spec.MaxSessionDuration != nil {\n529: \t\tmaxLifetime := int32(spec.MaxSessionDuration.Duration.Seconds())\n530: \t\tconfig.MaxLifetimeSeconds = &maxLifetime\n531: \t}\n532: \n533: \treturn config\n534: }\n535: \n536: // SandboxResourceKey creates a unique key for a sandbox resource.\n537: func SandboxResourceKey(namespace, name string, workloadType types.WorkloadType) string {\n538: \treturn namespace + \"/\" + string(workloadType) + \"/\" + name\n539: }\n\n(End of file - total 539 lines)\n</content>","metadata":{"preview":"/*\nCopyright 2026 The Volcano Authors.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\n// Package lifecycle provides sandbox lifecycle management functionality.\npackage lifecycle\n\nimport (","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/workloadmanager/lifecycle/types.go","time":{"start":1775850394164,"end":1775850394192}}}}
