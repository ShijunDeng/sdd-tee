 all resources.\n80: \tCategoryAll = \"all\"\n81: )\n82: \n83: // Common label and annotation keys used across AgentCube resources.\n84: const (\n85: \t// LabelManagedBy is the label key indicating the controller managing the resource.\n86: \tLabelManagedBy = \"app.kubernetes.io/managed-by\"\n87: \n88: \t// LabelCreatedBy is the label key indicating the creator of the resource.\n89: \tLabelCreatedBy = \"app.kubernetes.io/created-by\"\n90: \n91: \t// LabelComponent is the label key indicating the component type.\n92: \tLabelComponent = \"app.kubernetes.io/component\"\n93: \n94: \t// LabelInstance is the label key indicating the instance name.\n95: \tLabelInstance = \"app.kubernetes.io/instance\"\n96: \n97: \t// LabelPartOf is the label key indicating the application this resource is part of.\n98: \tLabelPartOf = \"app.kubernetes.io/part-of\"\n99: \n100: \t// LabelSandboxID is the label key for the sandbox ID.\n101: \tLabelSandboxID = \"runtime.agentcube.volcano.sh/sandbox-id\"\n102: \n103: \t// LabelSessionID is the label key for the session ID.\n104: \tLabelSessionID = \"runtime.agentcube.volcano.sh/session-id\"\n105: \n106: \t// LabelResourceType is the label key for the resource type.\n107: \tLabelResourceType = \"runtime.agentcube.volcano.sh/resource-type\"\n108: )\n109: \n110: // Common annotation keys used across AgentCube resources.\n111: const (\n112: \t// AnnotationDescription is the annotation key for resource description.\n113: \tAnnotationDescription = \"runtime.agentcube.volcano.sh/description\"\n114: \n115: \t// AnnotationCreatedAt is the annotation key for creation timestamp.\n116: \tAnnotationCreatedAt = \"runtime.agentcube.volcano.sh/created-at\"\n117: \n118: \t// AnnotationUpdatedAt is the annotation key for update timestamp.\n119: \tAnnotationUpdatedAt = \"runtime.agentcube.volcano.sh/updated-at\"\n120: \n121: \t// AnnotationLastAppliedConfiguration is the annotation key for the last applied configuration.\n122: \tAnnotationLastAppliedConfiguration = \"runtime.agentcube.volcano.sh/last-applied-configuration\"\n123: \n124: \t// AnnotationSandboxURL is the annotation key for the sandbox access URL.\n125: \tAnnotationSandboxURL = \"runtime.agentcube.volcano.sh/sandbox-url\"\n126: \n127: \t// AnnotationSandboxEndpoint is the annotation key for the sandbox endpoint.\n128: \tAnnotationSandboxEndpoint = \"runtime.agentcube.volcano.sh/sandbox-endpoint\"\n129: \n130: \t// AnnotationIdleTimeout is the annotation key for idle timeout.\n131: \tAnnotationIdleTimeout = \"runtime.agentcube.volcano.sh/idle-timeout\"\n132: \n133: \t// AnnotationMaxLifetime is the annotation key for maximum lifetime.\n134: \tAnnotationMaxLifetime = \"runtime.agentcube.volcano.sh/max-lifetime\"\n135: )\n136: \n137: // Condition reason constants for consistent condition reasoning.\n138: const (\n139: \t// ReasonCreating indicates the resource is being created.\n140: \tReasonCreating = \"Creating\"\n141: \n142: \t// ReasonCreated indicates the resource has been created.\n143: \tReasonCreated = \"Created\"\n144: \n145: \t// ReasonRunning indicates the resource is running.\n146: \tReasonRunning = \"Running\"\n147: \n148: \t// ReasonSucceeded indicates the resource has succeeded.\n149: \tReasonSucceeded = \"Succeeded\"\n150: \n151: \t// ReasonFailed indicates the resource has failed.\n152: \tReasonFailed = \"Failed\"\n153: \n154: \t// ReasonPending indicates the resource is pending.\n155: \tReasonPending = \"Pending\"\n156: \n157: \t// ReasonUnknown indicates the resource state is unknown.\n158: \tReasonUnknown = \"Unknown\"\n159: \n160: \t// ReasonScheduled indicates the resource has been scheduled.\n161: \tReasonScheduled = \"Scheduled\"\n162: \n163: \t// ReasonInitialized indicates the resource has been initialized.\n164: \tReasonInitialized = \"Initialized\"\n165: \n166: \t// ReasonTerminating indicates the resource is being terminated.\n167: \tReasonTerminating = \"Terminating\"\n168: \n169: \t// ReasonTerminated indicates the resource has been terminated.\n170: \tReasonTerminated = \"Terminated\"\n171: \n172: \t// ReasonSandboxCreating indicates the sandbox is being created.\n173: \tReasonSandboxCreating = \"SandboxCreating\"\n174: \n175: \t// ReasonSandboxCreated indicates the sandbox has been created.\n176: \tReasonSandboxCreated = \"SandboxCreated\"\n177: \n178: \t// ReasonSandboxReady indicates the sandbox is ready.\n179: \tReasonSandboxReady = \"SandboxReady\"\n180: \n181: \t// ReasonSandboxFailed indicates the sandbox creation failed.\n182: \tReasonSandboxFailed = \"SandboxFailed\"\n183: \n184: \t// ReasonCleanup indicates the resource is being cleaned up.\n185: \tReasonCleanup = \"Cleanup\"\n186: \n187: \t// ReasonTimeout indicates the resource has timed out.\n188: \tReasonTimeout = \"Timeout\"\n189: \n190: \t// ReasonIdle indicates the resource has been idle.\n191: \tReasonIdle = \"Idle\"\n192: )\n193: \n194: // Condition message constants for consistent condition messaging.\n195: const (\n196: \t// MessageCreating indicates the resource is being created.\n197: \tMessageCreating = \"Resource is being created\"\n198: \n199: \t// MessageRunning indicates the resource is running.\n200: \tMessageRunning = \"Resource is running and ready\"\n201: \n202: \t// MessageSucceeded indicates the resource has completed successfully.\n203: \tMessageSucceeded = \"Resource has completed successfully\"\n204: \n205: \t// MessageFailed indicates the resource has failed.\n206: \tMessageFailed = \"Resource has failed\"\n207: \n208: \t// MessagePending indicates the resource is pending.\n209: \tMessagePending = \"Resource is pending\"\n210: \n211: \t// MessageUnknown indicates the resource state is unknown.\n212: \tMessageUnknown = \"Resource state is unknown\"\n213: \n214: \t// MessageSandboxCreating indicates the sandbox is being created.\n215: \tMessageSandboxCreating = \"Sandbox is being created\"\n216: \n217: \t// MessageSandboxReady indicates the sandbox is ready.\n218: \tMessageSandboxReady = \"Sandbox is ready 