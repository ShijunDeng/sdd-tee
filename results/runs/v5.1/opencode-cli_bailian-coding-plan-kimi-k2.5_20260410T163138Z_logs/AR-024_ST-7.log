der\",\n    \"KubernetesProvider\",\n]","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/agentcube/services/__init__.py","time":{"start":1775896068016,"end":1775896068030}}}}
