\n32: \n33: // Resource kind constants for AgentCube runtime resources.\n34: // These are used for Kind fields and type identification.\n35: const (\n36: \t// AgentRuntimeKind is the Kind name for AgentRuntime resources.\n37: \tAgentRuntimeKind = \"AgentRuntime\"\n38: \n39: \t// AgentRuntimeListKind is the Kind name for AgentRuntimeList resources.\n40: \tAgentRuntimeListKind = \"AgentRuntimeList\"\n41: \n42: \t// CodeInterpreterKind is the Kind name for CodeInterpreter resources.\n43: \tCodeInterpreterKind = \"CodeInterpreter\"\n44: \n45: \t// CodeInterpreterListKind is the Kind name for CodeInterpreterList resources.\n46: \tCodeInterpreterListKind = \"CodeInterpreterList\"\n47: )\n48: \n49: // Resource name constants for AgentCube runtime resources.\n50: // These are used for resource naming in URLs and API calls.\n51: const (\n52: \t// AgentRuntimeResourceName is the plural resource name for AgentRuntime.\n53: \tAgentRuntimeResourceName = \"agentruntimes\"\n54: \n55: \t// AgentRuntimeSingularName is the singular resource name for AgentRuntime.\n56: \tAgentRuntimeSingularName = \"agentruntime\"\n57: \n58: \t// CodeInterpreterResourceName is the plural resource name for CodeInterpreter.\n59: \tCodeInterpreterResourceName = \"codeinterpreters\"\n60: \n61: \t// CodeInterpreterSingularName is the singular resource name for CodeInterpreter.\n62: \tCodeInterpreterSingularName = \"codeinterpreter\"\n63: )\n64: \n65: // Short name constants for kubectl usage.\n66: const (\n67: \t// AgentRuntimeShortNames are the short names for AgentRuntime resources.\n68: \tAgentRuntimeShortNames = \"ar,ars\"\n69: \n70: \t// CodeInterpreterShortNames are the short names for CodeInterpreter resources.\n71: \tCodeInterpreterShortNames = \"ci,cis\"\n72: )\n73: \n74: // Category constants for resource grouping.\n75: const (\n76: \t// CategoryAgentCube is the category name for all AgentCube resources.\n77: \tCategoryAgentCube = \"agentcube\"\n78: \n79: \t// CategoryAll is the category name for all resources.\n80: \tCategoryAll = \"all\"\n81: )\n82: \n83: // Common label and annotation keys used across AgentCube resources.\n84: const (\n85: \t// LabelManagedBy is the label key indicating the controller managing the resource.\n86: \tLabelManagedBy = \"app.kubernetes.io/managed-by\"\n87: \n88: \t// LabelCreatedBy is the label key indicating the creator of the resource.\n89: \tLabelCreatedBy = \"app.kubernetes.io/created-by\"\n90: \n91: \t// LabelComponent is the label key indicating the component type.\n92: \tLabelComponent = \"app.kubernetes.io/component\"\n93: \n94: \t// LabelInstance is the label key indicating the instance name.\n95: \tLabelInstance = \"app.kubernetes.io/instance\"\n96: \n97: \t// LabelPartOf is the label key indicating the application this resource is part of.\n98: \tLabelPartOf = \"app.kubernetes.io/part-of\"\n99: \n100: \t// LabelSandboxID is the label key for the sandbox ID.\n101: \tLabelSandboxID = \"runtime.agentcube.volcano.sh/sandbox-id\"\n102: \n103: \t// LabelSessionID is the label key for the session ID.\n104: \tLabelSessionID = \"runtime.agentcube.volcano.sh/session-id\"\n105: \n106: \t// LabelResourceType is the label key for the resource type.\n107: \tLabelResourceType = \"runtime.agentcube.volcano.sh/resource-type\"\n108: )\n109: \n110: // Common annotation keys used across AgentCube resources.\n111: const (\n112: \t// AnnotationDescription is the annotation key for resource description.\n113: \tAnnotationDescription = \"runtime.agentcube.volcano.sh/description\"\n114: \n115: \t// AnnotationCreatedAt is the annotation key for creation timestamp.\n116: \tAnnotationCreatedAt = \"runtime.agentcube.volcano.sh/created-at\"\n117: \n118: \t// AnnotationUpdatedAt is the annotation key for update timestamp.\n119: \tAnnotationUpdatedAt = \"runtime.agentcube.volcano.sh/updated-at\"\n120: \n121: \t// AnnotationLastAppliedConfiguration is the annotation key for the last applied configuration.\n122: \tAnnotationLastAppliedConfiguration = \"runtime.agentcube.volcano.sh/last-applied-configuration\"\n123: \n124: \t// AnnotationSandboxURL is the annotation key for the sandbox access URL.\n125: \tAnnotationSandboxURL = \"runtime.agentcube.volcano.sh/sandbox-url\"\n126: \n127: \t// AnnotationSandboxEndpoint is the annotation key for the sandbox endpoint.\n128: \tAnnotationSandboxEndpoint = \"runtime.agentcube.volcano.sh/sandbox-endpoint\"\n129: \n130: \t// AnnotationIdleTimeout is the annotation key for idle timeout.\n131: \tAnnotationIdleTimeout = \"runtime.agentcube.volcano.sh/idle-timeout\"\n132: \n133: \t// AnnotationMaxLifetime is the annotation key for maximum lifetime.\n134: \tAnnotationMaxLifetime = \"runtime.agentcube.volcano.sh/max-lifetime\"\n135: )\n136: \n137: // Condition reason constants for consistent condition reasoning.\n138: const (\n139: \t// ReasonCreating indicates the resource is being created.\n140: \tReasonCreating = \"Creating\"\n141: \n142: \t// ReasonCreated indicates the resource has been created.\n143: \tReasonCreated = \"Created\"\n144: \n145: \t// ReasonRunning indicates the resource is running.\n146: \tReasonRunning = \"Running\"\n147: \n148: \t// ReasonSucceeded indicates the resource has succeeded.\n149: \tReasonSucceeded = \"Succeeded\"\n150: \n151: \t// ReasonFailed indicates the resource has failed.\n152: \tReasonFailed = \"Failed\"\n153: \n154: \t// ReasonPending indicates the resource is pending.\n155: \tReasonPending = \"Pending\"\n156: \n157: \t// ReasonUnknown indicates the resource state is unknown.\n158: \tReasonUnknown = \"Unknown\"\n159: \n160: \t// ReasonScheduled indicates the resource has been scheduled.\n161: \tReasonScheduled = \"Scheduled\"\n162: \n163: \t// ReasonInitialized indicates the resource has been initialized.\n164: \tReasonInitialized = \"Initialized\"\n165: \n166: \t// ReasonTerminating indicates the resource is being terminated.\n167: \tReasonTerminating = \"Terminating\"\n168: \n169: \t// ReasonTerminated indicates the resource has been terminated.\n170: \tReasonTerminated = \"Terminated\"\n171: \n172: \t// ReasonSandboxCreating indicates the sandbox is being created.\n173: \tReasonSandboxCreating = \"SandboxCreating\"\n174: \n175: \t// ReasonSandboxCreated indicates the sandbox has been created.\n176: \tReasonSandboxCreated = \"SandboxCreated\"\n177: \n178: \t// ReasonSandboxReady indicates the sandbox is ready.\n179: \tReasonSandboxReady = \"SandboxReady\"\n180: \n181: \t// ReasonSandboxFailed indicates the sandbox creation failed.\n182: \tReasonSandboxFailed = \"SandboxFailed\"\n183: \n184: \t// ReasonCleanup indicates the resource is being cleaned up.\n185: \tReasonCleanup = \"Cleanup\"\n186: \n187: \t// ReasonTimeout indicates the resource has timed out.\n188: \tReasonTimeout = \"Timeout\"\n189: \n190: \t// ReasonIdle indicates the resource has been idle.\n191: \tReasonIdle = \"Idle\"\n192: )\n193: \n194: // Condition message constants for consistent condition messaging.\n195: const (\n196: \t// MessageCreating indicates the resource is being created.\n197: \tMessageCreating = \"Resource is being created\"\n198: \n199: \t// MessageRunning indicates the resource is running.\n200: \tMessageRunning = \"Resource is running and ready\"\n201: \n202: \t// MessageSucceeded indicates the resource has completed successfully.\n203: \tMessageSucceeded = \"Resource has completed successfully\"\n204: \n205: \t// MessageFailed indicates the resource has failed.\n206: \tMessageFailed = \"Resource has failed\"\n207: \n208: \t// MessagePending indicates the resource is pending.\n209: \tMessagePending = \"Resource is pending\"\n210: \n211: \t// MessageUnknown indicates the resource state is unknown.\n212: \tMessageUnknown = \"Resource state is unknown\"\n213: \n214: \t// MessageSandboxCreating indicates the sandbox is being created.\n215: \tMessageSandboxCreating = \"Sandbox is being created\"\n216: \n217: \t// MessageSandboxReady indicates the sandbox is ready.\n218: \tMessageSandboxReady = \"Sandbox is ready for use\"\n219: \n220: \t// MessageSandboxFailed indicates the sandbox creation failed.\n221: \tMessageSandboxFailed = \"Sandbox creation failed\"\n222: )\n223: \n224: // Default timeout values in seconds.\n225: const (\n226: \t// DefaultTTLSecondsAfterFinished is the default time to live after the resource finishes.\n227: \tDefaultTTLSecondsAfterFinished = 3600 // 1 hour\n228: \n229: \t// DefaultIdleTimeoutSeconds is the default idle timeout.\n230: \tDefaultIdleTimeoutSeconds = 1800 // 30 minutes\n231: \n232: \t// DefaultMaxLifetimeSeconds is the default maximum lifetime.\n233: \tDefaultMaxLifetimeSeconds = 28800 // 8 hours\n234: \n235: \t// DefaultSessionTimeoutSeconds is the default session timeout.\n236: \tDefaultSessionTimeoutSeconds = 900 // 15 minutes\n237: \n238: \t// DefaultGracePeriodSeconds is the default grace period for termination.\n239: \tDefaultGracePeriodSeconds = 30\n240: )\n241: \n242: // Default duration strings for metav1.Duration.\n243: const (\n244: \t// DefaultSessionTimeout is the default session timeout duration string.\n245: \tDefaultSessionTimeout = \"15m\"\n246: \n247: \t// DefaultMaxSessionDuration is the default maximum session duration string.\n248: \tDefaultMaxSessionDuration = \"8h\"\n249: )\n250: \n251: // Port constants for common services.\n252: const (\n253: \t// DefaultHTTPPort is the default HTTP port.\n254: \tDefaultHTTPPort = 80\n255: \n256: \t// DefaultHTTPSPort is the default HTTPS port.\n257: \tDefaultHTTPSPort = 443\n258: \n259: \t// DefaultCodeInterpreterPort is the default port for CodeInterpreter.\n260: \tDefaultCodeInterpreterPort = 8888\n261: \n262: \t// MinPortNumber is the minimum valid port number.\n263: \tMinPortNumber = 1\n264: \n265: \t// MaxPortNumber is the maximum valid port number.\n266: \tMaxPortNumber = 65535\n267: )\n268: \n269: // Resource quantity defaults.\n270: const (\n271: \t// DefaultCPURequest is the default CPU request.\n272: \tDefaultCPURequest = \"100m\"\n273: \n274: \t// DefaultCPULimit is the default CPU limit.\n275: \tDefaultCPULimit = \"1000m\"\n276: \n277: \t// DefaultMemoryRequest is the default memory request.\n278: \tDefaultMemoryRequest = \"128Mi\"\n279: \n280: \t// DefaultMemoryLimit is the default memory limit.\n281: \tDefaultMemoryLimit = \"1Gi\"\n282: )\n283: \n284: // Status condition constants.\n285: const (\n286: \t// StatusTrue represents a true condition status.\n287: \tStatusTrue = \"True\"\n288: \n289: \t// StatusFalse represents a false condition status.\n290: \tStatusFalse = \"False\"\n291: \n292: \t// StatusUnknown represents an unknown condition status.\n293: \tStatusUnknown = \"Unknown\"\n294: )\n295: \n296: // Finalizer constants for resource cleanup.\n297: const (\n298: \t// FinalizerSandbox is the finalizer for sandbox cleanup.\n299: \tFinalizerSandbox = \"runtime.agentcube.volcano.sh/sandbox-cleanup\"\n300: \n301: \t// FinalizerResource is the finalizer for general resource cleanup.\n302: \tFinalizerResource = \"runtime.agentcube.volcano.sh/resource-cleanup\"\n303: )\n304: \n305: // Event reason constants for Kubernetes events.\n306: const (\n307: \t// EventReasonCreated indicates a resource was created.\n308: \tEventReasonCreated = \"Created\"\n309: \n310: \t// EventReasonUpdated indicates a resource was updated.\n311: \tEventReasonUpdated = \"Updated\"\n312: \n313: \t// EventReasonDeleted indicates a resource was deleted.\n314: \tEventReasonDeleted = \"Deleted\"\n315: \n316: \t// EventReasonFailed indicates a resource operation failed.\n317: \tEventReasonFailed = \"Failed\"\n318: \n319: \t// EventReasonSucceeded indicates a resource operation succeeded.\n320: \tEventReasonSucceeded = \"Succeeded\"\n321: \n322: \t// EventReasonSandboxCreated indicates a sandbox was created.\n323: \tEventReasonSandboxCreated = \"SandboxCreated\"\n324: \n325: \t// EventReasonSandboxDeleted indicates a sandbox was deleted.\n326: \tEventReasonSandboxDeleted = \"SandboxDeleted\"\n327: \n328: \t// EventReasonSandboxFailed indicates a sandbox operation failed.\n329: \tEventReasonSandboxFailed = \"SandboxFailed\"\n330: \n331: \t// EventReasonTimeout indicates a timeout occurred.\n332: \tEventReasonTimeout = \"Timeout\"\n333: \n334: \t// EventReasonIdle indicates an idle timeout occurred.\n335: \tEventReasonIdle = \"Idle\"\n336: )\n337: \n338: // Error message constants for consistent error reporting.\n339: const (\n340: \t// ErrMsgResourceNotFound is the error message for resource not found.\n341: \tErrMsgResourceNotFound = \"resource not found\"\n342: \n343: \t// ErrMsgResourceAlreadyExists is the error message for resource already exists.\n344: \tErrMsgResourceAlreadyExists = \"resource already exists\"\n345: \n346: \t// ErrMsgInvalidSpec is the error message for invalid spec.\n347: \tErrMsgInvalidSpec = \"invalid spec\"\n348: \n349: \t// ErrMsgSandboxCreationFailed is the error message for sandbox creation failure.\n350: \tErrMsgSandboxCreationFailed = \"sandbox creation failed\"\n351: \n352: \t// ErrMsgSandboxNotReady is the error message for sandbox not ready.\n353: \tErrMsgSandboxNotReady = \"sandbox not ready\"\n354: \n355: \t// ErrMsgTimeout is the error message for timeout.\n356: \tErrMsgTimeout = \"operation timed out\"\n357: \n358: \t// ErrMsgUnauthorized is the error message for unauthorized access.\n359: \tErrMsgUnauthorized = \"unauthorized\"\n360: \n361: \t// ErrMsgForbidden is the error message for forbidden access.\n362: \tErrMsgForbidden = \"forbidden\"\n363: )\n\n(End of file - total 363 lines)\n</content>","metadata":{"preview":"/*\nCopyright 2026 The Volcano Authors.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\npackage v1alpha1\n\n// API Group and Version constants for the runtime.agentcube.volcano.sh API group.\nconst (","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/apis/runtime/v1alpha1/constants.go","time":{"start":1775856979172,"end":1775856979187}}}}
