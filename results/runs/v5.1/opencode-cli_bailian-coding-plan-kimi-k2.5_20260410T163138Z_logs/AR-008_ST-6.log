{"type":"tool_use","timestamp":1775856953239,"sessionID":"ses_286b4886fffej46k80vZS1AYFy","part":{"id":"prt_d7952a3280014Kudwy6vpp7sqT","messageID":"msg_d79529a59001RvVcV7S75W1rE3","sessionID":"ses_286b4886fffej46k80vZS1AYFy","type":"tool","tool":"read","callID":"toolu_functions.read:40","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/apis/runtime/v1alpha1/common_types_test.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/apis/runtime/v1alpha1/common_types_test.go</path>\n<type>file</type>\n<content>\n1: /*\n2: Copyright 2026 The Volcano Authors.\n3: \n4: Licensed under the Apache License, Version 2.0 (the \"License\");\n5: you may not use this file except in compliance with the License.\n6: You may obtain a copy of the License at\n7: \n8:     http://www.apache.org/licenses/LICENSE-2.0\n9: \n10: Unless required by applicable law or agreed to in writing, software\n11: distributed under the License is distributed on an \"AS IS\" BASIS,\n12: WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n13: See the License for the specific language governing permissions and\n14: limitations under the License.\n15: */\n16: \n17: package v1alpha1\n18: \n19: import (\n20: \t\"encoding/json\"\n21: \t\"testing\"\n22: \t\"time\"\n23: \n24: \tcorev1 \"k8s.io/api/core/v1\"\n25: \t\"k8s.io/apimachinery/pkg/api/resource\"\n26: \tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n27: \t\"k8s.io/apimachinery/pkg/util/intstr\"\n28: )\n29: \n30: func TestPhaseValues(t *testing.T) {\n31: \ttests := []struct {\n32: \t\tname     string\n33: \t\tphase    Phase\n34: \t\texpected string\n35: \t}{\n36: \t\t{\"Pending\", PhasePending, \"Pending\"},\n37: \t\t{\"Running\", PhaseRunning, \"Running\"},\n38: \t\t{\"Succeeded\", PhaseSucceeded, \"Succeeded\"},\n39: \t\t{\"Failed\", PhaseFailed, \"Failed\"},\n40: \t\t{\"Unknown\", PhaseUnknown, \"Unknown\"},\n41: \t}\n42: \n43: \tfor _, tt := range tests {\n44: \t\tt.Run(tt.name, func(t *testing.T) {\n45: \t\t\tif string(tt.phase) != tt.expected {\n46: \t\t\t\tt.Errorf(\"Expected phase %s, got %s\", tt.expected, tt.phase)\n47: \t\t\t}\n48: \t\t})\n49: \t}\n50: }\n51: \n52: func TestConditionTypeValues(t *testing.T) {\n53: \ttests := []struct {\n54: \t\tname     string\n55: \t\tcondType ConditionType\n56: \t\texpected string\n57: \t}{\n58: \t\t{\"Ready\", ConditionReady, \"Ready\"},\n59: \t\t{\"SandboxCreated\", ConditionSandboxCreated, \"SandboxCreated\"},\n60: \t\t{\"SandboxReady\", ConditionSandboxReady, \"SandboxReady\"},\n61: \t\t{\"Failed\", ConditionFailed, \"Failed\"},\n62: \t\t{\"Scheduled\", ConditionScheduled, \"Scheduled\"},\n63: \t\t{\"Initialized\", ConditionInitialized, \"Initialized\"},\n64: \t}\n65: \n66: \tfor _, tt := range tests {\n67: \t\tt.Run(tt.name, func(t *testing.T) {\n68: \t\t\tif string(tt.condType) != tt.expected {\n69: \t\t\t\tt.Errorf(\"Expected condition type %s, got %s\", tt.expected, tt.condType)\n70: \t\t\t}\n71: \t\t})\n72: \t}\n73: }\n74: \n75: func TestStorageTypeValues(t *testing.T) {\n76: \ttests := []struct {\n77: \t\tname     string\n78: \t\tstorage  StorageType\n79: \t\texpected string\n80: \t}{\n81: \t\t{\"EmptyDir\", StorageTypeEmptyDir, \"EmptyDir\"},\n82: \t\t{\"HostPath\", StorageTypeHostPath, \"HostPath\"},\n83: \t\t{\"PersistentVolumeClaim\", StorageTypePersistentVolumeClaim, \"PersistentVolumeClaim\"},\n84: \t\t{\"ConfigMap\", StorageTypeConfigMap, \"ConfigMap\"},\n85: \t\t{\"Secret\", StorageTypeSecret, \"Secret\"},\n86: \t}\n87: \n88: \tfor _, tt := range tests {\n89: \t\tt.Run(tt.name, func(t *testing.T) {\n90: \t\t\tif string(tt.storage) != tt.expected {\n91: \t\t\t\tt.Errorf(\"Expected storage type %s, got %s\", tt.expected, tt.storage)\n92: \t\t\t}\n93: \t\t})\n94: \t}\n95: }\n96: \n97: func TestCondition(t *testing.T) {\n98: \tnow := metav1.NewTime(time.Now())\n99: \n100: \ttests := []struct {\n101: \t\tname      string\n102: \t\tcondition Condition\n103: \t}{\n104: \t\t{\n105: \t\t\tname: \"minimal condition\",\n106: \t\t\tcondition: Condition{\n107: \t\t\t\tType:   ConditionReady,\n108: \t\t\t\tStatus: corev1.ConditionTrue,\n109: \t\t\t},\n110: \t\t},\n111: \t\t{\n112: \t\t\tname: \"full condition\",\n113: \t\t\tcondition: Condition{\n114: \t\t\t\tType:               ConditionSandboxReady,\n115: \t\t\t\tStatus:             corev1.ConditionTrue,\n116: \t\t\t\tLastTransitionTime: now,\n117: \t\t\t\tReason:             \"SandboxCreated\",\n118: \t\t\t\tMessage:            \"Sandbox is ready for use\",\n119: \t\t\t\tObservedGeneration: 1,\n120: \t\t\t},\n121: \t\t},\n122: \t\t{\n123: \t\t\tname: \"failed condition\",\n124: \t\t\tcondition: Condition{\n125: \t\t\t\tType:               ConditionFailed,\n126: \t\t\t\tStatus:             corev1.ConditionFalse,\n127: \t\t\t\tLastTransitionTime: now,\n128: \t\t\t\tReason:             \"SandboxCreationFailed\",\n129: \t\t\t\tMessage:            \"Failed to create sandbox pod\",\n130: \t\t\t\tObservedGeneration: 2,\n131: \t\t\t},\n132: \t\t},\n133: \t}\n134: \n135: \tfor _, tt := range tests {\n136: \t\tt.Run(tt.name, func(t *testing.T) {\n137: \t\t\tif tt.condition.Type == \"\" {\n138: \t\t\t\tt.Error(\"Condition Type should not be empty\")\n139: \t\t\t}\n140: \t\t\tif tt.condition.Status == \"\" {\n141: \t\t\t\tt.Error(\"Condition Status should not be empty\")\n142: \t\t\t}\n143: \t\t})\n144: \t}\n145: }\n146: \n147: func TestResourceReference(t *testing.T) {\n148: \ttests := []struct {\n149: \t\tname     string\n150: \t\tref      ResourceReference\n151: \t\twantName string\n152: \t\twantNS   string\n153: \t}{\n154: \t\t{\n155: \t\t\tname: \"simple reference\",\n156: \t\t\tref: ResourceReference{\n157: \t\t\t\tName: \"my-secret\",\n158: \t\t\t},\n159: \t\t\twantName: \"my-secret\",\n160: \t\t\twantNS:   \"\",\n161: \t\t},\n162: \t\t{\n163: \t\t\tname: \"reference with namespace\",\n164: \t\t\tref: ResourceReference{\n165: \t\t\t\tName:      \"my-config\",\n166: \t\t\t\tNamespace: \"other-namespace\",\n167: \t\t\t},\n168: \t\t\twantName: \"my-config\",\n169: \t\t\twantNS:   \"other-namespace\",\n170: \t\t},\n171: \t}\n172: \n173: \tfor _, tt := range tests {\n174: \t\tt.Run(tt.name, func(t *testing.T) {\n175: \t\t\tif tt.ref.Name != tt.wantName {\n176: \t\t\t\tt.Errorf(\"Expected name %s, got %s\", tt.wantName, tt.ref.Name)\n177: \t\t\t}\n178: \t\t\tif tt.ref.Namespace != tt.wantNS {\n179: \t\t\t\tt.Errorf(\"Expected namespace %s, got %s\", tt.wantNS, tt.ref.Namespace)\n180: \t\t\t}\n181: \t\t})\n182: \t}\n183: }\n184: \n185: func TestLocalResourceReference(t *testing.T) {\n186: \tref := LocalResourceReference{\n187: \t\tName: \"my-resource\",\n188: \t}\n189: \n190: \tif ref.Name != \"my-resource\" {\n191: \t\tt.Errorf(\"Expected name 'my-resource', got %s\", ref.Name)\n192: \t}\n193: }\n194: \n195: func TestSecretReference(t *testing.T) {\n196: \ttests := []struct {\n197: \t\tname     string\n198: \t\tref      SecretReference\n199: \t\twantName string\n200: \t\twantKey  string\n201: \t}{\n202: \t\t{\n203: \t\t\tname: \"secret without key\",\n204: \t\t\tref: SecretReference{\n205: \t\t\t\tName: \"my-secret\",\n206: \t\t\t},\n207: \t\t\twantName: \"my-secret\",\n208: \t\t\twantKey:  \"\",\n209: \t\t},\n210: \t\t{\n211: \t\t\tname: \"secret with key\",\n212: \t\t\tref: SecretReference{\n213: \t\t\t\tName: \"my-secret\",\n214: \t\t\t\tKey:  \"password\",\n215: \t\t\t},\n216: \t\t\twantName: \"my-secret\",\n217: \t\t\twantKey:  \"password\",\n218: \t\t},\n219: \t}\n220: \n221: \tfor _, tt := range tests {\n222: \t\tt.Run(tt.name, func(t *testing.T) {\n223: \t\t\tif tt.ref.Name != tt.wantName {\n224: \t\t\t\tt.Errorf(\"Expected name %s, got %s\", tt.wantName, tt.ref.Name)\n225: \t\t\t}\n226: \t\t\tif tt.ref.Key != tt.wantKey {\n227: \t\t\t\tt.Errorf(\"Expected key %s, got %s\", tt.wantKey, tt.ref.Key)\n228: \t\t\t}\n229: \t\t})\n230: \t}\n231: }\n232: \n233: func TestConfigMapReference(t *testing.T) {\n234: \ttests := []struct {\n235: \t\tname     string\n236: \t\tref      ConfigMapReference\n237: \t\twantName string\n238: \t\twantKey  string\n239: \t}{\n240: \t\t{\n241: \t\t\tname: \"configmap without key\",\n242: \t\t\tref: ConfigMapReference{\n243: \t\t\t\tName: \"my-config\",\n244: \t\t\t},\n245: \t\t\twantName: \"my-config\",\n246: \t\t\twantKey:  \"\",\n247: \t\t},\n248: \t\t{\n249: \t\t\tname: \"configmap with key\",\n250: \t\t\tref: ConfigMapReference{\n251: \t\t\t\tName: \"my-config\",\n252: \t\t\t\tKey:  \"data\",\n253: \t\t\t},\n254: \t\t\twantName: \"my-config\",\n255: \t\t\twantKey:  \"data\",\n256: \t\t},\n257: \t}\n258: \n259: \tfor _, tt := range tests {\n260: \t\tt.Run(tt.name, func(t *testing.T) {\n261: \t\t\tif tt.ref.Name != tt.wantName {\n262: \t\t\t\tt.Errorf(\"Expected name %s, got %s\", tt.wantName, tt.ref.Name)\n263: \t\t\t}\n264: \t\t\tif tt.ref.Key != tt.wantKey {\n265: \t\t\t\tt.Errorf(\"Expected key %s, got %s\", tt.wantKey, tt.ref.Key)\n266: \t\t\t}\n267: \t\t})\n268: \t}\n269: }\n270: \n271: func TestResourceRequirements(t *testing.T) {\n272: \treq := ResourceRequirements{\n273: \t\tLimits: corev1.ResourceList{\n274: \t\t\tcorev1.ResourceCPU:    mustParseQuantity(\"1000m\"),\n275: \t\t\tcorev1.ResourceMemory: mustParseQuantity(\"1Gi\"),\n276: \t\t},\n277: \t\tRequests: corev1.ResourceList{\n278: \t\t\tcorev1.ResourceCPU:    mustParseQuantity(\"500m\"),\n279: \t\t\tcorev1.ResourceMemory: mustParseQuantity(\"512Mi\"),\n280: \t\t},\n281: \t}\n282: \n283: \tif req.Limits.Cpu().MilliValue() != 1000 {\n284: \t\tt.Errorf(\"Expected CPU limit 1000m, got %d\", req.Limits.Cpu().MilliValue())\n285: \t}\n286: \n287: \tif req.Requests.Cpu().MilliValue() != 500 {\n288: \t\tt.Errorf(\"Expected CPU request 500m, got %d\", req.Requests.Cpu().MilliValue())\n289: \t}\n290: }\n291: \n292: func TestSandboxTemplate(t *testing.T) {\n293: \ttests := []struct {\n294: \t\tname     string\n295: \t\ttemplate SandboxTemplate\n296: \t}{\n297: \t\t{\n298: \t\t\tname:     \"empty template\",\n299: \t\t\ttemplate: SandboxTemplate{},\n300: \t\t},\n301: \t\t{\n302: \t\t\tname: \"template with labels\",\n303: \t\t\ttemplate: SandboxTemplate{\n304: \t\t\t\tLabels: map[string]string{\n305: \t\t\t\t\t\"app\":     \"test\",\n306: \t\t\t\t\t\"version\": \"v1\",\n307: \t\t\t\t},\n308: \t\t\t},\n309: \t\t},\n310: \t\t{\n311: \t\t\tname: \"template with annotations\",\n312: \t\t\ttemplate: SandboxTemplate{\n313: \t\t\t\tAnnotations: map[string]string{\n314: \t\t\t\t\t\"description\": \"Test sandbox\",\n315: \t\t\t\t},\n316: \t\t\t},\n317: \t\t},\n318: \t\t{\n319: \t\t\tname: \"template with spec\",\n320: \t\t\ttemplate: SandboxTemplate{\n321: \t\t\t\tSpec: &corev1.PodSpec{\n322: \t\t\t\t\tContainers: []corev1.Container{\n323: \t\t\t\t\t\t{\n324: \t\t\t\t\t\t\tName:  \"test\",\n325: \t\t\t\t\t\t\tImage: \"busybox:latest\",\n326: \t\t\t\t\t\t},\n327: \t\t\t\t\t},\n328: \t\t\t\t},\n329: \t\t\t},\n330: \t\t},\n331: \t\t{\n332: \t\t\tname: \"full template\",\n333: \t\t\ttemplate: SandboxTemplate{\n334: \t\t\t\tLabels: map[string]string{\n335: \t\t\t\t\t\"app\": \"test\",\n336: \t\t\t\t},\n337: \t\t\t\tAnnotations: map[string]string{\n338: \t\t\t\t\t\"description\": \"Test sandbox\",\n339: \t\t\t\t},\n340: \t\t\t\tSpec: &corev1.PodSpec{\n341: \t\t\t\t\tContainers: []corev1.Container{\n342: \t\t\t\t\t\t{\n343: \t\t\t\t\t\t\tName:  \"main\",\n344: \t\t\t\t\t\t\tImage: \"ubuntu:22.04\",\n345: \t\t\t\t\t\t},\n346: \t\t\t\t\t},\n347: \t\t\t\t},\n348: \t\t\t},\n349: \t\t},\n350: \t}\n351: \n352: \tfor _, tt := range tests {\n353: \t\tt.Run(tt.name, func(t *testing.T) {\n354: \t\t\t// Just verify the template can be created\n355: \t\t\t_ = tt.template\n356: \t\t})\n357: \t}\n358: }\n359: \n360: func TestVolumeSource(t *testing.T) {\n361: \ttests := []struct {\n362: \t\tname     string\n363: \t\tvs       VolumeSource\n364: \t\twantType StorageType\n365: \t}{\n366: \t\t{\n367: \t\t\tname: \"empty dir volume\",\n368: \t\t\tvs: VolumeSource{\n369: \t\t\t\tType:     StorageTypeEmptyDir,\n370: \t\t\t\tEmptyDir: &corev1.EmptyDirVolumeSource{},\n371: \t\t\t},\n372: \t\t\twantType: StorageTypeEmptyDir,\n373: \t\t},\n374: \t\t{\n375: \t\t\tname: \"host path volume\",\n376: \t\t\tvs: VolumeSource{\n377: \t\t\t\tType: StorageTypeHostPath,\n378: \t\t\t\tHostPath: &corev1.HostPathVolumeSource{\n379: \t\t\t\t\tPath: \"/data\",\n380: \t\t\t\t},\n381: \t\t\t},\n382: \t\t\twantType: StorageTypeHostPath,\n383: \t\t},\n384: \t\t{\n385: \t\t\tname: \"pvc volume\",\n386: \t\t\tvs: VolumeSource{\n387: \t\t\t\tType: StorageTypePersistentVolumeClaim,\n388: \t\t\t\tPersistentVolumeClaim: &corev1.PersistentVolumeClaimVolumeSource{\n389: \t\t\t\t\tClaimName: \"my-pvc\",\n390: \t\t\t\t},\n391: \t\t\t},\n392: \t\t\twantType: StorageTypePersistentVolumeClaim,\n393: \t\t},\n394: \t\t{\n395: \t\t\tname: \"configmap volume\",\n396: \t\t\tvs: VolumeSource{\n397: \t\t\t\tType: StorageTypeConfigMap,\n398: \t\t\t\tConfigMap: &corev1.ConfigMapVolumeSource{\n399: \t\t\t\t\tLocalObjectReference: corev1.LocalObjectReference{\n400: \t\t\t\t\t\tName: \"my-config\",\n401: \t\t\t\t\t},\n402: \t\t\t\t},\n403: \t\t\t},\n404: \t\t\twantType: StorageTypeConfigMap,\n405: \t\t},\n406: \t\t{\n407: \t\t\tname: \"secret volume\",\n408: \t\t\tvs: VolumeSource{\n409: \t\t\t\tType: StorageTypeSecret,\n410: \t\t\t\tSecret: &corev1.SecretVolumeSource{\n411: \t\t\t\t\tSecretName: \"my-secret\",\n412: \t\t\t\t},\n413: \t\t\t},\n414: \t\t\twantType: StorageTypeSecret,\n415: \t\t},\n416: \t}\n417: \n418: \tfor _, tt := range tests {\n419: \t\tt.Run(tt.name, func(t *testing.T) {\n420: \t\t\tif tt.vs.Type != tt.wantType {\n421: \t\t\t\tt.Errorf(\"Expected type %s, got %s\", tt.wantType, tt.vs.Type)\n422: \t\t\t}\n423: \t\t})\n424: \t}\n425: }\n426: \n427: func TestVolumeMount(t *testing.T) {\n428: \ttests := []struct {\n429: \t\tname         string\n430: \t\tvm           VolumeMount\n431: \t\twantName     string\n432: \t\twantPath     string\n433: \t\twantReadOnly bool\n434: \t}{\n435: \t\t{\n436: \t\t\tname: \"basic mount\",\n437: \t\t\tvm: VolumeMount{\n438: \t\t\t\tName:      \"data\",\n439: \t\t\t\tMountPath: \"/data\",\n440: \t\t\t},\n441: \t\t\twantName:     \"data\",\n442: \t\t\twantPath:     \"/data\",\n443: \t\t\twantReadOnly: false,\n444: \t\t},\n445: \t\t{\n446: \t\t\tname: \"read-only mount\",\n447: \t\t\tvm: VolumeMount{\n448: \t\t\t\tName:      \"config\",\n449: \t\t\t\tMountPath: \"/etc/config\",\n450: \t\t\t\tReadOnly:  true,\n451: \t\t\t},\n452: \t\t\twantName:     \"config\",\n453: \t\t\twantPath:     \"/etc/config\",\n454: \t\t\twantReadOnly: true,\n455: \t\t},\n456: \t\t{\n457: \t\t\tname: \"mount with subpath\",\n458: \t\t\tvm: VolumeMount{\n459: \t\t\t\tName:      \"data\",\n460: \t\t\t\tMountPath: \"/data\",\n461: \t\t\t\tSubPath:   \"subdir\",\n462: \t\t\t},\n463: \t\t\twantName: \"data\",\n464: \t\t\twantPath: \"/data\",\n465: \t\t},\n466: \t}\n467: \n468: \tfor _, tt := range tests {\n469: \t\tt.Run(tt.name, func(t *testing.T) {\n470: \t\t\tif tt.vm.Name != tt.wantName {\n471: \t\t\t\tt.Errorf(\"Expected name %s, got %s\", tt.wantName, tt.vm.Name)\n472: \t\t\t}\n473: \t\t\tif tt.vm.MountPath != tt.wantPath {\n474: \t\t\t\tt.Errorf(\"Expected mount path %s, got %s\", tt.wantPath, tt.vm.MountPath)\n475: \t\t\t}\n476: \t\t\tif tt.vm.ReadOnly != tt.wantReadOnly {\n477: \t\t\t\tt.Errorf(\"Expected readOnly %v, got %v\", tt.wantReadOnly, tt.vm.ReadOnly)\n478: \t\t\t}\n479: \t\t})\n480: \t}\n481: }\n482: \n483: func TestNetworkConfig(t *testing.T) {\n484: \tnc := NetworkConfig{\n485: \t\tHostNetwork: true,\n486: \t\tHostPID:     true,\n487: \t\tHostIPC:     false,\n488: \t\tDNSPolicy:   corev1.DNSClusterFirst,\n489: \t\tDNSConfig: &corev1.PodDNSConfig{\n490: \t\t\tNameservers: []string{\"8.8.8.8\"},\n491: \t\t},\n492: \t}\n493: \n494: \tif !nc.HostNetwork {\n495: \t\tt.Error(\"Expected HostNetwork to be true\")\n496: \t}\n497: \n498: \tif !nc.HostPID {\n499: \t\tt.Error(\"Expected HostPID to be true\")\n500: \t}\n501: \n502: \tif nc.HostIPC {\n503: \t\tt.Error(\"Expected HostIPC to be false\")\n504: \t}\n505: \n506: \tif nc.DNSPolicy != corev1.DNSClusterFirst {\n507: \t\tt.Errorf(\"Expected DNSPolicy DNSClusterFirst, got %s\", nc.DNSPolicy)\n508: \t}\n509: \n510: \tif nc.DNSConfig == nil {\n511: \t\tt.Error(\"Expected DNSConfig to be set\")\n512: \t}\n513: }\n514: \n515: func TestSecurityContext(t *testing.T) {\n516: \tsc := SecurityContext{\n517: \t\tRunAsUser:                int64Ptr(1000),\n518: \t\tRunAsGroup:               int64Ptr(1000),\n519: \t\tRunAsNonRoot:             boolPtr(true),\n520: \t\tReadOnlyRootFilesystem:   boolPtr(true),\n521: \t\tPrivileged:               boolPtr(false),\n522: \t\tAllowPrivilegeEscalation: boolPtr(false),\n523: \t}\n524: \n525: \tif sc.RunAsUser == nil || *sc.RunAsUser != 1000 {\n526: \t\tt.Error(\"Expected RunAsUser to be 1000\")\n527: \t}\n528: \n529: \tif sc.RunAsGroup == nil || *sc.RunAsGroup != 1000 {\n530: \t\tt.Error(\"Expected RunAsGroup to be 1000\")\n531: \t}\n532: \n533: \tif sc.RunAsNonRoot == nil || !*sc.RunAsNonRoot {\n534: \t\tt.Error(\"Expected RunAsNonRoot to be true\")\n535: \t}\n536: \n537: \tif sc.ReadOnlyRootFilesystem == nil || !*sc.ReadOnlyRootFilesystem {\n538: \t\tt.Error(\"Expected ReadOnlyRootFilesystem to be true\")\n539: \t}\n540: \n541: \tif sc.Privileged == nil || *sc.Privileged {\n542: \t\tt.Error(\"Expected Privileged to be false\")\n543: \t}\n544: \n545: \tif sc.AllowPrivilegeEscalation == nil || *sc.AllowPrivilegeEscalation {\n546: \t\tt.Error(\"Expected AllowPrivilegeEscalation to be false\")\n547: \t}\n548: }\n549: \n550: func TestLifecycleHooks(t *testing.T) {\n551: \tlh := LifecycleHooks{\n552: \t\tPostStart: &corev1.LifecycleHandler{\n553: \t\t\tExec: &corev1.ExecAction{\n554: \t\t\t\tCommand: []string{\"echo\", \"started\"},\n555: \t\t\t},\n556: \t\t},\n557: \t\tPreStop: &corev1.LifecycleHandler{\n558: \t\t\tExec: &corev1.ExecAction{\n559: \t\t\t\tCommand: []string{\"echo\", \"stopping\"},\n560: \t\t\t},\n561: \t\t},\n562: \t}\n563: \n564: \tif lh.PostStart == nil {\n565: \t\tt.Error(\"Expected PostStart to be set\")\n566: \t}\n567: \n568: \tif lh.PreStop == nil {\n569: \t\tt.Error(\"Expected PreStop to be set\")\n570: \t}\n571: }\n572: \n573: func TestHealthCheck(t *testing.T) {\n574: \thc := HealthCheck{\n575: \t\tLivenessProbe: &corev1.Probe{\n576: \t\t\tProbeHandler: corev1.ProbeHandler{\n577: \t\t\t\tHTTPGet: &corev1.HTTPGetAction{\n578: \t\t\t\t\tPath: \"/health\",\n579: \t\t\t\t\tPort: int32FromInt(8080),\n580: \t\t\t\t},\n581: \t\t\t},\n582: \t\t},\n583: \t\tReadinessProbe: &corev1.Probe{\n584: \t\t\tProbeHandler: corev1.ProbeHandler{\n585: \t\t\t\tHTTPGet: &corev1.HTTPGetAction{\n586: \t\t\t\t\tPath: \"/ready\",\n587: \t\t\t\t\tPort: int32FromInt(8080),\n588: \t\t\t\t},\n589: \t\t\t},\n590: \t\t},\n591: \t\tStartupProbe: &corev1.Probe{\n592: \t\t\tProbeHandler: corev1.ProbeHandler{\n593: \t\t\t\tHTTPGet: &corev1.HTTPGetAction{\n594: \t\t\t\t\tPath: \"/startup\",\n595: \t\t\t\t\tPort: int32FromInt(8080),\n596: \t\t\t\t},\n597: \t\t\t},\n598: \t\t},\n599: \t}\n600: \n601: \tif hc.LivenessProbe == nil {\n602: \t\tt.Error(\"Expected LivenessProbe to be set\")\n603: \t}\n604: \n605: \tif hc.ReadinessProbe == nil {\n606: \t\tt.Error(\"Expected ReadinessProbe to be set\")\n607: \t}\n608: \n609: \tif hc.StartupProbe == nil {\n610: \t\tt.Error(\"Expected StartupProbe to be set\")\n611: \t}\n612: }\n613: \n614: func TestTimeoutConfig(t *testing.T) {\n615: \ttc := TimeoutConfig{\n616: \t\tTTLSecondsAfterFinished: int32Ptr(3600),\n617: \t\tIdleTimeoutSeconds:      int32Ptr(1800),\n618: \t\tMaxLifetimeSeconds:      int32Ptr(28800),\n619: \t\tGracePeriodSeconds:      int64Ptr(30),\n620: \t}\n621: \n622: \tif tc.TTLSecondsAfterFinished == nil || *tc.TTLSecondsAfterFinished != 3600 {\n623: \t\tt.Error(\"Expected TTLSecondsAfterFinished to be 3600\")\n624: \t}\n625: \n626: \tif tc.IdleTimeoutSeconds == nil || *tc.IdleTimeoutSeconds != 1800 {\n627: \t\tt.Error(\"Expected IdleTimeoutSeconds to be 1800\")\n628: \t}\n629: \n630: \tif tc.MaxLifetimeSeconds == nil || *tc.MaxLifetimeSeconds != 28800 {\n631: \t\tt.Error(\"Expected MaxLifetimeSeconds to be 28800\")\n632: \t}\n633: \n634: \tif tc.GracePeriodSeconds == nil || *tc.GracePeriodSeconds != 30 {\n635: \t\tt.Error(\"Expected GracePeriodSeconds to be 30\")\n636: \t}\n637: }\n638: \n639: func TestConditionJSONMarshal(t *testing.T) {\n640: \tnow := metav1.NewTime(time.Now())\n641: \n642: \tcond := Condition{\n643: \t\tType:               ConditionReady,\n644: \t\tStatus:             corev1.ConditionTrue,\n645: \t\tLastTransitionTime: now,\n646: \t\tReason:             \"ResourceReady\",\n647: \t\tMessage:            \"Resource is ready\",\n648: \t\tObservedGeneration: 1,\n649: \t}\n650: \n651: \tdata, err := json.Marshal(cond)\n652: \tif err != nil {\n653: \t\tt.Fatalf(\"Failed to marshal Condition: %v\", err)\n654: \t}\n655: \n656: \tvar unmarshaled Condition\n657: \terr = json.Unmarshal(data, &unmarshaled)\n658: \tif err != nil {\n659: \t\tt.Fatalf(\"Failed to unmarshal Condition: %v\", err)\n660: \t}\n661: \n662: \tif unmarshaled.Type != cond.Type {\n663: \t\tt.Errorf(\"Expected type %s, got %s\", cond.Type, unmarshaled.Type)\n664: \t}\n665: \n666: \tif unmarshaled.Status != cond.Status {\n667: \t\tt.Errorf(\"Expected status %s, got %s\", cond.Status, unmarshaled.Status)\n668: \t}\n669: \n670: \tif unmarshaled.Reason != cond.Reason {\n671: \t\tt.Errorf(\"Expected reason %s, got %s\", cond.Reason, unmarshaled.Reason)\n672: \t}\n673: \n674: \tif unmarshaled.Message != cond.Message {\n675: \t\tt.Errorf(\"Expected message %s, got %s\", cond.Message, unmarshaled.Message)\n676: \t}\n677: }\n678: \n679: func TestConstants(t *testing.T) {\n680: \t// Test API constants\n681: \tif APIGroup != \"runtime.agentcube.volcano.sh\" {\n682: \t\tt.Errorf(\"Expected APIGroup 'runtime.agentcube.volcano.sh', got %s\", APIGroup)\n683: \t}\n684: \n685: \tif APIVersion != \"v1alpha1\" {\n686: \t\tt.Errorf(\"Expected APIVersion 'v1alpha1', got %s\", APIVersion)\n687: \t}\n688: \n689: \tif FullAPIVersion != \"runtime.agentcube.volcano.sh/v1alpha1\" {\n690: \t\tt.Errorf(\"Expected FullAPIVersion 'runtime.agentcube.volcano.sh/v1alpha1', got %s\", FullAPIVersion)\n691: \t}\n692: \n693: \t// Test kind constants\n694: \tif AgentRuntimeKind != \"AgentRuntime\" {\n695: \t\tt.Errorf(\"Expected AgentRuntimeKind 'AgentRuntime', got %s\", AgentRuntimeKind)\n696: \t}\n697: \n698: \tif CodeInterpreterKind != \"CodeInterpreter\" {\n699: \t\tt.Errorf(\"Expected CodeInterpreterKind 'CodeInterpreter', got %s\", CodeInterpreterKind)\n700: \t}\n701: \n702: \t// Test phase constants\n703: \tif PhasePending != \"Pending\" {\n704: \t\tt.Errorf(\"Expected PhasePending 'Pending', got %s\", PhasePending)\n705: \t}\n706: \n707: \t// Test condition type constants\n708: \tif ConditionReady != \"Ready\" {\n709: \t\tt.Errorf(\"Expected ConditionReady 'Ready', got %s\", ConditionReady)\n710: \t}\n711: \n712: \t// Test reason constants\n713: \tif ReasonCreating != \"Creating\" {\n714: \t\tt.Errorf(\"Expected ReasonCreating 'Creating', got %s\", ReasonCreating)\n715: \t}\n716: \n717: \t// Test timeout constants\n718: \tif DefaultTTLSecondsAfterFinished != 3600 {\n719: \t\tt.Errorf(\"Expected DefaultTTLSecondsAfterFinished 3600, got %d\", DefaultTTLSecondsAfterFinished)\n720: \t}\n721: \n722: \t// Test port constants\n723: \tif DefaultHTTPPort != 80 {\n724: \t\tt.Errorf(\"Expected DefaultHTTPPort 80, got %d\", DefaultHTTPPort)\n725: \t}\n726: \n727: \t// Test resource quantity defaults\n728: \tif DefaultCPURequest != \"100m\" {\n729: \t\tt.Errorf(\"Expected DefaultCPURequest '100m', got %s\", DefaultCPURequest)\n730: \t}\n731: \n732: \t// Test status constants\n733: \tif StatusTrue != \"True\" {\n734: \t\tt.Errorf(\"Expected StatusTrue 'True', got %s\", StatusTrue)\n735: \t}\n736: \n737: \t// Test finalizer constants\n738: \tif FinalizerSandbox != \"runtime.agentcube.volcano.sh/sandbox-cleanup\" {\n739: \t\tt.Errorf(\"Expected FinalizerSandbox 'runtime.agentcube.volcano.sh/sandbox-cleanup', got %s\", FinalizerSandbox)\n740: \t}\n741: \n742: \t// Test event reason constants\n743: \tif EventReasonCreated != \"Created\" {\n744: \t\tt.Errorf(\"Expected EventReasonCreated 'Created', got %s\", EventReasonCreated)\n745: \t}\n746: \n747: \t// Test error message constants\n748: \tif ErrMsgResourceNotFound != \"resource not found\" {\n749: \t\tt.Errorf(\"Expected ErrMsgResourceNotFound 'resource not found', got %s\", ErrMsgResourceNotFound)\n750: \t}\n751: }\n752: \n753: func int64Ptr(i int64) *int64 {\n754: \treturn &i\n755: }\n756: \n757: func mustParseQuantity(s string) resource.Quantity {\n758: \treturn resource.MustParse(s)\n759: }\n760: \n761: func int32FromInt(i int) intstr.IntOrString {\n762: \treturn intstr.FromInt(i)\n763: }\n\n(End of file - total 763 lines)\n</content>","metadata":{"preview":"/*\nCopyright 2026 The Volcano Authors.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\npackage v1alpha1\n\nimport (\n\t\"encoding/json\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/apis/runtime/v1alpha1/common_types_test.go","time":{"start":1775856953219,"end":1775856953236}}}}
