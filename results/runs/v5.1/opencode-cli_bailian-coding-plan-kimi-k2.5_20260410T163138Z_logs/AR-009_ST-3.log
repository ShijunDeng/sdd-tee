{"type":"tool_use","timestamp":1775857902995,"sessionID":"ses_2869f70cdffe6GHqTShtbr9109","part":{"id":"prt_d79611d2f001r3vU3oi5NJ2Avr","messageID":"msg_d79610eae001Ri7CXNWcK7kDzR","sessionID":"ses_2869f70cdffe6GHqTShtbr9109","type":"tool","tool":"read","callID":"toolu_functions.read:11","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/apis/runtime/v1alpha1/common_types.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/apis/runtime/v1alpha1/common_types.go</path>\n<type>file</type>\n<content>\n1: /*\n2: Copyright 2026 The Volcano Authors.\n3: \n4: Licensed under the Apache License, Version 2.0 (the \"License\");\n5: you may not use this file except in compliance with the License.\n6: You may obtain a copy of the License at\n7: \n8:     http://www.apache.org/licenses/LICENSE-2.0\n9: \n10: Unless required by applicable law or agreed to in writing, software\n11: distributed under the License is distributed on an \"AS IS\" BASIS,\n12: WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n13: See the License for the specific language governing permissions and\n14: limitations under the License.\n15: */\n16: \n17: package v1alpha1\n18: \n19: import (\n20: \tcorev1 \"k8s.io/api/core/v1\"\n21: \tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n22: )\n23: \n24: // Phase represents the common phase of a runtime resource.\n25: // This type is shared across different CRDs to provide consistent phase semantics.\n26: // +kubebuilder:validation:Enum=Pending;Running;Succeeded;Failed;Unknown\n27: // +kubebuilder:validation:Type=string\n28: type Phase string\n29: \n30: const (\n31: \t// PhasePending indicates the resource is being created or initialized.\n32: \tPhasePending Phase = \"Pending\"\n33: \n34: \t// PhaseRunning indicates the resource is active and running.\n35: \tPhaseRunning Phase = \"Running\"\n36: \n37: \t// PhaseSucceeded indicates the resource completed successfully.\n38: \tPhaseSucceeded Phase = \"Succeeded\"\n39: \n40: \t// PhaseFailed indicates the resource has failed.\n41: \tPhaseFailed Phase = \"Failed\"\n42: \n43: \t// PhaseUnknown indicates the resource state is unknown.\n44: \tPhaseUnknown Phase = \"Unknown\"\n45: )\n46: \n47: // ConditionType represents a common condition type for runtime resources.\n48: // This type is shared across different CRDs to provide consistent condition semantics.\n49: // +kubebuilder:validation:Enum=Ready;SandboxCreated;SandboxReady;Failed;Scheduled;Initialized\n50: // +kubebuilder:validation:Type=string\n51: type ConditionType string\n52: \n53: const (\n54: \t// ConditionReady indicates the resource is ready to accept requests.\n55: \tConditionReady ConditionType = \"Ready\"\n56: \n57: \t// ConditionSandboxCreated indicates the sandbox has been created.\n58: \tConditionSandboxCreated ConditionType = \"SandboxCreated\"\n59: \n60: \t// ConditionSandboxReady indicates the sandbox is ready for use.\n61: \tConditionSandboxReady ConditionType = \"SandboxReady\"\n62: \n63: \t// ConditionFailed indicates the resource has failed.\n64: \tConditionFailed ConditionType = \"Failed\"\n65: \n66: \t// ConditionScheduled indicates the resource has been scheduled.\n67: \tConditionScheduled ConditionType = \"Scheduled\"\n68: \n69: \t// ConditionInitialized indicates the resource has been initialized.\n70: \tConditionInitialized ConditionType = \"Initialized\"\n71: )\n72: \n73: // Condition represents a common condition for runtime resources.\n74: // This struct is shared across different CRDs to provide consistent condition representation.\n75: type Condition struct {\n76: \t// Type is the type of the condition.\n77: \t// +kubebuilder:validation:Required\n78: \tType ConditionType `json:\"type\"`\n79: \n80: \t// Status is the status of the condition (True, False, Unknown).\n81: \t// +kubebuilder:validation:Required\n82: \t// +kubebuilder:validation:Enum=True;False;Unknown\n83: \tStatus corev1.ConditionStatus `json:\"status\"`\n84: \n85: \t// LastTransitionTime is the last time the condition transitioned.\n86: \t// +kubebuilder:validation:Optional\n87: \tLastTransitionTime metav1.Time `json:\"lastTransitionTime,omitempty\"`\n88: \n89: \t// Reason is a brief reason for the condition's last transition.\n90: \t// +kubebuilder:validation:Optional\n91: \tReason string `json:\"reason,omitempty\"`\n92: \n93: \t// Message is a human-readable message indicating details about the transition.\n94: \t// +kubebuilder:validation:Optional\n95: \tMessage string `json:\"message,omitempty\"`\n96: \n97: \t// ObservedGeneration is the observed generation of the resource.\n98: \t// +kubebuilder:validation:Optional\n99: \t// +kubebuilder:validation:Minimum=0\n100: \tObservedGeneration int64 `json:\"observedGeneration,omitempty\"`\n101: }\n102: \n103: // ResourceReference represents a reference to a Kubernetes resource.\n104: // This type is used to reference resources across different namespaces.\n105: type ResourceReference struct {\n106: \t// Name is the name of the referenced resource.\n107: \t// +kubebuilder:validation:Required\n108: \t// +kubebuilder:validation:MinLength=1\n109: \tName string `json:\"name\"`\n110: \n111: \t// Namespace is the namespace of the referenced resource.\n112: \t// If not specified, the current namespace is used.\n113: \t// +kubebuilder:validation:Optional\n114: \tNamespace string `json:\"namespace,omitempty\"`\n115: }\n116: \n117: // LocalResourceReference represents a reference to a Kubernetes resource in the same namespace.\n118: type LocalResourceReference struct {\n119: \t// Name is the name of the referenced resource.\n120: \t// +kubebuilder:validation:Required\n121: \t// +kubebuilder:validation:MinLength=1\n122: \tName string `json:\"name\"`\n123: }\n124: \n125: // SecretReference represents a reference to a Kubernetes Secret.\n126: type SecretReference struct {\n127: \t// Name is the name of the secret.\n128: \t// +kubebuilder:validation:Required\n129: \t// +kubebuilder:validation:MinLength=1\n130: \tName string `json:\"name\"`\n131: \n132: \t// Key is the key within the secret to reference.\n133: \t// If not specified, all keys are referenced.\n134: \t// +kubebuilder:validation:Optional\n135: \tKey string `json:\"key,omitempty\"`\n136: }\n137: \n138: // ConfigMapReference represents a reference to a Kubernetes ConfigMap.\n139: type ConfigMapReference struct {\n140: \t// Name is the name of the configmap.\n141: \t// +kubebuilder:validation:Required\n142: \t// +kubebuilder:validation:MinLength=1\n143: \tName string `json:\"name\"`\n144: \n145: \t// Key is the key within the configmap to reference.\n146: \t// If not specified, all keys are referenced.\n147: \t// +kubebuilder:validation:Optional\n148: \tKey string `json:\"key,omitempty\"`\n149: }\n150: \n151: // ResourceRequirements represents the compute resource requirements for a sandbox.\n152: // This is a wrapper around corev1.ResourceRequirements with additional validation.\n153: type ResourceRequirements struct {\n154: \t// Limits describes the maximum amount of compute resources allowed.\n155: \t// +kubebuilder:validation:Optional\n156: \tLimits corev1.ResourceList `json:\"limits,omitempty\"`\n157: \n158: \t// Requests describes the minimum amount of compute resources required.\n159: \t// +kubebuilder:validation:Optional\n160: \tRequests corev1.ResourceList `json:\"requests,omitempty\"`\n161: }\n162: \n163: // SandboxTemplate defines a common template for creating sandboxes.\n164: // This struct can be reused across different CRD types.\n165: type SandboxTemplate struct {\n166: \t// Labels are optional labels to apply to the sandbox pod.\n167: \t// +kubebuilder:validation:Optional\n168: \t// +mapType=atomic\n169: \tLabels map[string]string `json:\"labels,omitempty\"`\n170: \n171: \t// Annotations are optional annotations to apply to the sandbox pod.\n172: \t// +kubebuilder:validation:Optional\n173: \t// +mapType=atomic\n174: \tAnnotations map[string]string `json:\"annotations,omitempty\"`\n175: \n176: \t// Spec is the Pod specification for the sandbox.\n177: \t// This field is optional and will be merged with default values.\n178: \t// +kubebuilder:validation:Optional\n179: \tSpec *corev1.PodSpec `json:\"spec,omitempty\"`\n180: }\n181: \n182: // StorageType represents the type of storage for volumes.\n183: // +kubebuilder:validation:Enum=EmptyDir;HostPath;PersistentVolumeClaim;ConfigMap;Secret\n184: // +kubebuilder:validation:Type=string\n185: type StorageType string\n186: \n187: const (\n188: \t// StorageTypeEmptyDir represents an empty directory storage.\n189: \tStorageTypeEmptyDir StorageType = \"EmptyDir\"\n190: \n191: \t// StorageTypeHostPath represents a host path storage.\n192: \tStorageTypeHostPath StorageType = \"HostPath\"\n193: \n194: \t// StorageTypePersistentVolumeClaim represents a PVC storage.\n195: \tStorageTypePersistentVolumeClaim StorageType = \"PersistentVolumeClaim\"\n196: \n197: \t// StorageTypeConfigMap represents a ConfigMap storage.\n198: \tStorageTypeConfigMap StorageType = \"ConfigMap\"\n199: \n200: \t// StorageTypeSecret represents a Secret storage.\n201: \tStorageTypeSecret StorageType = \"Secret\"\n202: )\n203: \n204: // VolumeSource represents a shared volume source definition.\n205: type VolumeSource struct {\n206: \t// Type is the type of storage.\n207: \t// +kubebuilder:validation:Required\n208: \tType StorageType `json:\"type\"`\n209: \n210: \t// EmptyDir represents an empty directory volume source.\n211: \t// +kubebuilder:validation:Optional\n212: \tEmptyDir *corev1.EmptyDirVolumeSource `json:\"emptyDir,omitempty\"`\n213: \n214: \t// HostPath represents a host path volume source.\n215: \t// +kubebuilder:validation:Optional\n216: \tHostPath *corev1.HostPathVolumeSource `json:\"hostPath,omitempty\"`\n217: \n218: \t// PersistentVolumeClaim represents a PVC volume source.\n219: \t// +kubebuilder:validation:Optional\n220: \tPersistentVolumeClaim *corev1.PersistentVolumeClaimVolumeSource `json:\"persistentVolumeClaim,omitempty\"`\n221: \n222: \t// ConfigMap represents a ConfigMap volume source.\n223: \t// +kubebuilder:validation:Optional\n224: \tConfigMap *corev1.ConfigMapVolumeSource `json:\"configMap,omitempty\"`\n225: \n226: \t// Secret represents a Secret volume source.\n227: \t// +kubebuilder:validation:Optional\n228: \tSecret *corev1.SecretVolumeSource `json:\"secret,omitempty\"`\n229: }\n230: \n231: // VolumeMount represents a mount point for a volume within a container.\n232: type VolumeMount struct {\n233: \t// Name is the name of the volume to mount.\n234: \t// +kubebuilder:validation:Required\n235: \t// +kubebuilder:validation:MinLength=1\n236: \tName string `json:\"name\"`\n237: \n238: \t// MountPath is the path within the container where the volume should be mounted.\n239: \t// +kubebuilder:validation:Required\n240: \t// +kubebuilder:validation:MinLength=1\n241: \tMountPath string `json:\"mountPath\"`\n242: \n243: \t// ReadOnly indicates whether the mount should be read-only.\n244: \t// +kubebuilder:validation:Optional\n245: \tReadOnly bool `json:\"readOnly,omitempty\"`\n246: \n247: \t// SubPath is the sub-path within the volume to mount.\n248: \t// +kubebuilder:validation:Optional\n249: \tSubPath string `json:\"subPath,omitempty\"`\n250: }\n251: \n252: // NetworkConfig represents common network configuration for sandboxes.\n253: type NetworkConfig struct {\n254: \t// HostNetwork indicates whether to use the host's network namespace.\n255: \t// +kubebuilder:validation:Optional\n256: \tHostNetwork bool `json:\"hostNetwork,omitempty\"`\n257: \n258: \t// HostPID indicates whether to use the host's PID namespace.\n259: \t// +kubebuilder:validation:Optional\n260: \tHostPID bool `json:\"hostPID,omitempty\"`\n261: \n262: \t// HostIPC indicates whether to use the host's IPC namespace.\n263: \t// +kubebuilder:validation:Optional\n264: \tHostIPC bool `json:\"hostIPC,omitempty\"`\n265: \n266: \t// DNSPolicy defines the DNS policy for the pod.\n267: \t// +kubebuilder:validation:Optional\n268: \tDNSPolicy corev1.DNSPolicy `json:\"dnsPolicy,omitempty\"`\n269: \n270: \t// DNSConfig specifies the DNS parameters of the pod.\n271: \t// +kubebuilder:validation:Optional\n272: \tDNSConfig *corev1.PodDNSConfig `json:\"dnsConfig,omitempty\"`\n273: }\n274: \n275: // SecurityContext represents common security context for sandboxes.\n276: type SecurityContext struct {\n277: \t// RunAsUser is the UID to run the entrypoint of the container process.\n278: \t// +kubebuilder:validation:Optional\n279: \t// +kubebuilder:validation:Minimum=0\n280: \tRunAsUser *int64 `json:\"runAsUser,omitempty\"`\n281: \n282: \t// RunAsGroup is the GID to run the entrypoint of the container process.\n283: \t// +kubebuilder:validation:Optional\n284: \t// +kubebuilder:validation:Minimum=0\n285: \tRunAsGroup *int64 `json:\"runAsGroup,omitempty\"`\n286: \n287: \t// RunAsNonRoot indicates that the container must run as a non-root user.\n288: \t// +kubebuilder:validation:Optional\n289: \tRunAsNonRoot *bool `json:\"runAsNonRoot,omitempty\"`\n290: \n291: \t// ReadOnlyRootFilesystem indicates whether the container's root filesystem is read-only.\n292: \t// +kubebuilder:validation:Optional\n293: \tReadOnlyRootFilesystem *bool `json:\"readOnlyRootFilesystem,omitempty\"`\n294: \n295: \t// Privileged indicates whether the container is privileged.\n296: \t// +kubebuilder:validation:Optional\n297: \tPrivileged *bool `json:\"privileged,omitempty\"`\n298: \n299: \t// AllowPrivilegeEscalation controls whether a process can gain more privileges than its parent process.\n300: \t// +kubebuilder:validation:Optional\n301: \tAllowPrivilegeEscalation *bool `json:\"allowPrivilegeEscalation,omitempty\"`\n302: }\n303: \n304: // LifecycleHooks represents lifecycle hooks for sandbox containers.\n305: type LifecycleHooks struct {\n306: \t// PostStart is a hook that is called after the container is started.\n307: \t// +kubebuilder:validation:Optional\n308: \tPostStart *corev1.LifecycleHandler `json:\"postStart,omitempty\"`\n309: \n310: \t// PreStop is a hook that is called before the container is terminated.\n311: \t// +kubebuilder:validation:Optional\n312: \tPreStop *corev1.LifecycleHandler `json:\"preStop,omitempty\"`\n313: }\n314: \n315: // HealthCheck represents health check configuration for sandboxes.\n316: type HealthCheck struct {\n317: \t// LivenessProbe specifies the liveness probe configuration.\n318: \t// +kubebuilder:validation:Optional\n319: \tLivenessProbe *corev1.Probe `json:\"livenessProbe,omitempty\"`\n320: \n321: \t// ReadinessProbe specifies the readiness probe configuration.\n322: \t// +kubebuilder:validation:Optional\n323: \tReadinessProbe *corev1.Probe `json:\"readinessProbe,omitempty\"`\n324: \n325: \t// StartupProbe specifies the startup probe configuration.\n326: \t// +kubebuilder:validation:Optional\n327: \tStartupProbe *corev1.Probe `json:\"startupProbe,omitempty\"`\n328: }\n329: \n330: // TimeoutConfig represents timeout configuration for sandbox resources.\n331: type TimeoutConfig struct {\n332: \t// TTLSecondsAfterFinished specifies the time to live (in seconds) after\n333: \t// the resource has finished (succeeded or failed).\n334: \t// +kubebuilder:validation:Optional\n335: \t// +kubebuilder:validation:Minimum=0\n336: \tTTLSecondsAfterFinished *int32 `json:\"ttlSecondsAfterFinished,omitempty\"`\n337: \n338: \t// IdleTimeoutSeconds specifies the maximum time (in seconds) the resource\n339: \t// can be idle before being terminated.\n340: \t// +kubebuilder:validation:Optional\n341: \t// +kubebuilder:validation:Minimum=1\n342: \tIdleTimeoutSeconds *int32 `json:\"idleTimeoutSeconds,omitempty\"`\n343: \n344: \t// MaxLifetimeSeconds specifies the maximum lifetime (in seconds) of the resource.\n345: \t// +kubebuilder:validation:Optional\n346: \t// +kubebuilder:validation:Minimum=1\n347: \tMaxLifetimeSeconds *int32 `json:\"maxLifetimeSeconds,omitempty\"`\n348: \n349: \t// GracePeriodSeconds specifies the duration in seconds the pod needs to\n350: \t// terminate gracefully upon deletion.\n351: \t// +kubebuilder:validation:Optional\n352: \t// +kubebuilder:validation:Minimum=0\n353: \tGracePeriodSeconds *int64 `json:\"gracePeriodSeconds,omitempty\"`\n354: }\n\n(End of file - total 354 lines)\n</content>","metadata":{"preview":"/*\nCopyright 2026 The Volcano Authors.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\npackage v1alpha1\n\nimport (\n\tcorev1 \"k8s.io/api/core/v1\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/apis/runtime/v1alpha1/common_types.go","time":{"start":1775857902935,"end":1775857902993}}}}
{"type":"tool_use","timestamp":1775857903027,"sessionID":"ses_2869f70cdffe6GHqTShtbr9109","part":{"id":"prt_d796118b1001ySV8ayx7ds1czK","messageID":"msg_d79610eae001Ri7CXNWcK7kDzR","sessionID":"ses_2869f70cdffe6GHqTShtbr9109","type":"tool","tool":"read","callID":"toolu_functions.read:10","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/apis/runtime/v1alpha1/agentruntime_types.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/apis/runtime/v1alpha1/agentruntime_types.go</path>\n<type>file</type>\n<content>\n1: /*\n2: Copyright 2026 The Volcano Authors.\n3: \n4: Licensed under the Apache License, Version 2.0 (the \"License\");\n5: you may not use this file except in compliance with the License.\n6: You may obtain a copy of the License at\n7: \n8:     http://www.apache.org/licenses/LICENSE-2.0\n9: \n10: Unless required by applicable law or agreed to in writing, software\n11: distributed under the License is distributed on an \"AS IS\" BASIS,\n12: WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n13: See the License for the specific language governing permissions and\n14: limitations under the License.\n15: */\n16: \n17: package v1alpha1\n18: \n19: import (\n20: \tcorev1 \"k8s.io/api/core/v1\"\n21: \tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n22: )\n23: \n24: // AgentRuntimePhase represents the current phase of an AgentRuntime.\n25: // +kubebuilder:validation:Enum=Pending;Running;Succeeded;Failed;Unknown\n26: // +kubebuilder:validation:Type=string\n27: type AgentRuntimePhase string\n28: \n29: const (\n30: \t// AgentRuntimePhasePending indicates the sandbox is being created.\n31: \tAgentRuntimePhasePending AgentRuntimePhase = \"Pending\"\n32: \n33: \t// AgentRuntimePhaseRunning indicates the sandbox is active and running.\n34: \tAgentRuntimePhaseRunning AgentRuntimePhase = \"Running\"\n35: \n36: \t// AgentRuntimePhaseSucceeded indicates the sandbox completed successfully.\n37: \tAgentRuntimePhaseSucceeded AgentRuntimePhase = \"Succeeded\"\n38: \n39: \t// AgentRuntimePhaseFailed indicates the sandbox failed.\n40: \tAgentRuntimePhaseFailed AgentRuntimePhase = \"Failed\"\n41: \n42: \t// AgentRuntimePhaseUnknown indicates the sandbox state is unknown.\n43: \tAgentRuntimePhaseUnknown AgentRuntimePhase = \"Unknown\"\n44: )\n45: \n46: // AgentRuntimeConditionType represents a condition type for AgentRuntime.\n47: // +kubebuilder:validation:Enum=Ready;SandboxCreated;SandboxReady;Failed\n48: // +kubebuilder:validation:Type=string\n49: type AgentRuntimeConditionType string\n50: \n51: const (\n52: \t// AgentRuntimeConditionReady indicates the AgentRuntime is ready to accept requests.\n53: \tAgentRuntimeConditionReady AgentRuntimeConditionType = \"Ready\"\n54: \n55: \t// AgentRuntimeConditionSandboxCreated indicates the sandbox has been created.\n56: \tAgentRuntimeConditionSandboxCreated AgentRuntimeConditionType = \"SandboxCreated\"\n57: \n58: \t// AgentRuntimeConditionSandboxReady indicates the sandbox is ready for use.\n59: \tAgentRuntimeConditionSandboxReady AgentRuntimeConditionType = \"SandboxReady\"\n60: \n61: \t// AgentRuntimeConditionFailed indicates the AgentRuntime has failed.\n62: \tAgentRuntimeConditionFailed AgentRuntimeConditionType = \"Failed\"\n63: )\n64: \n65: // AgentRuntimeSpec defines the desired state of AgentRuntime.\n66: // This specification describes the configuration for a sandbox instance\n67: // that will run an AI agent.\n68: type AgentRuntimeSpec struct {\n69: \t// Image is the container image to use for the sandbox.\n70: \t// This field is required and must be a valid container image reference.\n71: \t// +kubebuilder:validation:Required\n72: \t// +kubebuilder:validation:MinLength=1\n73: \tImage string `json:\"image\"`\n74: \n75: \t// Resources defines the compute resources (CPU, memory) for the sandbox.\n76: \t// If not specified, default resource limits will be applied.\n77: \t// +kubebuilder:validation:Optional\n78: \tResources *corev1.ResourceRequirements `json:\"resources,omitempty\"`\n79: \n80: \t// Env defines environment variables to set in the sandbox container.\n81: \t// These variables will be available to the running agent.\n82: \t// +kubebuilder:validation:Optional\n83: \t// +listType=map\n84: \t// +listMapKey=name\n85: \tEnv []corev1.EnvVar `json:\"env,omitempty\"`\n86: \n87: \t// Command overrides the default container entrypoint.\n88: \t// If not specified, the image's default entrypoint will be used.\n89: \t// +kubebuilder:validation:Optional\n90: \tCommand []string `json:\"command,omitempty\"`\n91: \n92: \t// Args provides arguments to the command or the default entrypoint.\n93: \t// +kubebuilder:validation:Optional\n94: \tArgs []string `json:\"args,omitempty\"`\n95: \n96: \t// WorkingDir specifies the working directory for the container.\n97: \t// If not specified, the container's default working directory will be used.\n98: \t// +kubebuilder:validation:Optional\n99: \tWorkingDir string `json:\"workingDir,omitempty\"`\n100: \n101: \t// Ports defines the ports to expose from the sandbox container.\n102: \t// +kubebuilder:validation:Optional\n103: \t// +listType=map\n104: \t// +listMapKey=containerPort\n105: \tPorts []corev1.ContainerPort `json:\"ports,omitempty\"`\n106: \n107: \t// VolumeMounts defines volumes to mount into the sandbox container.\n108: \t// +kubebuilder:validation:Optional\n109: \t// +listType=map\n110: \t// +listMapKey=name\n111: \tVolumeMounts []corev1.VolumeMount `json:\"volumeMounts,omitempty\"`\n112: \n113: \t// Volumes defines the volumes that can be mounted by the sandbox.\n114: \t// +kubebuilder:validation:Optional\n115: \t// +listType=map\n116: \t// +listMapKey=name\n117: \tVolumes []corev1.Volume `json:\"volumes,omitempty\"`\n118: \n119: \t// ServiceAccountName specifies the service account to use for the sandbox pod.\n120: \t// If not specified, the default service account will be used.\n121: \t// +kubebuilder:validation:Optional\n122: \tServiceAccountName string `json:\"serviceAccountName,omitempty\"`\n123: \n124: \t// NodeSelector specifies node labels for pod scheduling.\n125: \t// The pod will only be scheduled on nodes matching these labels.\n126: \t// +kubebuilder:validation:Optional\n127: \t// +mapType=atomic\n128: \tNodeSelector map[string]string `json:\"nodeSelector,omitempty\"`\n129: \n130: \t// Tolerations allow the pod to be scheduled on nodes with matching taints.\n131: \t// +kubebuilder:validation:Optional\n132: \t// +listType=atomic\n133: \tTolerations []corev1.Toleration `json:\"tolerations,omitempty\"`\n134: \n135: \t// Affinity defines the scheduling constraints for the pod.\n136: \t// +kubebuilder:validation:Optional\n137: \tAffinity *corev1.Affinity `json:\"affinity,omitempty\"`\n138: \n139: \t// TTLSecondsAfterFinished specifies the time to live (in seconds) after\n140: \t// the sandbox has finished (succeeded or failed). The sandbox will be\n141: \t// automatically deleted after this time.\n142: \t// If not specified, the sandbox will not be automatically deleted.\n143: \t// +kubebuilder:validation:Optional\n144: \t// +kubebuilder:validation:Minimum=0\n145: \tTTLSecondsAfterFinished *int32 `json:\"ttlSecondsAfterFinished,omitempty\"`\n146: \n147: \t// IdleTimeoutSeconds specifies the maximum time (in seconds) the sandbox\n148: \t// can be idle before being terminated. If not specified, no idle timeout\n149: \t// is enforced.\n150: \t// +kubebuilder:validation:Optional\n151: \t// +kubebuilder:validation:Minimum=1\n152: \tIdleTimeoutSeconds *int32 `json:\"idleTimeoutSeconds,omitempty\"`\n153: \n154: \t// MaxLifetimeSeconds specifies the maximum lifetime (in seconds) of the sandbox.\n155: \t// The sandbox will be terminated after this duration regardless of activity.\n156: \t// If not specified, no maximum lifetime is enforced.\n157: \t// +kubebuilder:validation:Optional\n158: \t// +kubebuilder:validation:Minimum=1\n159: \tMaxLifetimeSeconds *int32 `json:\"maxLifetimeSeconds,omitempty\"`\n160: }\n161: \n162: // AgentRuntimeStatus defines the observed state of AgentRuntime.\n163: // This status is updated by the controller to reflect the current\n164: // state of the sandbox instance.\n165: type AgentRuntimeStatus struct {\n166: \t// Phase represents the current phase of the AgentRuntime.\n167: \t// Possible values: Pending, Running, Succeeded, Failed, Unknown.\n168: \t// +kubebuilder:validation:Optional\n169: \tPhase AgentRuntimePhase `json:\"phase,omitempty\"`\n170: \n171: \t// Conditions represents the latest available observations of the AgentRuntime's state.\n172: \t// +kubebuilder:validation:Optional\n173: \t// +listType=map\n174: \t// +listMapKey=type\n175: \t// +patchMergeKey=type\n176: \t// +patchStrategy=merge\n177: \tConditions []AgentRuntimeCondition `json:\"conditions,omitempty\"`\n178: \n179: \t// SandboxID is the unique identifier of the created sandbox pod.\n180: \t// This is set once the sandbox pod has been successfully created.\n181: \t// +kubebuilder:validation:Optional\n182: \tSandboxID string `json:\"sandboxId,omitempty\"`\n183: \n184: \t// PodName is the name of the pod running the sandbox.\n185: \t// +kubebuilder:validation:Optional\n186: \tPodName string `json:\"podName,omitempty\"`\n187: \n188: \t// PodIP is the IP address assigned to the sandbox pod.\n189: \t// +kubebuilder:validation:Optional\n190: \tPodIP string `json:\"podIP,omitempty\"`\n191: \n192: \t// StartTime is the time when the sandbox was started.\n193: \t// +kubebuilder:validation:Optional\n194: \tStartTime *metav1.Time `json:\"startTime,omitempty\"`\n195: \n196: \t// CompletionTime is the time when the sandbox completed (succeeded or failed).\n197: \t// +kubebuilder:validation:Optional\n198: \tCompletionTime *metav1.Time `json:\"completionTime,omitempty\"`\n199: \n200: \t// LastActivityTime is the time of the last activity in the sandbox.\n201: \t// Used for idle timeout tracking.\n202: \t// +kubebuilder:validation:Optional\n203: \tLastActivityTime *metav1.Time `json:\"lastActivityTime,omitempty\"`\n204: \n205: \t// Message provides a human-readable description of the current status.\n206: \t// This may contain error messages or other status information.\n207: \t// +kubebuilder:validation:Optional\n208: \tMessage string `json:\"message,omitempty\"`\n209: \n210: \t// Reason provides a brief reason for the current phase.\n211: \t// This is typically a CamelCase string indicating why the phase is set.\n212: \t// +kubebuilder:validation:Optional\n213: \tReason string `json:\"reason,omitempty\"`\n214: \n215: \t// ObservedGeneration is the most recent generation observed by the controller.\n216: \t// This is used to determine if the spec has been processed.\n217: \t// +kubebuilder:validation:Optional\n218: \t// +kubebuilder:validation:Minimum=0\n219: \tObservedGeneration int64 `json:\"observedGeneration,omitempty\"`\n220: }\n221: \n222: // AgentRuntimeCondition represents a condition of an AgentRuntime.\n223: type AgentRuntimeCondition struct {\n224: \t// Type is the type of the condition.\n225: \t// +kubebuilder:validation:Required\n226: \tType AgentRuntimeConditionType `json:\"type\"`\n227: \n228: \t// Status is the status of the condition (True, False, Unknown).\n229: \t// +kubebuilder:validation:Required\n230: \t// +kubebuilder:validation:Enum=True;False;Unknown\n231: \tStatus corev1.ConditionStatus `json:\"status\"`\n232: \n233: \t// LastTransitionTime is the last time the condition transitioned.\n234: \t// +kubebuilder:validation:Optional\n235: \tLastTransitionTime metav1.Time `json:\"lastTransitionTime,omitempty\"`\n236: \n237: \t// Reason is a brief reason for the condition's last transition.\n238: \t// +kubebuilder:validation:Optional\n239: \tReason string `json:\"reason,omitempty\"`\n240: \n241: \t// Message is a human-readable message indicating details about the transition.\n242: \t// +kubebuilder:validation:Optional\n243: \tMessage string `json:\"message,omitempty\"`\n244: }\n245: \n246: // +genclient\n247: // +genclient:noStatus\n248: // +k8s:deepcopy-gen:interfaces=k8s.io/apimachinery/pkg/runtime.Object\n249: // +kubebuilder:object:root=true\n250: // +kubebuilder:resource:path=agentruntimes,shortName=ar;ars,singular=agentruntime,categories={agentcube,all}\n251: // +kubebuilder:subresource:status\n252: // +kubebuilder:printcolumn:name=\"Phase\",type=string,JSONPath=`.status.phase`,description=\"Current phase of the agent runtime\"\n253: // +kubebuilder:printcolumn:name=\"Sandbox\",type=string,JSONPath=`.status.sandboxId`,description=\"ID of the sandbox pod\"\n254: // +kubebuilder:printcolumn:name=\"Age\",type=date,JSONPath=`.metadata.creationTimestamp`,description=\"Time since creation\"\n255: // +kubebuilder:printcolumn:name=\"Message\",type=string,JSONPath=`.status.message`,priority=1\n256: \n257: // AgentRuntime is the Schema for the agentruntimes API.\n258: // An AgentRuntime represents a sandbox instance for running AI agents.\n259: // The controller creates and manages the lifecycle of the underlying\n260: // sandbox pod based on this resource.\n261: type AgentRuntime struct {\n262: \tmetav1.TypeMeta   `json:\",inline\"`\n263: \tmetav1.ObjectMeta `json:\"metadata,omitempty\"`\n264: \n265: \t// Spec defines the desired state of the AgentRuntime.\n266: \t// +kubebuilder:validation:Required\n267: \tSpec AgentRuntimeSpec `json:\"spec,omitempty\"`\n268: \n269: \t// Status defines the observed state of the AgentRuntime.\n270: \t// +kubebuilder:validation:Optional\n271: \tStatus AgentRuntimeStatus `json:\"status,omitempty\"`\n272: }\n273: \n274: // +k8s:deepcopy-gen:interfaces=k8s.io/apimachinery/pkg/runtime.Object\n275: // +kubebuilder:object:root=true\n276: \n277: // AgentRuntimeList contains a list of AgentRuntime resources.\n278: type AgentRuntimeList struct {\n279: \tmetav1.TypeMeta `json:\",inline\"`\n280: \tmetav1.ListMeta `json:\"metadata,omitempty\"`\n281: \n282: \t// Items is the list of AgentRuntime resources.\n283: \t// +kubebuilder:validation:Required\n284: \tItems []AgentRuntime `json:\"items\"`\n285: }\n\n(End of file - total 285 lines)\n</content>","metadata":{"preview":"/*\nCopyright 2026 The Volcano Authors.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\npackage v1alpha1\n\nimport (\n\tcorev1 \"k8s.io/api/core/v1\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/apis/runtime/v1alpha1/agentruntime_types.go","time":{"start":1775857902930,"end":1775857903020}}}}
