{"type":"tool_use","timestamp":1775857958230,"sessionID":"ses_2869f70cdffe6GHqTShtbr9109","part":{"id":"prt_d7961f4cc00174CsC6kmv6w0Oy","messageID":"msg_d7961d083001KW4ldJZ3x6HZG1","sessionID":"ses_2869f70cdffe6GHqTShtbr9109","type":"tool","tool":"read","callID":"toolu_functions.read:18","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/workloadmanager/types/request.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/workloadmanager/types/request.go</path>\n<type>file</type>\n<content>\n1: /*\n2: Copyright 2026 The Volcano Authors.\n3: \n4: Licensed under the Apache License, Version 2.0 (the \"License\");\n5: you may not use this file except in compliance with the License.\n6: You may obtain a copy of the License at\n7: \n8:     http://www.apache.org/licenses/LICENSE-2.0\n9: \n10: Unless required by applicable law or agreed to in writing, software\n11: distributed under the License is distributed on an \"AS IS\" BASIS,\n12: WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n13: See the License for the specific language governing permissions and\n14: limitations under the License.\n15: */\n16: \n17: package types\n18: \n19: import (\n20: \t\"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1\"\n21: )\n22: \n23: // WorkloadType defines the type of workload.\n24: type WorkloadType string\n25: \n26: const (\n27: \t// WorkloadTypeAgentRuntime represents an AgentRuntime workload.\n28: \tWorkloadTypeAgentRuntime WorkloadType = \"agentruntime\"\n29: \n30: \t// WorkloadTypeCodeInterpreter represents a CodeInterpreter workload.\n31: \tWorkloadTypeCodeInterpreter WorkloadType = \"codeinterpreter\"\n32: )\n33: \n34: // CreateWorkloadRequest represents a request to create a new workload.\n35: type CreateWorkloadRequest struct {\n36: \t// Namespace is the Kubernetes namespace (default: default)\n37: \tNamespace string `json:\"namespace,omitempty\" validate:\"omitempty,k8sNamespace\"`\n38: \n39: \t// Name is the workload name (optional, auto-generated if not provided)\n40: \tName string `json:\"name,omitempty\" validate:\"omitempty,k8sName\"`\n41: \n42: \t// Type is the workload type: \"agentruntime\" or \"codeinterpreter\"\n43: \tType WorkloadType `json:\"type\" validate:\"required,oneof=agentruntime codeinterpreter\"`\n44: \n45: \t// AgentRuntimeSpec is the specification for AgentRuntime workloads\n46: \tAgentRuntimeSpec *v1alpha1.AgentRuntimeSpec `json:\"agentRuntimeSpec,omitempty\" validate:\"required_if=Type agentruntime\"`\n47: \n48: \t// CodeInterpreterSpec is the specification for CodeInterpreter workloads\n49: \tCodeInterpreterSpec *v1alpha1.CodeInterpreterSpec `json:\"codeInterpreterSpec,omitempty\" validate:\"required_if=Type codeinterpreter\"`\n50: \n51: \t// Labels are workload labels\n52: \tLabels map[string]string `json:\"labels,omitempty\"`\n53: \n54: \t// Annotations are workload annotations\n55: \tAnnotations map[string]string `json:\"annotations,omitempty\"`\n56: }\n57: \n58: // UpdateWorkloadRequest represents a request to update an existing workload.\n59: type UpdateWorkloadRequest struct {\n60: \t// AgentRuntimeSpec is the updated specification for AgentRuntime workloads\n61: \tAgentRuntimeSpec *v1alpha1.AgentRuntimeSpec `json:\"agentRuntimeSpec,omitempty\"`\n62: \n63: \t// CodeInterpreterSpec is the updated specification for CodeInterpreter workloads\n64: \tCodeInterpreterSpec *v1alpha1.CodeInterpreterSpec `json:\"codeInterpreterSpec,omitempty\"`\n65: \n66: \t// Labels are updated workload labels (merged with existing)\n67: \tLabels map[string]string `json:\"labels,omitempty\"`\n68: \n69: \t// Annotations are updated workload annotations (merged with existing)\n70: \tAnnotations map[string]string `json:\"annotations,omitempty\"`\n71: }\n72: \n73: // ListWorkloadsRequest represents parameters for listing workloads.\n74: type ListWorkloadsRequest struct {\n75: \t// Namespace filters by namespace (default: all namespaces)\n76: \tNamespace string `query:\"namespace\"`\n77: \n78: \t// Type filters by workload type\n79: \tType WorkloadType `query:\"type\" validate:\"omitempty,oneof=agentruntime codeinterpreter\"`\n80: \n81: \t// LabelSelector filters by label selector\n82: \tLabelSelector string `query:\"labelSelector\"`\n83: \n84: \t// FieldSelector filters by field selector\n85: \tFieldSelector string `query:\"fieldSelector\"`\n86: \n87: \t// Limit is the maximum number of results to return (default: 100, max: 1000)\n88: \tLimit int `query:\"limit\" validate:\"min=1,max=1000\"`\n89: \n90: \t// Continue is the continuation token for pagination\n91: \tContinue string `query:\"continue\"`\n92: }\n93: \n94: // WatchOptions contains options for watching workloads.\n95: type WatchOptions struct {\n96: \t// Namespace filters by namespace\n97: \tNamespace string\n98: \n99: \t// Type filters by workload type\n100: \tType WorkloadType\n101: \n102: \t// LabelSelector filters by label selector\n103: \tLabelSelector string\n104: \n105: \t// ResourceVersion watches from specific resource version\n106: \tResourceVersion string\n107: }\n108: \n109: // WatchStream represents a stream of workload events.\n110: type WatchStream interface {\n111: \t// Next returns the next event or error\n112: \tNext() (*WorkloadEvent, error)\n113: \n114: \t// Stop stops the watch stream\n115: \tStop()\n116: }\n117: \n118: // WorkloadEvent represents a workload watch event.\n119: type WorkloadEvent struct {\n120: \t// Type is the event type: \"ADDED\", \"MODIFIED\", \"DELETED\"\n121: \tType string `json:\"type\"`\n122: \n123: \t// Workload is the workload data\n124: \tWorkload *WorkloadResponse `json:\"workload\"`\n125: }\n\n(End of file - total 125 lines)\n</content>","metadata":{"preview":"/*\nCopyright 2026 The Volcano Authors.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\npackage types\n\nimport (\n\t\"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/workloadmanager/types/request.go","time":{"start":1775857958214,"end":1775857958228}}}}
