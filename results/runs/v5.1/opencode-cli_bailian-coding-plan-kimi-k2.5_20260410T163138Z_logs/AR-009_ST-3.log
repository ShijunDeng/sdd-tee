(if known)\n94: \tRemainingItemCount *int64 `json:\"remainingItemCount,omitempty\"`\n95: }\n96: \n97: // HealthResponse represents the health check response.\n98: type HealthResponse struct {\n99: \t// Status is the health status: \"healthy\", \"degraded\", or \"unhealthy\"\n100: \tStatus string `json:\"status\"`\n101: \n102: \t// Checks contains individual health check results\n103: \tChecks map[string]HealthCheck `json:\"checks,omitempty\"`\n104: \n105: \t// Version is the server version\n106: \tVersion string `json:\"version\"`\n107: }\n108: \n109: // HealthCheck represents an individual health check.\n110: type HealthCheck struct {\n111: \t// Status is the check status: \"pass\", \"fail\", or \"warn\"\n112: \tStatus string `json:\"status\"`\n113: \n114: \t// Message provides additional context\n115: \tMessage string `json:\"message,omitempty\"`\n116: \n117: \t// LastChecked is the timestamp of the last check\n118: \tLastChecked string `json:\"lastChecked\"`\n119: }\n120: \n121: // DeleteWorkloadResponse represents a delete workload response.\n122: type DeleteWorkloadResponse struct {\n123: \t// Deleted indicates if the workload was successfully deleted\n124: \tDeleted bool `json:\"deleted\"`\n125: \n126: \t// Namespace is the namespace of the deleted workload\n127: \tNamespace string `json:\"namespace\"`\n128: \n129: \t// Name is the name of the deleted workload\n130: \tName string `json:\"name\"`\n131: \n132: \t// Type is the type of the deleted workload\n133: \tType WorkloadType `json:\"type\"`\n134: }\n\n(End of file - total 134 lines)\n</content>","metadata":{"preview":"/*\nCopyright 2026 The Volcano Authors.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS I