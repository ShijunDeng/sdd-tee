that exit_code is stored.\"\"\"\n40:         error = CommandExecutionError(exit_code=1, stderr=\"error\")\n41:         assert error.exit_code == 1\n42: \n43:     def test_stores_stderr(self):\n44:         \"\"\"Test that stderr is stored.\"\"\"\n45:         error = CommandExecutionError(exit_code=1, stderr=\"error output\")\n46:         assert error.stderr == \"error output\"\n47: \n48:     def test_stores_command(self):\n49:         \"\"\"Test that command is stored.\"\"\"\n50:         error = CommandExecutionError(exit_code=1, stderr=\"error\", command=\"ls -la\")\n51:         assert error.command == \"ls -la\"\n52: \n53:     def test_message_without_command(self):\n54:         \"\"\"Test message format without command.\"\"\"\n55:         error = CommandExecutionError(exit_code=1, stderr=\"failed\")\n56:         assert str(error) == \"Command failed (exit 1): failed\"\n57: \n58:     def test_message_with_command(self):\n59:         \"\"\"Test message format with command.\"\"\"\n60:         error = CommandExecutionError(exit_code=1, stderr=\"failed\", command=\"python script.py\")\n61:         assert str(error) == \"Command 'python script.py' failed (exit 1): failed\"\n62: \n63:     def test_can_be_raised(self):\n64:         \"\"\"Test that CommandExecutionError can be raised and caught.\"\"\"\n65:         with pytest.raises(CommandExecutionError) as exc_info:\n66:             raise CommandExecutionError(exit_code=127, stderr=\"command not found\")\n67:         assert exc_info.value.exit_code == 127\n68: \n69: \n70: class TestSessionError:\n71:     \"\"\"Tests for SessionError.\"\"\"\n72: \n73:     def test_is_agentcube_error_subclass(self):\n74:         \"\"\"Test that SessionError is an AgentCubeError subclass.\"\"\"\n75:         assert issubclass(SessionError, AgentCubeError)\n76: \n77:     def test_can_be_raised(self):\n78:         \"\"\"Test that SessionError can be raised and caught.\"\"\"\n79:         with pytest.raises(SessionError):\n80:             raise 