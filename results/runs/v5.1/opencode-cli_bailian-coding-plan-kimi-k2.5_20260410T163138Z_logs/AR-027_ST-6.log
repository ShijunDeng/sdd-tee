bose: bool = False,\n39:         session_id: Optional[str] = None,\n40:         timeout: int = 120,\n41:         connect_timeout: float = 5.0,\n42:     ):\n43:         \"\"\"Initialize the Agent Runtime client.\n44: \n45:         Args:\n46:             agent_name: Name of the agent to invoke.\n47:             namespace: Kubernetes namespace (default: \"default\").\n48:             router_url: Router URL (or env ROUTER_URL, required).\n49:             verbose: Enable verbose logging.\n50:             session_id: Existing session ID to reuse.\n51:             timeout: Read timeout in seconds (default: 120).\n52:             connect_timeout: Connect timeout in seconds (default: 5.0).\n53: \n54:         Raises:\n55:             ValueError: If router_url is not provided and ROUTER_URL env is not set.\n56:             ValueError: If bootstrapping session ID fails.\n57:         \"\"\"\n58:         self.agent_name = agent_name\n59:         self.namespace = namespace\n60:         self.timeout = timeout\n61:         self.connect_timeout = connect_timeout\n62:         self.verbose = verbose\n63:         self.logger = get_logger(\n64:             __name__,\n65:             logging.DEBUG if verbose else logging.INFO,\n66:         )\n67: \n68:         # Resolve router URL (required)\n69:         self.router_url = router_url or os.environ.get(\"ROUTER_URL\")\n70:         if not self.router_url:\n71:             raise ValueError(\n72:                 \"Router URL must be provided via argument or ROUTER_URL environment variable\"\n73:             )\n74: \n75:         # Build base URL\n76:         base_path = f\"/v1/namespaces/{namespace}/agent-runtimes/{agent_name}/invocations/\"\n77:         base_url = urljoin(self.router_url, base_path)\n78: \n79:         # Initialize data plane client\n80:         self.dp_client = AgentRuntimeDataPlaneClient(\n81:             base_url=base_url,\n82:             timeout=timeout,\n83:             connect_timeout=connect_timeout,\n84:         )\n85: \n86:         # Initialize session ID\n87:         if session_id:\n88:             self.session_id = session_id\n89:         else:\n90:             self.session_id = self.dp_client.bootstrap_session_id()\n91: \n92:     def invoke(\n93:         self,\n94:         payload: Dict[str, Any],\n95:         timeout: Optional[int] = None,\n96:     ) -> Dict[str, Any]:\n97:         \"\"\"Invoke the Agent Runtime with a payload.\n98: \n99:         Args:\n100:             payload: JSON payload to send to the agent.\n101:             timeout: Optional timeout override in seconds.\n102: \n103:         Returns:\n104:             Response data as a dictionary.\n105: \n106:         Raises:\n107:             ValueError: If session_id is not initialized.\n108:             requests.RequestException: If the HTTP request fails.\n109:         \"\"\"\n110:         if not self.session_id:\n111:             raise ValueError(\"AgentRuntime session_id is not initialized\")\n112: \n113:         response = self.dp_client.invoke(\n114:             session_id=self.session_id,\n115:             payload=payload,\n116:             timeout=timeout,\n117:         )\n118: \n119:         return response.json()\n120: \n121:     def close(self) -> None:\n122:         \"\"\"Close the client and release resources.\"\"\"\n123:         if self.dp_client:\n124:             self.dp_client.close()\n125: \n126:     def __enter__(self) -> \"AgentRuntimeClient\":\n127:         \"\"\"Context manager entry.\"\"\"\n128:         return self\n129: \n130:     def __exit__(self, exc_type, exc_val, exc_tb) -> None:\n131:         \"\"\"Context manager exit - close resources.\"\"\"\n132:         self.close()\n\n(End of file - total 132 lines)\n</content>","metadata":{"preview":"\"\"\"High-level client for Agent Runtime invocation.\n\nThis module provides the AgentRuntimeClient, a high-level interface for\ninvoking Agent Runtime workloads through the Router.\n\"\"\"\n\nimport logging\nimport os\nfrom typing import Any, Dict, 