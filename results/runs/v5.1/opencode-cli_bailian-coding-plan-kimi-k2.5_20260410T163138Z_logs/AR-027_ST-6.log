turn f.read().strip()\n47:     except (IOError, OSError):\n48:         return \"\"\n49: \n50: \n51: SERVICE_ACCOUNT_TOKEN_PATH = \"/var/run/secrets/kubernetes.io/serviceaccount/token\"\n52: \n53: \n54: def get_service_account_token() -> Optional[str]:\n55:     \"\"\"Read the Kubernetes service account token.\n56: \n57:     Returns:\n58:         The service account token if available, None otherwise.\n59:     \"\"\"\n60:     token = read_token_from_file(SERVICE_ACCOUNT_TOKEN_PATH)\n61:     return token if token else None\n\n(End of file - total 61 lines)\n</content>","metadata":{"preview":"\"\"\"HTTP utilities for AgentCube SDK.\n\nThis module provides HTTP session factory and token reading utilities.\n\"\"\"\n\nfrom typing import Optional\n\nimport requests\nfrom requests.adapters import HTTPAdapter\n\n\ndef create_session(\n    pool_connections: int = 10,\n    pool_maxsize: int = 10,\n) -> requests.Session:\n    \"\"\"Create an HTTP session with connection pooling.\n\n    Args:\n        pool_connections: Number of connection pools to cache.\n        pool_maxsize: Maximum number of connections to save in the pool.","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/agentcube/utils/http.py","time":{"start":1775903986387,"end":1775903986440}}}}
