fined for extension; core client modules primarily use ValueError\n46:     or requests exceptions for session-related errors.\n47:     \"\"\"\n48: \n49:     pass\n50: \n51: \n52: class DataPlaneError(AgentCubeError):\n53:     \"\"\"Raised when Data Plane operations fail.\n54: \n55:     Defined for extension; core client modules may raise ValueError\n56:     or requests exceptions for data plane errors.\n57:     \"\"\"\n58: \n59:     pass\n\n(End of file - total 59 lines)\n</content>","metadata":{"preview":"\"\"\"Exception hierarchy for AgentCube SDK.\n\nThis module defines all custom exceptions used by the AgentCube SDK.\n\"\"\"\n\nfrom typing import Optional\n\n\nclass AgentCubeError(Exception):\n    \"\"\"Base exception for AgentCube SDK.\n\n    All SDK-specific exceptions inherit from this class.\n    \"\"\"\n\n    pass\n\n\nclass CommandExecutionError(AgentCubeError):\n    \"\"\"Raised when remote command returns non-zero exit code.\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/agentcube/exceptions.py","time":{"start":1775903986377,"end":1775903986429}}}}
