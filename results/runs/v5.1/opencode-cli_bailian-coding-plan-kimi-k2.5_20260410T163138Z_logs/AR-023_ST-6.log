{"type":"tool_use","timestamp":1775893678162,"sessionID":"ses_2847f2e74ffeGWPWz8Ke9vbXmV","part":{"id":"prt_d7b82f326001MgtYETYP8qBv5K","messageID":"msg_d7b82dc74001F1hkgHotLSLpSj","sessionID":"ses_2847f2e74ffeGWPWz8Ke9vbXmV","type":"tool","tool":"read","callID":"toolu_functions.read:24","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/agentcube/services/docker_service.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/agentcube/services/docker_service.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Docker service for AgentCube CLI.\n2: \n3: This module provides the DockerService class for building and managing\n4: Docker images using the Docker SDK.\n5: \"\"\"\n6: \n7: import logging\n8: import time\n9: from pathlib import Path\n10: from typing import Any, Dict, List, Optional\n11: \n12: import docker\n13: from docker.errors import BuildError, DockerException\n14: \n15: from agentcube.utils.log import get_logger\n16: \n17: \n18: def _format_image_id(image_id: Optional[str]) -> str:\n19:     \"\"\"Format Docker image ID for display.\n20: \n21:     Args:\n22:         image_id: Raw Docker image ID (may include 'sha256:' prefix).\n23: \n24:     Returns:\n25:         Formatted 12-character image ID.\n26:     \"\"\"\n27:     if not image_id:\n28:         return \"unknown\"\n29:     if \":\" in image_id:\n30:         return image_id.split(\":\")[-1][:12]\n31:     return image_id[:12]\n32: \n33: \n34: class DockerService:\n35:     \"\"\"Service for Docker image building and management.\"\"\"\n36: \n37:     def __init__(self, verbose: bool = False) -> None:\n38:         \"\"\"Initialize DockerService.\n39: \n40:         Args:\n41:             verbose: Whether to enable verbose logging.\n42:         \"\"\"\n43:         self.verbose = verbose\n44:         self.logger = get_logger(__name__, logging.DEBUG if verbose else logging.INFO)\n45:         self._client: Optional[docker.DockerClient] = None\n46: \n47:     def _get_client(self) -> docker.DockerClient:\n48:         \"\"\"Get or create Docker client.\n49: \n50:         Returns:\n51:             Docker client instance.\n52: \n53:         Raises:\n54:             RuntimeError: If Docker is not available or not running.\n55:         \"\"\"\n56:         if self._client is None:\n57:             try:\n58:                 self._client = docker.from_env()\n59:                 self._client.ping()  # Verify Docker is running\n60:             except DockerException as e:\n61:                 self.logger.error(f\"Docker connection failed: {e}\")\n62:                 raise RuntimeError(\"Docker is not available or not running\") from e\n63:         return self._client\n64: \n65:     def is_docker_available(self) -> bool:\n66:         \"\"\"Check if Docker daemon is available and running.\n67: \n68:         Returns:\n69:             True if Docker is available, False otherwise.\n70:         \"\"\"\n71:         try:\n72:             client = docker.from_env()\n73:             client.ping()\n74:             return True\n75:         except DockerException:\n76:             return False\n77: \n78:     def build_image(\n79:         self,\n80:         context_path: Path,\n81:         dockerfile_path: Path,\n82:         image_name: str,\n83:         tag: str,\n84:         build_args: Optional[Dict[str, str]] = None,\n85:     ) -> Dict[str, Any]:\n86:         \"\"\"Build a Docker image from a Dockerfile.\n87: \n88:         Args:\n89:             context_path: Path to the build context directory.\n90:             dockerfile_path: Path to the Dockerfile.\n91:             image_name: Name of the image to build.\n92:             tag: Tag for the image.\n93:             build_args: Optional build arguments to pass to Docker.\n94: \n95:         Returns:\n96:             Dict containing build results with keys:\n97:             - image_name: Name of the built image\n98:             - image_id: Docker image ID\n99:             - image_size: Human-readable image size\n100:             - build_time: Build duration in seconds\n101:             - image_tag: Full image tag (name:tag)\n102: \n103:         Raises:\n104:             RuntimeError: If the build fails or Docker is not available.\n105:             FileNotFoundError: If the Dockerfile does not exist.\n106:         \"\"\"\n107:         if not dockerfile_path.exists():\n108:             raise FileNotFoundError(f\"Dockerfile not found: {dockerfile_path}\")\n109: \n110:         if not context_path.exists():\n111:             raise FileNotFoundError(f\"Build context not found: {context_path}\")\n112: \n113:         client = self._get_client()\n114: \n115:         full_tag = f\"{image_name}:{tag}\"\n116:         self.logger.info(f\"Building Docker image: {full_tag}\")\n117:         self.logger.debug(f\"Context: {context_path}\")\n118:         self.logger.debug(f\"Dockerfile: {dockerfile_path}\")\n119: \n120:         # Prepare build arguments\n121:         dockerfile_rel = dockerfile_path.relative_to(context_path)\n122:         build_kwargs: Dict[str, Any] = {\n123:             \"path\": str(context_path),\n124:             \"dockerfile\": str(dockerfile_rel),\n125:             \"tag\": full_tag,\n126:             \"rm\": True,  # Remove intermediate containers\n127:             \"forcerm\": True,  # Force remove intermediate containers\n128:         }\n129: \n130:         if build_args:\n131:             build_kwargs[\"buildargs\"] = build_args\n132:             self.logger.debug(f\"Build args: {build_args}\")\n133: \n134:         # Build the image\n135:         start_time = time.time()\n136:         try:\n137:             image, build_logs = client.images.build(**build_kwargs)\n138:         except BuildError as e:\n139:             # Collect all error messages from build logs\n140:             error_msgs = []\n141:             for log in e.build_log:\n142:                 if \"error\" in log:\n143:                     error_msgs.append(log[\"error\"])\n144:             error_msg = \"; \".join(error_msgs) if error_msgs else str(e)\n145:             self.logger.error(f\"Docker build failed: {error_msg}\")\n146:             raise RuntimeError(f\"Docker build failed: {error_msg}\") from e\n147: \n148:         build_time = time.time() - start_time\n149: \n150:         # Get image details\n151:         image_id = _format_image_id(getattr(image, \"id\", None))\n152:         size_bytes = image.attrs.get(\"Size\", 0)\n153:         size_mb = size_bytes / (1024 * 1024)\n154: \n155:         self.logger.info(f\"Successfully built image {full_tag} ({image_id}) in {build_time:.2f}s\")\n156: \n157:         return {\n158:             \"image_name\": image_name,\n159:             \"image_tag\": tag,\n160:             \"image_id\": image_id,\n161:             \"image_size\": f\"{size_mb:.2f}MB\",\n162:             \"build_time\": f\"{build_time:.2f}\",\n163:             \"full_tag\": full_tag,\n164:         }\n165: \n166:     def tag_image(self, image_name: str, source_tag: str, target_tag: str) -> Dict[str, str]:\n167:         \"\"\"Tag an existing Docker image.\n168: \n169:         Args:\n170:             image_name: Name of the image.\n171:             source_tag: Source tag.\n172:             target_tag: Target tag to apply.\n173: \n174:         Returns:\n175:             Dict with tagging results.\n176:         \"\"\"\n177:         client = self._get_client()\n178: \n179:         full_source = f\"{image_name}:{source_tag}\"\n180:         full_target = f\"{image_name}:{target_tag}\"\n181: \n182:         try:\n183:             image = client.images.get(full_source)\n184:             image.tag(image_name, target_tag)\n185:             self.logger.info(f\"Tagged {full_source} as {full_target}\")\n186:             image_id = _format_image_id(getattr(image, \"id\", None))\n187:             return {\n188:                 \"source\": full_source,\n189:                 \"target\": full_target,\n190:                 \"image_id\": image_id,\n191:             }\n192:         except DockerException as e:\n193:             self.logger.error(f\"Failed to tag image: {e}\")\n194:             raise RuntimeError(f\"Failed to tag image: {e}\") from e\n195: \n196:     def get_image_info(self, image_name: str, tag: str = \"latest\") -> Dict[str, Any]:\n197:         \"\"\"Get information about a Docker image.\n198: \n199:         Args:\n200:             image_name: Name of the image.\n201:             tag: Tag of the image.\n202: \n203:         Returns:\n204:             Dict containing image information.\n205: \n206:         Raises:\n207:             RuntimeError: If the image does not exist.\n208:         \"\"\"\n209:         client = self._get_client()\n210:         full_tag = f\"{image_name}:{tag}\"\n211: \n212:         try:\n213:             image = client.images.get(full_tag)\n214:             size_bytes = image.attrs.get(\"Size\", 0)\n215:             size_mb = size_bytes / (1024 * 1024)\n216: \n217:             return {\n218:                 \"name\": image_name,\n219:                 \"tag\": tag,\n220:                 \"id\": _format_image_id(getattr(image, \"id\", None)),\n221:                 \"size\": f\"{size_mb:.2f}MB\",\n222:                 \"created\": image.attrs.get(\"Created\", \"\"),\n223:                 \"labels\": image.labels or {},\n224:             }\n225:         except DockerException as e:\n226:             self.logger.error(f\"Image not found: {full_tag}\")\n227:             raise RuntimeError(f\"Image not found: {full_tag}\") from e\n228: \n229:     def list_images(self, name: Optional[str] = None) -> List[Dict[str, Any]]:\n230:         \"\"\"List Docker images.\n231: \n232:         Args:\n233:             name: Optional filter by image name.\n234: \n235:         Returns:\n236:             List of image information dicts.\n237:         \"\"\"\n238:         client = self._get_client()\n239: \n240:         try:\n241:             images = client.images.list(name=name)\n242:             result = []\n243:             for image in images:\n244:                 size_bytes = image.attrs.get(\"Size\", 0)\n245:                 size_mb = size_bytes / (1024 * 1024)\n246:                 tags = image.tags if image.tags else [\"<none>:<none>\"]\n247: \n248:                 for tag in tags:\n249:                     if \":\" in tag:\n250:                         name_part, tag_part = tag.rsplit(\":\", 1)\n251:                     else:\n252:                         name_part, tag_part = tag, \"latest\"\n253: \n254:                     result.append(\n255:                         {\n256:                             \"name\": name_part,\n257:                             \"tag\": tag_part,\n258:                             \"id\": _format_image_id(getattr(image, \"id\", None)),\n259:                             \"size\": f\"{size_mb:.2f}MB\",\n260:                             \"created\": image.attrs.get(\"Created\", \"\"),\n261:                         }\n262:                     )\n263: \n264:             return result\n265:         except DockerException as e:\n266:             self.logger.error(f\"Failed to list images: {e}\")\n267:             raise RuntimeError(f\"Failed to list images: {e}\") from e\n268: \n269:     def push_image(\n270:         self,\n271:         image_name: str,\n272:         tag: str = \"latest\",\n273:         registry_url: Optional[str] = None,\n274:         username: Optional[str] = None,\n275:         password: Optional[str] = None,\n276:     ) -> Dict[str, Any]:\n277:         \"\"\"Push a Docker image to a registry.\n278: \n279:         Args:\n280:             image_name: Name of the image to push.\n281:             tag: Tag of the image (default: \"latest\").\n282:             registry_url: Optional registry URL (e.g., \"registry.example.com\").\n283:             username: Optional username for registry authentication.\n284:             password: Optional password for registry authentication.\n285: \n286:         Returns:\n287:             Dict containing push results with keys:\n288:             - image_name: Full image name including registry\n289:             - tag: Image tag\n290:             - registry: Registry URL (if any)\n291:             - pushed: Whether push was successful\n292: \n293:         Raises:\n294:             RuntimeError: If the push fails or image doesn't exist.\n295:         \"\"\"\n296:         client = self._get_client()\n297: \n298:         # Construct full image name\n299:         local_tag = f\"{image_name}:{tag}\"\n300:         if registry_url:\n301:             full_image_name = f\"{registry_url}/{image_name}:{tag}\"\n302:         else:\n303:             full_image_name = local_tag\n304: \n305:         self.logger.info(f\"Pushing image: {full_image_name}\")\n306: \n307:         try:\n308:             # Get the local image\n309:             image = client.images.get(local_tag)\n310: \n311:             # Tag with registry URL if different from local name\n312:             if registry_url and not local_tag.startswith(registry_url):\n313:                 image.tag(f\"{registry_url}/{image_name}\", tag=tag)\n314:                 self.logger.debug(f\"Tagged image as {full_image_name}\")\n315: \n316:             # Login to registry if credentials provided\n317:             if username and password and registry_url:\n318:                 self.logger.debug(f\"Logging in to registry: {registry_url}\")\n319:                 client.login(\n320:                     username=username,\n321:                     password=password,\n322:                     registry=registry_url,\n323:                 )\n324:                 self.logger.debug(\"Registry login successful\")\n325: \n326:             # Push the image\n327:             push_logs = client.images.push(full_image_name, stream=True, decode=True)\n328: \n329:             # Process push logs\n330:             for log in push_logs:\n331:                 if isinstance(log, dict):\n332:                     if \"status\" in log:\n333:                         self.logger.debug(f\"Push status: {log['status']}\")\n334:                     if \"error\" in log:\n335:                         error_msg = log[\"error\"]\n336:                         self.logger.error(f\"Push failed: {error_msg}\")\n337:                         raise RuntimeError(f\"Failed to push image: {error_msg}\")\n338: \n339:             self.logger.info(f\"Successfully pushed image: {full_image_name}\")\n340: \n341:             return {\n342:                 \"image_name\": full_image_name,\n343:                 \"tag\": tag,\n344:                 \"registry\": registry_url,\n345:                 \"pushed\": True,\n346:             }\n347: \n348:         except DockerException as e:\n349:             self.logger.error(f\"Push failed: {e}\")\n350:             raise RuntimeError(f\"Failed to push image: {e}\") from e\n351: \n352:     def extract_credentials_from_url(\n353:         self, image_url: str\n354:     ) -> tuple[str, Optional[str], Optional[str]]:\n355:         \"\"\"Extract credentials from image URL with embedded auth.\n356: \n357:         Args:\n358:             image_url: Image URL potentially containing credentials\n359:                       (e.g., \"user:pass@registry.com/image:tag\").\n360: \n361:         Returns:\n362:             Tuple of (clean_url, username, password) where username and password\n363:             may be None if not present in the URL.\n364:         \"\"\"\n365:         import urllib.parse\n366: \n367:         # Parse the URL\n368:         parsed = urllib.parse.urlparse(f\"//{image_url}\")\n369: \n370:         username = None\n371:         password = None\n372:         clean_url = image_url\n373: \n374:         # Extract credentials from netloc\n375:         if parsed.username:\n376:             username = urllib.parse.unquote(parsed.username)\n377:         if parsed.password:\n378:             password = urllib.parse.unquote(parsed.password)\n379: \n380:         # Remove credentials from URL\n381:         if parsed.username or parsed.password:\n382:             netloc = parsed.hostname or \"\"\n383:             if parsed.port:\n384:                 netloc += f\":{parsed.port}\"\n385:             clean_path = parsed.path.lstrip(\"/\")\n386:             if parsed.query:\n387:                 clean_path += f\"?{parsed.query}\"\n388:             clean_url = f\"{netloc}/{clean_path}\"\n389: \n390:         return clean_url, username, password\n\n(End of file - total 390 lines)\n</content>","metadata":{"preview":"\"\"\"Docker service for AgentCube CLI.\n\nThis module provides the DockerService class for building and managing\nDocker images using the Docker SDK.\n\"\"\"\n\nimport logging\nimport time\nfrom pathlib import Path\nfrom typing import Any, Dict, List, Optional\n\nimport docker\nfrom docker.errors import BuildError, DockerException\n\nfrom agentcube.utils.log import get_logger\n\n\ndef _format_image_id(image_id: Optional[str]) -> str:\n    \"\"\"Format Docker image ID for display.\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/agentcube/services/docker_service.py","time":{"start":1775893678144,"end":1775893678160}}}}
