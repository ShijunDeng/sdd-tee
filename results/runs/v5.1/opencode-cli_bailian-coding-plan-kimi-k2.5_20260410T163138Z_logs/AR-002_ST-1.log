pcopy, and client-go\nmake gen-all\n\n# Verify no diff (all generated files committed)\nmake gen-check\n\n# Validate CRD schema\nkubectl apply -f manifests/charts/base/crds/ --dry-run=server\n```","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/proposal.md","time":{"start":1775840210378,"end":1775840210387}}}}
