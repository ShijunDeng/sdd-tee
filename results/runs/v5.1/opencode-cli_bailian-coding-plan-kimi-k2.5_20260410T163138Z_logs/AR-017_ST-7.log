{"type":"tool_use","timestamp":1775879325017,"sessionID":"ses_285588390ffes13MP8IEGHIZ9q","part":{"id":"prt_d7aa7f3d6001iDAg0qrPaMfm0E","messageID":"msg_d7aa7dd37001O6MLUkh484ozit","sessionID":"ses_285588390ffes13MP8IEGHIZ9q","type":"tool","tool":"read","callID":"toolu_functions.read:8","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/picod/jwt/types.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/picod/jwt/types.go</path>\n<type>file</type>\n<content>\n1: /*\n2: Copyright 2026 The Volcano Authors.\n3: \n4: Licensed under the Apache License, Version 2.0 (the \"License\");\n5: you may not use this file except in compliance with the License.\n6: You may obtain a copy of the License at\n7: \n8:     http://www.apache.org/licenses/LICENSE-2.0\n9: \n10: Unless required by applicable law or agreed to in writing, software\n11: distributed under the License is distributed on an \"AS IS\" BASIS,\n12: WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n13: See the License for the specific language governing permissions and\n14: limitations under the License.\n15: */\n16: \n17: package jwt\n18: \n19: import (\n20: \t\"context\"\n21: \t\"crypto/rsa\"\n22: \t\"net/http\"\n23: \t\"time\"\n24: )\n25: \n26: // contextKey is a custom type for context keys to avoid collisions\n27: type contextKey string\n28: \n29: const (\n30: \t// claimsContextKey is the key used to store claims in the request context\n31: \tclaimsContextKey contextKey = \"jwt.claims\"\n32: \n33: \t// defaultClockSkew is the default clock skew tolerance\n34: \tdefaultClockSkew = 1 * time.Minute\n35: \n36: \t// authorizationHeader is the HTTP header name for authorization\n37: \tauthorizationHeader = \"Authorization\"\n38: \n39: \t// bearerPrefix is the prefix for bearer tokens\n40: \tbearerPrefix = \"Bearer \"\n41: )\n42: \n43: // JWTValidator validates JWT tokens\n44: type JWTValidator interface {\n45: \t// ValidateToken validates a JWT string and returns the parsed claims\n46: \tValidateToken(token string) (*Claims, error)\n47: }\n48: \n49: // Claims represents validated JWT claims\n50: type Claims struct {\n51: \t// Subject identifies the principal that is the subject of the JWT\n52: \tSubject string `json:\"sub\"`\n53: \n54: \t// Issuer identifies the principal that issued the JWT\n55: \tIssuer string `json:\"iss\"`\n56: \n57: \t// Audience identifies the recipients that the JWT is intended for\n58: \tAudience []string `json:\"aud,omitempty\"`\n59: \n60: \t// ExpiresAt identifies the expiration time on or after which the JWT must not be accepted\n61: \tExpiresAt time.Time `json:\"exp\"`\n62: \n63: \t// NotBefore identifies the time before which the JWT must not be accepted\n64: \tNotBefore *time.Time `json:\"nbf,omitempty\"`\n65: \n66: \t// IssuedAt identifies the time at which the JWT was issued\n67: \tIssuedAt time.Time `json:\"iat\"`\n68: \n69: \t// JWTID provides a unique identifier for the JWT\n70: \tJWTID string `json:\"jti,omitempty\"`\n71: }\n72: \n73: // IsExpired checks if the token is expired considering clock skew\n74: func (c *Claims) IsExpired(clockSkew time.Duration) bool {\n75: \tif c.ExpiresAt.IsZero() {\n76: \t\treturn false\n77: \t}\n78: \treturn time.Now().After(c.ExpiresAt.Add(clockSkew))\n79: }\n80: \n81: // IsNotYetValid checks if the token is not yet valid considering clock skew\n82: func (c *Claims) IsNotYetValid(clockSkew time.Duration) bool {\n83: \tif c.NotBefore == nil || c.NotBefore.IsZero() {\n84: \t\treturn false\n85: \t}\n86: \treturn time.Now().Before(c.NotBefore.Add(-clockSkew))\n87: }\n88: \n89: // ValidationOptions configures the validator\n90: type ValidationOptions struct {\n91: \t// Algorithm is the expected signing algorithm (e.g., \"HS256\", \"RS256\")\n92: \tAlgorithm string\n93: \n94: \t// Secret is the HMAC secret for HS256 algorithm\n95: \tSecret []byte\n96: \n97: \t// PublicKey is the RSA public key for RS256 algorithm\n98: \tPublicKey *rsa.PublicKey\n99: \n100: \t// ExpectedIssuer is the expected issuer claim value\n101: \tExpectedIssuer string\n102: \n103: \t// ExpectedAudience is the expected audience claim value (optional)\n104: \tExpectedAudience string\n105: \n106: \t// ClockSkew is the allowed clock skew for time-based validations\n107: \tClockSkew time.Duration\n108: \n109: \t// AllowedAlgs is the list of allowed signing algorithms\n110: \t// If empty, defaults to Algorithm\n111: \tAllowedAlgs []string\n112: \n113: \t// RequireExpiration requires the exp claim to be present\n114: \tRequireExpiration bool\n115: }\n116: \n117: // MiddlewareOptions configures the middleware behavior\n118: type MiddlewareOptions struct {\n119: \t// Validator is the JWT validator to use\n120: \tValidator JWTValidator\n121: \n122: \t// ErrorHandler is an optional custom error handler\n123: \t// If nil, a default error handler is used\n124: \tErrorHandler func(http.ResponseWriter, error)\n125: \n126: \t// SkipValidation is an optional function to skip validation for certain requests\n127: \t// If it returns true, validation is skipped\n128: \tSkipValidation func(*http.Request) bool\n129: }\n130: \n131: // GetClaims retrieves validated claims from the context\n132: // Returns the claims and true if found, nil and false otherwise\n133: func GetClaims(ctx context.Context) (*Claims, bool) {\n134: \tclaims, ok := ctx.Value(claimsContextKey).(*Claims)\n135: \treturn claims, ok\n136: }\n137: \n138: // WithClaims adds claims to the context\n139: func WithClaims(ctx context.Context, claims *Claims) context.Context {\n140: \treturn context.WithValue(ctx, claimsContextKey, claims)\n141: }\n\n(End of file - total 141 lines)\n</content>","metadata":{"preview":"/*\nCopyright 2026 The Volcano Authors.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\npackage jwt\n\nimport (\n\t\"context\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/picod/jwt/types.go","time":{"start":1775879324996,"end":1775879325016}}}}
{"type":"tool_use","timestamp":1775879325018,"sessionID":"ses_285588390ffes13MP8IEGHIZ9q","part":{"id":"prt_d7aa7f9e7001Y0E6xxWzIFwCFR","messageID":"msg_d7aa7dd37001O6MLUkh484ozit","sessionID":"ses_285588390ffes13MP8IEGHIZ9q","type":"tool","tool":"read","callID":"toolu_functions.read:9","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/picod/jwt/errors.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/picod/jwt/errors.go</path>\n<type>file</type>\n<content>\n1: /*\n2: Copyright 2026 The Volcano Authors.\n3: \n4: Licensed under the Apache License, Version 2.0 (the \"License\");\n5: you may not use this file except in compliance with the License.\n6: You may obtain a copy of the License at\n7: \n8:     http://www.apache.org/licenses/LICENSE-2.0\n9: \n10: Unless required by applicable law or agreed to in writing, software\n11: distributed under the License is distributed on an \"AS IS\" BASIS,\n12: WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n13: See the License for the specific language governing permissions and\n14: limitations under the License.\n15: */\n16: \n17: package jwt\n18: \n19: import \"errors\"\n20: \n21: // Authentication errors\n22: var (\n23: \t// ErrMissingToken is returned when no Authorization header is present\n24: \tErrMissingToken = errors.New(\"jwt: missing bearer token\")\n25: \n26: \t// ErrInvalidTokenFormat is returned when the Authorization header format is invalid\n27: \tErrInvalidTokenFormat = errors.New(\"jwt: invalid token format\")\n28: \n29: \t// ErrInvalidSignature is returned when token signature verification fails\n30: \tErrInvalidSignature = errors.New(\"jwt: invalid signature\")\n31: \n32: \t// ErrTokenExpired is returned when the token has expired\n33: \tErrTokenExpired = errors.New(\"jwt: token expired\")\n34: \n35: \t// ErrTokenNotYetValid is returned when the token is used before its issued at time\n36: \tErrTokenNotYetValid = errors.New(\"jwt: token not yet valid\")\n37: \n38: \t// ErrInvalidIssuer is returned when the issuer claim does not match\n39: \tErrInvalidIssuer = errors.New(\"jwt: invalid issuer\")\n40: \n41: \t// ErrUnsupportedAlgorithm is returned when the signing algorithm is not allowed\n42: \tErrUnsupportedAlgorithm = errors.New(\"jwt: unsupported algorithm\")\n43: \n44: \t// ErrMissingClaims is returned when required claims are missing\n45: \tErrMissingClaims = errors.New(\"jwt: missing required claims\")\n46: \n47: \t// ErrInvalidConfiguration is returned when the validator configuration is invalid\n48: \tErrInvalidConfiguration = errors.New(\"jwt: invalid configuration\")\n49: \n50: \t// ErrFailedToLoadKey is returned when a key cannot be loaded from file\n51: \tErrFailedToLoadKey = errors.New(\"jwt: failed to load key\")\n52: )\n\n(End of file - total 52 lines)\n</content>","metadata":{"preview":"/*\nCopyright 2026 The Volcano Authors.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\npackage jwt\n\nimport \"errors\"\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/picod/jwt/errors.go","time":{"start":1775879325002,"end":1775879325017}}}}
{"type":"tool_use","timestamp":1775879325021,"sessionID":"ses_285588390ffes13MP8IEGHIZ9q","part":{"id":"prt_d7aa7ff94001TfGVcQibvuTVz5","messageID":"msg_d7aa7dd37001O6MLUkh484ozit","sessionID":"ses_285588390ffes13MP8IEGHIZ9q","type":"tool","tool":"read","callID":"toolu_functions.read:10","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/picod/jwt/validator.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/picod/jwt/validator.go</path>\n<type>file</type>\n<content>\n1: /*\n2: Copyright 2026 The Volcano Authors.\n3: \n4: Licensed under the Apache License, Version 2.0 (the \"License\");\n5: you may not use this file except in compliance with the License.\n6: You may obtain a copy of the License at\n7: \n8:     http://www.apache.org/licenses/LICENSE-2.0\n9: \n10: Unless required by applicable law or agreed to in writing, software\n11: distributed under the License is distributed on an \"AS IS\" BASIS,\n12: WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n13: See the License for the specific language governing permissions and\n14: limitations under the License.\n15: */\n16: \n17: package jwt\n18: \n19: import (\n20: \t\"crypto/rsa\"\n21: \t\"fmt\"\n22: \t\"time\"\n23: \n24: \t\"github.com/golang-jwt/jwt/v5\"\n25: )\n26: \n27: // validator implements the JWTValidator interface\n28: type validator struct {\n29: \topts ValidationOptions\n30: }\n31: \n32: // NewValidator creates a new JWTValidator with the given options\n33: func NewValidator(opts ValidationOptions) (JWTValidator, error) {\n34: \t// Set default clock skew if not specified\n35: \tif opts.ClockSkew == 0 {\n36: \t\topts.ClockSkew = defaultClockSkew\n37: \t}\n38: \n39: \t// Set default algorithm if not specified\n40: \tif opts.Algorithm == \"\" {\n41: \t\topts.Algorithm = \"RS256\"\n42: \t}\n43: \n44: \t// Validate algorithm\n45: \tif !isValidAlgorithm(opts.Algorithm) {\n46: \t\treturn nil, fmt.Errorf(\"%w: invalid algorithm %q\", ErrInvalidConfiguration, opts.Algorithm)\n47: \t}\n48: \n49: \t// Set allowed algorithms if not specified\n50: \tif len(opts.AllowedAlgs) == 0 {\n51: \t\topts.AllowedAlgs = []string{opts.Algorithm}\n52: \t}\n53: \n54: \t// Validate required configuration based on algorithm\n55: \tif err := validateAlgorithmConfig(opts); err != nil {\n56: \t\treturn nil, err\n57: \t}\n58: \n59: \treturn &validator{opts: opts}, nil\n60: }\n61: \n62: // ValidateToken validates a JWT token string and returns the parsed claims\n63: func (v *validator) ValidateToken(tokenString string) (*Claims, error) {\n64: \tif tokenString == \"\" {\n65: \t\treturn nil, ErrMissingToken\n66: \t}\n67: \n68: \t// Parse the token with clock skew as leeway for time-based validations\n69: \ttoken, err := jwt.Parse(tokenString, v.keyFunc,\n70: \t\tjwt.WithValidMethods(v.opts.AllowedAlgs),\n71: \t\tjwt.WithLeeway(v.opts.ClockSkew),\n72: \t)\n73: \tif err != nil {\n74: \t\treturn nil, v.mapError(err)\n75: \t}\n76: \n77: \tif !token.Valid {\n78: \t\treturn nil, ErrInvalidSignature\n79: \t}\n80: \n81: \t// Extract and validate claims\n82: \tclaims, err := v.extractClaims(token)\n83: \tif err != nil {\n84: \t\treturn nil, err\n85: \t}\n86: \n87: \t// Validate custom claims\n88: \tif err := v.validateCustomClaims(claims); err != nil {\n89: \t\treturn nil, err\n90: \t}\n91: \n92: \treturn claims, nil\n93: }\n94: \n95: // keyFunc returns the appropriate key for the given token\n96: func (v *validator) keyFunc(token *jwt.Token) (interface{}, error) {\n97: \talg, ok := token.Header[\"alg\"].(string)\n98: \tif !ok {\n99: \t\treturn nil, ErrUnsupportedAlgorithm\n100: \t}\n101: \n102: \t// Check if algorithm is allowed\n103: \tif !v.isAlgorithmAllowed(alg) {\n104: \t\treturn nil, ErrUnsupportedAlgorithm\n105: \t}\n106: \n107: \tswitch alg {\n108: \tcase \"HS256\":\n109: \t\tif len(v.opts.Secret) == 0 {\n110: \t\t\treturn nil, fmt.Errorf(\"%w: HMAC secret not configured\", ErrInvalidConfiguration)\n111: \t\t}\n112: \t\treturn v.opts.Secret, nil\n113: \tcase \"RS256\":\n114: \t\tif v.opts.PublicKey == nil {\n115: \t\t\treturn nil, fmt.Errorf(\"%w: RSA public key not configured\", ErrInvalidConfiguration)\n116: \t\t}\n117: \t\treturn v.opts.PublicKey, nil\n118: \tdefault:\n119: \t\treturn nil, ErrUnsupportedAlgorithm\n120: \t}\n121: }\n122: \n123: // isAlgorithmAllowed checks if the algorithm is in the allowed list\n124: func (v *validator) isAlgorithmAllowed(alg string) bool {\n125: \tfor _, allowed := range v.opts.AllowedAlgs {\n126: \t\tif allowed == alg {\n127: \t\t\treturn true\n128: \t\t}\n129: \t}\n130: \treturn false\n131: }\n132: \n133: // extractClaims extracts Claims from a parsed JWT token\n134: func (v *validator) extractClaims(token *jwt.Token) (*Claims, error) {\n135: \tmapClaims, ok := token.Claims.(jwt.MapClaims)\n136: \tif !ok {\n137: \t\treturn nil, ErrMissingClaims\n138: \t}\n139: \n140: \tclaims := &Claims{}\n141: \n142: \t// Extract subject\n143: \tif sub, ok := mapClaims[\"sub\"].(string); ok {\n144: \t\tclaims.Subject = sub\n145: \t}\n146: \n147: \t// Extract issuer\n148: \tif iss, ok := mapClaims[\"iss\"].(string); ok {\n149: \t\tclaims.Issuer = iss\n150: \t}\n151: \n152: \t// Extract audience (can be string or []string)\n153: \tif aud, ok := mapClaims[\"aud\"]; ok {\n154: \t\tswitch a := aud.(type) {\n155: \t\tcase string:\n156: \t\t\tclaims.Audience = []string{a}\n157: \t\tcase []string:\n158: \t\t\tclaims.Audience = a\n159: \t\tcase []interface{}:\n160: \t\t\tfor _, item := range a {\n161: \t\t\t\tif s, ok := item.(string); ok {\n162: \t\t\t\t\tclaims.Audience = append(claims.Audience, s)\n163: \t\t\t\t}\n164: \t\t\t}\n165: \t\t}\n166: \t}\n167: \n168: \t// Extract expiration time\n169: \tif exp, err := mapClaims.GetExpirationTime(); err == nil && exp != nil {\n170: \t\tclaims.ExpiresAt = exp.Time\n171: \t}\n172: \n173: \t// Extract not before time\n174: \tif nbf, err := mapClaims.GetNotBefore(); err == nil && nbf != nil {\n175: \t\tclaims.NotBefore = &nbf.Time\n176: \t}\n177: \n178: \t// Extract issued at time\n179: \tif iat, err := mapClaims.GetIssuedAt(); err == nil && iat != nil {\n180: \t\tclaims.IssuedAt = iat.Time\n181: \t}\n182: \n183: \t// Extract JWT ID\n184: \tif jti, ok := mapClaims[\"jti\"].(string); ok {\n185: \t\tclaims.JWTID = jti\n186: \t}\n187: \n188: \treturn claims, nil\n189: }\n190: \n191: // validateCustomClaims performs custom claim validations\n192: func (v *validator) validateCustomClaims(claims *Claims) error {\n193: \t// Validate expiration with clock skew\n194: \tif v.opts.RequireExpiration && claims.ExpiresAt.IsZero() {\n195: \t\treturn ErrMissingClaims\n196: \t}\n197: \n198: \tif !claims.ExpiresAt.IsZero() && claims.IsExpired(v.opts.ClockSkew) {\n199: \t\treturn ErrTokenExpired\n200: \t}\n201: \n202: \t// Validate not before with clock skew\n203: \tif claims.IsNotYetValid(v.opts.ClockSkew) {\n204: \t\treturn ErrTokenNotYetValid\n205: \t}\n206: \n207: \t// Validate issuer\n208: \tif v.opts.ExpectedIssuer != \"\" && claims.Issuer != v.opts.ExpectedIssuer {\n209: \t\treturn ErrInvalidIssuer\n210: \t}\n211: \n212: \t// Validate audience if specified\n213: \tif v.opts.ExpectedAudience != \"\" {\n214: \t\tfound := false\n215: \t\tfor _, aud := range claims.Audience {\n216: \t\t\tif aud == v.opts.ExpectedAudience {\n217: \t\t\t\tfound = true\n218: \t\t\t\tbreak\n219: \t\t\t}\n220: \t\t}\n221: \t\tif !found {\n222: \t\t\treturn ErrInvalidIssuer\n223: \t\t}\n224: \t}\n225: \n226: \treturn nil\n227: }\n228: \n229: // mapError maps JWT library errors to our error types\n230: func (v *validator) mapError(err error) error {\n231: \tif err == nil {\n232: \t\treturn nil\n233: \t}\n234: \n235: \t// In jwt/v5, validation errors are returned as standard errors\n236: \t// We need to check error messages to determine the type\n237: \terrStr := err.Error()\n238: \n239: \tswitch {\n240: \t// Check for expired token\n241: \tcase contains(errStr, \"token is expired\") ||\n242: \t\tcontains(errStr, \"token has invalid claims: token is expired\"):\n243: \t\treturn ErrTokenExpired\n244: \n245: \t// Check for not yet valid token\n246: \tcase contains(errStr, \"token is not valid yet\") ||\n247: \t\tcontains(errStr, \"token has invalid claims: token is not valid yet\"):\n248: \t\treturn ErrTokenNotYetValid\n249: \n250: \t// Check for unsupported algorithm (must be before signature check\n251: \t// because jwt/v5 includes \"signature is invalid\" in the error message)\n252: \tcase contains(errStr, \"signing method\") && contains(errStr, \"is invalid\"):\n253: \t\treturn ErrUnsupportedAlgorithm\n254: \n255: \t// Check for invalid signature\n256: \tcase contains(errStr, \"signature is invalid\") ||\n257: \t\tcontains(errStr, \"token signature invalid\"):\n258: \t\treturn ErrInvalidSignature\n259: \n260: \t// Check for malformed token\n261: \tcase contains(errStr, \"token is malformed\") ||\n262: \t\tcontains(errStr, \"token contains an invalid number of segments\") ||\n263: \t\tcontains(errStr, \"invalid character\") ||\n264: \t\tcontains(errStr, \"illegal base64\"):\n265: \t\treturn ErrInvalidTokenFormat\n266: \t}\n267: \n268: \treturn err\n269: }\n270: \n271: // contains checks if a string contains a substring\n272: func contains(s, substr string) bool {\n273: \treturn len(s) >= len(substr) && (s == substr ||\n274: \t\t(len(s) > len(substr) &&\n275: \t\t\t(findSubstring(s, substr) >= 0)))\n276: }\n277: \n278: // findSubstring finds the substring position\n279: func findSubstring(s, substr string) int {\n280: \tfor i := 0; i <= len(s)-len(substr); i++ {\n281: \t\tif s[i:i+len(substr)] == substr {\n282: \t\t\treturn i\n283: \t\t}\n284: \t}\n285: \treturn -1\n286: }\n287: \n288: // isValidAlgorithm checks if the algorithm is supported\n289: func isValidAlgorithm(alg string) bool {\n290: \tswitch alg {\n291: \tcase \"HS256\", \"RS256\":\n292: \t\treturn true\n293: \tdefault:\n294: \t\treturn false\n295: \t}\n296: }\n297: \n298: // validateAlgorithmConfig validates configuration based on algorithm\n299: func validateAlgorithmConfig(opts ValidationOptions) error {\n300: \tswitch opts.Algorithm {\n301: \tcase \"HS256\":\n302: \t\tif len(opts.Secret) == 0 {\n303: \t\t\treturn fmt.Errorf(\"%w: HMAC secret required for HS256\", ErrInvalidConfiguration)\n304: \t\t}\n305: \tcase \"RS256\":\n306: \t\tif opts.PublicKey == nil {\n307: \t\t\treturn fmt.Errorf(\"%w: RSA public key required for RS256\", ErrInvalidConfiguration)\n308: \t\t}\n309: \t}\n310: \treturn nil\n311: }\n312: \n313: // ensureRSAPublicKey ensures the key is an RSA public key\n314: func ensureRSAPublicKey(key interface{}) (*rsa.PublicKey, error) {\n315: \tswitch k := key.(type) {\n316: \tcase *rsa.PublicKey:\n317: \t\treturn k, nil\n318: \tdefault:\n319: \t\treturn nil, fmt.Errorf(\"%w: expected RSA public key\", ErrInvalidConfiguration)\n320: \t}\n321: }\n322: \n323: // getSigningMethod returns the jwt.SigningMethod for the algorithm\n324: func getSigningMethod(alg string) jwt.SigningMethod {\n325: \tswitch alg {\n326: \tcase \"HS256\":\n327: \t\treturn jwt.SigningMethodHS256\n328: \tcase \"RS256\":\n329: \t\treturn jwt.SigningMethodRS256\n330: \tdefault:\n331: \t\treturn nil\n332: \t}\n333: }\n334: \n335: // now is a variable to allow mocking in tests\n336: var now = time.Now\n337: \n338: // setNow sets the time function for testing\n339: func setNow(fn func() time.Time) {\n340: \tnow = fn\n341: }\n\n(End of file - total 341 lines)\n</content>","metadata":{"preview":"/*\nCopyright 2026 The Volcano Authors.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\npackage jwt\n\nimport (\n\t\"crypto/rsa\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/picod/jwt/validator.go","time":{"start":1775879325004,"end":1775879325019}}}}
