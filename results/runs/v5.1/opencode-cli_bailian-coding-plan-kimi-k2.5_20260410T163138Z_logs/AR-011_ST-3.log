TemplateNotFoundError struct {\n40: \tNamespace string\n41: \tName      string\n42: \tKind      string\n43: }\n44: \n45: // Error implements the error interface.\n46: func (e *SandboxTemplateNotFoundError) Error() string {\n47: \treturn fmt.Sprintf(\"sandbox template '%s/%s' of kind '%s' not found\", e.Namespace, e.Name, e.Kind)\n48: }\n49: \n50: // NewSandboxTemplateNotFoundError creates a new SandboxTemplateNotFoundError.\n51: func NewSandboxTemplateNotFoundError(namespace, name, kind string) *SandboxTemplateNotFoundError {\n52: \treturn &SandboxTemplateNotFoundError{\n53: \t\tNamespace: namespace,\n54: \t\tName:      name,\n55: \t\tKind:      kind,\n56: \t}\n57: }\n58: \n59: // JWTSigningError represents an error when JWT signing fails.\n60: type JWTSigningError struct {\n61: \tCause error\n62: }\n63: \n64: // Error implements the error interface.\n65: func (e *JWTSigningError) Error() string {\n66: \treturn fmt.Sprintf(\"failed to sign JWT: %v\", e.Cause)\n67: }\n68: \n69: // NewJWTSigningError creates a new JWTSigningError.\n70: func NewJWTSigningError(cause error) *JWTSigningError {\n71: \treturn &JWTSigningError{Cause: cause}\n72: }\n73: \n74: // NoEntryPointError represents an error when no entry point is found for a sandbox.\n75: type NoEntryPointError struct {\n76: \tSandboxID string\n77: }\n78: \n79: // Error implements the error interface.\n80: func (e *NoEntryPointError) Error() string {\n81: \treturn fmt.Sprintf(\"no entry point found for sandbox '%s'\", e.SandboxID)\n82: }\n83: \n84: // NewNoEntryPointError creates a new NoEntryPointError.\n85: func NewNoEntryPointError(sandboxID string) *NoEntryPointError {\n86: \treturn &NoEntryPointError{SandboxID: sandboxID}\n87: }\n88: \n89: // IsSessionNotFoundError checks if an error is a SessionNotFoundError.\n90: func IsSessionNotFoundError(err error) bool {\n91: \t_, ok := err.(*SessionNotFoundError)\n92: \treturn ok\n93: }\n94: \n95: // IsSandboxTemplateNotFoundError checks if an error is a SandboxTemplateNotFoundError.\n96: func IsSandboxTemplateNotFoundError(err error) bool {\n97: \t_, ok := err.(*SandboxTemplateNotFoundError)\n98: \treturn ok\n99: }\n\n(End of file - total 99 lines)\n</content>","metadata":{"preview":"/*\nCopyright 2026 The Volcano Authors.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\npackage router\n\nimport (\n\t\"fmt\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/router/errors.go","time":{"start":1775862389482,"end":1775862389501}}}}
