{"type":"tool_use","timestamp":1775862389500,"sessionID":"ses_2865b0a75ffepxYCm60X9v5r8p","part":{"id":"prt_d79a584ed001Bw45ef533Ev12d","messageID":"msg_d79a55d9a001w5qcSV24zx6lN4","sessionID":"ses_2865b0a75ffepxYCm60X9v5r8p","type":"tool","tool":"read","callID":"toolu_functions.read:7","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/router/jwt.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/router/jwt.go</path>\n<type>file</type>\n<content>\n1: /*\n2: Copyright 2026 The Volcano Authors.\n3: \n4: Licensed under the Apache License, Version 2.0 (the \"License\");\n5: you may not use this file except in compliance with the License.\n6: You may obtain a copy of the License at\n7: \n8:     http://www.apache.org/licenses/LICENSE-2.0\n9: \n10: Unless required by applicable law or agreed to in writing, software\n11: distributed under the License is distributed on an \"AS IS\" BASIS,\n12: WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n13: See the License for the specific language governing permissions and\n14: limitations under the License.\n15: */\n16: \n17: package router\n18: \n19: import (\n20: \t\"crypto/rand\"\n21: \t\"crypto/rsa\"\n22: \t\"crypto/x509\"\n23: \t\"encoding/pem\"\n24: \t\"fmt\"\n25: \t\"os\"\n26: \t\"time\"\n27: \n28: \t\"github.com/golang-jwt/jwt/v5\"\n29: \tcorev1 \"k8s.io/api/core/v1\"\n30: \tapierrors \"k8s.io/apimachinery/pkg/api/errors\"\n31: \tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n32: \t\"k8s.io/client-go/kubernetes\"\n33: \t\"k8s.io/client-go/rest\"\n34: \t\"k8s.io/klog/v2\"\n35: )\n36: \n37: const (\n38: \trsaKeySize         = 2048\n39: \tjwtExpiration      = 5 * time.Minute\n40: \tidentitySecretName = \"picod-router-identity\"\n41: \tprivateKeyDataKey  = \"private.pem\"\n42: \tpublicKeyDataKey   = \"public.pem\"\n43: )\n44: \n45: // IdentityNamespace is the namespace where the JWT identity secret is stored.\n46: // Initialized from AGENTCUBE_NAMESPACE env var or defaults to \"default\".\n47: var IdentityNamespace = \"default\"\n48: \n49: func init() {\n50: \tif ns := os.Getenv(\"AGENTCUBE_NAMESPACE\"); ns != \"\" {\n51: \t\tIdentityNamespace = ns\n52: \t}\n53: }\n54: \n55: // JWTManager handles JWT key generation and token signing.\n56: type JWTManager struct {\n57: \tprivateKey *rsa.PrivateKey\n58: \tpublicKey  *rsa.PublicKey\n59: \tclientset  kubernetes.Interface\n60: }\n61: \n62: // NewJWTManager creates a new JWTManager with a generated RSA key pair.\n63: func NewJWTManager() (*JWTManager, error) {\n64: \tprivateKey, err := rsa.GenerateKey(rand.Reader, rsaKeySize)\n65: \tif err != nil {\n66: \t\treturn nil, fmt.Errorf(\"failed to generate RSA key: %w\", err)\n67: \t}\n68: \n69: \treturn &JWTManager{\n70: \t\tprivateKey: privateKey,\n71: \t\tpublicKey:  &privateKey.PublicKey,\n72: \t}, nil\n73: }\n74: \n75: // GenerateToken creates a JWT with the given claims.\n76: func (m *JWTManager) GenerateToken(claims map[string]interface{}) (string, error) {\n77: \tnow := time.Now()\n78: \n79: \t// Build base claims\n80: \ttokenClaims := jwt.MapClaims{\n81: \t\t\"exp\": now.Add(jwtExpiration).Unix(),\n82: \t\t\"iat\": now.Unix(),\n83: \t\t\"iss\": \"agentcube-router\",\n84: \t}\n85: \n86: \t// Merge custom claims\n87: \tfor k, v := range claims {\n88: \t\ttokenClaims[k] = v\n89: \t}\n90: \n91: \t// Create and sign token\n92: \ttoken := jwt.NewWithClaims(jwt.SigningMethodRS256, tokenClaims)\n93: \ttokenString, err := token.SignedString(m.privateKey)\n94: \tif err != nil {\n95: \t\treturn \"\", fmt.Errorf(\"failed to sign token: %w\", err)\n96: \t}\n97: \n98: \treturn tokenString, nil\n99: }\n100: \n101: // GetPublicKeyPEM returns the public key in PEM format.\n102: func (m *JWTManager) GetPublicKeyPEM() ([]byte, error) {\n103: \tpublicKeyBytes, err := x509.MarshalPKIXPublicKey(m.publicKey)\n104: \tif err != nil {\n105: \t\treturn nil, fmt.Errorf(\"failed to marshal public key: %w\", err)\n106: \t}\n107: \n108: \tpemBlock := &pem.Block{\n109: \t\tType:  \"PUBLIC KEY\",\n110: \t\tBytes: publicKeyBytes,\n111: \t}\n112: \n113: \treturn pem.EncodeToMemory(pemBlock), nil\n114: }\n115: \n116: // GetPrivateKeyPEM returns the private key in PEM format.\n117: func (m *JWTManager) GetPrivateKeyPEM() ([]byte, error) {\n118: \tprivateKeyBytes := x509.MarshalPKCS1PrivateKey(m.privateKey)\n119: \n120: \tpemBlock := &pem.Block{\n121: \t\tType:  \"RSA PRIVATE KEY\",\n122: \t\tBytes: privateKeyBytes,\n123: \t}\n124: \n125: \treturn pem.EncodeToMemory(pemBlock), nil\n126: }\n127: \n128: // TryStoreOrLoadJWTKeySecret attempts to store the JWT keys in a Kubernetes secret\n129: // or load them if the secret already exists. Returns nil if not running in-cluster.\n130: func (m *JWTManager) TryStoreOrLoadJWTKeySecret() error {\n131: \t// Try to get in-cluster config\n132: \tconfig, err := rest.InClusterConfig()\n133: \tif err != nil {\n134: \t\tklog.Warningf(\"Not running in Kubernetes cluster, using ephemeral JWT keys: %v\", err)\n135: \t\treturn nil\n136: \t}\n137: \n138: \t// Create clientset\n139: \tclientset, err := kubernetes.NewForConfig(config)\n140: \tif err != nil {\n141: \t\treturn fmt.Errorf(\"failed to create Kubernetes client: %w\", err)\n142: \t}\n143: \n144: \tm.clientset = clientset\n145: \n146: \t// Get or create the secret\n147: \treturn m.createOrLoadSecret()\n148: }\n149: \n150: func (m *JWTManager) createOrLoadSecret() error {\n151: \t// Try to create the secret\n152: \tprivatePEM, err := m.GetPrivateKeyPEM()\n153: \tif err != nil {\n154: \t\treturn fmt.Errorf(\"failed to encode private key: %w\", err)\n155: \t}\n156: \n157: \tpublicPEM, err := m.GetPublicKeyPEM()\n158: \tif err != nil {\n159: \t\treturn fmt.Errorf(\"failed to encode public key: %w\", err)\n160: \t}\n161: \n162: \tsecret := &corev1.Secret{\n163: \t\tObjectMeta: metav1.ObjectMeta{\n164: \t\t\tName:      identitySecretName,\n165: \t\t\tNamespace: IdentityNamespace,\n166: \t\t\tLabels: map[string]string{\n167: \t\t\t\t\"app\":       \"agentcube\",\n168: \t\t\t\t\"component\": \"router\",\n169: \t\t\t},\n170: \t\t},\n171: \t\tType: corev1.SecretTypeOpaque,\n172: \t\tData: map[string][]byte{\n173: \t\t\tprivateKeyDataKey: privatePEM,\n174: \t\t\tpublicKeyDataKey:  publicPEM,\n175: \t\t},\n176: \t}\n177: \n178: \t_, err = m.clientset.CoreV1().Secrets(IdentityNamespace).Create(nil, secret, metav1.CreateOptions{})\n179: \tif err != nil {\n180: \t\tif apierrors.IsAlreadyExists(err) {\n181: \t\t\t// Secret exists, load the keys\n182: \t\t\treturn m.loadExistingSecret()\n183: \t\t}\n184: \t\treturn fmt.Errorf(\"failed to create JWT secret: %w\", err)\n185: \t}\n186: \n187: \tklog.Infof(\"Created JWT identity secret '%s' in namespace '%s'\", identitySecretName, IdentityNamespace)\n188: \treturn nil\n189: }\n190: \n191: func (m *JWTManager) loadExistingSecret() error {\n192: \tsecret, err := m.clientset.CoreV1().Secrets(IdentityNamespace).Get(nil, identitySecretName, metav1.GetOptions{})\n193: \tif err != nil {\n194: \t\treturn fmt.Errorf(\"failed to get existing JWT secret: %w\", err)\n195: \t}\n196: \n197: \tprivatePEM, ok := secret.Data[privateKeyDataKey]\n198: \tif !ok {\n199: \t\treturn fmt.Errorf(\"existing JWT secret missing private key data\")\n200: \t}\n201: \n202: \treturn m.loadPrivateKeyPEM(privatePEM)\n203: }\n204: \n205: func (m *JWTManager) loadPrivateKeyPEM(pemData []byte) error {\n206: \tblock, _ := pem.Decode(pemData)\n207: \tif block == nil {\n208: \t\treturn fmt.Errorf(\"failed to decode PEM block\")\n209: \t}\n210: \n211: \tprivateKey, err := x509.ParsePKCS1PrivateKey(block.Bytes)\n212: \tif err != nil {\n213: \t\treturn fmt.Errorf(\"failed to parse private key: %w\", err)\n214: \t}\n215: \n216: \tm.privateKey = privateKey\n217: \tm.publicKey = &privateKey.PublicKey\n218: \n219: \tklog.Infof(\"Loaded existing JWT keys from secret '%s'\", identitySecretName)\n220: \treturn nil\n221: }\n\n(End of file - total 221 lines)\n</content>","metadata":{"preview":"/*\nCopyright 2026 The Volcano Authors.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\npackage router\n\nimport (\n\t\"crypto/rand\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/router/jwt.go","time":{"start":1775862389478,"end":1775862389499}}}}
