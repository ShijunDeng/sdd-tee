n_value = mock_apps_v1\n575:         mock_client.CoreV1Api.return_value = mock_core_v1\n576: \n577:         result = provider.delete_agent(\"test-agent\")\n578: \n579:         assert result[\"name\"] == \"test-agent\"\n580:         assert result[\"deployment_deleted\"] is True\n581:         assert result[\"service_deleted\"] is True\n582:         mock_apps_v1.delete_namespaced_deployment.assert_called_once()\n583:         mock_core_v1.delete_namespaced_service.assert_called_once()\n584: \n585:     @patch(\"kubernetes.client\")\n586:     @patch(\"kubernetes.config\")\n587:     def test_delete_agent_idempotent(self, mock_config: Mock, mock_client: Mock) -> None:\n588:         \"\"\"Test idempotent deletion when resources don't exist.\"\"\"\n589:         from agentcube.services.k8s_provider import KubernetesProvider\n590: \n591:         provider = KubernetesProvider()\n592: \n593:         mock_config.load_kube_config.return_value = None\n594: \n595:         mock_apps_v1 = MagicMock()\n596:         mock_core_v1 = MagicMock()\n597:         mock_client.AppsV1Api.return_value = mock_apps_v1\n598:         mock_client.CoreV1Api.return_value = mock_core_v1\n599: \n600:         # Mock both resources not found\n601:         from kubernetes.client.exceptions import NotFoundException\n602: \n603:         mock_apps_v1.delete_namespaced_deployment.side_effect = NotFoundException()\n604:         mock_core_v1.delete_namespaced_service.side_effect = NotFoundException()\n605: \n606:         # Should not raise exception\n607:         result = provider.delete_agent(\"non-existent\")\n608: \n609:         assert result[\"deployment_deleted\"] is False\n610:         assert result[\"service_deleted\"] is False\n611: \n612:     @patch(\"kubernetes.client\")\n613:     @patch(\"kubernetes.config\")\n614:     def test_delete_agent_deployment_error(self, mock_config: Mock, mock_client: Mock) -> None:\n615:         \"\"\"Test deletion error handling for deployment.\"\"\"\n616:         from agentcu