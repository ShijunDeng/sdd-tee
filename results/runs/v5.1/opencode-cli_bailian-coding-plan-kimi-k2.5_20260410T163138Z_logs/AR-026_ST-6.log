{"type":"tool_use","timestamp":1775901168112,"sessionID":"ses_2840b139dffeO4wT0g0XOLmHO7","part":{"id":"prt_d7bf539f8001Oeg49Bt4YyKqpd","messageID":"msg_d7bf50c35001mf3SRWgtuO72L1","sessionID":"ses_2840b139dffeO4wT0g0XOLmHO7","type":"tool","tool":"read","callID":"toolu_functions.read:5","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/agentcube/cli/main.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/agentcube/cli/main.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Main CLI module for AgentCube.\n2: \n3: This module provides the Typer-based CLI application with all commands\n4: for agent lifecycle management including pack, build, publish, invoke, and status.\n5: \"\"\"\n6: \n7: import json\n8: import logging\n9: from pathlib import Path\n10: from typing import Any, Optional\n11: \n12: import typer\n13: from rich.console import Console\n14: from rich.progress import Progress, SpinnerColumn, TextColumn\n15: from rich.table import Table\n16: \n17: from agentcube import __version__\n18: from agentcube.runtime.build_runtime import BuildRuntime\n19: from agentcube.runtime.invoke_runtime import InvokeRuntime\n20: from agentcube.runtime.pack_runtime import PackRuntime\n21: from agentcube.runtime.publish_runtime import PublishRuntime\n22: from agentcube.runtime.status_runtime import StatusRuntime\n23: \n24: # Create Typer app\n25: app = typer.Typer(\n26:     name=\"agentcube\",\n27:     help=\"AgentCube CLI - A developer tool for AI agent lifecycle management\",\n28:     no_args_is_help=True,\n29:     rich_markup_mode=\"rich\",\n30:     add_completion=False,\n31: )\n32: \n33: # Create console for output\n34: console = Console()\n35: \n36: \n37: def version_callback(value: bool) -> None:\n38:     \"\"\"Display version and exit.\n39: \n40:     Args:\n41:         value: Whether the --version flag was passed.\n42:     \"\"\"\n43:     if value:\n44:         console.print(f\"AgentCube CLI (kubectl agentcube) version: {__version__}\")\n45:         raise typer.Exit()\n46: \n47: \n48: def _handle_error(e: Exception, command_name: str, verbose: bool) -> None:\n49:     \"\"\"Handle command errors with optional traceback.\n50: \n51:     Args:\n52:         e: The exception that was raised.\n53:         command_name: Name of the command being executed.\n54:         verbose: Whether verbose mode is enabled.\n55:     \"\"\"\n56:     console.print(f\"Error {command_name}: {e}\", style=\"red\")\n57:     if verbose:\n58:         console.print_exception()\n59:     raise typer.Exit(1)\n60: \n61: \n62: def _parse_payload(payload_str: str) -> dict[str, Any]:\n63:     \"\"\"Parse and validate JSON payload.\n64: \n65:     Args:\n66:         payload_str: JSON string to parse.\n67: \n68:     Returns:\n69:         Parsed JSON dictionary.\n70: \n71:     Raises:\n72:         typer.Exit: If JSON is invalid (exit code 1).\n73:     \"\"\"\n74:     try:\n75:         return json.loads(payload_str)\n76:     except json.JSONDecodeError as e:\n77:         console.print(f\"Invalid JSON payload: {e}\", style=\"red\")\n78:         raise typer.Exit(1)\n79: \n80: \n81: def _parse_headers(header_list: Optional[list[str]]) -> dict[str, str]:\n82:     \"\"\"Parse header strings into dictionary.\n83: \n84:     Args:\n85:         header_list: List of header strings in 'key:value' format.\n86: \n87:     Returns:\n88:         Dictionary of headers.\n89: \n90:     Raises:\n91:         typer.Exit: If header format is invalid (exit code 1).\n92:     \"\"\"\n93:     headers: dict[str, str] = {}\n94:     if header_list:\n95:         for header in header_list:\n96:             if \":\" not in header:\n97:                 console.print(\n98:                     f\"Invalid header format: '{header}'. Expected 'key:value'\",\n99:                     style=\"red\",\n100:                 )\n101:                 raise typer.Exit(1)\n102:             key, value = header.split(\":\", 1)\n103:             headers[key.strip()] = value.strip()\n104:     return headers\n105: \n106: \n107: def _display_status_table(status: dict[str, Any]) -> None:\n108:     \"\"\"Display status in a Rich Table format.\n109: \n110:     Args:\n111:         status: Status dictionary from get_status().\n112:     \"\"\"\n113:     table = Table(title=\"Agent Status\")\n114:     table.add_column(\"Property\", style=\"cyan\")\n115:     table.add_column(\"Value\", style=\"green\")\n116: \n117:     # Map status values to colors\n118:     status_value = status.get(\"status\", \"unknown\")\n119:     if status_value == \"ready\":\n120:         status_display = \"[green]ready[/green]\"\n121:     elif status_value == \"error\":\n122:         status_display = \"[red]error[/red]\"\n123:     elif status_value == \"not_published\":\n124:         status_display = \"[yellow]not_published[/yellow]\"\n125:     elif status_value == \"not_found\":\n126:         status_display = \"[red]not_found[/red]\"\n127:     elif status_value == \"not_found_in_k8s\":\n128:         status_display = \"[red]not_found_in_k8s[/red]\"\n129:     elif status_value == \"not_ready\":\n130:         status_display = \"[yellow]not_ready[/yellow]\"\n131:     elif status_value == \"partial\":\n132:         status_display = \"[yellow]partial[/yellow]\"\n133:     elif status_value == \"pending\":\n134:         status_display = \"[yellow]pending[/yellow]\"\n135:     else:\n136:         status_display = f\"[yellow]{status_value}[/yellow]\"\n137: \n138:     table.add_row(\"Status\", status_display)\n139:     table.add_row(\"Agent Name\", status.get(\"agent_name\", \"N/A\"))\n140:     table.add_row(\"Agent ID\", status.get(\"agent_id\", \"N/A\"))\n141:     table.add_row(\"Provider\", status.get(\"provider\", \"N/A\"))\n142:     table.add_row(\"Namespace\", status.get(\"namespace\", \"N/A\"))\n143: \n144:     if status.get(\"agent_endpoint\"):\n145:         table.add_row(\"Endpoint\", status[\"agent_endpoint\"])\n146: \n147:     if status.get(\"deployment\"):\n148:         dep = status[\"deployment\"]\n149:         table.add_row(\n150:             \"Replicas\",\n151:             f\"{dep.get('ready_replicas', 0)}/{dep.get('replicas', 0)}\",\n152:         )\n153: \n154:     if status.get(\"service\"):\n155:         svc = status[\"service\"]\n156:         if svc.get(\"node_port\"):\n157:             table.add_row(\"NodePort\", str(svc[\"node_port\"]))\n158:         if svc.get(\"cluster_ip\"):\n159:             table.add_row(\"Cluster IP\", svc[\"cluster_ip\"])\n160: \n161:     if status.get(\"message\"):\n162:         table.add_row(\"Message\", status[\"message\"])\n163: \n164:     if status.get(\"error\"):\n165:         table.add_row(\"Error\", f\"[red]{status['error']}[/red]\")\n166: \n167:     console.print(table)\n168: \n169: \n170: @app.callback()\n171: def main(\n172:     version: Optional[bool] = typer.Option(\n173:         None,\n174:         \"--version\",\n175:         help=\"Show version and exit\",\n176:         callback=version_callback,\n177:         is_eager=True,\n178:     ),\n179:     verbose: bool = typer.Option(False, \"--verbose\", \"-v\", help=\"Enable verbose output\"),\n180: ) -> None:\n181:     \"\"\"AgentCube CLI - A developer tool for AI agent lifecycle management.\"\"\"\n182:     if verbose:\n183:         logging.basicConfig(level=logging.DEBUG)\n184: \n185: \n186: @app.command()\n187: def pack(\n188:     workspace: str = typer.Option(\n189:         \".\",\n190:         \"-f\",\n191:         \"--workspace\",\n192:         help=\"Path to the agent workspace directory\",\n193:         show_default=True,\n194:     ),\n195:     agent_name: Optional[str] = typer.Option(None, \"--agent-name\", help=\"Override the agent name\"),\n196:     language: Optional[str] = typer.Option(\n197:         None, \"--language\", help=\"Programming language (python, java)\"\n198:     ),\n199:     entrypoint: Optional[str] = typer.Option(\n200:         None, \"--entrypoint\", help=\"Override the entrypoint command\"\n201:     ),\n202:     port: Optional[int] = typer.Option(None, \"--port\", help=\"Port to expose in the Dockerfile\"),\n203:     build_mode: Optional[str] = typer.Option(\n204:         None, \"--build-mode\", help=\"Build strategy: local or cloud\"\n205:     ),\n206:     description: Optional[str] = typer.Option(None, \"--description\", help=\"Agent description\"),\n207:     output: Optional[str] = typer.Option(\n208:         None, \"--output\", help=\"Output path for packaged workspace\"\n209:     ),\n210:     verbose: bool = typer.Option(False, \"--verbose\", help=\"Enable detailed logging\"),\n211: ) -> None:\n212:     \"\"\"Pack an agent workspace for building and publishing.\n213: \n214:     This command validates the workspace structure, processes metadata,\n215:     handles dependencies, and optionally generates a Dockerfile.\n216:     \"\"\"\n217:     workspace_path = Path(workspace)\n218: \n219:     # Create PackRuntime with verbose flag\n220:     runtime = PackRuntime(verbose=verbose)\n221: \n222:     try:\n223:         with Progress(\n224:             SpinnerColumn(),\n225:             TextColumn(\"[progress.description]{task.description}\"),\n226:             console=console,\n227:             transient=True,\n228:         ) as progress:\n229:             task = progress.add_task(\"Packing agent workspace...\", total=None)\n230: \n231:             result = runtime.pack(\n232:                 workspace_path,\n233:                 agent_name=agent_name,\n234:                 language=language,\n235:                 entrypoint=entrypoint,\n236:                 port=port,\n237:                 build_mode=build_mode,\n238:                 description=description,\n239:                 output=output,\n240:                 verbose=verbose,\n241:             )\n242: \n243:             progress.update(task, completed=True)\n244: \n245:         # Print success message\n246:         console.print(\"[green]✓[/green] Successfully packed agent workspace\")\n247:         console.print(f\"  Agent name: [cyan]{result['agent_name']}[/cyan]\")\n248:         console.print(f\"  Workspace: [cyan]{result['workspace_path']}[/cyan]\")\n249:         console.print(f\"  Metadata: [cyan]{result['metadata_path']}[/cyan]\")\n250: \n251:     except Exception as e:\n252:         _handle_error(e, \"packing agent\", verbose)\n253: \n254: \n255: @app.command()\n256: def build(\n257:     workspace: str = typer.Option(\n258:         \".\",\n259:         \"-f\",\n260:         \"--workspace\",\n261:         help=\"Path to the agent workspace directory\",\n262:         show_default=True,\n263:     ),\n264:     proxy: Optional[str] = typer.Option(\n265:         None, \"-p\", \"--proxy\", help=\"Custom proxy URL for dependency resolution\"\n266:     ),\n267:     cloud_provider: Optional[str] = typer.Option(\n268:         None, \"--cloud-provider\", help=\"Cloud provider name (e.g., huawei)\"\n269:     ),\n270:     output: Optional[str] = typer.Option(None, \"--output\", help=\"Output path for build artifacts\"),\n271:     verbose: bool = typer.Option(False, \"--verbose\", help=\"Enable detailed logging\"),\n272: ) -> None:\n273:     \"\"\"Build an agent image from the packaged workspace.\n274: \n275:     This command builds a container image from the agent workspace,\n276:     either locally or using a cloud build service.\n277:     \"\"\"\n278:     workspace_path = Path(workspace).resolve()\n279: \n280:     # Create BuildRuntime with verbose flag\n281:     runtime = BuildRuntime(verbose=verbose)\n282: \n283:     try:\n284:         # Show build header\n285:         console.print(f\"Building agent from [cyan]{workspace_path}[/cyan]...\")\n286:         if verbose:\n287:             console.print(f\"  Proxy: {proxy or 'None'}\")\n288:             console.print(f\"  Cloud provider: {cloud_provider or 'None'}\")\n289:             console.print(f\"  Output: {output or 'Default'}\