{"type":"tool_use","timestamp":1775901210902,"sessionID":"ses_2840b139dffeO4wT0g0XOLmHO7","part":{"id":"prt_d7bf5c252001OIAmUCAl20K2Z3","messageID":"msg_d7bf58ca1001go1u1EkuMRaS3k","sessionID":"ses_2840b139dffeO4wT0g0XOLmHO7","type":"tool","tool":"read","callID":"toolu_functions.read:16","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/agentcube/services/k8s_provider.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/agentcube/services/k8s_provider.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Kubernetes provider for deploying standard K8s resources.\n2: \n3: This module provides the KubernetesProvider class for deploying agents\n4: as standard Kubernetes Deployment and Service resources.\n5: \"\"\"\n6: \n7: import logging\n8: import time\n9: from typing import Any, Dict, Optional\n10: \n11: from agentcube.utils.log import get_logger\n12: \n13: \n14: class KubernetesProvider:\n15:     \"\"\"Provider for standard Kubernetes Deployment and Service deployment.\"\"\"\n16: \n17:     def __init__(self, namespace: str = \"default\", verbose: bool = False) -> None:\n18:         \"\"\"Initialize KubernetesProvider.\n19: \n20:         Args:\n21:             namespace: The Kubernetes namespace for deployment.\n22:             verbose: Whether to enable verbose logging.\n23:         \"\"\"\n24:         self.namespace = namespace\n25:         self.verbose = verbose\n26:         self.logger = get_logger(__name__, logging.DEBUG if verbose else logging.INFO)\n27:         self._k8s_client = None\n28:         self._apps_v1 = None\n29:         self._core_v1 = None\n30: \n31:     def _get_k8s_client(self) -> Any:\n32:         \"\"\"Get or create Kubernetes client.\n33: \n34:         Returns:\n35:             Kubernetes client instance.\n36: \n37:         Raises:\n38:             RuntimeError: If Kubernetes client cannot be initialized.\n39:         \"\"\"\n40:         if self._k8s_client is None:\n41:             try:\n42:                 from kubernetes import client, config\n43: \n44:                 # Try to load kubeconfig\n45:                 try:\n46:                     config.load_kube_config()\n47:                     self.logger.debug(\"Loaded kubeconfig\")\n48:                 except Exception:\n49:                     # Try in-cluster config\n50:                     try:\n51:                         config.load_incluster_config()\n52:                         self.logger.debug(\"Loaded in-cluster config\")\n53:                     except Exception as e:\n54:                         raise RuntimeError(\n55:                             \"Failed to load Kubernetes configuration. \"\n56:                             \"Ensure kubeconfig is available or running in-cluster.\"\n57:                         ) from e\n58: \n59:                 self._k8s_client = client\n60:                 self._apps_v1 = client.AppsV1Api()\n61:                 self._core_v1 = client.CoreV1Api()\n62: \n63:             except ImportError as e:\n64:                 raise RuntimeError(\n65:                     \"Kubernetes client library not installed. Install with: pip install kubernetes\"\n66:                 ) from e\n67:             except Exception as e:\n68:                 raise RuntimeError(f\"Failed to initialize Kubernetes client: {e}\") from e\n69: \n70:         return self._k8s_client\n71: \n72:     def _ensure_namespace(self) -> None:\n73:         \"\"\"Ensure the target namespace exists.\n74: \n75:         Creates the namespace if it doesn't exist.\n76:         \"\"\"\n77:         client = self._get_k8s_client()\n78: \n79:         try:\n80:             self._core_v1.read_namespace(self.namespace)\n81:             self.logger.debug(f\"Namespace {self.namespace} exists\")\n82:         except client.exceptions.NotFoundException:\n83:             self.logger.info(f\"Creating namespace: {self.namespace}\")\n84:             namespace_body = client.V1Namespace(metadata=client.V1ObjectMeta(name=self.namespace))\n85:             self._core_v1.create_namespace(namespace_body)\n86:             self.logger.info(f\"Created namespace: {self.namespace}\")\n87: \n88:     def deploy_agent(\n89:         self,\n90:         agent_name: str,\n91:         image_url: str,\n92:         port: int,\n93:         entrypoint: Optional[str] = None,\n94:         replicas: int = 1,\n95:         node_port: Optional[int] = None,\n96:         env_vars: Optional[Dict[str, str]] = None,\n97:     ) -> Dict[str, Any]:\n98:         \"\"\"Deploy an agent as Kubernetes Deployment and NodePort Service.\n99: \n100:         Args:\n101:             agent_name: Name of the agent.\n102:             image_url: Full URL of the container image.\n103:             port: Port exposed by the agent.\n104:             entrypoint: Optional entrypoint command.\n105:             replicas: Number of replicas (default: 1).\n106:             node_port: Optional NodePort (30000-32767). Auto-assigned if not specified.\n107:             env_vars: Optional environment variables.\n108: \n109:         Returns:\n110:             Dict containing deployment results with keys:\n111:             - deployment_name: Name of the created Deployment\n112:             - service_name: Name of the created Service\n113:             - namespace: Deployment namespace\n114:             - node_port: Assigned NodePort\n115:             - replicas: Number of replicas\n116:             - service_url: Service access URL\n117: \n118:         Raises:\n119:             RuntimeError: If deployment fails.\n120:             ValueError: If node_port is outside valid range.\n121:         \"\"\"\n122:         # Validate node_port if provided\n123:         if node_port is not None:\n124:             if not 30000 <= node_port <= 32767:\n125:                 raise ValueError(f\"NodePort must be in range 30000-32767, got {node_port}\")\n126: \n127:         client = self._get_k8s_client()\n128: \n129:         # Ensure namespace exists\n130:         self._ensure_namespace()\n131: \n132:         self.logger.info(f\"Deploying agent to Kubernetes: {agent_name}\")\n133: \n134:         # Create or update Deployment\n135:         deployment_result = self._create_or_update_deployment(\n136:             agent_name=agent_name,\n137:             image_url=image_url,\n138:             port=port,\n139:             entrypoint=entrypoint,\n140:             replicas=replicas,\n141:             env_vars=env_vars,\n142:         )\n143: \n144:         # Create or update Service\n145:         service_result = self._create_or_update_service(\n146:             agent_name=agent_name,\n147:             port=port,\n148:             node_port=node_port,\n149:         )\n150: \n151:         # Build service URL\n152:         node_port_assigned = service_result.get(\"node_port\")\n153:         service_url = f\"http://localhost:{node_port_assigned}\"\n154: \n155:         return {\n156:             \"deployment_name\": deployment_result[\"name\"],\n157:             \"service_name\": service_result[\"name\"],\n158:             \"namespace\": self.namespace,\n159:             \"node_port\": node_port_assigned,\n160:             \"replicas\": replicas,\n161:             \"service_url\": service_url,\n162:             \"status\": \"deployed\",\n163:         }\n164: \n165:     def _create_or_update_deployment(\n166:         self,\n167:         agent_name: str,\n168:         image_url: str,\n169:         port: int,\n170:         entrypoint: Optional[str] = None,\n171:         replicas: int = 1,\n172:         env_vars: Optional[Dict[str, str]] = None,\n173:     ) -> Dict[str, Any]:\n174:         \"\"\"Create or update a Kubernetes Deployment.\n175: \n176:         Args:\n177:             agent_name: Name of the agent.\n178:             image_url: Full URL of the container image.\n179:             port: Port exposed by the agent.\n180:             entrypoint: Optional entrypoint command.\n181:             replicas: Number of replicas.\n182:             env_vars: Optional environment variables.\n183: \n184:         Returns:\n185:             Dict containing deployment information.\n186:         \"\"\"\n187:         client = self._get_k8s_client()\n188: \n189:         # Build container spec\n190:         container = client.V1Container(\n191:             name=agent_name,\n192:             image=image_url,\n193:             ports=[client.V1ContainerPort(container_port=port)],\n194:             env=[client.V1EnvVar(name=k, value=v) for k, v in (env_vars or {}).items()]\n195:             if env_vars\n196:             else None,\n197:         )\n198: \n199:         # Add command/args if entrypoint provided\n200:         if entrypoint:\n201:             parts = entrypoint.split()\n202:             if parts:\n203:                 container.command = [parts[0]]\n204:                 if len(parts) > 1:\n205:                     container.args = parts[1:]\n206: \n207:         # Build pod template\n208:         template = client.V1PodTemplateSpec(\n209:             metadata=client.V1ObjectMeta(\n210:                 labels={\"app\": agent_name},\n211:             ),\n212:             spec=client.V1PodSpec(\n213:                 containers=[container],\n214:             ),\n215:         )\n216: \n217:         # Build deployment spec\n218:         deployment_spec = client.V1DeploymentSpec(\n219:             replicas=replicas,\n220:             selector={\"matchLabels\": {\"app\": agent_name}},\n221:             template=template,\n222:         )\n223: \n224:         # Build deployment\n225:         deployment = client.V1Deployment(\n226:             api_version=\"apps/v1\",\n227:             kind=\"Deployment\",\n228:             metadata=client.V1ObjectMeta(\n229:                 name=agent_name,\n230:                 namespace=self.namespace,\n231:                 labels={\"app\": agent_name},\n232:             ),\n233:             spec=deployment_spec,\n234:         )\n235: \n236:         try:\n237:             # Try to get existing deployment\n238:             existing = self._apps_v1.read_namespaced_deployment(\n239:                 name=agent_name,\n240:                 namespace=self.namespace,\n241:             )\n242: \n243:             if existing:\n244:                 # Update existing deployment\n245:                 self.logger.info(f\"Updating existing Deployment: {agent_name}\")\n246:                 result = self._apps_v1.replace_namespaced_deployment(\n247:                     name=agent_name,\n248:                     namespace=self.namespace,\n249:                     body=deployment,\n250:                 )\n251:                 self.logger.info(f\"Updated Deployment: {agent_name}\")\n252: \n253:         except client.exceptions.NotFoundException:\n254:             # Create new deployment\n255:             self.logger.info(f\"Creating new Deployment: {agent_name}\")\n256:             result = self._apps_v1.create_namespaced_deployment(\n257:                 namespace=self.namespace,\n258:                 body=deployment,\n259:             )\n260:             self.logger.info(f\"Created Deployment: {agent_name}\")\n261: \n262:         return {\"name\": agent_name, \"namespace\": self.namespace}\n263: \n264:     def _create_or_update_service(\n265:         self,\n266:         agent_name: str,\n267:         port: int,\n268:         node_port: Optional[int] = None,\n269:     ) -> Dict[str, Any]:\n270:         \"\"\"Create or update a Kubernetes NodePort Service.\n271: \n272:         Args:\n273:             agent_name: Name of the agent (used for service name).\n274:             port: Target port on the pod.\n275:             node_port: Optional NodePort (30000-32767).\n276: \n277:         Returns:\n278:             Dict containing service information including assigned node_port.\n279:         \"\"\"\n280:         client = self._get_k8s_client()\n281: \n282:         # Build service ports\n283:         service_port = client.V1ServicePort(\n284:             port=port,\n285:             target_port=port,\n286:             node_port=node_port,\n287:         )\n288: \n289:         # Build service spec\n290:         service_spec = client.V1ServiceSpec(\n291:             type=\"NodePort\",\n292:             selector={\"app\": agent_name},\n293:             ports=[service_port],\n294:         )\n295: \n296:         # Build service\n297:         service = client.V1Service(\n298:             api_version=\"v1\",\n299:             kind=\"Service\",\n300:             metadata=client.V1ObjectMeta(\n301:                 name=agent_name,\n302:                 namespace=self.namespace,\n303:                 labels={\"app\": agent_name},\n304:             ),\n305:             spec=service_spec,\n306:         )\n307: \n308:         try:\n309:             # Try to get existing service\n310:             existing = self._core_v1.read_namespaced_service(\n311:                 name=agent_name,\n312:                 namespace=self.namespace,\n313:             )\n314: \n315:             if existing:\n316:                 # Update existing service\n317:                 self.logger.info(f\"Updating existing Service: {agent_name}\")\n318:                 result = self._core_v1.replace_namespaced_service(\n319:                     name=agent_name,\n320:                     namespace=self.namespace,\n321:                     body=service,\n322:                 )\n323:                 self.logger.info(f\"Updated Service: {agent_name}\")\n324: \n325:         except client.exceptions.NotFoundException:\n326:             # Create new service\n327:             self.logger.info(f\"Creating new Service: {agent_name}\")\n328:             result = self._core_v1.create_namespaced_service(\n329:                 namespace=self.namespace,\n330:                 body=service,\n331:             )\n332:             self.logger.info(f\"Created Service: {agent_name}\")\n333: \n334:         # Get the assigned node port\n335:         assigned_node_port = None\n336:         if result and result.spec and result.spec.ports:\n337:             assigned_node_port = result.spec.ports[0].node_port\n338: \n339:         return {\n340:             \"name\": agent_name,\n341:             \"namespace\": self.namespace,\n342:             \"node_port\": assigned_node_port,\n343:         }\n344: \n345:     def wait_for_deployment_ready(\n346:         self,\n347:         name: str,\n348:         timeout: int = 120,\n349:         interval: int = 5,\n350:     ) -> Dict[str, Any]:\n351:         \"\"\"Wait for a Deployment to be ready.\n352: \n353:         Args:\n354:             name: Name of the deployment.\n355:             timeout: Maximum time to wait in seconds (default: 120).\n356:             interval: Check interval in seconds (default: 5).\n357: \n358:         Returns:\n359:             Dict containing deployment status.\n360: \n361:         Raises:\n362:             TimeoutError: If deployment is not ready within timeout.\n363:             RuntimeError: If deployment fails.\n364:         \"\"\"\n365:         client = self._get_k8s_client()\n366: \n367:         self.logger.info(f\"Waiting for Deployment {name} to be ready (timeout: {timeout}s)\")\n368: \n369:         start_time = time.time()\n370:         while time.time() - start_time < timeout:\n371:             try:\n372:                 deployment = self._apps_v1.read_namespaced_deployment(\n373:                     name=name,\n374:                     namespace=self.namespace,\n375:                 )\n376: \n377:                 if deployment.status:\n378:                     ready_replicas = deployment.status.ready_replicas or 0\n379:                     desired_replicas = deployment.spec.replicas or 1\n380: \n381:                     self.logger.debug(\n382:                         f\"Deployment {name}: {ready_replicas}/{desired_replicas} ready\"\n383:                     )\n384: \n385:                     if ready_replicas >= desired_replicas:\n386:                         self.logger.info(f\"Deployment {name} is ready\")\n387:                         return {\n388:                             \"name\": name,\n389:                             \"namespace\": self.namespace,\n390:                             \"ready_replicas\": ready_replicas,\n391:                             \"desired_replicas\": desired_replicas,\n392:                             \"status\": \"ready\",\n393:                         }\n394: \n395:                     # Check for failures\n396:                     if (\n397:                         deployment.status.unavailable_replicas\n398:                         and deployment.status.unavailable_replicas > 0\n399:                     ):\n400:                         # Check if there are any failed conditions\n401:                         conditions = deployment.status.conditions or []\n402:                         for condition in conditions:\n403:                             if condition.type == \"Progressing\" and condition.status == \"False\":\n404:                                 raise RuntimeError(f\"Deployment {name} failed: {condition.message}\")\n405: \n406:             except client.exceptions.NotFoundException:\n407:                 self.logger.debug(f\"Deployment {name} not yet created\")\n408: \n409:             except Exception as e:\n410:                 self.logger.warning(f\"Error checking deployment status: {e}\")\n411: \n412:             time.sleep(interval)\n413: \n414:         # Timeout reached\n415:         raise TimeoutError(f\"Deployment {name} did not become ready within {timeout} seconds\")\n416: \n417:     def get_agent_status(self, name: str) -> Dict[str, Any]:\n418:         \"\"\"Get the status of a deployed agent.\n419: \n420:         Args:\n421:             name: Name of the agent (deployment name).\n422: \n423:         Returns:\n424:             Dict containing the agent status.\n425: \n426:         Raises:\n427:             RuntimeError: If status retrieval fails.\n428:         \"\"\"\n429:         client = self._get_k8s_client()\n430: \n431:         try:\n432:             deployment = self._apps_v1.read_namespaced_deployment(\n433:                 name=name,\n434:                 namespace=self.namespace,\n435:             )\n436: \n437:             service = None\n438:             try:\n439:                 service = self._core_v1.read_namespaced_service(\n440:                     name=name,\n441:                     namespace=self.namespace,\n442:                 )\n443:             except client.exceptions.NotFoundException:\n444:                 pass\n445: \n446:             return {\n447:                 \"name\": name,\n448:                 \"namespace\": self.namespace,\n449:                 \"deployment\": {\n450:                     \"replicas\": deployment.spec.replicas if deployment.spec else 0,\n451:                     \"ready_replicas\": deployment.status.ready_replicas if deployment.status else 0,\n452:                     \"available_replicas\": deployment.status.available_replicas\n453:                     if deployment.status\n454:                     else 0,\n455:                 },\n456:                 \"service\": {\n457:                     \"cluster_ip\": service.spec.cluster_ip if service and service.spec else None,\n458:                     \"node_port\": service.spec.ports[0].node_port\n459:                     if service and service.spec and service.spec.ports\n460:                     else None,\n461:                 }\n462:                 if service\n463:                 else None,\n464:             }\n465: \n466:         except client.exceptions.NotFoundException:\n467:             return {\n468:                 \"name\": name,\n469:                 \"namespace\": self.namespace,\n470:                 \"status\": \"not_found\",\n471:             }\n472: \n473:         except Exception as e:\n474:             self.logger.error(f\"Failed to get agent status: {e}\")\n475:             raise RuntimeError(f\"Failed to get agent status: {e}\") from e\n476: \n477:     def delete_agent(self, name: str) -> Dict[str, Any]:\n478:         \"\"\"Delete a deployed agent (Deployment and Service).\n479: \n480:         Args:\n481:             name: Name of the agent to delete.\n482: \n483:         Returns:\n484:             Dict containing deletion result.\n485: \n486:         Raises:\n487:             RuntimeError: If deletion fails.\n488:         \"\"\"\n489:         client = self._get_k8s_client()\n490: \n491:         result = {\n492:             \"name\": name,\n493:             \"namespace\": self.namespace,\n494:             \"deployment_deleted\": False,\n495:             \"service_deleted\": False,\n496:         }\n497: \n498:         # Delete Deployment\n499:         try:\n500:             self._apps_v1.delete_namespaced_deployment(\n501:                 name=name,\n502:                 namespace=self.namespace,\n503:             )\n504:             self.logger.info(f\"Deleted Deployment: {name}\")\n505:             result[\"deployment_deleted\"] = True\n506:         except client.exceptions.NotFoundException:\n507:             self.logger.warning(f\"Deployment not found: {name}\")\n508:         except Exception as e:\n509:             self.logger.error(f\"Failed to delete Deployment: {e}\")\n510:             raise RuntimeError(f\"Failed to delete Deployment: {e}\") from e\n511: \n512:         # Delete Service\n513:         try:\n514:             self._core_v1.delete_namespaced_service(\n515:                 name=name,\n516:                 namespace=self.namespace,\n517:             )\n518:             self.logger.info(f\"Deleted Service: {name}\")\n519:             result[\"service_deleted\"] = True\n520:         except client.exceptions.NotFoundException:\n521:             self.logger.warning(f\"Service not found: {name}\")\n522:         except Exception as e:\n523:             self.logger.error(f\"Failed to delete Service: {e}\")\n524:             raise RuntimeError(f\"Failed to delete Service: {e}\") from e\n525: \n526:         return result\n\n(End of file - total 526 lines)\n</content>","metadata":{"preview":"\"\"\"Kubernetes provider for deploying standard K8s resources.\n\nThis module provides the KubernetesProvider class for deploying agents\nas standard Kubernetes Deployment and Service resources.\n\"\"\"\n\nimport logging\nimport time\nfrom typing import Any, Dict, Optional\n\nfrom agentcube.utils.log import get_logger\n\n\nclass KubernetesProvider:\n    \"\"\"Provider for standard Kubernetes Deployment and Service deployment.\"\"\"\n\n    def __init__(self, namespace: str = \"default\", verbose: bool = False) -> None:\n        \"\"\"Initialize KubernetesProvider.\n\n        Args:","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/agentcube/services/k8s_provider.py","time":{"start":1775901210870,"end":1775901210900}}}}
{"type":"tool_use","timestamp":1775901210904,"sessionID":"ses_2840b139dffeO4wT0g0XOLmHO7","part":{"id":"prt_d7bf5c95c001LePKLYtDQdN4RD","messageID":"msg_d7bf58ca1001go1u1EkuMRaS3k","sessionID":"ses_2840b139dffeO4wT0g0XOLmHO7","type":"tool","tool":"read","callID":"toolu_functions.read:17","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/agentcube/services/agentcube_provider.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/agentcube/services/agentcube_provider.py</path>\n<type>file</type>\n<content>\n1: \"\"\"AgentCube provider for deploying AgentRuntime Custom Resources.\n2: \n3: This module provides the AgentCubeProvider class for deploying agents\n4: as AgentRuntime Custom Resources in Kubernetes.\n5: \"\"\"\n6: \n7: import logging\n8: import time\n9: from pathlib import Path\n10: from typing import Any, Dict, Optional\n11: \n12: from agentcube.utils.log import get_logger\n13: \n14: \n15: class AgentCubeProvider:\n16:     \"\"\"Provider for AgentCube-specific AgentRuntime CR deployment.\"\"\"\n17: \n18:     def __init__(self, namespace: str = \"default\", verbose: bool = False) -> None:\n19:         \"\"\"Initialize AgentCubeProvider.\n20: \n21:         Args:\n22:             namespace: The Kubernetes namespace for deployment.\n23:             verbose: Whether to enable verbose logging.\n24:         \"\"\"\n25:         self.namespace = namespace\n26:         self.verbose = verbose\n27:         self.logger = get_logger(__name__, logging.DEBUG if verbose else logging.INFO)\n28:         self._k8s_client = None\n29: \n30:     def _get_k8s_client(self) -> Any:\n31:         \"\"\"Get or create Kubernetes client.\n32: \n33:         Returns:\n34:             Kubernetes client instance.\n35: \n36:         Raises:\n37:             RuntimeError: If Kubernetes client cannot be initialized.\n38:         \"\"\"\n39:         if self._k8s_client is None:\n40:             try:\n41:                 from kubernetes import client, config\n42: \n43:                 # Try to load kubeconfig\n44:                 try:\n45:                     config.load_kube_config()\n46:                     self.logger.debug(\"Loaded kubeconfig\")\n47:                 except Exception:\n48:                     # Try in-cluster config\n49:                     try:\n50:                         config.load_incluster_config()\n51:                         self.logger.debug(\"Loaded in-cluster config\")\n52:                     except Exception as e:\n53:                         raise RuntimeError(\n54:                             \"Failed to load Kubernetes configuration. \"\n55:                             \"Ensure kubeconfig is available or running in-cluster.\"\n56:                         ) from e\n57: \n58:                 self._k8s_client = client\n59:             except ImportError as e:\n60:                 raise RuntimeError(\n61:                     \"Kubernetes client library not installed. Install with: pip install kubernetes\"\n62:                 ) from e\n63:             except Exception as e:\n64:                 raise RuntimeError(f\"Failed to initialize Kubernetes client: {e}\") from e\n65: \n66:         return self._k8s_client\n67: \n68:     def _ensure_namespace(self) -> None:\n69:         \"\"\"Ensure the target namespace exists.\n70: \n71:         Creates the namespace if it doesn't exist.\n72:         \"\"\"\n73:         client = self._get_k8s_client()\n74:         core_v1 = client.CoreV1Api()\n75: \n76:         try:\n77:             core_v1.read_namespace(self.namespace)\n78:             self.logger.debug(f\"Namespace {self.namespace} exists\")\n79:         except client.exceptions.NotFoundException:\n80:             self.logger.info(f\"Creating namespace: {self.namespace}\")\n81:             namespace_body = client.V1Namespace(metadata=client.V1ObjectMeta(name=self.namespace))\n82:             core_v1.create_namespace(namespace_body)\n83:             self.logger.info(f\"Created namespace: {self.namespace}\")\n84: \n85:     def deploy_agent_runtime(\n86:         self,\n87:         agent_name: str,\n88:         image_url: str,\n89:         port: int,\n90:         entrypoint: Optional[str] = None,\n91:         env_vars: Optional[Dict[str, str]] = None,\n92:         workload_manager_url: Optional[str] = None,\n93:         router_url: Optional[str] = None,\n94:         readiness_probe_path: Optional[str] = None,\n95:         readiness_probe_port: Optional[int] = None,\n96:         session_timeout: str = \"15m\",\n97:         max_session_duration: str = \"8h\",\n98:         image_pull_secrets: Optional[list] = None,\n99:     ) -> Dict[str, Any]:\n100:         \"\"\"Deploy an AgentRuntime Custom Resource to Kubernetes.\n101: \n102:         Args:\n103:             agent_name: Name of the agent.\n104:             image_url: Full URL of the container image.\n105:             port: Port exposed by the agent.\n106:             entrypoint: Optional entrypoint command.\n107:             env_vars: Optional environment variables.\n108:             workload_manager_url: URL for the Workload Manager.\n109:             router_url: URL for the Router.\n110:             readiness_probe_path: Path for readiness probe.\n111:             readiness_probe_port: Port for readiness probe.\n112:             session_timeout: Session timeout duration (default: \"15m\").\n113:             max_session_duration: Maximum session duration (default: \"8h\").\n114:             image_pull_secrets: List of image pull secrets.\n115: \n116:         Returns:\n117:             Dict containing deployment results with keys:\n118:             - agent_id: The deployed agent identifier\n119:             - agent_endpoint: The agent endpoint URL\n120:             - name: The AgentRuntime CR name\n121:             - namespace: The deployment namespace\n122:             - status: Deployment status\n123: \n124:         Raises:\n125:             RuntimeError: If deployment fails.\n126:             ValueError: If required parameters are missing.\n127:         \"\"\"\n128:         if not workload_manager_url or not router_url:\n129:             raise ValueError(\n130:                 \"AgentCube provider requires router_url and workload_manager_url. \"\n131:                 \"Please set these in agent_metadata.yaml or provide via options.\"\n132:             )\n133: \n134:         client = self._get_k8s_client()\n135: \n136:         # Ensure namespace exists\n137:         self._ensure_namespace()\n138: \n139:         self.logger.info(f\"Deploying AgentRuntime CR: {agent_name}\")\n140: \n141:         # Build the AgentRuntime CR spec\n142:         cr_spec = self._build_agent_runtime_spec(\n143:             agent_name=agent_name,\n144:             image_url=image_url,\n145:             port=port,\n146:             entrypoint=entrypoint,\n147:             env_vars=env_vars,\n148:             workload_manager_url=workload_manager_url,\n149:             router_url=router_url,\n150:             readiness_probe_path=readiness_probe_path,\n151:             readiness_probe_port=readiness_probe_port,\n152:             session_timeout=session_timeout,\n153:             max_session_duration=max_session_duration,\n154:             image_pull_secrets=image_pull_secrets,\n155:         )\n156: \n157:         # Apply the CR to the cluster\n158:         result = self._apply_agent_runtime_cr(agent_name, cr_spec)\n159: \n160:         # Build endpoint URL from router_url\n161:         agent_endpoint = f\"{router_url}/v1/agents/{agent_name}\"\n162: \n163:         return {\n164:             \"agent_id\": agent_name,\n165:             \"agent_endpoint\": agent_endpoint,\n166:             \"name\": agent_name,\n167:             \"namespace\": self.namespace,\n168:             \"status\": \"deployed\",\n169:             \"workload_manager_url\": workload_manager_url,\n170:             \"router_url\": router_url,\n171:         }\n172: \n173:     def _build_agent_runtime_spec(\n174:         self,\n175:         agent_name: str,\n176:         image_url: str,\n177:         port: int,\n178:         entrypoint: Optional[str] = None,\n179:         env_vars: Optional[Dict[str, str]] = None,\n180:         workload_manager_url: Optional[str] = None,\n181:         router_url: Optional[str] = None,\n182:         readiness_probe_path: Optional[str] = None,\n183:         readiness_probe_port: Optional[int] = None,\n184:         session_timeout: str = \"15m\",\n185:         max_session_duration: str = \"8h\",\n186:         image_pull_secrets: Optional[list] = None,\n187:     ) -> Dict[str, Any]:\n188:         \"\"\"Build the AgentRuntime Custom Resource specification.\n189: \n190:         Args:\n191:             agent_name: Name of the agent.\n192:             image_url: Full URL of the container image.\n193:             port: Port exposed by the agent.\n194:             entrypoint: Optional entrypoint command.\n195:             env_vars: Optional environment variables.\n196:             workload_manager_url: URL for the Workload Manager.\n197:             router_url: URL for the Router.\n198:             readiness_probe_path: Path for readiness probe.\n199:             readiness_probe_port: Port for readiness probe.\n200:             session_timeout: Session timeout duration.\n201:             max_session_duration: Maximum session duration.\n202:             image_pull_secrets: List of image pull secrets.\n203: \n204:         Returns:\n205:             Dict containing the AgentRuntime CR specification.\n206:         \"\"\"\n207:         # Merge env vars with AgentCube required vars\n208:         merged_env = env_vars.copy() if env_vars else {}\n209:         merged_env[\"WORKLOAD_MANAGER_URL\"] = workload_manager_url\n210:         merged_env[\"ROUTER_URL\"] = router_url\n211: \n212:         # Build container spec\n213:         container_spec = {\n214:             \"name\": agent_name,\n215:             \"image\": image_url,\n216:             \"ports\": [{\"containerPort\": port}],\n217:             \"env\": [{\"name\": k, \"value\": v} for k, v in merged_env.items()],\n218:         }\n219: \n220:         # Add entrypoint if provided\n221:         if entrypoint:\n222:             # Parse entrypoint into command and args\n223:             parts = entrypoint.split()\n224:             if parts:\n225:                 container_spec[\"command\"] = [parts[0]]\n226:                 if len(parts) > 1:\n227:                     container_spec[\"args\"] = parts[1:]\n228: \n229:         # Add readiness probe if configured\n230:         if readiness_probe_path:\n231:             probe_port = readiness_probe_port or port\n232:             container_spec[\"readinessProbe\"] = {\n233:                 \"httpGet\": {\n234:                     \"path\": readiness_probe_path,\n235:                     \"port\": probe_port,\n236:                 },\n237:                 \"initialDelaySeconds\": 10,\n238:                 \"periodSeconds\": 5,\n239:             }\n240: \n241:         # Build the CR spec\n242:         spec = {\n243:             \"apiVersion\": \"agentcube.io/v1\",\n244:             \"kind\": \"AgentRuntime\",\n245:             \"metadata\": {\n246:                 \"name\": agent_name,\n247:                 \"namespace\": self.namespace,\n248:             },\n249:             \"spec\": {\n250:                 \"image\": image_url,\n251:                 \"port\": port,\n252:                 \"sessionTimeout\": session_timeout,\n253:                 \"maxSessionDuration\": max_session_duration,\n254:                 \"podTemplate\": {\n255:                     \"spec\": {\n256:                         \"containers\": [container_spec],\n257:                     }\n258:                 },\n259:             },\n260:         }\n261: \n262:         # Add image pull secrets if provided\n263:         if image_pull_secrets:\n264:             spec[\"spec\"][\"podTemplate\"][\"spec\"][\"imagePullSecrets\"] = image_pull_secrets\n265:         else:\n266:             # Default image pull secret\n267:             spec[\"spec\"][\"podTemplate\"][\"spec\"][\"imagePullSecrets\"] = [{\"name\": \"default-secret\"}]\n268: \n269:         return spec\n270: \n271:     def _apply_agent_runtime_cr(self, agent_name: str, cr_spec: Dict[str, Any]) -> Dict[str, Any]:\n272:         \"\"\"Apply the AgentRuntime CR to the Kubernetes cluster.\n273: \n274:         Args:\n275:             agent_name: Name of the agent.\n276:             cr_spec: The AgentRuntime CR specification.\n277: \n278:         Returns:\n279:             Dict containing the applied CR information.\n280: \n281:         Raises:\n282:             RuntimeError: If CR application fails.\n283:         \"\"\"\n284:         client = self._get_k8s_client()\n285: \n286:         # Use the CustomObjectsApi for CR operations\n287:         api = client.CustomObjectsApi()\n288: \n289:         group = \"agentcube.io\"\n290:         version = \"v1\"\n291:         plural = \"agentruntimes\"\n292: \n293:         try:\n294:             # Check if CR already exists\n295:             existing = api.get_namespaced_custom_object(\n296:                 group=group,\n297:                 version=version,\n298:                 namespace=self.namespace,\n299:                 plural=plural,\n300:                 name=agent_name,\n301:             )\n302: \n303:             if existing:\n304:                 # Update (patch) existing CR\n305:                 self.logger.info(f\"Updating existing AgentRuntime: {agent_name}\")\n306:                 result = api.patch_namespaced_custom_object(\n307:                     group=group,\n308:                     version=version,\n309:                     namespace=self.namespace,\n310:                     plural=plural,\n311:                     name=agent_name,\n312:                     body=cr_spec,\n313:                 )\n314:                 self.logger.info(f\"Updated AgentRuntime: {agent_name}\")\n315:                 return result\n316: \n317:         except client.exceptions.NotFoundException:\n318:             # CR doesn't exist, create it\n319:             self.logger.info(f\"Creating new AgentRuntime: {agent_name}\")\n320:             result = api.create_namespaced_custom_object(\n321:                 group=group,\n322:                 version=version,\n323:                 namespace=self.namespace,\n324:                 plural=plural,\n325:                 body=cr_spec,\n326:             )\n327:             self.logger.info(f\"Created AgentRuntime: {agent_name}\")\n328:             return result\n329: \n330:         except Exception as e:\n331:             self.logger.error(f\"Failed to apply AgentRuntime CR: {e}\")\n332:             raise RuntimeError(f\"Failed to deploy AgentRuntime: {e}\") from e\n333: \n334:         return cr_spec\n335: \n336:     def get_agent_status(self, agent_name: str) -> Dict[str, Any]:\n337:         \"\"\"Get the status of a deployed AgentRuntime.\n338: \n339:         Args:\n340:             agent_name: Name of the agent.\n341: \n342:         Returns:\n343:             Dict containing the agent status.\n344: \n345:         Raises:\n346:             RuntimeError: If status retrieval fails.\n347:         \"\"\"\n348:         client = self._get_k8s_client()\n349:         api = client.CustomObjectsApi()\n350: \n351:         group = \"agentcube.io\"\n352:         version = \"v1\"\n353:         plural = \"agentruntimes\"\n354: \n355:         try:\n356:             result = api.get_namespaced_custom_object(\n357:                 group=group,\n358:                 version=version,\n359:                 namespace=self.namespace,\n360:                 plural=plural,\n361:                 name=agent_name,\n362:             )\n363: \n364:             return {\n365:                 \"agent_name\": agent_name,\n366:                 \"namespace\": self.namespace,\n367:                 \"status\": result.get(\"status\", {}),\n368:                 \"spec\": result.get(\"spec\", {}),\n369:             }\n370: \n371:         except client.exceptions.NotFoundException:\n372:             return {\n373:                 \"agent_name\": agent_name,\n374:                 \"namespace\": self.namespace,\n375:                 \"status\": \"not_found\",\n376:             }\n377: \n378:         except Exception as e:\n379:             self.logger.error(f\"Failed to get agent status: {e}\")\n380:             raise RuntimeError(f\"Failed to get agent status: {e}\") from e\n381: \n382:     def delete_agent(self, agent_name: str) -> Dict[str, Any]:\n383:         \"\"\"Delete an AgentRuntime Custom Resource.\n384: \n385:         Args:\n386:             agent_name: Name of the agent to delete.\n387: \n388:         Returns:\n389:             Dict containing deletion result.\n390: \n391:         Raises:\n392:             RuntimeError: If deletion fails.\n393:         \"\"\"\n394:         client = self._get_k8s_client()\n395:         api = client.CustomObjectsApi()\n396: \n397:         group = \"agentcube.io\"\n398:         version = \"v1\"\n399:         plural = \"agentruntimes\"\n400: \n401:         try:\n402:             api.delete_namespaced_custom_object(\n403:                 group=group,\n404:                 version=version,\n405:                 namespace=self.namespace,\n406:                 plural=plural,\n407:                 name=agent_name,\n408:             )\n409: \n410:             self.logger.info(f\"Deleted AgentRuntime: {agent_name}\")\n411:             return {\n412:                 \"agent_name\": agent_name,\n413:                 \"namespace\": self.namespace,\n414:                 \"deleted\": True,\n415:             }\n416: \n417:         except client.exceptions.NotFoundException:\n418:             self.logger.warning(f\"AgentRuntime not found: {agent_name}\")\n419:             return {\n420:                 \"agent_name\": agent_name,