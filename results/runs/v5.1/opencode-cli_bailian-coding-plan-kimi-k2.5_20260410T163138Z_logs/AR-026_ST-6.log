{"type":"tool_use","timestamp":1775901227167,"sessionID":"ses_2840b139dffeO4wT0g0XOLmHO7","part":{"id":"prt_d7bf61c18001DRd8eDjtGhfHRh","messageID":"msg_d7bf5f9550017XpPOhashG7qAm","sessionID":"ses_2840b139dffeO4wT0g0XOLmHO7","type":"tool","tool":"read","callID":"toolu_functions.read:22","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/tests/test_pack_models.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/tests/test_pack_models.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Tests for pack_models module.\n2: \n3: This module contains unit tests for:\n4: - MetadataOptions dataclass\n5: \"\"\"\n6: \n7: from typing import Any, Dict\n8: \n9: import pytest\n10: \n11: from agentcube.models.pack_models import MetadataOptions\n12: \n13: \n14: class TestMetadataOptions:\n15:     \"\"\"Tests for MetadataOptions dataclass.\"\"\"\n16: \n17:     def test_default_values(self) -> None:\n18:         \"\"\"Test that default values are set correctly.\"\"\"\n19:         options = MetadataOptions()\n20: \n21:         assert options.agent_name is None\n22:         assert options.language == \"python\"\n23:         assert options.entrypoint is None\n24:         assert options.port == 8080\n25:         assert options.build_mode == \"local\"\n26:         assert options.requirements_file is None\n27:         assert options.description is None\n28:         assert options.workload_manager_url == \"\"\n29:         assert options.router_url == \"\"\n30:         assert options.readiness_probe_path == \"\"\n31:         assert options.readiness_probe_port == 8080\n32:         assert options.registry_url == \"\"\n33:         assert options.registry_username == \"\"\n34:         assert options.registry_password == \"\"\n35:         assert options.agent_endpoint == \"\"\n36: \n37:     def test_custom_values(self) -> None:\n38:         \"\"\"Test that custom values can be set.\"\"\"\n39:         options = MetadataOptions(\n40:             agent_name=\"my-agent\",\n41:             language=\"java\",\n42:             entrypoint=\"java -jar app.jar\",\n43:             port=9090,\n44:             build_mode=\"cloud\",\n45:             requirements_file=\"pom.xml\",\n46:             description=\"My agent description\",\n47:             workload_manager_url=\"http://wm:8080\",\n48:             router_url=\"http://router:8080\",\n49:             readiness_probe_path=\"/health\",\n50:             readiness_probe_port=9090,\n51:             registry_url=\"registry.example.com\",\n52:             registry_username=\"user\",\n53:             registry_password=\"pass\",\n54:             agent_endpoint=\"http://agent:8080\",\n55:         )\n56: \n57:         assert options.agent_name == \"my-agent\"\n58:         assert options.language == \"java\"\n59:         assert options.entrypoint == \"java -jar app.jar\"\n60:         assert options.port == 9090\n61:         assert options.build_mode == \"cloud\"\n62:         assert options.requirements_file == \"pom.xml\"\n63:         assert options.description == \"My agent description\"\n64:         assert options.workload_manager_url == \"http://wm:8080\"\n65:         assert options.router_url == \"http://router:8080\"\n66:         assert options.readiness_probe_path == \"/health\"\n67:         assert options.readiness_probe_port == 9090\n68:         assert options.registry_url == \"registry.example.com\"\n69:         assert options.registry_username == \"user\"\n70:         assert options.registry_password == \"pass\"\n71:         assert options.agent_endpoint == \"http://agent:8080\"\n72: \n73:     def test_partial_values(self) -> None:\n74:         \"\"\"Test that partial values can be set with defaults for others.\"\"\"\n75:         options = MetadataOptions(agent_name=\"test-agent\", entrypoint=\"python main.py\")\n76: \n77:         assert options.agent_name == \"test-agent\"\n78:         assert options.entrypoint == \"python main.py\"\n79:         assert options.language == \"python\"  # default\n80:         assert options.port == 8080  # default\n81: \n82:     def test_from_options_all_values(self) -> None:\n83:         \"\"\"Test from_options with all values provided.\"\"\"\n84:         options_dict: Dict[str, Any] = {\n85:             \"agent_name\": \"dict-agent\",\n86:             \"language\": \"java\",\n87:             \"entrypoint\": \"java -jar app.jar\",\n88:             \"port\": 9090,\n89:             \"build_mode\": \"cloud\",\n90:             \"requirements_file\": \"pom.xml\",\n91:             \"description\": \"From dict\",\n92:             \"workload_manager_url\": \"http://wm:9090\",\n93:             \"router_url\": \"http://router:9090\",\n94:             \"readiness_probe_path\": \"/ready\",\n95:             \"readiness_probe_port\": 9090,\n96:             \"registry_url\": \"registry.io\",\n97:             \"registry_username\": \"admin\",\n98:             \"registry_password\": \"secret\",\n99:             \"agent_endpoint\": \"http://ep:9090\",\n100:         }\n101: \n102:         options = MetadataOptions.from_options(options_dict)\n103: \n104:         assert options.agent_name == \"dict-agent\"\n105:         assert options.language == \"java\"\n106:         assert options.entrypoint == \"java -jar app.jar\"\n107:         assert options.port == 9090\n108:         assert options.build_mode == \"cloud\"\n109:         assert options.requirements_file == \"pom.xml\"\n110:         assert options.description == \"From dict\"\n111:         assert options.workload_manager_url == \"http://wm:9090\"\n112:         assert options.router_url == \"http://router:9090\"\n113:         assert options.readiness_probe_path == \"/ready\"\n114:         assert options.readiness_probe_port == 9090\n115:         assert options.registry_url == \"registry.io\"\n116:         assert options.registry_username == \"admin\"\n117:         assert options.registry_password == \"secret\"\n118:         assert options.agent_endpoint == \"http://ep:9090\"\n119: \n120:     def test_from_options_partial_values(self) -> None:\n121:         \"\"\"Test from_options with partial values.\"\"\"\n122:         options_dict: Dict[str, Any] = {\n123:             \"agent_name\": \"partial-agent\",\n124:             \"port\": 3000,\n125:         }\n126: \n127:         options = MetadataOptions.from_options(options_dict)\n128: \n129:         assert options.agent_name == \"partial-agent\"\n130:         assert options.port == 3000\n131:         assert options.language == \"python\"  # default\n132:         assert options.entrypoint is None  # default\n133:         assert options.build_mode == \"local\"  # default\n134: \n135:     def test_from_options_empty_dict(self) -> None:\n136:         \"\"\"Test from_options with empty dict.\"\"\"\n137:         options = MetadataOptions.from_options({})\n138: \n139:         assert options.agent_name is None\n140:         assert options.language == \"python\"\n141:         assert options.entrypoint is None\n142:         assert options.port == 8080\n143:         assert options.build_mode == \"local\"\n144: \n145:     def test_from_options_filters_none(self) -> None:\n146:         \"\"\"Test that from_options filters out None values.\"\"\"\n147:         options_dict: Dict[str, Any] = {\n148:             \"agent_name\": \"filtered-agent\",\n149:             \"language\": None,  # Should be filtered, allowing default\n150:             \"port\": None,  # Should be filtered, allowing default\n151:             \"description\": None,  # Should be filtered, allowing default\n152:         }\n153: \n154:         options = MetadataOptions.from_options(options_dict)\n155: \n156:         assert options.agent_name == \"filtered-agent\"\n157:         # None values should be filtered, so defaults are used\n158:         assert options.language == \"python\"  # default, not None\n159:         assert options.port == 8080  # default, not None\n160:         assert options.description is None  # default is None anyway\n161: \n162:     def test_from_options_preserves_non_none(self) -> None:\n163:         \"\"\"Test that from_options preserves non-None values including empty strings.\"\"\"\n164:         options_dict: Dict[str, Any] = {\n165:             \"agent_name\": \"\",\n166:             \"language\": \"\",\n167:             \"description\": \"\",\n168:         }\n169: \n170:         options = MetadataOptions.from_options(options_dict)\n171: \n172:         # Empty strings are not None, so they should be preserved\n173:         assert options.agent_name == \"\"\n174:         assert options.language == \"\"\n175:         assert options.description == \"\"\n176: \n177:     def test_from_options_preserves_zero(self) -> None:\n178:         \"\"\"Test that from_options preserves zero values.\"\"\"\n179:         options_dict: Dict[str, Any] = {\n180:             \"port\": 0,\n181:         }\n182: \n183:         options = MetadataOptions.from_options(options_dict)\n184: \n185:         # Zero is not None, so it should be preserved\n186:         assert options.port == 0\n187: \n188:     def test_from_options_preserves_false(self) -> None:\n189:         \"\"\"Test that from_options preserves False values in valid fields.\"\"\"\n190:         # Note: MetadataOptions doesn't have a 'verbose' field, so we test\n191:         # that the method handles boolean values correctly for existing fields\n192:         # by testing with an optional field that could be set to a boolean\n193:         # In this case, we're just verifying the filtering logic works\n194:         options_dict: Dict[str, Any] = {\n195:             \"agent_name\": \"test\",\n196:             \"language\": \"python\",\n197:         }\n198: \n199:         options = MetadataOptions.from_options(options_dict)\n200: \n201:         # The values should be preserved\n202:         assert options.agent_name == \"test\"\n203:         assert options.language == \"python\"\n204: \n205:     def test_from_options_ignores_extra_keys(self) -> None:\n206:         \"\"\"Test that from_options handles extra keys gracefully.\n207: \n208:         Note: The current implementation passes all non-None keys to the constructor,\n209:         which will raise TypeError for unexpected keys. This is the expected behavior\n210:         as it prevents silently ignoring potentially important configuration.\n211:         \"\"\"\n212:         options_dict: Dict[str, Any] = {\n213:             \"agent_name\": \"extra-keys-agent\",\n214:             \"extra_field\": \"ignored\",\n215:             \"another_extra\": 123,\n216:         }\n217: \n218:         # Should raise TypeError because extra_field is not a valid field\n219:         with pytest.raises(TypeError):\n220:             MetadataOptions.from_options(options_dict)\n221: \n222:         # Valid options without extra keys should work fine\n223:         valid_dict: Dict[str, Any] = {\n224:             \"agent_name\": \"valid-agent\",\n225:             \"language\": \"java\",\n226:         }\n227:         options = MetadataOptions.from_options(valid_dict)\n228:         assert options.agent_name == \"valid-agent\"\n229:         assert options.language == \"java\"\n230: \n231:     def test_field_count(self) -> None:\n232:         \"\"\"Test that all expected fields are present.\"\"\"\n233:         options = MetadataOptions()\n234: \n235:         # Check that all 15 fields are present\n236:         expected_fields = [\n237:             \"agent_name\",\n238:             \"language\",\n239:             \"entrypoint\",\n240:             \"port\",\n241:             \"build_mode\",\n242:             \"requirements_file\",\n243:             \"description\",\n244:             \"workload_manager_url\",\n245:             \"router_url\",\n246:             \"readiness_probe_path\",\n247:             \"readiness_probe_port\",\n248:             \"registry_url\",\n249:             \"registry_username\",\n250:             \"registry_password\",\n251:             \"agent_endpoint\",\n252:         ]\n253: \n254:         for field in expected_fields:\n255:             assert hasattr(options, field), f\"Missing field: {field}\"\n256: \n257:     def test_mutability(self) -> None:\n258:         \"\"\"Test that MetadataOptions is mutable.\"\"\"\n259:         options = MetadataOptions(agent_name=\"initial\")\n260: \n261:         assert options.agent_name == \"initial\"\n262: \n263:         options.agent_name = \"changed\"\n264:         options.port = 3000\n265: \n266:         assert options.agent_name == \"changed\"\n267:         assert options.port == 3000\n268: \n269:     def test_comparison(self) -> None:\n270:         \"\"\"Test that two MetadataOptions instances can be compared.\"\"\"\n271:         options1 = MetadataOptions(agent_name=\"test\", port=8080)\n272:         options2 = MetadataOptions(agent_name=\"test\", port=8080)\n273:         options3 = MetadataOptions(agent_name=\"other\", port=9090)\n274: \n275:         assert options1 == options2\n276:         assert options1 != options3\n277:         assert options1.agent_name == options2.agent_name\n\n(End of file - total 277 lines)\n</content>","metadata":{"preview":"\"\"\"Tests for pack_models module.\n\nThis module contains unit tests for:\n- MetadataOptions dataclass\n\"\"\"\n\nfrom typing import Any, Dict\n\nimport pytest\n\nfrom agentcube.models.pack_models import MetadataOptions\n\n\nclass TestMetadataOptions:\n    \"\"\"Tests for MetadataOptions dataclass.\"\"\"\n\n    def test_default_values(self) -> None:\n        \"\"\"Test that default values are set correctly.\"\"\"\n        options = MetadataOptions()\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/tests/test_pack_models.py","time":{"start":1775901227113,"end":1775901227165}}}}
{"type":"tool_use","timestamp":1775901227170,"sessionID":"ses_2840b139dffeO4wT0g0XOLmHO7","part":{"id":"prt_d7bf62b8f001A0uuWdi2uwGMTK","messageID":"msg_d7bf5f9550017XpPOhashG7qAm","sessionID":"ses_2840b139dffeO4wT0g0XOLmHO7","type":"tool","tool":"read","callID":"toolu_functions.read:24","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/tests/test_k8s_provider.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/tests/test_k8s_provider.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Tests for k8s_provider module.\n2: \n3: This module contains comprehensive unit tests for:\n4: - KubernetesProvider class\n5: \"\"\"\n6: \n7: import tempfile\n8: from pathlib import Path\n9: from typing import Any, Dict\n10: from unittest.mock import MagicMock, Mock, patch\n11: \n12: import pytest\n13: \n14: \n15: class TestKubernetesProvider:\n16:     \"\"\"Tests for KubernetesProvider class.\"\"\"\n17: \n18:     def test_init_default(self) -> None:\n19:         \"\"\"Test default initialization.\"\"\"\n20:         from agentcube.services.k8s_provider import KubernetesProvider\n21: \n22:         provider = KubernetesProvider()\n23: \n24:         assert provider.namespace == \"default\"\n25:         assert provider.verbose is False\n26:         assert provider._k8s_client is None\n27:         assert provider._apps_v1 is None\n28:         assert provider._core_v1 is None\n29: \n30:     def test_init_with_namespace(self) -> None:\n31:         \"\"\"Test initialization with custom namespace.\"\"\"\n32:         from agentcube.services.k8s_provider import KubernetesProvider\n33: \n34:         provider = KubernetesProvider(namespace=\"custom-ns\")\n35: \n36:         assert provider.namespace == \"custom-ns\"\n37: \n38:     def test_init_verbose(self) -> None:\n39:         \"\"\"Test initialization with verbose mode.\"\"\"\n40:         from agentcube.services.k8s_provider import KubernetesProvider\n41: \n42:         provider = KubernetesProvider(verbose=True)\n43: \n44:         assert provider.verbose is True\n45: \n46:     def test_get_k8s_client_import_error(self) -> None:\n47:         \"\"\"Test that import error raises RuntimeError.\"\"\"\n48:         from agentcube.services.k8s_provider import KubernetesProvider\n49: \n50:         provider = KubernetesProvider()\n51: \n52:         with patch.dict(\"sys.modules\", {\"kubernetes\": None}):\n53:             with patch(\n54:                 \"builtins.__import__\", side_effect=ImportError(\"No module named 'kubernetes'\")\n55:             ):\n56:                 with pytest.raises(RuntimeError) as exc_info:\n57:                     provider._get_k8s_client()\n58: \n59:                 assert \"Kubernetes client library not installed\" in str(exc_info.value)\n60: \n61:     @patch(\"kubernetes.client\")\n62:     @patch(\"kubernetes.config\")\n63:     def test_get_k8s_client_load_kubeconfig(self, mock_config: Mock, mock_client: Mock) -> None:\n64:         \"\"\"Test loading kubeconfig.\"\"\"\n65:         from agentcube.services.k8s_provider import KubernetesProvider\n66: \n67:         provider = KubernetesProvider()\n68: \n69:         # Mock config loading\n70:         mock_config.load_kube_config.return_value = None\n71:         mock_config.load_incluster_config.side_effect = Exception(\"Not in cluster\")\n72: \n73:         client = provider._get_k8s_client()\n74: \n75:         assert client is not None\n76:         assert provider._apps_v1 is not None\n77:         assert provider._core_v1 is not None\n78:         mock_config.load_kube_config.assert_called_once()\n79: \n80:     @patch(\"kubernetes.client\")\n81:     @patch(\"kubernetes.config\")\n82:     def test_get_k8s_client_load_incluster(self, mock_config: Mock, mock_client: Mock) -> None:\n83:         \"\"\"Test fallback to in-cluster config.\"\"\"\n84:         from agentcube.services.k8s_provider import KubernetesProvider\n85: \n86:         provider = KubernetesProvider()\n87: \n88:         # Mock kubeconfig failure, in-cluster success\n89:         mock_config.load_kube_config.side_effect = Exception(\"No kubeconfig\")\n90:         mock_config.load_incluster_config.return_value = None\n91: \n92:         client = provider._get_k8s_client()\n93: \n94:         assert client is not None\n95:         mock_config.load_kube_config.assert_called_once()\n96:         mock_config.load_incluster_config.assert_called_once()\n97: \n98:     @patch(\"kubernetes.client\")\n99:     @patch(\"kubernetes.config\")\n100:     def test_get_k8s_client_both_fail(self, mock_config: Mock, mock_client: Mock) -> None:\n101:         \"\"\"Test that failure to load any config raises RuntimeError.\"\"\"\n102:         from agentcube.services.k8s_provider import KubernetesProvider\n103: \n104:         provider = KubernetesProvider()\n105: \n106:         # Mock both config loading methods failing\n107:         mock_config.load_kube_config.side_effect = Exception(\"No kubeconfig\")\n108:         mock_config.load_incluster_config.side_effect = Exception(\"Not in cluster\")\n109: \n110:         with pytest.raises(RuntimeError) as exc_info:\n111:             provider._get_k8s_client()\n112: \n113:         assert \"Failed to load Kubernetes configuration\" in str(exc_info.value)\n114: \n115:     @patch(\"kubernetes.client\")\n116:     @patch(\"kubernetes.config\")\n117:     def test_get_k8s_client_cached(self, mock_config: Mock, mock_client: Mock) -> None:\n118:         \"\"\"Test that client is cached and not recreated.\"\"\"\n119:         from agentcube.services.k8s_provider import KubernetesProvider\n120: \n121:         provider = KubernetesProvider()\n122: \n123:         mock_config.load_kube_config.return_value = None\n124: \n125:         # First call\n126:         client1 = provider._get_k8s_client()\n127:         # Second call should return cached client\n128:         client2 = provider._get_k8s_client()\n129: \n130:         assert client1 is client2\n131:         # Config should only be loaded once\n132:         mock_config.load_kube_config.assert_called_once()\n133: \n134:     @patch(\"kubernetes.client\")\n135:     @patch(\"kubernetes.config\")\n136:     def test_ensure_namespace_exists(self, mock_config: Mock, mock_client: Mock) -> None:\n137:         \"\"\"Test namespace exists - no creation needed.\"\"\"\n138:         from agentcube.services.k8s_provider import KubernetesProvider\n139: \n140:         provider = KubernetesProvider(namespace=\"test-ns\")\n141: \n142:         mock_config.load_kube_config.return_value = None\n143: \n144:         # Mock CoreV1Api\n145:         mock_core_v1 = MagicMock()\n146:         mock_client.CoreV1Api.return_value = mock_core_v1\n147: \n148:         # Mock namespace exists\n149:         mock_core_v1.read_namespace.return_value = MagicMock()\n150: \n151:         provider._ensure_namespace()\n152: \n153:         mock_core_v1.read_namespace.assert_called_once_with(\"test-ns\")\n154:         mock_core_v1.create_namespace.assert_not_called()\n155: \n156:     @patch(\"kubernetes.client\")\n157:     @patch(\"kubernetes.config\")\n158:     def test_ensure_namespace_create(self, mock_config: Mock, mock_client: Mock) -> None:\n159:         \"\"\"Test namespace creation when it doesn't exist.\"\"\"\n160:         from agentcube.services.k8s_provider import KubernetesProvider\n161: \n162:         provider = KubernetesProvider(namespace=\"test-ns\")\n163: \n164:         mock_config.load_kube_config.return_value = None\n165: \n166:         # Mock CoreV1Api\n167:         mock_core_v1 = MagicMock()\n168:         mock_client.CoreV1Api.return_value = mock_core_v1\n169: \n170:         # Mock namespace doesn't exist\n171:         from kubernetes.client.exceptions import NotFoundException\n172: \n173:         mock_core_v1.read_namespace.side_effect = NotFoundException()\n174: \n175:         provider._ensure_namespace()\n176: \n177:         mock_core_v1.read_namespace.assert_called_once_with(\"test-ns\")\n178:         mock_core_v1.create_namespace.assert_called_once()\n179: \n180:     @patch(\"kubernetes.client\")\n181:     @patch(\"kubernetes.config\")\n182:     def test_deploy_agent_invalid_node_port(self, mock_config: Mock, mock_client: Mock) -> None:\n183:         \"\"\"Test that invalid node_port raises ValueError.\"\"\"\n184:         from agentcube.services.k8s_provider import KubernetesProvider\n185: \n186:         provider = KubernetesProvider()\n187: \n188:         with pytest.raises(ValueError) as exc_info:\n189:             provider.deploy_agent(\n190:                 agent_name=\"test-agent\",\n191:                 image_url=\"nginx:latest\",\n192:                 port=8080,\n193:                 node_port=1000,  # Invalid: below 30000\n194:             )\n195: \n196:         assert \"NodePort must be in range 30000-32767\" in str(exc_info.value)\n197: \n198:     @patch(\"kubernetes.client\")\n199:     @patch(\"kubernetes.config\")\n200:     def test_deploy_agent_node_port_too_high(self, mock_config: Mock, mock_client: Mock) -> None:\n201:         \"\"\"Test that node_port above range raises ValueError.\"\"\"\n202:         from agentcube.services.k8s_provider import KubernetesProvider\n203: \n204:         provider = KubernetesProvider()\n205: \n206:         with pytest.raises(ValueError) as exc_info:\n207:             provider.deploy_agent(\n208:                 agent_name=\"test-agent\",\n209:                 image_url=\"nginx:latest\",\n210:                 port=8080,\n211:                 node_port=40000,  # Invalid: above 32767\n212:             )\n213: \n214:         assert \"NodePort must be in range 30000-32767\" in str(exc_info.value)\n215: \n216:     @patch(\"kubernetes.client\")\n217:     @patch(\"kubernetes.config\")\n218:     def test_deploy_agent_valid_node_port(self, mock_config: Mock, mock_client: Mock) -> None:\n219:         \"\"\"Test valid node_port is accepted.\"\"\"\n220:         from agentcube.services.k8s_provider import KubernetesProvider\n221: \n222:         provider = KubernetesProvider()\n223: \n224:         mock_config.load_kube_config.return_value = None\n225: \n226:         # Mock deployment and service creation\n227:         mock_apps_v1 = MagicMock()\n228:         mock_core_v1 = MagicMock()\n229:         mock_client.AppsV1Api.return_value = mock_apps_v1\n230:         mock_client.CoreV1Api.return_value = mock_core_v1\n231: \n232:         # Mock namespace exists\n233:         mock_core_v1.read_namespace.return_value = MagicMock()\n234: \n235:         # Mock create deployment (NotFoundException means create new)\n236:         from kubernetes.client.exceptions import NotFoundException\n237: \n238:         mock_apps_v1.read_namespaced_deployment.side_effect = NotFoundException()\n239:         mock_apps_v1.create_namespaced_deployment.return_value = MagicMock()\n240: \n241:         # Mock create service\n242:         mock_core_v1.read_namespaced_service.side_effect = NotFoundException()\n243:         mock_service_result = MagicMock()\n244:         mock_service_result.spec.ports = [MagicMock()]\n245:         mock_service_result.spec.ports[0].node_port = 30080\n246:         mock_core_v1.create_namespaced_service.return_value = mock_service_result\n247: \n248:         result = provider.deploy_agent(\n249:             agent_name=\"test-agent\",\n250:             image_url=\"nginx:latest\",\n251:             port=8080,\n252:             node_port=30080,\n253:             replicas=2,\n254:         )\n255: \n256:         assert result[\"deployment_name\"] == \"test-agent\"\n257:         assert result[\"service_name\"] == \"test-agent\"\n258:         assert result[\"node_port\"] == 30080\n259:         assert result[\"replicas\"] == 2\n260:         assert result[\"status\"] == \"deployed\"\n261:         assert \"service_url\" in result\n262: \n263:     @patch(\"kubernetes.client\")\n264:     @patch(\"kubernetes.config\")\n