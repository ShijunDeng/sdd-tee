t that missing entrypoint raises ValidationError.\"\"\"\n37:         with pytest.raises(ValidationError) as exc_info:\n38:             AgentMetadata(agent_name=\"test-agent\")\n39:         assert \"entrypoint\" in str(exc_info.value)\n40: \n41:     def test_default_values(self) -> None:\n42:         \"\"\"Test that default values are applied correctly.\"\"\"\n43:         metadata = AgentMetadata(agent_name=\"test-agent\", entrypoint=\"python main.py\")\n44: \n45:         assert metadata.language == \"python\"\n46:         assert metadata.port == 8080\n47:         assert metadata.build_mode == \"local\"\n48:         assert metadata.requirements_file == \"requirements.txt\"\n49:         assert metadata.registry_url == \"\"\n50:         assert metadata.registry_username == \"\"\n51:         assert metadata.registry_password == \"\"\n52:         assert metadata.description is None\n53:         assert metadata.version is None\n54:         assert metadata.region is None\n55: \n56:     def test_language_validation_valid_values(self) -> None:\n57:         \"\"\"Test that valid language values are accepted.\"\"\"\n58:         # Lowercase\n59:         metadata = AgentMetadata(agent_name=\"test\", entrypoint=\"main.py\", language=\"python\")\n60:         assert metadata.language == \"python\"\n61: \n62:         metadata = AgentMetadata(agent_name=\"test\", entrypoint=\"main.py\", language=\"java\")\n63:         assert metadata.language == \"java\"\n64: \n65:     def test_language_validation_case_insensitive(self) -> None:\n66:         \"\"\"Test that language is normalized to lowercase.\"\"\"\n67:         metadata = AgentMetadata(agent_name=\"test\", entrypoint=\"main.py\", language=\"PYTHON\")\n68:         assert metadata.language == \"python\"\n69: \n70:         metadata = AgentMetadata(agent_name=\"test\", entrypoint=\"main.py\", language=\"Python\")\n71:         assert metadata.language == \"python\"\n72: \n73:         metadata = AgentMetadata(agent_name=\"test\", entrypoint=\"main.py\", language=\"JAVA\")\n74:         assert metadata.language == \"java\"\n75: \n76:         metadata = AgentMetadata(agent_name=\"test\", entrypoint=\"main.py\", language=\"Java\")\n77:         assert metadata.language == \"java\"\n78: \n79:     def test_language_validation_invalid(self) -> None:\n80:         \"\"\"Test that invalid language values raise ValidationError.\"\"\"\n81:         with pytest.raises(ValidationError) as exc_info:\n82:             AgentMetadata(agent_name=\"test\", entrypoint=\"main.py\", language=\"ruby\")\n83:         assert \"Unsupported language\" in str(exc_info.value)\n84: \n85:         with pytest.raises(ValidationError) as exc_info:\n86:             AgentMetadata(agent_name=\"test\", entrypoint=\"main.py\", language=\"go\")\n87:         assert \"Unsupported language\" in str(exc_info.value)\n88: \n89:     def test_build_mode_validation_valid(self) -> None:\n90:         \"\"\"Test that valid build_mode values are accepted.\"\"\"\n91:         metadata = AgentMetadata(agent_name=\"test\", entrypoint=\"main.py\", build_mode=\"local\")\n92:         assert metadata.build_mode == \"local\"\n93: \n94:         metadata = AgentMetadata(agent_name=\"test\", entrypoint=\"main.py\", build_mode=\"cloud\")\n95:         assert metadata.build_mode == \"cloud\"\n96: \n97:     def test_build_mode_validation_case_insensitive(self) -> None:\n98:         \"\"\"Test that build_mode is normalized to lowercase.\"\"\"\n99:         metadata = AgentMetadata(agent_name=\"test\", entrypoint=\"main.py\", build_mode=\"LOCAL\")\n100:         assert metadata.build_mode == \"local\"\n101: \n102:         metadata = AgentMetadata(agent_name=\"test\", entrypoint=\"main.py\", build_mode=\"Cloud\")\n103:         assert metadata.build_mode == \"cloud\"\n104: \n105:     def test_build_mode_validation_invalid(self) -> None:\n106:         \"\"\"Test that invalid build_mode values raise ValidationError.\"\"\"\n107:         with pytest.raises(ValidationError) as exc_info:\n108:             AgentMetadata(agent_name=\"test\", entrypoint=\"main.py\", build_mode=\"hybrid\")\n109:         assert \"Unsupported build_mode\" in str(exc_info.value)\n110: \n111:     def test_port_validation_valid(self) -> None:\n112:         \"\"\"Test that valid port values are accepted.\"\"\"\n113:         # Boundary values\n114:         metadata = AgentMetadata(agent_name=\"test\", entrypoint=\"main.py\", port=1)\n115:         assert metadata.port == 1\n116: \n117:         metadata = AgentMetadata(agent_name=\"test\", entrypoint=\"main.py\", port=65535)\n118:         assert metadata.port == 65535\n119: \n120:         # Common ports\n121:         metadata = AgentMetadata(agent_name=\"test\", entrypoint=\"main.py\", port=80)\n122:         assert metadata.port == 80\n123: \n124:         metadata = AgentMetadata(agent_name=\"test\", entrypoint=\"main.py\", port=8080)\n125:         assert metadata.port == 8080\n126: \n127:         metadata = AgentMetadata(agent_name=\"test\", entrypoint=\"main.py\", port=443)\n128:         assert metadata.port == 443\n129: \n130:     def test_port_validation_below_range(self) -> None:\n131:         \"\"\"Test that port < 1 raises ValidationError.\"\"\"\n132:         with pytest.raises(ValidationError) as exc_info:\n133:             AgentMetadata(agent_name=\"test\", entrypoint=\"main.py\", port=0)\n134:         assert \"Invalid port\" in str(exc_info.value)\n135: \n136:         with pytest.raises(ValidationError) as exc_info:\n137:             AgentMetadata(agent_name=\"test\", entrypoint=\"main.py\", port=-1)\n138:         assert \"Invalid port\" in str(exc_info.value)\n139: \n140:     def test_port_validation_above_range(self) -> None:\n141:         \"\"\"Test that port > 65535 raises ValidationError.\"\"\"\n142:         with pytest.raises(ValidationError) as exc_info:\n143:             AgentMetadata(agent_name=\"test\", entrypoint=\"main.py\", port=65536)\n144:         assert \"Invalid port\" in str(exc_info.value)\n145: \n146:         with pytest.raises(ValidationError) as exc_info:\n147:             AgentMetadata(agent_name=\"test\", entrypoint=\"main.py\", port=99999)\n148:         assert \"Invalid port\" in str(exc_info.value)\n149: \n150:     def test_optional_fields(self) -> None:\n151:         \"\"\"Test that optional fields can be set and retrieved.\"\"\"\n152:         image: Dict[str, Any] = {\"name\": \"my-image\", \"tag\": \"v1.0.0\"}\n153:         auth: Dict[str, Any] = {\"token\": \"secret\"}\n154:         k8s_deployment: Dict[str, Any] = {\"replicas\": 3}\n155: \n156:         metadata = AgentMetadata(\n157:             agent_name=\"test-agent\",\n158:             entrypoint=\"python main.py\",\n159:             description=\"Test description\",\n160:             version=\"1.0.0\",\n161:             region=\"us-west\",\n162:             image=image,\n163:             auth=auth,\n164:             agent_endpoint=\"http://localhost:8080\",\n165:             workload_manager_url=\"http://wm:8080\",\n166:             router_url=\"http://router:8080\",\n167:             readiness_probe_path=\"/health\",\n168:             readiness_probe_port=8080,\n169:             agent_id=\"agent-123\",\n170:             session_id=\"session-456\",\n171:             k8s_deployment=k8s_deployment,\n172:             pack_timestamp=\"2024-01-15T10:30:00Z\",\n173:             dockerfile_generated=True,\n174:         )\n175: \n176:         assert metadata.description == \"Test description\"\n177:         assert metadata.version == \"1.0.0\"\n178:         assert metadata.region == \"us-west\"\n179:         assert metadata.image == image\n180:         assert metadata.auth == auth\n181:         assert metadata.agent_endpoint == \"http://localhost:8080\"\n182:         assert metadata.workload_manager_url == \"http://wm:8080\"\n183:         assert metadata.router_url == \"http://router:8080\"\n184:         assert metadata.readiness_probe_path == \"/health\"\n185:         assert metadata.readiness_probe_port == 8080\n186:         assert metadata.agent_id == \"agent-123\"\n187:         assert metadata.session_id == \"session-456\"\n188:         assert metadata.k8s_deployment == k8s_deployment\n189:         assert metadata.pack_timestamp == \"2024-01-15T10:30:00Z\"\n190:         assert metadata.dockerfile_generated is True\n191: \n192:     def test_model_dump_exclude_none(self) -> None:\n193:         \"\"\"Test model_dump with exclude_none=True.\"\"\"\n194:         metadata = AgentMetadata(\n195:             agent_name=\"test-agent\",\n196:             entrypoint=\"python main.py\",\n197:             description=None,\n198:             version=\"1.0.0\",\n199:         )\n200: \n201:         data = metadata.model_dump(exclude_none=True)\n202: \n203:         # None values should be excluded\n204:         assert \"description\" not in data\n205:         assert \"image\" not in data\n206:         assert \"auth\" not in data\n207: \n208:         # Non-None values should be included\n209:         assert data[\"agent_name\"] == \"test-agent\"\n210:         assert data[\"entrypoint\"] == \"python main.py\"\n211:         assert data[\"version\"] == \"1.0.0\"\n212:         assert data[\"language\"] == \"python\"\n213:         assert data[\"port\"] == 8080\n214:         assert data[\"build_mode\"] == \"local\"\n215: \n216:     def test_model_dump_include_none(self) -> None:\n217:         \"\"\"Test model_dump without exclude_none.\"\"\"\n218:         metadata = AgentMetadata(agent_name=\"test-agent\", entrypoint=\"python main.py\")\n219: \n220:         data = metadata.model_dump()\n221: \n222:         # None values should be included\n223:         assert \"description\" in data\n224:         assert data[\"description\"] is None\n225: \n226:     def test_model_dump_json(self) -> None:\n227:         \"\"\"Test model_dump_json.\"\"\"\n228:         metadata = AgentMetadata(\n229:             agent_name=\"test-agent\",\n230:             entrypoint=\"python main.py\",\n231:             version=\"1.0.0\",\n232:         )\n233: \n234:         json_str = metadata.model_dump_json()\n235: \n236:         assert \"test-agent\" in json_str\n237:         assert \"python main.py\" in json_str\n238:         assert \"1.0.0\" in json_str\n239: \n240:     def test_all_fields(self) -> None:\n241:         \"\"\"Test that all 20+ fields are present and work correctly.\"\"\"\n242:         metadata = AgentMetadata(\n243:             agent_name=\"full-test-agent\",\n244:             entrypoint=\"python app.py\",\n245:             language=\"java\",\n246:             port=9090,\n247:             build_mode=\"cloud\",\n248:             description=\"Full test\",\n249:             version=\"2.0.0\",\n250:             region=\"eu-central\",\n251:             requirements_file=\"requirements-dev.txt\",\n252:             registry_url=\"registry.example.com\",\n253:             registry_username=\"user\",\n254:             registry_password=\"pass\",\n255:             agent_endpoint=\"http://ep:8080\",\n256:             workload_manager_url=\"http://wm:9090\",\n257:             router_url=\"http://router:9090\",\n258:             readiness_probe_path=\"/ready\",\n259:             readiness_probe_port=9090,\n260:             agent_id=\"id-123\",\n261:             session_id=\"sess-456\",\n262:             k8s_deployment={\"ns\": \"default\"},\n263:             image={\"repo\": \"img\"},\n264:             auth={\"key\": \"val\"},\n265:             pack_timestamp=\"2024-01-01\",\n266:             dockerfile_generated=False,\n267:         )\n268: \n269:         # Verify all fields\n270:         assert metadata.agent_name == \"full-test-agent\"\n271:         assert metadata.entrypoint == \"python app.py\"\n272:         assert metadata.language == \"java\"\n273:         assert metadata.port == 9090\n274:         assert metadata.build_mode == \"cloud\"\n275:         assert metadata.description == \"Full test\"\n276:         assert metadata.version == \"2.0.0\"\n277:         assert metadata.region == \"eu-central\"\n278:         assert metadata.requirements_file == \"requirements-dev.txt\"\n279:         assert metadata.registry_url == \"registry.example.com\"\n280:         assert metadata.registry_username == \"user\"\n281:         assert metadata.registry_password == \"pass\"\n282:         assert metadata.agent_endpoint == \"http://ep:8080\"\n283:         assert metadata.workload_manager_url == \"http://wm:9090\"\n284:         assert metadata.router_url == \"http://router:9090\"\n285:         assert metadata.readiness_probe_path == \"/ready\"\n286:         assert metadata.readiness_probe_port == 9090\n287:         assert metadata.agent_id == \"id-123\"\n288:         assert metadata.session_id == \"sess-456\"\n289:         assert metadata.k8s_deployment == {\"ns\": \"default\"}\n290:         assert metadata.image == {\"repo\": \"img\"}\n291:         assert metadata.auth == {\"key\": \"val\"}\n292:         assert metadata.pack_timestamp == \"2024-01-01\"\n293:         assert metadata.dockerfile_generated is False\n294: \n295: \n296: class TestMetadataService:\n297:     \"\"\"Tests for MetadataService class.\"\"\"\n298: \n299:     def test_init(self) -> None:\n300:         \"\"\"Test MetadataService initialization.\"\"\"\n301:         service = MetadataService()\n302:         assert service.verbose is False\n303: \n304:         service_verbose = MetadataService(verbose=True)\n305:         assert service_verbose.verbose is True\n306: \n307:     def test_load_metadata_primary_file(self) -> None:\n308:         \"\"\"Test loading from primary file (agent_metadata.yaml).\"\"\"\n309:         with tempfile.TemporaryDirectory() as tmpdir:\n310:             workspace = Path(tmpdir)\n311:             metadata_file = workspace / \"agent_metadata.yaml\"\n312: \n313:             data = {\n314:                 \"agent_name\": \"test-agent\",\n315:                 \"entrypoint\": \"python main.py\",\n316:                 \"language\": \"python\",\n317:                 \"port\": 8080,\n318:             }\n319:             metadata_file.write_text(yaml.dump(data))\n320: \n321:             service = MetadataService()\n322:             metadata = service.load_metadata(workspace)\n323: \n324:             assert metadata.agent_name == \"test-agent\"\n325:             assert metadata.entrypoint == \"python main.py\"\n326:             assert metadata.language == \"python\"\n327:             assert metadata.port == 8080\n328: \n329:     def test_load_metadata_fallback_agent_yaml(self) -> None:\n330:         \"\"\"Test loading from first fallback (agent.yaml).\"\"\"\n331:         with tempfile.TemporaryDirectory() as tmpdir:\n332:             workspace = Path(tmpdir)\n333:             metadata_file = workspace / \"agent.yaml\"\n334: \n335:             data = {\n336:                 \"agent_name\": \"fallback-agent\",\n337:                 \"entrypoint\": \"java -jar app.jar\",\n338:                 \"language\": \"java\",\n339:             }\n340:             metadata_file.write_text(yaml.dump(data))\n341: \n342:             service = MetadataService()\n343:             metadata = service.load_metadata(workspace)\n344: \n345:             assert metadata.agent_name == \"fallback-agent\"\n346:             assert metadata.entrypoint == \"java -jar app.jar\"\n347:             assert metadata.language == \"java\"\n348: \n349:     def test_load_metadata_fallback_metadata_yaml(self) -> None:\n350:         \"\"\"Test loading from second fallback (metadata.yaml).\"\"\"\n351:         with tempfile.TemporaryDirectory() as tmpdir:\n352:             workspace = Path(tmpdir)\n353:             metadata_file = workspace / \"metadata.yaml\"\n354: \n355:             data = {\n356:                 \"agent_name\": \"metadata-agent\",\n357:                 \"entrypoint\": \"python app.py\",\n358:             }\n359:             metadata_file.write_text(yaml.dump(data))\n360: \n361:             service = MetadataService()\n362:             metadata = service.load_metadata(workspace)\n363: \n364:             assert metadata.agent_name == \"metadata-agent\"\n365:             assert metadata.entrypoint == \"python app.py\"\n366: \n367:     def test_load_metadata_precedence(self) -> None:\n368:         \"\"\"Test that primary file takes precedence over fallbacks.\"\"\"\n369:         with tempfile.TemporaryDirectory() as tmpdir:\n370:             workspace = Path(tmpdir)\n371: \n372:             # Create all three files\n373:             (workspace / \"agent_metadata.yaml\").write_text(\n374:                 yaml.dump({\"agent_name\": \"primary\", \"entrypoint\": \"python primary.py\"})\n375:             )\n376:             (workspace / \"agent.yaml\").write_text(\n377:                 yaml.dump({\"agent_name\": \"fallback1\", \"entrypoint\": \"python fallback1.py\"})\n378:             )\n379:             (workspace / \"metadata.yaml\").write_text(\n380:                 yaml.dump({\"agent_name\": \"fallback2\", \"entrypoint\": \"python fallback2.py\"})\n381:             )\n382: \n383:             service = MetadataService()\n384:             metadata = service.load_metadata(workspace)\n385: \n386:             assert metadata.agent_name == \"primary\"\n387: \n388:     def test_load_metadata_file_not_found(self) -> None:\n389:         \"\"\"Test that FileNotFoundError is raised when no metadata file exists.\"\"\"\n390:         with tempfile.TemporaryDirectory() as tmpdir:\n391:             workspace = Path(tmpdir)\n392: \n393:             service = MetadataService()\n394:             with pytest.raises(FileNotFoundError) as exc_info:\n395:                 service.load_metadata(workspace)\n396: \n397:             assert \"No metadata file found\" in str(exc_info.value)\n398:             assert str(workspace) in str(exc_info.value)\n399: \n400:     def test_load_metadata_invalid_yaml(self) -> None:\n401:         \"\"\"Test that invalid YAML raises YAMLError.\"\"\"\n402:         with tempfile.TemporaryDirectory() as tmpdir:\n403:             workspace = Path(tmpdir)\n404:             metadata_file = workspace / \"agent_metadata.yaml\"\n405:             metadata_file.write_text(\"invalid: yaml: content: [\")\n406: \n407:             service = MetadataService()\n408:             with pytest.raises(yaml.YAMLError):\n409:                 service.load_metadata(workspace)\n410: \n411:     def test_load_metadata_validation_error(self) -> None:\n412:         \"\"\"Test that invalid schema raises ValidationError.\"\"\"\n413:         with tempfile.TemporaryDirectory() as tmpdir:\n414:             workspace = Path(tmpdir)\n415:             metadata_file = workspace / \"agent_metadata.yaml\"\n416: \n417:             data = {\n418:                 \"agent_name\": \"test\",\n419:                 \"entrypoint\": \"main.py\",\n420:                 \"port\": \"not-a-number\",  # Invalid type\n421:             }\n422:             metadata_file.write_text(yaml.dump(data))\n423: \n424:             service = MetadataService()\n425:             with pytest.raises(ValidationError):\n426:                 service.load_metadata(workspace)\n427: \n428:     def test_save_metadata(self) -> None:\n429:         \"\"\"Test saving metadata to file.\"\"\"\n430:         with tempfile.TemporaryDirectory() as tmpdir:\n431:             workspace = Path(tmpdir)\n432: \n433:             metadata = AgentMetadata(\n434:                 agent_name=\"save-test\",\n435:                 entrypoint=\"python main.py\",\n436:                 description=\"Test description\",\n437:                 version=\"1.0.0\",\n438:             )\n439: \n440:             service = MetadataService()\n441:             service.save_metadata(workspace, metadata)\n442: \n443:             # Verify file was created\n444:             saved_file = workspace / \"agent_metadata.yaml\"\n445:             assert saved_file.exists()\n446: \n447:             # Verify content\n448:             saved_data = yaml.safe_load(saved_file.read_text())\n449:             assert saved_data[\"agent_name\"] == \"save-test\"\n450:             assert saved_data[\"entrypoint\"] == \"python main.py\"\n451:             assert saved_data[\"description\"] == \"Test description\"\n452:             assert saved_data[\"version\"] == \"1.0.0\"\n453: \n454:     def test_save_metadata_excludes_none(self) -> None:\n455:         \"\"\"Test that None values are excluded when saving.\"\"\"\n456:         with tempfile.TemporaryDirectory() as tmpdir:\n457:             workspace = Path(tmpdir)\n458: \n459:             metadata = AgentMetadata(\n460:                 agent_name=\"none-test\",\n461:                 entrypoint=\"python main.py\",\n462:                 description=None,\n463:                 version=\"1.0.0\",\n464:             )\n465: \n466:             service = MetadataService()\n467:             service.save_metadata(workspace, metadata)\n468: \n469:             saved_file = workspace / \"agent_metadata.yaml\"\n470:             content = saved_file.read_text()\n471: \n472:             # None values should not be in the file\n473:             assert \"description:\" not in content or \"description: null\" not in content\n474: \n475:             # Non-None values should be present\n476:             assert \"agent_name: none-test\" in content\n477:             assert \"version: 1.0.0\" in content\n478: \n479:     def test_save_metadata_yaml_formatting(self) -> None:\n480:         \"\"\"Test that YAML is formatted correctly.\"\"\"\n481:         with tempfile.TemporaryDirectory() as tmpdir:\n482:             workspace = Path(tmpdir)\n483: \n484:             metadata = AgentMetadata(\n485:                 agent_name=\"format-test\",\n486:                 entrypoint=\"python main.py\",\n487:                 language=\"python\",\n488:                 port=8080,\n489:             )\n490: \n491:             service = MetadataService()\n492:             service.save_metadata(workspace, metadata)\n493: \n494:             content = (workspace / \"agent_metadata.yaml\").read_text()\n495: \n496:             # Should use flow style False (block style) - key: value format\n497:             assert \": \" in content\n498: \n499:             # Should not use curly braces (flow style)\n500:             assert \"{\" not in content\n501: \n502:     def test_update_metadata(self) -> None:\n503:         \"\"\"Test updating metadata with partial updates.\"\"\"\n504:         with tempfile.TemporaryDirectory() as tmpdir:\n505:             workspace = Path(tmpdir)\n506: \n507:             # Create initial metadata\n508:             initial = AgentMetadata(\n509:                 agent_name=\"update-test\",\n510:                 entrypoint=\"python main.py\",\n511:                 version=\"1.0.0\",\n512:             )\n513:             service = MetadataService()\n514:             service.save_metadata(workspace, initial)\n515: \n516:             # Update\n517:             updates = {\"version\": \"2.0.0\", \"description\": \"Updated description\"}\n518:             updated = service.update_metadata(workspace, updates)\n519: \n520:             assert updated.version == \"2.0.0\"\n521:             assert updated.description == \"Updated description\"\n522:             assert updated.agent_name == \"update-test\"  # Unchanged\n523: \n524:             # Verify file was updated\n525:             reloaded = service.load_metadata(workspace)\n526:             assert reloaded.version == \"2.0.0\"\n527:             assert reloaded.description == \"Updated description\"\n528: \n529:     def test_update_metadata_empty_dict(self) -> None:\n530:         \"\"\"Test update with empty dict reloads and re-saves.\"\"\"\n531:         with tempfile.TemporaryDirectory() as tmpdir:\n532:             workspace = Path(tmpdir)\n533: \n534:             initial = AgentMetadata(\n535:                 agent_name=\"empty-update-test\",\n536:                 entrypoint=\"python main.py\",\n537:                 version=\"1.0.0\",\n538:             )\