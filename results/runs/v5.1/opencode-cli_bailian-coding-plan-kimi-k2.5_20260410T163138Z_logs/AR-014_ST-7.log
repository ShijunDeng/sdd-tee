{"type":"tool_use","timestamp":1775870783896,"sessionID":"ses_285da9c5cffeHuoQt8KD5hVVRp","part":{"id":"prt_d7a25acec0015TGp0AaBerr18o","messageID":"msg_d7a25a06f00132CiLcpXOFFRpu","sessionID":"ses_285da9c5cffeHuoQt8KD5hVVRp","type":"tool","tool":"read","callID":"toolu_functions.read:7","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/store/valkey.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/store/valkey.go</path>\n<type>file</type>\n<content>\n1: /*\n2: Copyright 2026 The Volcano Authors.\n3: \n4: Licensed under the Apache License, Version 2.0 (the \"License\");\n5: you may not use this file except in compliance with the License.\n6: You may obtain a copy of the License at\n7: \n8:     http://www.apache.org/licenses/LICENSE-2.0\n9: \n10: Unless required by applicable law or agreed to in writing, software\n11: distributed under the License is distributed on an \"AS IS\" BASIS,\n12: WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n13: See the License for the specific language governing permissions and\n14: limitations under the License.\n15: */\n16: \n17: package store\n18: \n19: import (\n20: \t\"context\"\n21: \t\"encoding/json\"\n22: \t\"fmt\"\n23: \t\"time\"\n24: \n25: \t\"github.com/valkey-io/valkey-go\"\n26: \t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n27: )\n28: \n29: // valkeyStore implements Store interface using Valkey backend.\n30: type valkeyStore struct {\n31: \tcli                  valkey.Client\n32: \tsessionPrefix        string\n33: \texpiryIndexKey       string\n34: \tlastActivityIndexKey string\n35: }\n36: \n37: // newValkeyStore creates a new Valkey-backed Store instance.\n38: func newValkeyStore() (Store, error) {\n39: \topts, err := makeValkeyOptions()\n40: \tif err != nil {\n41: \t\treturn nil, err\n42: \t}\n43: \n44: \tclientOption := valkey.ClientOption{\n45: \t\tInitAddress:       opts.InitAddress,\n46: \t\tDisableCache:      opts.DisableCache,\n47: \t\tForceSingleClient: opts.ForceSingleClient,\n48: \t}\n49: \n50: \t// Configure password if provided\n51: \tif opts.Password != \"\" {\n52: \t\tclientOption.Password = opts.Password\n53: \t}\n54: \n55: \tclient, err := valkey.NewClient(clientOption)\n56: \tif err != nil {\n57: \t\treturn nil, fmt.Errorf(\"failed to create valkey client: %w\", err)\n58: \t}\n59: \n60: \treturn &valkeyStore{\n61: \t\tcli:                  client,\n62: \t\tsessionPrefix:        sessionPrefix,\n63: \t\texpiryIndexKey:       expiryIndexKey,\n64: \t\tlastActivityIndexKey: lastActivityIndexKey,\n65: \t}, nil\n66: }\n67: \n68: // sessionKey constructs the Valkey key for a session.\n69: func (s *valkeyStore) sessionKey(sessionID string) string {\n70: \treturn s.sessionPrefix + sessionID\n71: }\n72: \n73: // Ping verifies connectivity to the Valkey backend.\n74: // Returns nil on success, error on failure.\n75: func (s *valkeyStore) Ping(ctx context.Context) error {\n76: \tresult := s.cli.Do(ctx, s.cli.B().Ping().Build())\n77: \tif result.Error() != nil {\n78: \t\treturn result.Error()\n79: \t}\n80: \n81: \tpong, err := result.ToString()\n82: \tif err != nil {\n83: \t\treturn fmt.Errorf(\"failed to parse ping response: %w\", err)\n84: \t}\n85: \tif pong != \"PONG\" {\n86: \t\treturn fmt.Errorf(\"unexpected ping response: %s\", pong)\n87: \t}\n88: \treturn nil\n89: }\n90: \n91: // GetSandboxBySessionID retrieves sandbox info by session ID.\n92: // Returns ErrNotFound if the session does not exist.\n93: func (s *valkeyStore) GetSandboxBySessionID(ctx context.Context, sessionID string) (*types.SandboxInfo, error) {\n94: \tif sessionID == \"\" {\n95: \t\treturn nil, fmt.Errorf(\"sessionID is empty\")\n96: \t}\n97: \n98: \tkey := s.sessionKey(sessionID)\n99: \tresult := s.cli.Do(ctx, s.cli.B().Get().Key(key).Build())\n100: \tif result.Error() != nil {\n101: \t\tif valkey.IsValkeyNil(result.Error()) {\n102: \t\t\treturn nil, ErrNotFound\n103: \t\t}\n104: \t\treturn nil, result.Error()\n105: \t}\n106: \n107: \tdata, err := result.ToString()\n108: \tif err != nil {\n109: \t\treturn nil, fmt.Errorf(\"failed to get session data: %w\", err)\n110: \t}\n111: \n112: \tvar sandbox types.SandboxInfo\n113: \tif err := json.Unmarshal([]byte(data), &sandbox); err != nil {\n114: \t\treturn nil, fmt.Errorf(\"failed to unmarshal sandbox: %w\", err)\n115: \t}\n116: \n117: \treturn &sandbox, nil\n118: }\n119: \n120: // StoreSandbox creates a new sandbox entry with atomic index updates.\n121: // Validates sandbox is non-nil and has valid ExpiresAt.\n122: // Uses SETNX to prevent overwriting existing keys.\n123: func (s *valkeyStore) StoreSandbox(ctx context.Context, sandbox *types.SandboxInfo) error {\n124: \tif sandbox == nil {\n125: \t\treturn fmt.Errorf(\"sandbox is nil\")\n126: \t}\n127: \tif sandbox.SessionID == \"\" {\n128: \t\treturn fmt.Errorf(\"sessionID is empty\")\n129: \t}\n130: \tif sandbox.ExpiresAt.IsZero() {\n131: \t\treturn fmt.Errorf(\"expiresAt is zero\")\n132: \t}\n133: \n134: \tkey := s.sessionKey(sandbox.SessionID)\n135: \tdata, err := json.Marshal(sandbox)\n136: \tif err != nil {\n137: \t\treturn fmt.Errorf(\"failed to marshal sandbox: %w\", err)\n138: \t}\n139: \n140: \tnow := time.Now().Unix()\n141: \n142: \t// Use DoMulti for atomic operations\n143: \tresults := s.cli.DoMulti(ctx,\n144: \t\ts.cli.B().Set().Key(key).Value(string(data)).Nx().Build(),\n145: \t\ts.cli.B().Zadd().Key(s.expiryIndexKey).ScoreMember().\n146: \t\t\tScoreMember(float64(sandbox.ExpiresAt.Unix()), sandbox.SessionID).Build(),\n147: \t\ts.cli.B().Zadd().Key(s.lastActivityIndexKey).ScoreMember().\n148: \t\t\tScoreMember(float64(now), sandbox.SessionID).Build(),\n149: \t)\n150: \n151: \t// Check for errors in any of the results\n152: \tfor i, r := range results {\n153: \t\tif r.Error() != nil {\n154: \t\t\t// Clean up already executed commands on error (best effort)\n155: \t\t\treturn r.Error()\n156: \t\t}\n157: \n158: \t\t// First command is SET NX - check if it succeeded\n159: \t\tif i == 0 {\n160: \t\t\tsetResult, err := r.ToString()\n161: \t\t\tif err != nil {\n162: \t\t\t\treturn fmt.Errorf(\"session already exists\")\n163: \t\t\t}\n164: \t\t\tif setResult != \"OK\" {\n165: \t\t\t\treturn fmt.Errorf(\"session already exists\")\n166: \t\t\t}\n167: \t\t}\n168: \t}\n169: \n170: \treturn nil\n171: }\n172: \n173: // UpdateSandbox updates an existing sandbox's JSON data.\n174: // Uses SET with XX flag (key must exist).\n175: // Does NOT modify expiry or last-activity indexes.\n176: func (s *valkeyStore) UpdateSandbox(ctx context.Context, sandbox *types.SandboxInfo) error {\n177: \tif sandbox == nil {\n178: \t\treturn fmt.Errorf(\"sandbox is nil\")\n179: \t}\n180: \tif sandbox.SessionID == \"\" {\n181: \t\treturn fmt.Errorf(\"sessionID is empty\")\n182: \t}\n183: \n184: \tkey := s.sessionKey(sandbox.SessionID)\n185: \tdata, err := json.Marshal(sandbox)\n186: \tif err != nil {\n187: \t\treturn fmt.Errorf(\"failed to marshal sandbox: %w\", err)\n188: \t}\n189: \n190: \t// SET with XX flag - only set if key exists\n191: \tresult := s.cli.Do(ctx, s.cli.B().Set().Key(key).Value(string(data)).Xx().Build())\n192: \tif result.Error() != nil {\n193: \t\treturn result.Error()\n194: \t}\n195: \n196: \t// Check if the operation succeeded (XX returns nil/empty if key doesn't exist)\n197: \tstrResult, err := result.ToString()\n198: \tif err != nil {\n199: \t\treturn fmt.Errorf(\"key not exists\")\n200: \t}\n201: \tif strResult != \"OK\" {\n202: \t\treturn fmt.Errorf(\"key not exists\")\n203: \t}\n204: \n205: \treturn nil\n206: }\n207: \n208: // DeleteSandboxBySessionID removes a sandbox and its indexes.\n209: // Uses atomic pipeline: DEL + ZREM expiry + ZREM last_activity.\n210: func (s *valkeyStore) DeleteSandboxBySessionID(ctx context.Context, sessionID string) error {\n211: \tif sessionID == \"\" {\n212: \t\treturn fmt.Errorf(\"sessionID is empty\")\n213: \t}\n214: \n215: \tkey := s.sessionKey(sessionID)\n216: \n217: \t// Use DoMulti for atomic operations\n218: \tresults := s.cli.DoMulti(ctx,\n219: \t\ts.cli.B().Del().Key(key).Build(),\n220: \t\ts.cli.B().Zrem().Key(s.expiryIndexKey).Member(sessionID).Build(),\n221: \t\ts.cli.B().Zrem().Key(s.lastActivityIndexKey).Member(sessionID).Build(),\n222: \t)\n223: \n224: \t// Check for errors\n225: \tfor _, r := range results {\n226: \t\tif r.Error() != nil {\n227: \t\t\treturn r.Error()\n228: \t\t}\n229: \t}\n230: \n231: \treturn nil\n232: }\n233: \n234: // ListExpiredSandboxes returns sessions with ExpiresAt <= before.\n235: // Queries session:expiry ZSET with ZRANGEBYSCORE.\n236: // Returns nil, nil if limit <= 0.\n237: func (s *valkeyStore) ListExpiredSandboxes(ctx context.Context, before time.Time, limit int64) ([]*types.SandboxInfo, error) {\n238: \tif limit <= 0 {\n239: \t\treturn nil, nil\n240: \t}\n241: \n242: \t// Get expired session IDs from the ZSET\n243: \tzrangeResult := s.cli.Do(ctx, s.cli.B().Zrangebyscore().Key(s.expiryIndexKey).\n244: \t\tMin(\"-inf\").Max(fmt.Sprintf(\"%d\", before.Unix())).Limit(0, limit).Build())\n245: \tif zrangeResult.Error() != nil {\n246: \t\treturn nil, zrangeResult.Error()\n247: \t}\n248: \n249: \tarr, err := zrangeResult.ToArray()\n250: \tif err != nil {\n251: \t\treturn nil, fmt.Errorf(\"failed to parse zrange result: %w\", err)\n252: \t}\n253: \n254: \tsessionIDs := make([]string, 0, len(arr))\n255: \tfor _, v := range arr {\n256: \t\tid, err := v.ToString()\n257: \t\tif err != nil {\n258: \t\t\tcontinue\n259: \t\t}\n260: \t\tsessionIDs = append(sessionIDs, id)\n261: \t}\n262: \n263: \treturn s.loadSandboxesBySessionIDs(ctx, sessionIDs)\n264: }\n265: \n266: // ListInactiveSandboxes returns sessions with last activity <= before.\n267: // Queries session:last_activity ZSET with ZRANGEBYSCORE.\n268: // Returns nil, nil if limit <= 0.\n269: func (s *valkeyStore) ListInactiveSandboxes(ctx context.Context, before time.Time, limit int64) ([]*types.SandboxInfo, error) {\n270: \tif limit <= 0 {\n271: \t\treturn nil, nil\n272: \t}\n273: \n274: \t// Get inactive session IDs from the ZSET\n275: \tzrangeResult := s.cli.Do(ctx, s.cli.B().Zrangebyscore().Key(s.lastActivityIndexKey).\n276: \t\tMin(\"-inf\").Max(fmt.Sprintf(\"%d\", before.Unix())).Limit(0, limit).Build())\n277: \tif zrangeResult.Error() != nil {\n278: \t\treturn nil, zrangeResult.Error()\n279: \t}\n280: \n281: \tarr, err := zrangeResult.ToArray()\n282: \tif err != nil {\n283: \t\treturn nil, fmt.Errorf(\"failed to parse zrange result: %w\", err)\n284: \t}\n285: \n286: \tsessionIDs := make([]string, 0, len(arr))\n287: \tfor _, v := range arr {\n288: \t\tid, err := v.ToString()\n289: \t\tif err != nil {\n290: \t\t\tcontinue\n291: \t\t}\n292: \t\tsessionIDs = append(sessionIDs, id)\n293: \t}\n294: \n295: \treturn s.loadSandboxesBySessionIDs(ctx, sessionIDs)\n296: }\n297: \n298: // loadSandboxesBySessionIDs loads sandbox info for the given session IDs.\n299: // Skips entries where the session key is missing (orphaned ZSET entries).\n300: func (s *valkeyStore) loadSandboxesBySessionIDs(ctx context.Context, sessionIDs []string) ([]*types.SandboxInfo, error) {\n301: \tif len(sessionIDs) == 0 {\n302: \t\treturn []*types.SandboxInfo{}, nil\n303: \t}\n304: \n305: \t// Build keys for all session IDs\n306: \tkeys := make([]string, len(sessionIDs))\n307: \tfor i, id := range sessionIDs {\n308: \t\tkeys[i] = s.sessionKey(id)\n309: \t}\n310: \n311: \t// Use MGET to fetch all sessions in one call\n312: \tmgetResult := s.cli.Do(ctx, s.cli.B().Mget().Key(keys...).Build())\n313: \tif mgetResult.Error() != nil {\n314: \t\treturn nil, mgetResult.Error()\n315: \t}\n316: \n317: \tarr, err := mgetResult.ToArray()\n318: \tif err != nil {\n319: \t\treturn nil, fmt.Errorf(\"failed to parse mget result: %w\", err)\n320: \t}\n321: \n322: \t// Parse results, skipping empty entries (orphaned ZSET members)\n323: \tsandboxes := make([]*types.SandboxInfo, 0, len(arr))\n324: \tfor _, v := range arr {\n325: \t\tdata, err := v.ToString()\n326: \t\tif err != nil {\n327: \t\t\t// Nil value or error - skip\n328: \t\t\tcontinue\n329: \t\t}\n330: \n331: \t\tif data == \"\" {\n332: \t\t\t// Orphaned ZSET entry - skip\n333: \t\t\tcontinue\n334: \t\t}\n335: \n336: \t\tvar sandbox types.SandboxInfo\n337: \t\tif err := json.Unmarshal([]byte(data), &sandbox); err != nil {\n338: \t\t\t// Failed to parse - skip this entry but continue\n339: \t\t\tcontinue\n340: \t\t}\n341: \n342: \t\tsandboxes = append(sandboxes, &sandbox)\n343: \t}\n344: \n345: \treturn sandboxes, nil\n346: }\n347: \n348: // UpdateSessionLastActivity updates the last activity timestamp for a session.\n349: // Returns ErrNotFound if session does not exist.\n350: // If at is zero time, uses time.Now().\n351: func (s *valkeyStore) UpdateSessionLastActivity(ctx context.Context, sessionID string, at time.Time) error {\n352: \tif sessionID == \"\" {\n353: \t\treturn fmt.Errorf(\"sessionID is empty\")\n354: \t}\n355: \n356: \t// Verify session exists before updating\n357: \tkey := s.sessionKey(sessionID)\n358: \texistsResult := s.cli.Do(ctx, s.cli.B().Exists().Key(key).Build())\n359: \tif existsResult.Error() != nil {\n360: \t\treturn existsResult.Error()\n361: \t}\n362: \n363: \texists, err := existsResult.ToInt64()\n364: \tif err != nil {\n365: \t\treturn fmt.Errorf(\"failed to check session existence: %w\", err)\n366: \t}\n367: \tif exists == 0 {\n368: \t\treturn ErrNotFound\n369: \t}\n370: \n371: \t// Use current time if at is zero\n372: \tif at.IsZero() {\n373: \t\tat = time.Now()\n374: \t}\n375: \n376: \t// Update the activity index\n377: \tzaddResult := s.cli.Do(ctx, s.cli.B().Zadd().Key(s.lastActivityIndexKey).ScoreMember().\n378: \t\tScoreMember(float64(at.Unix()), sessionID).Build())\n379: \tif zaddResult.Error() != nil {\n380: \t\treturn zaddResult.Error()\n381: \t}\n382: \n383: \treturn nil\n384: }\n385: \n386: // Close closes the Valkey connection.\n387: func (s *valkeyStore) Close() error {\n388: \ts.cli.Close()\n389: \treturn nil\n390: }\n\n(End of file - total 390 lines)\n</content>","metadata":{"preview":"/*\nCopyright 2026 The Volcano Authors.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\npackage store\n\nimport (\n\t\"context\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/store/valkey.go","time":{"start":1775870783856,"end":1775870783894}}}}
