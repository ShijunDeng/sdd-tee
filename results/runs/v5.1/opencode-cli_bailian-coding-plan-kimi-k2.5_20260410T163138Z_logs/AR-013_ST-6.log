{"type":"tool_use","timestamp":1775868295236,"sessionID":"ses_28600cab4ffep6L858aRhkgvHB","part":{"id":"prt_d79ffadc9001aj0W7r8yGI3nfQ","messageID":"msg_d79ff9056001aJriicJkvhIgPU","sessionID":"ses_28600cab4ffep6L858aRhkgvHB","type":"tool","tool":"read","callID":"toolu_functions.read:8","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/store/redis_test.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/store/redis_test.go</path>\n<type>file</type>\n<content>\n1: /*\n2: Copyright 2026 The Volcano Authors.\n3: \n4: Licensed under the Apache License, Version 2.0 (the \"License\");\n5: you may not use this file except in compliance with the License.\n6: You may obtain a copy of the License at\n7: \n8:     http://www.apache.org/licenses/LICENSE-2.0\n9: \n10: Unless required by applicable law or agreed to in writing, software\n11: distributed under the License is distributed on an \"AS IS\" BASIS,\n12: WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n13: See the License for the specific language governing permissions and\n14: limitations under the License.\n15: */\n16: \n17: package store\n18: \n19: import (\n20: \t\"context\"\n21: \t\"encoding/json\"\n22: \t\"fmt\"\n23: \t\"os\"\n24: \t\"strings\"\n25: \t\"testing\"\n26: \t\"time\"\n27: \n28: \t\"github.com/alicebob/miniredis/v2\"\n29: \tredisv9 \"github.com/redis/go-redis/v9\"\n30: \t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n31: )\n32: \n33: // setupTestRedis creates a new miniredis instance for testing.\n34: func setupTestRedis(t *testing.T) *miniredis.Miniredis {\n35: \treturn miniredis.RunT(t)\n36: }\n37: \n38: // createTestRedisStore creates a redisStore instance connected to the test server.\n39: func createTestRedisStore(t *testing.T, m *miniredis.Miniredis) *redisStore {\n40: \tclient := newRedisClient(m.Addr(), \"\")\n41: \treturn &redisStore{\n42: \t\tcli:                  client,\n43: \t\tsessionPrefix:        sessionPrefix,\n44: \t\texpiryIndexKey:       expiryIndexKey,\n45: \t\tlastActivityIndexKey: lastActivityIndexKey,\n46: \t}\n47: }\n48: \n49: // newRedisClient creates a redis client for testing.\n50: func newRedisClient(addr, password string) *redisv9.Client {\n51: \treturn redisv9.NewClient(&redisv9.Options{\n52: \t\tAddr:     addr,\n53: \t\tPassword: password,\n54: \t})\n55: }\n56: \n57: // createTestSandbox creates a test sandbox with the given sessionID.\n58: func createTestSandbox(sessionID string, expiresAt time.Time) *types.SandboxInfo {\n59: \treturn &types.SandboxInfo{\n60: \t\tKind:             \"AgentRuntime\",\n61: \t\tSandboxID:        fmt.Sprintf(\"sb-%s\", sessionID),\n62: \t\tSandboxNamespace: \"default\",\n63: \t\tName:             fmt.Sprintf(\"runtime-%s\", sessionID),\n64: \t\tEntryPoints: []types.SandboxEntryPoint{\n65: \t\t\t{\n66: \t\t\t\tPath:     \"/api\",\n67: \t\t\t\tProtocol: \"http\",\n68: \t\t\t\tEndpoint: \"localhost:8080\",\n69: \t\t\t},\n70: \t\t},\n71: \t\tSessionID: sessionID,\n72: \t\tCreatedAt: time.Now().UTC(),\n73: \t\tExpiresAt: expiresAt,\n74: \t\tStatus:    \"Running\",\n75: \t\tPodIP:     \"10.0.0.1\",\n76: \t\tPodName:   fmt.Sprintf(\"pod-%s\", sessionID),\n77: \t}\n78: }\n79: \n80: func TestRedisStore_Ping(t *testing.T) {\n81: \tm := setupTestRedis(t)\n82: \tdefer m.Close()\n83: \n84: \ts := createTestRedisStore(t, m)\n85: \tdefer s.Close()\n86: \n87: \tctx := context.Background()\n88: \terr := s.Ping(ctx)\n89: \tif err != nil {\n90: \t\tt.Fatalf(\"Ping() error = %v\", err)\n91: \t}\n92: }\n93: \n94: func TestRedisStore_Ping_Failure(t *testing.T) {\n95: \t// Create a client to a non-existent server\n96: \tclient := newRedisClient(\"localhost:63791\", \"\")\n97: \ts := &redisStore{\n98: \t\tcli:                  client,\n99: \t\tsessionPrefix:        sessionPrefix,\n100: \t\texpiryIndexKey:       expiryIndexKey,\n101: \t\tlastActivityIndexKey: lastActivityIndexKey,\n102: \t}\n103: \tdefer s.Close()\n104: \n105: \tctx, cancel := context.WithTimeout(context.Background(), 100*time.Millisecond)\n106: \tdefer cancel()\n107: \n108: \terr := s.Ping(ctx)\n109: \tif err == nil {\n110: \t\tt.Error(\"Ping() expected error for unreachable server\")\n111: \t}\n112: }\n113: \n114: func TestRedisStore_GetSandboxBySessionID(t *testing.T) {\n115: \tm := setupTestRedis(t)\n116: \tdefer m.Close()\n117: \n118: \ts := createTestRedisStore(t, m)\n119: \tdefer s.Close()\n120: \n121: \tctx := context.Background()\n122: \n123: \t// Test case: empty sessionID\n124: \t_, err := s.GetSandboxBySessionID(ctx, \"\")\n125: \tif err == nil {\n126: \t\tt.Error(\"GetSandboxBySessionID(\\\"\\\") expected error\")\n127: \t}\n128: \n129: \t// Test case: not found\n130: \t_, err = s.GetSandboxBySessionID(ctx, \"non-existent\")\n131: \tif !strings.Contains(err.Error(), \"not found\") && err != ErrNotFound {\n132: \t\tt.Errorf(\"GetSandboxBySessionID() expected ErrNotFound, got %v\", err)\n133: \t}\n134: \n135: \t// Store a sandbox first\n136: \tsandbox := createTestSandbox(\"test-session\", time.Now().Add(time.Hour))\n137: \tif err := s.StoreSandbox(ctx, sandbox); err != nil {\n138: \t\tt.Fatalf(\"StoreSandbox() error = %v\", err)\n139: \t}\n140: \n141: \t// Test case: found\n142: \tresult, err := s.GetSandboxBySessionID(ctx, \"test-session\")\n143: \tif err != nil {\n144: \t\tt.Fatalf(\"GetSandboxBySessionID() error = %v\", err)\n145: \t}\n146: \tif result.SessionID != sandbox.SessionID {\n147: \t\tt.Errorf(\"GetSandboxBySessionID() SessionID = %v, want %v\", result.SessionID, sandbox.SessionID)\n148: \t}\n149: }\n150: \n151: func TestRedisStore_StoreSandbox(t *testing.T) {\n152: \tm := setupTestRedis(t)\n153: \tdefer m.Close()\n154: \n155: \ts := createTestRedisStore(t, m)\n156: \tdefer s.Close()\n157: \n158: \tctx := context.Background()\n159: \n160: \t// Test case: nil sandbox\n161: \terr := s.StoreSandbox(ctx, nil)\n162: \tif err == nil {\n163: \t\tt.Error(\"StoreSandbox(nil) expected error\")\n164: \t}\n165: \n166: \t// Test case: empty sessionID\n167: \tsandbox := createTestSandbox(\"\", time.Now().Add(time.Hour))\n168: \terr = s.StoreSandbox(ctx, sandbox)\n169: \tif err == nil {\n170: \t\tt.Error(\"StoreSandbox() with empty sessionID expected error\")\n171: \t}\n172: \n173: \t// Test case: zero ExpiresAt\n174: \tsandbox = createTestSandbox(\"test-session\", time.Time{})\n175: \terr = s.StoreSandbox(ctx, sandbox)\n176: \tif err == nil {\n177: \t\tt.Error(\"StoreSandbox() with zero ExpiresAt expected error\")\n178: \t}\n179: \n180: \t// Test case: valid sandbox\n181: \tsandbox = createTestSandbox(\"test-session\", time.Now().Add(time.Hour))\n182: \tif err := s.StoreSandbox(ctx, sandbox); err != nil {\n183: \t\tt.Fatalf(\"StoreSandbox() error = %v\", err)\n184: \t}\n185: \n186: \t// Verify the sandbox was stored\n187: \tkey := s.sessionKey(\"test-session\")\n188: \tdata, err := m.Get(key)\n189: \tif err != nil {\n190: \t\tt.Fatalf(\"Failed to get stored data: %v\", err)\n191: \t}\n192: \n193: \tvar stored types.SandboxInfo\n194: \tif err := json.Unmarshal([]byte(data), &stored); err != nil {\n195: \t\tt.Fatalf(\"Failed to unmarshal stored data: %v\", err)\n196: \t}\n197: \tif stored.SessionID != sandbox.SessionID {\n198: \t\tt.Errorf(\"Stored SessionID = %v, want %v\", stored.SessionID, sandbox.SessionID)\n199: \t}\n200: \n201: \t// Verify indexes were created\n202: \texpiryScore, err := m.ZScore(s.expiryIndexKey, \"test-session\")\n203: \tif err != nil || expiryScore == 0 {\n204: \t\tt.Error(\"Expiry index not created\")\n205: \t}\n206: \n207: \tactivityScore, err := m.ZScore(s.lastActivityIndexKey, \"test-session\")\n208: \tif err != nil || activityScore == 0 {\n209: \t\tt.Error(\"Activity index not created\")\n210: \t}\n211: \n212: \t// Test case: duplicate session\n213: \terr = s.StoreSandbox(ctx, sandbox)\n214: \tif err == nil {\n215: \t\tt.Error(\"StoreSandbox() duplicate session expected error\")\n216: \t}\n217: }\n218: \n219: func TestRedisStore_UpdateSandbox(t *testing.T) {\n220: \tm := setupTestRedis(t)\n221: \tdefer m.Close()\n222: \n223: \ts := createTestRedisStore(t, m)\n224: \tdefer s.Close()\n225: \n226: \tctx := context.Background()\n227: \n228: \t// Test case: nil sandbox\n229: \terr := s.UpdateSandbox(ctx, nil)\n230: \tif err == nil {\n231: \t\tt.Error(\"UpdateSandbox(nil) expected error\")\n232: \t}\n233: \n234: \t// Test case: empty sessionID\n235: \tsandbox := createTestSandbox(\"\", time.Now().Add(time.Hour))\n236: \terr = s.UpdateSandbox(ctx, sandbox)\n237: \tif err == nil {\n238: \t\tt.Error(\"UpdateSandbox() with empty sessionID expected error\")\n239: \t}\n240: \n241: \t// Test case: non-existent sandbox\n242: \tsandbox = createTestSandbox(\"non-existent\", time.Now().Add(time.Hour))\n243: \terr = s.UpdateSandbox(ctx, sandbox)\n244: \tif err == nil {\n245: \t\tt.Error(\"UpdateSandbox() non-existent sandbox expected error\")\n246: \t}\n247: \n248: \t// Store a sandbox first\n249: \tsandbox = createTestSandbox(\"test-session\", time.Now().Add(time.Hour))\n250: \tif err := s.StoreSandbox(ctx, sandbox); err != nil {\n251: \t\tt.Fatalf(\"StoreSandbox() error = %v\", err)\n252: \t}\n253: \n254: \t// Update the sandbox\n255: \tsandbox.Status = \"Updated\"\n256: \tif err := s.UpdateSandbox(ctx, sandbox); err != nil {\n257: \t\tt.Fatalf(\"UpdateSandbox() error = %v\", err)\n258: \t}\n259: \n260: \t// Verify the update\n261: \tresult, err := s.GetSandboxBySessionID(ctx, \"test-session\")\n262: \tif err != nil {\n263: \t\tt.Fatalf(\"GetSandboxBySessionID() error = %v\", err)\n264: \t}\n265: \tif result.Status != \"Updated\" {\n266: \t\tt.Errorf(\"Status = %v, want Updated\", result.Status)\n267: \t}\n268: }\n269: \n270: func TestRedisStore_DeleteSandboxBySessionID(t *testing.T) {\n271: \tm := setupTestRedis(t)\n272: \tdefer m.Close()\n273: \n274: \ts := createTestRedisStore(t, m)\n275: \tdefer s.Close()\n276: \n277: \tctx := context.Background()\n278: \n279: \t// Test case: empty sessionID\n280: \terr := s.DeleteSandboxBySessionID(ctx, \"\")\n281: \tif err == nil {\n282: \t\tt.Error(\"DeleteSandboxBySessionID(\\\"\\\") expected error\")\n283: \t}\n284: \n285: \t// Store a sandbox first\n286: \tsandbox := createTestSandbox(\"test-session\", time.Now().Add(time.Hour))\n287: \tif err := s.StoreSandbox(ctx, sandbox); err != nil {\n288: \t\tt.Fatalf(\"StoreSandbox() error = %v\", err)\n289: \t}\n290: \n291: \t// Delete the sandbox\n292: \tif err := s.DeleteSandboxBySessionID(ctx, \"test-session\"); err != nil {\n293: \t\tt.Fatalf(\"DeleteSandboxBySessionID() error = %v\", err)\n294: \t}\n295: \n296: \t// Verify deletion\n297: \t_, err = s.GetSandboxBySessionID(ctx, \"test-session\")\n298: \tif err == nil {\n299: \t\tt.Error(\"GetSandboxBySessionID() after delete expected error\")\n300: \t}\n301: \n302: \t// Verify indexes were removed\n303: \t_, err = m.ZScore(s.expiryIndexKey, \"test-session\")\n304: \tif err == nil {\n305: \t\tt.Error(\"Expiry index not removed\")\n306: \t}\n307: \t_, err = m.ZScore(s.lastActivityIndexKey, \"test-session\")\n308: \tif err == nil {\n309: \t\tt.Error(\"Activity index not removed\")\n310: \t}\n311: \n312: \t// Test case: delete non-existent (idempotent)\n313: \terr = s.DeleteSandboxBySessionID(ctx, \"non-existent\")\n314: \tif err != nil {\n315: \t\tt.Errorf(\"DeleteSandboxBySessionID() non-existent expected no error, got %v\", err)\n316: \t}\n317: }\n318: \n319: func TestRedisStore_ListExpiredSandboxes(t *testing.T) {\n320: \tm := setupTestRedis(t)\n321: \tdefer m.Close()\n322: \n323: \ts := createTestRedisStore(t, m)\n324: \tdefer s.Close()\n325: \n326: \tctx := context.Background()\n327: \tnow := time.Now()\n328: \n329: \t// Test case: limit <= 0\n330: \tresult, err := s.ListExpiredSandboxes(ctx, now, 0)\n331: \tif err != nil {\n332: \t\tt.Fatalf(\"ListExpiredSandboxes() error = %v\", err)\n333: \t}\n334: \tif result != nil {\n335: \t\tt.Error(\"ListExpiredSandboxes() with limit=0 expected nil\")\n336: \t}\n337: \n338: \t// Store expired sandboxes\n339: \tsandbox1 := createTestSandbox(\"expired-1\", now.Add(-time.Hour))\n340: \tsandbox2 := createTestSandbox(\"expired-2\", now.Add(-30*time.Minute))\n341: \tsandbox3 := createTestSandbox(\"active-1\", now.Add(time.Hour))\n342: \n343: \tif err := s.StoreSandbox(ctx, sandbox1); err != nil {\n344: \t\tt.Fatalf(\"StoreSandbox() error = %v\", err)\n345: \t}\n346: \tif err := s.StoreSandbox(ctx, sandbox2); err != nil {\n347: \t\tt.Fatalf(\"StoreSandbox() error = %v\", err)\n348: \t}\n349: \tif err := s.StoreSandbox(ctx, sandbox3); err != nil {\n350: \t\tt.Fatalf(\"StoreSandbox() error = %v\", err)\n351: \t}\n352: \n353: \t// List expired sandboxes\n354: \texpired, err := s.ListExpiredSandboxes(ctx, now, 10)\n355: \tif err != nil {\n356: \t\tt.Fatalf(\"ListExpiredSandboxes() error = %v\", err)\n357: \t}\n358: \n359: \tif len(expired) != 2 {\n360: \t\tt.Errorf(\"ListExpiredSandboxes() returned %d sandboxes, want 2\", len(expired))\n361: \t}\n362: \n363: \t// Test with limit\n364: \texpiredLimited, err := s.ListExpiredSandboxes(ctx, now, 1)\n365: \tif err != nil {\n366: \t\tt.Fatalf(\"ListExpiredSandboxes() error = %v\", err)\n367: \t}\n368: \tif len(expiredLimited) != 1 {\n369: \t\tt.Errorf(\"ListExpiredSandboxes() with limit=1 returned %d sandboxes, want 1\", len(expiredLimited))\n370: \t}\n371: }\n372: \n373: func TestRedisStore_ListInactiveSandboxes(t *testing.T) {\n374: \tm := setupTestRedis(t)\n375: \tdefer m.Close()\n376: \n377: \ts := createTestRedisStore(t, m)\n378: \tdefer s.Close()\n379: \n380: \tctx := context.Background()\n381: \tnow := time.Now()\n382: \n383: \t// Test case: limit <= 0\n384: \tresult, err := s.ListInactiveSandboxes(ctx, now, 0)\n385: \tif err != nil {\n386: \t\tt.Fatalf(\"ListInactiveSandboxes() error = %v\", err)\n387: \t}\n388: \tif result != nil {\n389: \t\tt.Error(\"ListInactiveSandboxes() with limit=0 expected nil\")\n390: \t}\n391: \n392: \t// Store sandbox and update activity\n393: \tsandbox := createTestSandbox(\"test-session\", now.Add(time.Hour))\n394: \tif err := s.StoreSandbox(ctx, sandbox); err != nil {\n395: \t\tt.Fatalf(\"StoreSandbox() error = %v\", err)\n396: \t}\n397: \n398: \t// Manually set activity to past time by manipulating the sorted set\n399: \t// (since StoreSandbox sets activity to now)\n400: \tm.ZRem(s.lastActivityIndexKey, \"test-session\")\n401: \tm.ZAdd(s.lastActivityIndexKey, float64(now.Add(-time.Hour).Unix()), \"test-session\")\n402: \n403: \t// List inactive sandboxes\n404: \tinactive, err := s.ListInactiveSandboxes(ctx, now.Add(-30*time.Minute), 10)\n405: \tif err != nil {\n406: \t\tt.Fatalf(\"ListInactiveSandboxes() error = %v\", err)\n407: \t}\n408: \n409: \tif len(inactive) != 1 {\n410: \t\tt.Errorf(\"ListInactiveSandboxes() returned %d sandboxes, want 1\", len(inactive))\n411: \t}\n412: }\n413: \n414: func TestRedisStore_UpdateSessionLastActivity(t *testing.T) {\n415: \tm := setupTestRedis(t)\n416: \tdefer m.Close()\n417: \n418: \ts := createTestRedisStore(t, m)\n419: \tdefer s.Close()\n420: \n421: \tctx := context.Background()\n422: \tnow := time.Now()\n423: \n424: \t// Test case: empty sessionID\n425: \terr := s.UpdateSessionLastActivity(ctx, \"\", now)\n426: \tif err == nil {\n427: \t\tt.Error(\"UpdateSessionLastActivity(\\\"\\\") expected error\")\n428: \t}\n429: \n430: \t// Test case: non-existent session\n431: \terr = s.UpdateSessionLastActivity(ctx, \"non-existent\", now)\n432: \tif err == nil {\n433: \t\tt.Error(\"UpdateSessionLastActivity() non-existent expected error\")\n434: \t}\n435: \n436: \t// Store a sandbox first\n437: \tsandbox := createTestSandbox(\"test-session\", now.Add(time.Hour))\n438: \tif err := s.StoreSandbox(ctx, sandbox); err != nil {\n439: \t\tt.Fatalf(\"StoreSandbox() error = %v\", err)\n440: \t}\n441: \n442: \t// Get initial activity score\n443: \tinitialScore := m.ZScore(s.lastActivityIndexKey, \"test-session\")\n444: \n445: \t// Wait a bit to ensure different timestamp\n446: \ttime.Sleep(10 * time.Millisecond)\n447: \n448: \t// Update activity with zero time (should use Now)\n449: \tif err := s.UpdateSessionLastActivity(ctx, \"test-session\", time.Time{}); err != nil {\n450: \t\tt.Fatalf(\"UpdateSessionLastActivity() error = %v\", err)\n451: \t}\n452: \n453: \t// Verify activity was updated\n454: \tnewScore := m.ZScore(s.lastActivityIndexKey, \"test-session\")\n455: \tif newScore <= initialScore {\n456: \t\tt.Error(\"Activity timestamp was not updated\")\n457: \t}\n458: \n459: \t// Update activity with specific time\n460: \tfuture := now.Add(time.Hour)\n461: \tif err := s.UpdateSessionLastActivity(ctx, \"test-session\", future); err != nil {\n462: \t\tt.Fatalf(\"UpdateSessionLastActivity() error = %v\", err)\n463: \t}\n464: \n465: \t// Verify specific time was used\n466: \tscore := m.ZScore(s.lastActivityIndexKey, \"test-session\")\n467: \tif score != float64(future.Unix()) {\n468: \t\tt.Errorf(\"Activity timestamp = %v, want %v\", score, float64(future.Unix()))\n469: \t}\n470: }\n471: \n472: func TestRedisStore_Close(t *testing.T) {\n473: \tm := setupTestRedis(t)\n474: \tdefer m.Close()\n475: \n476: \ts := createTestRedisStore(t, m)\n477: \n478: \terr := s.Close()\n479: \tif err != nil {\n480: \t\tt.Errorf(\"Close() error = %v\", err)\n481: \t}\n482: }\n483: \n484: func TestRedisStore_LoadSandboxesBySessionIDs(t *testing.T) {\n485: \tm := setupTestRedis(t)\n486: \tdefer m.Close()\n487: \n488: \ts := createTestRedisStore(t, m)\n489: \tdefer s.Close()\n490: \n491: \tctx := context.Background()\n492: \n493: \t// Test case: empty sessionIDs\n494: \tresult, err := s.loadSandboxesBySessionIDs(ctx, []string{})\n495: \tif err != nil {\n496: \t\tt.Fatalf(\"loadSandboxesBySessionIDs() error = %v\", err)\n497: \t}\n498: \tif len(result) != 0 {\n499: \t\tt.Errorf(\"loadSandboxesBySessionIDs() returned %d sandboxes, want 0\", len(result))\n500: \t}\n501: \n502: \t// Store multiple sandboxes\n503: \tsandbox1 := createTestSandbox(\"session-1\", time.Now().Add(time.Hour))\n504: \tsandbox2 := createTestSandbox(\"session-2\", time.Now().Add(time.Hour))\n505: \n506: \tif err := s.StoreSandbox(ctx, sandbox1); err != nil {\n507: \t\tt.Fatalf(\"StoreSandbox() error = %v\", err)\n508: \t}\n509: \tif err := s.StoreSandbox(ctx, sandbox2); err != nil {\n510: \t\tt.Fatalf(\"StoreSandbox() error = %v\", err)\n511: \t}\n512: \n513: \t// Load by session IDs\n514: \tsessionIDs := []string{\"session-1\", \"session-2\", \"non-existent\"}\n515: \tsandboxes, err := s.loadSandboxesBySessionIDs(ctx, sessionIDs)\n516: \tif err != nil {\n517: \t\tt.Fatalf(\"loadSandboxesBySessionIDs() error = %v\", err)\n518: \t}\n519: \tif len(sandboxes) != 2 {\n520: \t\tt.Errorf(\"loadSandboxesBySessionIDs() returned %d sandboxes, want 2\", len(sandboxes))\n521: \t}\n522: }\n523: \n524: func TestRedisStore_LoadSandboxesWithOrphanedIndex(t *testing.T) {\n525: \tm := setupTestRedis(t)\n526: \tdefer m.Close()\n527: \n528: \ts := createTestRedisStore(t, m)\n529: \tdefer s.Close()\n530: \n531: \tctx := context.Background()\n532: \n533: \t// Store a sandbox\n534: \tsandbox := createTestSandbox(\"test-session\", time.Now().Add(time.Hour))\n535: \tif err := s.StoreSandbox(ctx, sandbox); err != nil {\n536: \t\tt.Fatalf(\"StoreSandbox() error = %v\", err)\n537: \t}\n538: \n539: \t// Delete the session data but keep the index (simulate orphaned index)\n540: \tm.Del(s.sessionKey(\"test-session\"))\n541: \n542: \t// List expired sandboxes should handle orphaned entries gracefully\n543: \texpired, err := s.ListExpiredSandboxes(ctx, time.Now().Add(time.Hour*2), 10)\n544: \tif err != nil {\n545: \t\tt.Fatalf(\"ListExpiredSandboxes() error = %v\", err)\n546: \t}\n547: \tif len(expired) != 0 {\n548: \t\tt.Errorf(\"ListExpiredSandboxes() returned %d sandboxes, want 0 (orphaned entries should be skipped)\", len(expired))\n549: \t}\n550: }\n551: \n552: func TestRedisStore_SessionKey(t *testing.T) {\n553: \ts := &redisStore{\n554: \t\tsessionPrefix: \"session:\",\n555: \t}\n556: \n557: \tkey := s.sessionKey(\"test-id\")\n558: \tif key != \"session:test-id\" {\n559: \t\tt.Errorf(\"sessionKey() = %v, want session:test-id\", key)\n560: \t}\n561: }\n562: \n563: func TestMakeRedisOptions(t *testing.T) {\n564: \t// Clean up environment after test\n565: \toriginalAddr := os.Getenv(\"REDIS_ADDR\")\n566: \toriginalPassword := os.Getenv(\"REDIS_PASSWORD\")\n567: \toriginalRequired := os.Getenv(\"REDIS_PASSWORD_REQUIRED\")\n568: \tdefer func() {\n569: \t\tos.Setenv(\"REDIS_ADDR\", originalAddr)\n570: \t\tos.Setenv(\"REDIS_PASSWORD\", originalPassword)\n571: \t\tos.Setenv(\"REDIS_PASSWORD_REQUIRED\", originalRequired)\n572: \t}()\n573: \n574: \t// Test case: missing REDIS_ADDR\n575: \tos.Unsetenv(\"REDIS_ADDR\")\n576: \tos.Setenv(\"REDIS_PASSWORD\", \"secret\")\n577: \t_, err := makeRedisOptions()\n578: \tif err == nil {\n579: \t\tt.Error(\"makeRedisOptions() without REDIS_ADDR expected error\")\n580: \t}\n581: \n582: \t// Test case: missing REDIS_PASSWORD when required\n583: \tos.Setenv(\"REDIS_ADDR\", \"localhost:6379\")\n584: \tos.Setenv(\"REDIS_PASSWORD\", \"\")\n585: \tos.Unsetenv(\"REDIS_PASSWORD_REQUIRED\")\n586: \t_, err = makeRedisOptions()\n587: \tif err == nil {\n588: \t\tt.Error(\"makeRedisOptions() without password when required expected error\")\n589: \t}\n590: \n591: \t// Test case: password not required\n592: \tos.Setenv(\"REDIS_ADDR\", \"localhost:6379\")\n593: \tos.Setenv(\"REDIS_PASSWORD\", \"\")\n594: \tos.Setenv(\"REDIS_PASSWORD_REQUIRED\", \"false\")\n595: \topts, err := makeRedisOptions()\n596: \tif err != nil {\n597: \t\tt.Fatalf(\"makeRedisOptions() error = %v\", err)\n598: \t}\n599: \tif opts.Addr != \"localhost:6379\" {\n600: \t\tt.Errorf(\"Addr = %v, want localhost:6379\", opts.Addr)\n601: \t}\n602: \tif opts.Password != \"\" {\n603: \t\tt.Errorf(\"Password = %v, want empty\", opts.Password)\n604: \t}\n605: \n606: \t// Test case: password required and provided\n607: \tos.Setenv(\"REDIS_ADDR\", \"redis:6379\")\n608: \tos.Setenv(\"REDIS_PASSWORD\", \"mysecret\")\n609: \tos.Setenv(\"REDIS_PASSWORD_REQUIRED\", \"true\")\n610: \topts, err = makeRedisOptions()\n611: \tif err != nil {\n612: \t\tt.Fatalf(\"makeRedisOptions() error = %v\", err)\n613: \t}\n614: \tif opts.Addr != \"redis:6379\" {\n615: \t\tt.Errorf(\"Addr = %v, want redis:6379\", opts.Addr)\n616: \t}\n617: \tif opts.Password != \"mysecret\" {\n618: \t\tt.Errorf(\"Password = %v, want mysecret\", opts.Password)\n619: \t}\n620: \n621: \t// Test case: whitespace trimming\n622: \tos.Setenv(\"REDIS_ADDR\", \"  localhost:6379  \")\n623: \tos.Setenv(\"REDIS_PASSWORD\", \"  secret  \")\n624: \topts, err = makeRedisOptions()\n625: \tif err != nil {\n626: \t\tt.Fatalf(\"makeRedisOptions() error = %v\", err)\n627: \t}\n628: \tif opts.Addr != \"localhost:6379\" {\n629: \t\tt.Errorf(\"Addr = %v, want localhost:6379 (trimmed)\", opts.Addr)\n630: \t}\n631: \tif opts.Password != \"  secret  \" {\n632: \t\tt.Errorf(\"Password = %v, want \\\"  secret  \\\" (not trimmed)\", opts.Password)\n633: \t}\n634: }\n635: \n636: func TestMakeRedisOptions_InvalidBool(t *testing.T) {\n637: \t// Clean up environment after test\n638: \toriginalAddr := os.Getenv(\"REDIS_ADDR\")\n639: \toriginalRequired := os.Getenv(\"REDIS_PASSWORD_REQUIRED\")\n640: \tdefer func() {\n641: \t\tos.Setenv(\"REDIS_ADDR\", originalAddr)\n642: \t\tos.Setenv(\"REDIS_PASSWORD_REQUIRED\", originalRequired)\n643: \t}()\n644: \n645: \tos.Setenv(\"REDIS_ADDR\", \"localhost:6379\")\n646: \tos.Setenv(\"REDIS_PASSWORD\", \"secret\")\n647: \tos.Setenv(\"REDIS_PASSWORD_REQUIRED\", \"invalid\")\n648: \n649: \t// Should use default (true) when parsing fails\n650: \t_, err := makeRedisOptions()\n651: \tif err != nil {\n652: \t\tt.Errorf(\"makeRedisOptions() with invalid bool should use default, got error: %v\", err)\n653: \t}\n654: }\n655: \n656: func TestNewRedisStore(t *testing.T) {\n657: \tm := setupTestRedis(t)\n658: \tdefer m.Close()\n659: \n660: \t// Clean up environment after test\n661: \toriginalAddr := os.Getenv(\"REDIS_ADDR\")\n662: \tdefer func() {\n663: \t\tos.Setenv(\"REDIS_ADDR\", originalAddr)\n664: \t}()\n665: \n666: \tos.Setenv(\"REDIS_ADDR\", m.Addr())\n667: \tos.Setenv(\"REDIS_PASSWORD\", \"\")\n668: \tos.Setenv(\"REDIS_PASSWORD_REQUIRED\", \"false\")\n669: \n670: \tstore, err := newRedisStore()\n671: \tif err != nil {\n672: \t\tt.Fatalf(\"newRedisStore() error = %v\", err)\n673: \t}\n674: \tif store == nil {\n675: \t\tt.Fatal(\"newRedisStore() returned nil\")\n676: \t}\n677: \tdefer store.Close()\n678: \n679: \t// Test that it implements Store interface\n680: \tvar _ Store = store\n681: }\n682: \n683: func TestNewRedisStore_MissingAddr(t *testing.T) {\n684: \t// Clean up environment\n685: \toriginalAddr := os.Getenv(\"REDIS_ADDR\")\n686: \tdefer func() {\n687: \t\tos.Setenv(\"REDIS_ADDR\", originalAddr)\n688: \t}()\n689: \n690: \tos.Unsetenv(\"REDIS_ADDR\")\n691: \n692: \t_, err := newRedisStore()\n693: \tif err == nil {\n694: \t\tt.Error(\"newRedisStore() without REDIS_ADDR expected error\")\n695: \t}\n696: }\n\n(End of file - total 696 lines)\n</content>","metadata":{"preview":"/*\nCopyright 2026 The Volcano Authors.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\npackage store\n\nimport (\n\t\"context\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/store/redis_test.go","time":{"start":1775868295214,"end":1775868295234}}