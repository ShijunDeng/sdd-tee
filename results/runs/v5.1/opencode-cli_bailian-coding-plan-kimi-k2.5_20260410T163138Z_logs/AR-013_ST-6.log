{"type":"tool_use","timestamp":1775868284943,"sessionID":"ses_28600cab4ffep6L858aRhkgvHB","part":{"id":"prt_d79ff7adb001sPD5ZKLoN4CPgI","messageID":"msg_d79ff6361001DbC3439sIaoI3k","sessionID":"ses_28600cab4ffep6L858aRhkgvHB","type":"tool","tool":"read","callID":"toolu_functions.read:3","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/store/redis.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/store/redis.go</path>\n<type>file</type>\n<content>\n1: /*\n2: Copyright 2026 The Volcano Authors.\n3: \n4: Licensed under the Apache License, Version 2.0 (the \"License\");\n5: you may not use this file except in compliance with the License.\n6: You may obtain a copy of the License at\n7: \n8:     http://www.apache.org/licenses/LICENSE-2.0\n9: \n10: Unless required by applicable law or agreed to in writing, software\n11: distributed under the License is distributed on an \"AS IS\" BASIS,\n12: WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n13: See the License for the specific language governing permissions and\n14: limitations under the License.\n15: */\n16: \n17: package store\n18: \n19: import (\n20: \t\"context\"\n21: \t\"encoding/json\"\n22: \t\"fmt\"\n23: \t\"time\"\n24: \n25: \tredisv9 \"github.com/redis/go-redis/v9\"\n26: \t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n27: )\n28: \n29: // redisStore implements Store interface using Redis backend.\n30: type redisStore struct {\n31: \tcli                  *redisv9.Client\n32: \tsessionPrefix        string\n33: \texpiryIndexKey       string\n34: \tlastActivityIndexKey string\n35: }\n36: \n37: // newRedisStore creates a new Redis-backed Store instance.\n38: func newRedisStore() (Store, error) {\n39: \topts, err := makeRedisOptions()\n40: \tif err != nil {\n41: \t\treturn nil, err\n42: \t}\n43: \n44: \tclient := redisv9.NewClient(&redisv9.Options{\n45: \t\tAddr:     opts.Addr,\n46: \t\tPassword: opts.Password,\n47: \t})\n48: \n49: \treturn &redisStore{\n50: \t\tcli:                  client,\n51: \t\tsessionPrefix:        sessionPrefix,\n52: \t\texpiryIndexKey:       expiryIndexKey,\n53: \t\tlastActivityIndexKey: lastActivityIndexKey,\n54: \t}, nil\n55: }\n56: \n57: // sessionKey constructs the Redis key for a session.\n58: func (s *redisStore) sessionKey(sessionID string) string {\n59: \treturn s.sessionPrefix + sessionID\n60: }\n61: \n62: // Ping verifies connectivity to the Redis backend.\n63: // Returns nil on success, error on failure.\n64: func (s *redisStore) Ping(ctx context.Context) error {\n65: \tresult, err := s.cli.Ping(ctx).Result()\n66: \tif err != nil {\n67: \t\treturn err\n68: \t}\n69: \tif result != \"PONG\" {\n70: \t\treturn fmt.Errorf(\"unexpected ping response: %s\", result)\n71: \t}\n72: \treturn nil\n73: }\n74: \n75: // GetSandboxBySessionID retrieves sandbox info by session ID.\n76: // Returns ErrNotFound if the session does not exist.\n77: func (s *redisStore) GetSandboxBySessionID(ctx context.Context, sessionID string) (*types.SandboxInfo, error) {\n78: \tif sessionID == \"\" {\n79: \t\treturn nil, fmt.Errorf(\"sessionID is empty\")\n80: \t}\n81: \n82: \tkey := s.sessionKey(sessionID)\n83: \tdata, err := s.cli.Get(ctx, key).Result()\n84: \tif err == redisv9.Nil {\n85: \t\treturn nil, ErrNotFound\n86: \t}\n87: \tif err != nil {\n88: \t\treturn nil, err\n89: \t}\n90: \n91: \tvar sandbox types.SandboxInfo\n92: \tif err := json.Unmarshal([]byte(data), &sandbox); err != nil {\n93: \t\treturn nil, fmt.Errorf(\"failed to unmarshal sandbox: %w\", err)\n94: \t}\n95: \n96: \treturn &sandbox, nil\n97: }\n98: \n99: // StoreSandbox creates a new sandbox entry with atomic index updates.\n100: // Validates sandbox is non-nil and has valid ExpiresAt.\n101: // Uses SETNX to prevent overwriting existing keys.\n102: func (s *redisStore) StoreSandbox(ctx context.Context, sandbox *types.SandboxInfo) error {\n103: \tif sandbox == nil {\n104: \t\treturn fmt.Errorf(\"sandbox is nil\")\n105: \t}\n106: \tif sandbox.SessionID == \"\" {\n107: \t\treturn fmt.Errorf(\"sessionID is empty\")\n108: \t}\n109: \tif sandbox.ExpiresAt.IsZero() {\n110: \t\treturn fmt.Errorf(\"expiresAt is zero\")\n111: \t}\n112: \n113: \tkey := s.sessionKey(sandbox.SessionID)\n114: \tdata, err := json.Marshal(sandbox)\n115: \tif err != nil {\n116: \t\treturn fmt.Errorf(\"failed to marshal sandbox: %w\", err)\n117: \t}\n118: \n119: \t// Use pipeline for atomic operations\n120: \tpipe := s.cli.Pipeline()\n121: \tsetCmd := pipe.SetNX(ctx, key, data, 0)\n122: \tzaddExpiryCmd := pipe.ZAdd(ctx, s.expiryIndexKey, redisv9.Z{\n123: \t\tScore:  float64(sandbox.ExpiresAt.Unix()),\n124: \t\tMember: sandbox.SessionID,\n125: \t})\n126: \tzaddActivityCmd := pipe.ZAdd(ctx, s.lastActivityIndexKey, redisv9.Z{\n127: \t\tScore:  float64(time.Now().Unix()),\n128: \t\tMember: sandbox.SessionID,\n129: \t})\n130: \n131: \t_, err = pipe.Exec(ctx)\n132: \tif err != nil {\n133: \t\treturn err\n134: \t}\n135: \n136: \t// Check if SETNX succeeded\n137: \tif !setCmd.Val() {\n138: \t\treturn fmt.Errorf(\"session already exists\")\n139: \t}\n140: \n141: \t// Check ZADD results\n142: \tif zaddExpiryCmd.Err() != nil {\n143: \t\treturn zaddExpiryCmd.Err()\n144: \t}\n145: \tif zaddActivityCmd.Err() != nil {\n146: \t\treturn zaddActivityCmd.Err()\n147: \t}\n148: \n149: \treturn nil\n150: }\n151: \n152: // UpdateSandbox updates an existing sandbox's JSON data.\n153: // Uses SET with XX flag (key must exist).\n154: // Does NOT modify expiry or last-activity indexes.\n155: func (s *redisStore) UpdateSandbox(ctx context.Context, sandbox *types.SandboxInfo) error {\n156: \tif sandbox == nil {\n157: \t\treturn fmt.Errorf(\"sandbox is nil\")\n158: \t}\n159: \tif sandbox.SessionID == \"\" {\n160: \t\treturn fmt.Errorf(\"sessionID is empty\")\n161: \t}\n162: \n163: \tkey := s.sessionKey(sandbox.SessionID)\n164: \tdata, err := json.Marshal(sandbox)\n165: \tif err != nil {\n166: \t\treturn fmt.Errorf(\"failed to marshal sandbox: %w\", err)\n167: \t}\n168: \n169: \t// SET with XX flag - only set if key exists\n170: \tresult, err := s.cli.SetXX(ctx, key, data, 0).Result()\n171: \tif err != nil {\n172: \t\treturn err\n173: \t}\n174: \tif !result {\n175: \t\treturn fmt.Errorf(\"key not exists\")\n176: \t}\n177: \n178: \treturn nil\n179: }\n180: \n181: // DeleteSandboxBySessionID removes a sandbox and its indexes.\n182: // Uses atomic pipeline: DEL + ZREM expiry + ZREM last_activity.\n183: func (s *redisStore) DeleteSandboxBySessionID(ctx context.Context, sessionID string) error {\n184: \tif sessionID == \"\" {\n185: \t\treturn fmt.Errorf(\"sessionID is empty\")\n186: \t}\n187: \n188: \tkey := s.sessionKey(sessionID)\n189: \n190: \tpipe := s.cli.Pipeline()\n191: \tdelCmd := pipe.Del(ctx, key)\n192: \tzremExpiryCmd := pipe.ZRem(ctx, s.expiryIndexKey, sessionID)\n193: \tzremActivityCmd := pipe.ZRem(ctx, s.lastActivityIndexKey, sessionID)\n194: \n195: \t_, err := pipe.Exec(ctx)\n196: \tif err != nil {\n197: \t\treturn err\n198: \t}\n199: \n200: \t// We don't need to check the results - deletion is idempotent\n201: \t_ = delCmd.Val()\n202: \t_ = zremExpiryCmd.Val()\n203: \t_ = zremActivityCmd.Val()\n204: \n205: \treturn nil\n206: }\n207: \n208: // ListExpiredSandboxes returns sessions with ExpiresAt <= before.\n209: // Queries session:expiry ZSET with ZRANGEBYSCORE.\n210: // Returns nil, nil if limit <= 0.\n211: func (s *redisStore) ListExpiredSandboxes(ctx context.Context, before time.Time, limit int64) ([]*types.SandboxInfo, error) {\n212: \tif limit <= 0 {\n213: \t\treturn nil, nil\n214: \t}\n215: \n216: \t// Get expired session IDs from the ZSET\n217: \tmemberArgs := redisv9.ZRangeArgs{\n218: \t\tKey:     s.expiryIndexKey,\n219: \t\tStart:   \"-inf\",\n220: \t\tStop:    float64(before.Unix()),\n221: \t\tByScore: true,\n222: \t\tCount:   limit,\n223: \t}\n224: \n225: \tsessionIDs, err := s.cli.ZRangeArgs(ctx, memberArgs).Result()\n226: \tif err != nil {\n227: \t\treturn nil, err\n228: \t}\n229: \n230: \treturn s.loadSandboxesBySessionIDs(ctx, sessionIDs)\n231: }\n232: \n233: // ListInactiveSandboxes returns sessions with last activity <= before.\n234: // Queries session:last_activity ZSET with ZRANGEBYSCORE.\n235: // Returns nil, nil if limit <= 0.\n236: func (s *redisStore) ListInactiveSandboxes(ctx context.Context, before time.Time, limit int64) ([]*types.SandboxInfo, error) {\n237: \tif limit <= 0 {\n238: \t\treturn nil, nil\n239: \t}\n240: \n241: \t// Get inactive session IDs from the ZSET\n242: \tmemberArgs := redisv9.ZRangeArgs{\n243: \t\tKey:     s.lastActivityIndexKey,\n244: \t\tStart:   \"-inf\",\n245: \t\tStop:    float64(before.Unix()),\n246: \t\tByScore: true,\n247: \t\tCount:   limit,\n248: \t}\n249: \n250: \tsessionIDs, err := s.cli.ZRangeArgs(ctx, memberArgs).Result()\n251: \tif err != nil {\n252: \t\treturn nil, err\n253: \t}\n254: \n255: \treturn s.loadSandboxesBySessionIDs(ctx, sessionIDs)\n256: }\n257: \n258: // loadSandboxesBySessionIDs loads sandbox info for the given session IDs.\n259: // Skips entries where the session key is missing (orphaned ZSET entries).\n260: func (s *redisStore) loadSandboxesBySessionIDs(ctx context.Context, sessionIDs []string) ([]*types.SandboxInfo, error) {\n261: \tif len(sessionIDs) == 0 {\n262: \t\treturn []*types.SandboxInfo{}, nil\n263: \t}\n264: \n265: \t// Build keys for all session IDs\n266: \tkeys := make([]string, len(sessionIDs))\n267: \tfor idx, id := range sessionIDs {\n268: \t\tkeys[idx] = s.sessionKey(id)\n269: \t}\n270: \n271: \t// Use MGET to fetch all sessions in one call\n272: \tresults, err := s.cli.MGet(ctx, keys...).Result()\n273: \tif err != nil {\n274: \t\treturn nil, err\n275: \t}\n276: \n277: \t// Parse results, skipping nil entries (orphaned ZSET members)\n278: \tsandboxes := make([]*types.SandboxInfo, 0, len(results))\n279: \tfor _, result := range results {\n280: \t\tif result == nil {\n281: \t\t\t// Orphaned ZSET entry - skip\n282: \t\t\tcontinue\n283: \t\t}\n284: \n285: \t\tdata, ok := result.(string)\n286: \t\tif !ok || data == \"\" {\n287: \t\t\t// Invalid data - skip\n288: \t\t\tcontinue\n289: \t\t}\n290: \n291: \t\tvar sandbox types.SandboxInfo\n292: \t\tif err := json.Unmarshal([]byte(data), &sandbox); err != nil {\n293: \t\t\t// Failed to parse - skip this entry but continue\n294: \t\t\tcontinue\n295: \t\t}\n296: \n297: \t\tsandboxes = append(sandboxes, &sandbox)\n298: \t}\n299: \n300: \treturn sandboxes, nil\n301: }\n302: \n303: // UpdateSessionLastActivity updates the last activity timestamp for a session.\n304: // Returns ErrNotFound if session does not exist.\n305: // If at is zero time, uses time.Now().\n306: func (s *redisStore) UpdateSessionLastActivity(ctx context.Context, sessionID string, at time.Time) error {\n307: \tif sessionID == \"\" {\n308: \t\treturn fmt.Errorf(\"sessionID is empty\")\n309: \t}\n310: \n311: \t// Verify session exists before updating\n312: \tkey := s.sessionKey(sessionID)\n313: \texists, err := s.cli.Exists(ctx, key).Result()\n314: \tif err != nil {\n315: \t\treturn err\n316: \t}\n317: \tif exists == 0 {\n318: \t\treturn ErrNotFound\n319: \t}\n320: \n321: \t// Use current time if at is zero\n322: \tif at.IsZero() {\n323: \t\tat = time.Now()\n324: \t}\n325: \n326: \t// Update the activity index\n327: \t_, err = s.cli.ZAdd(ctx, s.lastActivityIndexKey, redisv9.Z{\n328: \t\tScore:  float64(at.Unix()),\n329: \t\tMember: sessionID,\n330: \t}).Result()\n331: \tif err != nil {\n332: \t\treturn err\n333: \t}\n334: \n335: \treturn nil\n336: }\n337: \n338: // Close closes the Redis connection.\n339: func (s *redisStore) Close() error {\n340: \treturn s.cli.Close()\n341: }\n\n(End of file - total 341 lines)\n</content>","metadata":{"preview":"/*\nCopyright 2026 The Volcano Authors.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\npackage store\n\nimport (\n\t\"context\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/store/redis.go","time":{"start":1775868284910,"end":1775868284941}}}}
{"type":"tool_use","timestamp":1775868284944,"sessionID":"ses_28600cab4ffep6L858aRhkgvHB","part":{"id":"prt_d79ff7fc2001DY4648FGIeyJNu","messageID":"msg_d79ff6361001DbC3439sIaoI3k","sessionID":"ses_28600cab4ffep6L858aRhkgvHB","type":"tool","tool":"read","callID":"toolu_functions.read:4","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/store/store.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/store/store.go</path>\n<type>file</type>\n<content>\n1: /*\n2: Copyright 2026 The Volcano Authors.\n3: \n4: Licensed under the Apache License, Version 2.0 (the \"License\");\n5: you may not use this file except in compliance with the License.\n6: You may obtain a copy of the License at\n7: \n8:     http://www.apache.org/licenses/LICENSE-2.0\n9: \n10: Unless required by applicable law or agreed to in writing, software\n11: distributed under the License is distributed on an \"AS IS\" BASIS,\n12: WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n13: See the License for the specific language governing permissions and\n14: limitations under the License.\n15: */\n16: \n17: package store\n18: \n19: import (\n20: \t\"context\"\n21: \t\"errors\"\n22: \t\"time\"\n23: \n24: \t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n25: )\n26: \n27: // ErrNotFound is returned when a session is not found in the store.\n28: var ErrNotFound = errors.New(\"store: not found\")\n29: \n30: // Store defines the interface for session storage backends.\n31: // Implementations include Redis and Valkey providers.\n32: type Store interface {\n33: \t// Ping checks connectivity to the store.\n34: \tPing(ctx context.Context) error\n35: \n36: \t// GetSandboxBySessionID retrieves sandbox information by session ID.\n37: \t// Returns ErrNotFound if the session does not exist.\n38: \tGetSandboxBySessionID(ctx context.Context, sessionID string) (*types.SandboxInfo, error)\n39: \n40: \t// StoreSandbox stores sandbox information in the store.\n41: \tStoreSandbox(ctx context.Context, sandboxStore *types.SandboxInfo) error\n42: \n43: \t// UpdateSandbox updates existing sandbox information.\n44: \tUpdateSandbox(ctx context.Context, sandboxStore *types.SandboxInfo) error\n45: \n46: \t// DeleteSandboxBySessionID removes a sandbox from the store.\n47: \tDeleteSandboxBySessionID(ctx context.Context, sessionID string) error\n48: \n49: \t// ListExpiredSandboxes returns sandboxes that have expired before the given time.\n50: \tListExpiredSandboxes(ctx context.Context, before time.Time, limit int64) ([]*types.SandboxInfo, error)\n51: \n52: \t// ListInactiveSandboxes returns sandboxes inactive since before the given time.\n53: \tListInactiveSandboxes(ctx context.Context, before time.Time, limit int64) ([]*types.SandboxInfo, error)\n54: \n55: \t// UpdateSessionLastActivity updates the last activity timestamp for a session.\n56: \tUpdateSessionLastActivity(ctx context.Context, sessionID string, at time.Time) error\n57: \n58: \t// Close closes the store connection.\n59: \tClose() error\n60: }\n\n(End of file - total 60 lines)\n</content>","metadata":{"preview":"/*\nCopyright 2026 The Volcano Authors.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\npackage store\n\nimport (\n\t\"context\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/store/store.go","time":{"start":1775868284913,"end":1775868284943}}}}
{"type":"tool_use","timestamp":1775868284946,"sessionID":"ses_28600cab4ffep6L858aRhkgvHB","part":{"id":"prt_d79ff84b6001zeg9kGOs2Aeg8F","messageID":"msg_d79ff6361001DbC3439sIaoI3k","sessionID":"ses_28600cab4ffep6L858aRhkgvHB","type":"tool","tool":"read","callID":"toolu_functions.read:5","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/store/singleton.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/store/singleton.go</path>\n<type>file</type>\n<content>\n1: /*\n2: Copyright 2026 The Volcano Authors.\n3: \n4: Licensed under the Apache License, Version 2.0 (the \"License\");\n5: you may not use this file except in compliance with the License.\n6: You may obtain a copy of the License at\n7: \n8:     http://www.apache.org/licenses/LICENSE-2.0\n9: \n10: Unless required by applicable law or agreed to in writing, software\n11: distributed under the License is distributed on an \"AS IS\" BASIS,\n12: WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n13: See the License for the specific language governing permissions and\n14: limitations under the License.\n15: */\n16: \n17: package store\n18: \n19: import (\n20: \t\"fmt\"\n21: \t\"os\"\n22: \t\"strconv\"\n23: \t\"strings\"\n24: \t\"sync\"\n25: \n26: \t\"k8s.io/klog/v2\"\n27: )\n28: \n29: const (\n30: \tredisStoreType  string = \"redis\"\n31: \tvalkeyStoreType string = \"valkey\"\n32: \n33: \tsessionPrefix        string = \"session:\"\n34: \texpiryIndexKey       string = \"session:expiry\"\n35: \tlastActivityIndexKey string = \"session:last_activity\"\n36: )\n37: \n38: // redisOptions holds Redis connection configuration.\n39: type redisOptions struct {\n40: \tAddr     string\n41: \tPassword string\n42: }\n43: \n44: // valkeyOptions holds Valkey connection configuration.\n45: type valkeyOptions struct {\n46: \tInitAddress       []string\n47: \tPassword          string\n48: \tDisableCache      bool\n49: \tForceSingleClient bool\n50: }\n51: \n52: var (\n53: \tinitStoreOnce sync.Once\n54: \tstoreInstance Store\n55: \tinitError     error\n56: )\n57: \n58: // Storage returns the singleton Store instance.\n59: // Initializes on first call using sync.Once for thread safety.\n60: // Fatals via klog.Fatal if initialization fails.\n61: func Storage() Store {\n62: \tinitStoreOnce.Do(func() {\n63: \t\tstoreInstance, initError = initStore()\n64: \t\tif initError != nil {\n65: \t\t\tklog.Fatalf(\"init store failed: %v\", initError)\n66: \t\t}\n67: \t})\n68: \treturn storeInstance\n69: }\n70: \n71: // initStore creates the appropriate Store implementation based on STORE_TYPE env var.\n72: // Returns an error if the store type is unsupported or if required environment\n73: // variables are missing.\n74: func initStore() (Store, error) {\n75: \tstoreType := strings.ToLower(strings.TrimSpace(os.Getenv(\"STORE_TYPE\")))\n76: \tif storeType == \"\" {\n77: \t\tstoreType = redisStoreType\n78: \t}\n79: \n80: \tswitch storeType {\n81: \tcase redisStoreType:\n82: \t\treturn newRedisStore()\n83: \tcase valkeyStoreType:\n84: \t\treturn newValkeyStore()\n85: \tdefault:\n86: \t\treturn nil, fmt.Errorf(\"unsupported store type: %s (supported: redis, valkey)\", storeType)\n87: \t}\n88: }\n89: \n90: // makeRedisOptions creates redis.Options from environment variables.\n91: // Required: REDIS_ADDR\n92: // Required: REDIS_PASSWORD (unless REDIS_PASSWORD_REQUIRED=false)\n93: func makeRedisOptions() (*redisOptions, error) {\n94: \taddr := strings.TrimSpace(os.Getenv(\"REDIS_ADDR\"))\n95: \tif addr == \"\" {\n96: \t\treturn nil, fmt.Errorf(\"REDIS_ADDR is required\")\n97: \t}\n98: \n99: \tpassword := os.Getenv(\"REDIS_PASSWORD\")\n100: \tpasswordRequiredStr := strings.ToLower(strings.TrimSpace(os.Getenv(\"REDIS_PASSWORD_REQUIRED\")))\n101: \tpasswordRequired := true\n102: \tif passwordRequiredStr != \"\" {\n103: \t\tparsed, err := strconv.ParseBool(passwordRequiredStr)\n104: \t\tif err == nil {\n105: \t\t\tpasswordRequired = parsed\n106: \t\t}\n107: \t}\n108: \n109: \tif passwordRequired && password == \"\" {\n110: \t\treturn nil, fmt.Errorf(\"REDIS_PASSWORD is required (set REDIS_PASSWORD_REQUIRED=false to disable)\")\n111: \t}\n112: \n113: \treturn &redisOptions{\n114: \t\tAddr:     addr,\n115: \t\tPassword: password,\n116: \t}, nil\n117: }\n118: \n119: // makeValkeyOptions creates valkey.ClientOption from environment variables.\n120: // Required: VALKEY_ADDR (comma-separated addresses)\n121: // Required: VALKEY_PASSWORD (unless VALKEY_PASSWORD_REQUIRED=false)\n122: // Optional: VALKEY_DISABLE_CACHE, VALKEY_FORCE_SINGLE\n123: func makeValkeyOptions() (*valkeyOptions, error) {\n124: \taddrStr := strings.TrimSpace(os.Getenv(\"VALKEY_ADDR\"))\n125: \tif addrStr == \"\" {\n126: \t\treturn nil, fmt.Errorf(\"VALKEY_ADDR is required\")\n127: \t}\n128: \n129: \taddresses := strings.Split(addrStr, \",\")\n130: \tfor i, addr := range addresses {\n131: \t\taddresses[i] = strings.TrimSpace(addr)\n132: \t}\n133: \n134: \tpassword := os.Getenv(\"VALKEY_PASSWORD\")\n135: \tpasswordRequiredStr := strings.ToLower(strings.TrimSpace(os.Getenv(\"VALKEY_PASSWORD_REQUIRED\")))\n136: \tpasswordRequired := true\n137: \tif passwordRequiredStr != \"\" {\n138: \t\tparsed, err := strconv.ParseBool(passwordRequiredStr)\n139: \t\tif err == nil {\n140: \t\t\tpasswordRequired = parsed\n141: \t\t}\n142: \t}\n143: \n144: \tif passwordRequired && password == \"\" {\n145: \t\treturn nil, fmt.Errorf(\"VALKEY_PASSWORD is required (set VALKEY_PASSWORD_REQUIRED=false to disable)\")\n146: \t}\n147: \n148: \topts := &valkeyOptions{\n149: \t\tInitAddress: addresses,\n150: \t\tPassword:    password,\n151: \t}\n152: \n153: \tdisableCacheStr := strings.TrimSpace(os.Getenv(\"VALKEY_DISABLE_CACHE\"))\n154: \tif disableCacheStr != \"\" {\n155: \t\tparsed, err := strconv.ParseBool(disableCacheStr)\n156: \t\tif err == nil {\n157: \t\t\topts.DisableCache = parsed\n158: \t\t}\n159: \t}\n160: \n161: \tforceSingleStr := strings.TrimSpace(os.Getenv(\"VALKEY_FORCE_SINGLE\"))\n162: \tif forceSingleStr != \"\" {\n163: \t\tparsed, err := strconv.ParseBool(forceSingleStr)\n164: \t\tif err == nil {\n165: \t\t\topts.ForceSingleClient = parsed\n166: \t\t}\n167: \t}\n168: \n169: \treturn opts, nil\n170: }\n\n(End of file - total 170 lines)\n</content>","metadata":{"preview":"/*\nCopyright 2026 The Volcano Authors.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\npackage store\n\nimport (\n\t\"fmt\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/store/singleton.go","time":{"start":1775868284915,"end":1775868284945}}}}
