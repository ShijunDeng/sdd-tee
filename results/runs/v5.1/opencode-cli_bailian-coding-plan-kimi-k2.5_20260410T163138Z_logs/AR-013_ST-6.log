/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/store/redis_test.go\n+++ /home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/store/redis_test.go\n@@ -444,10 +444,10 @@\n if err != nil {\n \tt.Fatalf(\"ZScore() error = %v\", err)\n }\n \n-// Wait a bit to ensure different timestamp\n-time.Sleep(10 * time.Millisecond)\n+// Wait to ensure different Unix timestamp (ZAdd uses Unix() which is in seconds)\n+time.Sleep(1100 * time.Millisecond)\n \n // Update activity with zero time (should use Now)\n if err := s.UpdateSessionLastActivity(ctx, \"test-session\", time.Time{}); err != nil {\n \tt.Fatalf(\"UpdateSessionLastActivity() error = %v\", err)\n","filediff":{"file":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/store/redis_test.go","before":"/*\nCopyright 2026 The Volcano Authors.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\npackage store\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"os\"\n\t\"strings\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/alicebob/miniredis/v2\"\n\tredisv9 \"github.com/redis/go-redis/v9\"\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n)\n\n// setupTestRedis creates a new miniredis instance for testing.\nfunc setupTestRedis(t *testing.T) *miniredis.Miniredis {\n\treturn miniredis.RunT(t)\n}\n\n// createTestRedisStore creates a redisStore instance connected to the test server.\nfunc createTestRedisStore(t *testing.T, m *miniredis.Miniredis) *redisStore {\n\tclient := newRedisClient(m.Addr(), \"\")\n\treturn &redisStore{\n\t\tcli:                  client,\n\t\tsessionPrefix:        sessionPrefix,\n\t\texpiryIndexKey:       expiryIndexKey,\n\t\tlastActivityIndexKey: lastActivityIndexKey,\n\t}\n}\n\n// newRedisClient creates a redis client for testing.\nfunc newRedisClient(addr, password string) *redisv9.Client {\n\treturn redisv9.NewClient(&redisv9.Options{\n\t\tAddr:     addr,\n\t\tPassword: password,\n\t})\n}\n\n// createTestSandbox creates a test sandbox with the given sessionID.\nfunc createTestSandbox(sessionID string, expiresAt time.Time) *types.SandboxInfo {\n\treturn &types.SandboxInfo{\n\t\tKind:             \"AgentRuntime\",\n\t\tSandboxID:        fmt.Sprintf(\"sb-%s\", sessionID),\n\t\tSandboxNamespace: \"default\",\n\t\tName:             fmt.Sprintf(\"runtime-%s\", sessionID),\n\t\tEntryPoints: []types.SandboxEntryPoint{\n\t\t\t{\n\t\t\t\tPath:     \"/api\",\n\t\t\t\tProtocol: \"http\",\n\t\t\t\tEndpoint: \"localhost:8080\",\n\t\t\t},\n\t\t},\n\t\tSessionID: sessionID,\n\t\tCreatedAt: time.Now().UTC(),\n\t\tExpiresAt: expiresAt,\n\t\tStatus:    \"Running\",\n\t\tPodIP:     \"10.0.0.1\",\n\t\tPodName:   fmt.Sprintf(\"pod-%s\", sessionID),\n\t}\n}\n\nfunc TestRedisStore_Ping(t *testing.T) {\n\tm := setupTestRedis(t)\n\tdefer m.Close()\n\n\ts := createTestRedisStore(t, m)\n\tdefer s.Close()\n\n\tctx := context.Background()\n\terr := s.Ping(ctx)\n\tif err != nil {\n\t\tt.Fatalf(\"Ping() error = %v\", err)\n\t}\n}\n\nfunc TestRedisStore_Ping_Failure(t *testing.T) {\n\t// Create a client to a non-existent server\n\tclient := newRedisClient(\"localhost:63791\", \"\")\n\ts := &redisStore{\n\t\tcli:                  client,\n\t\tsessionPrefix:        sessionPrefix,\n\t\texpiryIndexKey:       expiryIndexKey,\n\t\tlastActivityIndexKey: lastActivityIndexKey,\n\t}\n\tdefer s.Close()\n\n\tctx, cancel := context.WithTimeout(context.Background(), 100*time.Millisecond)\n\tdefer cancel()\n\n\terr := s.Ping(ctx)\n\tif err == nil {\n\t\tt.Error(\"Ping() expected error for unreachable server\")\n\t}\n}\n\nfunc TestRedisStore_GetSandboxBySessionID(t *testing.T) {\n\tm := setupTestRedis(t)\n\tdefer m.Close()\n\n\ts := createTestRedisStore(t, m)\n\tdefer s.Close()\n\n\tctx := context.Background()\n\n\t// Test case: empty sessionID\n\t_, err := s.GetSandboxBySessionID(ctx, \"\")\n\tif err == nil {\n\t\tt.Error(\"GetSandboxBySessionID(\\\"\\\") expected error\")\n\t}\n\n\t// Test case: not found\n\t_, err = s.GetSandboxBySessionID(ctx, \"non-existent\")\n\tif !strings.Contains(err.Error(), \"not found\") && err != ErrNotFound {\n\t\tt.Errorf(\"GetSandboxBySessionID() expected ErrNotFound, got %v\", err)\n\t}\n\n\t// Store a sandbox first\n\tsandbox := createTestSandbox(\"test-session\", time.Now().Add(time.Hour))\n\tif err := s.StoreSandbox(ctx, sandbox); err != nil {\n\t\tt.Fatalf(\"StoreSandbox() error = %v\", err)\n\t}\n\n\t// Test case: found\n\tresult, err := s.GetSandboxBySessionID(ctx, \"test-session\")\n\tif err != nil {\n\t\tt.Fatalf(\"GetSandboxBySessionID() error = %v\", err)\n\t}\n\tif result.SessionID != sandbox.SessionID {\n\t\tt.Errorf(\"GetSandboxBySessionID() SessionID = %v, want %v\", result.SessionID, sandbox.SessionID)\n\t}\n}\n\nfunc TestRedisStore_StoreSandbox(t *testing.T) {\n\tm := setupTestRedis(t)\n\tdefer m.Close()\n\n\ts := createTestRedisStore(t, m)\n\tdefer s.Close()\n\n\tctx := context.Background()\n\n\t// Test case: nil sandbox\n\terr := s.StoreSandbox(ctx, nil)\n\tif err == nil {\n\t\tt.Error(\"StoreSandbox(nil) expected error\")\n\t}\n\n\t// Test case: empty sessionID\n\tsandbox := createTestSandbox(\"\", time.Now().Add(time.Hour))\n\terr = s.StoreSandbox(ctx, sandbox)\n\tif err == nil {\n\t\tt.Error(\"StoreSandbox() with empty sessionID expected error\")\n\t}\n\n\t// Test case: zero ExpiresAt\n\tsandbox = createTestSandbox(\"test-session\", time.Time{})\n\terr = s.StoreSandbox(ctx, sandbox)\n\tif err == nil {\n\t\tt.Error(\"StoreSandbox() with zero ExpiresAt expected error\")\n\t}\n\n\t// Test case: valid sandbox\n\tsandbox = createTestSandbox(\"test-session\", time.Now().Add(time.Hour))\n\tif err := s.StoreSandbox(ctx, sandbox); err != nil {\n\t\tt.Fatalf(\"StoreSandbox() error = %v\", err)\n\t}\n\n\t// Verify the sandbox was stored\n\tkey := s.sessionKey(\"test-session\")\n\tdata, err := m.Get(key)\n\tif err != nil {\n\t\tt.Fatalf(\"Failed to get stored data: %v\", err)\n\t}\n\n\tvar stored types.SandboxInfo\n\tif err := json.Unmarshal([]byte(data), &stored); err != nil {\n\t\tt.Fatalf(\"Failed to unmarshal stored data: %v\", err)\n\t}\n\tif stored.SessionID != sandbox.SessionID {\n\t\tt.Errorf(\"Stored SessionID = %v, want %v\", stored.SessionID, sandbox.SessionID)\n\t}\n\n\t// Verify indexes were created\n\texpiryScore, err := m.ZScore(s.expiryIndexKey, \"test-session\")\n\tif err != nil || expiryScore == 0 {\n\t\tt.Error(\"Expiry index not created\")\n\t}\n\n\tactivityScore, err := m.ZScore(s.lastActivityIndexKey, \"test-session\")\n\tif err != nil || activityScore == 0 {\n\t\tt.Error(\"Activity index not created\")\n\t}\n\n\t// Test case: duplicate session\n\terr = s.StoreSandbox(ctx, sandbox)\n\tif err == nil {\n\t\tt.Error(\"StoreSandbox() duplicate session expected error\")\n\t}\n}\n\nfunc TestRedisStore_UpdateSandbox(t *testing.T) {\n\tm := setupTestRedis(t)\n\tdefer m.Close()\n\n\ts := createTestRedisStore(t, m)\n\tdefer s.Close()\n\n\tctx := context.Background()\n\n\t// Test case: nil sandbox\n\terr := s.UpdateSandbox(ctx, nil)\n\tif err == nil {\n\t\tt.Error(\"UpdateSandbox(nil) expected error\")\n\t}\n\n\t// Test case: empty sessionID\n\tsandbox := createTestSandbox(\"\", time.Now().Add(time.Hour))\n\terr = s.UpdateSandbox(ctx, sandbox)\n\tif err == nil {\n\t\tt.Error(\"UpdateSandbox() with empty sessionID expected error\")\n\t}\n\n\t// Test case: non-existent sandbox\n\tsandbox = createTestSandbox(\"non-existent\", time.Now().Add(time.Hour))\n\terr = s.UpdateSandbox(ctx, sandbox)\n\tif err == nil {\n\t\tt.Error(\"UpdateSandbox() non-existent sandbox expected error\")\n\t}\n\n\t// Store a sandbox first\n\tsandbox = createTestSandbox(\"test-session\", time.Now().Add(time.Hour))\n\tif err := s.StoreSandbox(ctx, sandbox); err != nil {\n\t\tt.Fatalf(\"StoreSandbox() error = %v\", err)\n\t}\n\n\t// Update the sandbox\n\tsandbox.Status = \"Updated\"\n\tif err := s.UpdateSandbox(ctx, sandbox); err != nil {\n\t\tt.Fatalf(\"UpdateSandbox() error = %v\", err)\n\t}\n\n\t// Verify the update\n\tresult, err := s.GetSandboxBySessionID(ctx, \"test-session\")\n\tif err != nil {\n\t\tt.Fatalf(\"GetSandboxBySessionID() error = %v\", err)\n\t}\n\tif result.Status != \"Updated\" {\n\t\tt.Errorf(\"Status = %v, want Updated\", result.Status)\n\t}\n}\n\nfunc TestRedisStore_DeleteSandboxBySessionID(t *testing.T) {\n\tm := setupTestRedis(t)\n\tdefer m.Close()\n\n\ts := createTestRedisStore(t, m)\n\tdefer s.Close()\n\n\tctx := context.Background()\n\n\t// Test case: empty sessionID\n\terr := s.DeleteSandboxBySessionID(ctx, \"\")\n\tif err == nil {\n\t\tt.Error(\"DeleteSandboxBySessionID(\\\"\\\") expected error\")\n\t}\n\n\t// Store a sandbox first\n\tsandbox := createTestSandbox(\"test-session\", time.Now().Add(time.Hour))\n\tif err := s.StoreSandbox(ctx, sandbox); err != nil {\n\t\tt.Fatalf(\"StoreSandbox() error = %v\", err)\n\t}\n\n\t// Delete the sandbox\n\tif err := s.DeleteSandboxBySessionID(ctx, \"test-session\"); err != nil {\n\t\tt.Fatalf(\"DeleteSandboxBySessionID() error = %v\", err)\n\t}\n\n\t// Verify deletion\n\t_, err = s.GetSandboxBySessionID(ctx, \"test-session\")\n\tif err == nil {\n\t\tt.Error(\"GetSandboxBySessionID() after delete expected error\")\n\t}\n\n\t// Verify indexes were removed\n\t_, err = m.ZScore(s.expiryIndexKey, \"test-session\")\n\tif err == nil {\n\t\tt.Error(\"Expiry index not removed\")\n\t}\n\t_, err = m.ZScore(s.lastActivityIndexKey, \"test-session\")\n\tif err == nil {\n\t\tt.Error(\"Activity index not removed\")\n\t}\n\n\t// Test case: delete non-existent (idempotent)\n\terr = s.DeleteSandboxBySessionID(ctx, \"non-existent\")\n\tif err != nil {\n\t\tt.Errorf(\"DeleteSandboxBySessionID() non-existent expected no error, got %v\", err)\n\t}\n}\n\nfunc TestRedisStore_ListExpiredSandboxes(t *testing.T) {\n\tm := setupTestRedis(t)\n\tdefer m.Close()\n\n\ts := createTestRedisStore(t, m)\n\tdefer s.Close()\n\n\tctx := context.Background()\n\tnow := time.Now()\n\n\t// Test case: limit <= 0\n\tresult, err := s.ListExpiredSandboxes(ctx, now, 0)\n\tif err != nil {\n\t\tt.Fatalf(\"ListExpiredSandboxes() error = %v\", err)\n\t}\n\tif result != nil {\n\t\tt.Error(\"ListExpiredSandboxes() with limit=0 expected nil\")\n\t}\n\n\t// Store expired sandboxes\n\tsandbox1 := createTestSandbox(\"expired-1\", now.Add(-time.Hour))\n\tsandbox2 := createTestSandbox(\"expired-2\", now.Add(-30*time.Minute))\n\tsandbox3 := createTestSandbox(\"active-1\", now.Add(time.Hour))\n\n\tif err := s.StoreSandbox(ctx, sandbox1); err != nil {\n\t\tt.Fatalf(\"StoreSandbox() error = %v\", err)\n\t}\n\tif err := s.StoreSandbox(ctx, sandbox2); err != nil {\n\t\tt.Fatalf(\"StoreSandbox() error = %v\", err)\n\t}\n\tif err := s.StoreSandbox(ctx, sandbox3); err != nil {\n\t\tt.Fatalf(\"StoreSandbox() error = %v\", err)\n\t}\n\n\t// List expired sandboxes\n\texpired, err := s.ListExpiredSandboxes(ctx, now, 10)\n\tif err != nil {\n\t\tt.Fatalf(\"ListExpiredSandboxes() error = %v\", err)\n\t}\n\n\tif len(expired) != 2 {\n\t\tt.Errorf(\"ListExpiredSandboxes() returned %d sandboxes, want 2\", len(expired))\n\t}\n\n\t// Test with limit\n\texpiredLimited, err := s.ListExpiredSandboxes(ctx, now, 1)\n\tif err != nil {\n\t\tt.Fatalf(\"ListExpiredSandboxes() error = %v\", err)\n\t}\n\tif len(expiredLimited) != 1 {\n\t\tt.Errorf(\"ListExpiredSandboxes() with limit=1 returned %d sandboxes, want 1\", len(expiredLimited))\n\t}\n}\n\nfunc TestRedisStore_ListInactiveSandboxes(t *testing.T) {\n\tm := setupTestRedis(t)\n\tdefer m.Close()\n\n\ts := createTestRedisStore(t, m)\n\tdefer s.Close()\n\n\tctx := context.Background()\n\tnow := time.Now()\n\n\t// Test case: limit <= 0\n\tresult, err := s.ListInactiveSandboxes(ctx, now, 0)\n\tif err != nil {\n\t\tt.Fatalf(\"ListInactiveSandboxes() error = %v\", err)\n\t}\n\tif result != nil {\n\t\tt.Error(\"ListInactiveSandboxes() with limit=0 expected nil\")\n\t}\n\n\t// Store sandbox and update activity\n\tsandbox := createTestSandbox(\"test-session\", now.Add(time.Hour))\n\tif err := s.StoreSandbox(ctx, sandbox); err != nil {\n\t\tt.Fatalf(\"StoreSandbox() error = %v\", err)\n\t}\n\n\t// Manually set activity to past time by manipulating the sorted set\n\t// (since StoreSandbox sets activity to now)\n\tm.ZRem(s.lastActivityIndexKey, \"test-session\")\n\tm.ZAdd(s.lastActivityIndexKey, float64(now.Add(-time.Hour).Unix()), \"test-session\")\n\n\t// List inactive sandboxes\n\tinactive, err := s.ListInactiveSandboxes(ctx, now.Add(-30*time.Minute), 10)\n\tif err != nil {\n\t\tt.Fatalf(\"ListInactiveSandboxes() error = %v\", err)\n\t}\n\n\tif len(inactive) != 1 {\n\t\tt.Errorf(\"ListInactiveSandboxes() returned %d sandboxes, want 1\", len(inactive))\n\t}\n}\n\nfunc TestRedisStore_UpdateSessionLastActivity(t *testing.T) {\n\tm := setupTestRedis(t)\n\tdefer m.Close()\n\n\ts := createTestRedisStore(t, m)\n\tdefer s.Close()\n\n\tctx := context.Background()\n\tnow := time.Now()\n\n\t// Test case: empty sessionID\n\terr := s.UpdateSessionLastActivity(ctx, \"\", now)\n\tif err == nil {\n\t\tt.Error(\"UpdateSessionLastActivity(\\\"\\\") expected error\")\n\t}\n\n\t// Test case: non-existent session\n\terr = s.UpdateSessionLastActivity(ctx, \"non-existent\", now)\n\tif err == nil {\n\t\tt.Error(\"UpdateSessionLastActivity() non-existent expected error\")\n\t}\n\n\t// Store a sandbox first\n\tsandbox := createTestSandbox(\"test-session\", now.Add(time.Hour))\n\tif err := s.StoreSandbox(ctx, sandbox); err != nil {\n\t\tt.Fatalf(\"StoreSandbox() error = %v\", err)\n\t}\n\n\t// Get initial activity score\n\tinitialScore, err := m.ZScore(s.lastActivityIndexKey, \"test-session\")\n\tif err != nil {\n\t\tt.Fatalf(\"ZScore() error = %v\", err)\n\t}\n\n\t// Wait a bit to ensure different timestamp\n\ttime.Sleep(10 * time.Millisecond)\n\n\t// Update activity with zero time (should use Now)\n\tif err := s.UpdateSessionLastActivity(ctx, \"test-session\", time.Time{}); err != nil {\n\t\tt.Fatalf(\"UpdateSessionLastActivity() error = %v\", err)\n\t}\n\n\t// Verify activity was updated\n\tnewScore, err := m.ZScore(s.lastActivityIndexKey, \"test-session\")\n\tif err != nil {\n\t\tt.Fatalf(\"ZScore() error = %v\", err)\n\t}\n\tif newScore <= initialScore {\n\t\tt.Error(\"Activity timestamp was not updated\")\n\t}\n\n\t// Update activity with specific time\n\tfuture := now.Add(time.Hour)\n\tif err := s.UpdateSessionLastActivity(ctx, \"test-session\", future); err != nil {\n\t\tt.Fatalf(\"UpdateSessionLastActivity() error = %v\", err)\n\t}\n\n\t// Verify specific time was used\n\tscore, err := m.ZScore(s.lastActivityIndexKey, \"test-session\")\n\tif err != nil {\n\t\tt.Fatalf(\"ZScore() error = %v\", err)\n\t}\n\tif score != float64(future.Unix()) {\n\t\tt.Errorf(\"Activity timestamp = %v, want %v\", score, float64(future.Unix()))\n\t}\n}\n\nfunc TestRedisStore_Close(t *testing.T) {\n\tm := setupTestRedis(t)\n\tdefer m.Close()\n\n\ts := createTestRedisStore(t, m)\n\n\terr := s.Close()\n\tif err != nil {\n\t\tt.Errorf(\"Close() error = %v\", err)\n\t}\n}\n\nfunc TestRedisStore_LoadSandboxesBySessionIDs(t *testing.T) {\n\tm := setupTestRedis(t)\n\tdefer m.Close()\n\n\ts := createTestRedisStore(t, m)\n\tdefer s.Close()\n\n\tctx := context.Background()\n\n\t// Test case: empty sessionIDs\n\tresult, err := s.loadSandboxesBySessionIDs(ctx, []string{})\n\tif err != nil {\n\t\tt.Fatalf(\"loadSandboxesBySessionIDs() error = %v\", err)\n\t}\n\tif len(result) != 0 {\n\t\tt.Errorf(\"loadSandboxesBySessionIDs() returned %d sandboxes, want 0\", len(result))\n\t}\n\n\t// Store multiple sandboxes\n\tsandbox1 := createTestSandbox(\"session-1\", time.Now().Add(time.Hour))\n\tsandbox2 := createTestSandbox(\"session-2\", time.Now().Add(time.Hour))\n\n\tif err := s.StoreSandbox(ctx, sandbox1); err != nil {\n\t\tt.Fatalf(\"StoreSandbox() error = %v\", err)\n\t}\n\tif err := s.StoreSandbox(ctx, sandbox2); err != nil {\n\t\tt.Fatalf(\"StoreSandbox() error = %v\", err)\n\t}\n\n\t// Load by session IDs\n\tsessionIDs := []string{\"session-1\", \"session-2\", \"non-existent\"}\n\tsandboxes, err := s.loadSandboxesBySessionIDs(ctx, sessionIDs)\n\tif err != nil {\n\t\tt.Fatalf(\"loadSandboxesBySessionIDs() error = %v\", err)\n\t}\n\tif len(sandboxes) != 2 {\n\t\tt.Errorf(\"loadSandboxesBySessionIDs() returned %d sandboxes, want 2\", len(sandboxes))\n\t}\n}\n\nfunc TestRedisStore_LoadSandboxesWithOrphanedIndex(t *testing.T) {\n\tm := setupTestRedis(t)\n\tdefer m.Close()\n\n\ts := createTestRedisStore(t, m)\n\tdefer s.Close()\n\n\tctx := context.Background()\n\n\t// Store a sandbox\n\tsandbox := createTestSandbox(\"test-session\", time.Now().Add(time.Hour))\n\tif err := s.StoreSandbox(ctx, sandbox); err != nil {\n\t\tt.Fatalf(\"StoreSandbox() error = %v\", err)\n\t}\n\n\t// Delete the session data but keep the index (simulate orphaned index)\n\tm.Del(s.sessionKey(\"test-session\"))\n\n\t// List expired sandboxes should handle orphaned entries gracefully\n\texpired, err := s.ListExpiredSandboxes(ctx, time.Now().Add(time.Hour*2), 10)\n\tif err != nil {\n\t\tt.Fatalf(\"ListExpiredSandboxes() error = %v\", err)\n\t}\n\tif len(expired) != 0 {\n\t\tt.Errorf(\"ListExpiredSandboxes() returned %d sandboxes, want 0 (orphaned entries should be skipped)\", len(expired))\n\t}\n}\n\nfunc TestRedisStore_SessionKey(t *testing.T) {\n\ts := &redisStore{\n\t\tsessionPrefix: \"session:\",\n\t}\n\n\tkey := s.sessionKey(\"test-id\")\n\tif key != \"session:test-id\" {\n\t\tt.Errorf(\"sessionKey() = %v, want session:test-id\", key)\n\t}\n}\n\nfunc TestMakeRedisOptions(t *testing.T) {\n\t// Clean up environment after test\n\toriginalAddr := os.Getenv(\"REDIS_ADDR\")\n\toriginalPassword := os.Getenv(\"REDIS_PASSWORD\")\n\toriginalRequired := os.Getenv(\"REDIS_PASSWORD_REQUIRED\")\n\tdefer func() {\n\t\tos.Setenv(\"REDIS_ADDR\", originalAddr)\n\t\tos.Setenv(\"REDIS_PASSWORD\", originalPassword)\n\t\tos.Setenv(\"REDIS_PASSWORD_REQUIRED\", originalRequired)\n\t}()\n\n\t// Test case: missing REDIS_ADDR\n\tos.Unsetenv(\"REDIS_ADDR\")\n\tos.Setenv(\"REDIS_PASSWORD\", \"secret\")\n\t_, err := makeRedisOptions()\n\tif err == nil {\n\t\tt.Error(\"makeRedisOptions() without REDIS_ADDR expected error\")\n\t}\n\n\t// Test case: missing REDIS_PASSWORD when required\n\tos.Setenv(\"REDIS_ADDR\", \"localhost:6379\")\n\tos.Setenv(\"REDIS_PASSWORD\", \"\")\n\tos.Unsetenv(\"REDIS_PASSWORD_REQUIRED\")\n\t_, err = makeRedisOptions()\n\tif err == nil {\n\t\tt.Error(\"makeRedisOptions() without password when required expected error\")\n\t}\n\n\t// Test case: password not required\n\tos.Setenv(\"REDIS_ADDR\", \"localhost:6379\")\n\tos.Setenv(\"REDIS_PASSWORD\", \"\")\n\tos.Setenv(\"REDIS_PASSWORD_REQUIRED\", \"false\")\n\topts, err := makeRedisOptions()\n\tif err != nil {\n\t\tt.Fatalf(\"makeRedisOptions() error = %v\", err)\n\t}\n\tif opts.Addr != \"localhost:6379\" {\n\t\tt.Errorf(\"Addr = %v, want localhost:6379\", opts.Addr)\n\t}\n\tif opts.Password != \"\" {\n\t\tt.Errorf(\"Password = %v, want empty\", opts.Password)\n\t}\n\n\t// Test case: password required and provided\n\tos.Setenv(\"REDIS_ADDR\", \"redis:6379\")\n\tos.Setenv(\"REDIS_PASSWORD\", \"mysecret\")\n\tos.Setenv(\"REDIS_PASSWORD_REQUIRED\", \"true\")\n\topts, err = makeRedisOptions()\n\tif err != nil {\n\t\tt.Fatalf(\"makeRedisOptions() error = %v\", err)\n\t}\n\tif opts.Addr != \"redis:6379\" {\n\t\tt.Errorf(\"Addr = %v, want redis:6379\", opts.Addr)\n\t}\n\tif opts.Password != \"mysecret\" {\n\t\tt.Errorf(\"Password = %v, want mysecret\", opts.Password)\n\t}\n\n\t// Test case: whitespace trimming\n\tos.Setenv(\"REDIS_ADDR\", \"  localhost:6379  \")\n\tos.Setenv(\"REDIS_PASSWORD\", \"  secret  \")\n\topts, err = makeRedisOptions()\n\tif err != nil {\n\t\tt.Fatalf(\"makeRedisOptions() error = %v\", err)\n\t}\n\tif opts.Addr != \"localhost:6379\" {\n\t\tt.Errorf(\"Addr = %v, want localhost:6379 (trimmed)\", opts.Addr)\n\t}\n\tif opts.Password != \"  secret  \" {\n\t\tt.Errorf(\"Password = %v, want \\\"  secret  \\\" (not trimmed)\", opts.Password)\n\t}\n}\n\nfunc TestMakeRedisOptions_InvalidBool(t *testing.T) {\n\t// Clean up environment after test\n\toriginalAddr := os.Getenv(\"REDIS_ADDR\")\n\toriginalRequired := os.Getenv(\"REDIS_PASSWORD_REQUIRED\")\n\tdefer func() {\n\t\tos.Setenv(\"REDIS_ADDR\", originalAddr)\n\t\tos.Setenv(\"REDIS_PASSWORD_REQUIRED\", originalRequired)\n\t}()\n\n\tos.Setenv(\"REDIS_ADDR\", \"localhost:6379\")\n\tos.Setenv(\"REDIS_PASSWORD\", \"secret\")\n\tos.Setenv(\"REDIS_PASSWORD_REQUIRED\", \"invalid\")\n\n\t// Should use default (true) when parsing fails\n\t_, err := makeRedisOptions()\n\tif err != nil {\n\t\tt.Errorf(\"makeRedisOptions() with invalid bool should use default, got error: %v\", err)\n\t}\n}\n\nfunc TestNewRedisStore(t *testing.T) {\n\tm := setupTestRedis(t)\n\tdefer m.Close()\n\n\t// Clean up environment after test\n\toriginalAddr := os.Getenv(\"REDIS_ADDR\")\n\tdefer func() {\n\t\tos.Setenv(\"REDIS_ADDR\", originalAddr)\n\t}()\n\n\tos.Setenv(\"REDIS_ADDR\", m.Addr())\n\tos.Setenv(\"REDIS_PASSWORD\", \"\")\n\tos.Setenv(\"REDIS_PASSWORD_REQUIRED\", \"false\")\n\n\tstore, err := newRedisStore()\n\tif err != nil {\n\t\tt.Fatalf(\"newRedisStore() error = %v\", err)\n\t}\n\tif store == nil {\n\t\tt.Fatal(\"newRedisStore() returned nil\")\n\t}\n\tdefer store.Close()\n\n\t// Test that it implements Store interface\n\tvar _ Store = store\n}\n\nfunc TestNewRedisStore_MissingAddr(t *testing.T) {\n\t// Clean up environment\n\toriginalAddr := os.Getenv(\"REDIS_ADDR\")\n\tdefer func() {\n\t\tos.Setenv(\"REDIS_ADDR\", originalAddr)\n\t}()\n\n\tos.Unsetenv(\"REDIS_ADDR\")\n\n\t_, err := newRedisStore()\n\tif err == nil {\n\t\tt.Error(\"newRedisStore() without REDIS_ADDR expected error\")\n\t}\n}\n","after":"/*\nCopyright 2026 The Volcano Authors.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\npackage store\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"os\"\n\t\"strings\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/alicebob/miniredis/v2\"\n\tredisv9 \"github.com/redis/go-redis/v9\"\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n)\n\n// setupTestRedis creates a new miniredis instance for testing.\nfunc setupTestRedis(t *testing.T) *miniredis.Miniredis {\n\treturn miniredis.RunT(t)\n}\n\n// createTestRedisStore creates a redisStore instance connected to the test server.\nfunc createTestRedisStore(t *testing.T, m *miniredis.Miniredis) *redisStore {\n\tclient := newRedisClient(m.Addr(), \"\")\n\treturn &redisStore{\n\t\tcli:                  client,\n\t\tsessionPrefix:        sessionPrefix,\n\t\texpiryIndexKey:       expiryIndexKey,\n\t\tlastActivityIndexKey: lastActivityIndexKey,\n\t}\n}\n\n// newRedisClient creates a redis client for testing.\nfunc newRedisClient(addr, password string) *redisv9.Client {\n\treturn redisv9.NewClient(&redisv9.Options{\n\t\tAddr:     addr,\n\t\tPassword: password,\n\t})\n}\n\n// createTestSandbox creates a test sandbox with the given sessionID.\nfunc createTestSandbox(sessionID string, expiresAt time.Time) *types.SandboxInfo {\n\treturn &types.SandboxInfo{\n\t\tKind:             \"AgentRuntime\",\n\t\tSandboxID:        fmt.Sprintf(\"sb-%s\", sessionID),\n\t\tSandboxNamespace: \"default\",\n\t\tName:             fmt.Sprintf(\"runtime-%s\", sessionID),\n\t\tEntryPoints: []types.SandboxEntryPoint{\n\t\t\t{\n\t\t\t\tPath:     \"/api\",\n\t\t\t\tProtocol: \"http\",\n\t\t\t\tEndpoint: \"localhost:8080\",\n\t\t\t},\n\t\t},\n\t\tSessionID: sessionID,\n\t\tCreatedAt: time.Now().UTC(),\n\t\tExpiresAt: expiresAt,\n\t\tStatus:    \"Running\",\n\t\tPodIP:     \"10.0.0.1\",\n\t\tPodName:   fmt.Sprintf(\"pod-%s\", sessionID),\n\t}\n}\n\nfunc TestRedisStore_Ping(t *testing.T) {\n\tm := setupTestRedis(t)\n\tdefer m.Close()\n\n\ts := createTestRedisStore(t, m)\n\tdefer s.Close()\n\n\tctx := context.Background()\n\terr := s.Ping(ctx)\n\tif err != nil {\n\t\tt.Fatalf(\"Ping() error = %v\", err)\n\t}\n}\n\nfunc TestRedisStore_Ping_Failure(t *testing.T) {\n\t// Create a client to a non-existent server\n\tclient := newRedisClient(\"localhost:63791\", \"\")\n\ts := &redisStore{\n\t\tcli:                  client,\n\t\tsessionPrefix:        sessionPrefix,\n\t\texpiryIndexKey:       expiryIndexKey,\n\t\tlastActivityIndexKey: lastActivityIndexKey,\n\t}\n\tdefer s.Close()\n\n\tctx, cancel := context.WithTimeout(context.Background(), 100*time.Millisecond)\n\tdefer cancel()\n\n\terr := s.Ping(ctx)\n\tif err == nil {\n\t\tt.Error(\"Ping() expected error for unreachable server\")\n\t}\n}\n\nfunc TestRedisStore_GetSandboxBySessionID(t *testing.T) {\n\tm := setupTestRedis(t)\n\tdefer m.Close()\n\n\ts := createTestRedisStore(t, m)\n\tdefer s.Close()\n\n\tctx := context.Background()\n\n\t// Test case: empty sessionID\n\t_, err := s.GetSandboxBySessionID(ctx, \"\")\n\tif err == nil {\n\t\tt.Error(\"GetSandboxBySessionID(\\\"\\\") expected error\")\n\t}\n\n\t// Test case: not found\n\t_, err = s.GetSandboxBySessionID(ctx, \"non-existent\")\n\tif !strings.Contains(err.Error(), \"not found\") && err != ErrNotFound {\n\t\tt.Errorf(\"GetSandboxBySessionID() expected ErrNotFound, got %v\", err)\n\t}\n\n\t// Store a sandbox first\n\tsandbox := createTestSandbox(\"test-session\", time.Now().Add(time.Hour))\n\tif err := s.StoreSandbox(ctx, sandbox); err != nil {\n\t\tt.Fatalf(\"StoreSandbox() error = %v\", err)\n\t}\n\n\t// Test case: found\n\tresult, err := s.GetSandboxBySessionID(ctx, \"test-session\")\n\tif err != nil {\n\t\tt.Fatalf(\"GetSandboxBySessionID() error = %v\", err)\n\t}\n\tif result.SessionID != sandbox.SessionID {\n\t\tt.Errorf(\"GetSandboxBySessionID() SessionID = %v, want %v\", result.SessionID, sandbox.SessionID)\n\t}\n}\n\nfunc TestRedisStore_StoreSandbox(t *testing.T) {\n\tm := setupTestRedis(t)\n\tdefer m.Close()\n\n\ts := createTestRedisStore(t, m)\n\tdefer s.Close()\n\n\tctx := context.Background()\n\n\t// Test case: nil sandbox\n\terr := s.StoreSandbox(ctx, nil)\n\tif err == nil {\n\t\tt.Error(\"StoreSandbox(nil) expected error\")\n\t}\n\n\t// Test case: empty sessionID\n\tsandbox := createTestSandbox(\"\", time.Now().Add(time.Hour))\n\terr = s.StoreSandbox(ctx, sandbox)\n\tif err == nil {\n\t\tt.Error(\"StoreSandbox() with empty sessionID expected error\")\n\t}\n\n\t// Test case: zero ExpiresAt\n\tsandbox = createTestSandbox(\"test-session\", time.Time{})\n\terr = s.StoreSandbox(ctx, sandbox)\n\tif err == nil {\n\t\tt.Error(\"StoreSandbox() with zero ExpiresAt expected error\")\n\t}\n\n\t// Test case: valid sandbox\n\tsandbox = createTestSandbox(\"test-session\", time.Now().Add(time.Hour))\n\tif err := s.StoreSandbox(ctx, sandbox); err != nil {\n\t\tt.Fatalf(\"StoreSandbox() error = %v\", err)\n\t}\n\n\t// Verify the sandbox was stored\n\tkey := s.sessionKey(\"test-session\")\n\tdata, err := m.Get(key)\n\tif err != nil {\n\t\tt.Fatalf(\"Failed to get stored data: %v\", err)\n\t}\n\n\tvar stored types.SandboxInfo\n\tif err := json.Unmarshal([]byte(data), &stored); err != nil {\n\t\tt.Fatalf(\"Failed to unmarshal stored data: %v\", err)\n\t}\n\tif stored.SessionID != sandbox.SessionID {\n\t\tt.Errorf(\"Stored SessionID = %v, want %v\", stored.SessionID, sandbox.SessionID)\n\t}\n\n\t// Verify indexes were created\n\texpiryScore, err := m.ZScore(s.expiryIndexKey, \"test-session\")\n\tif err != nil || expiryScore == 0 {\n\t\tt.Error(\"Expiry index not created\")\n\t}\n\n\tactivityScore, err := m.ZScore(s.lastActivityIndexKey, \"test-session\")\n\tif err != nil || activityScore == 0 {\n\t\tt.Error(\"Activity index not created\")\n\t}\n\n\t// Test case: duplicate session\n\terr = s.StoreSandbox(ctx, sandbox)\n\tif err == nil {\n\t\tt.Error(\"StoreSandbox() duplicate session expected error\")\n\t}\n}\n\nfunc TestRedisStore_UpdateSandbox(t *testing.T) {\n\tm := setupTestRedis(t)\n\tdefer m.Close()\n\n\ts := createTestRedisStore(t, m)\n\tdefer s.Close()\n\n\tctx := context.Background()\n\n\t// Test case: nil sandbox\n\terr := s.UpdateSandbox(ctx, nil)\n\tif err == nil {\n\t\tt.Error(\"UpdateSandbox(nil) expected error\")\n\t}\n\n\t// Test case: empty sessionID\n\tsandbox := createTestSandbox(\"\", time.Now().Add(time.Hour))\n\terr = s.UpdateSandbox(ctx, sandbox)\n\tif err == nil {\n\t\tt.Error(\"UpdateSandbox() with empty sessionID expected error\")\n\t}\n\n\t// Test case: non-existent sandbox\n\tsandbox = createTestSandbox(\"non-existent\", time.Now().Add(time.Hour))\n\terr = s.UpdateSandbox(ctx, sandbox)\n\tif err == nil {\n\t\tt.Error(\"UpdateSandbox() non-existent sandbox expected error\")\n\t}\n\n\t// Store a sandbox first\n\tsandbox = createTestSandbox(\"test-session\", time.Now().Add(time.Hour))\n\tif err := s.StoreSandbox(ctx, sandbox); err != nil {\n\t\tt.Fatalf(\"StoreSandbox() error = %v\", err)\n\t}\n\n\t// Update the sandbox\n\tsandbox.Status = \"Updated\"\n\tif err := s.UpdateSandbox(ctx, sandbox); err != nil {\n\t\tt.Fatalf(\"UpdateSandbox() error = %v\", err)\n\t}\n\n\t// Verify the update\n\tresult, err := s.GetSandboxBySessionID(ctx, \"test-session\")\n\tif err != nil {\n\t\tt.Fatalf(\"GetSandboxBySessionID() error = %v\", err)\n\t}\n\tif result.Status != \"Updated\" {\n\t\tt.Errorf(\"Status = %v, want Updated\", result.Status)\n\t}\n}\n\nfunc TestRedisStore_DeleteSandboxBySessionID(t *testing.T) {\n\tm := setupTestRedis(t)\n\tdefer m.Close()\n\n\ts := createTestRedisStore(t, m)\n\tdefer s.Close()\n\n\tctx := context.Background()\n\n\t// Test case: empty sessionID\n\terr := s.DeleteSandboxBySessionID(ctx, \"\")\n\tif err == nil {\n\t\tt.Error(\"DeleteSandboxBySessionID(\\\"\\\") expected error\")\n\t}\n\n\t// Store a sandbox first\n\tsandbox := createTestSandbox(\"test-session\", time.Now().Add(time.Hour))\n\tif err := s.StoreSandbox(ctx, sandbox); err != nil {\n\t\tt.Fatalf(\"StoreSandbox() error = %v\", err)\n\t}\n\n\t// Delete the sandbox\n\tif err := s.DeleteSandboxBySessionID(ctx, \"test-session\"); err != nil {\n\t\tt.Fatalf(\"DeleteSandboxBySessionID() error = %v\", err)\n\t}\n\n\t// Verify deletion\n\t_, err = s.GetSandboxBySessionID(ctx, \"test-session\")\n\tif err == nil {\n\t\tt.Error(\"GetSandboxBySessionID() after delete expected error\")\n\t}\n\n\t// Verify indexes were removed\n\t_, err = m.ZScore(s.expiryIndexKey, \"test-session\")\n\tif err == nil {\n\t\tt.Error(\"Expiry index not removed\")\n\t}\n\t_, err = m.ZScore(s.lastActivityIndexKey, \"test-session\")\n\tif err == nil {\n\t\tt.Error(\"Activity index not removed\")\n\t}\n\n\t// Test case: delete non-existent (idempotent)\n\terr = s.DeleteSandboxBySessionID(ctx, \"non-existent\")\n\tif err != nil {\n\t\tt.Errorf(\"DeleteSandboxBySessionID() non-existent expected no error, got %v\", err)\n\t}\n}\n\nfunc TestRedisStore_ListExpiredSandboxes(t *testing.T) {\n\tm := setupTestRedis(t)\n\tdefer m.Close()\n\n\ts := createTestRedisStore(t, m)\n\tdefer s.Close()\n\n\tctx := context.Background()\n\tnow := time.Now()\n\n\t// Test case: limit <= 0\n\tresult, err := s.ListExpiredSandboxes(ctx, now, 0)\n\tif err != nil {\n\t\tt.Fatalf(\"ListExpiredSandboxes() error = %v\", err)\n\t}\n\tif result != nil {\n\t\tt.Error(\"ListExpiredSandboxes() with limit=0 expected nil\")\n\t}\n\n\t// Store expired sandboxes\n\tsandbox1 := createTestSandbox(\"expired-1\", now.Add(-time.Hour))\n\tsandbox2 := createTestSandbox(\"expired-2\", now.Add(-30*time.Minute))\n\tsandbox3 := createTestSandbox(\"active-1\", now.Add(time.Hour))\n\n\tif err := s.StoreSandbox(ctx, sandbox1); err != nil {\n\t\tt.Fatalf(\"StoreSandbox() error = %v\", err)\n\t}\n\tif err := s.StoreSandbox(ctx, sandbox2); err != nil {\n\t\tt.Fatalf(\"StoreSandbox() error = %v\", err)\n\t}\n\tif err := s.StoreSandbox(ctx, sandbox3); err != nil {\n\t\tt.Fatalf(\"StoreSandbox() error = %v\", err)\n\t}\n\n\t// List expired sandboxes\n\texpired, err := s.ListExpiredSandboxes(ctx, now, 10)\n\tif err != nil {\n\t\tt.Fatalf(\"ListExpiredSandboxes() error = %v\", err)\n\t}\n\n\tif len(expired) != 2 {\n\t\tt.Errorf(\"ListExpiredSandboxes() returned %d sandboxes, want 2\", len(expired))\n\t}\n\n\t// Test with limit\n\texpiredLimited, err := s.ListExpiredSandboxes(ctx, now, 1)\n\tif err != nil {\n\t\tt.Fatalf(\"ListExpiredSandboxes() error = %v\", err)\n\t}\n\tif len(expiredLimited) != 1 {\n\t\tt.Errorf(\"ListExpiredSandboxes() with limit=1 returned %d sandboxes, want 1\", len(expiredLimited))\n\t}\n}\n\nfunc TestRedisStore_ListInactiveSandboxes(t *testing.T) {\n\tm := setupTestRedis(t)\n\tdefer m.Close()\n\n\ts := createTestRedisStore(t, m)\n\tdefer s.Close()\n\n\tctx := context.Background()\n\tnow := time.Now()\n\n\t// Test case: limit <= 0\n\tresult, err := s.ListInactiveSandboxes(ctx, now, 0)\n\tif err != nil {\n\t\tt.Fatalf(\"ListInactiveSandboxes() error = %v\", err)\n\t}\n\tif result != nil {\n\t\tt.Error(\"ListInactiveSandboxes() with limit=0 expected nil\")\n\t}\n\n\t// Store sandbox and update activity\n\tsandbox := createTestSandbox(\"test-session\", now.Add(time.Hour))\n\tif err := s.StoreSandbox(ctx, sandbox); err != nil {\n\t\tt.Fatalf(\"StoreSandbox() error = %v\", err)\n\t}\n\n\t// Manually set activity to past time by manipulating the sorted set\n\t// (since StoreSandbox sets activity to now)\n\tm.ZRem(s.lastActivityIndexKey, \"test-session\")\n\tm.ZAdd(s.lastActivityIndexKey, float64(now.Add(-time.Hour).Unix()), \"test-session\")\n\n\t// List inactive sandboxes\n\tinactive, err := s.ListInactiveSandboxes(ctx, now.Add(-30*time.Minute), 10)\n\tif err != nil {\n\t\tt.Fatalf(\"ListInactiveSandboxes() error = %v\", err)\n\t}\n\n\tif len(inactive) != 1 {\n\t\tt.Errorf(\"ListInactiveSandboxes() returned %d sandboxes, want 1\", len(inactive))\n\t}\n}\n\nfunc TestRedisStore_UpdateSessionLastActivity(t *testing.T) {\n\tm := setupTestRedis(t)\n\tdefer m.Close()\n\n\ts := createTestRedisStore(t, m)\n\tdefer s.Close()\n\n\tctx := context.Background()\n\tnow := time.Now()\n\n\t// Test case: empty sessionID\n\terr := s.UpdateSessionLastActivity(ctx, \"\", now)\n\tif err == nil {\n\t\tt.Error(\"UpdateSessionLastActivity(\\\"\\\") expected error\")\n\t}\n\n\t// Test case: non-existent session\n\terr = s.UpdateSessionLastActivity(ctx, \"non-existent\", now)\n\tif err == nil {\n\t\tt.Error(\"UpdateSessionLastActivity() non-existent expected error\")\n\t}\n\n\t// Store a sandbox first\n\tsandbox := createTestSandbox(\"test-session\", now.Add(time.Hour))\n\tif err := s.StoreSandbox(ctx, sandbox); err != nil {\n\t\tt.Fatalf(\"StoreSandbox() error = %v\", err)\n\t}\n\n\t// Get initial activity score\n\tinitialScore, err := m.ZScore(s.lastActivityIndexKey, \"test-session\")\n\tif err != nil {\n\t\tt.Fatalf(\"ZScore() error = %v\", err)\n\t}\n\n\t// Wait to ensure different Unix timestamp (ZAdd uses Unix() which is in seconds)\n\ttime.Sleep(1100 * time.Millisecond)\n\n\t// Update activity with zero time (should use Now)\n\tif err := s.UpdateSessionLastActivity(ctx, \"test-session\", time.Time{}); err != nil {\n\t\tt.Fatalf(\"UpdateSessionLastActivity() error = %v\", err)\n\t}\n\n\t// Verify activity was updated\n\tnewScore, err := m.ZScore(s.lastActivityIndexKey, \"test-session\")\n\tif err != nil {\n\t\tt.Fatalf(\"ZScore() error = %v\", err)\n\t}\n\tif newScore <= initialScore {\n\t\tt.Error(\"Activity timestamp was not updated\")\n\t}\n\n\t// Update activity with specific time\n\tfuture := now.Add(time.Hour)\n\tif err := s.UpdateSessionLastActivity(ctx, \"test-session\", future); err != nil {\n\t\tt.Fatalf(\"UpdateSessionLastActivity() error = %v\", err)\n\t}\n\n\t// Verify specific time was used\n\tscore, err := m.ZScore(s.lastActivityIndexKey, \"test-session\")\n\tif err != nil {\n\t\tt.Fatalf(\"ZScore() error = %v\", err)\n\t}\n\tif score != float64(future.Unix()) {\n\t\tt.Errorf(\"Activity timestamp = %v, want %v\", score, float64(future.Unix()))\n\t}\n}\n\nfunc TestRedisStore_Close(t *testing.T) {\n\tm := setupTestRedis(t)\n\tdefer m.Close()\n\n\ts := createTestRedisStore(t, m)\n\n\terr := s.Close()\n\tif err != nil {\n\t\tt.Errorf(\"Close() error = %v\", err)\n\t}\n}\n\nfunc TestRedisStore_LoadSandboxesBySessionIDs(t *testing.T) {\n\tm := setupTestRedis(t)\n\tdefer m.Close()\n\n\ts := createTestRedisStore(t, m)\n\tdefer s.Close()\n\n\tctx := context.Background()\n\n\t// Test case: empty sessionIDs\n\tresult, err := s.loadSandboxesBySessionIDs(ctx, []string{})\n\tif err != nil {\n\t\tt.Fatalf(\"loadSandboxesBySessionIDs() error = %v\", err)\n\t}\n\tif len(result) != 0 {\n\t\tt.Errorf(\"loadSandboxesBySessionIDs() returned %d sandboxes, want 0\", len(result))\n\t}\n\n\t// Store multiple sandboxes\n\tsandbox1 := createTestSandbox(\"session-1\", time.Now().Add(time.Hour))\n\tsandbox2 := createTestSandbox(\"session-2\", time.Now().Add(time.Hour))\n\n\tif err := s.StoreSandbox(ctx, sandbox1); err != nil {\n\t\tt.Fatalf(\"StoreSandbox() error = %v\", err)\n\t}\n\tif err := s.StoreSandbox(ctx, sandbox2); err != nil {\n\t\tt.Fatalf(\"StoreSandbox() error = %v\", err)\n\t}\n\n\t// Load by session IDs\n\tsessionIDs := []string{\"session-1\", \"session-2\", \"non-existent\"}\n\tsandboxes, err := s.loadSandboxesBySessionIDs(ctx, sessionIDs)\n\tif err != nil {\n\t\tt.Fatalf(\"loadSandboxesBySessionIDs() error = %v\", err)\n\t}\n\tif len(sandboxes) != 2 {\n\t\tt.Errorf(\"loadSandboxesBySessionIDs() returned %d sandboxes, want 2\", len(sandboxes))\n\t}\n}\n\nfunc TestRedisStore_LoadSandboxesWithOrphanedIndex(t *testing.T) {\n\tm := setupTestRedis(t)\n\tdefer m.Close()\n\n\ts := createTestRedisStore(t, m)\n\tdefer s.Close()\n\n\tctx := context.Background()\n\n\t// Store a sandbox\n\tsandbox := createTestSandbox(\"test-session\", time.Now().Add(time.Hour))\n\tif err := s.StoreSandbox(ctx, sandbox); err != nil {\n\t\tt.Fatalf(\"StoreSandbox() error = %v\", err)\n\t}\n\n\t// Delete the session data but keep the index (simulate orphaned index)\n\tm.Del(s.sessionKey(\"test-session\"))\n\n\t// List expired sandboxes should handle orphaned entries gracefully\n\texpired, err := s.ListExpiredSandboxes(ctx, time.Now().Add(time.Hour*2), 10)\n\tif err != nil {\n\t\tt.Fatalf(\"ListExpiredSandboxes() error = %v\", err)\n\t}\n\tif len(expired) != 0 {\n\t\tt.Errorf(\"ListExpiredSandboxes() returned %d sandboxes, want 0 (orphaned entries should be skipped)\", len(expired))\n\t}\n}\n\nfunc TestRedisStore_SessionKey(t *testing.T) {\n\ts := &redisStore{\n\t\tsessionPrefix: \"session:\",\n\t}\n\n\tkey := s.sessionKey(\"test-id\")\n\tif key != \"session:test-id\" {\n\t\tt.Errorf(\"sessionKey() = %v, want session:test-id\", key)\n\t}\n}\n\nfunc TestMakeRedisOptions(t *testing.T) {\n\t// Clean up environment after test\n\toriginalAddr := os.Getenv(\"REDIS_ADDR\")\n\toriginalPassword := os.Getenv(\"REDIS_PASSWORD\")\n\toriginalRequired := os.Getenv(\"REDIS_PASSWORD_REQUIRED\")\n\tdefer func() {\n\t\tos.Setenv(\"REDIS_ADDR\", originalAddr)\n\t\tos.Setenv(\"REDIS_PASSWORD\", originalPassword)\n\t\tos.Setenv(\"REDIS_PASSWORD_REQUIRED\", originalRequired)\n\t}()\n\n\t// Test case: missing REDIS_ADDR\n\tos.Unsetenv(\"REDIS_ADDR\")\n\tos.Setenv(\"REDIS_PASSWORD\", \"secret\")\n\t_, err := makeRedisOptions()\n\tif err == nil {\n\t\tt.Error(\"makeRedisOptions() without REDIS_ADDR expected error\")\n\t}\n\n\t// Test case: missing REDIS_PASSWORD when required\n\tos.Setenv(\"REDIS_ADDR\", \"localhost:6379\")\n\tos.Setenv(\"REDIS_PASSWORD\", \"\")\n\tos.Unsetenv(\"REDIS_PASSWORD_REQUIRED\")\n\t_, err = makeRedisOptions()\n\tif err == nil {\n\t\tt.Error(\"makeRedisOptions() without password when required expected error\")\n\t}\n\n\t// Test case: password not required\n\tos.Setenv(\"REDIS_ADDR\", \"localhost:6379\")\n\tos.Setenv(\"REDIS_PASSWORD\", \"\")\n\tos.Setenv(\"REDIS_PASSWORD_REQUIRED\", \"false\")\n\topts, err := makeRedisOptions()\n\tif err != nil {\n\t\tt.Fatalf(\"makeRedisOptions() error = %v\", err)\n\t}\n\tif opts.Addr != \"localhost:6379\" {\n\t\tt.Errorf(\"Addr = %v, want localhost:6379\", opts.Addr)\n\t}\n\tif opts.Password != \"\" {\n\t\tt.Errorf(\"Password = %v, want empty\", opts.Password)\n\t}\n\n\t// Test case: password required and provided\n\tos.Setenv(\"REDIS_ADDR\", \"redis:6379\")\n\tos.Setenv(\"REDIS_PASSWORD\", \"mysecret\")\n\tos.Setenv(\"REDIS_PASSWORD_REQUIRED\", \"true\")\n\topts, err = makeRedisOptions()\n\tif err != nil {\n\t\tt.Fatalf(\"makeRedisOptions() error = %v\", err)\n\t}\n\tif opts.Addr != \"redis:6379\" {\n\t\tt.Errorf(\"Addr = %v, want redis:6379\", opts.Addr)\n\t}\n\tif opts.Password != \"mysecret\" {\n\t\tt.Errorf(\"Password = %v, want mysecret\", opts.Password)\n\t}\n\n\t// Test case: whitespace trimming\n\tos.Setenv(\"REDIS_ADDR\", \"  localhost:6379  \")\n\tos.Setenv(\"REDIS_PASSWORD\", \"  secret  \")\n\topts, err = makeRedisOptions()\n\tif err != nil {\n\t\tt.Fatalf(\"makeRedisOptions() error = %v\", err)\n\t}\n\tif opts.Addr != \"localhost:6379\" {\n\t\tt.Errorf(\"Addr = %v, want localhost:6379 (trimmed)\", opts.Addr)\n\t}\n\tif opts.Password != \"  secret  \" {\n\t\tt.Errorf(\"Password = %v, want \\\"  secret  \\\" (not trimmed)\", opts.Password)\n\t}\n}\n\nfunc TestMakeRedisOptions_InvalidBool(t *testing.T) {\n\t// Clean up environment after test\n\toriginalAddr := os.Getenv(\"REDIS_ADDR\")\n\toriginalRequired := os.Getenv(\"REDIS_PASSWORD_REQUIRED\")\n\tdefer func() {\n\t\tos.Setenv(\"REDIS_ADDR\", originalAddr)\n\t\tos.Setenv(\"REDIS_PASSWORD_REQUIRED\", originalRequired)\n\t}()\n\n\tos.Setenv(\"REDIS_ADDR\", \"localhost:6379\")\n\tos.Setenv(\"REDIS_PASSWORD\", \"secret\")\n\tos.Setenv(\"REDIS_PASSWORD_REQUIRED\", \"invalid\")\n\n\t// Should use default (true) when parsing fails\n\t_, err := makeRedisOptions()\n\tif err != nil {\n\t\tt.Errorf(\"makeRedisOptions() with invalid bool should use default, got error: %v\", err)\n\t}\n}\n\nfunc TestNewRedisStore(t *testing.T) {\n\tm := setupTestRedis(t)\n\tdefer m.Close()\n\n\t// Clean up environment after test\n\toriginalAddr := os.Getenv(\"REDIS_ADDR\")\n\tdefer func() {\n\t\tos.Setenv(\"REDIS_ADDR\", originalAddr)\n\t}()\n\n\tos.Setenv(\"REDIS_ADDR\", m.Addr())\n\tos.Setenv(\"REDIS_PASSWORD\", \"\")\n\tos.Setenv(\"REDIS_PASSWORD_REQUIRED\", \"false\")\n\n\tstore, err := newRedisStore()\n\tif err != nil {\n\t\tt.Fatalf(\"newRedisStore() error = %v\", err)\n\t}\n\tif store == nil {\n\t\tt.Fatal(\"newRedisStore() returned nil\")\n\t}\n\tdefer store.Close()\n\n\t// Test that it implements Store interface\n\tvar _ Store = store\n}\n\nfunc TestNewRedisStore_MissingAddr(t *testing.T) {\n\t// Clean up environment\n\toriginalAddr := os.Getenv(\"REDIS_ADDR\")\n\tdefer func() {\n\t\tos.Setenv(\"REDIS_ADDR\", originalAddr)\n\t}()\n\n\tos.Unsetenv(\"REDIS_ADDR\")\n\n\t_, err := newRedisStore()\n\tif err == nil {\n\t\tt.Error(\"newRedisStore() without REDIS_ADDR expected error\")\n\t}\n}\n","additions":2,"deletions":2},"truncated":false},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-kimi-k2.5_20260410T163138Z/pkg/store/redis_test.go","time":{"start":1775868397361,"end":1775868397555}}}}
