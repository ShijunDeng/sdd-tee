with open('pkg/store/store_redis.go', 'w') as f:
    f.write('''package store

import (
	"context"
	"encoding/json"
	"errors"
	"fmt"
	"os"
	"strings"
	"time"

	"github.com/redis/go-redis/v9"
	"github.com/volcano-sh/agentcube/pkg/common/types"
)

type RedisStore struct {
	client *redis.Client
}

func NewRedisStore() (*RedisStore, error) {
	addr := os.Getenv("REDIS_ADDR")
	if addr == "" {
		return nil, errors.New("REDIS_ADDR is required")
	}

	password := os.Getenv("REDIS_PASSWORD")
	passwordReq := strings.ToLower(os.Getenv("REDIS_PASSWORD_REQUIRED"))
	if password == "" && passwordReq != "false" {
		return nil, errors.New("REDIS_PASSWORD is required unless REDIS_PASSWORD_REQUIRED=false")
	}

	client := redis.NewClient(&redis.Options{
		Addr:     addr,
		Password: password,
	})

	return &RedisStore{client: client}, nil
}

func (s *RedisStore) Ping(ctx context.Context) error {
	res, err := s.client.Ping(ctx).Result()
	if err != nil {
		return err
	}
	if res != "PONG" {
		return fmt.Errorf("expected PONG, got %s", res)
	}
	return nil
}

func (s *RedisStore) GetSandboxBySessionID(ctx context.Context, sessionID string) (*types.SandboxInfo, error) {
	key := "session:" + sessionID
	val, err := s.client.Get(ctx, key).Result()
	if err != nil {
		if errors.Is(err, redis.Nil) {
			return nil, ErrNotFound
		}
		return nil, err
	}

	var info types.SandboxInfo
	if err := json.Unmarshal([]byte(val), &info); err != nil {
		return nil, err
	}
	return &info, nil
}

func (s *RedisStore) StoreSandbox(ctx context.Context, sandbox *types.SandboxInfo) error {
	if sandbox == nil {
		return errors.New("sandbox cannot be nil")
	}
	if sandbox.ExpiresAt.IsZero() {
		return errors.New("sandbox ExpiresAt must be set")
	}

	key := "session:" + sandbox.SessionID
	data, err := json.Marshal(sandbox)
	if err != nil {
		return err
	}

	pipe := s.client.TxPipeline()
	setnx := pipe.SetNX(ctx, key, data, 0)
	pipe.ZAdd(ctx, "session:expiry", redis.Z{Score: float64(sandbox.ExpiresAt.Unix()), Member: sandbox.SessionID})
	pipe.ZAdd(ctx, "session:last_activity", redis.Z{Score: float64(time.Now().Unix()), Member: sandbox.SessionID})

	_, err = pipe.Exec(ctx)
	if err != nil {
		return err
	}
	if !setnx.Val() {
		return errors.New("session already exists")
	}
	return nil
}

func (s *RedisStore) UpdateSandbox(ctx context.Context, sandbox *types.SandboxInfo) error {
	if sandbox == nil {
		return errors.New("sandbox cannot be nil")
	}

	key := "session:" + sandbox.SessionID
	data, err := json.Marshal(sandbox)
	if err != nil {
		return err
	}

	res, err := s.client.SetXX(ctx, key, data, 0).Result()
	if err != nil {
		return err
	}
	if !res {
		return errors.New("key not exists")
	}
	return nil
}

func (s *RedisStore) DeleteSandboxBySessionID(ctx context.Context, sessionID string) error {
	key := "session:" + sessionID

	pipe := s.client.TxPipeline()
	pipe.Del(ctx, key)
	pipe.ZRem(ctx, "session:expiry", sessionID)
	pipe.ZRem(ctx, "session:last_activity", sessionID)

	_, err := pipe.Exec(ctx)
	return err
}

func (s *RedisStore) listSandboxesByZSet(ctx context.Context, zset string, before time.Time, limit int64) ([]*types.SandboxInfo, error) {
	opt := &redis.ZRangeBy{
		Min:    "-inf",
		Max:    fmt.Sprintf("%d", before.Unix()),
		Offset: 0,
		Count:  limit,
	}

	members, err := s.client.ZRangeByScore(ctx, zset, opt).Result()
	if err != nil {
		return nil, err
	}

	if len(members) == 0 {
		return nil, nil
	}

	pipe := s.client.Pipeline()
	cmds := make(map[string]*redis.StringCmd)
	for _, member := range members {
		key := "session:" + member
		cmds[member] = pipe.Get(ctx, key)
	}

	_, err = pipe.Exec(ctx)
	if err != nil && !errors.Is(err, redis.Nil) {
		return nil, err
	}

	var results []*types.SandboxInfo
	for _, member := range members {
		cmd := cmds[member]
		val, err := cmd.Result()
		if err != nil {
			continue // skip missing keys as required
		}
		var info types.SandboxInfo
		if err := json.Unmarshal([]byte(val), &info); err == nil {
			results = append(results, &info)
		}
	}

	return results, nil
}

func (s *RedisStore) ListExpiredSandboxes(ctx context.Context, before time.Time, limit int64) ([]*types.SandboxInfo, error) {
	return s.listSandboxesByZSet(ctx, "session:expiry", before, limit)
}

func (s *RedisStore) ListInactiveSandboxes(ctx context.Context, before time.Time, limit int64) ([]*types.SandboxInfo, error) {
	return s.listSandboxesByZSet(ctx, "session:last_activity", before, limit)
}

func (s *RedisStore) UpdateSessionLastActivity(ctx context.Context, sessionID string, at time.Time) error {
	if sessionID == "" {
		return errors.New("empty session id")
	}
	if at.IsZero() {
		at = time.Now()
	}

	key := "session:" + sessionID
	exists, err := s.client.Exists(ctx, key).Result()
	if err != nil {
		return err
	}
	if exists == 0 {
		return ErrNotFound
	}

	return s.client.ZAdd(ctx, "session:last_activity", redis.Z{Score: float64(at.Unix()), Member: sessionID}).Err()
}

func (s *RedisStore) Close() error {
	return s.client.Close()
}
''')

with open('pkg/store/store_valkey.go', 'w') as f:
    f.write('''package store

import (
	"context"
	"encoding/json"
	"errors"
	"fmt"
	"os"
	"strings"
	"time"

	"github.com/valkey-io/valkey-go"
	"github.com/volcano-sh/agentcube/pkg/common/types"
)

type ValkeyStore struct {
	client valkey.Client
}

func NewValkeyStore() (*ValkeyStore, error) {
	addr := os.Getenv("VALKEY_ADDR")
	if addr == "" {
		return nil, errors.New("VALKEY_ADDR is required")
	}

	password := os.Getenv("VALKEY_PASSWORD")
	passwordReq := strings.ToLower(os.Getenv("VALKEY_PASSWORD_REQUIRED"))
	if password == "" && passwordReq != "false" {
		return nil, errors.New("VALKEY_PASSWORD is required unless VALKEY_PASSWORD_REQUIRED=false")
	}

	opts := valkey.ClientOption{
		InitAddress: strings.Split(addr, ","),
		Password:    password,
	}

	if strings.ToLower(os.Getenv("VALKEY_DISABLE_CACHE")) == "true" {
		opts.DisableCache = true
	}
	if strings.ToLower(os.Getenv("VALKEY_FORCE_SINGLE")) == "true" {
		opts.ForceSingleClient = true
	}

	client, err := valkey.NewClient(opts)
	if err != nil {
		return nil, err
	}

	return &ValkeyStore{client: client}, nil
}

func (s *ValkeyStore) Ping(ctx context.Context) error {
	res, err := s.client.Do(ctx, s.client.B().Ping().Build()).ToString()
	if err != nil {
		return err
	}
	if res != "PONG" {
		return fmt.Errorf("expected PONG, got %s", res)
	}
	return nil
}

func (s *ValkeyStore) GetSandboxBySessionID(ctx context.Context, sessionID string) (*types.SandboxInfo, error) {
	key := "session:" + sessionID
	val, err := s.client.Do(ctx, s.client.B().Get().Key(key).Build()).ToString()
	if err != nil {
		if valkey.IsValkeyNil(err) {
			return nil, ErrNotFound
		}
		return nil, err
	}

	var info types.SandboxInfo
	if err := json.Unmarshal([]byte(val), &info); err != nil {
		return nil, err
	}
	return &info, nil
}

func (s *ValkeyStore) StoreSandbox(ctx context.Context, sandbox *types.SandboxInfo) error {
	if sandbox == nil {
		return errors.New("sandbox cannot be nil")
	}
	if sandbox.ExpiresAt.IsZero() {
		return errors.New("sandbox ExpiresAt must be set")
	}

	key := "session:" + sandbox.SessionID
	data, err := json.Marshal(sandbox)
	if err != nil {
		return err
	}

	setnxCmd := s.client.B().Set().Key(key).Value(string(data)).Nx().Build()
	zaddExpiryCmd := s.client.B().Zadd().Key("session:expiry").ScoreMember().ScoreMember(float64(sandbox.ExpiresAt.Unix()), sandbox.SessionID).Build()
	zaddLastActivityCmd := s.client.B().Zadd().Key("session:last_activity").ScoreMember().ScoreMember(float64(time.Now().Unix()), sandbox.SessionID).Build()

	res := s.client.DoMulti(ctx, setnxCmd, zaddExpiryCmd, zaddLastActivityCmd)
	for _, r := range res {
		if r.Error() != nil {
			return r.Error()
		}
	}
	
	if val, _ := res[0].ToString(); val == "" {
		return errors.New("session already exists")
	}

	return nil
}

func (s *ValkeyStore) UpdateSandbox(ctx context.Context, sandbox *types.SandboxInfo) error {
	if sandbox == nil {
		return errors.New("sandbox cannot be nil")
	}

	key := "session:" + sandbox.SessionID
	data, err := json.Marshal(sandbox)
	if err != nil {
		return err
	}

	cmd := s.client.B().Set().Key(key).Value(string(data)).Xx().Build()
	res, err := s.client.Do(ctx, cmd).ToString()
	if err != nil {
		return err
	}
	if res != "OK" {
		return errors.New("key not exists")
	}
	return nil
}

func (s *ValkeyStore) DeleteSandboxBySessionID(ctx context.Context, sessionID string) error {
	key := "session:" + sessionID

	delCmd := s.client.B().Del().Key(key).Build()
	zremExpiryCmd := s.client.B().Zrem().Key("session:expiry").Member(sessionID).Build()
	zremLastActivityCmd := s.client.B().Zrem().Key("session:last_activity").Member(sessionID).Build()

	res := s.client.DoMulti(ctx, delCmd, zremExpiryCmd, zremLastActivityCmd)
	for _, r := range res {
		if r.Error() != nil {
			return r.Error()
		}
	}
	return nil
}

func (s *ValkeyStore) listSandboxesByZSet(ctx context.Context, zset string, before time.Time, limit int64) ([]*types.SandboxInfo, error) {
	cmd := s.client.B().Zrangebyscore().Key(zset).Min("-inf").Max(fmt.Sprintf("%d", before.Unix())).Limit(0, limit).Build()
	members, err := s.client.Do(ctx, cmd).AsStrSlice()
	if err != nil {
		if valkey.IsValkeyNil(err) {
			return nil, nil
		}
		return nil, err
	}

	if len(members) == 0 {
		return nil, nil
	}

	var keys []string
	for _, m := range members {
		keys = append(keys, "session:"+m)
	}

	mgetCmd := s.client.B().Mget().Key(keys...).Build()
	vals, err := s.client.Do(ctx, mgetCmd).AsStrSlice()
	if err != nil && !valkey.IsValkeyNil(err) {
		return nil, err
	}

	var results []*types.SandboxInfo
	for _, val := range vals {
		if val == "" {
			continue // skip missing keys
		}
		var info types.SandboxInfo
		if err := json.Unmarshal([]byte(val), &info); err == nil {
			results = append(results, &info)
		}
	}

	return results, nil
}

func (s *ValkeyStore) ListExpiredSandboxes(ctx context.Context, before time.Time, limit int64) ([]*types.SandboxInfo, error) {
	return s.listSandboxesByZSet(ctx, "session:expiry", before, limit)
}

func (s *ValkeyStore) ListInactiveSandboxes(ctx context.Context, before time.Time, limit int64) ([]*types.SandboxInfo, error) {
	return s.listSandboxesByZSet(ctx, "session:last_activity", before, limit)
}

func (s *ValkeyStore) UpdateSessionLastActivity(ctx context.Context, sessionID string, at time.Time) error {
	if sessionID == "" {
		return errors.New("empty session id")
	}
	if at.IsZero() {
		at = time.Now()
	}

	key := "session:" + sessionID
	existsCmd := s.client.B().Exists().Key(key).Build()
	exists, err := s.client.Do(ctx, existsCmd).AsInt64()
	if err != nil {
		return err
	}
	if exists == 0 {
		return ErrNotFound
	}

	zaddCmd := s.client.B().Zadd().Key("session:last_activity").ScoreMember().ScoreMember(float64(at.Unix()), sessionID).Build()
	return s.client.Do(ctx, zaddCmd).Error()
}

func (s *ValkeyStore) Close() error {
	s.client.Close()
	return nil
}
