				c.Set(string(contextKeyServiceAccountName), info.saName)
			} else {
				if s.kubeClient == nil {
					c.JSON(http.StatusUnauthorized, ErrorResponse{Message: "kubeClient not configured"})
					c.Abort()
					return
				}
				tr := &authv1.TokenReview{
					Spec: authv1.TokenReviewSpec{
						Token: token,
					},
				}
				result, err := s.kubeClient.AuthenticationV1().TokenReviews().Create(c.Request.Context(), tr, metav1.CreateOptions{})
				if err != nil || !result.Status.Authenticated {
					c.JSON(http.StatusUnauthorized, ErrorResponse{Message: "client extraction error"})
					c.Abort()
					return
				}
				
				username := result.Status.User.Username
				partsSA := strings.Split(username, ":")
				var ns, saName string
				if len(partsSA) >= 4 && partsSA[0] == "system" && partsSA[1] == "serviceaccount" {
					ns = partsSA[2]
					saName = partsSA[3]
				}

				authMutex.Lock()
				// LRU logic - if capacity > 1000, remove random (simplified LRU)
				if len(authCache) >= 1000 {
					for k := range authCache {
						delete(authCache, k)
						break
					}
				}
				authCache[token] = &authInfo{
					username:  username,
					namespace: ns,
					saName:    saName,
					expiresAt: time.Now().Add(5 * time.Minute),
				}
				authMutex.Unlock()

				c.Set(string(contextKeyUserToken), token)
				c.Set(string(contextKeyServiceAccount), username)
				if ns != "" {
					c.Set(string(contextKeyNamespace), ns)
					c.Set(string(contextKeyServiceAccountName), saName)
				}
			}
		}
		c.Next()
	}
}

type K8sClient struct{}

var (
	userClients = make(map[string]dynamic.Interface)
	clientMutex sync.RWMutex
)

// AR-014
func GetOrCreateUserK8sClient(namespace, serviceAccountName string, cfg *rest.Config, token string) (dynamic.Interface, error) {
	key := namespace + ":" + serviceAccountName
	clientMutex.RLock()
	client, exists := userClients[key]
	clientMutex.RUnlock()
	if exists {
		return client, nil
	}

	clientMutex.Lock()
	defer clientMutex.Unlock()
	
	if client, exists = userClients[key]; exists {
		return client, nil
	}

	if cfg == nil {
		return nil, errors.New("rest config is nil")
	}

	userConfig := *cfg
	userConfig.BearerToken = token
	userConfig.BearerTokenFile = ""

	dynClient, err := dynamic.NewForConfig(&userConfig)
	if err != nil {
		return nil, err
	}
	
	userClients[key] = dynClient
	return dynClient, nil
}

type garbageCollector struct {
	k8sClient   *K8sClient
	interval    time.Duration
	storeClient store.Store
}

func newGarbageCollector(k8s *K8sClient, storeClient store.Store, interval time.Duration) *garbageCollector {
	return &garbageCollector{
		k8sClient:   k8s,
		storeClient: storeClient,
		interval:    interval,
	}
}

func (gc *garbageCollector) run(ctx context.Context) {
	ticker := time.NewTicker(gc.interval)
	defer ticker.Stop()
	for {
		select {
		case <-ctx.Done():
			return
		case <-ticker.C:
			gc.tick()
		}
	}
}

func (gc *garbageCollector) tick() {
	ctx, cancel := context.WithTimeout(context.Background(), gcOnceTimeout)
	defer cancel()

	inactiveTime := time.Now().Add(-DefaultSandboxIdleTimeout)
	if gc.storeClient != nil {
		inactive, _ := gc.storeClient.ListInactiveSandboxes(ctx, inactiveTime, 16)
		expired, _ := gc.storeClient.ListExpiredSandboxes(ctx, time.Now(), 16)

		// Merge and unique
		toDelete := make(map[string]*store.SandboxInfo)
		for _, sb := range inactive {
			toDelete[sb.SessionID] = sb
		}
		for _, sb := range expired {
			toDelete[sb.SessionID] = sb
		}

		for sessionID, _ := range toDelete {
			// Mock deleting sandbox claim or sandbox
			// Then remove from store
			_ = gc.storeClient.DeleteSandboxBySessionID(ctx, sessionID)
		}
	}
}
