	}))
	defer backend.Close()

	dStore := &dummyStore{updateErr: errors.New("store down")}
	sm := &SessionManager{
		Store: dStore,
	}

	req := httptest.NewRequest("GET", "/", nil)
	rr := httptest.NewRecorder()

	sandbox := &types.SandboxInfo{
		EntryPoints: []types.SandboxEntryPoint{
			{Endpoint: backend.URL},
		},
	}

	sm.ForwardToSandbox(rr, req, sandbox, "/")

	if rr.Code != http.StatusOK {
		t.Errorf("expected proxy to succeed despite store error, got %v", rr.Code)
	}
}
