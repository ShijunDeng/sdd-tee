// AR-038, AR-039, AR-040, AR-041, AR-042: Full proxy scenarios
func TestForwardToSandbox_Proxy(t *testing.T) {
	var receivedToken string
	var receivedPath string
	var receivedHost string
	var receivedProto string

	backend := httptest.NewServer(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
		receivedToken = r.Header.Get("Authorization")
		receivedPath = r.URL.Path
		receivedHost = r.Header.Get("X-Forwarded-Host")
		receivedProto = r.Header.Get("X-Forwarded-Proto")
		w.WriteHeader(http.StatusOK)
		w.Write([]byte("ok"))
	}))
	defer backend.Close()

	dStore := &dummyStore{}
	sm := &SessionManager{
		Store: dStore,
		JWTManager: &JWTManager{
			GenerateJWTFunc: func(namespace, name string) (string, error) {
				return "generated-token", nil
			},
		},
	}

	req := httptest.NewRequest("GET", "http://example.com/invoke", nil)
	rr := httptest.NewRecorder()

	sandbox := &types.SandboxInfo{
		Kind:      types.SandboxKind,
		SessionID: "sess-123",
		EntryPoints: []types.SandboxEntryPoint{
			{Protocol: "http", Endpoint: strings.TrimPrefix(backend.URL, "http://"), Path: "/"},
		},
	}

	sm.ForwardToSandbox(rr, req, sandbox, "invoke")

	if rr.Code != http.StatusOK {
		t.Errorf("expected 200, got %v", rr.Code)
	}
	if rr.Header().Get("x-agentcube-session-id") != "sess-123" {
		t.Errorf("expected response header x-agentcube-session-id")
	}
	if receivedToken != "Bearer generated-token" {
		t.Errorf("expected JWT token, got %v", receivedToken)
	}
	if receivedPath != "/invoke" {
		t.Errorf("expected path /invoke, got %v", receivedPath)
	}
	if receivedHost != "example.com" {
		t.Errorf("expected X-Forwarded-Host example.com, got %v", receivedHost)
	}
	if receivedProto != "http" {
		t.Errorf("expected X-Forwarded-Proto http, got %v", receivedProto)
	}

	// AR-042: Last-activity update 1 and 2
	if dStore.updateCount.Load() != 2 {
		t.Errorf("expected 2 updates, got %d", dStore.updateCount.Load())
	}
}

