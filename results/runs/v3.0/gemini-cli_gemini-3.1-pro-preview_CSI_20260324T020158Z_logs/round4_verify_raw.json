// AR-041: Proxy error mapping
func TestForwardToSandbox_ProxyErrors(t *testing.T) {
	sm := &SessionManager{
		Store: &dummyStore{},
	}

	req := httptest.NewRequest("GET", "/", nil)
	rr := httptest.NewRecorder()

	sandbox := &types.SandboxInfo{
		EntryPoints: []types.SandboxEntryPoint{
			{Endpoint: "http://127.0.0.1:0"}, // Will cause connection refused
		},
	}

	sm.ForwardToSandbox(rr, req, sandbox, "/")

