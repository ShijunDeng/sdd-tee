// AR-035 & AR-037: Missing session triggers create, successful and failed scenarios
func TestGetSandboxBySession_Create(t *testing.T) {
	tests := []struct {
		name         string
		wmStatus     int
		wmResponse   any
		expectErr    string
		expectStatus int
	}{
		{
			name:     "Success",
			wmStatus: http.StatusOK,
			wmResponse: types.CreateSandboxResponse{
				SessionID: "new-session",
				SandboxID: "sbx-123",
			},
			expectErr: "",
		},
		{
			name:       "Non-OK 404",
			wmStatus:   http.StatusNotFound,
			wmResponse: "not found",
			expectErr:  "not found", // Will be mapped to SandboxTemplateNotFoundError
		},
		{
			name:     "Empty session ID",
			wmStatus: http.StatusOK,
			wmResponse: types.CreateSandboxResponse{
				SessionID: "",
			},
			expectErr: "sessionId is empty in workload manager response",
		},
	}

	for _, tc := range tests {
		t.Run(tc.name, func(t *testing.T) {
			wmServer := httptest.NewServer(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
				w.WriteHeader(tc.wmStatus)
				json.NewEncoder(w).Encode(tc.wmResponse)
			}))
			defer wmServer.Close()

			os.Setenv("WORKLOAD_MANAGER_URL", wmServer.URL)
			sm, _ := NewSessionManager(&dummyStore{}, nil)

			sbx, err := sm.GetSandboxBySession(context.Background(), types.AgentRuntimeKind, "default", "test", "")
			if tc.expectErr != "" {
				if err == nil {
					t.Fatalf("expected error containing %q, got nil", tc.expectErr)
				}
				if tc.wmStatus == http.StatusNotFound && !strings.Contains(err.Error(), "not found") {
					t.Errorf("expected not found error, got %v", err)
				}
			} else {
				if err != nil {
					t.Fatalf("unexpected error: %v", err)
				}
				if sbx.SessionID != "new-session" {
					t.Errorf("expected session ID new-session, got %v", sbx.SessionID)
				}
			}
		})
	}
}

