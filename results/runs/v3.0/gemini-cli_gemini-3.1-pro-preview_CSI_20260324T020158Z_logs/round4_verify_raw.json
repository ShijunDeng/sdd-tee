func (d *dummyStore) GetSandboxBySessionID(ctx context.Context, sessionID string) (*types.SandboxInfo, error) {
	if sessionID == "unknown" {
		return nil, store.ErrNotFound
	}
	return &types.SandboxInfo{SessionID: sessionID}, nil
}

func (d *dummyStore) UpdateSessionLastActivity(ctx context.Context, sessionID string, at time.Time) error {
	d.updateCount.Add(1)
	return d.updateErr
}

