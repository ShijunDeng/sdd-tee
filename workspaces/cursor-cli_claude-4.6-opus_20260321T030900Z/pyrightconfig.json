{
  "include": ["sdk-python"],
  "exclude": [
    "**/__pycache__",
    "**/.venv",
    "**/node_modules",
    "**/*.egg-info"
  ],
  "venvPath": "sdk-python",
  "venv": ".venv",
  "pythonVersion": "3.11",
  "typeCheckingMode": "standard",
  "reportMissingImports": true,
  "reportUnusedImport": true,
  "executionEnvironments": [
    {
      "root": "sdk-python",
      "extraPaths": ["sdk-python"]
    }
  ]
}
